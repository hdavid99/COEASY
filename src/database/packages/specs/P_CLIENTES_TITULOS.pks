      (P_FECHA IN DATE);
      
   PROCEDURE VALORAR_COMPROMISOS (QFECHA DATE);
  
   PROCEDURE GENERAR_VALORACION_COMPROMISOS (QFECHA DATE, P_CONSECUTIVO NUMBER);
      
   PROCEDURE BORRAR_DIFERENTE_FIN_MES_COMP
