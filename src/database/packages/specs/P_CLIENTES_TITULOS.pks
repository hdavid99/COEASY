  CREATE OR REPLACE EDITIONABLE PACKAGE "PROD"."P_CLIENTES_TITULOS" IS

   TYPE O_CURSOR IS REF CURSOR;
   
   PROCEDURE GENERAR_SALDOS_DIA;

   PROCEDURE CREAR_SALDOS_DIA;
   
   PROCEDURE BORRAR_DIFERENTE_FIN_MES
      (P_FECHA IN  DATE);
      
