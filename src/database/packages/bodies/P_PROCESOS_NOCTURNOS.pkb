    COLUMNAS NUMBER;

    CURSOR C_NOMBRE IS
      SELECT PER_NUM_IDEN IDEN, PER_TID_CODIGO TID
        FROM PERSONAS
       WHERE PER_TIPO = 'PJU'
         AND PER_TID_CODIGO != 'SSN'
         AND EXISTS
       (SELECT 'X'
                FROM CLIENTES
               WHERE CLI_PER_NUM_IDEN = PER_NUM_IDEN
                 AND CLI_PER_TID_CODIGO = PER_TID_CODIGO);
    V_NOMBRE C_NOMBRE%ROWTYPE;

    CURSOR C_CONTRAPARTE(IDEN VARCHAR2) IS
      SELECT (LCCT_LIMITE_CONTRA_95_COP * 1000000)
        FROM LIMITES_CONSUMO_CONTRAPARTES
       WHERE LCCT_NIT_CONTRAPARTE = IDEN
         AND LCCT_MONEDA = 'COP'
         AND LCCT_FECHA = (SELECT MAX(LCCT_FECHA)
                             FROM LIMITES_CONSUMO_CONTRAPARTES
                            WHERE LCCT_NIT_CONTRAPARTE = IDEN);
    V_CONTRAPARTE NUMBER;

