  -------------------------------------FIN CREACION DE SALDOS DEL PORTAL------------------------------------

  ------------GENERACION INFORMACION PRECIA-------------
  PROCEDURE P_PROCESO_PRECIA(P_FECHA DATE) IS
    CURSOR C_CIERRE IS
      SELECT DISTINCT (PCR.PCRC_FON_CODIGO) NIT,
                      PCR.PCRC_PMRC_ID_REPORTE,
                      SUBSTR(PCR.PCRC_FON_CODIGO, 1, 9) NIT_FONDO,
                      SUBSTR(PCR.PCRC_FON_CODIGO, 11, 11) CLASE,
                      --F.FON_RAZON_SOCIAL,
                      PCR.PCRC_COD_DECEVAL_VAL,
                      PCR.PCRC_COD_BVC_VAL
        FROM PARAM_CMPS_REPCRRFON PCR --, FONDOS F
       WHERE PCR.PCRC_PMRC_ID_REPORTE = 7
      --AND PCR.PCRC_FON_CODIGO LIKE '800154697%'
      --AND F.FON_CODIGO LIKE PCR.PCRC_FON_CODIGO || '%'
      ;
    P_CIERRE C_CIERRE%ROWTYPE;

    CURSOR C_FONDOS(FONDO varchar2) IS
      SELECT FON_CODIGO, FON_RAZON_SOCIAL FONDO
        FROM FONDOS
       WHERE FON_CODIGO = FONDO;
    P_FONDOS C_FONDOS%ROWTYPE;

    CURSOR C_VALORIZACION(FONDO VARCHAR2, FECHAINI DATE, FECHAFIN DATE) IS
      SELECT VF.VFO_FECHA_VALORIZACION FECHA_VALOR,
             round(VF.VFO_VALOR, 6) VALOR_UNIDAD,
             (VF.VFO_CAPITAL + VF.VFO_REND_RF + VF.VFO_REND_RV) VALOR_FONDO
        FROM VALORIZACIONES_FONDO VF
       WHERE VF.VFO_FON_CODIGO = FONDO
         AND (VF.VFO_CAPITAL + VF.VFO_REND_RF + VF.VFO_REND_RV) > 0
         AND VF.VFO_FECHA_VALORIZACION >= FECHAINI
         AND VF.VFO_FECHA_VALORIZACION < FECHAFIN;
    P_VALORIZACION C_VALORIZACION%ROWTYPE;

    TIP_ARCHIVO    UTL_FILE.FILE_TYPE;
    ARCHIVO_FONDO  VARCHAR2(100);
    LINEA          VARCHAR2(5000);
    FONDO          VARCHAR2(10);
    FECHA          DATE;
    V_FECHA_VALOR  DATE;
    V_VALOR_UNIDAD NUMBER(15, 6);
    V_VALOR_FONDO  NUMBER(20, 2);

    FECHA_FIN  DATE;
    FECHA_BASE DATE;
    FECHA_INI  DATE;

    HABIL   VARCHAR2(1);
    HABIL_1 VARCHAR2(1);
  BEGIN
    FECHA_BASE := TRUNC(P_FECHA);
    --FECHA_BASE := TO_DATE('01-JUN-2020', 'DD-MON-YYYY');
    FECHA_FIN := FECHA_BASE;
    DBMS_OUTPUT.PUT_LINE(FECHA_FIN);
    HABIL_1 := NULL;
    HABIL_1 := P_TOOLS.FN_ES_DIA_HABIL(FECHA_FIN);
    DBMS_OUTPUT.PUT_LINE(HABIL_1);
    IF HABIL_1 = 'S' THEN
      FECHA_INI := TRUNC(FECHA_BASE - 1);
      DBMS_OUTPUT.PUT_LINE(FECHA_INI);
      HABIL := NULL;
      HABIL := P_TOOLS.FN_ES_DIA_HABIL(FECHA_INI);
      DBMS_OUTPUT.PUT_LINE(HABIL);
      IF HABIL = 'N' THEN
        IF TO_CHAR(FECHA_INI, 'D') = '1' THEN
          DBMS_OUTPUT.PUT_LINE('DOMINGO');
          FECHA_INI := FECHA_INI - 2;
          DBMS_OUTPUT.PUT_LINE(FECHA_INI);
          HABIL := NULL;
          HABIL := P_TOOLS.FN_ES_DIA_HABIL(FECHA_INI);
          DBMS_OUTPUT.PUT_LINE(HABIL);
          IF HABIL = 'N' THEN
            FECHA_INI := FECHA_INI - 1;
            DBMS_OUTPUT.PUT_LINE(FECHA_INI);
            HABIL := NULL;
            HABIL := P_TOOLS.FN_ES_DIA_HABIL(FECHA_INI);
            DBMS_OUTPUT.PUT_LINE(HABIL);
            IF HABIL = 'N' THEN
              DBMS_OUTPUT.PUT_LINE('SEMANA SANTA');
              FECHA_INI := FECHA_INI - 1;
              DBMS_OUTPUT.PUT_LINE(FECHA_INI);
              HABIL := NULL;
              HABIL := P_TOOLS.FN_ES_DIA_HABIL(FECHA_INI);
              DBMS_OUTPUT.PUT_LINE(HABIL);
            END IF;
          END IF;
        ELSIF TO_CHAR(FECHA_INI, 'D') = '2' THEN
          DBMS_OUTPUT.PUT_LINE('LUNES');
          FECHA_INI := FECHA_INI - 3;
          DBMS_OUTPUT.PUT_LINE(FECHA_INI);
          HABIL := NULL;
          HABIL := P_TOOLS.FN_ES_DIA_HABIL(FECHA_INI);
          DBMS_OUTPUT.PUT_LINE(HABIL);
        ELSE
          DBMS_OUTPUT.PUT_LINE('OTRO DIA');
          FECHA_INI := FECHA_INI - 1;
          DBMS_OUTPUT.PUT_LINE(FECHA_INI);
          HABIL := NULL;
          HABIL := P_TOOLS.FN_ES_DIA_HABIL(FECHA_INI);
          DBMS_OUTPUT.PUT_LINE(HABIL);
          IF HABIL = 'N' THEN
            FECHA_INI := FECHA_INI - 1;
            DBMS_OUTPUT.PUT_LINE(FECHA_INI);
            HABIL := NULL;
            HABIL := P_TOOLS.FN_ES_DIA_HABIL(FECHA_INI);
            DBMS_OUTPUT.PUT_LINE(HABIL);
          END IF;
        END IF;
      END IF;
      FECHA := FECHA_BASE - 1;

      --DBMS_OUTPUT.put_line('EL FONDO ES ' || P_FONDOS.FONDO);
      ARCHIVO_FONDO := '860079174' || '_' ||
                       TO_CHAR(FECHA_BASE, 'YYYYMMDD') || '.csv';
      DBMS_OUTPUT.put_line(ARCHIVO_FONDO);
      TIP_ARCHIVO := UTL_FILE.FOPEN('PRECIA', ARCHIVO_FONDO, 'W', 10000);

      FOR P_CIERRE IN C_CIERRE LOOP
        V_VALOR_UNIDAD := 0;
        V_VALOR_FONDO  := 0;
        OPEN C_FONDOS(P_CIERRE.NIT);
        FETCH C_FONDOS
          INTO P_FONDOS;
        CLOSE C_FONDOS;

        --DBMS_OUTPUT.put_line('FECHAS '||FECHA_INI||' '|| FECHA_FIN);
        --DBMS_OUTPUT.put_line('FONDO '||' '|| P_CIERRE.NIT);
        FOR P_VALORIZACION IN C_VALORIZACION(P_CIERRE.NIT,
                                             FECHA_INI,
                                             FECHA_FIN) LOOP

          /*DBMS_OUTPUT.put_line(P_VALORIZACION.FECHA_VALOR || ' ' ||
          P_CIERRE.NIT_FONDO || ' ' || P_CIERRE.CLASE || ' ' ||
          P_VALORIZACION.VALOR_UNIDAD || ' ' ||
          P_VALORIZACION.VALOR_FONDO || ' ' ||
          P_FONDOS.FONDO || ' ' ||
          P_CIERRE.PCRC_COD_DECEVAL_VAL
          || ' ' ||
          P_CIERRE.PCRC_COD_BVC_VAL
          );*/

          LINEA := TO_CHAR(P_VALORIZACION.FECHA_VALOR, 'YYYY-MM-DD') || ',' ||
                   P_CIERRE.NIT_FONDO || ',' || P_CIERRE.CLASE || ',' ||
                   P_VALORIZACION.VALOR_UNIDAD || ',' ||
                   P_VALORIZACION.VALOR_FONDO || ',' || P_FONDOS.FONDO || ',' ||
                   P_CIERRE.PCRC_COD_BVC_VAL || ',' ||
                   P_CIERRE.PCRC_COD_DECEVAL_VAL;
          UTL_FILE.PUT_LINE(TIP_ARCHIVO, LINEA);

        END LOOP;
      END LOOP;
      UTL_FILE.FCLOSE(TIP_ARCHIVO);
    END IF;
  END P_PROCESO_PRECIA;

  ------------FIN INFORMACION PRECIA-------------
  -- WILLIAM CAMPOS 11/09/2020
  PROCEDURE P_LIMPIA_HISTORICO_SALDOS IS
  BEGIN

    DELETE HIS_SALDOS_CLIENTE_CANAL where HSCC_FECHA > trunc(sysdate - 60);

  END P_LIMPIA_HISTORICO_SALDOS;

  ----- PROCESO PARA BLOQUEAR A USUARIOS PREVIAMENTE ACTIVADOS DESDE EL AREA DE SARLAFT
  PROCEDURE PR_BLOQUEO_USUARIO_NOCTURNO IS

    CURSOR C_BLOQUEO_NOCTURNO IS
      SELECT CLI_MOI_ANTERIOR,
             CLI_ECL_ANTERIOR,
             CLI_PER_NUM_IDEN,
             CLI_PER_TID_CODIGO
        FROM CLIENTES
       WHERE CLI_BLOQUEO_NOCTURNO = 'S'
         AND CLI_ECL_ANTERIOR IS NOT NULL
         AND CLI_MOI_ANTERIOR IS NOT NULL
         AND CLI_ECL_MNEMONICO = 'ACC';
    P_BLOQUEO C_BLOQUEO_NOCTURNO%ROWTYPE;
  BEGIN
    FOR P_BLOQUEO IN C_BLOQUEO_NOCTURNO LOOP
      DBMS_OUTPUT.put_line('EL SUJETO ES ' || P_BLOQUEO.CLI_PER_NUM_IDEN || ' ' ||
                           P_BLOQUEO.CLI_PER_TID_CODIGO);
      UPDATE CLIENTES
         SET CLI_ECL_MNEMONICO             = P_BLOQUEO.CLI_ECL_ANTERIOR,
             CLI_MOI_MNEMONICO             = P_BLOQUEO.CLI_MOI_ANTERIOR,
             CLI_ECL_ANTERIOR              = '',
             CLI_MOI_ANTERIOR              = '',
             CLI_FECHA_ULTIMA_MODIFICACION = SYSDATE,
             CLI_USUARIO_ULTIMA_MODIFICA   = USER,
             CLI_BLOQUEO_NOCTURNO          = 'N',
             CLI_BLOQUEADO_PROCESO         = 'S'
       WHERE CLI_PER_NUM_IDEN = P_BLOQUEO.CLI_PER_NUM_IDEN
         AND CLI_PER_TID_CODIGO = P_BLOQUEO.CLI_PER_TID_CODIGO;
      COMMIT;
    END LOOP;
  EXCEPTION
    WHEN NO_DATA_FOUND THEN
      DBMS_OUTPUT.put_line('NO HAY CLIENTES QUE ACTUALIZAR ' || SQLERRM);
    WHEN OTHERS THEN
      DBMS_OUTPUT.put_line('OTRO ERROR Y ES ' || SQLERRM);
  END PR_BLOQUEO_USUARIO_NOCTURNO;

  PROCEDURE P_LIMITES_CLIENTES IS

    CURSOR C_LIMITE_NAT IS
      SELECT L.LISA_LIMITE    LIMITE,
             P.PER_NUM_IDEN   IDEN,
             P.PER_TID_CODIGO TID
        FROM PERSONAS P, LIMITE_SARIC L
       WHERE L.LISA_CLI_PER_NUM_IDEN = P.PER_NUM_IDEN
         AND L.LISA_CLI_PER_TID_CODIGO = P.PER_TID_CODIGO
         AND L.LISA_ESTADO = 'A'
      --AND P.PER_TIPO                = 'PNA'
      ;
    V_LIMITE_NAT C_LIMITE_NAT%ROWTYPE;

    CURSOR C_LIMITES IS
      SELECT PER_NUM_IDEN IDEN, PER_TID_CODIGO TID
        FROM PERSONAS
       WHERE PER_LIMITE IS NOT NULL
         AND PER_TIPO_LIMITE IS NOT NULL;
    V_LIMITES C_LIMITES%ROWTYPE;

    CURSOR C_NOMBRES(TID VARCHAR2, IDEN VARCHAR2) IS
      SELECT PER_RAZON_SOCIAL NOMBRE, PER_TIPO TIPO
        FROM PERSONAS
       WHERE PER_NUM_IDEN = IDEN
         AND PER_TID_CODIGO = TID
         AND EXISTS (SELECT 'X'
                FROM CLIENTES
               WHERE CLI_PER_NUM_IDEN = PER_NUM_IDEN
                 AND CLI_PER_TID_CODIGO = PER_TID_CODIGO
                 AND CLI_ECL_MNEMONICO != 'INA');
    V_NOMBRES C_NOMBRES%ROWTYPE;

    CURSOR C_NUEVO_LIM IS
      SELECT PER_NUM_IDEN IDEN, PER_TID_CODIGO TID
        FROM PERSONAS
       WHERE PER_TIPO_LIMITE IS NOT NULL;
    V_NUEVO_LIM C_NUEVO_LIM%ROWTYPE;

    CURSOR C_POR_COLUM IS
      SELECT E.PBL_PILC_COLUMNA COLUMNA
        FROM PROD.COLUMNAS_LIMITE_CONTRAPARTE C,
             PROD.PARAMETRO_BASE_LIMITE       E
       WHERE E.PBL_PILC_COLUMNA = C.CLC_ID_COLUMNA
         AND E.PBL_LIT_FECHA_CARGUE =
             (SELECT MAX(PBL_LIT_FECHA_CARGUE)
                FROM PROD.PARAMETRO_BASE_LIMITE
               WHERE PBL_DLC_DESCRIPCION_LIMITE || ' ' || PBL_PLC_PORCENTAJE || '% ' ||
                     PBL_BASEMONETARIA = 'Lżmite de Contraparte 95% Pesos')
         AND E.PBL_DLC_DESCRIPCION_LIMITE || ' ' || E.PBL_PLC_PORCENTAJE || '% ' ||
             E.PBL_BASEMONETARIA = 'Lżmite de Contraparte 95% Pesos';

    CURSOR C_MOSTRAR28 IS
      SELECT A.LIT_LIMITE_INVERSION_PP_100_C LIMITE,
             A.LIT_IDENTIFICACION_I          IDEN
        FROM ARCHIVO_LIMITE_CONTRAPARTE A, PERSONAS P
       WHERE A.LIT_IDENTIFICACION_I = P.PER_NUM_IDEN
         AND P.PER_TIPO = 'PJU'
         AND A.LIT_FECHA_CARGUE =
             (SELECT MAX(LIT_FECHA_CARGUE) FROM ARCHIVO_LIMITE_CONTRAPARTE);
