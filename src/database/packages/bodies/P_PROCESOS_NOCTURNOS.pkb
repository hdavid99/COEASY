  -- ----------------------------------------------------------------------------
  PROCEDURE P_CONFIRMA_ORDEN_FONDOS(FECHA_PROCESO DATE,
                                    P_SUC_CODIGO  NUMBER DEFAULT NULL,
                                    P_ORDEN       NUMBER DEFAULT NULL,
                                    P_TX          IN NUMBER DEFAULT NULL) IS

    -- VAGTUD991
    -- TRAE ORDENES DE RETIRO PARA VALIDAR SI EL FONDO HA SALTADO A UNA NUEVA PARTICIPACION
    CURSOR C_ORDENES_RETIRO IS
      SELECT OFO_SUC_CODIGO,
             OFO_CONSECUTIVO,
             OFO_CFO_CCC_CLI_PER_NUM_IDEN,
             OFO_CFO_CCC_CLI_PER_TID_CODIGO,
             OFO_CFO_CCC_NUMERO_CUENTA,
             OFO_CFO_FON_CODIGO,
             OFO_CFO_CODIGO,
             OFO_EOF_CODIGO,
             OFO_TTO_TOF_CODIGO,
             OFO_FECHA_EJECUCION,
             OFO_FECHA_CAPTURA,
             OFO_MONTO,
             OFO_MONTO_ANTICIPO,
             OFO_TCF_TAF_GRP_FON_CODIGO,
             OFO_TCF_TAF_GRP_MNEMONICO,
             OFO_TCF_TAF_MODALIDAD_TASA,
             OFO_TCF_NUMERO_TITULO,
             OFO_OFO_SUC_CODIGO,
             OFO_OFO_CONSECUTIVO,
             OFO_CARGO_ABONO_CUENTA,
             OFO_FECHA_CUMPLIMIENTO
        FROM ORDENES_FONDOS
       WHERE OFO_EOF_CODIGO IN ('APL', 'COL')
         AND OFO_AUTORIZACION = 'S'
         AND OFO_TTO_TOF_CODIGO IN ('RP', 'RT')
         AND TRUNC(OFO_FECHA_EJECUCION) = TRUNC(FECHA_PROCESO)
         AND OFO_CFO_FON_CODIGO IN
             (SELECT FON_CODIGO
                FROM FONDOS
               WHERE FON_ESTADO = 'A'
                 AND FON_TIPO_ADMINISTRACION = 'F'
                 AND FON_TIPO IN ('A')
                 AND FON_NOMBRE_CORTO IS NOT NULL)
            -- LAS DE OMNIBUS NO SE MODIFICAN
         AND NOT EXISTS
       (SELECT 'S'
                FROM PARAMETROS_FONDOS
               WHERE PFO_FON_CODIGO = OFO_CFO_FON_CODIGO
                 AND PFO_PAR_CODIGO = 115
                 AND PFO_RANGO_MIN_CHAR = 'S')
         AND ((P_SUC_CODIGO IS NULL AND P_ORDEN IS NULL) OR
             (P_SUC_CODIGO IS NOT NULL AND P_ORDEN IS NOT NULL AND
             OFO_SUC_CODIGO = P_SUC_CODIGO AND OFO_CONSECUTIVO = P_ORDEN))
       ORDER BY OFO_CFO_FON_CODIGO;
    R_OFORET C_ORDENES_RETIRO%ROWTYPE;

    V_APLICA_SALTOS VARCHAR2(1);
    V_FONDO_ACTIVO  VARCHAR2(15);
    -- FIN VAGTUD991

    /*Selecciona las Ordenes de Fondos a Confirmar*/
    CURSOR C_ORDENES IS
      SELECT OFO_SUC_CODIGO,
             OFO_CONSECUTIVO,
             OFO_CFO_CCC_CLI_PER_NUM_IDEN,
             OFO_CFO_CCC_CLI_PER_TID_CODIGO,
             OFO_CFO_CCC_NUMERO_CUENTA,
             OFO_CFO_FON_CODIGO,
             OFO_CFO_CODIGO,
             OFO_EOF_CODIGO,
             OFO_TTO_TOF_CODIGO,
             OFO_FECHA_EJECUCION,
             OFO_FECHA_CAPTURA,
             OFO_MONTO,
             OFO_MONTO_ANTICIPO,
             OFO_TCF_TAF_GRP_FON_CODIGO,
             OFO_TCF_TAF_GRP_MNEMONICO,
             OFO_TCF_TAF_MODALIDAD_TASA,
             OFO_TCF_NUMERO_TITULO,
             OFO_OFO_SUC_CODIGO,
             OFO_OFO_CONSECUTIVO,
             OFO_CARGO_ABONO_CUENTA,
             OFO_FECHA_CUMPLIMIENTO
        FROM ORDENES_FONDOS
       WHERE OFO_EOF_CODIGO IN ('APL', 'COL')
         AND OFO_AUTORIZACION = 'S'
         AND TRUNC(OFO_FECHA_EJECUCION) = TRUNC(FECHA_PROCESO)
         AND OFO_CFO_FON_CODIGO IN
             (SELECT FON_CODIGO
                FROM FONDOS
               WHERE FON_ESTADO = 'A'
                 AND FON_TIPO_ADMINISTRACION = 'F'
                 AND FON_TIPO IN ('A')
                 AND FON_NOMBRE_CORTO IS NOT NULL)
         AND ((P_SUC_CODIGO IS NULL AND P_ORDEN IS NULL) OR
             (P_SUC_CODIGO IS NOT NULL AND P_ORDEN IS NOT NULL AND
             OFO_SUC_CODIGO = P_SUC_CODIGO AND OFO_CONSECUTIVO = P_ORDEN))
       ORDER BY OFO_CFO_FON_CODIGO;
    C_OFO C_ORDENES%ROWTYPE;

    /*Verifica si la cuenta esta activa */
    CURSOR C_ESTADO IS
      SELECT CFO_ESTADO
        FROM CUENTAS_FONDOS
       WHERE CFO_CCC_CLI_PER_TID_CODIGO =
             C_OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO
         AND CFO_CCC_CLI_PER_NUM_IDEN = C_OFO.OFO_CFO_CCC_CLI_PER_NUM_IDEN
         AND CFO_CCC_NUMERO_CUENTA = C_OFO.OFO_CFO_CCC_NUMERO_CUENTA
         AND CFO_FON_CODIGO = C_OFO.OFO_CFO_FON_CODIGO
         AND CFO_CODIGO = C_OFO.OFO_CFO_CODIGO;
    C_EST C_ESTADO%ROWTYPE;

    /*Selecciona datos del fondo en proceso */
    CURSOR FONDOS IS
      SELECT FON_BMO_MNEMONICO
        FROM FONDOS
       WHERE FON_CODIGO = C_OFO.OFO_CFO_FON_CODIGO;
    C_FON FONDOS%ROWTYPE;

    /*Verifica si el cliente es exento */
    CURSOR EXCENTO IS
      SELECT CCC_EXENTA_GMF
        FROM CUENTAS_CLIENTE_CORREDORES
       WHERE CCC_CLI_PER_NUM_IDEN = C_OFO.OFO_CFO_CCC_CLI_PER_NUM_IDEN
         AND CCC_CLI_PER_TID_CODIGO = C_OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO
         AND CCC_NUMERO_CUENTA = C_OFO.OFO_CFO_CCC_NUMERO_CUENTA;
    COND_EXC VARCHAR2(1);

    /*Verifica si el Fondo ya cerro el dia anterior */
    CURSOR C_CIERRE IS
      SELECT 'X'
        FROM CONFIRMACION_FONDOS_DIA
       WHERE CFD_FON_CODIGO = C_OFO.OFO_CFO_FON_CODIGO
         AND CFD_FECHA = TRUNC(FECHA_PROCESO - 1)
         AND CFD_APROBACION_ORDENES = 'S'
         AND CFD_VALORIZACION_PORTAFOLIO = 'S';
    COND_CIE VARCHAR2(1);

    /*Selecciona ordenes de la misma cuenta */
    CURSOR CANT_ORDEN1 IS
      SELECT SUM(OFO_MONTO)
        FROM ORDENES_FONDOS
       WHERE OFO_CFO_CCC_CLI_PER_NUM_IDEN =
             C_OFO.OFO_CFO_CCC_CLI_PER_NUM_IDEN
         AND OFO_CFO_CCC_CLI_PER_TID_CODIGO =
             C_OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO
         AND OFO_CFO_CCC_NUMERO_CUENTA = C_OFO.OFO_CFO_CCC_NUMERO_CUENTA
         AND OFO_CFO_CODIGO = C_OFO.OFO_CFO_CODIGO
         AND OFO_CFO_FON_CODIGO = C_OFO.OFO_CFO_FON_CODIGO
         AND OFO_EOF_CODIGO IN ('COL', 'CON', 'APL')
         AND OFO_TTO_TOF_CODIGO IN
             ('RP', 'RPS', 'PSC', 'PSR', 'CRC', 'PCS', 'RCA', 'RDA', 'CRD');

    /*Selecciona ordenes de la misma cuenta */
    CURSOR CANT_ORDEN2 IS
      SELECT SUM(OFO_MONTO)
        FROM ORDENES_FONDOS
       WHERE OFO_CFO_CCC_CLI_PER_NUM_IDEN =
             C_OFO.OFO_CFO_CCC_CLI_PER_NUM_IDEN
         AND OFO_CFO_CCC_CLI_PER_TID_CODIGO =
             C_OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO
         AND OFO_CFO_CCC_NUMERO_CUENTA = C_OFO.OFO_CFO_CCC_NUMERO_CUENTA
         AND OFO_CFO_CODIGO = C_OFO.OFO_CFO_CODIGO
         AND OFO_CFO_FON_CODIGO = C_OFO.OFO_CFO_FON_CODIGO
         AND OFO_EOF_CODIGO IN ('COL', 'CON', 'APL')
         AND OFO_TTO_TOF_CODIGO IN ('ING', 'INC');

    /*Selecciona los saldos de la cuenta */
    CURSOR SALDOS IS
      SELECT CFO_SALDO_RENDIMIENTOS_RF   SAL_RND_RF,
             CFO_SALDO_RENDIMIENTOS_RV   SAL_RND_RV,
             CFO_SALDO_RETEFUENTE        SAL_RET,
             CFO_SALDO_CAPITAL           SAL_CAP,
             CFO_SALDO_INVER             SAL_INV,
             CFO_SALDO_UNIDADES          SAL_UNI,
             CFO_SALDO_INTERESES_PAGADOS SAL_INT,
             CFO_TASA_PROMEDIO           SAL_TAS,
             SYSDATE                     SAL_FEC
        FROM CUENTAS_FONDOS
       WHERE CFO_CCC_CLI_PER_TID_CODIGO =
             C_OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO
         AND CFO_CCC_CLI_PER_NUM_IDEN = C_OFO.OFO_CFO_CCC_CLI_PER_NUM_IDEN
         AND CFO_CCC_NUMERO_CUENTA = C_OFO.OFO_CFO_CCC_NUMERO_CUENTA
         AND CFO_FON_CODIGO = C_OFO.OFO_CFO_FON_CODIGO
         AND CFO_CODIGO = C_OFO.OFO_CFO_CODIGO;
    SAL SALDOS%ROWTYPE;

    /*Verifica los traslados de la cuenta */
    CURSOR C_RETIRO_TRASLADO IS
      SELECT 'X'
        FROM ORDENES_FONDOS
       WHERE OFO_OFO_CONSECUTIVO = C_OFO.OFO_CONSECUTIVO
         AND OFO_OFO_SUC_CODIGO = C_OFO.OFO_SUC_CODIGO;
    TRASLADO VARCHAR2(1);

    --PROCESOS T + N
    /*Selecciona las Ordenes T + N de Fondos a Confirmar*/
    CURSOR C_ORDENES_TN IS
      SELECT OFO_SUC_CODIGO,
             OFO_CONSECUTIVO,
             OFO_CFO_CCC_CLI_PER_NUM_IDEN,
             OFO_CFO_CCC_CLI_PER_TID_CODIGO,
             OFO_CFO_CCC_NUMERO_CUENTA,
             OFO_CFO_FON_CODIGO,
             OFO_CFO_CODIGO,
             OFO_EOF_CODIGO,
             OFO_TTO_TOF_CODIGO,
             OFO_FECHA_EJECUCION,
             OFO_FECHA_CAPTURA,
             OFO_MONTO,
             OFO_MONTO_ANTICIPO,
             OFO_TCF_TAF_GRP_FON_CODIGO,
             OFO_TCF_TAF_GRP_MNEMONICO,
             OFO_TCF_TAF_MODALIDAD_TASA,
             OFO_TCF_NUMERO_TITULO,
             OFO_OFO_SUC_CODIGO,
             OFO_OFO_CONSECUTIVO,
             OFO_CARGO_ABONO_CUENTA,
             OFO_FECHA_CUMPLIMIENTO
        FROM ORDENES_FONDOS OFO1
       WHERE OFO_EOF_CODIGO IN ('APR')
         AND OFO_TTO_TOF_CODIGO IN ('RP', 'RT') -- OMORA
         AND OFO_CFO_FON_CODIGO IN
             (SELECT FON_CODIGO
                FROM FONDOS
               WHERE FON_ESTADO = 'A'
                 AND FON_TIPO_ADMINISTRACION = 'F'
                 AND FON_TIPO IN ('A')
                 AND FON_NOMBRE_CORTO IS NOT NULL)
         AND ((P_SUC_CODIGO IS NULL AND P_ORDEN IS NULL) OR
             (P_SUC_CODIGO IS NOT NULL AND P_ORDEN IS NOT NULL AND
             OFO_SUC_CODIGO = P_SUC_CODIGO AND OFO_CONSECUTIVO = P_ORDEN))
            -- INICIO OMORA CUENTA UNICA
         AND ((TRUNC(OFO_FECHA_CUMPLIMIENTO) > TRUNC(OFO_FECHA_EJECUCION) AND
             TRUNC(OFO_FECHA_CUMPLIMIENTO) = TRUNC(SYSDATE) AND
             OFO_CFO_FON_CODIGO IN
             (SELECT PFO_FON_CODIGO
                  FROM PARAMETROS_FONDOS
                 WHERE PFO_PAR_CODIGO = 96
                   AND NVL(PFO_RANGO_MIN_NUMBER, 0) > 0)) OR
             (TRUNC(OFO_FECHA_EJECUCION) >= TRUNC(SYSDATE - 1) AND
             OFO_FECHA_CUMPLIMIENTO IS NULL AND OFO_TTO_TOF_CODIGO = 'RT' AND
             EXISTS (SELECT 1
                        FROM ORDENES_DE_PAGO ODP
                       WHERE ODP.ODP_OFO_CONSECUTIVO = OFO_CONSECUTIVO
                         AND ODP.ODP_OFO_SUC_CODIGO = OFO_SUC_CODIGO
                         AND ODP.ODP_TPA_MNEMONICO = 'TRB')) OR
             (TRUNC(OFO_FECHA_CUMPLIMIENTO) = TRUNC(OFO_FECHA_EJECUCION) AND
             TRUNC(OFO_FECHA_EJECUCION) >= TRUNC(SYSDATE - 1) AND
             OFO_TTO_TOF_CODIGO = 'RT' AND EXISTS
              (SELECT 1
                  FROM DETALLES_ABONOS_CUENTAS
                 WHERE DAA_OFO_CONSECUTIVO = OFO_CONSECUTIVO
                   AND DAA_OFO_SUC_CODIGO = OFO_SUC_CODIGO) AND EXISTS
              (SELECT 1
                  FROM ORDENES_FONDOS OFO2
                 WHERE OFO2.OFO_OFO_CONSECUTIVO = OFO1.OFO_CONSECUTIVO
                   AND OFO2.OFO_OFO_SUC_CODIGO = OFO1.OFO_SUC_CODIGO)))
      -- FIN OMORA CUENTA UNICA
       ORDER BY OFO_CFO_FON_CODIGO;
    C_OFO_TN C_ORDENES_TN%ROWTYPE;

    -- INICIO OMORA CUENTA UNICA
    -- CURSOR CONSULTA LA ORDEN DE PAGO DE LA ORDEN DE FONDOS
    CURSOR C_ORDEN_PAGO(P_OFO_CONSECUTIVO NUMBER, P_OFO_SUC_CODIGO NUMBER) IS
      SELECT ODP.ODP_TPA_MNEMONICO
        FROM ORDENES_DE_PAGO ODP
       WHERE ODP.ODP_OFO_CONSECUTIVO = P_OFO_CONSECUTIVO
         AND ODP.ODP_OFO_SUC_CODIGO = P_OFO_SUC_CODIGO;
    P_TPA_MNEMONICO ORDENES_DE_PAGO.ODP_TPA_MNEMONICO%TYPE;

    -- CURSOR CONSULTA EL TIPO DE MOVIMIENTO
    CURSOR C_DESCRIPCION_MOVIMIENTO(P_TPA_MENEMONICO VARCHAR2) IS
      SELECT TTE_MNEMONICO, TTE_DESCRIPCION
        FROM TIPOS_MOVIMIENTOS_TESORERIA
       WHERE TTE_TPA_MNEMONICO = P_TPA_MENEMONICO
         AND TTE_DE_REVERSION = 'N';
    TTE1            C_DESCRIPCION_MOVIMIENTO%ROWTYPE;
    TIPO_MOV_MOTEFO VARCHAR2(5);
    TIPO_MOV_COMOCO VARCHAR2(5);

    -- CURSOR VERIFICA SI EXISTE MOVIMIENTO TESORERIA
    CURSOR C_EXISTE_MOTEFO(P_OFO_CONSECUTIVO NUMBER,
                           P_OFO_SUC_CODIGO  NUMBER,
                           P_TTE_MNEMONICO   VARCHAR2) IS
      SELECT COUNT(1)
        FROM MOVIMIENTOS_TESORERIA_FONDOS MO
       WHERE MO.MTF_OFO_CONSECUTIVO = P_OFO_CONSECUTIVO
         AND MO.MTF_OFO_SUC_CODIGO = P_OFO_SUC_CODIGO
         AND MO.MTF_TTE_MNEMONICO = P_TTE_MNEMONICO;
    P_CONTADOR_MOTEFO NUMBER;

    -- CURSOR VERIFICA SI EXISTE MOVIMIENTO CORREDORES
    CURSOR C_EXISTE_COMOCO(P_OFO_CONSECUTIVO NUMBER,
                           P_OFO_SUC_CODIGO  NUMBER,
                           P_TMC_MNEMONICO   VARCHAR2) IS
      SELECT COUNT(1)
        FROM MOVIMIENTOS_CUENTA_CORREDORES MO
       WHERE MO.MCC_OFO_CONSECUTIVO = P_OFO_CONSECUTIVO
         AND MO.MCC_OFO_SUC_CODIGO = P_OFO_SUC_CODIGO
         AND MO.MCC_TMC_MNEMONICO = P_TMC_MNEMONICO;
    P_CONTADOR_COMOCO NUMBER;
    -- FIN OMORA CUENTA UNICA

    /*Selecciona datos del fondo en proceso T + N  */
    CURSOR FONDOS_TN IS
      SELECT FON_BMO_MNEMONICO
        FROM FONDOS
       WHERE FON_CODIGO = C_OFO_TN.OFO_CFO_FON_CODIGO;
    C_FON_TN FONDOS_TN%ROWTYPE;

    /*Verifica si el Fondo ya cerro el dia anterior */
    CURSOR C_CIERRE_TN IS
      SELECT 'X'
        FROM CONFIRMACION_FONDOS_DIA
       WHERE CFD_FON_CODIGO = C_OFO_TN.OFO_CFO_FON_CODIGO
         AND CFD_FECHA = TRUNC(FECHA_PROCESO - 1)
         AND CFD_APROBACION_ORDENES = 'S'
         AND CFD_VALORIZACION_PORTAFOLIO = 'S';
    COND_CIE_TN VARCHAR2(1);

    /*Verifica si la cuenta esta activa */
    CURSOR C_ESTADO_TN IS
      SELECT CFO_ESTADO
        FROM CUENTAS_FONDOS
       WHERE CFO_CCC_CLI_PER_TID_CODIGO =
             C_OFO_TN.OFO_CFO_CCC_CLI_PER_TID_CODIGO
         AND CFO_CCC_CLI_PER_NUM_IDEN =
             C_OFO_TN.OFO_CFO_CCC_CLI_PER_NUM_IDEN
         AND CFO_CCC_NUMERO_CUENTA = C_OFO_TN.OFO_CFO_CCC_NUMERO_CUENTA
         AND CFO_FON_CODIGO = C_OFO_TN.OFO_CFO_FON_CODIGO
         AND CFO_CODIGO = C_OFO_TN.OFO_CFO_CODIGO;
    C_EST_TN C_ESTADO_TN%ROWTYPE;

    /*Verifica si el cliente es exento */
    CURSOR EXCENTO_TN IS
      SELECT CCC_EXENTA_GMF
        FROM CUENTAS_CLIENTE_CORREDORES
       WHERE CCC_CLI_PER_NUM_IDEN = C_OFO_TN.OFO_CFO_CCC_CLI_PER_NUM_IDEN
         AND CCC_CLI_PER_TID_CODIGO =
             C_OFO_TN.OFO_CFO_CCC_CLI_PER_TID_CODIGO
         AND CCC_NUMERO_CUENTA = C_OFO_TN.OFO_CFO_CCC_NUMERO_CUENTA;
    COND_EXC_TN VARCHAR2(1);

    /*Selecciona los saldos de la cuenta */
    CURSOR SALDOS_TN IS
      SELECT CFO_SALDO_RENDIMIENTOS_RF   SAL_RND_RF,
             CFO_SALDO_RENDIMIENTOS_RV   SAL_RND_RV,
             CFO_SALDO_RETEFUENTE        SAL_RET,
             CFO_SALDO_CAPITAL           SAL_CAP,
             CFO_SALDO_INVER             SAL_INV,
             CFO_SALDO_UNIDADES          SAL_UNI,
             CFO_SALDO_INTERESES_PAGADOS SAL_INT,
             CFO_TASA_PROMEDIO           SAL_TAS,
             SYSDATE                     SAL_FEC
        FROM CUENTAS_FONDOS
       WHERE CFO_CCC_CLI_PER_TID_CODIGO =
             C_OFO_TN.OFO_CFO_CCC_CLI_PER_TID_CODIGO
         AND CFO_CCC_CLI_PER_NUM_IDEN =
             C_OFO_TN.OFO_CFO_CCC_CLI_PER_NUM_IDEN
         AND CFO_CCC_NUMERO_CUENTA = C_OFO_TN.OFO_CFO_CCC_NUMERO_CUENTA
         AND CFO_FON_CODIGO = C_OFO_TN.OFO_CFO_FON_CODIGO
         AND CFO_CODIGO = C_OFO_TN.OFO_CFO_CODIGO;
    SAL_TN SALDOS_TN%ROWTYPE;

    /*Verifica el valor del RT*/
    CURSOR C_VERIF_ACO_TN IS
      SELECT SUM(DAA_VALOR) DAA_VALOR
        FROM DETALLES_ABONOS_CUENTAS, TIPOS_ABONOS_CUENTAS
       WHERE DAA_TAC_MNEMONICO = TAC_MNEMONICO
         AND DAA_OFO_SUC_CODIGO = C_OFO_TN.OFO_SUC_CODIGO
         AND DAA_OFO_CONSECUTIVO = C_OFO_TN.OFO_CONSECUTIVO
         AND NOT EXISTS
       (SELECT 'X'
                FROM FONDOS
               WHERE FON_NPR_PRO_MNEMONICO = TAC_PRO_MNEMONICO
                 AND FON_TIPO_ADMINISTRACION = 'F'
                 AND FON_NEG_CONSECUTIVO != 2
                 AND FON_TIPO IN ('A', 'C'));
    R_VERIF_ACO_TN C_VERIF_ACO_TN%ROWTYPE;

    --CURSOR PARA EVALUAR EL PARAMETRO 96
    CURSOR C_VALOR_PAR2(TIPO NUMBER) IS
      SELECT PFO_RANGO_MIN_NUMBER, PFO_RANGO_MAX_NUMBER
        FROM PARAMETROS_FONDOS A
       WHERE PFO_FON_CODIGO = C_OFO.OFO_CFO_FON_CODIGO
         AND A.PFO_PAR_CODIGO = TIPO;
    PFO1 C_VALOR_PAR2%ROWTYPE;

    V_TOTAL_ABO_TN            NUMBER;
    V_DIAS_PAGO               NUMBER;
    P_FON_PADRE_COMPARTIMENTO VARCHAR2(15);
    P_FONDO_COMPARTIMENTO     VARCHAR2(1);
    FONDO_ANT                 VARCHAR2(15);
    PROCESAR                  VARCHAR2(1);
    CONDI                     VARCHAR2(1);
    P_EXC                     VARCHAR2(1) := NULL;
    P_T0                      VARCHAR2(5) := NULL;
    SALDO_RETIROS             NUMBER;
    SALDO_INGRESOS            NUMBER;
    MONTO_ORDENES             NUMBER;
    MONTO_ANTICIPO            NUMBER;
    RP_PRC                    NUMBER;
    BASE_MONETARIA            VARCHAR2(5);

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

    -- PARAMETROS PARA NOTIFICACIONES POR NO PROCESO
    P_FLAG_ERROR     VARCHAR2(1);
    P_NOTIFICA_ERROR VARCHAR2(2000);

    P_CLI_PER_TID_CODIGO NOTIFICACIONES_MAIL_CORREDORES.NMC_CLI_PER_TID_CODIGO%TYPE;
    P_CLI_PER_NUM_IDEN   NOTIFICACIONES_MAIL_CORREDORES.NMC_CLI_PER_NUM_IDEN%TYPE;
    P_SERVICIO           NOTIFICACIONES_MAIL_CORREDORES.NMC_SERVICIO%TYPE;
    P_DE                 NOTIFICACIONES_MAIL_CORREDORES.NMC_DE%TYPE;
    P_PARA               NOTIFICACIONES_MAIL_CORREDORES.NMC_PARA%TYPE;
    P_ASUNTO             NOTIFICACIONES_MAIL_CORREDORES.NMC_ASUNTO%TYPE;
    P_MENSAJE            NOTIFICACIONES_MAIL_CORREDORES.NMC_CUERPO%TYPE;
    P_CLOB               CLOB;
    P_MENSAJE_CLOB       CLOB;

    --
    SALDO_INSUFICIENTE EXCEPTION;
    CONN             UTL_SMTP.CONNECTION;
    EXTRACTO_ARCHIVO UTL_FILE.FILE_TYPE;
    V_NOMBRE_ARCHIVO VARCHAR2(100);
    V_LINEA          VARCHAR2(8000);
    V_ARCHIVO        VARCHAR2(80);
    CRLF             VARCHAR2(2) := CHR(13) || CHR(10);
    V_EXISTE         NUMBER;
    N_ID_PROCESO     NUMBER;
    N_TX             NUMBER;

    CURSOR C_ERRORES_PROCESOS IS
      SELECT ERP_CONSECUTIVO,
             ERP_FECHA_ERROR,
             ERP_PROCESO,
             ERP_ERROR,
             ERP_TABLA_ERROR,
             ROWID RID
        FROM ERRORES_PROCESOS
       WHERE ERP_PROCESO LIKE
             'P_PROCESOS_NOCTURNOS.P_CONFIRMA_ORDEN_FONDOS%'
         AND ERP_FECHA_ERROR >= TRUNC(SYSDATE)
         AND ERP_FECHA_ERROR < TRUNC(SYSDATE + 1)
         AND ERP_TABLA_ERROR IS NULL;
    ERP C_ERRORES_PROCESOS%ROWTYPE;
    --

  BEGIN

    BEGIN
       --se asigna el consecutivo del proceso(tabla PARAMETRIZACION_PROCESOS)
      N_ID_PROCESO := P_TRAZA_CORE.FN_ID_PROCESO('P_PROCESOS_NOCTURNOS.P_CONFIRMA_ORDEN_FONDOS');

      --se Asigna consecutivo para la transaccion, si el proceso es el primero que se llama, reinicia el consecutivo
      N_TX := P_TRAZA_CORE.FN_TRAE_TX(P_TX);

      --Registra Traza
      P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                      'I',
                                      'Inicio proceso P_PROCESOS_NOCTURNOS.P_CONFIRMA_ORDEN_FONDOS. Fecha Proceso: ' ||
                                      TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss'),
                                      N_TX);

      -- VAGTUD991 - SE VALIDA PARTICIPACION ACTIVA DE ORDENES DE RETIRO DE FONDOS CON SALTO EN PARTICIPACIONES
      OPEN C_ORDENES_RETIRO;
      FETCH C_ORDENES_RETIRO
        INTO R_OFORET;
      WHILE C_ORDENES_RETIRO%FOUND LOOP
        V_APLICA_SALTOS := 'N';
        V_FONDO_ACTIVO  := NULL;
        V_APLICA_SALTOS := P_ORDENES_FONDOS.FN_APLICA_SALTOS(R_OFORET.OFO_CFO_FON_CODIGO);
        IF NVL(V_APLICA_SALTOS, 'N') = 'S' THEN
          V_FONDO_ACTIVO := P_RECAUDOS_DAVICASH.FN_PARTICIPACION_ACTIVA(P_CCC_CLI_PER_TID_CODIGO => R_OFORET.OFO_CFO_CCC_CLI_PER_TID_CODIGO,
                                                                        P_CCC_CLI_PER_NUM_IDEN   => R_OFORET.OFO_CFO_CCC_CLI_PER_NUM_IDEN,
                                                                        P_CCC_NUMERO_CUENTA      => R_OFORET.OFO_CFO_CCC_NUMERO_CUENTA,
                                                                        P_CFO_FON_CODIGO         => R_OFORET.OFO_CFO_FON_CODIGO,
                                                                        P_CFO_CODIGO             => R_OFORET.OFO_CFO_CODIGO);
          IF V_FONDO_ACTIVO IS NOT NULL AND
             V_FONDO_ACTIVO != R_OFORET.OFO_CFO_FON_CODIGO THEN
            UPDATE ORDENES_FONDOS
               SET OFO_CFO_FON_CODIGO = V_FONDO_ACTIVO
             WHERE OFO_CONSECUTIVO = R_OFORET.OFO_CONSECUTIVO
               AND OFO_SUC_CODIGO = R_OFORET.OFO_SUC_CODIGO;
          END IF;
        END IF;
        FETCH C_ORDENES_RETIRO
          INTO R_OFORET;
      END LOOP;
      CLOSE C_ORDENES_RETIRO;
      COMMIT;
      -- FIN VAGTUD991

      OPEN C_ORDENES;
      FETCH C_ORDENES
        INTO C_OFO;

      FONDO_ANT := '999999999';
      PROCESAR  := 'N';

      P_FLAG_ERROR     := 'N';
      P_NOTIFICA_ERROR := '';

      WHILE C_ORDENES%FOUND LOOP

        BEGIN
          --BEGIN SAVEPOINT
          SAVEPOINT SV_CONFIRMA_ORDENES_FONDOS;
          --------------------------
          -- DIAS PARA PAGO
          --------------------------
          OPEN C_VALOR_PAR2(96);
          FETCH C_VALOR_PAR2
            INTO PFO1;
          IF C_VALOR_PAR2%NOTFOUND THEN
            PFO1.PFO_RANGO_MIN_NUMBER := 0;
          END IF;
          V_DIAS_PAGO := NVL(PFO1.PFO_RANGO_MIN_NUMBER, 0);
          CLOSE C_VALOR_PAR2;

          IF FONDO_ANT != C_OFO.OFO_CFO_FON_CODIGO THEN
            FONDO_ANT := C_OFO.OFO_CFO_FON_CODIGO;
            OPEN FONDOS;
            FETCH FONDOS
              INTO BASE_MONETARIA;
            CLOSE FONDOS;

            OPEN C_CIERRE;
            FETCH C_CIERRE
              INTO COND_CIE;
            CLOSE C_CIERRE;
            IF COND_CIE = 'X' THEN
              P_FONDO_COMPARTIMENTO := 'N';
              P_ORDENES_FONDOS.P_VALIDA_PARAMETROS_COMP(P_FON_CODIGO         => C_OFO.OFO_CFO_FON_CODIGO,
                                                        P_PAR_CODIGO         => 70,
                                                        P_PFO_RANGO_MIN_CHAR => P_FONDO_COMPARTIMENTO);

              P_FONDO_COMPARTIMENTO := NVL(P_FONDO_COMPARTIMENTO, 'N');

              IF NVL(P_FONDO_COMPARTIMENTO, 'N') = 'S' THEN
                P_ORDENES_FONDOS.P_VALIDA_PARAMETROS_COMP(P_FON_CODIGO         => C_OFO.OFO_CFO_FON_CODIGO,
                                                          P_PAR_CODIGO         => 71,
                                                          P_PFO_RANGO_MIN_CHAR => P_FON_PADRE_COMPARTIMENTO);
                IF P_FON_PADRE_COMPARTIMENTO IS NULL THEN
                  P_FON_PADRE_COMPARTIMENTO := 'N';
                END IF;
              END IF;
              PROCESAR := 'S';
            ELSE
              PROCESAR := 'N';
            END IF;
          END IF;

          PROCESAR := 'S';

          IF PROCESAR = 'S' THEN
            OPEN C_ESTADO;
            FETCH C_ESTADO
              INTO C_EST;
            IF C_EST.CFO_ESTADO = 'A' THEN
              PROCESAR := 'S';
              OPEN EXCENTO;
              FETCH EXCENTO
                INTO COND_EXC;
              CLOSE EXCENTO;
              P_EXC := NVL(COND_EXC, 'N');
              OPEN SALDOS;
              FETCH SALDOS
                INTO SAL;
              IF SALDOS%FOUND THEN
                PROCESAR := 'S';
              ELSE
                PROCESAR         := 'N';
                P_FLAG_ERROR     := 'S';
                P_NOTIFICA_ERROR := P_NOTIFICA_ERROR ||
                                    C_OFO.OFO_CONSECUTIVO || '-';
              END IF;
              CLOSE SALDOS;
            ELSE
              PROCESAR         := 'N';
              P_FLAG_ERROR     := 'S';
              P_NOTIFICA_ERROR := P_NOTIFICA_ERROR || C_OFO.OFO_CONSECUTIVO || '-';
            END IF;
            CLOSE C_ESTADO;
          END IF;

          IF PROCESAR = 'S' THEN
            CONDI := 'S';
            IF C_OFO.OFO_TTO_TOF_CODIGO IN ('ING', 'INC', 'RP', 'RT') THEN
              P_ORDENES_FONDOS.VERIFICA_TRANSFERENCIA(C_OFO.OFO_OFO_SUC_CODIGO,
                                                      C_OFO.OFO_OFO_CONSECUTIVO,
                                                      C_OFO.OFO_SUC_CODIGO,
                                                      C_OFO.OFO_CONSECUTIVO,
                                                      C_OFO.OFO_EOF_CODIGO,
                                                      C_OFO.OFO_CFO_CCC_CLI_PER_NUM_IDEN,
                                                      'ANU',
                                                      CONDI);
            END IF;
            IF CONDI = 'S' THEN
              /* VERIFICACION DE A QUE TIPO CORRESPONDE LA ORDEN */
              /*
              **
              ** INGRESO
              **
              */
              IF C_OFO.OFO_TTO_TOF_CODIGO = 'ING' THEN
                UPDATE ORDENES_RECAUDO
                   SET ORR_ESTADO = 'APR'
                 WHERE ORR_OFO_SUC_CODIGO = C_OFO.OFO_SUC_CODIGO
                   AND ORR_OFO_CONSECUTIVO = C_OFO.OFO_CONSECUTIVO;
                P_ORDENES_FONDOS.INSERTAR_MOVIMIENTO_CORREDORES(C_OFO.OFO_CFO_CCC_CLI_PER_NUM_IDEN,
                                                                C_OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO,
                                                                C_OFO.OFO_CFO_CCC_NUMERO_CUENTA,
                                                                C_OFO.OFO_MONTO,
                                                                C_OFO.OFO_CONSECUTIVO,
                                                                C_OFO.OFO_SUC_CODIGO,
                                                                'ING');
                P_ORDENES_FONDOS.MOVIMIENTO_BANCARIO(P_OFO_SUC_CODIGO            => C_OFO.OFO_SUC_CODIGO,
                                                     P_OFO_CONSECUTIVO           => C_OFO.OFO_CONSECUTIVO,
                                                     P_OFO_CFO_FON_CODIGO        => C_OFO.OFO_CFO_FON_CODIGO,
                                                     P_OFO_TTO_TOF_CODIGO        => C_OFO.OFO_TTO_TOF_CODIGO,
                                                     P_EXC                       => P_EXC,
                                                     P_TIPO                      => 'R',
                                                     P_COMPARTIMENTO_B           => P_FONDO_COMPARTIMENTO,
                                                     P_FON_PADRE_COMPARTIMENTO_B => P_FON_PADRE_COMPARTIMENTO,
                                                     P_ESTADO                    => 'APR');
                P_ORDENES_FONDOS.ABONO_CARGO_CUENTA(C_OFO.OFO_SUC_CODIGO,
                                                    C_OFO.OFO_CONSECUTIVO,
                                                    C_OFO.OFO_CFO_CCC_cLI_PER_NUM_IDEN,
                                                    C_OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO,
                                                    C_OFO.OFO_CFO_CCC_NUMERO_CUENTA,
                                                    C_OFO.OFO_CFO_FON_CODIGO,
                                                    C_OFO.OFO_CFO_CODIGO,
                                                    P_EXC,
                                                    'C',
                                                    'ING');
                UPDATE ORDENES_FONDOS
                   SET OFO_FECHA_EJECUCION = SYSDATE,
                       OFO_EOF_CODIGO      = 'CON'
                 WHERE OFO_SUC_CODIGO = C_OFO.OFO_SUC_CODIGO
                   AND OFO_CONSECUTIVO = C_OFO.OFO_CONSECUTIVO;
                -- VAGTUD941-2 BOTON PSE
                -- SI LA OFO SE ORIGINO EN EL BOTON PSE LOS MOVIMIENTOS EN MTF SE ACTUALIZAN
                P_ORDENES_FONDOS.PR_VALIDA_OFO_PSE(C_OFO.OFO_CONSECUTIVO,
                                                   C_OFO.OFO_SUC_CODIGO);
                -- FIN VAGTUD941-2

                /*
                **
                ** INCREMENTO
                **
                */
              ELSIF C_OFO.OFO_TTO_TOF_CODIGO = 'INC' THEN
                UPDATE ORDENES_RECAUDO
                   SET ORR_ESTADO = 'APR'
                 WHERE ORR_OFO_SUC_CODIGO = C_OFO.OFO_SUC_CODIGO
                   AND ORR_OFO_CONSECUTIVO = C_OFO.OFO_CONSECUTIVO;

                P_ORDENES_FONDOS.INSERTAR_MOVIMIENTO_CORREDORES(C_OFO.OFO_CFO_CCC_CLI_PER_NUM_IDEN,
                                                                C_OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO,
                                                                C_OFO.OFO_CFO_CCC_NUMERO_CUENTA,
                                                                C_OFO.OFO_MONTO,
                                                                C_OFO.OFO_CONSECUTIVO,
                                                                C_OFO.OFO_SUC_CODIGO,
                                                                'INC');
                P_ORDENES_FONDOS.MOVIMIENTO_BANCARIO(P_OFO_SUC_CODIGO            => C_OFO.OFO_SUC_CODIGO,
                                                     P_OFO_CONSECUTIVO           => C_OFO.OFO_CONSECUTIVO,
                                                     P_OFO_CFO_FON_CODIGO        => C_OFO.OFO_CFO_FON_CODIGO,
                                                     P_OFO_TTO_TOF_CODIGO        => C_OFO.OFO_TTO_TOF_CODIGO,
                                                     P_EXC                       => P_EXC,
                                                     P_TIPO                      => 'R',
                                                     P_COMPARTIMENTO_B           => P_FONDO_COMPARTIMENTO,
                                                     P_FON_PADRE_COMPARTIMENTO_B => P_FON_PADRE_COMPARTIMENTO,
                                                     P_ESTADO                    => 'APR');
                P_ORDENES_FONDOS.ABONO_CARGO_CUENTA(C_OFO.OFO_SUC_CODIGO,
                                                    C_OFO.OFO_CONSECUTIVO,
                                                    C_OFO.OFO_CFO_CCC_CLI_PER_NUM_IDEN,
                                                    C_OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO,
                                                    C_OFO.OFO_CFO_CCC_NUMERO_CUENTA,
                                                    C_OFO.OFO_CFO_FON_CODIGO,
                                                    C_OFO.OFO_CFO_CODIGO,
                                                    P_EXC,
                                                    'C',
                                                    'INC');
                UPDATE ORDENES_FONDOS
                   SET OFO_FECHA_EJECUCION = SYSDATE,
                       OFO_EOF_CODIGO      = 'CON'
                 WHERE OFO_SUC_CODIGO = C_OFO.OFO_SUC_CODIGO
                   AND OFO_CONSECUTIVO = C_OFO.OFO_CONSECUTIVO;
                -- VAGTUD941-2 BOTON PSE
                -- SI LA OFO SE ORIGINO EN EL BOTON PSE LOS MOVIMIENTOS EN MTF SE ACTUALIZAN
                P_ORDENES_FONDOS.PR_VALIDA_OFO_PSE(C_OFO.OFO_CONSECUTIVO,
                                                   C_OFO.OFO_SUC_CODIGO);
                -- FIN VAGTUD941-2

                /*
                **
                ** RETIRO TOTAL
                **
                */
              ELSIF C_OFO.OFO_TTO_TOF_CODIGO = 'RT' THEN
                SALDO_RETIROS := 0;
                OPEN CANT_ORDEN1;
                FETCH CANT_ORDEN1
                  INTO SALDO_RETIROS;
                CLOSE CANT_ORDEN1;
                SALDO_INGRESOS := 0;
                OPEN CANT_ORDEN2;
                FETCH CANT_ORDEN2
                  INTO SALDO_INGRESOS;
                CLOSE CANT_ORDEN2;
                SAL.SAL_INV := (NVL(SAL.SAL_INV, 0) +
                               NVL(SALDO_INGRESOS, 0)) -
                               NVL(SALDO_RETIROS, 0);
                IF SAL.SAL_INV >= 0 THEN
                  IF BASE_MONETARIA = 'PESOS' THEN
                    MONTO_ORDENES  := P_ORDENES_FONDOS.MONTO_ORDENES_PAGO(C_OFO.OFO_SUC_CODIGO,
                                                                          C_OFO.OFO_CONSECUTIVO,
                                                                          'A');
                    MONTO_ANTICIPO := NVL(MONTO_ORDENES, 0);
                    P_ORDENES_FONDOS.APROBAR_ORDENES_PAGO(C_OFO.OFO_SUC_CODIGO,
                                                          C_OFO.OFO_CONSECUTIVO,
                                                          'RT',
                                                          P_T0);
                    IF V_DIAS_PAGO > 0 AND TRUNC(C_OFO.OFO_FECHA_CUMPLIMIENTO) >
                       TRUNC(C_OFO.OFO_FECHA_EJECUCION) AND
                       C_OFO.OFO_FECHA_CUMPLIMIENTO IS NOT NULL THEN
                      NULL;
                    ELSE
                      P_ORDENES_FONDOS.MOVIMIENTO_BANCARIO(P_OFO_SUC_CODIGO            => C_OFO.OFO_SUC_CODIGO,
                                                           P_OFO_CONSECUTIVO           => C_OFO.OFO_CONSECUTIVO,
                                                           P_OFO_CFO_FON_CODIGO        => C_OFO.OFO_CFO_FON_CODIGO,
                                                           P_OFO_TTO_TOF_CODIGO        => C_OFO.OFO_TTO_TOF_CODIGO,
                                                           P_EXC                       => P_EXC,
                                                           P_TIPO                      => 'P',
                                                           P_COMPARTIMENTO_B           => P_FONDO_COMPARTIMENTO,
                                                           P_FON_PADRE_COMPARTIMENTO_B => P_FON_PADRE_COMPARTIMENTO,
                                                           P_ESTADO                    => 'APR');
                    END IF;

                    /* Verifica si el retiro total es un traslado entre fondos. Si es asi no se inserta movimiento
                    en MOVIMIENTOS_CARGOS_ABONO para que en la aprobaciżn de la noche se genere todo el monto
                    con fecha de dia siguiente */

                    OPEN C_RETIRO_TRASLADO;
                    FETCH C_RETIRO_TRASLADO
                      INTO TRASLADO;
                    CLOSE C_RETIRO_TRASLADO;
                    IF NVL(TRASLADO, ' ') = ' ' THEN
                      IF V_DIAS_PAGO > 0 AND
                         TRUNC(C_OFO.OFO_FECHA_CUMPLIMIENTO) >
                         TRUNC(C_OFO.OFO_FECHA_EJECUCION) AND
                         C_OFO.OFO_FECHA_CUMPLIMIENTO IS NOT NULL THEN
                        NULL;
                      ELSE
                        P_ORDENES_FONDOS.ABONO_CARGO_CUENTA(C_OFO.OFO_SUC_CODIGO,
                                                            C_OFO.OFO_CONSECUTIVO,
                                                            C_OFO.OFO_CFO_CCC_cLI_PER_NUM_IDEN,
                                                            C_OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO,
                                                            C_OFO.OFO_CFO_CCC_NUMERO_CUENTA,
                                                            C_OFO.OFO_CFO_FON_CODIGO,
                                                            C_OFO.OFO_CFO_CODIGO,
                                                            P_EXC,
                                                            'A',
                                                            'RT');
                      END IF;
                    END IF;
                  END IF;
                  UPDATE ORDENES_FONDOS
                     SET OFO_EOF_CODIGO     = 'CON',
                         OFO_MONTO_ANTICIPO = MONTO_ANTICIPO
                   WHERE OFO_SUC_CODIGO = C_OFO.OFO_SUC_CODIGO
                     AND OFO_CONSECUTIVO = C_OFO.OFO_CONSECUTIVO;
                ELSE
                  IF P_ORDEN IS NOT NULL THEN
                    RAISE SALDO_INSUFICIENTE;
                  END IF;
                END IF;
                /*
                **
                ** RETIRO PARCIAL
                **
                */
              ELSIF C_OFO.OFO_TTO_TOF_CODIGO = 'RP' THEN
                SALDO_RETIROS := 0;
                OPEN CANT_ORDEN1;
                FETCH CANT_ORDEN1
                  INTO SALDO_RETIROS;
                CLOSE CANT_ORDEN1;
                SALDO_RETIROS  := NVL(SALDO_RETIROS, 0) - C_OFO.OFO_MONTO;
                SALDO_INGRESOS := 0;
                OPEN CANT_ORDEN2;
                FETCH CANT_ORDEN2
                  INTO SALDO_INGRESOS;
                CLOSE CANT_ORDEN2;
                SAL.SAL_INV := (NVL(SAL.SAL_INV, 0) +
                               NVL(SALDO_INGRESOS, 0)) -
                               NVL(SALDO_RETIROS, 0);
                RP_PRC      := C_OFO.OFO_MONTO / SAL.SAL_INV;
                IF (C_OFO.OFO_MONTO < SAL.SAL_INV) THEN
                  IF BASE_MONETARIA = 'PESOS' THEN
                    P_ORDENES_FONDOS.APROBAR_ORDENES_PAGO(C_OFO.OFO_SUC_CODIGO,
                                                          C_OFO.OFO_CONSECUTIVO,
                                                          'RP',
                                                          P_T0);
                    IF V_DIAS_PAGO > 0 AND TRUNC(C_OFO.OFO_FECHA_CUMPLIMIENTO) >
                       TRUNC(C_OFO.OFO_FECHA_EJECUCION) AND
                       C_OFO.OFO_FECHA_CUMPLIMIENTO IS NOT NULL THEN
                      NULL;
                    ELSE
                      P_ORDENES_FONDOS.MOVIMIENTO_BANCARIO(P_OFO_SUC_CODIGO            => C_OFO.OFO_SUC_CODIGO,
                                                           P_OFO_CONSECUTIVO           => C_OFO.OFO_CONSECUTIVO,
                                                           P_OFO_CFO_FON_CODIGO        => C_OFO.OFO_CFO_FON_CODIGO,
                                                           P_OFO_TTO_TOF_CODIGO        => C_OFO.OFO_TTO_TOF_CODIGO,
                                                           P_EXC                       => P_EXC,
                                                           P_TIPO                      => 'P',
                                                           P_COMPARTIMENTO_B           => P_FONDO_COMPARTIMENTO,
                                                           P_FON_PADRE_COMPARTIMENTO_B => P_FON_PADRE_COMPARTIMENTO,
                                                           P_ESTADO                    => 'APR');
                      P_ORDENES_FONDOS.ABONO_CARGO_CUENTA(C_OFO.OFO_SUC_CODIGO,
                                                          C_OFO.OFO_CONSECUTIVO,
                                                          C_OFO.OFO_CFO_CCC_CLI_PER_NUM_IDEN,
                                                          C_OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO,
                                                          C_OFO.OFO_CFO_CCC_NUMERO_CUENTA,
                                                          C_OFO.OFO_CFO_FON_CODIGO,
                                                          C_OFO.OFO_CFO_CODIGO,
                                                          P_EXC,
                                                          'A',
                                                          'RP');
                      P_ORDENES_FONDOS.INSERTAR_MOVIMIENTO_CORREDORES(C_OFO.OFO_CFO_CCC_CLI_PER_NUM_IDEN,
                                                                      C_OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO,
                                                                      C_OFO.OFO_CFO_CCC_NUMERO_CUENTA,
                                                                      C_OFO.OFO_MONTO,
                                                                      C_OFO.OFO_CONSECUTIVO,
                                                                      C_OFO.OFO_SUC_CODIGO,
                                                                      'RP');
                    END IF;
                  END IF;
                  UPDATE ORDENES_FONDOS
                     SET OFO_EOF_CODIGO = 'CON'
                   WHERE OFO_SUC_CODIGO = C_OFO.OFO_SUC_CODIGO
                     AND OFO_CONSECUTIVO = C_OFO.OFO_CONSECUTIVO;
                ELSE
                  IF P_ORDEN IS NOT NULL THEN
                    RAISE SALDO_INSUFICIENTE;
                  END IF;
                END IF;
              END IF; -- TERMINA TIPOS DE OPERACIONES
            END IF; -- IF CONDI = 'S'
          END IF; -- IF PROCESAR = 'S'

        EXCEPTION
          -- EXCEPTION SAVEPOINT
          WHEN SALDO_INSUFICIENTE THEN

            ROLLBACK TO SV_CONFIRMA_ORDENES_FONDOS;

            P_OPERACIONES.INSERTA_ERROR(P_PROCESO     => 'P_PROCESOS_NOCTURNOS.P_CONFIRMA_ORDEN_FONDOS',
                                        P_ERROR       => 'Saldo insuficiente Fondo ' ||
                                                         C_OFO.OFO_CFO_FON_CODIGO ||
                                                         ' Sucursal ' ||
                                                         C_OFO.OFO_SUC_CODIGO ||
                                                         ' Orden ' ||
                                                         C_OFO.OFO_CONSECUTIVO,
                                        P_TABLA_ERROR => NULL);
             --Registra Traza ERROR
              P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                              'E',
                                              'P_PROCESOS_NOCTURNOS.P_CONFIRMA_ORDEN_FONDOS. '||
                                              'Saldo insuficiente Fondo ' ||
                                                         C_OFO.OFO_CFO_FON_CODIGO ||
                                                         ' Sucursal ' ||
                                                         C_OFO.OFO_SUC_CODIGO ||
                                                         ' Orden ' ||
                                                         C_OFO.OFO_CONSECUTIVO||'Fecha: ' ||
                                              TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss') ,
                                              N_TX);                                        
          WHEN OTHERS THEN

            ROLLBACK TO SV_CONFIRMA_ORDENES_FONDOS;

            P_OPERACIONES.INSERTA_ERROR(P_PROCESO     => 'P_PROCESOS_NOCTURNOS.P_CONFIRMA_ORDEN_FONDOS',
                                        P_ERROR       => 'Fondo ' ||
                                                         C_OFO.OFO_CFO_FON_CODIGO ||
                                                         ' Sucursal ' ||
                                                         C_OFO.OFO_SUC_CODIGO ||
                                                         ' Orden ' ||
                                                         C_OFO.OFO_CONSECUTIVO ||
                                                         ' Identificacion cliente ' ||
                                                         C_OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO || '-' ||
                                                         C_OFO.OFO_CFO_CCC_CLI_PER_NUM_IDEN ||
                                                         ' Monto ' ||
                                                         C_OFO.OFO_MONTO || ' ' ||
                                                         SUBSTR(SQLERRM,
                                                                1,
                                                                400),
                                        P_TABLA_ERROR => NULL);
                --Registra Traza ERROR
              P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                              'E',
                                              'Error en procedimiento de confirmar_ordenes_fondos ' ||
                                              C_OFO.OFO_CFO_FON_CODIGO ||
                                              ' Sucursal ' || C_OFO.OFO_SUC_CODIGO ||
                                              ' Orden ' || C_OFO.OFO_CONSECUTIVO||' '||
                                              TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss') || ' ' ||
                                              SUBSTR(SQLERRM, 1, 150),
                                              N_TX);                                            

        END; --END SAVEPOINT
        FETCH C_ORDENES
          INTO C_OFO;
      END LOOP;
      CLOSE C_ORDENES;

      IF P_FLAG_ERROR = 'S' THEN

        -- SE PREPARA MENSAJE SOBRE INACTIVACION DE PARTICIPACION
        P_CLI_PER_TID_CODIGO := '0';
        P_CLI_PER_NUM_IDEN   := '0';
        P_SERVICIO           := 'NO_PROCESO_CONFIRMACION_ORD';
        P_DE                 := 'notificaciones@corredores.com';
        P_PARA               := 'fondosdeinversion@corredores.com';
        P_ASUNTO             := 'Listado de Ordenes no Confirmadas por el proceso nocturno';
        P_MENSAJE            := 'No se confirmaron las siguientes ordenes: ' ||
                                P_NOTIFICA_ERROR;

        -- SE ENVIA MENSAJE SOBRE INACTIVACION DE PARTICIPACION
        P_NOTIFICACIONES_MAIL.PR_ENVIO_MAIL(P_CLI_PER_TID_CODIGO,
                                            P_CLI_PER_NUM_IDEN,
                                            P_SERVICIO,
                                            P_DE,
                                            P_PARA,
                                            P_ASUNTO,
                                            P_MENSAJE,
                                            P_CLOB,
                                            P_MENSAJE_CLOB);
      END IF;

      --INICIO PROCESO PARA CONFIRMAR T+N

      OPEN C_ORDENES_TN;
      FETCH C_ORDENES_TN
        INTO C_OFO_TN;
      WHILE C_ORDENES_TN%FOUND LOOP
        BEGIN
          SAVEPOINT SV_CONFIRMA_ORDENES_FONDOS_TN;
          P_FONDO_COMPARTIMENTO := 'N';
          P_ORDENES_FONDOS.P_VALIDA_PARAMETROS_COMP(P_FON_CODIGO         => C_OFO_TN.OFO_CFO_FON_CODIGO,
                                                    P_PAR_CODIGO         => 70,
                                                    P_PFO_RANGO_MIN_CHAR => P_FONDO_COMPARTIMENTO);

          P_FONDO_COMPARTIMENTO := NVL(P_FONDO_COMPARTIMENTO, 'N');

          IF NVL(P_FONDO_COMPARTIMENTO, 'N') = 'S' THEN
            P_ORDENES_FONDOS.P_VALIDA_PARAMETROS_COMP(P_FON_CODIGO         => C_OFO_TN.OFO_CFO_FON_CODIGO,
                                                      P_PAR_CODIGO         => 71,
                                                      P_PFO_RANGO_MIN_CHAR => P_FON_PADRE_COMPARTIMENTO);
            IF P_FON_PADRE_COMPARTIMENTO IS NULL THEN
              P_FON_PADRE_COMPARTIMENTO := 'N';
            END IF;
          END IF;

          OPEN EXCENTO_TN;
          FETCH EXCENTO_TN
            INTO COND_EXC_TN;
          CLOSE EXCENTO_TN;
          P_EXC := NVL(COND_EXC_TN, 'N');

          /* VERIFICACION DE A QUE TIPO CORRESPONDE LA ORDEN */
          /*
          **
          */

          -- INICIO OMORA CUENTA UNICA
          -- VERIFICA EL TIPO DE PAGO
          OPEN C_ORDEN_PAGO(C_OFO_TN.OFO_CONSECUTIVO,
                            C_OFO_TN.OFO_SUC_CODIGO);
          FETCH C_ORDEN_PAGO
            INTO P_TPA_MNEMONICO;
          CLOSE C_ORDEN_PAGO;

          -- VERIFICA EL TIPO DE MOVIMIENTO
          OPEN C_DESCRIPCION_MOVIMIENTO(P_TPA_MNEMONICO);
          FETCH C_DESCRIPCION_MOVIMIENTO
            INTO TTE1;
          CLOSE C_DESCRIPCION_MOVIMIENTO;
          TIPO_MOV_MOTEFO := TTE1.TTE_MNEMONICO;

          -- VERIFICA SI EXISTE MOTEFO
          OPEN C_EXISTE_MOTEFO(C_OFO_TN.OFO_CONSECUTIVO,
                               C_OFO_TN.OFO_SUC_CODIGO,
                               TIPO_MOV_MOTEFO);
          FETCH C_EXISTE_MOTEFO
            INTO P_CONTADOR_MOTEFO;
          CLOSE C_EXISTE_MOTEFO;

          -- VERIFICA SI EXISTE COMOCO
          IF C_OFO_TN.OFO_TTO_TOF_CODIGO = 'RP' THEN
            TIPO_MOV_COMOCO := 'ARPF';
          ELSIF C_OFO_TN.OFO_TTO_TOF_CODIGO = 'RT' THEN
            TIPO_MOV_COMOCO := 'ARTF';
          END IF;

          OPEN C_EXISTE_COMOCO(C_OFO_TN.OFO_CONSECUTIVO,
                               C_OFO_TN.OFO_SUC_CODIGO,
                               TIPO_MOV_COMOCO);
          FETCH C_EXISTE_COMOCO
            INTO P_CONTADOR_COMOCO;
          CLOSE C_EXISTE_COMOCO;
          -- FIN OMORA CUENTA UNICA

          IF C_OFO_TN.OFO_TTO_TOF_CODIGO = 'RP' THEN
            IF P_CONTADOR_MOTEFO = 0 THEN
              -- OMORA CUENTA UNICA
              P_ORDENES_FONDOS.MOVIMIENTO_BANCARIO(P_OFO_SUC_CODIGO            => C_OFO_TN.OFO_SUC_CODIGO,
                                                   P_OFO_CONSECUTIVO           => C_OFO_TN.OFO_CONSECUTIVO,
                                                   P_OFO_CFO_FON_CODIGO        => C_OFO_TN.OFO_CFO_FON_CODIGO,
                                                   P_OFO_TTO_TOF_CODIGO        => C_OFO_TN.OFO_TTO_TOF_CODIGO,
                                                   P_EXC                       => P_EXC,
                                                   P_TIPO                      => 'P',
                                                   P_COMPARTIMENTO_B           => P_FONDO_COMPARTIMENTO,
                                                   P_FON_PADRE_COMPARTIMENTO_B => P_FON_PADRE_COMPARTIMENTO,
                                                   P_ESTADO                    => 'APR');
              P_ORDENES_FONDOS.ABONO_CARGO_CUENTA(C_OFO_TN.OFO_SUC_CODIGO,
                                                  C_OFO_TN.OFO_CONSECUTIVO,
                                                  C_OFO_TN.OFO_CFO_CCC_CLI_PER_NUM_IDEN,
                                                  C_OFO_TN.OFO_CFO_CCC_CLI_PER_TID_CODIGO,
                                                  C_OFO_TN.OFO_CFO_CCC_NUMERO_CUENTA,
                                                  C_OFO_TN.OFO_CFO_FON_CODIGO,
                                                  C_OFO_TN.OFO_CFO_CODIGO,
                                                  P_EXC,
                                                  'A',
                                                  'RP');
            END IF; -- OMORA

            IF P_CONTADOR_COMOCO = 0 THEN
              -- OMORA CUENTA UNICA
              P_ORDENES_FONDOS.INSERTAR_MOVIMIENTO_CORREDORES(C_OFO_TN.OFO_CFO_CCC_CLI_PER_NUM_IDEN,
                                                              C_OFO_TN.OFO_CFO_CCC_CLI_PER_TID_CODIGO,
                                                              C_OFO_TN.OFO_CFO_CCC_NUMERO_CUENTA,
                                                              C_OFO_TN.OFO_MONTO,
                                                              C_OFO_TN.OFO_CONSECUTIVO,
                                                              C_OFO_TN.OFO_SUC_CODIGO,
                                                              'RP');
            END IF; -- OMORA
          ELSIF C_OFO_TN.OFO_TTO_TOF_CODIGO = 'RT' THEN
            IF P_CONTADOR_MOTEFO = 0 THEN
              -- OMORA CUENTA UNICA
              P_ORDENES_FONDOS.MOVIMIENTO_BANCARIO(P_OFO_SUC_CODIGO            => C_OFO_TN.OFO_SUC_CODIGO,
                                                   P_OFO_CONSECUTIVO           => C_OFO_TN.OFO_CONSECUTIVO,
                                                   P_OFO_CFO_FON_CODIGO        => C_OFO_TN.OFO_CFO_FON_CODIGO,
                                                   P_OFO_TTO_TOF_CODIGO        => C_OFO_TN.OFO_TTO_TOF_CODIGO,
                                                   P_EXC                       => P_EXC,
                                                   P_TIPO                      => 'P',
                                                   P_COMPARTIMENTO_B           => P_FONDO_COMPARTIMENTO,
                                                   P_FON_PADRE_COMPARTIMENTO_B => P_FON_PADRE_COMPARTIMENTO,
                                                   P_ESTADO                    => 'APR');

              P_ORDENES_FONDOS.ABONO_CARGO_CUENTA(C_OFO_TN.OFO_SUC_CODIGO,
                                                  C_OFO_TN.OFO_CONSECUTIVO,
                                                  C_OFO_TN.OFO_CFO_CCC_cLI_PER_NUM_IDEN,
                                                  C_OFO_TN.OFO_CFO_CCC_CLI_PER_TID_CODIGO,
                                                  C_OFO_TN.OFO_CFO_CCC_NUMERO_CUENTA,
                                                  C_OFO_TN.OFO_CFO_FON_CODIGO,
                                                  C_OFO_TN.OFO_CFO_CODIGO,
                                                  P_EXC,
                                                  'A',
                                                  'RT',
                                                  'S');
            END IF; -- OMORA

            IF P_CONTADOR_COMOCO = 0 THEN
              -- OMORA CUENTA UNICA
              P_ORDENES_FONDOS.INSERTAR_MOVIMIENTO_CORREDORES(C_OFO_TN.OFO_CFO_CCC_CLI_PER_NUM_IDEN,
                                                              C_OFO_TN.OFO_CFO_CCC_CLI_PER_TID_CODIGO,
                                                              C_OFO_TN.OFO_CFO_CCC_NUMERO_CUENTA,
                                                              C_OFO_TN.OFO_MONTO,
                                                              C_OFO_TN.OFO_CONSECUTIVO,
                                                              C_OFO_TN.OFO_SUC_CODIGO,
                                                              'RT');
            END IF; -- OMORA

            OPEN C_VERIF_ACO_TN;
            FETCH C_VERIF_ACO_TN
              INTO R_VERIF_ACO_TN;
            V_TOTAL_ABO_TN := NVL(R_VERIF_ACO_TN.DAA_VALOR, 0);
            CLOSE C_VERIF_ACO_TN;
            IF V_TOTAL_ABO_TN != 0 THEN
              P_ORDENES_FONDOS.INSERTAR_MOVIMIENTO_CORR_CAAB(C_OFO_TN.OFO_CFO_CCC_CLI_PER_NUM_IDEN,
                                                             C_OFO_TN.OFO_CFO_CCC_CLI_PER_TID_CODIGO,
                                                             C_OFO_TN.OFO_CFO_CCC_NUMERO_CUENTA,
                                                             V_TOTAL_ABO_TN,
                                                             C_OFO_TN.OFO_CONSECUTIVO,
                                                             C_OFO_TN.OFO_SUC_CODIGO,
                                                             'RT');
            END IF;
          END IF; -- TERMINA TIPOS DE OPERACIONES

        EXCEPTION
          -- EXCEPTION SAVEPOINT
          WHEN OTHERS THEN
            ROLLBACK TO SV_CONFIRMA_ORDENES_FONDOS_TN;
            P_OPERACIONES.INSERTA_ERROR(P_PROCESO     => 'P_PROCESOS_NOCTURNOS.P_CONFIRMA_ORDEN_FONDOS TN',
                                        P_ERROR       => 'Fondo ' ||
                                                         C_OFO_TN.OFO_CFO_FON_CODIGO ||
                                                         ' Sucursal ' ||
                                                         C_OFO_TN.OFO_SUC_CODIGO ||
                                                         ' Orden ' ||
                                                         C_OFO_TN.OFO_CONSECUTIVO ||
                                                         ' Identificaciżn cliente ' ||
                                                         C_OFO_TN.OFO_CFO_CCC_CLI_PER_TID_CODIGO || '-' ||
                                                         C_OFO_TN.OFO_CFO_CCC_CLI_PER_NUM_IDEN ||
                                                         ' Monto ' ||
                                                         C_OFO_TN.OFO_MONTO || ' ' ||
                                                         SUBSTR(SQLERRM,
                                                                1,
                                                                400),
                                        P_TABLA_ERROR => NULL);

                    --Registra Traza ERROR
              P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                              'E',
                                              'Error en procedimiento de confirmar_ordenes_fondos ' ||
                                              C_OFO.OFO_CFO_FON_CODIGO ||
                                              ' Sucursal ' || C_OFO.OFO_SUC_CODIGO ||
                                              ' Orden ' || C_OFO.OFO_CONSECUTIVO||' '||
                                              TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss') || ' ' ||
                                              SUBSTR(SQLERRM, 1, 150),
                                              N_TX);                                            



        END; --END SAVEPOINT
        FETCH C_ORDENES_TN
          INTO C_OFO_TN;
      END LOOP;
      CLOSE C_ORDENES_TN;

      --
      SELECT COUNT(1)
        INTO V_EXISTE
        FROM ERRORES_PROCESOS
       WHERE ERP_PROCESO LIKE
             'P_PROCESOS_NOCTURNOS.P_CONFIRMA_ORDEN_FONDOS%'
         AND ERP_FECHA_ERROR >= TRUNC(SYSDATE)
         AND ERP_FECHA_ERROR < TRUNC(SYSDATE + 1)
         AND ERP_TABLA_ERROR IS NULL;

      IF V_EXISTE > 0 THEN
        --
        V_ARCHIVO := 'ERROR_CONFIRMA_ORDEN_FONDO_' ||
                     TO_CHAR(SYSDATE, 'DDMONYYYY');

        CONN := P_MAIL.BEGIN_MAIL(SENDER     => 'Administrador@corredores.com',
                                  RECIPIENTS => DESTINATARIOS_CONF_ORDEN_FOND,
                                  SUBJECT    => 'Informacion - Confirma Orden Fondos',
                                  MIME_TYPE  => P_MAIL.MULTIPART_MIME_TYPE);

        P_MAIL.ATTACH_TEXT(CONN      => CONN,
                           DATA      => '<html>' || '<head>' ||
                                        '<IMG src=https://zonatransaccional.corredores.com/CorredoresEnLinea/App_Themes/Default/images/imagen_header.jpg>' ||
                                        '</head>' || '<body FACE=arial> ' ||
                                        '<table>' ||
                                        '<font size=2 face=Arial Black>' ||
                                        '<br/><br/><br/><br/>' ||
                                        'Estamos remitiendo informacion de las ordenes a confirmar en los fondos que no se pudieron procesar' ||
                                        '<br/><br/><br/><br/>' ||
                                        ' Atentamente,' ||
                                        '<br/><br/><br/><br/>' || '<B>' ||
                                        'DAVIVIENDA CORREDORES' || '</B>' ||
                                        '<br/><br/><br/><br/><br/><br/>' ||
                                        '<br/><br/><br/>' || '</td>' ||
                                        '</font>' || '<table>' || '</body>' ||
                                        '</html>',
                           MIME_TYPE => 'text/html');

        P_MAIL.BEGIN_ATTACHMENT(CONN         => CONN,
                                MIME_TYPE    => V_ARCHIVO || '/csv',
                                INLINE       => TRUE,
                                FILENAME     => V_ARCHIVO || '.csv',
                                TRANSFER_ENC => 'text');

        V_NOMBRE_ARCHIVO := V_ARCHIVO;

        EXTRACTO_ARCHIVO := UTL_FILE.FOPEN('LOG_DIR', V_NOMBRE_ARCHIVO, 'W');

        V_LINEA := 'PROCESO' || ';' || 'ERROR';
        P_MAIL.WRITE_MB_TEXT(CONN, V_LINEA || CRLF);
        UTL_FILE.PUT_LINE(EXTRACTO_ARCHIVO, V_LINEA);
        OPEN C_ERRORES_PROCESOS;
        FETCH C_ERRORES_PROCESOS
          INTO ERP;
        WHILE C_ERRORES_PROCESOS%FOUND LOOP

          V_LINEA := ERP.ERP_PROCESO || ';' || ERP.ERP_ERROR;

          P_MAIL.WRITE_MB_TEXT(CONN, V_LINEA || CRLF);
          UTL_FILE.PUT_LINE(EXTRACTO_ARCHIVO, V_LINEA);

          UPDATE ERRORES_PROCESOS
             SET ERP_TABLA_ERROR = 'OK'
           WHERE ROWID = ERP.RID;

          FETCH C_ERRORES_PROCESOS
            INTO ERP;
        END LOOP;
        CLOSE C_ERRORES_PROCESOS;

        P_MAIL.END_ATTACHMENT(CONN => CONN);
        UTL_FILE.FCLOSE(EXTRACTO_ARCHIVO);

        P_MAIL.END_MAIL(CONN => CONN);
        --
      END IF;
      --

      COMMIT;

        COMMIT;
      -- Registrar traza FIN
      P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                'T',
                                'Fin proceso nocturno Confirmar_Ordenes_Fondos. Fecha Proceso: ' ||
                                TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss'),
                                N_TX);

    EXCEPTION
      WHEN OTHERS THEN
           --Registra Traza ERROR
              P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                              'E',
                                              'Error en procedimiento de confirmar_ordenes_fondos ' ||
                                              C_OFO.OFO_CFO_FON_CODIGO ||
                                              ' Sucursal ' || C_OFO.OFO_SUC_CODIGO ||
                                              ' Orden ' || C_OFO.OFO_CONSECUTIVO||' '||
                                              TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss') || ' ' ||
                                              SUBSTR(SQLERRM, 1, 150),
                                              N_TX);   
    END; -- VAGTUD941 FINALIZA BLOQUE DE PROCESO DE CONFIRMACION DE ORDENES

    -- VAGTUD941
    -- SE ADICIONA PROCESO DE COMPENSACION PARA ORDENES APLAZADAS DE FONDOS CON PARAMETRO 146 ACTIVADO
    BEGIN
      DECLARE
        V_PROCESO VARCHAR2(500);
      BEGIN
        V_PROCESO := 'PR_COMPENSAR_CBF_OTN';
        -- Registrar traza INICIO
        P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                  'T',
                                  'Registro Inicio llamado al proceso P_ORDENES_FONDOS.PR_COMPENSAR_CBF_OTN. Fecha Proceso: ' ||
                                  TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss'),
                                  N_TX);
          P_ORDENES_FONDOS.PR_COMPENSAR_CBF_OTN(N_TX);

          P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                      'T',
                                      'Registro Fin llamado proceso al P_ORDENES_FONDOS.PR_COMPENSAR_CBF_OTN. Fecha Proceso: ' ||
                                      TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss'),
                                      N_TX);                                                          

        -- VAGTUD941-3 SE ADICIONAN LOS SIGUIENTES PROCESOS DE COMPENSACION OTN
        V_PROCESO := 'PR_COMPENSA_PROD_OTN';
        P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                  'T',
                                  'Registro Inicio llamado proceso al P_ORDENES_FONDOS.PR_COMPENSA_PROD_OTN. Fecha Proceso: ' ||
                                  TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss'),
                                  N_TX);

         P_ORDENES_FONDOS.PR_COMPENSA_PROD_OTN(N_TX);

        P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                      'T',
                                      'Regisro Fin llamado proceso P_ORDENES_FONDOS.PR_COMPENSA_PROD_OTN. Fecha Proceso: ' ||
                                      TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss'),
                                      N_TX);                                                   

        V_PROCESO := 'PR_COMPENSA_FICS_OTN';

         P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                        'T',
                                        'Registro Inicio llamado al proceso P_ORDENES_FONDOS.PR_COMPENSA_FICS_OTN. Fecha Proceso: ' ||
                                        TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss'),
                                        N_TX);                                                          

        P_ORDENES_FONDOS.PR_COMPENSA_FICS_OTN(N_TX);

        P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                      'T',
                                      'Registro Fin llamado al proceso P_ORDENES_FONDOS.PR_COMPENSA_FICS_OTN. Fecha Proceso: ' ||
                                      TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss'),
                                      N_TX);    
         -- FIN VAGTUD941-3

      EXCEPTION
        WHEN OTHERS THEN
          P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                                'E',
                                                'ERROR proceso P_ORDENES_FONDOS.P_CONFIRMA_ORDEN_FONDOS. Fecha Proceso: ' ||
                                                TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss')||'-'||SQLERRM,
                                                N_TX);                                    
      END;

    END;
    -- FIN VAGTUD941
     --Registra Traza
      P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                      'F',
                                      'Fin proceso P_PROCESOS_NOCTURNOS.P_CONFIRMA_ORDEN_FONDOS. Fecha Proceso: ' ||
                                      TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss'),
                                      N_TX);

  END P_CONFIRMA_ORDEN_FONDOS;
  -- -----------------------------------------------------------------------------------
 PROCEDURE P_BORRADO_CENLINEA IS
    P_FECHA   DATE;
    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_BORRADO_CENLINEA',
                                                      'INI');

    BEGIN
      P_MAIL.ENVIO_MAIL_ERROR('Inicio proceso nocturno P_BORRADO_CENLINEA ',
                              '<br>' || 'Fecha Proceso: ' || SYSDATE,
                              DESTINATARIOS);
    EXCEPTION
      WHEN OTHERS THEN
        DBMS_OUTPUT.PUT_LINE('-20001 Fallo el llamado al paquete de Mail. ' ||
                             SQLERRM);
    END;
    --- DEJAR EN PROCESO HISTPORICO LOS ULTIMOS 30 DIAS
    P_FECHA := SYSDATE - 7;
    DELETE CENLINEA_NOTIFICA_RV
     WHERE CNRV_FECHA_INGRESO >= ADD_MONTHS(P_FECHA, -2)
       AND CNRV_FECHA_INGRESO < P_FECHA;
    DELETE CENLINEA_PRECIOS_MERCADO_RV
     WHERE CMRV_FECHA_INGRESO >= ADD_MONTHS(P_FECHA, -2)
       AND CMRV_FECHA_INGRESO < P_FECHA;
    DELETE PRECIOS_MERCADO_RV
     WHERE PMRV_FECHA_INGRESO >= ADD_MONTHS(P_FECHA, -2)
       AND PMRV_FECHA_INGRESO < P_FECHA;
    DELETE CENLINEA_NOTIFICA_RF
     WHERE CNRF_FECHA_INGRESO >= ADD_MONTHS(P_FECHA, -2)
       AND CNRF_FECHA_INGRESO < P_FECHA;
    DELETE PRECIOS_MERCADO_RF
     WHERE PMRF_FECHA_INGRESO >= ADD_MONTHS(P_FECHA, -2)
       AND PMRF_FECHA_INGRESO < P_FECHA;
    DELETE CENLINEA_PRECIOS_MERCADO_RF
     WHERE CMRF_FECHA_INGRESO >= ADD_MONTHS(P_FECHA, -2)
       AND CMRF_FECHA_INGRESO < P_FECHA;
    DELETE CENLINEA_NOTIFICA_DIV
     WHERE CNDV_FECHA_INGRESO >= ADD_MONTHS(P_FECHA, -2)
       AND CNDV_FECHA_INGRESO < P_FECHA;
    DELETE CENLINEA_PRECIOS_MERCADO_DIV
     WHERE CMDI_FECHA_INGRESO >= ADD_MONTHS(P_FECHA, -2)
       AND CMDI_FECHA_INGRESO < P_FECHA;
    DELETE PRECIOS_MERCADO_DIV
     WHERE PMDI_FECHA_INGRESO >= ADD_MONTHS(P_FECHA, -2)
       AND PMDI_FECHA_INGRESO < P_FECHA;
    DELETE CENLINEA_NOTIFICA_DER
     WHERE CNDE_FECHA_INGRESO >= ADD_MONTHS(P_FECHA, -2)
       AND CNDE_FECHA_INGRESO < P_FECHA;
    DELETE CENLINEA_PRECIOS_MERCADO_DER
     WHERE CMDE_FECHA_INGRESO >= ADD_MONTHS(P_FECHA, -2)
       AND CMDE_FECHA_INGRESO < P_FECHA;
    DELETE PRECIOS_MERCADO_DER
     WHERE PMDE_FECHA_INGRESO >= ADD_MONTHS(P_FECHA, -2)
       AND PMDE_FECHA_INGRESO < P_FECHA;
    DELETE CENLINEA_FLUJOS_RF
     WHERE CNFR_FECHA_INGRESO >= ADD_MONTHS(P_FECHA, -2)
       AND CNFR_FECHA_INGRESO < P_FECHA;
    DELETE CENLINEA_NOTIFICA_CANJE_DIV
     WHERE CNCD_FECHA_INGRESO >= ADD_MONTHS(P_FECHA, -2)
       AND CNCD_FECHA_INGRESO < P_FECHA;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_BORRADO_CENLINEA',
                                                      'FIN');
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento de borrado historico de controles en linea' ||
                              SUBSTR(SQLERRM, 1, 80),
                              DESTINATARIOS);
  END P_BORRADO_CENLINEA;
  -- ----------------------------------------------------------------------------------------------
  PROCEDURE P_SALDOS_DIARIOS_DIVISAS(FINICIO IN DATE,
                                     FFIN    IN DATE,
                                     P_TX    IN NUMBER DEFAULT NULL) IS

    CURSOR CLIENTE_DIV IS
      SELECT SCM_CCC_CLI_PER_NUM_IDEN,
             SCM_CCC_CLI_PER_TID_CODIGO,
             SCM_CCC_NUMERO_CUENTA
        FROM SALDOS_CLIENTES_MONETIZAR;
    C_CLIENTE CLIENTE_DIV%ROWTYPE;

    CURSOR C_ULTIMO_MVTO(P_FECHA DATE) IS
      SELECT M.MCM_SALDO_MONETIZAR
        FROM MOVIMIENTOS_CLIENTES_MONETIZAR M
       WHERE M.MCM_SCM_CCC_CLI_PER_NUM_IDEN =
             C_CLIENTE.SCM_CCC_CLI_PER_NUM_IDEN
         AND M.MCM_SCM_CCC_CLI_PER_TID_CODIGO =
             C_CLIENTE.SCM_CCC_CLI_PER_TID_CODIGO
         AND M.MCM_SCM_CCC_NUMERO_CUENTA = C_CLIENTE.SCM_CCC_NUMERO_CUENTA
         AND M.MCM_SECUENCIA =
             (SELECT MAX(M1.MCM_SECUENCIA)
                FROM MOVIMIENTOS_CLIENTES_MONETIZAR M1
               WHERE M1.MCM_SCM_CCC_CLI_PER_NUM_IDEN =
                     M.MCM_SCM_CCC_CLI_PER_NUM_IDEN
                 AND M1.MCM_SCM_CCC_CLI_PER_TID_CODIGO =
                     M.MCM_SCM_CCC_CLI_PER_TID_CODIGO
                 AND M1.MCM_SCM_CCC_NUMERO_CUENTA =
                     M.MCM_SCM_CCC_NUMERO_CUENTA
                 AND M1.MCM_FECHA <= TRUNC(P_FECHA) + 1);
    MVTO NUMBER;

    V_SECUENCIA NUMBER;
    FECHA       DATE;

    P_NUM_INI    NUMBER;
    P_NUM_FIN    NUMBER;
    N_ID_PROCESO NUMBER;
    N_TX         NUMBER;

  BEGIN


    N_ID_PROCESO := P_TRAZA_CORE.FN_ID_PROCESO('P_PROCESOS_NOCTURNOS.P_SALDOS_DIARIOS_DIVISAS');

    --se Asigna consecutivo para la transaccion, si el proceso es el primero que se llama, reinicia el consecutivo
    N_TX := P_TRAZA_CORE.FN_TRAE_TX(P_TX);

    --Registra Traza
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'I',
                                    'Inicio proceso P_PROCESOS_NOCTURNOS.P_SALDOS_DIARIOS_DIVISAS. Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE,
                                            'DD-MM-YYYY HH24:mi:ss') ||
                                    ' Rango de fechas procesado: ' ||
                                    TO_CHAR(FINICIO, 'DD-MON-YYYY') ||
                                    ' a ' || TO_CHAR(FFIN, 'DD-MON-YYYY'),
                                    N_TX);

    DELETE FROM SALDOS_CLIENTES_DIVISAS
     WHERE SDV_FECHA_SALDO >= TRUNC(FINICIO)
       AND SDV_FECHA_SALDO < TRUNC(FFIN + 1);

    FECHA := TRUNC(FINICIO);

    WHILE FECHA <= TRUNC(FFIN) LOOP
      OPEN CLIENTE_DIV;
      FETCH CLIENTE_DIV
        INTO C_CLIENTE;
      WHILE CLIENTE_DIV%FOUND LOOP

        OPEN C_ULTIMO_MVTO(P_FECHA => FECHA);
        FETCH C_ULTIMO_MVTO
          INTO MVTO;
        IF C_ULTIMO_MVTO%FOUND THEN

          SELECT SDV_SEQ.NEXTVAL INTO V_SECUENCIA FROM DUAL;

          INSERT INTO SALDOS_CLIENTES_DIVISAS
            (SDV_CONSECUTIVO,
             SDV_MCM_SECUENCIA,
             SDV_SCM_CCC_CLI_PER_NUM_IDEN,
             SDV_SCM_CCC_CLI_PER_TID_CODIGO,
             SDV_SCM_CCC_NUMERO_CUENTA,
             SDV_FECHA_SALDO,
             SDV_SALDO,
             SDV_FECHA_PROCESO)
          VALUES
            (V_SECUENCIA,
             NULL,
             C_CLIENTE.SCM_CCC_CLI_PER_NUM_IDEN,
             C_CLIENTE.SCM_CCC_CLI_PER_TID_CODIGO,
             C_CLIENTE.SCM_CCC_NUMERO_CUENTA,
             FECHA,
             MVTO,
             SYSDATE);
          COMMIT;
        END IF;
        CLOSE C_ULTIMO_MVTO;
        FETCH CLIENTE_DIV
          INTO C_CLIENTE;
      END LOOP;
      CLOSE CLIENTE_DIV;
      FECHA := FECHA + 1;
    END LOOP;

     P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'F',
                                    'Fin P_PROCESOS_NOCTURNOS.P_SALDOS_DIARIOS_DIVISAS. Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE,
                                            'DD-MM-YYYY HH24:mi:ss') ||
                                    'Rango de fechas procesado: ' ||
                                    TO_CHAR(FINICIO, 'DD-MON-YYYY') ||
                                    ' a ' || TO_CHAR(FFIN, 'DD-MON-YYYY') ||
                                    'Proceso terminado con exito',
                                    N_TX);
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN

       P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                      'E',
                                      'P_PROCESOS_NOCTURNOS.P_SALDOS_DIARIOS_DIVISAS. Fecha: ' ||
                                      TO_CHAR(SYSDATE,
                                              'DD-MM-YYYY HH24:mi:ss') ||
                                      ' Error en procedimiento saldos_diarios_divisas ' ||
                                      SUBSTR(SQLERRM, 1, 150),
                                      N_TX);

  END P_SALDOS_DIARIOS_DIVISAS;

  /**********************************************************************************
  ***  Procedimiento  PR_CUPOS_BANCOS para:                                        **
  ***  1. Guardar la informacion diaria de cupos de bancos y cuentas               **
  ***  2. Generar ordenes de pago de uso de cupo con que deben iniciar las cuentas **
  ***  se debe correr despues de las 12:00 no tiene limite de horario              **
  ***  Siempre evia mail al finalizar el proceso : con ERROR o EXITOSO             **
  ***  SE DEBE CORRER TODOS LOS DIAS                                               **
  ******************************************************************************** */
  PROCEDURE PR_CUPOS_BANCOS(P_FECHA IN DATE) IS

    P_FECHA_HOY DATE;
    CURSOR C_DNH IS
      SELECT DNH_FECHA
        FROM DIAS_NO_HABILES
       WHERE DNH_FECHA >= TRUNC(P_FECHA_HOY)
         AND DNH_FECHA < TRUNC(P_FECHA_HOY + 1);
    DNH C_DNH%ROWTYPE;

    CURSOR C_ERRORES IS
      SELECT COUNT(*) T
        FROM ERRORES_PROCESOS
       WHERE ERP_FECHA_ERROR >= TRUNC(P_FECHA)
         AND ERP_PROCESO IN
             ('P_TESORERIA.GUARDAR_HISTORIA_CUPOS',
              'P_TESORERIA.GENERAR_ODP_USO_CUPO');
    NUM_ERRORES NUMBER;
    -- VARIABLES PARA MAIL
    conn      utl_smtp.connection;
    req       utl_http.req;
    resp      utl_http.resp;
    data      RAW(200);
    NOM_ERROR VARCHAR2(80);

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_CUPOS_BANCOS',
                                                      'INI');

    P_TESORERIA.PR_GUARDAR_HISTORIA_CUPOS(P_FECHA);

    -- SOLO PARA FECHA = HOY Y SI ES DIA HABIL

    SELECT TRUNC(SYSDATE) INTO P_FECHA_HOY FROM DUAL;
    IF TRUNC(P_FECHA + 1) = TRUNC(P_FECHA_HOY) THEN
      OPEN C_DNH;
      FETCH C_DNH
        INTO DNH;
      IF C_DNH%FOUND OR TO_CHAR(P_FECHA_HOY, 'D') IN ('7', '1') THEN
        NULL;
      ELSE
        P_TESORERIA.PR_GENERAR_ODP_USO_CUPO;
      END IF;
    END IF;
    -- verifica si se generaron errores
    OPEN C_ERRORES;
    FETCH C_ERRORES
      INTO NUM_ERRORES;
    CLOSE C_ERRORES;
    NUM_ERRORES := NVL(NUM_ERRORES, 0);
    IF NUM_ERRORES != 0 THEN
      P_MAIL.ENVIO_MAIL_ERROR('PROCESO P_PROCESOS_NOCTURNOS.PR_CUPOS_BANCOS  F A L L O !!!',
                              ' Se corrio procedimiento y genero errores. Verificar en la tabla ERRORES_PROCESO');
    ELSE
      P_MAIL.ENVIO_MAIL_ERROR('PROCESO P_PROCESOS_NOCTURNOS.PR_CUPOS_BANCOS EXITOSO',
                              'PROCESO P_PROCESOS_NOCTURNOS.PR_CUPOS_BANCOS : EXITOSO');
    END IF;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_CUPOS_BANCOS',
                                                      'FIN');
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('PROCESO P_PROCESOS_NOCTURNOS.PR_CUPOS_BANCOS  F A L L O',
                              substr(sqlerrm, 1, 80));
  END PR_CUPOS_BANCOS;

