  END P_LIMCOS;

  -- Inicio Portafolio - Proyecto Factoring VAGTUD876

  PROCEDURE P_ARCHIVO_PORTAFOLIO_FACT IS

    CURSOR C_PART IS
      SELECT MFP_FCP_NUMERO_OPERACION MFP_FCP_NUMERO_OPERACION,
             MFP_FCP_FON_CODIGO MFP_FCP_FON_CODIGO,
             MFP_FCP_EMI_MNEMONICO MFP_FCP_EMI_MNEMONICO,
             MFP_EST_HIST MFP_EST_HIST,
             TO_DATE(MFP_FECHA, 'DD/MM/YY') MFP_FECHA,
             SUM(MFP_MONTO) MFP_MONTO,
             SUM(MFP_VALOR_TM) MFP_VALOR_TM,
             SUM(MFP_VALOR_FUTURO) MFP_VALOR_FUTURO,
             SUM(MFP_VALOR_EXCEDENTE) MFP_VALOR_EXCEDENTE,
             SUM(MFP_UTILIDAD) MFP_UTILIDAD,
             SUM(MFP_PERDIDA) MFP_PERDIDA,
             SUM(MFP_VALOR_DIST_REND_FINANCIERO) MFP_VALOR_DIST_REND_FINANCIERO,
             SUM(MFP_DIFERENCIA_CAMBIO) MFP_DIFERENCIA_CAMBIO,
             SUM(MFP_VALOR_TM_PESOS) MFP_VALOR_TM_PESOS,
             SUM(MFP_RENDIMIENTOS) MFP_RENDIMIENTOS,
             SUM(MFP_REND_ACUMULADOS) MFP_REND_ACUMULADOS,
             SUM(MFP_DET_CAPITAL) MFP_DET_CAPITAL,
             SUM(MFP_INTERES_MORA) MFP_INTERES_MORA,
             SUM(MFP_DETERIORO_RENDIMIENTOS) MFP_DETERIORO_RENDIMIENTOS,
             SUM(MFP_DET_REND_MORA) MFP_DET_REND_MORA,
             SUM(MFP_INT_MORA_ACUM) MFP_INT_MORA_ACUM,
             SUM(MFP_DET_CAP_ACUM) MFP_DET_CAP_ACUM,
             SUM(MFP_DET_REND_ACUM) MFP_DET_REND_ACUM,
             SUM(MFP_DET_REND_MORA_ACU) MFP_DET_REND_MORA_ACU
        FROM FACTURAS_PARTICIPACIONES, MVTOS_FACTURAS_PARTICIPACIONES
       WHERE FCP_NUMERO_OPERACION = MFP_FCP_NUMERO_OPERACION
         AND FCP_FON_CODIGO = MFP_FCP_FON_CODIGO
         AND FCP_EMI_MNEMONICO = MFP_FCP_EMI_MNEMONICO
         AND FCP_ESTADO != 'VEP'
         AND MFP_TVF_MNEMONICO IN
             ('VAF', 'ABO', 'DET', 'MRA', 'VEN', 'CPR')
         AND TRUNC(MFP_FECHA) >= TRUNC(SYSDATE - 1)
         AND TRUNC(MFP_FECHA) < TRUNC(SYSDATE)
       GROUP BY MFP_FCP_NUMERO_OPERACION,
                MFP_FCP_FON_CODIGO,
                MFP_FCP_EMI_MNEMONICO,
                MFP_EST_HIST,
                TO_DATE(MFP_FECHA, 'DD/MM/YY')
       ORDER BY MFP_FCP_NUMERO_OPERACION, MFP_FECHA;
    V_PART C_PART%ROWTYPE;

    CURSOR C_EST_HIS IS
      SELECT MFP_ID                   ID,
             MFP_FCP_NUMERO_OPERACION FACTURA,
             MFP_FCP_FON_CODIGO       FONDO,
             MFP_FCP_EMI_MNEMONICO    EMISOR
        FROM FACTURAS_PARTICIPACIONES, MVTOS_FACTURAS_PARTICIPACIONES
       WHERE FCP_NUMERO_OPERACION = MFP_FCP_NUMERO_OPERACION
         AND FCP_FON_CODIGO = MFP_FCP_FON_CODIGO
         AND FCP_EMI_MNEMONICO = MFP_FCP_EMI_MNEMONICO
         AND MFP_EST_HIST IS NULL
         AND TRUNC(MFP_FECHA) >= TRUNC(SYSDATE - 1)
         AND TRUNC(MFP_FECHA) < TRUNC(SYSDATE);
    V_EST_HIS C_EST_HIS%ROWTYPE;

    V_EST VARCHAR2(3);

    CURSOR C_FONDO(FONDO VARCHAR2) IS
      SELECT FON_RAZON_SOCIAL FROM FONDOS WHERE FON_CODIGO = FONDO;

    CURSOR C_FACT(FACTURA VARCHAR2, FONDO VARCHAR2, EMISOR VARCHAR2) IS
      SELECT FCP_PER_TID_CODIGO_PGA,
             FCP_PER_NUM_IDEN_PGA,
             FCP_EMI_MNEMONICO,
             FCP_TIPO_NEGOCIO,
             FCP_FECHA_COMPRA,
             FCP_FECHA_PAGO FCP_FECHA_VENCIMIENTO_FACT,
             FCP_TASA_DESCUENTO,
             FCP_TRE_MNEMONICO,
             FCP_PUNTOS_ADICIONALES,
             FCP_VALOR_COMPRA,
             FCP_VALOR_FUTURO,
             FCP_BMO_MNEMONICO,
             FCP_RECURSOS,
             FCP_COMISION,
             FCP_IVA_COMISION,
             FCP_FECHA_EMISION_FACT,
             FCP_VALOR_NETO
        FROM FACTURAS_PARTICIPACIONES
       WHERE FCP_NUMERO_OPERACION = FACTURA
         AND FCP_FON_CODIGO = FONDO
         AND FCP_EMI_MNEMONICO = EMISOR
         AND FCP_ESTADO IN ('VIG', 'VES'); --WGONZALEZ VAGTUS084549 - estabilizaciżn Necesidad # 4

    CURSOR C_ABONO(FECHA   DATE,
                   FACTURA VARCHAR2,
                   FONDO   VARCHAR2,
                   EMISOR  VARCHAR2) IS
      SELECT ABS(MFP_MONTO)
        FROM FACTURAS_PARTICIPACIONES, MVTOS_FACTURAS_PARTICIPACIONES
       WHERE FCP_NUMERO_OPERACION = MFP_FCP_NUMERO_OPERACION
         AND FCP_FON_CODIGO = MFP_FCP_FON_CODIGO
         AND FCP_EMI_MNEMONICO = MFP_FCP_EMI_MNEMONICO
         AND MFP_FECHA >= FECHA
         AND MFP_FECHA < FECHA + 1
         AND MFP_TVF_MNEMONICO = 'ABO'
         AND MFP_FCP_NUMERO_OPERACION = FACTURA
         AND MFP_FCP_FON_CODIGO = FONDO
         AND FCP_EMI_MNEMONICO = EMISOR;

    CURSOR C_ULT_MTF(FECHA   DATE,
                     FACTURA VARCHAR2,
                     FONDO   VARCHAR2,
                     EMISOR  VARCHAR2) IS
      SELECT MFP_REND_ACUMULADOS, MFP_UTILIDAD, MFP_PERDIDA
        FROM MVTOS_FACTURAS_PARTICIPACIONES
       WHERE MFP_ID = (SELECT MAX(MFP_ID)
                         FROM MVTOS_FACTURAS_PARTICIPACIONES
                        WHERE MFP_FECHA >= FECHA
                          AND MFP_FECHA < FECHA + 1
                          AND MFP_FCP_NUMERO_OPERACION = FACTURA
                          AND MFP_FCP_FON_CODIGO = FONDO
                          AND MFP_FCP_EMI_MNEMONICO = EMISOR);

    CURSOR C_TASA_MORA(FECHA   DATE,
                       FACTURA VARCHAR2,
                       FONDO   VARCHAR2,
                       EMISOR  VARCHAR2) IS
      SELECT (NVL(ROUND((MFP_INTERES_MORA / MFP_CAPITAL * 100), 2), 0))
        FROM FACTURAS_PARTICIPACIONES, MVTOS_FACTURAS_PARTICIPACIONES
       WHERE FCP_NUMERO_OPERACION = MFP_FCP_NUMERO_OPERACION
         AND FCP_FON_CODIGO = MFP_FCP_FON_CODIGO
         AND FCP_EMI_MNEMONICO = MFP_FCP_EMI_MNEMONICO
         AND MFP_FECHA >= FECHA
         AND MFP_FECHA < FECHA + 1
         AND MFP_FCP_NUMERO_OPERACION = FACTURA
         AND MFP_FCP_FON_CODIGO = FONDO
         AND FCP_EMI_MNEMONICO = EMISOR
         AND (MFP_INTERES_MORA IS NOT NULL OR MFP_INTERES_MORA != 0);

    CURSOR C_PAGADOR(NUM_IDEN VARCHAR2, TID VARCHAR2) IS
      SELECT PER_RAZON_SOCIAL || ' ' || PER_PRIMER_APELLIDO || ' ' ||
             PER_SEGUNDO_APELLIDO || ' ' || PER_NOMBRE NOMBRE,
             PER_SECTOR_PIP,
             NVL(PER_PREPAGO, 'NO')
        FROM PERSONAS
       WHERE PER_NUM_IDEN = NUM_IDEN
         AND PER_TID_CODIGO = TID;

    CURSOR C_EMISOR(EMI VARCHAR2) IS
      SELECT EMI_DESCRIPCION, EMI_NUMERO_IDENTIFICACION, EMI_SECTOR_PIP
        FROM EMISORES
       WHERE EMI_MNEMONICO = EMI;

    V_SECTOR_PIP_PER VARCHAR2(50);
    V_SECTOR_PIP_EMI VARCHAR2(50);

    CURSOR C_GARAN_P(ID VARCHAR2, NUM_IDEN VARCHAR2) IS
      SELECT GFA_TIPO_GARANTIA, GFA_CUSTODIO
        FROM GARANTIAS_FACTURAS
       WHERE GFA_PER_TID_CODIGO = ID
         AND GFA_PER_NUM_IDEN = NUM_IDEN;

    CURSOR C_GARAN_E(EMI VARCHAR2) IS
      SELECT GFA_TIPO_GARANTIA GARANTIA, GFA_CUSTODIO
        FROM GARANTIAS_FACTURAS
       WHERE GFA_EMI_MNEMONICO = EMI;

    CURSOR C_MOV_ABO(FECHA   DATE,
                     FACTURA VARCHAR2,
                     FONDO   VARCHAR2,
                     EMISOR  VARCHAR2) IS
      SELECT ABS(SUM(MFP_MONTO))
        FROM FACTURAS_PARTICIPACIONES, MVTOS_FACTURAS_PARTICIPACIONES
       WHERE FCP_NUMERO_OPERACION = MFP_FCP_NUMERO_OPERACION
         AND FCP_FON_CODIGO = MFP_FCP_FON_CODIGO
         AND FCP_EMI_MNEMONICO = MFP_FCP_EMI_MNEMONICO
         AND MFP_FCP_NUMERO_OPERACION = FACTURA
         AND MFP_FCP_FON_CODIGO = FONDO
         AND FCP_EMI_MNEMONICO = EMISOR
         AND MFP_TVF_MNEMONICO = 'ABO'
         AND MFP_FECHA >= FCP_FECHA_COMPRA
         AND MFP_FECHA < FECHA + 1;

    CURSOR C_DET(FECHA   DATE,
                 FACTURA VARCHAR2,
                 FONDO   VARCHAR2,
                 EMISOR  VARCHAR2) IS
      SELECT SUM(MFP_DET_CAPITAL + MFP_DETERIORO_RENDIMIENTOS +
                 MFP_DET_REND_MORA)
        FROM FACTURAS_PARTICIPACIONES, MVTOS_FACTURAS_PARTICIPACIONES
       WHERE FCP_NUMERO_OPERACION = MFP_FCP_NUMERO_OPERACION
         AND FCP_FON_CODIGO = MFP_FCP_FON_CODIGO
         AND FCP_EMI_MNEMONICO = MFP_FCP_EMI_MNEMONICO
         AND MFP_FCP_NUMERO_OPERACION = FACTURA
         AND MFP_FCP_FON_CODIGO = FONDO
         AND FCP_EMI_MNEMONICO = EMISOR
         AND TRUNC(MFP_FECHA) >= TRUNC(FECHA)
         AND TRUNC(MFP_FECHA) < TRUNC(FECHA) + 1;

    CURSOR C_DETE(FECHA   DATE,
                  FACTURA VARCHAR2,
                  FONDO   VARCHAR2,
                  EMISOR  VARCHAR2) IS
      SELECT SUM(MFP_DET_CAPITAL + MFP_DETERIORO_RENDIMIENTOS +
                 MFP_DET_REND_MORA)
        FROM FACTURAS_PARTICIPACIONES, MVTOS_FACTURAS_PARTICIPACIONES
       WHERE FCP_NUMERO_OPERACION = MFP_FCP_NUMERO_OPERACION
         AND FCP_FON_CODIGO = MFP_FCP_FON_CODIGO
         AND FCP_EMI_MNEMONICO = MFP_FCP_EMI_MNEMONICO
         AND MFP_FCP_NUMERO_OPERACION = FACTURA
         AND MFP_FCP_FON_CODIGO = FONDO
         AND FCP_EMI_MNEMONICO = EMISOR
         AND MFP_FECHA >= FCP_FECHA_COMPRA
         AND TRUNC(MFP_FECHA) < TRUNC(FECHA) + 1;

    CURSOR C_MERC(FECHA   DATE,
                  FACTURA VARCHAR2,
                  FONDO   VARCHAR2,
                  EMISOR  VARCHAR2) IS
      SELECT MFP_VALOR_TM
        FROM FACTURAS_PARTICIPACIONES, MVTOS_FACTURAS_PARTICIPACIONES
       WHERE FCP_NUMERO_OPERACION = MFP_FCP_NUMERO_OPERACION
         AND FCP_FON_CODIGO = MFP_FCP_FON_CODIGO
         AND FCP_EMI_MNEMONICO = MFP_FCP_EMI_MNEMONICO
         AND MFP_FCP_NUMERO_OPERACION = FACTURA
         AND MFP_FCP_FON_CODIGO = FONDO
         AND FCP_EMI_MNEMONICO = EMISOR
         AND MFP_TVF_MNEMONICO IN ('VAF', 'ABO', 'DET', 'MRA', 'VEN')
         AND TRUNC(MFP_FECHA) =
             (SELECT MAX(TRUNC(MFP_FECHA))
                FROM MVTOS_FACTURAS_PARTICIPACIONES
               WHERE MFP_FCP_NUMERO_OPERACION = FACTURA
                 AND MFP_FCP_FON_CODIGO = FONDO
                 AND MFP_FCP_EMI_MNEMONICO = EMISOR
                 AND TRUNC(MFP_FECHA) >= TRUNC(FECHA)
                 AND TRUNC(MFP_FECHA) < TRUNC(FECHA) + 1)
       ORDER BY TRUNC(MFP_FECHA), MFP_ID DESC;

    FECHA DATE;

    CURSOR C_TASA IS

      SELECT CTR_TASA_NOMINAL
        FROM COTIZACIONES_TASA_REFERENCIA
       WHERE CTR_TRE_MNEMONICO = 'TU'
       ORDER BY CTR_FECHA DESC;

    V_TASA NUMBER;

    CURSOR C_CAL1 IS
      SELECT DTF_DIA_INICIO INI,
             NVL(DTF_DIA_FIN, 1000) FIN,
             DTF_CALIFICACION CAL
        FROM DETERIOROS_FACTURAS;

    V_CAL1 C_CAL1%ROWTYPE;

    CURSOR C_VAL_PYG(FECHA   DATE,
                     FACTURA VARCHAR2,
                     FONDO   VARCHAR2,
                     EMISOR  VARCHAR) IS
      SELECT NVL(SUM(MFP_MONTO), 0)
        FROM FACTURAS_PARTICIPACIONES, MVTOS_FACTURAS_PARTICIPACIONES
       WHERE FCP_NUMERO_OPERACION = MFP_FCP_NUMERO_OPERACION
         AND FCP_FON_CODIGO = MFP_FCP_FON_CODIGO
         AND FCP_EMI_MNEMONICO = MFP_FCP_EMI_MNEMONICO
         AND MFP_FCP_NUMERO_OPERACION = FACTURA
         AND MFP_FCP_FON_CODIGO = FONDO
         AND FCP_EMI_MNEMONICO = EMISOR
         AND MFP_TVF_MNEMONICO IN ('VAF', 'DET', 'MRA')
         AND TRUNC(MFP_FECHA) >= TRUNC(FECHA)
         AND TRUNC(MFP_FECHA) < TRUNC(FECHA) + 1;

    CURSOR C_ESTADO(FECHA   DATE,
                    FACTURA VARCHAR2,
                    FONDO   VARCHAR2,
                    EMISOR  VARCHAR) IS
      SELECT MFP_EST_HIST
        FROM FACTURAS_PARTICIPACIONES, MVTOS_FACTURAS_PARTICIPACIONES
       WHERE FCP_NUMERO_OPERACION = MFP_FCP_NUMERO_OPERACION
         AND FCP_FON_CODIGO = MFP_FCP_FON_CODIGO
         AND FCP_EMI_MNEMONICO = MFP_FCP_EMI_MNEMONICO
         AND MFP_FCP_NUMERO_OPERACION = FACTURA
         AND MFP_FCP_FON_CODIGO = FONDO
         AND FCP_EMI_MNEMONICO = EMISOR
         AND TRUNC(MFP_FECHA) >= TRUNC(FECHA)
         AND TRUNC(MFP_FECHA) < TRUNC(FECHA) + 1
       ORDER BY TRUNC(MFP_FECHA) DESC;

    TID             VARCHAR2(3);
    EMISOR          VARCHAR2(3);
    FECHA_COMPRA    DATE;
    V_FECHA_EMISION DATE;
    V_FECHA_VENCI   DATE;

    V_TASA_MORA        NUMBER;
    V_TASA_DESCUENTO   NUMBER;
    V_PUNTOS_ADICION   NUMBER;
    V_DIAS_VENCIMIENTO NUMBER;
    V_DIAS_MORA        NUMBER;
    V_VALOR_ABONO_ACUM NUMBER;
    V_PLAZO            NUMBER;
    V_DET_ACUM         NUMBER;
    V_VALOR_MERCADO    NUMBER;
    V_VALOR_NOMINAL    NUMBER;
    V_DIST_DIA         NUMBER;
    V_MONTO            NUMBER;
    V_REND_ACUMULADOS  NUMBER;
    V_UTILIDAD         NUMBER;
    V_PERDIDA          NUMBER;
    V_DETERIORO        NUMBER;
    V_VALOR_COMPRA     NUMBER;
    V_VALOR_FUTURO     NUMBER;
    V_COMISION         NUMBER;
    V_IVA_COMISION     NUMBER;
    NIT_EMISOR         VARCHAR2(15);
    V_TRE_MNEMONICO    VARCHAR2(5);
    V_NIT_PAGADOR      VARCHAR2(15);
    EMISOR1            VARCHAR2(150);
    V_SECTOR_PIP       VARCHAR2(50);
    V_PAGADOR          VARCHAR2(150);
    V_FONDO            VARCHAR2(150);
    V_PRODUCTO         VARCHAR2(20);
    V_ESTADO           VARCHAR2(30);
    V_RUTA             VARCHAR2(100);
    NOMBRE_ARCHIVO     VARCHAR2(100);
    P_CODIGO           VARCHAR2(200);
    P_RESPUESTA        VARCHAR2(200);
    V_PREPAGO          VARCHAR2(2);
    V_GARANTIA         VARCHAR2(50);
    V_CUSTODIO         VARCHAR2(50);
    V_CALIFICACION     VARCHAR2(10);
    V_BMO_MNEMONICO    VARCHAR2(5);
    V_RECURSOS         VARCHAR2(1);

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_ARCHIVO_PORTAFOLIO_FACT',
                                                      'INI');

    DELETE FROM TMP_PORTAFOLIO_FACTORING;
    COMMIT;

    OPEN C_EST_HIS;
    FETCH C_EST_HIS
      INTO V_EST_HIS;
    WHILE C_EST_HIS%FOUND LOOP
      V_EST := NULL;
      SELECT MFP_EST_HIST
        INTO V_EST
        FROM FACTURAS_PARTICIPACIONES, MVTOS_FACTURAS_PARTICIPACIONES
       WHERE FCP_NUMERO_OPERACION = MFP_FCP_NUMERO_OPERACION
         AND FCP_FON_CODIGO = MFP_FCP_FON_CODIGO
         AND FCP_EMI_MNEMONICO = MFP_FCP_EMI_MNEMONICO
         AND MFP_FCP_NUMERO_OPERACION = V_EST_HIS.FACTURA
         AND MFP_FCP_FON_CODIGO = V_EST_HIS.FONDO
         AND MFP_FCP_EMI_MNEMONICO = V_EST_HIS.EMISOR
         AND TRUNC(MFP_FECHA) <= TRUNC(SYSDATE - 1)
         AND MFP_EST_HIST IS NOT NULL
         AND ROWNUM = 1
       ORDER BY TRUNC(MFP_FECHA) DESC;

      UPDATE MVTOS_FACTURAS_PARTICIPACIONES
         SET MFP_EST_HIST = V_EST
       WHERE MFP_FCP_NUMERO_OPERACION = V_EST_HIS.FACTURA
         AND MFP_FCP_FON_CODIGO = V_EST_HIS.FONDO
         AND MFP_FCP_EMI_MNEMONICO = V_EST_HIS.EMISOR
         AND MFP_ID = V_EST_HIS.ID;
      COMMIT;
      FETCH C_EST_HIS
        INTO V_EST_HIS;
    END LOOP;
    CLOSE C_EST_HIS;

    OPEN C_PART;
    FETCH C_PART
      INTO V_PART;
    WHILE C_PART%FOUND LOOP
      OPEN C_FONDO(V_PART.MFP_FCP_FON_CODIGO);
      FETCH C_FONDO
        INTO V_FONDO;
      CLOSE C_FONDO;
      OPEN C_FACT(V_PART.MFP_FCP_NUMERO_OPERACION,
                  V_PART.MFP_FCP_FON_CODIGO,
                  V_PART.MFP_FCP_EMI_MNEMONICO);
      FETCH C_FACT
        INTO TID,
             V_NIT_PAGADOR,
             EMISOR,
             V_PRODUCTO,
             FECHA_COMPRA,
             V_FECHA_VENCI,
             V_TASA_DESCUENTO,
             V_TRE_MNEMONICO,
             V_PUNTOS_ADICION,
             V_VALOR_COMPRA,
             V_VALOR_FUTURO,
             V_BMO_MNEMONICO,
             V_RECURSOS,
             V_COMISION,
             V_IVA_COMISION,
             V_FECHA_EMISION,
             V_VALOR_NOMINAL;
      IF V_TRE_MNEMONICO IS NULL OR V_TRE_MNEMONICO = '' THEN
        V_TRE_MNEMONICO := 0;
      END IF;
      CLOSE C_FACT;
      OPEN C_PAGADOR(V_NIT_PAGADOR, TID);
      FETCH C_PAGADOR
        INTO V_PAGADOR, V_SECTOR_PIP_PER, V_PREPAGO;
      CLOSE C_PAGADOR;
      IF V_PREPAGO = 'S' THEN
        V_PREPAGO := 'SI';
      ELSIF V_PREPAGO = 'N' THEN
        V_PREPAGO := 'NO';
      END IF;
      OPEN C_EMISOR(EMISOR);
      FETCH C_EMISOR
        INTO EMISOR1, NIT_EMISOR, V_SECTOR_PIP_EMI;
      CLOSE C_EMISOR;
      IF V_PRODUCTO = 'C' THEN
        V_PRODUCTO := 'CONFIRMING';
      ELSE
        V_PRODUCTO := 'FACTORING';
      END IF;
      IF V_SECTOR_PIP_PER IS NULL OR V_SECTOR_PIP_PER = '' THEN
        IF V_SECTOR_PIP_EMI IS NULL OR V_SECTOR_PIP_EMI = '' THEN
          V_SECTOR_PIP := NULL;
        ELSE
          V_SECTOR_PIP := V_SECTOR_PIP_EMI;
        END IF;
      ELSE
        V_SECTOR_PIP := V_SECTOR_PIP_PER;
      END IF;
      OPEN C_GARAN_E(EMISOR);
      FETCH C_GARAN_E
        INTO V_GARANTIA, V_CUSTODIO;
      IF C_GARAN_E%NOTFOUND THEN
        OPEN C_GARAN_P(TID, V_NIT_PAGADOR);
        FETCH C_GARAN_P
          INTO V_GARANTIA, V_CUSTODIO;
        CLOSE C_GARAN_P;
      END IF;
      CLOSE C_GARAN_E;
      OPEN C_ABONO(V_PART.MFP_FECHA,
                   V_PART.MFP_FCP_NUMERO_OPERACION,
                   V_PART.MFP_FCP_FON_CODIGO,
                   V_PART.MFP_FCP_EMI_MNEMONICO);
      FETCH C_ABONO
        INTO V_MONTO;
      IF V_MONTO IS NULL OR V_MONTO = '' THEN
        V_MONTO := 0;
      END IF;
      CLOSE C_ABONO;

      OPEN C_ULT_MTF(V_PART.MFP_FECHA,
                     V_PART.MFP_FCP_NUMERO_OPERACION,
                     V_PART.MFP_FCP_FON_CODIGO,
                     V_PART.MFP_FCP_EMI_MNEMONICO);
      FETCH C_ULT_MTF
        INTO V_REND_ACUMULADOS, V_UTILIDAD, V_PERDIDA;
      CLOSE C_ULT_MTF;

      V_DIAS_VENCIMIENTO := TRUNC(V_FECHA_VENCI) - TRUNC(V_PART.MFP_FECHA);
      V_DIAS_MORA        := TRUNC(V_PART.MFP_FECHA) - TRUNC(V_FECHA_VENCI);
      V_PLAZO            := TRUNC(V_FECHA_VENCI) - TRUNC(FECHA_COMPRA);
      IF V_DIAS_VENCIMIENTO < 0 THEN
        V_DIAS_VENCIMIENTO := 0;
      END IF;
      IF V_DIAS_MORA <= 0 THEN
        V_DIAS_MORA := 0;
      ELSE
        OPEN C_TASA_MORA(V_PART.MFP_FECHA,
                         V_PART.MFP_FCP_NUMERO_OPERACION,
                         V_PART.MFP_FCP_FON_CODIGO,
                         V_PART.MFP_FCP_EMI_MNEMONICO);
        FETCH C_TASA_MORA
          INTO V_TASA_MORA;
        IF V_TASA_MORA IS NULL OR V_TASA_MORA = '' THEN
          V_TASA_MORA := 0;
        END IF;
        CLOSE C_TASA_MORA;
      END IF;
      OPEN C_CAL1;
      FETCH C_CAL1
        INTO V_CAL1;
      WHILE C_CAL1%FOUND LOOP
        IF V_DIAS_MORA BETWEEN V_CAL1.INI AND V_CAL1.FIN THEN
          V_CALIFICACION := V_CAL1.CAL;
        END IF;
        FETCH C_CAL1
          INTO V_CAL1;
      END LOOP;
      CLOSE C_CAL1;
      OPEN C_MOV_ABO(V_PART.MFP_FECHA,
                     V_PART.MFP_FCP_NUMERO_OPERACION,
                     V_PART.MFP_FCP_FON_CODIGO,
                     V_PART.MFP_FCP_EMI_MNEMONICO);
      FETCH C_MOV_ABO
        INTO V_VALOR_ABONO_ACUM;
      IF V_VALOR_ABONO_ACUM IS NULL OR V_VALOR_ABONO_ACUM = '' THEN
        V_VALOR_ABONO_ACUM := 0;
      END IF;
      CLOSE C_MOV_ABO;
      OPEN C_DET(V_PART.MFP_FECHA,
                 V_PART.MFP_FCP_NUMERO_OPERACION,
                 V_PART.MFP_FCP_FON_CODIGO,
                 V_PART.MFP_FCP_EMI_MNEMONICO);
      FETCH C_DET
        INTO V_DETERIORO;
      IF V_DETERIORO IS NULL OR V_DETERIORO = '' THEN
        V_DETERIORO := 0;
      END IF;
      CLOSE C_DET;
      OPEN C_DETE(V_PART.MFP_FECHA,
                  V_PART.MFP_FCP_NUMERO_OPERACION,
                  V_PART.MFP_FCP_FON_CODIGO,
                  V_PART.MFP_FCP_EMI_MNEMONICO);
      FETCH C_DETE
        INTO V_DET_ACUM;
      IF V_DET_ACUM IS NULL OR V_DET_ACUM = '' THEN
        V_DET_ACUM := 0;
      END IF;
      CLOSE C_DETE;
      OPEN C_MERC(V_PART.MFP_FECHA,
                  V_PART.MFP_FCP_NUMERO_OPERACION,
                  V_PART.MFP_FCP_FON_CODIGO,
                  V_PART.MFP_FCP_EMI_MNEMONICO);
      FETCH C_MERC
        INTO V_VALOR_MERCADO;
      IF V_VALOR_MERCADO IS NULL OR V_VALOR_MERCADO = '' THEN
        V_VALOR_MERCADO := 0;
      END IF;
      CLOSE C_MERC;
      OPEN C_VAL_PYG(V_PART.MFP_FECHA,
                     V_PART.MFP_FCP_NUMERO_OPERACION,
                     V_PART.MFP_FCP_FON_CODIGO,
                     V_PART.MFP_FCP_EMI_MNEMONICO);
      FETCH C_VAL_PYG
        INTO V_DIST_DIA;
      IF V_DIST_DIA IS NULL OR V_DIST_DIA = '' THEN
        V_DIST_DIA := 0;
      END IF;
      CLOSE C_VAL_PYG;
      OPEN C_ESTADO(V_PART.MFP_FECHA,
                    V_PART.MFP_FCP_NUMERO_OPERACION,
                    V_PART.MFP_FCP_FON_CODIGO,
                    V_PART.MFP_FCP_EMI_MNEMONICO);
      FETCH C_ESTADO
        INTO V_ESTADO;
      CLOSE C_ESTADO;
      INSERT INTO TMP_PORTAFOLIO_FACTORING
        (TMPF_FECHA_CORTE,
         TMPF_NIT_FONDO,
         TMPF_FONDO,
         TMPF_NIT_PAGADOR,
         TMPF_PAGADOR,
         TMPF_NIT_EMISOR,
         TMPF_EMISOR,
         TMPF_FACT_NUM_OPE,
         TMPF_PRODUCTO,
         TMPF_ESTADO,
         TMPF_PLAZO,
         TMPF_FECHA_COMPRA,
         TMPF_FECHA_CUMPLIMIENTO,
         TMPF_TASA,
         TMPF_TASA_INDEXACION,
         TMPF_PUNTOS_ADICIONALES,
         TMPF_TASA_MORA,
         TMPF_DIAS_VENCIMIENTO,
         TMPF_DIAS_MORA,
         TMPF_VALOR_COMPRA,
         TMPF_RENDIMIENTOS,
         TMPF_DETERIORO,
         TMPF_DETERIORO_ACUM,
         TMPF_INTERES_MORA,
         TMPF_VALOR_MERCADO,
         TMPF_VALOR_FUTURO,
         TMPF_VALOR_ABONO,
         TMPF_VALOR_ABONO_ACUM,
         TMPF_BASE_MONETARIA,
         TMPF_SECTOR_PIP,
         TMPF_GARANTIA,
         TMPF_CUSTODIO,
         TMPF_CON_RECURSO,
         TMPF_COMISION,
         TMPF_IVA_COMISION,
         TMPF_PREPAGO,
         TMPF_FECHA_EMISION,
         TMPF_VALOR_NOMINAL,
         TMPF_DIST_DIA,
         TMPF_CALIFICACION,
         TMPF_UTILIDAD,
         TMPF_PERDIDA)
      VALUES
        (V_PART.MFP_FECHA,
         V_PART.MFP_FCP_FON_CODIGO,
         V_FONDO,
         V_NIT_PAGADOR,
         V_PAGADOR,
         NIT_EMISOR,
         EMISOR1,
         V_PART.MFP_FCP_NUMERO_OPERACION,
         V_PRODUCTO,
         V_ESTADO,
         V_PLAZO,
         FECHA_COMPRA,
         V_FECHA_VENCI,
         V_TASA_DESCUENTO,
         V_TRE_MNEMONICO,
         V_PUNTOS_ADICION,
         V_TASA_MORA,
         V_DIAS_VENCIMIENTO,
         V_DIAS_MORA,
         V_VALOR_COMPRA,
         V_REND_ACUMULADOS --V_PART.MFP_RENDIMIENTOS
        ,
         V_DETERIORO,
         V_DET_ACUM,
         V_PART.MFP_INTERES_MORA,
         V_VALOR_MERCADO,
         V_VALOR_FUTURO,
         V_MONTO,
         V_VALOR_ABONO_ACUM,
         V_BMO_MNEMONICO,
         V_SECTOR_PIP,
         V_GARANTIA,
         V_CUSTODIO,
         V_RECURSOS,
         V_COMISION,
         V_IVA_COMISION,
         V_PREPAGO,
         V_FECHA_EMISION,
         V_VALOR_NOMINAL,
         V_DIST_DIA,
         V_CALIFICACION,
         V_UTILIDAD,
         V_PERDIDA);
      COMMIT;
      FETCH C_PART
        INTO V_PART;
    END LOOP;
    CLOSE C_PART;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_ARCHIVO_PORTAFOLIO_FACT',
                                                      'FIN');
    COMMIT;

    V_RUTA         := '\\nas.corredor.local\contabilidad\PRIVADA\Reportes transmisiones\Diarios\'; --'\\nas\Presentaciones\';
    NOMBRE_ARCHIVO := 'PORTAFOLIO_FACTORING_' ||
                      TO_CHAR(SYSDATE - 1, 'DDMMYYYY_hh24mmss');

    P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => V_RUTA,
                                   P_NOMBRE_ARCHIVO => NOMBRE_ARCHIVO,
                                   P_QUERY          => ' SELECT NVL(PF.FECHA_CORTE,TRUNC(SYSDATE-1)) FECHA_CORTE,  ' ||
                                                       '        PF.NIT_FONDO,                    ' ||
                                                       '        PF.FONDO,                      ' ||
                                                       '        PF.NIT_PAGADOR,                  ' ||
                                                       '        PF.NOMBRE_PAGADOR,                 ' ||
                                                       '        PF.NIT_EMISOR,                   ' ||
                                                       '        PF.NOMBRE_EMISOR,                  ' ||
                                                       '        PF.FACT_NUM_OPE,                 ' ||
                                                       '        PF.PRODUCTO,                   ' ||
                                                       '        PF.ESTADO,                     ' ||
                                                       '        PF.PLAZO,                      ' ||
                                                       '        PF.FECHA_COMPRA,                 ' ||
                                                       '        PF.FECHA_CUMPLIMIENTO,               ' ||
                                                       '        PF.TASA,                     ' ||
                                                       '        PF.TASA_INDEXACION,                ' ||
                                                       '        PF.PUNTOS_ADICIONALES,               ' ||
                                                       '        PF.TASA_MORA,                    ' ||
                                                       '        PF.DIAS_VENCIMIENTO,               ' ||
                                                       '        PF.DIAS_MORA,                    ' ||
                                                       '        PF.VALOR_COMPRA,                 ' ||
                                                       '        PF.RENDIMIENTOS,                 ' ||
                                                       '        PF.DETERIORO,                    ' ||
                                                       '        PF.DETERIORO_ACUM,                 ' ||
                                                       '        PF.INTERES_MORA,                 ' ||
                                                       '        PF.VALOR_MERCADO,                  ' ||
                                                       '        PF.VALOR_FUTURO,                 ' ||
                                                       '        PF.VALOR_ABONO,                  ' ||
                                                       '        PF.VALOR_ABONO_ACUM,               ' ||
                                                       '        PF.BASE_MONETARIA,                 ' ||
                                                       '        PF.SECTOR_PIP,                   ' ||
                                                       '        PF.GARANTIA,                   ' ||
                                                       '        PF.CUSTODIO,                   ' ||
                                                       '        PF.CON_RECURSO,                  ' ||
                                                       '        PF.COMISION,                   ' ||
                                                       '        PF.IVA_COMISION,                 ' ||
                                                       '        PF.PREPAGO,                    ' ||
                                                       '        PF.FECHA_EMISION,                  ' ||
                                                       '        PF.VALOR_NOMINAL,                  ' ||
                                                       '        PF.DIST_DIA,                   ' ||
                                                       '        PF.CALIFICACION,                 ' ||
                                                       '        PF.UTILIDAD,                   ' ||
                                                       '        PF.PERDIDA,                    ' ||
                                                       '        PF.EST_HISTORICO                 ' ||
                                                       ' FROM VW_PORTAFOLIO_FACTORING PF             ' ||
                                                       ' WHERE (FECHA_CORTE >= TRUNC(SYSDATE -1)         ' ||
                                                       '        AND FECHA_CORTE < TRUNC(SYSDATE)           ' ||
                                                       '        OR FECHA_CORTE IS NULL)',
                                   P_CODIGO         => P_CODIGO,
                                   P_RESPUESTA      => P_RESPUESTA);

    IF P_CODIGO = '0000' THEN
      DBMS_OUTPUT.PUT_LINE('Se ha generado el archivo, en la ruta ' ||
                           V_RUTA);
    END IF;

    V_RUTA         := '\\nas.corredor.local\BI\ANEXOS_COEASY\'; --'\\nas\Presentaciones\';
    NOMBRE_ARCHIVO := 'PORTAFOLIO_FACTORING_' ||
                      TO_CHAR(SYSDATE - 1, 'DDMMYYYY_hh24mmss');

    P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => V_RUTA,
                                   P_NOMBRE_ARCHIVO => NOMBRE_ARCHIVO,
                                   P_QUERY          => 'SELECT TMPF_FECHA_CORTE        Fecha_Corte           ' ||
                                                       '     , TMPF_NIT_FONDO          NIT_Fondo             ' ||
                                                       '     , TMPF_FONDO              Fondo                 ' ||
                                                       '     , TMPF_NIT_PAGADOR        NIT_Pagador           ' ||
                                                       '     , TMPF_PAGADOR            Pagador               ' ||
                                                       '     , TMPF_NIT_EMISOR         NIT_Emisor            ' ||
                                                       '     , TMPF_EMISOR             Emisor                ' ||
                                                       '     , TMPF_FACT_NUM_OPE       Fact_Nume_Opera       ' ||
                                                       '     , TMPF_PRODUCTO           Producto              ' ||
                                                       '     , TMPF_ESTADO             Estado                ' ||
                                                       '     , TMPF_PLAZO              Plazo                 ' ||
                                                       '     , TMPF_FECHA_COMPRA       Fecha_Compra          ' ||
                                                       '     , TMPF_FECHA_CUMPLIMIENTO Fecha_Cumplimiento    ' ||
                                                       '     , TMPF_TASA               Tasa                  ' ||
                                                       '     , TMPF_TASA_INDEXACION    Tasa_Indexacion       ' ||
                                                       '     , TMPF_PUNTOS_ADICIONALES Puntos_Adicionales    ' ||
                                                       '     , TMPF_TASA_MORA          Tasa_Mora             ' ||
                                                       '     , TMPF_DIAS_VENCIMIENTO   Dias_Vencimiento      ' ||
                                                       '     , TMPF_DIAS_MORA          Dias_Mora             ' ||
                                                       '     , TMPF_VALOR_COMPRA       Valor_Compra          ' ||
                                                       '     , TMPF_RENDIMIENTOS       Rendimientos          ' ||
                                                       '     , TMPF_DETERIORO          Deterioro             ' ||
                                                       '     , TMPF_DETERIORO_ACUM     Deterioro_Acumulado   ' ||
                                                       '     , TMPF_INTERES_MORA       Intereses_de_Mora     ' ||
                                                       '     , TMPF_VALOR_MERCADO      Valor_Mercado         ' ||
                                                       '     , TMPF_VALOR_FUTURO       Valor_Futuro          ' ||
                                                       '     , TMPF_VALOR_ABONO        Valor_Abono           ' ||
                                                       '     , TMPF_VALOR_ABONO_ACUM   Valor_Abono_Acumulado ' ||
                                                       '     , TMPF_BASE_MONETARIA     Base_Monetaria        ' ||
                                                       '     , TMPF_SECTOR_PIP         Sector_PIP            ' ||
                                                       '     , TMPF_GARANTIA           Garantia              ' ||
                                                       '     , TMPF_CUSTODIO           Custodio              ' ||
                                                       '     , TMPF_CON_RECURSO        Con_Recurso           ' ||
                                                       '     , TMPF_COMISION           Comision              ' ||
                                                       '     , TMPF_IVA_COMISION       Iva_Comision          ' ||
                                                       '     , TMPF_PREPAGO            Prepago               ' ||
                                                       '     , TMPF_FECHA_EMISION      Fecha_Emision         ' ||
                                                       '     , TMPF_VALOR_NOMINAL      Valor_Nominal         ' ||
                                                       '     , TMPF_DIST_DIA           Vr_Dist_Dia           ' ||
                                                       '     , TMPF_CALIFICACION       Calificacion          ' ||
                                                       '     , TMPF_UTILIDAD           Utilidad              ' ||
                                                       '     , TMPF_PERDIDA            Perdida               ' ||
                                                       '  FROM TMP_PORTAFOLIO_FACTORING',
                                   P_CODIGO         => P_CODIGO,
                                   P_RESPUESTA      => P_RESPUESTA);

    IF P_CODIGO = '0000' THEN
      DBMS_OUTPUT.PUT_LINE('Se ha generado el archivo, en la ruta ' ||
                           V_RUTA);
    END IF;

    V_RUTA         := '\\nas.corredor.local\Riesgo\CONFIDENCIAL\Reportes Excel Coeasy\'; --'\\nas\Presentaciones\';
    NOMBRE_ARCHIVO := 'PORTAFOLIO_FACTORING_' ||
                      TO_CHAR(SYSDATE - 1, 'DDMMYYYY_hh24mmss');

    P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => V_RUTA,
                                   P_NOMBRE_ARCHIVO => NOMBRE_ARCHIVO,
                                   P_QUERY          => 'SELECT TMPF_FECHA_CORTE        Fecha_Corte           ' ||
                                                       '     , TMPF_NIT_FONDO          NIT_Fondo             ' ||
                                                       '     , TMPF_FONDO              Fondo                 ' ||
                                                       '     , TMPF_NIT_PAGADOR        NIT_Pagador           ' ||
                                                       '     , TMPF_PAGADOR            Pagador               ' ||
                                                       '     , TMPF_NIT_EMISOR         NIT_Emisor            ' ||
                                                       '     , TMPF_EMISOR             Emisor                ' ||
                                                       '     , TMPF_FACT_NUM_OPE       Fact_Nume_Opera       ' ||
                                                       '     , TMPF_PRODUCTO           Producto              ' ||
                                                       '     , TMPF_ESTADO             Estado                ' ||
                                                       '     , TMPF_PLAZO              Plazo                 ' ||
                                                       '     , TMPF_FECHA_COMPRA       Fecha_Compra          ' ||
                                                       '     , TMPF_FECHA_CUMPLIMIENTO Fecha_Cumplimiento    ' ||
                                                       '     , TMPF_TASA               Tasa                  ' ||
                                                       '     , TMPF_TASA_INDEXACION    Tasa_Indexacion       ' ||
                                                       '     , TMPF_PUNTOS_ADICIONALES Puntos_Adicionales    ' ||
                                                       '     , TMPF_TASA_MORA          Tasa_Mora             ' ||
                                                       '     , TMPF_DIAS_VENCIMIENTO   Dias_Vencimiento      ' ||
                                                       '     , TMPF_DIAS_MORA          Dias_Mora             ' ||
                                                       '     , TMPF_VALOR_COMPRA       Valor_Compra          ' ||
                                                       '     , TMPF_RENDIMIENTOS       Rendimientos          ' ||
                                                       '     , TMPF_DETERIORO          Deterioro             ' ||
                                                       '     , TMPF_DETERIORO_ACUM     Deterioro_Acumulado   ' ||
                                                       '     , TMPF_INTERES_MORA       Intereses_de_Mora     ' ||
                                                       '     , TMPF_VALOR_MERCADO      Valor_Mercado         ' ||
                                                       '     , TMPF_VALOR_FUTURO       Valor_Futuro          ' ||
                                                       '     , TMPF_VALOR_ABONO        Valor_Abono           ' ||
                                                       '     , TMPF_VALOR_ABONO_ACUM   Valor_Abono_Acumulado ' ||
                                                       '     , TMPF_BASE_MONETARIA     Base_Monetaria        ' ||
                                                       '     , TMPF_SECTOR_PIP         Sector_PIP            ' ||
                                                       '     , TMPF_GARANTIA           Garantia              ' ||
                                                       '     , TMPF_CUSTODIO           Custodio              ' ||
                                                       '     , TMPF_CON_RECURSO        Con_Recurso           ' ||
                                                       '     , TMPF_COMISION           Comision              ' ||
                                                       '     , TMPF_IVA_COMISION       Iva_Comision          ' ||
                                                       '     , TMPF_PREPAGO            Prepago               ' ||
                                                       '     , TMPF_FECHA_EMISION      Fecha_Emision         ' ||
                                                       '     , TMPF_VALOR_NOMINAL      Valor_Nominal         ' ||
                                                       '     , TMPF_DIST_DIA           Vr_Dist_Dia           ' ||
                                                       '     , TMPF_CALIFICACION       Calificacion          ' ||
                                                       '     , TMPF_UTILIDAD           Utilidad              ' ||
                                                       '     , TMPF_PERDIDA            Perdida               ' ||
                                                       '  FROM TMP_PORTAFOLIO_FACTORING',
                                   P_CODIGO         => P_CODIGO,
                                   P_RESPUESTA      => P_RESPUESTA);

    IF P_CODIGO = '0000' THEN
      DBMS_OUTPUT.PUT_LINE('Se ha generado el archivo, en la ruta ' ||
                           V_RUTA);
    END IF;

    V_RUTA         := '\\nas.corredor.local\Inversiones\confidencial\FIC_120\PORTAFOLIO\';
    NOMBRE_ARCHIVO := 'PORTAFOLIO_FACTORING_' ||
                      TO_CHAR(SYSDATE - 1, 'DDMMYYYY_hh24mmss');

    P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => V_RUTA,
                                   P_NOMBRE_ARCHIVO => NOMBRE_ARCHIVO,
                                   P_QUERY          => 'SELECT TMPF_FECHA_CORTE        Fecha_Corte           ' ||
                                                       '     , TMPF_NIT_FONDO          NIT_Fondo             ' ||
                                                       '     , TMPF_FONDO              Fondo                 ' ||
                                                       '     , TMPF_NIT_PAGADOR        NIT_Pagador           ' ||
                                                       '     , TMPF_PAGADOR            Pagador               ' ||
                                                       '     , TMPF_NIT_EMISOR         NIT_Emisor            ' ||
                                                       '     , TMPF_EMISOR             Emisor                ' ||
                                                       '     , TMPF_FACT_NUM_OPE       Fact_Nume_Opera       ' ||
                                                       '     , TMPF_PRODUCTO           Producto              ' ||
                                                       '     , TMPF_ESTADO             Estado                ' ||
                                                       '     , TMPF_PLAZO              Plazo                 ' ||
                                                       '     , TMPF_FECHA_COMPRA       Fecha_Compra          ' ||
                                                       '     , TMPF_FECHA_CUMPLIMIENTO Fecha_Cumplimiento    ' ||
                                                       '     , TMPF_TASA               Tasa                  ' ||
                                                       '     , TMPF_TASA_INDEXACION    Tasa_Indexacion       ' ||
                                                       '     , TMPF_PUNTOS_ADICIONALES Puntos_Adicionales    ' ||
                                                       '     , TMPF_TASA_MORA          Tasa_Mora             ' ||
                                                       '     , TMPF_DIAS_VENCIMIENTO   Dias_Vencimiento      ' ||
                                                       '     , TMPF_DIAS_MORA          Dias_Mora             ' ||
                                                       '     , TMPF_VALOR_COMPRA       Valor_Compra          ' ||
                                                       '     , TMPF_RENDIMIENTOS       Rendimientos          ' ||
                                                       '     , TMPF_DETERIORO          Deterioro             ' ||
                                                       '     , TMPF_DETERIORO_ACUM     Deterioro_Acumulado   ' ||
                                                       '     , TMPF_INTERES_MORA       Intereses_de_Mora     ' ||
                                                       '     , TMPF_VALOR_MERCADO      Valor_Mercado         ' ||
                                                       '     , TMPF_VALOR_FUTURO       Valor_Futuro          ' ||
                                                       '     , TMPF_VALOR_ABONO        Valor_Abono           ' ||
                                                       '     , TMPF_VALOR_ABONO_ACUM   Valor_Abono_Acumulado ' ||
                                                       '     , TMPF_BASE_MONETARIA     Base_Monetaria        ' ||
                                                       '     , TMPF_SECTOR_PIP         Sector_PIP            ' ||
                                                       '     , TMPF_GARANTIA           Garantia              ' ||
                                                       '     , TMPF_CUSTODIO           Custodio              ' ||
                                                       '     , TMPF_CON_RECURSO        Con_Recurso           ' ||
                                                       '     , TMPF_COMISION           Comision              ' ||
                                                       '     , TMPF_IVA_COMISION       Iva_Comision          ' ||
                                                       '     , TMPF_PREPAGO            Prepago               ' ||
                                                       '     , TMPF_FECHA_EMISION      Fecha_Emision         ' ||
                                                       '     , TMPF_VALOR_NOMINAL      Valor_Nominal         ' ||
                                                       '     , TMPF_DIST_DIA           Vr_Dist_Dia           ' ||
                                                       '     , TMPF_CALIFICACION       Calificacion          ' ||
                                                       '     , TMPF_UTILIDAD           Utilidad              ' ||
                                                       '     , TMPF_PERDIDA            Perdida               ' ||
                                                       '  FROM TMP_PORTAFOLIO_FACTORING',
                                   P_CODIGO         => P_CODIGO,
                                   P_RESPUESTA      => P_RESPUESTA);

    IF P_CODIGO = '0000' THEN
      DBMS_OUTPUT.PUT_LINE('Se ha generado el archivo, en la ruta ' ||
                           V_RUTA);
    END IF;

  EXCEPTION

    WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20059,
                              'No se genero el archivo, comuniquese con soporte, error: ' ||
                              SQLERRM);

  END P_ARCHIVO_PORTAFOLIO_FACT;

  -- Fin Portafolio - Proyecto Factoring VAGTUD876

  ----------------------
  --REPORTES PARA CONTRALORIA
  ---------------------

  PROCEDURE PR_REPORTE_MOVIMIENTOS(P_FECHA DATE) IS
    --DECLARE
    CURSOR C_BANCO IS
      SELECT DISTINCT (BAN.BAN_CODIGO),
                      BAN.BAN_NOMBRE,
                      CBA.CBA_NUMERO_CUENTA,
                      CASE
                        WHEN CBA.CBA_TCB_MNEMONICO = 'CCO' THEN
                         'CUENTA CORRIENTE'
                        ELSE
                         'CUENTA AHORROS'
                      END CBA_TCB_MNEMONICO,
                      CBA.CBA_NEG_CONSECUTIVO || '-' || NEG.NEG_DESCRIPCION CBA_NEG_CONSECUTIVO,
                      CBA.CBA_SUC_CODIGO
        FROM CUENTAS_BANCARIAS_CORREDORES CBA, BANCOS BAN, NEGOCIOS NEG
       WHERE CBA.CBA_BAN_CODIGO = BAN.BAN_CODIGO
         AND CBA.CBA_NEG_CONSECUTIVO = NEG.NEG_CONSECUTIVO
         AND BAN.BAN_ESTADO = 'A'
         AND CBA.CBA_ESTADO = 'A'
      --AND BAN.BAN_CODIGO = 1

       ORDER BY 1;
    P_BANCO C_BANCO%ROWTYPE;

    CURSOR C_FONDO(P_NUMERO_CUENTA VARCHAR2, P_BANCO NUMBER) IS
      SELECT FON_RAZON_SOCIAL
        FROM CUENTAS_BANCARIAS_FONDOS, FONDOS
       WHERE CBF_FON_CODIGO = FON_CODIGO
         AND CBF_BAN_CODIGO = P_BANCO
         AND CBF_NUMERO_CUENTA = P_NUMERO_CUENTA
      --AND CBF_ESTADO = 'A'
      --AND FON_ESTADO = 'A'
      ;
    C_FON C_FONDO%ROWTYPE;

    CURSOR C_MOVIMIENTO(P_NUMERO_CUENTA VARCHAR2,
                        P_BANCO         NUMBER,
                        P_FECHA_INI     DATE,
                        P_FECHA_FIN     DATE) IS
      SELECT MCB.MCB_CBA_BAN_CODIGO,
             MCB.MCB_CBA_NUMERO_CUENTA,
             MCB.MCB_FECHA,
             MCB.MCB_TMB_MNEMONICO,
             MCB.MCB_MONTO,
             MCB.MCB_CONCILIADO,
             TMB_DESCRIPCION,
             MCB.MCB_SUC_CODIGO,
             MCB.MCB_NEG_CONSECUTIVO MCB_NEG_CONSECUTIVO,
             MCB.MCB_CGE_CONSECUTIVO,
             MCB.MCB_CCJ_CONSECUTIVO,
             MCB.MCB_CEG_CONSECUTIVO,
             MCB.MCB_COB_CONSECUTIVO,
             MCB.MCB_TBC_CONSECUTIVO,
             MCB.MCB_TRC_CONSECUTIVO,
             MCB.MCB_CBA_BAN_CODIGO_TRANSFERENC,
             MCB.MCB_CBA_NUMERO_CUENTA_TRANSFER,
             MCB.MCB_NUMERO_NOTA,
             MCB.MCB_MCB_CONSECUTIVO,
             MCB.MCB_CDE_CONSECUTIVO,
             MCB.MCB_CGD_CONSECUTIVO,
             MCB.MCB_MDA_CONSECUTIVO
        FROM MOVIMIENTOS_CUENTAS_BANCARIAS MCB,
             TIPOS_MOVIMIENTOS_BANCOS      TMB
       WHERE MCB.MCB_TMB_MNEMONICO = TMB.TMB_MNEMONICO
         AND MCB_CBA_NUMERO_CUENTA = P_NUMERO_CUENTA
         AND MCB_CBA_BAN_CODIGO = P_BANCO
         AND MCB_FECHA <= TRUNC(P_FECHA_FIN + 1)
         AND MCB_FECHA > TRUNC(P_FECHA_INI)
       ORDER BY MCB.MCB_FECHA, MCB.MCB_CONSECUTIVO;
    P_MOVIMIENTO  C_MOVIMIENTO%ROWTYPE;
    P_MOVIMIENTO1 C_MOVIMIENTO%ROWTYPE;

    CURSOR C_SALDO(P_NUMERO_CUENTA VARCHAR2,
                   P_BANCO         NUMBER,
                   P_FECHA_INI     DATE) IS
      SELECT SCC_SALDO_MVTOS_CONCILIADOS + SCC_SALDO_MVTOS_NO_CONCILIADOS SCC_SALDO,
             SCC_FECHA
        FROM SALDOS_CTA_BANCARIA_CORREDORES
       WHERE SCC_CBA_BAN_CODIGO = P_BANCO --:BAN_CODIGO
         AND SCC_CBA_NUMERO_CUENTA = P_NUMERO_CUENTA --:CBA_NUMERO_CUENTA
         AND SCC_FECHA < TRUNC(TO_DATE(P_FECHA_INI, 'DD-MON-YYYY') + 1)
         AND SCC_CONFIRMADO = 'S'
       ORDER BY SCC_FECHA DESC;
    SCC C_SALDO%ROWTYPE;

    CURSOR C_MOVIMIENTOS(P_NUMERO_CUENTA VARCHAR2,
                         P_BANCO         NUMBER,
                         P_FECHA_INI     DATE,
                         P_FECHA_FIN     DATE) IS
      SELECT SUM(MCB_MONTO)
        FROM MOVIMIENTOS_CUENTAS_BANCARIAS
       WHERE MCB_CBA_BAN_CODIGO = P_BANCO --:BAN_CODIGO
         AND MCB_CBA_NUMERO_CUENTA = P_NUMERO_CUENTA --:CBA_NUMERO_CUENTA
         AND MCB_FECHA >= TRUNC(P_FECHA_INI) --TRUNC(SCC.SCC_FECHA)
         AND MCB_FECHA < TRUNC(TO_DATE(P_FECHA_FIN, 'DD-MON-YYYY'));

    CURSOR C_MOVIMIENTOS1(P_NUMERO_CUENTA VARCHAR2,
                          P_BANCO         NUMBER,
                          P_FECHA_FIN     DATE) IS
      SELECT SUM(MCB_MONTO)
        FROM MOVIMIENTOS_CUENTAS_BANCARIAS
       WHERE MCB_CBA_BAN_CODIGO = P_BANCO --:BAN_CODIGO
         AND MCB_CBA_NUMERO_CUENTA = P_NUMERO_CUENTA --:CBA_NUMERO_CUENTA
         AND MCB_FECHA < TRUNC(TO_DATE(P_FECHA_FIN, 'DD-MON-YYYY'));
    MONTO       NUMBER := 0;
    DEBITO      NUMBER;
    CREDITO     NUMBER;
    DEBITO1     NUMBER;
    CREDITO1    NUMBER;
    TOTAL       NUMBER;
    FINAL_MVTOS NUMBER;
    NOMBRE      VARCHAR2(300);
    DESCRIPCION VARCHAR2(200);

    SINO_DEV      VARCHAR2(1);
    P_FECHA_INI   DATE;
    P_FECHA_FIN   DATE;
    P_FECHA_SALDO DATE;

    ---------------------
    CURSOR C_PARAMETROS_CUENTAS(P_BANCO         NUMBER,
                                P_NUMERO_CUENTA VARCHAR2,
                                P_SUCURSAL      NUMBER) IS
      SELECT PCB.PBA_PRO_MNEMONICO, P.PRO_DESCRIPCION
        FROM PARAMETROS_CUENTAS_BANCARIAS PCB, PRODUCTOS P
       WHERE PCB.PBA_CBA_BAN_CODIGO = P_BANCO
         AND PCB.PBA_CBA_NUMERO_CUENTA = P_NUMERO_CUENTA
         AND PCB.PBA_SUC_CODIGO = P_SUCURSAL
         AND PCB.PBA_PRO_MNEMONICO = P.PRO_MNEMONICO;
    P_COD_PRODUCTO     VARCHAR2(10);
    P_PROD_DESCRIPCION VARCHAR2(100);
    CF_SALDO_INICIAL   NUMBER;
    DIA_HABIL          VARCHAR2(1);
    ------------------------

    TIP_ARCHIVO   UTL_FILE.FILE_TYPE;
    ARCHIVO_FONDO VARCHAR2(100);
    LINEA         VARCHAR2(5000);

  BEGIN
    --P_FECHA_FIN := '31-DIC-2020';
    P_FECHA_FIN := P_FECHA;
    --P_FECHA_INI := TRUNC (ADD_MONTHS(P_FECHA_FIN, -2),'MM');
    P_FECHA_INI   := P_FECHA_FIN;
    ARCHIVO_FONDO := 'RMOVBA' || '_' || TO_CHAR(P_FECHA_FIN, 'YYYYMMDD') ||
                     '.csv';
    DBMS_OUTPUT.put_line(ARCHIVO_FONDO);
    TIP_ARCHIVO := UTL_FILE.FOPEN('REPORTES_CONTRALORIA',
                                  ARCHIVO_FONDO,
                                  'W',
                                  10000);

    LINEA := 'GRUPO;' || 'BAN_CODIGO;' || 'BANCO;' || 'TIPO_CUENTA;' ||
             'CUENTA;' || 'NEGOCIO;' || 'FECHA;' || 'COMPARTIMENTO;' ||
             'COD_COMPAR;' || 'SALDO_LIBROS;' || 'TOTAL_MOV;' ||
             'SALDO_FINAL';
    UTL_FILE.PUT_LINE(TIP_ARCHIVO, LINEA);
    --DBMS_OUTPUT.PUT_LINE('LAS FECHAS SON :'||P_FECHA_FIN||' '||P_FECHA_INI);
    FOR P_BANCO IN C_BANCO LOOP
      OPEN C_FONDO(P_BANCO.CBA_NUMERO_CUENTA, P_BANCO.BAN_CODIGO);
      FETCH C_FONDO
        INTO NOMBRE;
      --DBMS_OUTPUT.PUT_LINE('NOMBRE '||NOMBRE);
      CLOSE C_FONDO;
      --DBMS_OUTPUT.PUT_LINE('P_FECHA_INI '||P_FECHA_INI);
      OPEN C_SALDO(P_BANCO.CBA_NUMERO_CUENTA,
                   P_BANCO.BAN_CODIGO,
                   P_FECHA_INI);
      FETCH C_SALDO
        INTO SCC;
      CLOSE C_SALDO;
      IF SCC.SCC_FECHA IS NULL THEN
        OPEN C_MOVIMIENTOS1(P_BANCO.CBA_NUMERO_CUENTA,
                            P_BANCO.BAN_CODIGO,
                            P_FECHA_INI);
        FETCH C_MOVIMIENTOS1
          INTO MONTO;
        CLOSE C_MOVIMIENTOS1;
        CF_SALDO_INICIAL := NVL(MONTO, 0);
      ELSE
        IF TRUNC(SCC.SCC_FECHA) =
           TRUNC(TO_DATE(P_FECHA_INI, 'DD-MON-YYYY')) THEN
          CF_SALDO_INICIAL := NVL(SCC.SCC_SALDO, 0);
        ELSE
          OPEN C_MOVIMIENTOS(P_BANCO.CBA_NUMERO_CUENTA,
                             P_BANCO.BAN_CODIGO,
                             SCC.SCC_FECHA,
                             P_FECHA_INI);
          FETCH C_MOVIMIENTOS
            INTO MONTO;
          CLOSE C_MOVIMIENTOS;
          CF_SALDO_INICIAL := NVL(SCC.SCC_SALDO, 0) + NVL(MONTO, 0);
        END IF;
      END IF;
      --DBMS_OUTPUT.PUT_LINE('CF_SALDO_INICIAL '||CF_SALDO_INICIAL);

      DEBITO1  := 0;
      CREDITO1 := 0;
      TOTAL    := 0;
      FOR P_MOVIMIENTO IN C_MOVIMIENTO(P_BANCO.CBA_NUMERO_CUENTA,
                                       P_BANCO.BAN_CODIGO,
                                       P_FECHA_INI,
                                       P_FECHA_FIN) LOOP
        DEBITO1     := 0;
        CREDITO1    := 0;
        DESCRIPCION := '';
        IF P_MOVIMIENTO.MCB_MONTO < 0 THEN
          --RETURN(-1 * :MCB_MONTO);
          DEBITO1 := -1 * P_MOVIMIENTO.MCB_MONTO;
        ELSE
          --RETURN 0;
          CREDITO1 := P_MOVIMIENTO.MCB_MONTO;
        END IF;

        TOTAL := TOTAL + NVL(CREDITO1, 0) - NVL(DEBITO1, 0);

      END LOOP;
      --DBMS_OUTPUT.PUT_LINE('TOTAL '||TOTAL);

      FINAL_MVTOS := 0;
      FINAL_MVTOS := (NVL(CF_SALDO_INICIAL, 0) + NVL(TOTAL, 0));

      OPEN C_PARAMETROS_CUENTAS(P_BANCO.BAN_CODIGO,
                                P_BANCO.CBA_NUMERO_CUENTA,
                                P_BANCO.CBA_SUC_CODIGO);
      FETCH C_PARAMETROS_CUENTAS
        INTO P_COD_PRODUCTO, P_PROD_DESCRIPCION;
      CLOSE C_PARAMETROS_CUENTAS;

      LINEA := ' ' || ';' || P_BANCO.BAN_CODIGO || ';' ||
               P_BANCO.BAN_NOMBRE || ';' || P_BANCO.CBA_TCB_MNEMONICO || ';' ||
               P_BANCO.CBA_NUMERO_CUENTA || ';' ||
               P_BANCO.CBA_NEG_CONSECUTIVO || ';' || P_FECHA_FIN || ';' ||
               P_PROD_DESCRIPCION || ';' || P_COD_PRODUCTO || ';' ||
               CF_SALDO_INICIAL || ';' || TOTAL || ';' || FINAL_MVTOS;
      UTL_FILE.PUT_LINE(TIP_ARCHIVO, LINEA);
    END LOOP;

    UTL_FILE.FCLOSE(TIP_ARCHIVO);

  END PR_REPORTE_MOVIMIENTOS;

  PROCEDURE PR_REPORTE_RENTA_VARIABLE(P_FECHA DATE) IS
    --DECLARE
    CURSOR C_CESVFO(P_FECHA_INI DATE, P_FECHA_FIN DATE) IS
      SELECT GNA_DESCRIPCION,
             ENA_MNEMONICO,
             ENA_CBU_MNEMONICO,
             VRV1.VRV_NUMERO_UNIDADES,
             VRV1.VRV_COSTO_PROMEDIO --* :P_BASE_MONETARIA VRV_COSTO_PROMEDIO
            ,
             VRV1.VRV_VALOR_ACTUAL --* :P_BASE_MONETARIA VRV_VALOR_ACTUAL
            ,
             VRV1.VRV_VALOR_ACTUAL_TOTAL,
             VRV1.VRV_VAL_COSTO_PROM_TOT --* :P_BASE_MONETARIA VRV_VAL_COSTO_PROM_TOT
            ,
             VRV1.VRV_VALORIZACION_ACUM --* :P_BASE_MONETARIA VRV_VALORIZACION_ACUM
            ,
             VRV1.VRV_VALORIZACION_DIARIA --* :P_BASE_MONETARIA VRV_VALORIZACION_DIARIA
            ,
             VRV1.VRV_FON_CODIGO FON_CODIGO,
             VRV1.VRV_FECHA,
             CASE
               WHEN ENA_TITULO_PARTICIPATIVO = 'S' AND
                    ENA_BST_MNEMONICO != 'EXT' THEN
                'TIT PART'
               ELSE
                ENA_BST_MNEMONICO
             END TIPO
        FROM VALORIZACIONES_RV VRV1, ESPECIES_NACIONALES, GRUPOS_NACIONALES
       WHERE VRV1.VRV_ENA_MNEMONICO = ENA_MNEMONICO
         AND ENA_GNA_MNEMONICO = GNA_MNEMONICO
         AND VRV1.VRV_FECHA >= P_FECHA_INI --'01-ENE-2021'--TRUNC(:P_FECHA)
         AND VRV1.VRV_FECHA < P_FECHA_FIN + 1 --'15-ENE-2021'--TRUNC(:P_FECHA + 1)
         AND VRV1.VRV_FECHA =
             (SELECT MAX(VRV2.VRV_FECHA)
                FROM VALORIZACIONES_RV VRV2
               WHERE VRV2.VRV_FECHA >= P_FECHA_INI --'01-ENE-2021'--TRUNC(:P_FECHA)
                 AND VRV2.VRV_FECHA < P_FECHA_FIN + 1 --'15-ENE-2021'--TRUNC(:P_FECHA + 1)
                 AND VRV2.VRV_FON_CODIGO = VRV1.VRV_FON_CODIGO
                 AND VRV2.VRV_ENA_MNEMONICO = VRV1.VRV_ENA_MNEMONICO)
            --- 16/DEC/2019 Entregable II
         AND NOT EXISTS
       (SELECT 'X'
                FROM CUENTAS_CLIENTE_CORREDORES CCC
               WHERE CCC.CCC_CUENTA_MASTER = 'S'
                 AND VRV1.VRV_CCC_CLI_PER_NUM_IDEN =
                     CCC.CCC_CLI_PER_NUM_IDEN
                 AND VRV1.VRV_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA)
      ---
      --&P_COND_FONDO
       ORDER BY GNA_DESCRIPCION, ENA_MNEMONICO;

    P_CESVFO C_CESVFO%ROWTYPE;

    CURSOR FECHA_PRECIO(P_ENA_MNEMONICO VARCHAR2, FECHA DATE) IS
      SELECT MAX(PEB_FECHA)
        FROM PRECIOS_ESPECIES_BOLSA
       WHERE PEB_ENA_MNEMONICO = P_ENA_MNEMONICO
         AND PEB_FECHA <= TO_CHAR(FECHA, 'DD-MON-YYYY');

    CURSOR PRECIO(P_ENA_MNEMONICO VARCHAR2, FECHA DATE) IS
      SELECT PEB_PRECIO_BOLSA
        FROM PRECIOS_ESPECIES_BOLSA
       WHERE PEB_ENA_MNEMONICO = P_ENA_MNEMONICO
         AND PEB_fecha = FECHA;

    CURSOR C_VNO(P_ENA_MNEMONICO VARCHAR2) IS
      SELECT VNO_VALOR_NOMINAL
        FROM VALORES_NOMINALES
       WHERE VNO_ENA_MNEMONICO = P_ENA_MNEMONICO
       ORDER BY VNO_FECHA DESC;
    CF_VALOR_MERCADO NUMBER;

    V_FECHA  DATE;
    V_PRECIO NUMBER(22, 8);
    V_VNO    NUMBER;

    CURSOR C_CBU(P_ENA_CBU_MNEMONICO VARCHAR2) IS
      SELECT CBU_DESCRIPCION
        FROM CALIFICADORES_BURSATILIDAD
       WHERE CBU_MNEMONICO = P_ENA_CBU_MNEMONICO;
    CBU C_CBU%ROWTYPE;

    CURSOR C_FONDO(P_FON_CODIGO VARCHAR2) IS
      SELECT FONDOS.FON_RAZON_SOCIAL
        FROM FONDOS
       WHERE FONDOS.FON_CODIGO = P_FON_CODIGO;
    V_FONDO     VARCHAR2(200);
    P_FECHA_INI DATE;
    P_FECHA_FIN DATE;
    P_ACU_DIA   NUMBER;

    FECHA DATE;
    V_BMO NUMBER;

    TIP_ARCHIVO   UTL_FILE.FILE_TYPE;
    ARCHIVO_FONDO VARCHAR2(100);
    LINEA         VARCHAR2(5000);

  BEGIN

    --P_FECHA_FIN := '31-DIC-2020';
    P_FECHA_FIN := P_FECHA;
    --P_FECHA_INI := TRUNC (ADD_MONTHS(P_FECHA_FIN, -2),'MM');
    P_FECHA_INI   := P_FECHA_FIN;
    ARCHIVO_FONDO := 'CESVFO' || '_' || TO_CHAR(P_FECHA_FIN, 'YYYYMMDD') ||
                     '.csv';
    DBMS_OUTPUT.put_line(ARCHIVO_FONDO);
    TIP_ARCHIVO := UTL_FILE.FOPEN('REPORTES_CONTRALORIA',
                                  ARCHIVO_FONDO,
                                  'W',
                                  10000);

    LINEA := 'GRUPO;' || 'FECHA;' || 'COD_FONDO;' || 'RAZON_SOCIAL;' ||
             'REPORTE;' || 'ESPECIE;' || 'UNIDAD;' || 'PRECIO_MERCADO;' ||
             'COSTO_PROMEDIO;' || 'VAL_ACTUAL;' || 'VAL_MERCADO;' ||
             'COSTO_PRM_INVERSION;' || 'VAL_ACUMULADO;' || 'VAL_DIA;' ||
             'ACUMULADO_MAS_DIAHABIL;' || 'VAL_NOMINA;' || 'BURSATILIDAD;' ||
             'TIPO';
    UTL_FILE.PUT_LINE(TIP_ARCHIVO, LINEA);

    FOR P_CESVFO IN C_CESVFO(P_FECHA_INI, P_FECHA_FIN) LOOP
      V_FECHA := '';
      OPEN FECHA_PRECIO(P_CESVFO.ENA_MNEMONICO, P_CESVFO.VRV_FECHA);
      FETCH FECHA_PRECIO
        INTO V_FECHA;
      --DBMS_OUTPUT.PUT_LINE('V_FECHA '||V_FECHA);
      CLOSE FECHA_PRECIO;

      V_PRECIO := 0;
      OPEN PRECIO(P_CESVFO.ENA_MNEMONICO, V_FECHA);
      FETCH PRECIO
        INTO V_PRECIO;
      --DBMS_OUTPUT.PUT_LINE('V_PRECIO '||V_PRECIO);
      CLOSE PRECIO;

      CF_VALOR_MERCADO := V_PRECIO * P_CESVFO.VRV_NUMERO_UNIDADES;

      V_VNO := 0;
      OPEN C_VNO(P_CESVFO.ENA_MNEMONICO);
      FETCH C_VNO
        INTO V_VNO;
      CLOSE C_VNO;

      OPEN C_CBU(P_CESVFO.ENA_CBU_MNEMONICO);
      FETCH C_CBU
        INTO CBU;
      CLOSE C_CBU;

      OPEN C_FONDO(P_CESVFO.FON_CODIGO);
      FETCH C_FONDO
        INTO V_FONDO;
      CLOSE C_FONDO;

      V_BMO := 1;

      P_ACU_DIA := P_CESVFO.VRV_VALORIZACION_ACUM +
                   P_CESVFO.VRV_VALORIZACION_DIARIA;

      LINEA := ' ' || ';' || P_FECHA_FIN || ';' || P_CESVFO.FON_CODIGO || ';' ||
               V_FONDO || ';' || 'CESVFO.REP' || ';' ||
               P_CESVFO.ENA_MNEMONICO || ';' ||
               P_CESVFO.VRV_NUMERO_UNIDADES || ';' || V_PRECIO || ';' ||
               P_CESVFO.VRV_COSTO_PROMEDIO || ';' ||
               P_CESVFO.VRV_VALOR_ACTUAL || ';' || CF_VALOR_MERCADO || ';' ||
               P_CESVFO.VRV_VAL_COSTO_PROM_TOT || ';' ||
               P_CESVFO.VRV_VALORIZACION_ACUM || ';' ||
               P_CESVFO.VRV_VALORIZACION_DIARIA || ';' || P_ACU_DIA || ';' ||
               V_VNO || ';' || CBU.CBU_DESCRIPCION || ';' || P_CESVFO.TIPO;
      UTL_FILE.PUT_LINE(TIP_ARCHIVO, LINEA);

    END LOOP;
    UTL_FILE.FCLOSE(TIP_ARCHIVO);
  END PR_REPORTE_RENTA_VARIABLE;

  PROCEDURE PR_REPORTE_RENTA_FIJA(P_FECHA DATE) IS
    --DECLARE
    CURSOR C_COPORF(P_FECHA_INI DATE, P_FECHA_FIN DATE) IS
      select /*+ INDEX (MRF1 MRF_PK) */
       FON_CODIGO,
       FON_RAZON_SOCIAL,
       FON_BMO_MNEMONICO,
       FON_TIPO,
       EMI_MNEMONICO,
       EMI_DESCRIPCION,
       GNA_MNEMONICO,
       GNA_DESCRIPCION,
       TFO_CODIGO,
       TFO_FON_CODIGO,
       TFO_ENA_MNEMONICO,
       TFO_VALOR_NOMINAL,
       TFO_PUNTOS_ADICIONALES,
       TFO_TRE_MNEMONICO,
       TFO_TASA_FACIAL,
       TFO_BMO_MNEMONICO,
       TFO_ETI_CODIGO,
       to_char(TFO_PERIODICIDAD_TASA) || TFO_MODALIDAD_TASA Moda,
       TFO_FECHA_EMISION,
       TFO_FECHA_VENCIMIENTO,
       TFO_FECHA_OPERACION,
       TFO_VALOR_OPERACION,
       TFO_MERCADO_COMPRA,
       TFO_LTI_MNEMONICO,
       TFO_TASA_MRC_CONGELADA,
       TFO_PRC_PRF_CONSECUTIVO,
       TFO_PRC_CONSECUTIVO,
       TFO_PRV_PRF_CONSECUTIVO,
       TFO_PRV_CONSECUTIVO,
       MRF1.MRF_TIR365_C * 100 MRF_TIR365_C,
       MRF1.MRF_TIR365_M,
       MRF1.MRF_MPE * 100 MRF_MPE,
       MRF1.MRF_VALOR_TITULO_TM,
       MRF1.MRF_VALORIZACION_TM,
       MRF1.MRF_VALORIZACION_TC,
       MRF1.MRF_VALOR_DISTRIBUIR_DIA,
       MRF1.MRF_TAI * 100 MRF_TAI,
       MRF1.MRF_DIFERENCIA_CAMBIO,
       NVL(TRUNC(MRF1.MRF_FECHA_VALORIZACION), TRUNC(MRF1.MRF_FECHA)) FECHA_VALORIZACION,
       TFO_DISTRIBUCION_ACUMULADA,
       MRF1.MRF_PRECIO,
       MRF1.MRF_MARGEN,
       MRF1.MRF_INDICE,
       MRF1.MRF_TASA,
       MRF1.MRF_TASA_DESCUENTO,
       MRF1.MRF_PRECIO_ALT,
       MRF1.MRF_TASA_ALT,
       MRF1.MRF_TASA_DESCUENTO_ALT,
       MRF1.MRF_PROV_PRINCIPAL,
       MRF1.MRF_PROV_ALTERNO,
       TFO_FONDEO,
       MRF1.MRF_FECHA_VALORIZACION,
       MRF1.MRF_FECHA,
       TFO_DERIVADO,
       DECODE(TFO_TIPO_PAGO_FLUJO, 'P', 'Previo', 'V', 'Vigente') TIPO_PAGO_FLUJO,
       MRF_INDICADOR,
       MRF_VIGENCIA,
       TFO_CAPITALIZABLE,
       MRF_TMT_MNEMONICO,
       ENA_MNEMONICO_SUPERVALORES,
       TFO_FUG_ISI_MNEMONICO || '' || TFO_NUMERO_EMISION_DCV TFO_FUG_ISI_MNEMONICO,
       DECODE(TFO_LTI_MNEMONICO,
              'DA',
              'DECEVAL',
              'DV',
              'DCV',
              TFO_LTI_MNEMONICO) TFO_LTI_MNEMONICO_D,
       DECODE(TFO_TIPO_GARANTIA,
              'CRCC',
              'GARANTIA CRCC',
              'BVC',
              'GARANTIA BVC',
              'DIVISAS',
              'GARANTIA DIVISAS',
              TFO_TIPO_GARANTIA) TFO_TIPO_GARANTIA,
       TFO_CUENTA_CRCC,
       TFO_SEGMENTO,
       TFO_SALDO_GARANTIA_SIM
        from TITULOS_FONDOS,
             ESPECIES_NACIONALES,
             FONDOS,
             EMISORES,
             GRUPOS_NACIONALES,
             MVTOS_RENTA_FIJA MRF1
       where ((FON_TIPO = 'A') OR
             (FON_TIPO IN ('C', 'E') AND
             TRUNC(FON_FECHA_FINALIZACION) >= TRUNC(SYSDATE)))
         AND NOT EXISTS
       (SELECT 'X'
                FROM PARAMETROS_FONDOS
               WHERE PFO_FON_CODIGO = FONDOS.FON_CODIGO
                 AND PFO_PAR_CODIGO in (70)
                 AND NVL(PFO_RANGO_MIN_CHAR, 'N') = 'S')
         and TFO_FON_CODIGO = FON_CODIGO
         and TFO_TYPE = 'TRF'
         and TFO_ENA_MNEMONICO = ENA_MNEMONICO
         and EMI_MNEMONICO = ENA_EMI_MNEMONICO
            --and EMI_MNEMONICO like :QueEmisor
         and GNA_MNEMONICO = ENA_GNA_MNEMONICO
            --and GNA_MNEMONICO like :QueGrupoE
            --&COND_MONTO
         and MRF1.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
         and MRF1.MRF_TFO_CODIGO = TFO_CODIGO
         and MRF1.MRF_FECHA >= P_FECHA_INI --'15-DIC-2020' --TRUNC(:QueFecha )
         and MRF1.MRF_FECHA < P_FECHA_FIN + 1 --'16-DIC-2020' --TRUNC(:QueFecha+1 )
         AND (MRF1.MRF_FECHA =
             (SELECT /*+ INDEX (MRF2 MRF_PK) */
                MAX(MRF2.MRF_FECHA)
                 FROM MVTOS_RENTA_FIJA MRF2
                WHERE MRF2.MRF_TFO_FON_CODIGO = MRF1.MRF_TFO_FON_CODIGO
                  AND MRF2.MRF_TFO_CODIGO = MRF1.MRF_TFO_CODIGO
                  AND MRF2.MRF_FECHA >= P_FECHA_INI --'15-DIC-2020' --TRUNC(:QueFecha)
                  AND MRF2.MRF_FECHA < P_FECHA_FIN + 1 --'16-DIC-2020' --TRUNC(:QueFecha + 1)
               ) AND
             ((EXISTS
              (SELECT /*+ INDEX (CFD CFD_PK) */
                  'X'
                   FROM CONFIRMACION_FONDOS_DIA CFD
                  WHERE CFD_FON_CODIGO = TFO_FON_CODIGO
                    AND CFD_FECHA >= P_FECHA_INI + 1 --'16-DIC-2020' --TRUNC(:QueFecha + 1)
                    AND CFD_FECHA < P_FECHA_FIN + 2 --'17-DIC-2020' --TRUNC(:QueFecha + 2)
                    AND CFD_VALORIZACION_PORTAFOLIO = 'S') AND EXISTS
              (SELECT /*+ INDEX (MRF3 MRF_PK) */
                  'X'
                   FROM MVTOS_RENTA_FIJA MRF3
                  WHERE MRF3.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                    AND MRF3.MRF_TFO_CODIGO = TFO_CODIGO
                    AND MRF3.MRF_FECHA >= P_FECHA_INI + 1 --'16-DIC-2020' --TRUNC(:QueFecha + 1)
                    AND MRF3.MRF_FECHA < P_FECHA_FIN + 2 --'17-DIC-2020' --TRUNC(:QueFecha + 2)
                    AND (MRF3.MRF_TMT_MNEMONICO = 'VAF' OR
                        (MRF3.MRF_TMT_MNEMONICO IN ('VGA', 'LRI', 'GRI')
                        --AND
                        --:P_TGA = 'S'
                        ))) AND TFO_FECHA_OPERACION < P_FECHA_FIN + 1 --'16-DIC-2020' --TRUNC(:QueFecha + 1)
             ) OR (NOT EXISTS (SELECT /*+ INDEX (CFD CFD_PK) */
                                  'X'
                                   FROM CONFIRMACION_FONDOS_DIA
                                  WHERE CFD_FON_CODIGO = TFO_FON_CODIGO
                                    AND CFD_FECHA >= P_FECHA_INI + 1 --'16-DIC-2020' --TRUNC(:QueFecha + 1)
                                    AND CFD_FECHA < P_FECHA_INI + 2 --'17-DIC-2020' --TRUNC(:QueFecha + 2)
                                    AND CFD_VALORIZACION_PORTAFOLIO = 'S') AND
              TFO_DIA_SIGUIENTE = 'S') OR
             (EXISTS
              (SELECT /*+ INDEX (MRF4 MRF_PK) */
                  'X'
                   FROM MVTOS_RENTA_FIJA MRF4
                  WHERE MRF4.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                    AND MRF4.MRF_TFO_CODIGO = TFO_CODIGO
                    AND MRF4.MRF_FECHA >= P_FECHA_INI --'15-DIC-2020' --TRUNC(:QueFecha)
                    AND MRF4.MRF_FECHA < P_FECHA_FIN + 1 --'16-DIC-2020' --TRUNC(:QueFecha + 1)
                    AND MRF4.MRF_TMT_MNEMONICO IN
                        ('VGA', 'REN', 'AMR', 'CRE')
                    AND MRF4.MRF_FECHA =
                        (SELECT MAX(MRF5.MRF_FECHA)
                           FROM MVTOS_RENTA_FIJA MRF5
                          WHERE MRF5.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                            AND MRF5.MRF_TFO_CODIGO = TFO_CODIGO)) AND
              TFO_ETI_CODIGO IN ('ANU', 'TGA')
             --AND :P_TGA = 'S'
             ) OR
             (EXISTS
              (SELECT /*+ INDEX (MRF4 MRF_PK) */
                  'X'
                   FROM MVTOS_RENTA_FIJA MRF4
                  WHERE MRF4.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                    AND MRF4.MRF_TFO_CODIGO = TFO_CODIGO
                    AND MRF4.MRF_FECHA >= P_FECHA_INI --'15-DIC-2020' --TRUNC(:QueFecha)
                    AND MRF4.MRF_FECHA < P_FECHA_FIN + 1 --'16-DIC-2020' --TRUNC(:QueFecha + 1)
                    AND MRF4.MRF_TMT_MNEMONICO IN ('VAF', 'CRF', 'REN')
                    AND MRF4.MRF_FECHA =
                        (SELECT MAX(MRF5.MRF_FECHA)
                           FROM MVTOS_RENTA_FIJA MRF5
                          WHERE MRF5.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                            AND MRF5.MRF_TFO_CODIGO = TFO_CODIGO)) AND
              TFO_ETI_CODIGO IN ('UNI', 'FRC', 'IAP') AND EXISTS
              (SELECT /*+ INDEX (MRF4 MRF_PK) */
                  'X'
                   FROM MVTOS_RENTA_FIJA MRF4, FRACCIONAMIENTOS_UNIFICACIONES
                  WHERE MRF4.MRF_TFO_FON_CODIGO =
                        FUN_TFO_FON_CODIGO_ES_PRODUCID
                    AND MRF4.MRF_TFO_CODIGO = FUN_TFO_CODIGO_ES_PRODUCIDA
                    AND MRF4.MRF_FECHA >= P_FECHA_INI + 1 --'16-DIC-2020' --TRUNC(:QueFecha + 1)
                    AND MRF4.MRF_FECHA < P_FECHA_FIN + 2 --'17-DIC-2020' --TRUNC(:QueFecha + 2)
                    AND MRF4.MRF_TMT_MNEMONICO IN ('UNI', 'FRA')
                    AND FUN_TFO_FON_CODIGO = TFO_FON_CODIGO
                    AND FUN_TFO_CODIGO = TFO_CODIGO)) OR
             (EXISTS (SELECT /*+ INDEX (MRF4 MRF_PK) */
                         'X'
                          FROM MVTOS_RENTA_FIJA MRF4
                         WHERE MRF4.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                           AND MRF4.MRF_TFO_CODIGO = TFO_CODIGO
                           AND MRF4.MRF_FECHA >= P_FECHA_INI --'15-DIC-2020' --TRUNC(:QueFecha)
                           AND MRF4.MRF_FECHA < P_FECHA_FIN + 1 --'16-DIC-2020' --TRUNC(:QueFecha + 1)
                           AND MRF4.MRF_TMT_MNEMONICO IN ('TGA')
                        --AND     :P_TGA = 'S'
                        ))))
       order by FON_CODIGO, EMI_DESCRIPCION, GNA_DESCRIPCION, TFO_CODIGO;
    P_COPORF C_COPORF%ROWTYPE;

    CURSOR C_FRACCIONAMIENTO(P_FON_CODIGO VARCHAR2, P_TFO_CODIGO VARCHAR2) IS
      SELECT 'X'
        FROM FRACCIONAMIENTOS_UNIFICACIONES
       WHERE FUN_TFO_FON_CODIGO_ES_PRODUCID = P_FON_CODIGO
         AND FUN_TFO_CODIGO_ES_PRODUCIDA = P_TFO_CODIGO;
    COND VARCHAR2(1);

    CURSOR C_PRC(P_TFO_PRC_PRF_CONSECUTIVO NUMBER,
                 P_FON_CODIGO              VARCHAR2,
                 P_TFO_PRC_CONSECUTIVO     NUMBER) IS
      SELECT PRC_CNE_MNEMONICO
        FROM PREORDENES_COMPRA
       WHERE PRC_PRF_CONSECUTIVO = P_TFO_PRC_PRF_CONSECUTIVO
         AND PRC_PRF_FON_CODIGO = P_FON_CODIGO
         AND PRC_CONSECUTIVO = P_TFO_PRC_CONSECUTIVO;

    CURSOR C_PRV(P_TFO_PRV_PRF_CONSECUTIVO NUMBER,
                 P_FON_CODIGO              VARCHAR2,
                 P_TFO_PRV_CONSECUTIVO     NUMBER) IS
      SELECT PRV_CNE_MNEMONICO, PRV_ARBITRAJE
        FROM PREORDENES_VENTA
       WHERE PRV_PRF_CONSECUTIVO = P_TFO_PRV_PRF_CONSECUTIVO
         AND PRV_PRF_FON_CODIGO = P_FON_CODIGO
         AND PRV_CONSECUTIVO = P_TFO_PRV_CONSECUTIVO;

    CURSOR C_MRF(P_FON_CODIGO VARCHAR2, P_TFO_CODIGO NUMBER) IS
      SELECT MRF_FECHA, MRF_TMT_MNEMONICO
        FROM MVTOS_RENTA_FIJA
       WHERE MRF_TFO_FON_CODIGO = P_FON_CODIGO
         AND MRF_TFO_CODIGO = P_TFO_CODIGO
       ORDER BY MRF_FECHA ASC;
    R_MRF C_MRF%ROWTYPE;

    CURSOR C_ETI(P_FON_CODIGO VARCHAR2, P_TFO_CODIGO NUMBER) IS
      SELECT TFO_ETI_CODIGO
        FROM TITULOS_FONDOS
       WHERE TFO_FON_CODIGO = P_FON_CODIGO
         AND TFO_CODIGO = P_TFO_CODIGO;
    P_TFO_ETI_CODIGO C_ETI%ROWTYPE;

    CNE_MNEMONICO VARCHAR2(5);
    ARBITRAJE     VARCHAR2(1);
    DESCRIPCION   VARCHAR2(20);
    CONSEC        NUMBER;
    P_FECHA_INI   DATE;
    P_FECHA_FIN   DATE;

    CURSOR VAL_MON(MON VARCHAR2, P_FECHA DATE) IS
      SELECT CBM_VALOR
        FROM COTIZACIONES_BASE_MONETARIAS
       WHERE CBM_BMO_MNEMONICO = MON
         AND CBM_FECHA >= TRUNC(P_FECHA) --NVL(TRUNC(:MRF_FECHA_VALORIZACION),TRUNC(:MRF_FECHA))
         AND CBM_FECHA < TRUNC(P_FECHA + 1); --NVL(TRUNC(:MRF_FECHA_VALORIZACION + 1),TRUNC(:MRF_FECHA + 1));
    FACT_MON  NUMBER;
    FACT_MON1 NUMBER;
    VALOR_TM  NUMBER;
    V_FECHA   DATE;
    TOTAL     NUMBER;
    CONT      NUMBER := 0;

    TIP_ARCHIVO   UTL_FILE.FILE_TYPE;
    ARCHIVO_FONDO VARCHAR2(100);
    LINEA         VARCHAR2(5000);

  BEGIN
    --P_FECHA_FIN := '31-DIC-2020';
    P_FECHA_FIN := P_FECHA;
    --P_FECHA_INI := TRUNC (ADD_MONTHS(P_FECHA_FIN, -2),'MM');
    P_FECHA_INI := P_FECHA_FIN;
    --DBMS_OUTPUT.PUT_LINE('FECHAS ' || P_FECHA_FIN || ' ' || P_FECHA_INI);
    ARCHIVO_FONDO := 'COPORF' || '_' || TO_CHAR(P_FECHA_FIN, 'YYYYMMDD') ||
                     '.csv';
    DBMS_OUTPUT.put_line(ARCHIVO_FONDO);
    TIP_ARCHIVO := UTL_FILE.FOPEN('REPORTES_CONTRALORIA',
                                  ARCHIVO_FONDO,
                                  'W',
                                  10000);

    LINEA := 'VACIO' || ';' || 'FECHA' || ';' || 'COD_FONDO' || ';' ||
             'RAZON_SOCIAL' || ';' || 'REPORTE' || ';' || 'GRUPO' || ';' ||
             'EMISOR' || ';' || 'CODIGO' || ';' || 'ESPECIE' || ';' ||
             'VALOR_TITULO_PIP' || ';' || 'TIPO_INVERSION' || ';' ||
             'NEGOCIO';
    UTL_FILE.PUT_LINE(TIP_ARCHIVO, LINEA);
    FOR P_COPORF IN C_COPORF(P_FECHA_INI, P_FECHA_FIN) LOOP

      DESCRIPCION := '';
      OPEN C_ETI(P_COPORF.FON_CODIGO, P_COPORF.TFO_CODIGO);
      FETCH C_ETI
        INTO P_TFO_ETI_CODIGO;
      CLOSE C_ETI;

      IF P_COPORF.TFO_PRV_PRF_CONSECUTIVO IS NOT NULL AND
         P_COPORF.TFO_PRV_CONSECUTIVO IS NOT NULL THEN
        OPEN C_PRV(P_COPORF.TFO_PRV_PRF_CONSECUTIVO,
                   P_COPORF.FON_CODIGO,
                   P_COPORF.TFO_PRV_CONSECUTIVO);
        FETCH C_PRV
          INTO CNE_MNEMONICO, ARBITRAJE;
        CLOSE C_PRV;
      END IF;

      IF P_COPORF.TFO_PRC_PRF_CONSECUTIVO IS NOT NULL AND
         P_COPORF.TFO_PRC_CONSECUTIVO IS NOT NULL THEN
        OPEN C_PRC(P_COPORF.TFO_PRC_PRF_CONSECUTIVO,
                   P_COPORF.FON_CODIGO,
                   P_COPORF.TFO_PRC_CONSECUTIVO);
        FETCH C_PRC
          INTO CNE_MNEMONICO;
        CLOSE C_PRC;
      END IF;

      OPEN C_MRF(P_COPORF.FON_CODIGO, P_COPORF.TFO_CODIGO);
      FETCH C_MRF
        INTO R_MRF;
      CLOSE C_MRF;
      --DBMS_OUTPUT.PUT_LINE('R_MRF '||R_MRF.MRF_FECHA||' - '||R_MRF.MRF_TMT_MNEMONICO);
      IF R_MRF.MRF_TMT_MNEMONICO IN ('TGA', 'VGA', 'AMR', 'REN') THEN
        --= 'TGA' THEN
        --IF :MRF_TMT_MNEMONICO IN ('TGA','VGA','AMR','REN') THEN
        IF P_COPORF.TFO_PRC_PRF_CONSECUTIVO IS NOT NULL AND
           P_COPORF.TFO_PRC_CONSECUTIVO IS NOT NULL THEN
          OPEN C_PRC(P_COPORF.TFO_PRC_PRF_CONSECUTIVO,
                     P_COPORF.FON_CODIGO,
                     P_COPORF.TFO_PRC_CONSECUTIVO);
          FETCH C_PRC
            INTO CNE_MNEMONICO;
          CLOSE C_PRC;
        END IF;

        IF CNE_MNEMONICO = 'SIM' THEN
          IF NVL(ARBITRAJE, 'N') = 'S' THEN
            DESCRIPCION := 'Gar.Sim.Activa - Arbitraje';
          ELSE
            DESCRIPCION := 'Gar.Sim.Activa';
          END IF;
        END IF;
        DESCRIPCION := 'Gar.Fon.Activo';
        --END IF;
      END IF;
      --DBMS_OUTPUT.PUT_LINE('P_COPORF.TFO_DERIVADO '||P_COPORF.TFO_DERIVADO);
      IF NVL(P_COPORF.TFO_DERIVADO, 'N') = 'S' THEN
        IF P_COPORF.TFO_PRC_PRF_CONSECUTIVO IS NOT NULL THEN
          IF P_COPORF.TFO_FONDEO = 'S' THEN
            DESCRIPCION := 'Oblig. Compra';
          ELSE
            DESCRIPCION := 'Derecho Compra';
          END IF;
        ELSIF P_COPORF.TFO_PRV_PRF_CONSECUTIVO IS NOT NULL THEN
          IF P_COPORF.TFO_FONDEO = 'S' THEN
            DESCRIPCION := 'Derecho Venta';
          ELSE
            DESCRIPCION := 'Oblig. Venta';
          END IF;
        ELSE
          DESCRIPCION := ' ';
        END IF;
      ELSE
        --DBMS_OUTPUT.PUT_LINE('P_TFO_ETI_CODIGO.TFO_ETI_CODIGO '||P_TFO_ETI_CODIGO.TFO_ETI_CODIGO);
        IF P_TFO_ETI_CODIGO.TFO_ETI_CODIGO = 'IAP' THEN
          DESCRIPCION := 'Inv. Aplazada';
        END IF;
        --DBMS_OUTPUT.PUT_LINE('P_COPORF.TFO_FONDEO '||P_COPORF.TFO_FONDEO);
        IF P_COPORF.TFO_FONDEO = 'S' THEN
          IF P_COPORF.TFO_PRV_PRF_CONSECUTIVO IS NOT NULL THEN
            IF P_TFO_ETI_CODIGO.TFO_ETI_CODIGO = 'IAP' THEN
              DESCRIPCION := 'Inv. Aplazada';
            END IF;

            IF P_COPORF.TFO_PRV_PRF_CONSECUTIVO IS NOT NULL AND
               P_COPORF.TFO_PRV_CONSECUTIVO IS NOT NULL THEN
              OPEN C_PRV(P_COPORF.TFO_PRV_PRF_CONSECUTIVO,
                         P_COPORF.FON_CODIGO,
                         P_COPORF.TFO_PRV_CONSECUTIVO);
              FETCH C_PRV
                INTO CNE_MNEMONICO, ARBITRAJE;
              CLOSE C_PRV;
            END IF;

            IF P_COPORF.TFO_PRC_PRF_CONSECUTIVO IS NOT NULL AND
               P_COPORF.TFO_PRC_CONSECUTIVO IS NOT NULL THEN
              OPEN C_PRC(P_COPORF.TFO_PRC_PRF_CONSECUTIVO,
                         P_COPORF.FON_CODIGO,
                         P_COPORF.TFO_PRC_CONSECUTIVO);
              FETCH C_PRC
                INTO CNE_MNEMONICO;
              CLOSE C_PRC;
            END IF;

            IF CNE_MNEMONICO = 'SIM' THEN
              IF NVL(ARBITRAJE, 'N') = 'S' THEN
                DESCRIPCION := 'Sim.Pasivo-Arbitraje';
              ELSE
                DESCRIPCION := 'Sim.Pasivo';
              END IF;
            END IF;
            DESCRIPCION := 'Fon.Pasivo';
          END IF;
          IF P_COPORF.TFO_PRC_PRF_CONSECUTIVO IS NOT NULL THEN
            IF P_COPORF.TFO_ETI_CODIGO = 'IAP' THEN
              DESCRIPCION := 'Inv. Aplazada';
            END IF;

            IF P_COPORF.TFO_PRV_PRF_CONSECUTIVO IS NOT NULL AND
               P_COPORF.TFO_PRV_CONSECUTIVO IS NOT NULL THEN
              OPEN C_PRV(P_COPORF.TFO_PRV_PRF_CONSECUTIVO,
                         P_COPORF.FON_CODIGO,
                         P_COPORF.TFO_PRV_CONSECUTIVO);
              FETCH C_PRV
                INTO CNE_MNEMONICO, ARBITRAJE;
              CLOSE C_PRV;
            END IF;

            IF P_COPORF.TFO_PRC_PRF_CONSECUTIVO IS NOT NULL AND
               P_COPORF.TFO_PRC_CONSECUTIVO IS NOT NULL THEN
              OPEN C_PRC(P_COPORF.TFO_PRC_PRF_CONSECUTIVO,
                         P_COPORF.FON_CODIGO,
                         P_COPORF.TFO_PRC_CONSECUTIVO);
              FETCH C_PRC
                INTO CNE_MNEMONICO;
              CLOSE C_PRC;
            END IF;

            IF CNE_MNEMONICO = 'SIM' THEN
              IF NVL(ARBITRAJE, 'N') = 'S' THEN
                DESCRIPCION := 'Sim.Activa - Arbitraje';
              ELSE
                DESCRIPCION := 'Sim.Activa';
              END IF;
            END IF;
            DESCRIPCION := 'Fon.Activo';
          END IF;
        ELSE
          --DBMS_OUTPUT.PUT_LINE('P_COPORF.TFO_PRC_PRF_CONSECUTIVO '||P_COPORF.TFO_PRC_PRF_CONSECUTIVO);
          IF P_COPORF.TFO_PRC_PRF_CONSECUTIVO IS NOT NULL THEN
            --DBMS_OUTPUT.PUT_LINE('P_TFO_ETI_CODIGO.TFO_ETI_CODIGO '||P_TFO_ETI_CODIGO.TFO_ETI_CODIGO);
            IF P_TFO_ETI_CODIGO.TFO_ETI_CODIGO = 'IAP' THEN
              DESCRIPCION := 'Inv. Aplazada';
            ELSE
              DESCRIPCION := 'Inversion';
            END IF;
          END IF;
          IF P_COPORF.TFO_PRV_PRF_CONSECUTIVO IS NOT NULL THEN
            IF P_COPORF.TFO_PRV_PRF_CONSECUTIVO IS NOT NULL AND
               P_COPORF.TFO_PRV_CONSECUTIVO IS NOT NULL THEN
              OPEN C_PRV(P_COPORF.TFO_PRV_PRF_CONSECUTIVO,
                         P_COPORF.FON_CODIGO,
                         P_COPORF.TFO_PRV_CONSECUTIVO);
              FETCH C_PRV
                INTO CNE_MNEMONICO, ARBITRAJE;
              CLOSE C_PRV;
            END IF;

            IF P_COPORF.TFO_PRC_PRF_CONSECUTIVO IS NOT NULL AND
               P_COPORF.TFO_PRC_CONSECUTIVO IS NOT NULL THEN
              OPEN C_PRC(P_COPORF.TFO_PRC_PRF_CONSECUTIVO,
                         P_COPORF.FON_CODIGO,
                         P_COPORF.TFO_PRC_CONSECUTIVO);
              FETCH C_PRC
                INTO CNE_MNEMONICO;
              CLOSE C_PRC;
            END IF;

            --DBMS_OUTPUT.PUT_LINE('CNE_MNEMONICO '||CNE_MNEMONICO);
            IF CNE_MNEMONICO = 'SIM' THEN
              IF NVL(ARBITRAJE, 'N') = 'S' THEN
                DESCRIPCION := 'Gar.Sim.Pasivo-Arbitraje';
              ELSE
                DESCRIPCION := 'Gar.Sim.Pasivo';
              END IF;
            END IF;
            IF DESCRIPCION IS NULL THEN
              DESCRIPCION := 'Gar.Fon.Pasivo';
            END IF;
          END IF;
        END IF;
        IF DESCRIPCION IS NULL THEN
          DESCRIPCION := 'Inversion';
        END IF;
      END IF;

      IF P_COPORF.TFO_PRV_PRF_CONSECUTIVO IS NOT NULL THEN
        CONSEC := P_COPORF.TFO_PRV_PRF_CONSECUTIVO;
      ELSE
        CONSEC := P_COPORF.TFO_PRC_PRF_CONSECUTIVO;
      END IF;

      ------------------- valor titulo
      IF P_COPORF.FON_TIPO = 'A' AND P_COPORF.FON_BMO_MNEMONICO != 'PESOS' THEN
        IF P_COPORF.TFO_BMO_MNEMONICO = 'PESOS' THEN
          VALOR_TM := P_COPORF.MRF_VALOR_TITULO_TM;
          VALOR_TM := VALOR_TM;

        ELSE
          IF P_COPORF.TFO_BMO_MNEMONICO != P_COPORF.FON_BMO_MNEMONICO THEN
            IF P_COPORF.TFO_BMO_MNEMONICO = 'DOLAR' THEN
              OPEN VAL_MON(P_COPORF.TFO_BMO_MNEMONICO,
                           TRUNC(P_FECHA_INI + 1));
            ELSE
              OPEN VAL_MON(P_COPORF.TFO_BMO_MNEMONICO, TRUNC(P_FECHA_INI));
              --OPEN VAL_MON(:FON_BMO_MNEMONICO, TRUNC(V_FECHA+1));
            END IF;

            FETCH VAL_MON
              INTO FACT_MON;
            IF VAL_MON%NOTFOUND THEN
              DBMS_OUTPUT.PUT_LINE('10009,No se encontro cotizacion para la base ' ||
                                   P_COPORF.TFO_BMO_MNEMONICO ||
                                   ' en la fecha ' ||
                                   TO_CHAR(P_FECHA_INI, 'DD-MON-YYYY'));
            END IF;
            CLOSE VAL_MON;

            OPEN VAL_MON(P_COPORF.FON_BMO_MNEMONICO,
                         TRUNC(P_FECHA_INI + 1));
            FETCH VAL_MON
              INTO FACT_MON1;
            IF VAL_MON%NOTFOUND THEN
              DBMS_OUTPUT.PUT_LINE('10009,No se encontro cotizacion para la base ' ||
                                   P_COPORF.FON_BMO_MNEMONICO ||
                                   ' en la fecha ' ||
                                   TO_CHAR(P_FECHA_INI + 1, 'DD-MON-YYYY'));
            END IF;
            CLOSE VAL_MON;

            VALOR_TM := ROUND(P_COPORF.MRF_VALOR_TITULO_TM *
                              NVL(FACT_MON, 0) / NVL(FACT_MON1, 0),
                              2) * NVL(FACT_MON1, 0);
            VALOR_TM := VALOR_TM;

          ELSE
            IF P_COPORF.TFO_BMO_MNEMONICO = 'DOLAR' THEN
              OPEN VAL_MON(P_COPORF.FON_BMO_MNEMONICO,
                           TRUNC(P_FECHA_INI + 1));
            ELSE
              OPEN VAL_MON(P_COPORF.FON_BMO_MNEMONICO, TRUNC(P_FECHA_INI));
            END IF;
            FETCH VAL_MON
              INTO FACT_MON;
            IF VAL_MON%NOTFOUND THEN
              DBMS_OUTPUT.PUT_LINE('10009,No se encontro cotizacion para la base ' ||
                                   P_COPORF.TFO_BMO_MNEMONICO ||
                                   ' en la fecha ' ||
                                   TO_CHAR(V_FECHA, 'DD-MON-YYYY'));
            END IF;
            CLOSE VAL_MON;
            VALOR_TM := ROUND(P_COPORF.MRF_VALOR_TITULO_TM *
                              NVL(FACT_MON, 0),
                              2);
            VALOR_TM := VALOR_TM;

          END IF;
        END IF;
      ELSE
        IF P_COPORF.TFO_BMO_MNEMONICO = 'PESOS' THEN
          VALOR_TM := P_COPORF.MRF_VALOR_TITULO_TM;

        ELSE
          IF P_COPORF.TFO_BMO_MNEMONICO = 'DOLAR' THEN
            OPEN VAL_MON(P_COPORF.TFO_BMO_MNEMONICO,
                         TRUNC(P_FECHA_INI + 1));
          ELSE
            OPEN VAL_MON(P_COPORF.TFO_BMO_MNEMONICO, TRUNC(P_FECHA_INI));
          END IF;
          FETCH VAL_MON
            INTO FACT_MON;
          IF VAL_MON%NOTFOUND THEN
            DBMS_OUTPUT.PUT_LINE('10008,No se encontro cotizacion para la base ' ||
                                 P_COPORF.TFO_BMO_MNEMONICO ||
                                 ' en la fecha ' ||
                                 TO_CHAR(V_FECHA, 'DD-MON-YYYY'));
          END IF;
          CLOSE VAL_MON;
          VALOR_TM := ROUND(P_COPORF.MRF_VALOR_TITULO_TM * NVL(FACT_MON, 0),
                            2);
          VALOR_TM := VALOR_TM;

        END IF;
      END IF;

      LINEA := ' ' || ';' || P_FECHA_FIN || ';' || P_COPORF.FON_CODIGO || ';' ||
               P_COPORF.FON_RAZON_SOCIAL || ';' ||
               'PORTAFOLIO DE TITULOS DE RENTA FIJA - COPORF' || ';' ||
               P_COPORF.GNA_DESCRIPCION || ';' || P_COPORF.EMI_DESCRIPCION || ';' ||
               P_COPORF.TFO_CODIGO || ';' || P_COPORF.TFO_ENA_MNEMONICO || ';' ||
               VALOR_TM || ';' || DESCRIPCION || ';' || CONSEC;
      UTL_FILE.PUT_LINE(TIP_ARCHIVO, LINEA);
    END LOOP;
    UTL_FILE.FCLOSE(TIP_ARCHIVO);
  END PR_REPORTE_RENTA_FIJA;

  PROCEDURE P_EJECUTA_VAPAEMI IS
    P_CODIGO       VARCHAR2(200);
    P_RESPUESTA    VARCHAR2(200);
    V_RUTA         VARCHAR2(100);
    NOMBRE_ARCHIVO VARCHAR2(100);

    CURSOR C_RABEMI_RF(P_FECA_DESDE DATE, P_FECHA_HASTA DATE) IS

      SELECT ENA_MNEMONICO,
             ISIN,
             EMI_DESCRIPCION,
             NUMERO_CUENTA,
             NUMERO_CUENTA2,
             SUM(MCC_MONTO_ADMON_VALORES) MONTO,
             MCC_FECHA,
             CTA_APT,
             CCC_CUENTA_APT
        FROM (SELECT EMI.EMI_NUMERO_IDENTIFICACION EMI_NUMERO_IDENTIFICACION,
                     EMI.EMI_DESCRIPCION EMI_DESCRIPCION,
                     ENA.ENA_MNEMONICO ENA_MNEMONICO,
                     ENA.ENA_DESCRIPCION ENA_DESCRIPCION,
                     MCC.MCC_TMC_MNEMONICO MCC_TMC_MNEMONICO,
                     TRUNC(MCC.MCC_FECHA) MCC_FECHA,
                     TO_CHAR(MCC.MCC_CCC_CLI_PER_NUM_IDEN) NUMERO_CUENTA,
                     TO_CHAR(CCC.CCC_FON_CODIGO) NUMERO_CUENTA2,
                     CCC.CCC_NOMBRE_CUENTA CCC_NOMBRE_CUENTA,
                     MCC.MCC_MONTO MCC_MONTO,
                     MCC.MCC_MONTO_ADMON_VALORES MCC_MONTO_ADMON_VALORES,
                     MCC.MCC_CONSECUTIVO MCC_CONSECUTIVO,
                     MCC.MCC_CFC_FUG_ISI_MNEMONICO ISIN,
                     SUBSTR(TLO.TLO_REFERENCIA_DEPOSITO,
                            0,
                            INSTR(TLO.TLO_REFERENCIA_DEPOSITO, '-') - 1) REFERENCIA_DEPOSITO,
                     CCC.CCC_NUMERO_CUENTA CTA_APT,
                     CCC.CCC_CUENTA_APT
                FROM ESPECIES_NACIONALES           ENA,
                     EMISORES                      EMI,
                     CUENTAS_CLIENTE_CORREDORES    CCC,
                     TITULOS                       TLO,
                     MOVIMIENTOS_CUENTA_CORREDORES MCC
               WHERE TLO.TLO_ENA_MNEMONICO = ENA.ENA_MNEMONICO(+)
                 AND MCC.MCC_EMI_MNEMONICO = EMI.EMI_MNEMONICO(+)
                 AND MCC.MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                 AND MCC.MCC_CCC_CLI_PER_TID_CODIGO =
                     CCC.CCC_CLI_PER_TID_CODIGO
                 AND MCC.MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA
                 AND MCC.MCC_TLO_CODIGO = TLO.TLO_CODIGO
                 AND MCC.MCC_FECHA >= TRUNC(P_FECA_DESDE)
                 AND MCC.MCC_FECHA < TRUNC(P_FECHA_HASTA)
                 AND MCC.MCC_TMC_MNEMONICO IN ('ABI')
              UNION
              SELECT DISTINCT EMI.EMI_NUMERO_IDENTIFICACION EMI_NUMERO_IDENTIFICACION,
                              EMI.EMI_DESCRIPCION EMI_DESCRIPCION,
                              ENA.ENA_MNEMONICO ENA_MNEMONICO,
                              ENA.ENA_DESCRIPCION ENA_DESCRIPCION,
                              MCC.MCC_TMC_MNEMONICO MCC_TMC_MNEMONICO,
                              TRUNC(MCC.MCC_FECHA) MCC_FECHA,
                              TO_CHAR(MCC.MCC_CCC_CLI_PER_NUM_IDEN) NUMERO_CUENTA,
                              TO_CHAR(CCC.CCC_FON_CODIGO) NUMERO_CUENTA2,
                              CCC.CCC_NOMBRE_CUENTA CCC_NOMBRE_CUENTA,
                              MCC.MCC_MONTO MCC_MONTO,
                              MCC.MCC_MONTO_ADMON_VALORES MCC_MONTO_ADMON_VALORES,
                              MCC.MCC_CONSECUTIVO MCC_CONSECUTIVO,
                              MCC.MCC_CFC_FUG_ISI_MNEMONICO ISIN,
                              NULL REFERENCIA_DEPOSITO,
                              CCC.CCC_NUMERO_CUENTA CTA_APT,
                              CCC.CCC_CUENTA_APT
                FROM ESPECIES_NACIONALES           ENA,
                     EMISORES                      EMI,
                     CUENTAS_CLIENTE_CORREDORES    CCC,
                     CUENTAS_FUNGIBLE_CLIENTE      CFC,
                     MOVIMIENTOS_CUENTA_CORREDORES MCC
               WHERE MCC.MCC_ENA_MNEMONICO = ENA.ENA_MNEMONICO(+)
                 AND MCC.MCC_EMI_MNEMONICO = EMI.EMI_MNEMONICO(+)
                 AND MCC.MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                 AND MCC.MCC_CCC_CLI_PER_TID_CODIGO =
                     CCC.CCC_CLI_PER_TID_CODIGO
                 AND MCC.MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA
                 AND MCC.MCC_CFC_FUG_ISI_MNEMONICO =
                     CFC.CFC_FUG_ISI_MNEMONICO
                 AND MCC.MCC_CFC_FUG_MNEMONICO = CFC.CFC_FUG_MNEMONICO
                 AND MCC.MCC_CFC_CUENTA_DECEVAL = CFC.CFC_CUENTA_DECEVAL
                 AND MCC.MCC_FECHA >= TRUNC(P_FECA_DESDE)
                 AND MCC.MCC_FECHA < TRUNC(P_FECHA_HASTA)
                 AND MCC.MCC_TMC_MNEMONICO IN ('ABI')
               ORDER BY NUMERO_CUENTA,
                        MCC_CONSECUTIVO,
                        MCC_MONTO_ADMON_VALORES) --ORDER BY MCC_FECHA ASC;
       WHERE NUMERO_CUENTA NOT IN ('860079174', '8600791743')
      --AND ENA_MNEMONICO = 'TFIT16240724'
       GROUP BY ENA_MNEMONICO,
                ISIN,
                EMI_DESCRIPCION,
                NUMERO_CUENTA,
                NUMERO_CUENTA2,
                MCC_FECHA,
                CTA_APT,
                CCC_CUENTA_APT;

    R_RABEMI_RF C_RABEMI_RF%ROWTYPE;

    CURSOR C_VALIDA_APT_RABEMI(P_FECHA_DESDE DATE,
                               P_FECHA_HASTA DATE,
                               P_FONDO       VARCHAR2,
                               P_ESPECIE     VARCHAR2,
                               P_CTA         VARCHAR2) IS
      SELECT CTA_APT, CCC_CUENTA_APT
        FROM (SELECT

               ENA.ENA_MNEMONICO ENA_MNEMONICO,
               ENA.ENA_DESCRIPCION ENA_DESCRIPCION,
               TRUNC(MCC.MCC_FECHA) MCC_FECHA,
               TO_CHAR(MCC.MCC_CCC_CLI_PER_NUM_IDEN) NUMERO_CUENTA,
               TO_CHAR(CCC.CCC_FON_CODIGO) NUMERO_CUENTA2,
               CCC.CCC_NUMERO_CUENTA CTA_APT,
               CCC.CCC_CUENTA_APT
                FROM ESPECIES_NACIONALES           ENA,
                     EMISORES                      EMI,
                     CUENTAS_CLIENTE_CORREDORES    CCC,
                     TITULOS                       TLO,
                     MOVIMIENTOS_CUENTA_CORREDORES MCC
               WHERE TLO.TLO_ENA_MNEMONICO = ENA.ENA_MNEMONICO(+)
                 AND MCC.MCC_EMI_MNEMONICO = EMI.EMI_MNEMONICO(+)
                 AND MCC.MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                 AND MCC.MCC_CCC_CLI_PER_TID_CODIGO =
                     CCC.CCC_CLI_PER_TID_CODIGO
                 AND MCC.MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA
                 AND MCC.MCC_TLO_CODIGO = TLO.TLO_CODIGO
                 AND MCC.MCC_FECHA >= TRUNC(P_FECHA_DESDE)
                 AND MCC.MCC_FECHA < TRUNC(P_FECHA_HASTA)
                 AND MCC.MCC_TMC_MNEMONICO IN ('ABI')
                 AND CCC.CCC_CUENTA_APT = 'S'
              UNION
              SELECT DISTINCT ENA.ENA_MNEMONICO ENA_MNEMONICO,
                              ENA.ENA_DESCRIPCION ENA_DESCRIPCION,
                              TRUNC(MCC.MCC_FECHA) MCC_FECHA,
                              TO_CHAR(MCC.MCC_CCC_CLI_PER_NUM_IDEN) NUMERO_CUENTA,
                              TO_CHAR(CCC.CCC_FON_CODIGO) NUMERO_CUENTA2,
                              CCC.CCC_NUMERO_CUENTA CTA_APT,
                              CCC.CCC_CUENTA_APT
                FROM ESPECIES_NACIONALES           ENA,
                     EMISORES                      EMI,
                     CUENTAS_CLIENTE_CORREDORES    CCC,
                     CUENTAS_FUNGIBLE_CLIENTE      CFC,
                     MOVIMIENTOS_CUENTA_CORREDORES MCC
               WHERE MCC.MCC_ENA_MNEMONICO = ENA.ENA_MNEMONICO(+)
                 AND MCC.MCC_EMI_MNEMONICO = EMI.EMI_MNEMONICO(+)
                 AND MCC.MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                 AND MCC.MCC_CCC_CLI_PER_TID_CODIGO =
                     CCC.CCC_CLI_PER_TID_CODIGO
                 AND MCC.MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA
                 AND MCC.MCC_CFC_FUG_ISI_MNEMONICO =
                     CFC.CFC_FUG_ISI_MNEMONICO
                 AND MCC.MCC_CFC_FUG_MNEMONICO = CFC.CFC_FUG_MNEMONICO
                 AND MCC.MCC_CFC_CUENTA_DECEVAL = CFC.CFC_CUENTA_DECEVAL
                 AND MCC.MCC_FECHA >= TRUNC(P_FECHA_DESDE)
                 AND MCC.MCC_FECHA < TRUNC(P_FECHA_HASTA)
                 AND MCC.MCC_TMC_MNEMONICO IN ('ABI')
                 AND CCC.CCC_CUENTA_APT = 'S') --ORDER BY MCC_FECHA ASC;
       WHERE NUMERO_CUENTA = P_FONDO
         AND ENA_MNEMONICO = P_ESPECIE
         AND CTA_APT = P_CTA
       GROUP BY CTA_APT, CCC_CUENTA_APT;
    R_VALIDA_APT_RABEMI C_VALIDA_APT_RABEMI%ROWTYPE;

    CURSOR C_RABEMI_RF_PP(P_FECA_DESDE DATE, P_FECHA_HASTA DATE) IS

      SELECT ENA_MNEMONICO,
             ISIN,
             EMI_DESCRIPCION,
             NUMERO_CUENTA,
             NUMERO_CUENTA2,
             SUM(MCC_MONTO_ADMON_VALORES) MONTO,
             MCC_FECHA
        FROM (SELECT EMI.EMI_NUMERO_IDENTIFICACION EMI_NUMERO_IDENTIFICACION,
                     EMI.EMI_DESCRIPCION EMI_DESCRIPCION,
                     ENA.ENA_MNEMONICO ENA_MNEMONICO,
                     ENA.ENA_DESCRIPCION ENA_DESCRIPCION,
                     MCC.MCC_TMC_MNEMONICO MCC_TMC_MNEMONICO,
                     TRUNC(MCC.MCC_FECHA) MCC_FECHA,
                     TO_CHAR(MCC.MCC_CCC_CLI_PER_NUM_IDEN) NUMERO_CUENTA,
                     TO_CHAR(CCC.CCC_FON_CODIGO) NUMERO_CUENTA2,
                     CCC.CCC_NOMBRE_CUENTA CCC_NOMBRE_CUENTA,
                     MCC.MCC_MONTO MCC_MONTO,
                     MCC.MCC_MONTO_ADMON_VALORES MCC_MONTO_ADMON_VALORES,
                     MCC.MCC_CONSECUTIVO MCC_CONSECUTIVO,
                     MCC.MCC_CFC_FUG_ISI_MNEMONICO ISIN,
                     SUBSTR(TLO.TLO_REFERENCIA_DEPOSITO,
                            0,
                            INSTR(TLO.TLO_REFERENCIA_DEPOSITO, '-') - 1) REFERENCIA_DEPOSITO
                FROM ESPECIES_NACIONALES           ENA,
                     EMISORES                      EMI,
                     CUENTAS_CLIENTE_CORREDORES    CCC,
                     TITULOS                       TLO,
                     MOVIMIENTOS_CUENTA_CORREDORES MCC
               WHERE TLO.TLO_ENA_MNEMONICO = ENA.ENA_MNEMONICO(+)
                 AND MCC.MCC_EMI_MNEMONICO = EMI.EMI_MNEMONICO(+)
                 AND MCC.MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                 AND MCC.MCC_CCC_CLI_PER_TID_CODIGO =
                     CCC.CCC_CLI_PER_TID_CODIGO
                 AND MCC.MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA
                 AND MCC.MCC_TLO_CODIGO = TLO.TLO_CODIGO
                 AND MCC.MCC_FECHA >= TRUNC(P_FECA_DESDE)
                 AND MCC.MCC_FECHA < TRUNC(P_FECHA_HASTA)
                 AND MCC.MCC_TMC_MNEMONICO IN ('ABI')
              UNION
              SELECT DISTINCT EMI.EMI_NUMERO_IDENTIFICACION EMI_NUMERO_IDENTIFICACION,
                              EMI.EMI_DESCRIPCION EMI_DESCRIPCION,
                              ENA.ENA_MNEMONICO ENA_MNEMONICO,
                              ENA.ENA_DESCRIPCION ENA_DESCRIPCION,
                              MCC.MCC_TMC_MNEMONICO MCC_TMC_MNEMONICO,
                              TRUNC(MCC.MCC_FECHA) MCC_FECHA,
                              TO_CHAR(MCC.MCC_CCC_CLI_PER_NUM_IDEN) NUMERO_CUENTA,
                              TO_CHAR(CCC.CCC_FON_CODIGO) NUMERO_CUENTA2,
                              CCC.CCC_NOMBRE_CUENTA CCC_NOMBRE_CUENTA,
                              MCC.MCC_MONTO MCC_MONTO,
                              MCC.MCC_MONTO_ADMON_VALORES MCC_MONTO_ADMON_VALORES,
                              MCC.MCC_CONSECUTIVO MCC_CONSECUTIVO,
                              MCC.MCC_CFC_FUG_ISI_MNEMONICO ISIN,
                              NULL REFERENCIA_DEPOSITO
                FROM ESPECIES_NACIONALES           ENA,
                     EMISORES                      EMI,
                     CUENTAS_CLIENTE_CORREDORES    CCC,
                     CUENTAS_FUNGIBLE_CLIENTE      CFC,
                     MOVIMIENTOS_CUENTA_CORREDORES MCC
               WHERE MCC.MCC_ENA_MNEMONICO = ENA.ENA_MNEMONICO(+)
                 AND MCC.MCC_EMI_MNEMONICO = EMI.EMI_MNEMONICO(+)
                 AND MCC.MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                 AND MCC.MCC_CCC_CLI_PER_TID_CODIGO =
                     CCC.CCC_CLI_PER_TID_CODIGO
                 AND MCC.MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA
                 AND MCC.MCC_CFC_FUG_ISI_MNEMONICO =
                     CFC.CFC_FUG_ISI_MNEMONICO
                 AND MCC.MCC_CFC_FUG_MNEMONICO = CFC.CFC_FUG_MNEMONICO
                 AND MCC.MCC_CFC_CUENTA_DECEVAL = CFC.CFC_CUENTA_DECEVAL
                 AND MCC.MCC_FECHA >= TRUNC(P_FECA_DESDE)
                 AND MCC.MCC_FECHA < TRUNC(P_FECHA_HASTA)
                 AND MCC.MCC_TMC_MNEMONICO IN ('ABI')
               ORDER BY NUMERO_CUENTA,
                        MCC_CONSECUTIVO,
                        MCC_MONTO_ADMON_VALORES) --ORDER BY MCC_FECHA ASC;
       WHERE NUMERO_CUENTA IN ('860079174', '8600791743')
      --AND ENA_MNEMONICO = 'TFIT16240724'
       GROUP BY ENA_MNEMONICO,
                ISIN,
                EMI_DESCRIPCION,
                NUMERO_CUENTA,
                NUMERO_CUENTA2,
                MCC_FECHA;

    R_RABEMI_RF_PP C_RABEMI_RF_PP%ROWTYPE;

    CURSOR C_TITULO(P_FONDO       VARCHAR2,
                    P_ESPECIE     VARCHAR2,
                    P_ISIN        VARCHAR2,
                    P_FECHA_DESDE DATE,
                    P_FECHA_HASTA DATE) IS
      SELECT T.TFO_BMO_MNEMONICO,
             T.TFO_CODIGO,
             T.TFO_ETI_CODIGO,
             T.TFO_VALOR_NOMINAL,
             DECODE(T.TFO_LTI_MNEMONICO,
                    'DA',
                    'DECEVAL',
                    'DV',
                    'DCV',
                    T.TFO_LTI_MNEMONICO) CUSTODIO
        FROM TITULOS_FONDOS T
       WHERE T.TFO_FON_CODIGO = P_FONDO
         AND T.TFO_TYPE = 'TRF'
         AND T.TFO_ENA_MNEMONICO = P_ESPECIE
         AND TFO_FUG_ISI_MNEMONICO = P_ISIN
         AND T.TFO_CODIGO IN
             (SELECT FRT6.FRT_TFO_CODIGO
                FROM FONDOS                      FON2,
                     TITULOS_FONDOS              TFO3,
                     FLUJOS_RENDIMIENTOS_TITULOS FRT6
               WHERE TFO3.TFO_FON_CODIGO = FON2.FON_CODIGO
                 AND TFO3.TFO_FON_CODIGO = FRT6.FRT_TFO_FON_CODIGO
                 AND TFO3.TFO_CODIGO = FRT6.FRT_TFO_CODIGO
                 AND FRT6.FRT_FECHA >= TRUNC(P_FECHA_DESDE)
                 AND FRT6.FRT_FECHA < TRUNC(P_FECHA_HASTA)
                 AND FRT6.FRT_ESTADO IN ('V', 'C')
                 AND TFO3.TFO_ENA_MNEMONICO = T.TFO_ENA_MNEMONICO
                 AND TFO3.TFO_FON_CODIGO = T.TFO_FON_CODIGO);
    R_TITULO C_TITULO%ROWTYPE;

    CURSOR C_SUM_TITULOS(P_FONDO       VARCHAR2,
                         P_ESPECIE     VARCHAR2,
                         P_ISIN        VARCHAR2,
                         P_FECHA_DESDE DATE,
                         P_FECHA_HASTA DATE) IS

      SELECT SUM(T.TFO_VALOR_NOMINAL) TOTAL_TIT
        FROM TITULOS_FONDOS T
       WHERE T.TFO_FON_CODIGO = P_FONDO
         AND T.TFO_TYPE = 'TRF'
         AND T.TFO_ENA_MNEMONICO = P_ESPECIE
         AND TFO_FUG_ISI_MNEMONICO = P_ISIN
         AND T.TFO_CODIGO IN
             (SELECT FRT6.FRT_TFO_CODIGO
                FROM FONDOS                      FON2,
                     TITULOS_FONDOS              TFO3,
                     FLUJOS_RENDIMIENTOS_TITULOS FRT6
               WHERE TFO3.TFO_FON_CODIGO = FON2.FON_CODIGO
                 AND TFO3.TFO_FON_CODIGO = FRT6.FRT_TFO_FON_CODIGO
                 AND TFO3.TFO_CODIGO = FRT6.FRT_TFO_CODIGO
                 AND FRT6.FRT_FECHA >= TRUNC(P_FECHA_DESDE)
                 AND FRT6.FRT_FECHA < TRUNC(P_FECHA_HASTA)
                 AND FRT6.FRT_ESTADO IN ('V', 'C')
                 AND TFO3.TFO_ENA_MNEMONICO = T.TFO_ENA_MNEMONICO
                 AND TFO3.TFO_FON_CODIGO = T.TFO_FON_CODIGO);

    R_SUM_TITULOS C_SUM_TITULOS%ROWTYPE;

    CURSOR C_TITULO_DCV(P_FONDO       VARCHAR2,
                        P_ESPECIE     VARCHAR2,
                        P_FECHA_DESDE DATE,
                        P_FECHA_HASTA DATE) IS
      SELECT T.TFO_BMO_MNEMONICO,
             T.TFO_CODIGO,
             T.TFO_ETI_CODIGO,
             T.TFO_VALOR_NOMINAL,
             DECODE(T.TFO_LTI_MNEMONICO,
                    'DA',
                    'DECEVAL',
                    'DV',
                    'DCV',
                    T.TFO_LTI_MNEMONICO) CUSTODIO,
             TFO_NUMERO_EMISION_DCV NUM_EMISION
        FROM TITULOS_FONDOS T
       WHERE T.TFO_FON_CODIGO = P_FONDO
         AND T.TFO_TYPE = 'TRF'
         AND T.TFO_ENA_MNEMONICO = P_ESPECIE
            --AND T.TFO_NUMERO_EMISION_DCV = P_NUM_EMI
         AND T.TFO_CODIGO IN
             (SELECT FRT6.FRT_TFO_CODIGO
                FROM FONDOS                      FON2,
                     TITULOS_FONDOS              TFO3,
                     FLUJOS_RENDIMIENTOS_TITULOS FRT6
               WHERE TFO3.TFO_FON_CODIGO = FON2.FON_CODIGO
                 AND TFO3.TFO_FON_CODIGO = FRT6.FRT_TFO_FON_CODIGO
                 AND TFO3.TFO_CODIGO = FRT6.FRT_TFO_CODIGO
                 AND FRT6.FRT_FECHA >= TRUNC(P_FECHA_DESDE)
                 AND FRT6.FRT_FECHA < TRUNC(P_FECHA_HASTA)
                 AND FRT6.FRT_ESTADO IN ('V', 'C')
                 AND TFO3.TFO_ENA_MNEMONICO = T.TFO_ENA_MNEMONICO
                 AND TFO3.TFO_FON_CODIGO = T.TFO_FON_CODIGO);
    R_TITULO_DCV C_TITULO_DCV%ROWTYPE;

    CURSOR C_SUM_TITULOS_DCV(P_FONDO       VARCHAR2,
                             P_ESPECIE     VARCHAR2, /*P_NUM_EMI VARCHAR2,*/
                             P_FECHA_DESDE DATE,
                             P_FECHA_HASTA DATE) IS

      SELECT SUM(T.TFO_VALOR_NOMINAL) TOTAL_TIT
        FROM TITULOS_FONDOS T
       WHERE T.TFO_FON_CODIGO = P_FONDO
         AND T.TFO_TYPE = 'TRF'
         AND T.TFO_ENA_MNEMONICO = P_ESPECIE
            --AND T.TFO_NUMERO_EMISION_DCV = P_NUM_EMI
         AND T.TFO_CODIGO IN
             (SELECT FRT6.FRT_TFO_CODIGO
                FROM FONDOS                      FON2,
                     TITULOS_FONDOS              TFO3,
                     FLUJOS_RENDIMIENTOS_TITULOS FRT6
               WHERE TFO3.TFO_FON_CODIGO = FON2.FON_CODIGO
                 AND TFO3.TFO_FON_CODIGO = FRT6.FRT_TFO_FON_CODIGO
                 AND TFO3.TFO_CODIGO = FRT6.FRT_TFO_CODIGO
                 AND FRT6.FRT_FECHA >= TRUNC(P_FECHA_DESDE)
                 AND FRT6.FRT_FECHA < TRUNC(P_FECHA_HASTA)
                 AND FRT6.FRT_ESTADO IN ('V', 'C')
                 AND TFO3.TFO_ENA_MNEMONICO = T.TFO_ENA_MNEMONICO
                 AND TFO3.TFO_FON_CODIGO = T.TFO_FON_CODIGO);

    R_SUM_TITULOS_DCV C_SUM_TITULOS_DCV%ROWTYPE;

    CURSOR C_TIT_PP(P_ESPECIE     VARCHAR2,
                    P_ISIN        VARCHAR2,
                    P_FECHA_DESDE DATE,
                    P_FECHA_HASTA DATE) IS
      SELECT T.TFO_BMO_MNEMONICO,
             T.TFO_CODIGO,
             T.TFO_ETI_CODIGO,
             T.TFO_VALOR_NOMINAL,
             DECODE(T.TFO_LTI_MNEMONICO,
                    'DA',
                    'DECEVAL',
                    'DV',
                    'DCV',
                    T.TFO_LTI_MNEMONICO) CUSTODIO
        FROM TITULOS_FONDOS T
       WHERE T.TFO_FON_CODIGO IN ('860079174', '8600791743')
         AND T.TFO_TYPE = 'TRF'
         AND T.TFO_ENA_MNEMONICO = P_ESPECIE
         AND TFO_FUG_ISI_MNEMONICO = P_ISIN
         AND T.TFO_CODIGO IN
             (SELECT FRT6.FRT_TFO_CODIGO
                FROM FONDOS                      FON2,
                     TITULOS_FONDOS              TFO3,
                     FLUJOS_RENDIMIENTOS_TITULOS FRT6
               WHERE TFO3.TFO_FON_CODIGO = FON2.FON_CODIGO
                 AND TFO3.TFO_FON_CODIGO = FRT6.FRT_TFO_FON_CODIGO
                 AND TFO3.TFO_CODIGO = FRT6.FRT_TFO_CODIGO
                 AND FRT6.FRT_FECHA >= TRUNC(P_FECHA_DESDE)
                 AND FRT6.FRT_FECHA < TRUNC(P_FECHA_HASTA)
                 AND FRT6.FRT_ESTADO IN ('V', 'C')
                 AND TFO3.TFO_ENA_MNEMONICO = T.TFO_ENA_MNEMONICO
                 AND TFO3.TFO_FON_CODIGO = T.TFO_FON_CODIGO);
    R_TIT_PP C_TIT_PP%ROWTYPE;

    CURSOR C_SUM_TIT_PP(P_ESPECIE     VARCHAR2,
                        P_ISIN        VARCHAR2,
                        P_FECHA_DESDE DATE,
                        P_FECHA_HASTA DATE) IS

      SELECT SUM(T.TFO_VALOR_NOMINAL) TOTAL_TIT
        FROM TITULOS_FONDOS T
       WHERE T.TFO_FON_CODIGO IN ('860079174', '8600791743')
         AND T.TFO_TYPE = 'TRF'
         AND T.TFO_ENA_MNEMONICO = P_ESPECIE
         AND TFO_FUG_ISI_MNEMONICO = P_ISIN
         AND T.TFO_CODIGO IN
             (SELECT FRT6.FRT_TFO_CODIGO
                FROM FONDOS                      FON2,
                     TITULOS_FONDOS              TFO3,
                     FLUJOS_RENDIMIENTOS_TITULOS FRT6
               WHERE TFO3.TFO_FON_CODIGO = FON2.FON_CODIGO
                 AND TFO3.TFO_FON_CODIGO = FRT6.FRT_TFO_FON_CODIGO
                 AND TFO3.TFO_CODIGO = FRT6.FRT_TFO_CODIGO
                 AND FRT6.FRT_FECHA >= TRUNC(P_FECHA_DESDE)
                 AND FRT6.FRT_FECHA < TRUNC(P_FECHA_HASTA)
                 AND FRT6.FRT_ESTADO IN ('V', 'C')
                 AND TFO3.TFO_ENA_MNEMONICO = T.TFO_ENA_MNEMONICO
                 AND TFO3.TFO_FON_CODIGO = T.TFO_FON_CODIGO);

    R_SUM_TIT_PP C_SUM_TIT_PP%ROWTYPE;

    CURSOR C_TIT_PP_DCV(P_ESPECIE     VARCHAR2, /* P_NUM_EMI VARCHAR2,*/
                        P_FECHA_DESDE DATE,
                        P_FECHA_HASTA DATE) IS
      SELECT T.TFO_BMO_MNEMONICO,
             T.TFO_CODIGO,
             T.TFO_ETI_CODIGO,
             T.TFO_VALOR_NOMINAL,
             DECODE(T.TFO_LTI_MNEMONICO,
                    'DA',
                    'DECEVAL',
                    'DV',
                    'DCV',
                    T.TFO_LTI_MNEMONICO) CUSTODIO,
             TFO_NUMERO_EMISION_DCV NUM_EMISION
        FROM TITULOS_FONDOS T
       WHERE T.TFO_FON_CODIGO IN ('860079174', '8600791743')
         AND T.TFO_TYPE = 'TRF'
         AND T.TFO_ENA_MNEMONICO = P_ESPECIE
         AND T.TFO_ETI_CODIGO = 'VIG'
            --AND T.TFO_NUMERO_EMISION_DCV = P_NUM_EMI
         AND T.TFO_CODIGO IN
             (SELECT FRT6.FRT_TFO_CODIGO
                FROM FONDOS                      FON2,
                     TITULOS_FONDOS              TFO3,
                     FLUJOS_RENDIMIENTOS_TITULOS FRT6
               WHERE TFO3.TFO_FON_CODIGO = FON2.FON_CODIGO
                 AND TFO3.TFO_FON_CODIGO = FRT6.FRT_TFO_FON_CODIGO
                 AND TFO3.TFO_CODIGO = FRT6.FRT_TFO_CODIGO
                 AND FRT6.FRT_FECHA >= TRUNC(P_FECHA_DESDE)
                 AND FRT6.FRT_FECHA < TRUNC(P_FECHA_HASTA)
                 AND FRT6.FRT_ESTADO IN ('V', 'C')
                 AND TFO3.TFO_ENA_MNEMONICO = T.TFO_ENA_MNEMONICO
                 AND TFO3.TFO_FON_CODIGO = T.TFO_FON_CODIGO);
    R_TIT_PP_DCV C_TIT_PP_DCV%ROWTYPE;

    CURSOR C_SUM_TIT_PP_DCV(P_ESPECIE     VARCHAR2, /*P_NUM_EMI VARCHAR2,*/
                            P_FECHA_DESDE DATE,
                            P_FECHA_HASTA DATE) IS

      SELECT SUM(T.TFO_VALOR_NOMINAL) TOTAL_TIT
        FROM TITULOS_FONDOS T
       WHERE T.TFO_FON_CODIGO IN ('860079174', '8600791743')
         AND T.TFO_TYPE = 'TRF'
         AND T.TFO_ENA_MNEMONICO = P_ESPECIE
         AND T.TFO_ETI_CODIGO = 'VIG'
            --AND T.TFO_NUMERO_EMISION_DCV = P_NUM_EMI
         AND T.TFO_CODIGO IN
             (SELECT FRT6.FRT_TFO_CODIGO
                FROM FONDOS                      FON2,
                     TITULOS_FONDOS              TFO3,
                     FLUJOS_RENDIMIENTOS_TITULOS FRT6
               WHERE TFO3.TFO_FON_CODIGO = FON2.FON_CODIGO
                 AND TFO3.TFO_FON_CODIGO = FRT6.FRT_TFO_FON_CODIGO
                 AND TFO3.TFO_CODIGO = FRT6.FRT_TFO_CODIGO
                 AND FRT6.FRT_FECHA >= TRUNC(P_FECHA_DESDE)
                 AND FRT6.FRT_FECHA < TRUNC(P_FECHA_HASTA)
                 AND FRT6.FRT_ESTADO IN ('V', 'C')
                 AND TFO3.TFO_ENA_MNEMONICO = T.TFO_ENA_MNEMONICO
                 AND TFO3.TFO_FON_CODIGO = T.TFO_FON_CODIGO);

    R_SUM_TIT_PP_DCV C_SUM_TIT_PP_DCV%ROWTYPE;

    CURSOR C_CBM(FECHA DATE, BASE VARCHAR2) IS
      SELECT DECODE(CBM_BMO_MNEMONICO, 'PESOS', 1, CBM_VALOR) CBM_VALOR
        FROM COTIZACIONES_BASE_MONETARIAS
       WHERE CBM_FECHA >= TRUNC(FECHA - 1) -- ayer
         AND CBM_FECHA < TRUNC(FECHA)
         AND CBM_BMO_MNEMONICO = BASE;
    CBM NUMBER;

    CURSOR C_REND2(P_FONDO       VARCHAR2,
                   P_TITULO      VARCHAR2,
                   P_FECHA_DESDE DATE,
                   P_FECHA_HASTA DATE) IS
      SELECT ABS(FRT6.FRT_INTERES_MERCADO) * CBM REDIMIENTOS,
             TRUNC(FRT6.FRT_FECHA) FECHA
        FROM FONDOS                      FON2,
             TITULOS_FONDOS              TFO3,
             FLUJOS_RENDIMIENTOS_TITULOS FRT6
       WHERE TFO3.TFO_FON_CODIGO = FON2.FON_CODIGO
         AND TFO3.TFO_FON_CODIGO = FRT6.FRT_TFO_FON_CODIGO
         AND TFO3.TFO_CODIGO = FRT6.FRT_TFO_CODIGO
         AND FRT6.FRT_FECHA >= TRUNC(P_FECHA_DESDE)
         AND FRT6.FRT_FECHA < TRUNC(P_FECHA_HASTA)
         AND FRT6.FRT_ESTADO IN ('V', 'C')
         AND TFO3.TFO_CODIGO = P_TITULO
         AND TFO3.TFO_FON_CODIGO = P_FONDO;
    REND_RF2  NUMBER;
    V_FEC_RED DATE;

    CURSOR C_REND2_PP(P_FONDO       VARCHAR2,
                      P_TITULO      VARCHAR2,
                      P_FECHA_DESDE DATE,
                      P_FECHA_HASTA DATE) IS
      SELECT ABS(FRT6.FRT_INTERES_MERCADO) * CBM REDIMIENTOS,
             TRUNC(FRT6.FRT_FECHA) FECHA
        FROM FONDOS                      FON2,
             TITULOS_FONDOS              TFO3,
             FLUJOS_RENDIMIENTOS_TITULOS FRT6
       WHERE TFO3.TFO_FON_CODIGO = FON2.FON_CODIGO
         AND TFO3.TFO_FON_CODIGO = FRT6.FRT_TFO_FON_CODIGO
         AND TFO3.TFO_CODIGO = FRT6.FRT_TFO_CODIGO
         AND FRT6.FRT_FECHA >= TRUNC(P_FECHA_DESDE)
         AND FRT6.FRT_FECHA < TRUNC(P_FECHA_HASTA)
         AND FRT6.FRT_ESTADO IN ('V', 'C')
         AND TFO3.TFO_CODIGO = P_TITULO
         AND TFO3.TFO_FON_CODIGO IN ('860079174', '8600791743');

    -- FIN RV

    CURSOR PORTAFOLIO1(FON_CODIGO VARCHAR2) IS
      SELECT CPOR_CODIGO,
             CPOR_DESCRIPCION,
             CPOR_FON_CODIGO,
             DECODE(CPOR_TIPO_PORTAFOLIO,
                    'SOC',
                    'SOCIEDAD',
                    'FIC',
                    'FONDOS DE INV. COLECTIVA',
                    'APT',
                    'ADMIN. PORTAFOLIO DE TERCEROS',
                    'FCP',
                    'FONDOS DE CAPITAL PRIVADO') AS CPOR_TIPO_PORTAFOLIO -- sortiz transmisiones plano V
        FROM CLASIFICACIONES_PORTAFOLIOS
       WHERE CPOR_FON_CODIGO LIKE FON_CODIGO || '%';
    POR PORTAFOLIO1%ROWTYPE;

    CURSOR C_ISIN_FUNGIBLE(NEMOTECNICO VARCHAR2) IS
      SELECT DISTINCT FUG_ISI_MNEMONICO
        FROM ISINS_ESPECIES, FUNGIBLES
       WHERE FUG_ISI_MNEMONICO = ISE_ISI_MNEMONICO
         AND FUG_ESTADO = 'A'
         AND ISE_ENA_MNEMONICO = NEMOTECNICO;

    CURSOR C_ISE_ISIN(NEMOTECNICO VARCHAR2) IS
      SELECT ISE_ISI_MNEMONICO
        FROM ISINS_ESPECIES
       WHERE ISE_ENA_MNEMONICO = NEMOTECNICO;

    CURSOR C_ASSET_CLASS(ESPECIE VARCHAR2) IS
      SELECT TMP_ENA_CCLD_CODIGO CODIGO, TMP_ENA_TIPO_ESPECIE TIPO_ESPECIE
        FROM TMP_ASSET_ESPECIES_NACIONALES
       WHERE TMP_ENA_MNEMONICO = ESPECIE;
    V_ASSET_CLASS C_ASSET_CLASS%ROWTYPE;

    CURSOR C_CAUSACION(P_FECHA DATE, ENA_MNEMONICO VARCHAR2) IS
      SELECT RDI_MONTO
        FROM RELOJ_DIVIDENDOS
       WHERE RDI_FECHA_EX_DIVIDENDO >= TRUNC(P_FECHA)
         AND RDI_FECHA_EX_DIVIDENDO < TRUNC(P_FECHA + 1)
         AND RDI_ENA_MNEMONICO = ENA_MNEMONICO;

    CAUSACION NUMBER;

    CURSOR PORTAFOLIO(FON_CODIGO VARCHAR2, CUENTA_CORR NUMBER) IS
      SELECT CPOR_CODIGO,
             CPOR_DESCRIPCION,
             CPOR_FON_CODIGO,
             DECODE(CPOR_TIPO_PORTAFOLIO,
                    'SOC',
                    'SOCIEDAD',
                    'FIC',
                    'FONDOS DE INV. COLECTIVA',
                    'APT',
                    'ADMIN. PORTAFOLIO DE TERCEROS',
                    'FCP',
                    'FONDOS DE CAPITAL PRIVADO') AS CPOR_TIPO_PORTAFOLIO -- sortiz transmisiones plano V
        FROM CLASIFICACIONES_PORTAFOLIOS
       WHERE CPOR_FON_CODIGO = FON_CODIGO
         AND NVL(CPOR_CCC_NUMERO_CUENTA, -1) = NVL(CUENTA_CORR, -1);
    POR PORTAFOLIO%ROWTYPE;

    --*********************
    --  RENTA VARIABLE    *
    --*********************

    CURSOR C_RABEMI(P_FECA_DESDE DATE, P_FECHA_HASTA DATE) IS

      SELECT MCC.MCC_FECHA,
             MCC.MCC_MONTO_ADMON_VALORES,
             MCC.MCC_CFC_FUG_ISI_MNEMONICO,
             MCC.MCC_ENA_MNEMONICO,
             MCC.MCC_VALOR_NOMINAL_CANTIDAD,
             MCC.MCC_CCC_CLI_PER_NUM_IDEN   FONDO,
             CCC.CCC_NUMERO_CUENTA          CTA_APT
        FROM MOVIMIENTOS_CUENTA_CORREDORES MCC,
             CUENTAS_CLIENTE_CORREDORES    CCC
       WHERE MCC.MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
         AND MCC.MCC_CCC_CLI_PER_TID_CODIGO = CCC.CCC_CLI_PER_TID_CODIGO
         AND MCC.MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA
         AND MCC.MCC_TMC_MNEMONICO = 'ABD'
         AND MCC.MCC_FECHA >= TRUNC(P_FECA_DESDE)
         AND MCC.MCC_FECHA < TRUNC(P_FECHA_HASTA + 1);
    --AND CCC.CCC_CLI_PER_NUM_IDEN = '800232356';

    R_RABEMI C_RABEMI%ROWTYPE;

    CURSOR C_CLAS_POR(P_FONDO VARCHAR2) IS
      SELECT CPOR_TIPO_PORTAFOLIO
        FROM CLASIFICACIONES_PORTAFOLIOS
       WHERE CPOR_FON_CODIGO = P_FONDO;

    CURSOR C_CTA_RABEMI(P_FECHA   DATE,
                        P_FONDO   VARCHAR2,
                        P_ISIN    VARCHAR2,
                        P_ESPECIE VARCHAR2) IS
      SELECT CCC.CCC_NUMERO_CUENTA CTA_APT, CCC.CCC_FON_CODIGO FONDO
        FROM MOVIMIENTOS_CUENTA_CORREDORES MCC,
             CUENTAS_CLIENTE_CORREDORES    CCC
       WHERE MCC.MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
         AND MCC.MCC_CCC_CLI_PER_TID_CODIGO = CCC.CCC_CLI_PER_TID_CODIGO
         AND MCC.MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA
         AND MCC.MCC_TMC_MNEMONICO = 'ABD'
         AND CCC.CCC_CUENTA_APT = 'S'
         AND MCC.MCC_FECHA >= TRUNC(P_FECHA)
         AND MCC.MCC_FECHA < TRUNC(P_FECHA + 1)
         AND MCC.MCC_CCC_CLI_PER_NUM_IDEN = P_FONDO
         AND MCC.MCC_CFC_FUG_ISI_MNEMONICO = P_ISIN
         AND MCC.MCC_ENA_MNEMONICO = P_ESPECIE
         AND CCC.CCC_NUMERO_CUENTA = R_RABEMI.CTA_APT
       GROUP BY CCC.CCC_NUMERO_CUENTA, CCC.CCC_FON_CODIGO;
    R_CTA_RABEMI C_CTA_RABEMI%ROWTYPE;

    CURSOR C_PORTA_RV(P_FECHA DATE, P_MNEMONICO VARCHAR2, P_FONDO VARCHAR2) IS

      SELECT ENA_MNEMONICO ESPECIE,
             EMI_DESCRIPCION EMISOR_DESCRIPCION,
             ENA_MNEMONICO NEMOTECNICO,
             ABS(PFRV_VRV_NUMERO_UNIDADES) CANTIDAD_VALOR_NOMINAL,
             ABS(PFRV_VRV_NUMERO_UNIDADES) NOMINAL_PESOS,
             ENA_TIPO_PRODUCTO CLASIFICACION_2,
             DECODE(PFRV_POSICION_CTTO,
                    'A',
                    'GRA',
                    'P',
                    'GRP',
                    DECODE(PFRV_PUNTA, 'C', 'DC', 'V', 'OV', 'I')) CODIGOTIPOOPERACIONPORTAFOLIO,
             PFRV_FON_CODIGO
        FROM ESPECIES_NACIONALES,
             HIS_PORTAFOLIO_FONDOS_RV,
             EMISORES,
             FONDOS,
             AREAS_GEOGRAFICAS,
             CLASES_TITULOS
       WHERE ENA_MNEMONICO = PFRV_ENA_MNEMONICO
         AND ENA_EMI_MNEMONICO = EMI_MNEMONICO
         AND FON_CODIGO = PFRV_FON_CODIGO
         AND EMI_AGE_CODIGO = AGE_CODIGO
         AND CTI_MNEMONICO(+) = ENA_MNEMONICO_SUPERVALORES
         AND PFRV_FECHA >= TRUNC(P_FECHA)
         AND PFRV_FECHA < TRUNC(P_FECHA + 1)
         AND PFRV_FON_CODIGO NOT IN ('111111', '999999')
         AND PFRV_VRV_NUMERO_UNIDADES <> 0
         AND ENA_MNEMONICO = P_MNEMONICO
         AND PFRV_FON_CODIGO = P_FONDO
         AND DECODE(PFRV_POSICION_CTTO,
                    'A',
                    'GRA',
                    'P',
                    'GRP',
                    DECODE(PFRV_PUNTA, 'C', 'DC', 'V', 'OV', 'I')) = 'I';

    R_POR_RV C_PORTA_RV%ROWTYPE;

    CURSOR C_RABEMI_APT(P_FECHA   DATE,
                        P_FONDO   VARCHAR2,
                        P_SIN     VARCHAR2,
                        P_ESPECIE VARCHAR2,
                        P_CTA_APT VARCHAR2) IS

      SELECT MCC.MCC_FECHA,
             MCC.MCC_MONTO_ADMON_VALORES,
             MCC.MCC_CFC_FUG_ISI_MNEMONICO,
             MCC.MCC_ENA_MNEMONICO,
             MCC.MCC_VALOR_NOMINAL_CANTIDAD,
             MCC.MCC_CCC_CLI_PER_NUM_IDEN FONDO,
             CCC.CCC_NUMERO_CUENTA
        FROM MOVIMIENTOS_CUENTA_CORREDORES MCC,
             CUENTAS_CLIENTE_CORREDORES    CCC
       WHERE MCC.MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
         AND MCC.MCC_CCC_CLI_PER_TID_CODIGO = CCC.CCC_CLI_PER_TID_CODIGO
         AND MCC.MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA
         AND MCC.MCC_TMC_MNEMONICO = 'ABD'
         AND CCC.CCC_CUENTA_APT = 'S'
         AND MCC.MCC_FECHA >= TRUNC(P_FECHA)
         AND MCC.MCC_FECHA < TRUNC(P_FECHA + 1)
         AND CCC.CCC_NUMERO_CUENTA = P_CTA_APT
         AND MCC.MCC_CCC_CLI_PER_NUM_IDEN = P_FONDO
         AND MCC.MCC_CFC_FUG_ISI_MNEMONICO = P_SIN
         AND MCC.MCC_ENA_MNEMONICO = P_ESPECIE;

    R_RABEMI_APT C_RABEMI_APT%ROWTYPE;

    ISIN                VARCHAR2(50);
    V_T_PORT            VARCHAR2(50);
    V_PORTAFOLIO        VARCHAR2(500);
    V_RELOJ_DIV         NUMBER;
    V_VAL_COEASY        NUMBER;
    DEF_WHERE           VARCHAR2(4000);
    SUMA                NUMBER;
    V_NM_CAUSACION2     NUMBER;
    V_SUM_NOMINAL       NUMBER;
    P_TIPO_ACTIVO       VARCHAR2(10);
    ASSET_CLASS         VARCHAR2(200);
    V_ESPECIE           VARCHAR2(100);
    GOB_RF              VARCHAR2(1);
    V_EMISOR            NUMBER(15);
    NEG_COMPRA          NUMBER;
    NEG_VENTA           NUMBER;
    NEG_COMPRA1         NUMBER;
    NEG_VENTA1          NUMBER;
    CTA_PRC             NUMBER;
    CTA_PRV             NUMBER;
    V_F_EX_DIVID        DATE;
    V_CUSTODIO          VARCHAR2(15);
    V_DIA_HAB_SIGUIENTE DATE;
    V_DIA_HABI          VARCHAR2(1);
    V_TIPO_NEG          VARCHAR2(5);

    V_NUM_REG NUMBER := 0;

    V_SI_RABEMI    VARCHAR2(1);
    V_FONDO        VARCHAR2(15) := NULL;
    V_SUM_TIT      NUMBER := 0;
    V_SI_APT       VARCHAR2(5);
    CTA_APT_RV     VARCHAR2(5);
    V_NM_MONTO_DIV NUMBER := 0;
    V_FONDO2_APT   VARCHAR2(15) := NULL;
    V_ISIN         VARCHAR2(15) := NULL;
    V_VAL_EMI_PP   NUMBER := 0;
    V_SI_PROCESAR  VARCHAR2(1) := 'N';
    V_QUERY        VARCHAR2(500) := 'N';

  BEGIN

    DELETE FROM GL_VALIDA_PAGO_EMISORES;
    COMMIT;

    DELETE FROM TMP_VALIDA_PAGO_EMISORES;
    COMMIT;
    --*********************
    --  RENTA FIJA2   *
    --*********************

    OPEN C_RABEMI_RF(TRUNC(SYSDATE - 1), TRUNC(SYSDATE));
    FETCH C_RABEMI_RF
      INTO R_RABEMI_RF;
    WHILE C_RABEMI_RF%FOUND LOOP

      IF P_TOOLS.FN_ES_DIA_HABIL(R_RABEMI_RF.MCC_FECHA) = 'N' THEN
        SELECT P_TOOLS.DIA_HABIL_SIGUIENTE(R_RABEMI_RF.MCC_FECHA)
          INTO V_DIA_HAB_SIGUIENTE
          FROM DUAL;
        V_DIA_HABI := 'S';
      ELSE
        V_DIA_HAB_SIGUIENTE := R_RABEMI_RF.MCC_FECHA;
        V_DIA_HABI          := 'S';
      END IF;

      IF V_DIA_HABI = 'S' THEN

        IF R_RABEMI_RF.NUMERO_CUENTA2 IS NULL THEN
          V_FONDO := R_RABEMI_RF.NUMERO_CUENTA;
        ELSE
          V_FONDO := R_RABEMI_RF.NUMERO_CUENTA2;
        END IF;

        OPEN C_CLAS_POR(V_FONDO);
        FETCH C_CLAS_POR
          INTO V_SI_APT;
        IF C_CLAS_POR%NOTFOUND THEN
          V_SI_APT := 'NO';
        END IF;
        CLOSE C_CLAS_POR;

        V_SI_PROCESAR := 'N';

        IF V_SI_APT = 'FIC' OR V_SI_APT = 'SOC' THEN

          V_SI_PROCESAR := 'S';

        ELSIF V_SI_APT = 'APT' THEN

          OPEN C_VALIDA_APT_RABEMI(TRUNC(SYSDATE - 1),
                                   TRUNC(SYSDATE),
                                   R_RABEMI_RF.NUMERO_CUENTA,
                                   R_RABEMI_RF.ENA_MNEMONICO,
                                   R_RABEMI_RF.CTA_APT);
          FETCH C_VALIDA_APT_RABEMI
            INTO R_VALIDA_APT_RABEMI;
          IF C_VALIDA_APT_RABEMI%FOUND THEN
            V_SI_PROCESAR := 'S';
          ELSE
            V_SI_PROCESAR := 'N';
          END IF;
          CLOSE C_VALIDA_APT_RABEMI;

        ELSE
          V_SI_PROCESAR := 'N';
        END IF;

        IF V_SI_PROCESAR = 'S' THEN
          IF R_RABEMI_RF.ISIN IS NOT NULL THEN
            OPEN C_TITULO(V_FONDO,
                          R_RABEMI_RF.ENA_MNEMONICO,
                          R_RABEMI_RF.ISIN,
                          TRUNC(SYSDATE - 1),
                          TRUNC(SYSDATE));
            FETCH C_TITULO
              INTO R_TITULO;
            IF C_TITULO%NOTFOUND THEN

              P_INSERT_PAG_EMISOR(TRUNC(R_RABEMI_RF.MCC_FECHA) --V_DIA_HAB_SIGUIENTE
                                 ,
                                  R_RABEMI_RF.ENA_MNEMONICO,
                                  R_RABEMI_RF.ISIN,
                                  NULL,
                                  R_RABEMI_RF.MONTO,
                                  0,
                                  NULL,
                                  V_FONDO);

            END IF;
            WHILE C_TITULO%FOUND LOOP

              OPEN C_SUM_TITULOS(V_FONDO,
                                 R_RABEMI_RF.ENA_MNEMONICO,
                                 R_RABEMI_RF.ISIN,
                                 TRUNC(SYSDATE - 1),
                                 TRUNC(SYSDATE));
              FETCH C_SUM_TITULOS
                INTO R_SUM_TITULOS;
              CLOSE C_SUM_TITULOS;

              OPEN C_CBM(R_RABEMI_RF.MCC_FECHA, R_TITULO.TFO_BMO_MNEMONICO);
              FETCH C_CBM
                INTO CBM;
              CLOSE C_CBM;

              REND_RF2  := 0;
              V_FEC_RED := NULL;
              OPEN C_REND2(V_FONDO,
                           R_TITULO.TFO_CODIGO,
                           TRUNC(SYSDATE - 1),
                           TRUNC(SYSDATE));
              FETCH C_REND2
                INTO REND_RF2, V_FEC_RED;
              WHILE C_REND2%FOUND LOOP

                REND_RF2 := NVL(REND_RF2, '0');

                V_SUM_TIT := ((R_RABEMI_RF.MONTO / R_SUM_TITULOS.TOTAL_TIT) *
                             R_TITULO.TFO_VALOR_NOMINAL);

                P_INSERT_PAG_EMISOR(TRUNC(V_FEC_RED) --V_DIA_HAB_SIGUIENTE
                                   ,
                                    R_RABEMI_RF.ENA_MNEMONICO,
                                    R_RABEMI_RF.ISIN,
                                    R_TITULO.TFO_VALOR_NOMINAL,
                                    V_SUM_TIT --R_RABEMI_RF.MONTO
                                   ,
                                    REND_RF2 --V_VAL_COEASY
                                   ,
                                    R_TITULO.CUSTODIO,
                                    V_FONDO);

                FETCH C_REND2
                  INTO REND_RF2, V_FEC_RED;
              END LOOP;
              CLOSE C_REND2;

              FETCH C_TITULO
                INTO R_TITULO;
            END LOOP;
            CLOSE C_TITULO;

          ELSE

            OPEN C_TITULO_DCV(V_FONDO,
                              R_RABEMI_RF.ENA_MNEMONICO,
                              TRUNC(SYSDATE - 1),
                              TRUNC(SYSDATE));
            FETCH C_TITULO_DCV
              INTO R_TITULO_DCV;
            IF C_TITULO_DCV%NOTFOUND THEN

              P_INSERT_PAG_EMISOR(TRUNC(R_RABEMI_RF.MCC_FECHA) --V_DIA_HAB_SIGUIENTE
                                 ,
                                  R_RABEMI_RF.ENA_MNEMONICO,
                                  NULL --R_RABEMI_RF.REFERENCIA_DEPOSITOR_RABEMI_RF.ISIN
                                 ,
                                  NULL - R_TITULO_DCV.TFO_VALOR_NOMINAL,
                                  R_RABEMI_RF.MONTO,
                                  0 --REND_RF2--V_VAL_COEASY
                                 ,
                                  NULL --R_TITULO_DCV.CUSTODIO
                                 ,
                                  V_FONDO);
            END IF;
            WHILE C_TITULO_DCV%FOUND LOOP

              OPEN C_SUM_TITULOS_DCV(V_FONDO,
                                     R_RABEMI_RF.ENA_MNEMONICO, /*R_RABEMI_RF.REFERENCIA_DEPOSITO,*/
                                     TRUNC(SYSDATE - 1),
                                     TRUNC(SYSDATE));
              FETCH C_SUM_TITULOS_DCV
                INTO R_SUM_TITULOS_DCV;
              CLOSE C_SUM_TITULOS_DCV;

              OPEN C_CBM(R_RABEMI_RF.MCC_FECHA,
                         R_TITULO_DCV.TFO_BMO_MNEMONICO);
              FETCH C_CBM
                INTO CBM;
              CLOSE C_CBM;

              REND_RF2  := 0;
              V_FEC_RED := NULL;
              OPEN C_REND2(V_FONDO,
                           R_TITULO_DCV.TFO_CODIGO,
                           TRUNC(SYSDATE - 1),
                           TRUNC(SYSDATE));
              FETCH C_REND2
                INTO REND_RF2, V_FEC_RED;
              WHILE C_REND2%FOUND LOOP

                REND_RF2 := NVL(REND_RF2, '0');

                V_SUM_TIT := ((R_RABEMI_RF.MONTO /
                             R_SUM_TITULOS_DCV.TOTAL_TIT) *
                             R_TITULO_DCV.TFO_VALOR_NOMINAL);

                P_INSERT_PAG_EMISOR(TRUNC(V_FEC_RED) --V_DIA_HAB_SIGUIENTE
                                   ,
                                    R_RABEMI_RF.ENA_MNEMONICO,
                                    R_TITULO_DCV.NUM_EMISION --R_RABEMI_RF.ISIN
                                   ,
                                    R_TITULO_DCV.TFO_VALOR_NOMINAL,
                                    V_SUM_TIT --R_RABEMI_RF.MONTO
                                   ,
                                    REND_RF2 --V_VAL_COEASY
                                   ,
                                    R_TITULO_DCV.CUSTODIO,
                                    V_FONDO);

                FETCH C_REND2
                  INTO REND_RF2, V_FEC_RED;
              END LOOP;
              CLOSE C_REND2;

              FETCH C_TITULO_DCV
                INTO R_TITULO_DCV;
            END LOOP;
            CLOSE C_TITULO_DCV;
          END IF;
        END IF;
      END IF;
      FETCH C_RABEMI_RF
        INTO R_RABEMI_RF;
    END LOOP;
    CLOSE C_RABEMI_RF;

    /******************************************
    PP-RC
    *******************************************/

    OPEN C_RABEMI_RF_PP(TRUNC(SYSDATE - 1), TRUNC(SYSDATE));
    FETCH C_RABEMI_RF_PP
      INTO R_RABEMI_RF_PP;
    WHILE C_RABEMI_RF_PP%FOUND LOOP

      IF P_TOOLS.FN_ES_DIA_HABIL(R_RABEMI_RF_PP.MCC_FECHA) = 'N' THEN
        SELECT P_TOOLS.DIA_HABIL_SIGUIENTE(R_RABEMI_RF_PP.MCC_FECHA)
          INTO V_DIA_HAB_SIGUIENTE
          FROM DUAL;
        V_DIA_HABI := 'S';
      ELSE
        V_DIA_HAB_SIGUIENTE := R_RABEMI_RF_PP.MCC_FECHA;
        V_DIA_HABI          := 'S';
      END IF;

      IF V_DIA_HABI = 'S' THEN

        IF R_RABEMI_RF_PP.NUMERO_CUENTA2 IS NULL THEN
          V_FONDO := R_RABEMI_RF_PP.NUMERO_CUENTA;
        ELSE
          V_FONDO := R_RABEMI_RF_PP.NUMERO_CUENTA2;
        END IF;

        IF R_RABEMI_RF_PP.ISIN IS NOT NULL THEN

          OPEN C_TIT_PP(R_RABEMI_RF_PP.ENA_MNEMONICO,
                        R_RABEMI_RF_PP.ISIN,
                        TRUNC(SYSDATE - 1),
                        TRUNC(SYSDATE));
          FETCH C_TIT_PP
            INTO R_TIT_PP;
          IF C_TIT_PP%NOTFOUND THEN

            P_INSERT_PAG_EMISOR(TRUNC(R_RABEMI_RF_PP.MCC_FECHA) --V_DIA_HAB_SIGUIENTE
                               ,
                                R_RABEMI_RF_PP.ENA_MNEMONICO,
                                R_RABEMI_RF_PP.ISIN,
                                NULL --R_TIT_PP.TFO_VALOR_NOMINAL
                               ,
                                R_RABEMI_RF_PP.MONTO,
                                0 --REND_RF2--V_VAL_COEASY
                               ,
                                NULL --R_TIT_PP.CUSTODIO
                               ,
                                V_FONDO);

          END IF;
          WHILE C_TIT_PP%FOUND LOOP

            OPEN C_SUM_TIT_PP(R_RABEMI_RF_PP.ENA_MNEMONICO,
                              R_RABEMI_RF_PP.ISIN,
                              TRUNC(SYSDATE - 1),
                              TRUNC(SYSDATE));
            FETCH C_SUM_TIT_PP
              INTO R_SUM_TIT_PP;
            CLOSE C_SUM_TIT_PP;

            OPEN C_CBM(R_RABEMI_RF_PP.MCC_FECHA,
                       R_TIT_PP.TFO_BMO_MNEMONICO);
            FETCH C_CBM
              INTO CBM;
            CLOSE C_CBM;

            REND_RF2  := 0;
            V_FEC_RED := NULL;
            OPEN C_REND2_PP(V_FONDO,
                            R_TIT_PP.TFO_CODIGO,
                            TRUNC(SYSDATE - 1),
                            TRUNC(SYSDATE));
            FETCH C_REND2_PP
              INTO REND_RF2, V_FEC_RED;
            WHILE C_REND2_PP%FOUND LOOP

              REND_RF2 := NVL(REND_RF2, '0');

              V_SUM_TIT := ((R_RABEMI_RF_PP.MONTO / R_SUM_TIT_PP.TOTAL_TIT) *
                           R_TIT_PP.TFO_VALOR_NOMINAL);

              P_INSERT_PAG_EMISOR(TRUNC(V_FEC_RED) --V_DIA_HAB_SIGUIENTE
                                 ,
                                  R_RABEMI_RF_PP.ENA_MNEMONICO,
                                  R_RABEMI_RF_PP.ISIN,
                                  R_TIT_PP.TFO_VALOR_NOMINAL,
                                  V_SUM_TIT --R_RABEMI_RF_PP.MONTO
                                 ,
                                  REND_RF2 --V_VAL_COEASY
                                 ,
                                  R_TIT_PP.CUSTODIO,
                                  V_FONDO);

              FETCH C_REND2_PP
                INTO REND_RF2, V_FEC_RED;
            END LOOP;
            CLOSE C_REND2_PP;

            FETCH C_TIT_PP
              INTO R_TIT_PP;
          END LOOP;
          CLOSE C_TIT_PP;

        ELSE

          OPEN C_TIT_PP_DCV(R_RABEMI_RF_PP.ENA_MNEMONICO, /*R_RABEMI_RF_PP.REFERENCIA_DEPOSITO,*/
                            TRUNC(SYSDATE - 1),
                            TRUNC(SYSDATE));
          FETCH C_TIT_PP_DCV
            INTO R_TIT_PP_DCV;

          IF C_TIT_PP_DCV%NOTFOUND THEN
            P_INSERT_PAG_EMISOR(TRUNC(V_FEC_RED) --V_DIA_HAB_SIGUIENTE
                               ,
                                R_RABEMI_RF_PP.ENA_MNEMONICO,
                                NULL --R_RABEMI_RF_PP.REFERENCIA_DEPOSITO--R_RABEMI_RF_PP.ISIN
                               ,
                                NULL --R_TIT_PP_DCV.TFO_VALOR_NOMINAL
                               ,
                                R_RABEMI_RF_PP.MONTO,
                                0 --REND_RF2--V_VAL_COEASY
                               ,
                                NULL --R_TIT_PP_DCV.CUSTODIO
                               ,
                                V_FONDO);
          END IF;

          WHILE C_TIT_PP_DCV%FOUND LOOP

            OPEN C_SUM_TIT_PP_DCV(R_RABEMI_RF_PP.ENA_MNEMONICO, /*R_RABEMI_RF_PP.REFERENCIA_DEPOSITO,*/
                                  TRUNC(SYSDATE - 1),
                                  TRUNC(SYSDATE));
            FETCH C_SUM_TIT_PP_DCV
              INTO R_SUM_TIT_PP_DCV;
            CLOSE C_SUM_TIT_PP_DCV;

            OPEN C_CBM(R_RABEMI_RF_PP.MCC_FECHA,
                       R_TIT_PP_DCV.TFO_BMO_MNEMONICO);
            FETCH C_CBM
              INTO CBM;
            CLOSE C_CBM;

            REND_RF2  := 0;
            V_FEC_RED := NULL;
            OPEN C_REND2_PP(V_FONDO,
                            R_TIT_PP_DCV.TFO_CODIGO,
                            TRUNC(SYSDATE - 1),
                            TRUNC(SYSDATE));
            FETCH C_REND2_PP
              INTO REND_RF2, V_FEC_RED;
            WHILE C_REND2_PP%FOUND LOOP

              REND_RF2 := NVL(REND_RF2, '0');

              V_SUM_TIT := ((R_RABEMI_RF_PP.MONTO /
                           R_SUM_TIT_PP_DCV.TOTAL_TIT) *
                           R_TIT_PP_DCV.TFO_VALOR_NOMINAL);

              P_INSERT_PAG_EMISOR(TRUNC(V_FEC_RED) --V_DIA_HAB_SIGUIENTE
                                 ,
                                  R_RABEMI_RF_PP.ENA_MNEMONICO,
                                  R_TIT_PP_DCV.NUM_EMISION --R_RABEMI_RF_PP.REFERENCIA_DEPOSITO--R_RABEMI_RF_PP.ISIN
                                 ,
                                  R_TIT_PP_DCV.TFO_VALOR_NOMINAL,
                                  V_SUM_TIT --R_RABEMI_RF_PP.MONTO
                                 ,
                                  REND_RF2 --V_VAL_COEASY
                                 ,
                                  R_TIT_PP_DCV.CUSTODIO,
                                  V_FONDO);

              FETCH C_REND2_PP
                INTO REND_RF2, V_FEC_RED;
            END LOOP;
            CLOSE C_REND2_PP;

            FETCH C_TIT_PP_DCV
              INTO R_TIT_PP_DCV;
          END LOOP;
          CLOSE C_TIT_PP_DCV;
        END IF;
      END IF;

      FETCH C_RABEMI_RF_PP
        INTO R_RABEMI_RF_PP;
    END LOOP;
    CLOSE C_RABEMI_RF_PP;

    --*********************
    --  RENTA VARIABLE    *
    --*********************

    OPEN C_RABEMI(TRUNC(SYSDATE - 1), TRUNC(SYSDATE));
    FETCH C_RABEMI
      INTO R_RABEMI;
    WHILE C_RABEMI%FOUND LOOP

      OPEN C_CLAS_POR(R_RABEMI.FONDO);
      FETCH C_CLAS_POR
        INTO V_SI_APT;
      IF C_CLAS_POR%NOTFOUND THEN
        V_SI_APT := 'NO';
      END IF;
      CLOSE C_CLAS_POR;

      IF V_SI_APT NOT IN ('SOC', 'FIC', 'FCP') THEN

        OPEN C_CTA_RABEMI(TRUNC(R_RABEMI.MCC_FECHA),
                          R_RABEMI.FONDO,
                          R_RABEMI.MCC_CFC_FUG_ISI_MNEMONICO,
                          R_RABEMI.MCC_ENA_MNEMONICO);
        FETCH C_CTA_RABEMI
          INTO R_CTA_RABEMI;
        IF C_CTA_RABEMI%FOUND THEN

          OPEN C_RABEMI_APT(TRUNC(R_RABEMI.MCC_FECHA),
                            R_RABEMI.FONDO,
                            R_RABEMI.MCC_CFC_FUG_ISI_MNEMONICO,
                            R_RABEMI.MCC_ENA_MNEMONICO,
                            R_CTA_RABEMI.CTA_APT);
          FETCH C_RABEMI_APT
            INTO R_RABEMI_APT;
          CLOSE C_RABEMI_APT;

          SELECT TRUNC(RDI_FECHA_EX_DIVIDENDO), RDI_MONTO
            INTO V_F_EX_DIVID, V_NM_MONTO_DIV
            FROM RELOJ_DIVIDENDOS
           WHERE RDI_ENA_MNEMONICO = R_RABEMI.MCC_ENA_MNEMONICO
             AND RDI_ISI_MNEMONICO = R_RABEMI.MCC_CFC_FUG_ISI_MNEMONICO
             AND RDI_FECHA_EX_DIVIDENDO =
                 (SELECT MAX(TRUNC(RDI_FECHA_EX_DIVIDENDO)) --INTO V_F_EX_DIVID
                    FROM RELOJ_DIVIDENDOS
                   WHERE RDI_ENA_MNEMONICO = R_RABEMI.MCC_ENA_MNEMONICO
                     AND RDI_ISI_MNEMONICO =
                         R_RABEMI.MCC_CFC_FUG_ISI_MNEMONICO
                     AND RDI_FECHA_EX_DIVIDENDO <= TRUNC(R_RABEMI.MCC_FECHA));

          V_NM_MONTO_DIV := V_NM_MONTO_DIV *
                            R_RABEMI.MCC_VALOR_NOMINAL_CANTIDAD;

          IF R_CTA_RABEMI.FONDO IS NOT NULL THEN
            V_FONDO2_APT := R_CTA_RABEMI.FONDO;
          ELSE
            V_FONDO2_APT := R_RABEMI.FONDO;
          END IF;

          OPEN C_PORTA_RV(V_F_EX_DIVID,
                          R_RABEMI.MCC_ENA_MNEMONICO,
                          V_FONDO2_APT);
          FETCH C_PORTA_RV
            INTO R_POR_RV;
          IF C_PORTA_RV%FOUND THEN

            BEGIN
              SELECT EMI_GOBIERNO
                INTO GOB_RF
                FROM EMISORES
               WHERE EMI_DESCRIPCION = R_POR_RV.EMISOR_DESCRIPCION;
            EXCEPTION
              WHEN OTHERS THEN

                GOB_RF := 'N';
            END;

            IF GOB_RF = 'N' THEN

              V_CUSTODIO := 'DECEVAL';

            ELSE

              V_CUSTODIO := 'DCV';

            END IF;

            P_INSERT_PAG_EMISOR(R_RABEMI.MCC_FECHA,
                                R_RABEMI.MCC_ENA_MNEMONICO,
                                R_RABEMI.MCC_CFC_FUG_ISI_MNEMONICO,
                                R_RABEMI.MCC_VALOR_NOMINAL_CANTIDAD,
                                R_RABEMI_APT.MCC_MONTO_ADMON_VALORES,
                                V_NM_MONTO_DIV --R_RABEMI.MCC_MONTO_ADMON_VALORES
                               ,
                                V_CUSTODIO,
                                V_FONDO2_APT -- R_RABEMI.FONDO
                                );

          END IF;
          CLOSE C_PORTA_RV;
        END IF;
        CLOSE C_CTA_RABEMI;

      ELSE

        SELECT TRUNC(RDI_FECHA_EX_DIVIDENDO), RDI_MONTO
          INTO V_F_EX_DIVID, V_NM_MONTO_DIV
          FROM RELOJ_DIVIDENDOS
         WHERE RDI_ENA_MNEMONICO = R_RABEMI.MCC_ENA_MNEMONICO
           AND RDI_ISI_MNEMONICO = R_RABEMI.MCC_CFC_FUG_ISI_MNEMONICO
           AND RDI_FECHA_EX_DIVIDENDO =
               (SELECT MAX(TRUNC(RDI_FECHA_EX_DIVIDENDO)) --INTO V_F_EX_DIVID
                  FROM RELOJ_DIVIDENDOS
                 WHERE RDI_ENA_MNEMONICO = R_RABEMI.MCC_ENA_MNEMONICO
                   AND RDI_ISI_MNEMONICO =
                       R_RABEMI.MCC_CFC_FUG_ISI_MNEMONICO
                   AND RDI_FECHA_EX_DIVIDENDO <= TRUNC(R_RABEMI.MCC_FECHA));

        V_NM_MONTO_DIV := V_NM_MONTO_DIV *
                          R_RABEMI.MCC_VALOR_NOMINAL_CANTIDAD;

        OPEN C_PORTA_RV(V_F_EX_DIVID,
                        R_RABEMI.MCC_ENA_MNEMONICO,
                        R_RABEMI.FONDO);
        FETCH C_PORTA_RV
          INTO R_POR_RV;
        IF C_PORTA_RV%FOUND THEN

          BEGIN
            SELECT EMI_GOBIERNO
              INTO GOB_RF
              FROM EMISORES
             WHERE EMI_DESCRIPCION = R_POR_RV.EMISOR_DESCRIPCION;
          EXCEPTION
            WHEN OTHERS THEN

              GOB_RF := 'N';
          END;

          IF GOB_RF = 'N' THEN

            V_CUSTODIO := 'DECEVAL';

          ELSE

            V_CUSTODIO := 'DCV';

          END IF;

          P_INSERT_PAG_EMISOR(R_RABEMI.MCC_FECHA,
                              R_RABEMI.MCC_ENA_MNEMONICO,
                              R_RABEMI.MCC_CFC_FUG_ISI_MNEMONICO,
                              R_RABEMI.MCC_VALOR_NOMINAL_CANTIDAD,
                              R_RABEMI.MCC_MONTO_ADMON_VALORES,
                              V_NM_MONTO_DIV --R_RABEMI.MCC_MONTO_ADMON_VALORES
                             ,
                              V_CUSTODIO,
                              R_RABEMI.FONDO);

        END IF;
        CLOSE C_PORTA_RV;

      END IF;

      FETCH C_RABEMI
        INTO R_RABEMI;
    END LOOP;
    CLOSE C_RABEMI;

    INSERT INTO TMP_VALIDA_PAGO_EMISORES
      SELECT GVP_FECHA,
             GVP_MNEMO_ESPECIE,
             GVP_ISIN,
             GVP_VALOR_NOMINAL,
             GVP_VALOR_EMISOR,
             GVP_VALOR_COEASY,
             GVP_CUSTODIO,
             GVP_PORTAFOLIO,
             GVP_NIT_PORTAFOLIO,
             GVP_TIPO_PORTAFOLIO
        FROM GL_VALIDA_PAGO_EMISORES;
    COMMIT;

    V_RUTA := '\\nas.corredor.local\Riesgo\CONFIDENCIAL\Reportes Excel Coeasy\';
    --V_RUTA := '\\nas.corredor.local\presentaciones\';

    V_QUERY        := 'SELECT TRUNC(TMP_FECHA) FECHA, TMP_MNEMO_ESPECIE ESPECIE, TMP_ISIN ISIN, TMP_VALOR_NOMINAL NOMINAL, TMP_VALOR_EMISOR VALOR_EMISOR,
                          TMP_VALOR_COEASY VALOR_COEASY, TMP_CUSTODIO CUSTODIO, TMP_PORTAFOLIO PORTAFOLIO, TMP_NIT_PORTAFOLIO NIT_PORTAFOLIO,
                            TMP_TIPO_PORTAFOLIO TIPO_PORTAFOLIO FROM  TMP_VALIDA_PAGO_EMISORES';
    NOMBRE_ARCHIVO := 'VAPEMI_' ||
                      TO_CHAR(SYSDATE - 1, 'DDMMYYYY_hh24mmss');

    P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => V_RUTA,
                                   P_NOMBRE_ARCHIVO => NOMBRE_ARCHIVO,
                                   P_QUERY          => V_QUERY,
                                   P_CODIGO         => P_CODIGO,
                                   P_RESPUESTA      => P_RESPUESTA);
    IF P_CODIGO = '0000' THEN
      DBMS_OUTPUT.PUT_LINE('Se ha generado el archivo, en la ruta ' ||
                           V_RUTA);
    END IF;
  EXCEPTION
    WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20059,
                              'No se genero reporte VAPEMI, comuniquese con soporte, error: ' ||
                              SQLERRM);
  END P_EJECUTA_VAPAEMI;

  PROCEDURE P_INSERT_PAG_EMISOR(P_FECHA         DATE,
                                P_ESPECIE       VARCHAR2,
                                P_ISIN          VARCHAR2,
                                P_VALOR_NOMINAL NUMBER,
                                P_VALOR_EMISOR  NUMBER,
                                P_VALOR_COEASY  NUMBER,
                                P_CUSTODIO      VARCHAR2,
                                P_FONDO         VARCHAR2) IS

    CURSOR C_CLASIF_PORTA(P_FONDO VARCHAR2) IS
      SELECT DECODE(CPOR_TIPO_PORTAFOLIO,
                    'SOC',
                    'SOCIEDAD',
                    'FIC',
                    'FONDOS DE INV. COLECTIVA',
                    'APT',
                    'ADMIN. PORTAFOLIO DE TERCEROS',
                    'FCP',
                    'FONDOS DE CAPITAL PRIVADO',
                    CPOR_TIPO_PORTAFOLIO) CPOR_TIPO_PORTAFOLIO,
             CPOR_DESCRIPCION
        FROM CLASIFICACIONES_PORTAFOLIOS
       WHERE CPOR_FON_CODIGO = P_FONDO;

    V_T_PORT     VARCHAR2(100);
    V_PORTAFOLIO VARCHAR2(100);

  BEGIN

    OPEN C_CLASIF_PORTA(P_FONDO);
    FETCH C_CLASIF_PORTA
      INTO V_T_PORT, V_PORTAFOLIO;
    IF C_CLASIF_PORTA%NOTFOUND THEN

      V_T_PORT     := NULL;
      V_PORTAFOLIO := NULL;

    END IF;
    CLOSE C_CLASIF_PORTA;

    INSERT INTO GL_VALIDA_PAGO_EMISORES
      (GVP_FECHA,
       GVP_MNEMO_ESPECIE,
       GVP_ISIN,
       GVP_VALOR_NOMINAL,
       GVP_VALOR_EMISOR,
       GVP_VALOR_COEASY,
       GVP_CUSTODIO,
       GVP_PORTAFOLIO,
       GVP_NIT_PORTAFOLIO,
       GVP_TIPO_PORTAFOLIO)
    VALUES
      (TRUNC(P_FECHA) --V_DIA_HAB_SIGUIENTE
      ,
       P_ESPECIE --R_RABEMI_RF.ENA_MNEMONICO
      ,
       P_ISIN --R_RABEMI_RF.ISIN
      ,
       P_VALOR_NOMINAL --R_TITULO.TFO_VALOR_NOMINAL
      ,
       P_VALOR_EMISOR --V_SUM_TIT--R_RABEMI_RF.MONTO
      ,
       P_VALOR_COEASY --REND_RF2--V_VAL_COEASY
      ,
       P_CUSTODIO --R_TITULO.CUSTODIO
      ,
       V_PORTAFOLIO --V_RF.PORTAFOLIO
      ,
       P_FONDO,
       V_T_PORT);

    COMMIT;

  END P_INSERT_PAG_EMISOR;

  PROCEDURE P_GENERA_CORTOS IS

    CURSOR C_EXISTE(P_FECHA_DESDE DATE, P_FECHA_HASTA DATE) IS
      SELECT COUNT(1)
        FROM OPERACIONES_COMPRAS_VENTAS
       WHERE OPCV_FECHA >= TRUNC(P_FECHA_DESDE)
         AND OPCV_FECHA < TRUNC(P_FECHA_HASTA);

    V_EXISTE       NUMBER;
    P_CODIGO       VARCHAR2(200);
    P_RESPUESTA    VARCHAR2(200);
    RUTA           VARCHAR2(100);
    NOMBRE_ARCHIVO VARCHAR2(100);
    V_QUERY        VARCHAR2(5000);
    P_NUM_INI      NUMBER;
    P_NUM_FIN      NUMBER;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_GENERA_CORTOS',
                                                      'INI');

    DELETE FROM TMP_INPOCO;
    COMMIT;
    DBMS_OUTPUT.PUT_LINE('DELETE: ');

    RUTA := '\\nas.corredor.local\contabilidad\PRIVADA\Reportes transmisiones\Diarios\';

    NOMBRE_ARCHIVO := 'INPOCO_' || TO_CHAR(SYSDATE, 'DD-MM-YYYY_hh24mmss');

    OPEN C_EXISTE(TRUNC(SYSDATE), TRUNC(SYSDATE + 1));
    FETCH C_EXISTE
      INTO V_EXISTE;
    IF NVL(V_EXISTE, 0) = 0 THEN
      P_REPORTES_CORTOS.PR_CALCULAR_CORTOS(TRUNC(SYSDATE));
    END IF;
    CLOSE C_EXISTE;

    INSERT INTO TMP_INPOCO
      (FECHA_DESDE, ESPECIE, ISIN, NETO_ACUMULADO, COMERCIAL)
      (SELECT OPCV_FECHA,
              OPCV_ENA_MNEMONICO,
              OPCV_ISI_MNEMONICO,
              OPCV_VALOR_NETO,
              OPCV_PPO_PER_NUM_IDEN
         FROM OPERACIONES_COMPRAS_VENTAS
        WHERE OPCV_FECHA >= TRUNC(SYSDATE)
          AND OPCV_FECHA < TRUNC(SYSDATE + 1)
          AND OPCV_ENA_MNEMONICO LIKE '%'
          AND OPCV_ISI_MNEMONICO LIKE '%');
    COMMIT;

    DBMS_OUTPUT.PUT_LINE('INSERTO: ');
    P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => RUTA,
                                   P_NOMBRE_ARCHIVO => NOMBRE_ARCHIVO,
                                   P_QUERY          => 'SELECT * FROM TMP_INPOCO',
                                   P_CODIGO         => P_CODIGO,
                                   P_RESPUESTA      => P_RESPUESTA);
    DBMS_OUTPUT.PUT_LINE('GENERO: ');
    IF P_CODIGO = '0000' THEN
      DBMS_OUTPUT.PUT_LINE('Se ha generado el archivo ' || nombre_archivo ||
                           ' en la ruta ' || RUTA);
    END IF;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_GENERA_CORTOS',
                                                      'FIN');
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento P_GENERA_CORTOS',
                              SUBSTR(SQLERRM, 1, 80),
                              'procesosnocturnos@corredores.com');

  END P_GENERA_CORTOS;

  -- sortiz transmisiones simultaneas 2
  PROCEDURE P_EJECUTA_GARCLI IS

    NOMBRE_ARCHIVO     VARCHAR2(100);
    P_FECHA2           VARCHAR2(20);
    TIPO_CLIENTE       VARCHAR2(20);
    TIP_ARCHIVO        UTL_FILE.FILE_TYPE;
    ARCHIVO_PORTAFOLIO VARCHAR2(100);
    V_RUTA             VARCHAR2(100);
    P_CODIGO           VARCHAR2(200);
    P_RESPUESTA        VARCHAR2(200);
    V_QUERY            VARCHAR2(1000);
    P_NUM_INI          NUMBER;
    P_NUM_FIN          NUMBER;

  BEGIN
    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_EJECUTA_GARCLI',
                                                      'INI');

    P_FRACCION_RV_C.CARGA_GARANTIAS_CLI(SYSDATE - 1, SYSDATE);
    P_FRACCION_RV_C.CARGA_GARANTIAS_CLI_RF(SYSDATE - 1, SYSDATE);

    V_RUTA         := '\\nas.corredor.local\Riesgo\CONFIDENCIAL\Reportes Excel Coeasy\';
    NOMBRE_ARCHIVO := 'GARCLI_RIESGOS' ||
                      TO_CHAR(SYSDATE - 1, 'DDMMYYYY_hh24mmss');
    V_QUERY        := 'SELECT SGC_CLI_PER_NUM_IDEN  NUM_ID,SGC_CLI_PER_TID_CODIGO TID_COD, SGC_NOMBRE RAZON_SOCIAL, SGC_ENA_MNEMONICO ESPECIE, SGC_ISI_MNEMONICO ISIN,' ||
                      'SGC_SALDO_GARANTIA NOMINAL, SGC_TIPO_GARANTIA TIPO_GARANTIA, SGC_CUENTA_CRCC CUENTA_CRCC, SGC_SEGMENTO SEGMENTO,' ||
                      'SGC_ACTIVO_GAR  ACTIVO_GARANTIA, SGC_TIPO_NEG TIPO_NEGOCIO, SGC_COD_TRANSMISION COD_TRANSMISION, SGC_RESTRICCION_351 RESTRICCION,' ||

                     -- OMORA F351
                     -- 'SGC_FECHA_CONSULTA FECHA_CONSULTA FROM SALDOS_GAR_CLIENTES ORDER BY SGC_FECHA_CONSULTA, SGC_TIPO_NEG, SGC_CLI_PER_NUM_IDEN, SGC_ACTIVO_GAR, SGC_ENA_MNEMONICO, SGC_CUENTA_CRCC  DESC ';
                      'SGC_FECHA_CONSULTA FECHA_CONSULTA FROM SALDOS_GAR_CLIENTES ' ||
                      'WHERE SGC_FECHA_CONSULTA >= TRUNC(SYSDATE - 1) AND SGC_FECHA_CONSULTA < TRUNC(SYSDATE) ' ||
                      ' AND SGC_TIPO_NEG <> ''CLI'' ' ||
                      ' ORDER BY SGC_FECHA_CONSULTA, SGC_TIPO_NEG, SGC_CLI_PER_NUM_IDEN, SGC_ACTIVO_GAR, SGC_ENA_MNEMONICO, SGC_CUENTA_CRCC  DESC ';
    -- FIN OMORA F351

    --LLAMADO AL PROGRAMA QUE CREA EL XSLX
    P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => V_RUTA,
                                   P_NOMBRE_ARCHIVO => NOMBRE_ARCHIVO,
                                   P_QUERY          => V_QUERY,
                                   P_CODIGO         => P_CODIGO,
                                   P_RESPUESTA      => P_RESPUESTA);

    V_RUTA         := '\\nas.corredor.local\contabilidad\PRIVADA\Reportes transmisiones\Diarios\';
    NOMBRE_ARCHIVO := 'GARCLI_CONTA' ||
                      TO_CHAR(SYSDATE - 1, 'DDMMYYYY_hh24mmss');

    P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => V_RUTA,
                                   P_NOMBRE_ARCHIVO => NOMBRE_ARCHIVO,
                                   P_QUERY          => V_QUERY,
                                   P_CODIGO         => P_CODIGO,
                                   P_RESPUESTA      => P_RESPUESTA);
    IF P_CODIGO = '0000' THEN
      DBMS_OUTPUT.PUT_LINE('Se ha generado el archivo, en la ruta ' ||
                           V_RUTA);
    END IF;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_EJECUTA_GARCLI',
                                                      'FIN');
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento P_EJECUTA_GARCLI',
                              SUBSTR(SQLERRM, 1, 80),
                              'procesosnocturnos@corredores.com');

  END P_EJECUTA_GARCLI;

  -- VAGTUD881-6 INVERSIONES INT FONDOS MUTUOS
  PROCEDURE PR_INVINT_OPFESTIVOS IS
    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN
    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_INVINT_OPFESTIVOS',
                                                      'INI');
    P_INVINT_FONDOS.PR_INVINT_OPCUMPLE_FESTIVOS(SYSDATE);
    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_INVINT_OPFESTIVOS',
                                                      'FIN');

  EXCEPTION
    WHEN OTHERS THEN
      NULL;
      P_MAIL.ENVIO_MAIL_ERROR('Error en proceso nocturno PR_INVINT_OPFESTIVOS',
                              SUBSTR(SQLERRM, 1, 80),
                              DESTINATARIOS);

  END PR_INVINT_OPFESTIVOS;

  PROCEDURE PR_ACT_MICROINVERSIONISTA IS
    CURSOR C_UVR(P_FECHA DATE) IS
      SELECT CBM_VALOR
        FROM COTIZACIONES_BASE_MONETARIAS
       WHERE CBM_FECHA = P_FECHA
         AND CBM_BMO_MNEMONICO = 'UVR';

    P_UVR   NUMBER;
    P_FECHA DATE;

    CURSOR C_SALDOS IS
      SELECT HST.HST_CCC_CLI_PER_NUM_IDEN,
             HST.HST_CCC_CLI_PER_TID_CODIGO,
             SUM(HST.HST_VALOR_TM_DISPONIBLE) TOTAL
        FROM HISTORICOS_SALDOS_TITULOS  HST,
             CUENTAS_CLIENTE_CORREDORES CCC,
             CLIENTES                   C
       WHERE HST.HST_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
         AND HST.HST_CCC_CLI_PER_TID_CODIGO = CCC.CCC_CLI_PER_TID_CODIGO
         AND HST.HST_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA
         AND HST.HST_FECHA = P_FECHA --'15-JUN-2021'
         AND C.CLI_PER_NUM_IDEN = HST.HST_CCC_CLI_PER_NUM_IDEN
         AND C.CLI_PER_TID_CODIGO = HST.HST_CCC_CLI_PER_TID_CODIGO
         AND C.CLI_MOT_EXE_SEG_MIV IS NULL
         AND C.CLI_SEG_MICRO = 'N'
         AND C.CLI_ECL_MNEMONICO != 'INA'
         AND (CCC.CCC_PER_NUM_IDEN, CCC.CCC_PER_TID_CODIGO) IN
             (SELECT PCP.PCP_PER_NUM_IDEN, PCP.PCP_PER_TID_CODIGO
                FROM PERSONAS_CENTROS_PRODUCCION PCP
               WHERE PCP_CPR_MNEMONICO IN (36, 67)
                 AND PCP_PRINCIPAL = 'S') HAVING
       SUM(HST.HST_VALOR_TM_DISPONIBLE) > 0
       GROUP BY HST.HST_CCC_CLI_PER_NUM_IDEN,
                HST.HST_CCC_CLI_PER_TID_CODIGO;
    P_SALDOS C_SALDOS%ROWTYPE;

    CURSOR C_CLIENTES IS
      SELECT CLI_PER_NUM_IDEN, CLI_PER_TID_CODIGO
        FROM CLIENTES
       WHERE CLI_SEG_MICRO = 'S'
         AND CLI_ECL_MNEMONICO != 'INA';
    P_CLIENTES C_CLIENTES%ROWTYPE;

    CURSOR C_COLECTIVA(NUM_IDEN VARCHAR2, TID_CODIGO VARCHAR2) IS
      SELECT CFO_CCC_CLI_PER_NUM_IDEN,
             CFO_CCC_CLI_PER_TID_CODIGO,
             SUM(CFO_SALDO_INVER) SUMA
        FROM CUENTAS_FONDOS CF, FONDOS F
       WHERE CF.CFO_FON_CODIGO = F.FON_CODIGO
         AND CFO_SALDO_INVER > 0
         AND FON_TIPO_ADMINISTRACION = 'F'
         AND FON_ESTADO = 'A'
         AND CFO_CCC_CLI_PER_NUM_IDEN = NUM_IDEN
         AND CFO_CCC_CLI_PER_TID_CODIGO = TID_CODIGO
       GROUP BY CFO_CCC_CLI_PER_NUM_IDEN, CFO_CCC_CLI_PER_TID_CODIGO;
    P_COLECTIVA C_COLECTIVA%ROWTYPE;

    P_RUTA           VARCHAR2(256);
    P_NOMBRE_ARCHIVO VARCHAR2(256);
    P_QUERY          VARCHAR2(256);
    P_CODIGO         VARCHAR2(4000);
    P_RESPUESTA      VARCHAR2(4000);
    ACTUALIZACION    VARCHAR2(1);
    P_NUM_INI        NUMBER;
    P_NUM_FIN        NUMBER;
  BEGIN
    --P_FECHA := '28-JUN-2021';
    P_FECHA := TRUNC(SYSDATE - 1);
    OPEN C_UVR(P_FECHA);
    FETCH C_UVR
      INTO P_UVR;
    --DBMS_OUTPUT.PUT_LINE('C_UVR '||P_UVR);
    CLOSE C_UVR;
    P_UVR := P_UVR * 66000;
    --DBMS_OUTPUT.PUT_LINE('C_UVR '||P_UVR);
    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_ACT_MICROINVERSIONISTA_ACCIONES',
                                                      'INI');
    FOR P_SALDOS IN C_SALDOS LOOP
      /*DBMS_OUTPUT.PUT_LINE('C_SALDOS '||P_SALDOS.HST_CCC_CLI_PER_NUM_IDEN||' - '||
      P_SALDOS.HST_CCC_CLI_PER_TID_CODIGO||' - '||
      P_SALDOS.TOTAL);*/
      IF P_SALDOS.TOTAL < P_UVR THEN
        --DBMS_OUTPUT.PUT_LINE('SALDO MENOR AL DEL UVR');
        UPDATE CLIENTES
           SET CLI_SEG_MICRO = 'S'
         WHERE CLI_PER_NUM_IDEN = P_SALDOS.HST_CCC_CLI_PER_NUM_IDEN
           AND CLI_PER_TID_CODIGO = P_SALDOS.HST_CCC_CLI_PER_TID_CODIGO;
      ELSE
        --DBMS_OUTPUT.PUT_LINE('SALDO MAYOR O IGUAL AL DEL UVR');
        UPDATE CLIENTES
           SET CLI_SEG_MICRO = 'N'
         WHERE CLI_PER_NUM_IDEN = P_SALDOS.HST_CCC_CLI_PER_NUM_IDEN
           AND CLI_PER_TID_CODIGO = P_SALDOS.HST_CCC_CLI_PER_TID_CODIGO;
      END IF;
    END LOOP;
    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_ACT_MICROINVERSIONISTA_ACCIONES',
                                                      'FIN');
    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_ACT_MICROINVERSIONISTA_FICS',
                                                      'INI');
    UPDATE CLIENTES
       SET CLI_SEG_MICRO = 'N'
     WHERE CLI_SEG_MICRO = 'S'
       AND EXISTS
     (SELECT 'X'
              FROM CUENTAS_FONDOS CF, FONDOS F
             WHERE CF.CFO_CCC_CLI_PER_NUM_IDEN = CLI_PER_NUM_IDEN
               AND CF.CFO_CCC_CLI_PER_TID_CODIGO = CLI_PER_TID_CODIGO
               AND CF.CFO_FON_CODIGO = F.FON_CODIGO
               AND CFO_SALDO_INVER > 0
               AND FON_TIPO_ADMINISTRACION = 'F'
               AND FON_ESTADO = 'A');
    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_ACT_MICROINVERSIONISTA_FICS',
                                                      'FIN');
    COMMIT;

  END PR_ACT_MICROINVERSIONISTA;

  PROCEDURE PR_ACT_ORDENES_RBDDNH IS
    --DECLARE
    CURSOR C_ORDENES IS
      SELECT OFO_CONSECUTIVO,
             OFO_SUC_CODIGO,
             OFO_CFO_CCC_CLI_PER_NUM_IDEN,
             OFO_CFO_CCC_CLI_PER_TID_CODIGO,
             OFO_CFO_CCC_NUMERO_CUENTA,
             OFO_CFO_FON_CODIGO,
             OFO_CFO_CODIGO,
             OFO_EOF_CODIGO,
             OFO_FECHA_EJECUCION
        FROM ORDENES_FONDOS
       WHERE OFO_MEDIO_RECEPCION = 'PSE'
         AND OFO_EOF_CODIGO = 'CON'
         AND OFO_FECHA_MODIFICACION >= TRUNC(SYSDATE)
         AND OFO_FECHA_MODIFICACION < TRUNC(SYSDATE) + 1;
    P_ORDENES C_ORDENES%ROWTYPE;

    P_HABIL       VARCHAR2(1);
    P_FECHA_HABIL DATE;

    P_CONSECUTIVOS_ORDEN VARCHAR2(1000);
    DESTINO              VARCHAR2(500) := 'crcastillo@corredores.com;aangel@corredores.com;';

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;
  BEGIN
    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_ACT_ORDENES_RBDDNH',
                                                      'INI');
    P_HABIL   := P_TOOLS.FN_ES_DIA_HABIL(TRUNC(SYSDATE));
    --P_HABIL := P_TOOLS.FN_ES_DIA_HABIL('30-JUL-2022');
    DBMS_OUTPUT.PUT_LINE('P_HABIL ' || P_HABIL);
    IF P_HABIL = 'N' THEN
      P_CONSECUTIVOS_ORDEN := '';
      FOR P_ORDENES IN C_ORDENES LOOP
        DBMS_OUTPUT.PUT_LINE('P_ORDENES ' || P_ORDENES.OFO_CONSECUTIVO || ';' ||
                             P_ORDENES.OFO_SUC_CODIGO || ';' ||
                             P_ORDENES.OFO_CFO_CCC_CLI_PER_NUM_IDEN || ';' ||
                             P_ORDENES.OFO_CFO_CCC_CLI_PER_TID_CODIGO || ';' ||
                             P_ORDENES.OFO_CFO_CCC_NUMERO_CUENTA || ';' ||
                             P_ORDENES.OFO_CFO_FON_CODIGO || ';' ||
                             P_ORDENES.OFO_CFO_CODIGO || ';' ||
                             P_ORDENES.OFO_EOF_CODIGO || ';' ||
                             P_ORDENES.OFO_FECHA_EJECUCION);
        P_FECHA_HABIL := P_TOOLS.DIA_HABIL_SIGUIENTE(P_ORDENES.OFO_FECHA_EJECUCION);
        DBMS_OUTPUT.PUT_LINE('P_FECHA_HABIL ' || P_FECHA_HABIL);
        UPDATE ORDENES_FONDOS
           SET OFO_EOF_CODIGO = 'APL', OFO_FECHA_EJECUCION = P_FECHA_HABIL
         WHERE OFO_CONSECUTIVO = P_ORDENES.OFO_CONSECUTIVO
           AND OFO_SUC_CODIGO = P_ORDENES.OFO_SUC_CODIGO
           AND OFO_CFO_CCC_CLI_PER_NUM_IDEN =
               P_ORDENES.OFO_CFO_CCC_CLI_PER_NUM_IDEN
           AND OFO_CFO_CCC_CLI_PER_TID_CODIGO =
               P_ORDENES.OFO_CFO_CCC_CLI_PER_TID_CODIGO
           AND OFO_CFO_CCC_NUMERO_CUENTA =
               P_ORDENES.OFO_CFO_CCC_NUMERO_CUENTA
           AND OFO_CFO_FON_CODIGO = P_ORDENES.OFO_CFO_FON_CODIGO
           AND OFO_CFO_CODIGO = P_ORDENES.OFO_CFO_CODIGO;

        P_CONSECUTIVOS_ORDEN := P_CONSECUTIVOS_ORDEN ||
                                P_ORDENES.OFO_CONSECUTIVO || ',';
      END LOOP;
      COMMIT;
      P_MAIL.envio_mail_error('ACTUALIZACION RECAUDO ORDENES NO HABILES',
                              'Se realizo la actualizacion de las siguientes ordenes en dia no habil ' ||
                              P_CONSECUTIVOS_ORDEN,
                              DESTINO);
    END IF;
    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_ACT_ORDENES_RBDDNH',
                                                      'FIN');

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.envio_mail_error('Error actualizacion ordenes Recaudos dias no habiles',
                              'Se presento error en la actualizacion de recaudos en dias no habiles ' ||
                              SQLERRM,
                              DESTINO);

  END PR_ACT_ORDENES_RBDDNH;

  --CSVELASQUEZ PLANO INETGRADO 8

  PROCEDURE P_EJECUTA_FIRECA IS

    FECHA      DATE := TRUNC(SYSDATE);
    RANGO      NUMBER := 0;
    RANGO_MAX  NUMBER := NULL;
    RANGO1     NUMBER := 0;
    RANGO_MAX1 NUMBER := NULL;

    CURSOR C_CARTERA IS
      SELECT SUC.SUC_CODIGO SUC_CODIGO,
             SUC.SUC_NOMBRE SUC_NOMBRE,
             PER.PER_INICIALES_USUARIO PER_PER_INICIALES_USUARIO,
             FCL.PER_NOMBRE PER_NOMBRE,
             GL.CCC_NOMBRE_CUENTA CCC_NOMBRE_CUENTA,
             GL.MCC_SALDO_CAPITAL CCC_SALDO_CAPITAL,
             GL.MCC_SALDO_A_CONTADO CCC_SALDO_A_CONTADO,
             GL.MCC_SALDO_A_PLAZO CCC_SALDO_A_PLAZO,
             GL.MCC_SALDO_ADMON_VALORES CCC_SALDO_ADMON_VALORES,
             GL.MDD_SALDO MDD_SALDO,
             GL.MCM_SALDO_MONETIZAR MCM_SALDO_MONETIZAR,
             GL.SALDO_DOLARES SALDO_DOLARES,
             GL.SALDO_REMESAS SALDO_REMESAS,
             GL.SALDO_GARANTIAS SALDO_GARANTIA,
             GL.FECHA_ULT_MOV_CAPITAL,
             GL.FECHA_ULT_MOV_CONTADO,
             GL.FECHA_ULT_MOV_PLAZO,
             GL.FECHA_ULT_MOV_ADVAL,
             GL.FECHA_ULT_MOV_CANJE,
             GL.FECHA_ULT_MOV_CC,
             GL.FECHA_ULT_MOV_CANJE_CC,
             GL.FECHA_ULT_MOV_BURSATIL,
             GL.FECHA_ULT_MOV_DERIVADOS,
             GL.FECHA_ULT_MOV_MONETIZAR,
             GL.FECHA_ULT_MOV_DOLARES,
             GL.FECHA_ULT_MOV_REMESAS,
             GL.FECHA_ULT_MOV_GARANTIAS,
             GL.CCC_CLI_PER_NUM_IDEN,
             GL.CCC_CLI_PER_TID_CODIGO,
             GL.CCC_NUMERO_CUENTA,
             GL.NUM_CUENTA,
             NVL(GL.MCC_SALDO_CC, 0) CCC_SALDO_CC,
             NVL(GL.MCC_SALDO_BURSATIL, 0) CCC_SALDO_BURSATIL,
             NVL(GL.MCC_SALDO_CANJE, 0) CCC_SALDO_CANJE,
             NVL(GL.MCC_SALDO_CANJE_CC, 0) CCC_SALDO_CANJE_CC
        FROM FILTRO_CLIENTES       FCL,
             SUCURSALES            SUC,
             FILTRO_COMERCIALES    PER,
             GL_MOVIMIENTOS_CUENTA GL
       WHERE FCL.CLI_PER_NUM_IDEN = GL.CCC_CLI_PER_NUM_IDEN
         AND FCL.CLI_PER_TID_CODIGO = GL.CCC_CLI_PER_TID_CODIGO
         AND SUC.SUC_CODIGO = PER.PER_SUC_CODIGO
         AND SUC.SUC_ESTADO = 'A'
         AND PER.PER_NUM_IDEN = GL.CCC_PER_NUM_IDEN
         AND PER.PER_TID_CODIGO = GL.CCC_PER_TID_CODIGO
         AND PER.PER_NUM_IDEN != '9999999999';

    R_CARTERA C_CARTERA%ROWTYPE;
    X_TEM     VARCHAR2(32767) := ' ';
    --ARCH        TEXT_IO.FILE_TYPE;
    BUFLINE             VARCHAR2(2000);
    v_nombre_archivo    VARCHAR2(100);
    nHash               NUMBER;
    N_CLI_PERFIL_RIESGO NUMBER;
    V_CLI_BSC_MNEMONICO VARCHAR2(100);
    P_PERFIL            VARCHAR2(150);
    P_SEGMENTO          VARCHAR2(150);

    P_CODIGO    VARCHAR2(200);
    P_RESPUESTA VARCHAR2(200);
    V_RUTA      VARCHAR2(100);
    -- V_NOMBRE_ARCHIVO     VARCHAR2(100);
    FUNCTION F_DIAS_MOV(FECHA_CORTE   IN DATE,
                        FECHA_ULT_MOV IN DATE,
                        SALDO         IN NUMBER) RETURN NUMBER IS
    BEGIN
      IF NVL(SALDO, 0) = 0 THEN
        RETURN NULL;
      ELSE
        RETURN(TRUNC(FECHA_CORTE) - TRUNC(FECHA_ULT_MOV));
      END IF;
    END;
    FUNCTION F_FECHA_MOV(FECHA IN DATE, SALDO IN NUMBER) RETURN DATE IS
    BEGIN
      IF NVL(SALDO, 0) = 0 THEN
        RETURN NULL;
      ELSE
        RETURN FECHA;
      END IF;
    END;
    FUNCTION F_SQL_HOY(FECHA      IN DATE,
                       RANGO      IN NUMBER,
                       RANGO_MAX  IN NUMBER,
                       RANGO1     IN NUMBER,
                       RANGO_MAX1 IN NUMBER) RETURN VARCHAR2 IS
      X_TEM                 VARCHAR2(32767) := ' ';
      P_CONDICION           VARCHAR2(1000) := ' ';
      P_CONDICION_RANGOS    VARCHAR2(500) := ' ';
      P_CONDICION_COMERCIAL VARCHAR2(100) := ' ';
      P_CONDICION_SUCURSAL  VARCHAR2(100) := ' ';
    BEGIN

      IF NVL(RANGO_MAX, 0) = 0 THEN
        P_CONDICION := ' SUM(SDI_SALDO_CAPITAL) >' || RANGO || ' OR ' ||
                       ' SUM(SDI_SALDO_A_PLAZO) > ' || RANGO || ' OR ' ||
                       ' SUM(SDI_SALDO_ADMON_VALORES) > ' || RANGO || 'OR ' ||
                       ' SUM(SDI_SALDO_CC) > ' || RANGO || 'OR ' ||
                       ' SUM(SDI_SALDO_BURSATIL) > ' || RANGO || 'OR ' ||
                       ' SUM(SDI_SALDO_A_CONTADO) > ' || RANGO || ' OR ' ||
                       ' SUM(SDD_MDD_SALDO) >' || RANGO || ' OR ' ||
                       ' SUM(SDV_SALDO) >' || RANGO || ' OR ' ||
                       ' SUM(MCD_SALDO) >' || RANGO || ' OR ' ||
                       ' SUM(SALDO_GARANTIAS) >' || RANGO || ' OR ';
      ELSE
        P_CONDICION := ' (SUM(SDI_SALDO_CAPITAL) > ' || RANGO || ' AND ' ||
                       '   SUM(SDI_SALDO_CAPITAL) <= ' || RANGO_MAX ||
                       ') OR ' || '  (SUM(SDI_SALDO_A_PLAZO) > ' || RANGO ||
                       ' AND ' || '   SUM(SDI_SALDO_A_PLAZO) <= ' ||
                       RANGO_MAX || ') OR ' ||
                       '  (SUM(SDI_SALDO_ADMON_VALORES) > ' || RANGO ||
                       ' AND ' || '   SUM(SDI_SALDO_ADMON_VALORES) <= ' ||
                       RANGO_MAX || ') OR ' || '  (SUM(SDI_SALDO_CC) > ' ||
                       RANGO || ' AND ' || '   SUM(SDI_SALDO_CC) <= ' ||
                       RANGO_MAX || ') OR ' ||
                       '  (SUM(SDI_SALDO_BURSATIL) > ' || RANGO || ' AND ' ||
                       '   SUM(SDI_SALDO_BURSATIL) <= ' || RANGO_MAX ||
                       ') OR ' || '  (SUM(SDI_SALDO_A_CONTADO) > ' || RANGO ||
                       ' AND ' || '   SUM(SDI_SALDO_A_CONTADO) <= ' ||
                       RANGO_MAX || ') OR ' || '  (SUM(SDD_MDD_SALDO) > ' ||
                       RANGO || ' AND ' || '   SUM(SDD_MDD_SALDO) <= ' ||
                       RANGO_MAX || ') OR ' || '  (SUM(SDV_SALDO) > ' ||
                       RANGO || ' AND ' || '   SUM(SDV_SALDO) <= ' ||
                       RANGO_MAX || ') OR ' || '  (SUM(MCD_SALDO) > ' ||
                       RANGO || ' AND ' || '   SUM(MCD_SALDO) <= ' ||
                       RANGO_MAX || ') OR ' || '  (SUM(SALDO_GARANTIAS) > ' ||
                       RANGO || ' AND ' || '   SUM(SALDO_GARANTIAS) <= ' ||
                       RANGO_MAX || ') OR ';
      END IF;

      IF NVL(RANGO_MAX1, 0) = 0 THEN
        P_CONDICION := P_CONDICION || ' SUM(SDI_SALDO_CAPITAL) < ' ||
                       -RANGO1 || ' OR ' || ' SUM(SDI_SALDO_A_PLAZO) <' ||
                       -RANGO1 || ' OR ' ||
                       ' SUM(SDI_SALDO_ADMON_VALORES) <' || -RANGO1 ||
                       ' OR ' || ' SUM(SDI_SALDO_CC) <' || -RANGO1 ||
                       ' OR ' || ' SUM(SDI_SALDO_BURSATIL) <' || -RANGO1 ||
                       ' OR ' || ' SUM(SDI_SALDO_A_CONTADO) < ' || -RANGO1 ||
                       ' OR ' || ' SUM(SDD_MDD_SALDO) < ' || -RANGO1 ||
                       ' OR ' || ' SUM(SDV_SALDO) < ' || -RANGO1 || ' OR ' ||
                       ' SUM(MCD_SALDO) < ' || -RANGO1 || ' OR ' ||
                       ' SUM(SALDO_GARANTIAS) < ' || -RANGO1;
      ELSE
        P_CONDICION := P_CONDICION || ' (SUM(SDI_SALDO_CAPITAL) < ' ||
                       -RANGO1 || ' AND ' || '  SUM(SDI_SALDO_CAPITAL) >=' ||
                       -RANGO_MAX1 || ') OR ' ||
                       ' (SUM(SDI_SALDO_A_PLAZO) < ' || -RANGO1 || ' AND ' ||
                       '  SUM(SDI_SALDO_A_PLAZO) >=' || -RANGO_MAX1 ||
                       ') OR ' || ' (SUM(SDI_SALDO_ADMON_VALORES) <' ||
                       -RANGO1 || ' AND ' ||
                       '  SUM(SDI_SALDO_ADMON_VALORES) >=' || -RANGO_MAX1 ||
                       ') OR ' || ' (SUM(SDI_SALDO_CC) <' || -RANGO1 ||
                       ' AND ' || '  SUM(SDI_SALDO_CC) >=' || -RANGO_MAX1 ||
                       ') OR ' || ' (SUM(SDI_SALDO_BURSATIL) <' || -RANGO1 ||
                       ' AND ' || '  SUM(SDI_SALDO_BURSATIL) >=' ||
                       -RANGO_MAX1 || ') OR ' ||
                       ' (SUM(SDI_SALDO_A_CONTADO) <' || -RANGO1 || ' AND ' ||
                       '  SUM(SDI_SALDO_A_CONTADO) >=' || -RANGO_MAX1 ||
                       ') OR ' || ' (SUM(SDD_MDD_SALDO) <' || -RANGO1 ||
                       ' AND ' || '  SUM(SDD_MDD_SALDO) >=' || -RANGO_MAX1 ||
                       ') OR ' || ' (SUM(SDV_SALDO) <' || -RANGO1 ||
                       ' AND ' || '  SUM(SDV_SALDO) >=' || -RANGO_MAX1 ||
                       ') OR ' || ' (SUM(MCD_SALDO) <' || -RANGO1 ||
                       ' AND ' || '  SUM(MCD_SALDO) >=' || -RANGO_MAX1 ||
                       ') OR ' || ' (SUM(SALDO_GARANTIAS) < ' || -RANGO1 ||
                       ' AND ' || '  SUM(SALDO_GARANTIAS) >=' ||
                       -RANGO_MAX1 || ') ';
      END IF;

      -- LLENADO DE TABLA GL_MOVIMIENTOS_CUENTA
      X_TEM := 'INSERT INTO GL_MOVIMIENTOS_CUENTA ' || '(MCC_FECHA ' ||
               ',CCC_NOMBRE_CUENTA ' || ',MCC_SALDO_CAPITAL ' ||
               ',MCC_SALDO_A_CONTADO ' || ',MCC_SALDO_A_PLAZO ' ||
               ',MCC_SALDO_ADMON_VALORES ' || ',MCC_SALDO_CC ' ||
               ',MCC_SALDO_BURSATIL ' || ',MCC_SALDO_CANJE ' ||
               ',MCC_SALDO_CANJE_CC ' || ',MDD_SALDO ' ||
               ',MCM_SALDO_MONETIZAR ' || ',SALDO_DOLARES ' ||
               ',SALDO_REMESAS ' || ',SALDO_GARANTIAS ' ||
               ',CCC_CLI_PER_NUM_IDEN ' || ',CCC_CLI_PER_TID_CODIGO ' ||
               ',CCC_NUMERO_CUENTA ' || ',CCC_PER_NUM_IDEN ' ||
               ',CCC_PER_TID_CODIGO ) ' || 'SELECT SYSDATE, ' || ''' '', ' ||
               'SUM(SDI_SALDO_CAPITAL), ' || 'SUM(SDI_SALDO_A_CONTADO), ' ||
               'SUM(SDI_SALDO_A_PLAZO), ' ||
               'SUM(SDI_SALDO_ADMON_VALORES), ' || 'SUM(SDI_SALDO_CC), ' ||
               'SUM(SDI_SALDO_BURSATIL), ' || 'SUM(SDI_SALDO_CANJE), ' ||
               'SUM(SDI_SALDO_CANJE_CC), ' || 'SUM(SDD_MDD_SALDO), ' ||
               'SUM(SDV_SALDO), ' || 'SUM(MCD_SALDO), ' ||
               'SUM(SALDO_REMESAS), ' || 'SUM(SALDO_GARANTIAS), ' ||
               'CCC_CLI_PER_NUM_IDEN, ' || 'CCC_CLI_PER_TID_CODIGO, ' ||
               'CCC_NUMERO_CUENTA, ' || 'CCC_PER_NUM_IDEN, ' ||
               'CCC_PER_TID_CODIGO ' ||
               'FROM (SELECT CCC_SALDO_CAPITAL SDI_SALDO_CAPITAL, ' ||
               'CCC_SALDO_A_CONTADO SDI_SALDO_A_CONTADO, ' ||
               'CCC_SALDO_A_PLAZO SDI_SALDO_A_PLAZO, ' ||
               'CCC_SALDO_ADMON_VALORES SDI_SALDO_ADMON_VALORES, ' ||
               'CCC_SALDO_CC SDI_SALDO_CC, ' ||
               'CCC_SALDO_BURSATIL SDI_SALDO_BURSATIL, ' ||
               'CCC_SALDO_CANJE SDI_SALDO_CANJE, ' ||
               'CCC_SALDO_CANJE_CC SDI_SALDO_CANJE_CC, ' ||
               '0 SDD_MDD_SALDO, ' || '0 SDV_SALDO, ' || '0 MCD_SALDO, ' ||
               '0 SALDO_REMESAS, ' || '0 SALDO_GARANTIAS, ' ||
               'CCC.CCC_CLI_PER_NUM_IDEN, ' ||
               'CCC.CCC_CLI_PER_TID_CODIGO, ' || 'CCC.CCC_NUMERO_CUENTA, ' ||
               'CCC.CCC_PER_NUM_IDEN, ' || 'CCC.CCC_PER_TID_CODIGO ' ||
               ' FROM CUENTAS_CLIENTE_CORREDORES CCC ' || ' UNION ALL ' ||
               ' SELECT 0 SDI_SALDO_CAPITAL,  ' ||
               '0 SDI_SALDO_A_CONTADO, ' || '0 SDI_SALDO_A_PLAZO, ' ||
               '0 SDI_SALDO_ADMON_VALORES, ' || '0 SDI_SALDO_CC, ' ||
               '0 SDI_SALDO_BURSATIL, ' || '0 SDI_SALDO_CANJE, ' ||
               '0 SDI_SALDO_CANJE_CC, ' || 'CDD_SALDO SDD_MDD_SALDO, ' ||
               '0 SDV_SALDO, ' || '0 MCD_SALDO, ' || '0 SALDO_REMESAS, ' ||
               '0 SALDO_GARANTIAS, ' || 'CCC.CCC_CLI_PER_NUM_IDEN, ' ||
               'CCC.CCC_CLI_PER_TID_CODIGO, ' || 'CCC.CCC_NUMERO_CUENTA, ' ||
               'CCC.CCC_PER_NUM_IDEN, ' || 'CCC.CCC_PER_TID_CODIGO ' ||
               ' FROM CUENTAS_CLIENTES_DERIVADOS CDD, ' ||
               ' CUENTAS_CLIENTE_CORREDORES CCC ' ||
               'WHERE CCC.CCC_CLI_PER_NUM_IDEN = CDD.CDD_CCC_CLI_PER_NUM_IDEN ' ||
               'AND   CCC.CCC_CLI_PER_TID_CODIGO = CDD.CDD_CCC_CLI_PER_TID_CODIGO ' ||
               'AND   CCC.CCC_NUMERO_CUENTA = CDD.CDD_CCC_NUMERO_CUENTA  ' ||
               ' UNION ALL ' || ' SELECT 0 SDI_SALDO_CAPITAL,  ' ||
               '0 SDI_SALDO_A_CONTADO, ' || '0 SDI_SALDO_A_PLAZO, ' ||
               '0 SDI_SALDO_ADMON_VALORES, ' || '0 SDI_SALDO_CC, ' ||
               '0 SDI_SALDO_BURSATIL, ' || '0 SDI_SALDO_CANJE, ' ||
               '0 SDI_SALDO_CANJE_CC, ' || '0 SDD_MDD_SALDO, ' ||
               'SCM_SALDO_MONETIZAR SDV_SALDO, ' || '0 MCD_SALDO, ' ||
               '0 SALDO_REMESAS, ' || '0 SALDO_GARANTIAS, ' ||
               'CCC.CCC_CLI_PER_NUM_IDEN, ' ||
               'CCC.CCC_CLI_PER_TID_CODIGO, ' || 'CCC.CCC_NUMERO_CUENTA, ' ||
               'CCC.CCC_PER_NUM_IDEN, ' || 'CCC.CCC_PER_TID_CODIGO ' ||
               ' FROM SALDOS_CLIENTES_MONETIZAR SCM, ' ||
               'CUENTAS_CLIENTE_CORREDORES CCC ' ||
               'WHERE CCC.CCC_CLI_PER_NUM_IDEN = SCM.SCM_CCC_CLI_PER_NUM_IDEN ' ||
               'AND   CCC.CCC_CLI_PER_TID_CODIGO = SCM.SCM_CCC_CLI_PER_TID_CODIGO ' ||
               'AND   CCC.CCC_NUMERO_CUENTA = SCM.SCM_CCC_NUMERO_CUENTA ' ||
               ' UNION ALL ' || ' SELECT 0 SDI_SALDO_CAPITAL,  ' ||
               '0 SDI_SALDO_A_CONTADO, ' || '0 SDI_SALDO_A_PLAZO, ' ||
               '0 SDI_SALDO_ADMON_VALORES, ' || '0 SDI_SALDO_CC, ' ||
               '0 SDI_SALDO_BURSATIL, ' || '0 SDI_SALDO_CANJE, ' ||
               '0 SDI_SALDO_CANJE_CC, ' || '0 SDD_MDD_SALDO, ' ||
               '0 SDV_SALDO, ' ||
               'CCOM_SALDO * CBM_VALOR * PMO_TASA_CONVERSION MCD_SALDO, ' ||
               '0 SALDO_REMESAS, ' || '0 SALDO_GARANTIAS, ' ||
               'CCC.CCC_CLI_PER_NUM_IDEN, ' ||
               'CCC.CCC_CLI_PER_TID_CODIGO, ' || 'CCC.CCC_NUMERO_CUENTA, ' ||
               'CCC.CCC_PER_NUM_IDEN, ' || 'CCC.CCC_PER_TID_CODIGO ' ||
               ' FROM CUENTAS_CLIENTES_OTRAS_MONEDAS, ' ||
               'POSICIONES_MONEDAS, ' || 'COTIZACIONES_BASE_MONETARIAS, ' ||
               'CUENTAS_CLIENTE_CORREDORES CCC ' ||
               'WHERE CCOM_BMO_MNEMONICO = PMO_BMO_MNEMONICO ' ||
               'AND PMO_FECHA = (SELECT MAX(PMO_FECHA) ' ||
               'FROM POSICIONES_MONEDAS ' ||
               'WHERE PMO_BMO_MNEMONICO = CCOM_BMO_MNEMONICO) ' ||
               'AND CBM_BMO_MNEMONICO = ''DOLAR'' ' ||
               'AND CBM_FECHA = (SELECT MAX(CBM_FECHA) ' ||
               'FROM COTIZACIONES_BASE_MONETARIAS ' ||
               'WHERE CBM_BMO_MNEMONICO = ''DOLAR'') ' ||
               'AND CCOM_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN ' ||
               'AND CCOM_CCC_CLI_PER_TID_CODIGO = CCC.CCC_CLI_PER_TID_CODIGO ' ||
               'AND CCOM_CCC_NUMERO_CUENTA   = CCC.CCC_NUMERO_CUENTA ' ||
               ' UNION ALL ' || ' SELECT 0 SDI_SALDO_CAPITAL,  ' ||
               '0 SDI_SALDO_A_CONTADO, ' || '0 SDI_SALDO_A_PLAZO, ' ||
               '0 SDI_SALDO_ADMON_VALORES, ' || '0 SDI_SALDO_CC, ' ||
               '0 SDI_SALDO_BURSATIL, ' || '0 SDI_SALDO_CANJE, ' ||
               '0 SDI_SALDO_CANJE_CC, ' || '0 SDD_MDD_SALDO, ' ||
               '0 SDV_SALDO, ' ||
               '(CDV_SALDO_RESTRINGIDO + CDV_SALDO) * CBM_VALOR MCD_SALDO, ' ||
               '0 SALDO_REMESAS, ' || '0 SALDO_GARANTIAS, ' ||
               'CCC.CCC_CLI_PER_NUM_IDEN, ' ||
               'CCC.CCC_CLI_PER_TID_CODIGO, ' || 'CCC.CCC_NUMERO_CUENTA, ' ||
               'CCC.CCC_PER_NUM_IDEN, ' || 'CCC.CCC_PER_TID_CODIGO ' ||
               ' FROM CUENTAS_CLIENTES_DIVISAS CDV, ' ||
               'COTIZACIONES_BASE_MONETARIAS CBM, ' ||
               'CUENTAS_CLIENTE_CORREDORES CCC ' ||
               'WHERE CDV_BMO_MNEMONICO = CBM_BMO_MNEMONICO ' ||
               'AND CBM_FECHA = (SELECT MAX(CBM_FECHA) ' ||
               'FROM COTIZACIONES_BASE_MONETARIAS ' ||
               'WHERE CBM_BMO_MNEMONICO = ''DOLAR'') ' ||
               'AND CDV.CDV_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN ' ||
               'AND CDV.CDV_CCC_CLI_PER_TID_CODIGO = CCC.CCC_CLI_PER_TID_CODIGO ' ||
               'AND CDV.CDV_CCC_NUMERO_CUENTA      = CCC.CCC_NUMERO_CUENTA ' ||
               'UNION ALL ' || 'SELECT 0 SDI_SALDO_CAPITAL, ' ||
               '0 SDI_SALDO_A_CONTADO, ' || '0 SDI_SALDO_A_PLAZO, ' ||
               '0 SDI_SALDO_ADMON_VALORES, ' || '0 SDI_SALDO_CC, ' ||
               '0 SDI_SALDO_BURSATIL, ' || '0 SDI_SALDO_CANJE, ' ||
               '0 SDI_SALDO_CANJE_CC, ' || '0 SDD_MDD_SALDO, ' ||
               '0 SDV_SALDO, ' || '0 MCD_SALDO, ' ||
               'NVL(RMS.RECL_CCA_MONTO,0) SALDO_REMESAS, ' ||
               '0 SALDO_GARANTIAS, ' || 'CCC.CCC_CLI_PER_NUM_IDEN, ' ||
               'CCC.CCC_CLI_PER_TID_CODIGO, ' || 'CCC.CCC_NUMERO_CUENTA, ' ||
               'CCC.CCC_PER_NUM_IDEN, ' || 'CCC.CCC_PER_TID_CODIGO ' ||
               '  FROM VW_REMESAS_POR_LEGALIZAR RMS, ' ||
               '  CUENTAS_CLIENTE_CORREDORES CCC ' ||
               '  WHERE RMS.RECL_RCA_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN ' ||
               '  AND RMS.RECL_RCA_CCC_CLI_PER_TID_COD    = CCC.CCC_CLI_PER_TID_CODIGO ' ||
               '  AND RMS.RECL_RCA_CCC_NUMERO_CUENTA      = CCC.CCC_NUMERO_CUENTA ' ||
               ' UNION ALL ' || ' SELECT 0 SDI_SALDO_CAPITAL,  ' ||
               '0 SDI_SALDO_A_CONTADO, ' || '0 SDI_SALDO_A_PLAZO, ' ||
               '0 SDI_SALDO_ADMON_VALORES, ' || '0 SDI_SALDO_CC, ' ||
               '0 SDI_SALDO_BURSATIL, ' || '0 SDI_SALDO_CANJE, ' ||
               '0 SDI_SALDO_CANJE_CC, ' || '0 SDD_MDD_SALDO, ' ||
               '0 SDV_SALDO, ' || '0 MCD_SALDO, ' || '0 SALDO_REMESAS, ' ||
               'SUM(VALOR_ODP) - SUM(VALOR_RCA) SALDO_GARANTIAS, ' ||
               'CCC.CCC_CLI_PER_NUM_IDEN, ' ||
               'CCC.CCC_CLI_PER_TID_CODIGO, ' || 'CCC.CCC_NUMERO_CUENTA, ' ||
               'CCC.CCC_PER_NUM_IDEN, ' || 'CCC.CCC_PER_TID_CODIGO ' ||
               'FROM (SELECT  RCA_FECHA FECHA, ' ||
               'NVL(CCA_MONTO,0) VALOR_RCA, ' || '0 VALOR_ODP, ' ||
               'RCA_CCC_CLI_PER_NUM_IDEN CLI_PER_NUM_IDEN, ' ||
               'RCA_CCC_CLI_PER_TID_CODIGO CLI_PER_TID_CODIGO, ' ||
               'RCA_CCC_NUMERO_CUENTA CCC_NUMERO_CUENTA ' ||
               'FROM   RECIBOS_DE_CAJA, ' || 'CHEQUES_CAJA ' ||
               'WHERE  RCA_SUC_CODIGO= CCA_RCA_SUC_CODIGO  ' ||
               'AND    RCA_NEG_CONSECUTIVO = CCA_RCA_NEG_CONSECUTIVO  ' ||
               'AND    RCA_CONSECUTIVO = CCA_RCA_CONSECUTIVO ' ||
               'AND    RCA_ES_CLIENTE = ''S'' ' ||
               'AND    RCA_REVERSADO = ''N'' ' ||
               'AND    RCA_COT_MNEMONICO = ''RGCE'' ' ||
               'AND    RCA_FECHA > ''01-AGO-2006'' ' ||
               'AND    RCA_FECHA < ' || CHR(39) ||
               TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               'AND    CCA_MONTO != 0 ' || 'UNION ALL ' ||
               'SELECT RCA_FECHA FECHA, ' || 'NVL(CCJ_MONTO,0) VALOR_RCA, ' ||
               '0 VALOR_ODP, ' ||
               'RCA_CCC_CLI_PER_NUM_IDEN CLI_PER_NUM_IDEN, ' ||
               'RCA_CCC_CLI_PER_TID_CODIGO CLI_PER_TID_CODIGO, ' ||
               'RCA_CCC_NUMERO_CUENTA CCC_NUMERO_CUENTA ' ||
               'FROM   RECIBOS_DE_CAJA, ' || 'CONSIGNACIONES_CAJA ' ||
               'WHERE  RCA_SUC_CODIGO= CCJ_RCA_SUC_CODIGO ' ||
               'AND    RCA_NEG_CONSECUTIVO = CCJ_RCA_NEG_CONSECUTIVO ' ||
               'AND    RCA_CONSECUTIVO = CCJ_RCA_CONSECUTIVO ' ||
               'AND    RCA_ES_CLIENTE = ''S'' ' ||
               'AND    RCA_REVERSADO = ''N'' ' ||
               'AND    RCA_COT_MNEMONICO = ''RGCE'' ' ||
               'AND    RCA_FECHA >  ''01-AGO-2006'' ' ||
               'AND    RCA_FECHA < ' || CHR(39) ||
               TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               'AND    CCJ_MONTO != 0 ' || 'UNION ALL ' ||
               'SELECT RCA_FECHA FECHA, ' || 'NVL(TRC_MONTO,0) VALOR_RCA, ' ||
               '0 VALOR_ODP, ' ||
               'RCA_CCC_CLI_PER_NUM_IDEN CLI_PER_NUM_IDEN, ' ||
               'RCA_CCC_CLI_PER_TID_CODIGO CLI_PER_TID_CODIGO, ' ||
               'RCA_CCC_NUMERO_CUENTA CCC_NUMERO_CUENTA ' ||
               'FROM   RECIBOS_DE_CAJA, ' || 'TRANSFERENCIAS_CAJA ' ||
               'WHERE  RCA_SUC_CODIGO= TRC_RCA_SUC_CODIGO ' ||
               'AND    RCA_NEG_CONSECUTIVO = TRC_RCA_NEG_CONSECUTIVO ' ||
               'AND    RCA_CONSECUTIVO = TRC_RCA_CONSECUTIVO ' ||
               'AND    RCA_ES_CLIENTE = ''S'' ' ||
               'AND    RCA_REVERSADO = ''N'' ' ||
               'AND    RCA_COT_MNEMONICO = ''RGCE'' ' ||
               'AND    RCA_FECHA >  ''01-AGO-2006'' ' ||
               'AND    RCA_FECHA < ' || CHR(39) ||
               TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               'AND    TRC_MONTO != 0 ' || 'UNION ALL ' ||
               'SELECT RCA_FECHA FECHA, ' ||
               'NVL(RCA_MONTO_EN_EFECTIVO,0) VALOR_RCA, ' ||
               '0 VALOR_ODP, ' ||
               'RCA_CCC_CLI_PER_NUM_IDEN CLI_PER_NUM_IDEN, ' ||
               'RCA_CCC_CLI_PER_TID_CODIGO CLI_PER_TID_CODIGO, ' ||
               'RCA_CCC_NUMERO_CUENTA CCC_NUMERO_CUENTA ' ||
               'FROM   RECIBOS_DE_CAJA ' ||
               'WHERE  RCA_ES_CLIENTE = ''S'' ' ||
               'AND    RCA_REVERSADO = ''N'' ' ||
               'AND    RCA_COT_MNEMONICO = ''RGCE''  ' ||
               'AND    RCA_FECHA >  ''01-AGO-2006''  ' ||
               'AND    RCA_FECHA < ' || CHR(39) ||
               TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               'AND    RCA_MONTO_EN_EFECTIVO != 0 ' || 'UNION ALL ' ||
               'SELECT  ODP_FECHA_EJECUCION FECHA, ' || '0 VALOR_RCA, ' ||
               'NVL(ODP_MONTO_ORDEN,0) VALOR_ODP, ' ||
               'ODP_CCC_CLI_PER_NUM_IDEN  CLI_PER_NUM_IDEN, ' ||
               'ODP_CCC_CLI_PER_TID_CODIGO CLI_PER_TID_CODIGO, ' ||
               'ODP_CCC_NUMERO_CUENTA CCC_NUMERO_CUENTA ' ||
               'FROM   ORDENES_DE_PAGO ' || 'WHERE ODP_ESTADO = ''APR'' ' ||
               'AND   ODP_ES_CLIENTE = ''S'' ' ||
               'AND   ODP_COT_MNEMONICO = ''GOPCE'' ' ||
               'AND   ODP_FECHA >  ''01-AGO-2006'' ' ||
               'AND   ODP_FECHA_EJECUCION < ' || CHR(39) ||
               TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               'AND   ODP_MONTO_ORDEN != 0 ' || 'UNION ALL ' ||
               'SELECT  RCA_FECHA FECHA, ' ||
               'NVL(CCA_MONTO,0) VALOR_RCA, ' || '0 VALOR_ODP, ' ||
               'RCA_CCC_CLI_PER_NUM_IDEN CLI_PER_NUM_IDEN, ' ||
               'RCA_CCC_CLI_PER_TID_CODIGO CLI_PER_TID_CODIGO, ' ||
               'RCA_CCC_NUMERO_CUENTA CCC_NUMERO_CUENTA ' ||
               'FROM   RECIBOS_DE_CAJA, ' || 'CHEQUES_CAJA ' ||
               'WHERE  RCA_SUC_CODIGO= CCA_RCA_SUC_CODIGO  ' ||
               'AND    RCA_NEG_CONSECUTIVO = CCA_RCA_NEG_CONSECUTIVO  ' ||
               'AND    RCA_CONSECUTIVO = CCA_RCA_CONSECUTIVO ' ||
               'AND    RCA_ES_CLIENTE = ''S'' ' ||
               'AND    RCA_REVERSADO = ''N'' ' ||
               'AND    RCA_COT_MNEMONICO = ''RGCF'' ' ||
               'AND    RCA_FECHA >  ''01-AGO-2006'' ' ||
               'AND    RCA_FECHA < ' || CHR(39) ||
               TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               'AND    CCA_MONTO != 0 ' || 'UNION ALL ' ||
               'SELECT  RCA_FECHA FECHA, ' ||
               'NVL(CCJ_MONTO,0) VALOR_RCA, ' || '0 VALOR_ODP, ' ||
               'RCA_CCC_CLI_PER_NUM_IDEN CLI_PER_NUM_IDEN, ' ||
               'RCA_CCC_CLI_PER_TID_CODIGO CLI_PER_TID_CODIGO, ' ||
               'RCA_CCC_NUMERO_CUENTA CCC_NUMERO_CUENTA ' ||
               'FROM   RECIBOS_DE_CAJA, ' || 'CONSIGNACIONES_CAJA ' ||
               'WHERE  RCA_SUC_CODIGO= CCJ_RCA_SUC_CODIGO ' ||
               'AND    RCA_NEG_CONSECUTIVO = CCJ_RCA_NEG_CONSECUTIVO ' ||
               'AND    RCA_CONSECUTIVO = CCJ_RCA_CONSECUTIVO ' ||
               'AND    RCA_ES_CLIENTE = ''S'' ' ||
               'AND    RCA_REVERSADO = ''N'' ' ||
               'AND    RCA_COT_MNEMONICO = ''RGCF'' ' ||
               'AND    RCA_FECHA >  ''01-AGO-2006'' ' ||
               'AND    RCA_FECHA < ' || CHR(39) ||
               TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               'AND    CCJ_MONTO != 0 ' || 'UNION ALL ' ||
               'SELECT  RCA_FECHA FECHA, ' ||
               'NVL(TRC_MONTO,0) VALOR_RCA, ' || '0 VALOR_ODP, ' ||
               'RCA_CCC_CLI_PER_NUM_IDEN CLI_PER_NUM_IDEN, ' ||
               'RCA_CCC_CLI_PER_TID_CODIGO CLI_PER_TID_CODIGO, ' ||
               'RCA_CCC_NUMERO_CUENTA CCC_NUMERO_CUENTA ' ||
               'FROM   RECIBOS_DE_CAJA, ' || 'TRANSFERENCIAS_CAJA ' ||
               'WHERE  RCA_SUC_CODIGO= TRC_RCA_SUC_CODIGO ' ||
               'AND    RCA_NEG_CONSECUTIVO = TRC_RCA_NEG_CONSECUTIVO ' ||
               'AND    RCA_CONSECUTIVO = TRC_RCA_CONSECUTIVO ' ||
               'AND    RCA_ES_CLIENTE = ''S'' ' ||
               'AND    RCA_REVERSADO = ''N'' ' ||
               'AND    RCA_COT_MNEMONICO = ''RGCF'' ' ||
               'AND    RCA_FECHA >  ''01-AGO-2006'' ' ||
               'AND    RCA_FECHA < ' || CHR(39) ||
               TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               'AND    TRC_MONTO != 0 ' || 'UNION ALL ' ||
               'SELECT RCA_FECHA FECHA, ' ||
               'NVL(RCA_MONTO_EN_EFECTIVO,0) VALOR_RCA, ' ||
               '0 VALOR_ODP, ' ||
               'RCA_CCC_CLI_PER_NUM_IDEN  CLI_PER_NUM_IDEN, ' ||
               'RCA_CCC_CLI_PER_TID_CODIGO CLI_PER_TID_CODIGO, ' ||
               'RCA_CCC_NUMERO_CUENTA CCC_NUMERO_CUENTA ' ||
               'FROM   RECIBOS_DE_CAJA ' ||
               'WHERE  RCA_ES_CLIENTE = ''S'' ' ||
               'AND    RCA_REVERSADO = ''N'' ' ||
               'AND    RCA_COT_MNEMONICO = ''RGCF''  ' ||
               'AND    RCA_FECHA > ''01-AGO-2006'' ' ||
               'AND    RCA_FECHA < ' || CHR(39) ||
               TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               'AND    RCA_MONTO_EN_EFECTIVO != 0 ' || 'UNION ALL ' ||
               'SELECT ODP_FECHA_EJECUCION FECHA, ' || '0 VALOR_RCA, ' ||
               'NVL(ODP_MONTO_ORDEN,0) VALOR_ODP, ' ||
               'ODP_CCC_CLI_PER_NUM_IDEN  CLI_PER_NUM_IDEN, ' ||
               'ODP_CCC_CLI_PER_TID_CODIGO CLI_PER_TID_CODIGO, ' ||
               'ODP_CCC_NUMERO_CUENTA CCC_NUMERO_CUENTA ' ||
               'FROM   ORDENES_DE_PAGO ' || 'WHERE ODP_ESTADO = ''APR'' ' ||
               'AND   ODP_ES_CLIENTE = ''S'' ' ||
               'AND   ODP_COT_MNEMONICO = ''GOPCF'' ' ||
               'AND   ODP_FECHA >  ''01-AGO-2006'' ' ||
               'AND   ODP_FECHA_EJECUCION < ' || CHR(39) ||
               TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               'AND   ODP_MONTO_ORDEN != 0 ' || 'UNION ALL ' ||
               'SELECT RCA_FECHA FECHA, ' || 'NVL(CCA_MONTO,0) VALOR_RCA, ' ||
               '0 VALOR_ODP, ' ||
               'RCA_CCC_CLI_PER_NUM_IDEN CLI_PER_NUM_IDEN, ' ||
               'RCA_CCC_CLI_PER_TID_CODIGO CLI_PER_TID_CODIGO, ' ||
               'RCA_CCC_NUMERO_CUENTA  CCC_NUMERO_CUENTA ' ||
               'FROM   RECIBOS_DE_CAJA, ' || 'CHEQUES_CAJA ' ||
               'WHERE    RCA_SUC_CODIGO= CCA_RCA_SUC_CODIGO  ' ||
               'AND    RCA_NEG_CONSECUTIVO = CCA_RCA_NEG_CONSECUTIVO ' ||
               'AND    RCA_CONSECUTIVO = CCA_RCA_CONSECUTIVO ' ||
               'AND    RCA_ES_CLIENTE = ''S'' ' ||
               'AND    RCA_REVERSADO = ''N'' ' ||
               'AND    RCA_COT_MNEMONICO = ''DGDE'' ' ||
               'AND    RCA_FECHA >  ''01-AGO-2006'' ' ||
               'AND    RCA_FECHA < ' || CHR(39) ||
               TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               'AND    CCA_MONTO != 0 ' || 'UNION ALL ' ||
               'SELECT RCA_FECHA FECHA, ' || 'NVL(CCJ_MONTO,0) VALOR_RCA, ' ||
               '0 VALOR_ODP, ' ||
               'RCA_CCC_CLI_PER_NUM_IDEN CLI_PER_NUM_IDEN, ' ||
               'RCA_CCC_CLI_PER_TID_CODIGO CLI_PER_TID_CODIGO, ' ||
               'RCA_CCC_NUMERO_CUENTA CCC_NUMERO_CUENTA ' ||
               'FROM   RECIBOS_DE_CAJA, ' || 'CONSIGNACIONES_CAJA  ' ||
               'WHERE  RCA_SUC_CODIGO= CCJ_RCA_SUC_CODIGO ' ||
               'AND  RCA_NEG_CONSECUTIVO = CCJ_RCA_NEG_CONSECUTIVO ' ||
               'AND  RCA_CONSECUTIVO = CCJ_RCA_CONSECUTIVO ' ||
               'AND  RCA_ES_CLIENTE = ''S''  ' ||
               'AND  RCA_REVERSADO = ''N'' ' ||
               'AND  RCA_COT_MNEMONICO = ''DGDE''  ' ||
               'AND  RCA_FECHA >  ''01-AGO-2006'' ' || 'AND  RCA_FECHA < ' ||
               CHR(39) || TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               'AND  CCJ_MONTO != 0 ' || 'UNION ALL ' ||
               'SELECT RCA_FECHA FECHA, ' || 'NVL(TRC_MONTO,0) VALOR_RCA, ' ||
               '0 VALOR_ODP, ' ||
               'RCA_CCC_CLI_PER_NUM_IDEN CLI_PER_NUM_IDEN, ' ||
               'RCA_CCC_CLI_PER_TID_CODIGO CLI_PER_TID_CODIGO, ' ||
               'RCA_CCC_NUMERO_CUENTA CCC_NUMERO_CUENTA ' ||
               'FROM   RECIBOS_DE_CAJA, ' || 'TRANSFERENCIAS_CAJA ' ||
               'WHERE  RCA_SUC_CODIGO= TRC_RCA_SUC_CODIGO ' ||
               'AND  RCA_NEG_CONSECUTIVO = TRC_RCA_NEG_CONSECUTIVO ' ||
               'AND  RCA_CONSECUTIVO = TRC_RCA_CONSECUTIVO ' ||
               'AND  RCA_ES_CLIENTE = ''S'' ' ||
               'AND  RCA_REVERSADO = ''N'' ' ||
               'AND  RCA_COT_MNEMONICO = ''DGDE''  ' ||
               'AND  RCA_FECHA >  ''01-AGO-2006''               ' ||
               'AND  RCA_FECHA < ' || CHR(39) ||
               TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               'AND  TRC_MONTO != 0 ' || 'UNION ALL ' ||
               'SELECT RCA_FECHA FECHA, ' ||
               'NVL(RCA_MONTO_EN_EFECTIVO,0) VALOR_RCA, ' ||
               '0 VALOR_ODP, ' ||
               'RCA_CCC_CLI_PER_NUM_IDEN CLI_PER_NUM_IDEN, ' ||
               'RCA_CCC_CLI_PER_TID_CODIGO CLI_PER_TID_CODIGO, ' ||
               'RCA_CCC_NUMERO_CUENTA CCC_NUMERO_CUENTA ' ||
               'FROM   RECIBOS_DE_CAJA ' ||
               'WHERE  RCA_ES_CLIENTE = ''S'' ' ||
               'AND  RCA_REVERSADO = ''N'' ' ||
               'AND  RCA_COT_MNEMONICO = ''DGDE'' ' ||
               'AND  RCA_FECHA >  ''01-AGO-2006'' ' || 'AND  RCA_FECHA < ' ||
               CHR(39) || TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               'AND  RCA_MONTO_EN_EFECTIVO != 0 ' || 'UNION ALL ' ||
               'SELECT ODP_FECHA_EJECUCION FECHA, ' || '0 VALOR_RCA, ' ||
               'NVL(ODP_MONTO_ORDEN,0) VALOR_ODP, ' ||
               'ODP_CCC_CLI_PER_NUM_IDEN CLI_PER_NUM_IDEN, ' ||
               'ODP_CCC_CLI_PER_TID_CODIGO CLI_PER_TID_CODIGO, ' ||
               'ODP_CCC_NUMERO_CUENTA  CCC_NUMERO_CUENTA  ' ||
               'FROM   ORDENES_DE_PAGO ' || 'WHERE ODP_ESTADO = ''APR'' ' ||
               'AND ODP_ES_CLIENTE = ''S'' ' ||
               'AND ODP_COT_MNEMONICO = ''CGDE'' ' ||
               'AND ODP_FECHA >  ''01-AGO-2006'' ' ||
               'AND ODP_FECHA_EJECUCION < ' || CHR(39) ||
               TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               'AND (ODP_CEG_CONSECUTIVO IS NOT NULL ' ||
               'OR ODP_CGE_CONSECUTIVO IS NOT NULL ' ||
               'OR ODP_TBC_CONSECUTIVO IS NOT NULL ' ||
               'OR ODP_TCC_CONSECUTIVO IS NOT NULL)  ' ||
               'AND ODP_MONTO_ORDEN != 0 ' || ') TMP, ' ||
               ' CUENTAS_CLIENTE_CORREDORES CCC ' ||
               'WHERE TMP.CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN ' ||
               'AND TMP.CLI_PER_TID_CODIGO = CCC.CCC_CLI_PER_TID_CODIGO ' ||
               'AND TMP.CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA ' ||
               'GROUP BY CCC.CCC_NOMBRE_CUENTA,CCC.CCC_CLI_PER_NUM_IDEN,CCC.CCC_CLI_PER_TID_CODIGO, CCC.CCC_NUMERO_CUENTA, CCC.CCC_PER_NUM_IDEN, CCC.CCC_PER_TID_CODIGO ' ||
               'HAVING SUM(VALOR_ODP) - SUM(VALOR_RCA)!=0 ' || ') TMP2 ' ||
               ' GROUP BY CCC_CLI_PER_NUM_IDEN,CCC_CLI_PER_TID_CODIGO,CCC_NUMERO_CUENTA,CCC_PER_NUM_IDEN,CCC_PER_TID_CODIGO' ||
               ' HAVING ' || P_CONDICION;
      return(X_TEM);
    END;
    FUNCTION F_SQL_DIAS_ANTERIORES(FECHA      IN DATE,
                                   RANGO      IN NUMBER,
                                   RANGO_MAX  IN NUMBER,
                                   RANGO1     IN NUMBER,
                                   RANGO_MAX1 IN NUMBER) RETURN VARCHAR2 IS
      X_TEM       VARCHAR2(32767) := ' ';
      P_CONDICION VARCHAR2(2000) := ' ';
    BEGIN
      IF NVL(RANGO_MAX, 0) = 0 THEN

        P_CONDICION := ' SUM(SDI_SALDO_CAPITAL) >' || RANGO || ' OR ' ||
                       ' SUM(SDI_SALDO_A_PLAZO) > ' || RANGO || ' OR ' ||
                       ' SUM(SDI_SALDO_ADMON_VALORES) > ' || RANGO || 'OR ' ||
                       ' SUM(SDI_SALDO_CC) > ' || RANGO || 'OR ' ||
                       ' SUM(SDI_SALDO_BURSATIL) > ' || RANGO || 'OR ' ||
                       ' SUM(SDI_SALDO_CANJE) > ' || RANGO || 'OR ' ||
                       ' SUM(SDI_SALDO_CANJE_CC) > ' || RANGO || 'OR ' ||
                       ' SUM(SDI_SALDO_A_CONTADO) > ' || RANGO || ' OR ' ||
                       ' SUM(SDD_MDD_SALDO) >' || RANGO || ' OR ' ||
                       ' SUM(SDV_SALDO) >' || RANGO || ' OR ' ||
                       ' SUM(MCD_SALDO) >' || RANGO || ' OR ' ||
                       ' SUM(SALDO_GARANTIAS) >' || RANGO || ' OR ';
      ELSE
        P_CONDICION := ' (SUM(SDI_SALDO_CAPITAL) > ' || RANGO || ' AND ' ||
                       '   SUM(SDI_SALDO_CAPITAL) <= ' || RANGO_MAX ||
                       ') OR ' || '  (SUM(SDI_SALDO_A_PLAZO) > ' || RANGO ||
                       ' AND ' || '   SUM(SDI_SALDO_A_PLAZO) <= ' ||
                       RANGO_MAX || ') OR ' ||
                       '  (SUM(SDI_SALDO_ADMON_VALORES) > ' || RANGO ||
                       ' AND ' || '   SUM(SDI_SALDO_ADMON_VALORES) <= ' ||
                       RANGO_MAX || ') OR ' || '  (SUM(SDI_SALDO_CC) > ' ||
                       RANGO || ' AND ' || '   SUM(SDI_SALDO_CC) <= ' ||
                       RANGO_MAX || ') OR ' ||
                       '  (SUM(SDI_SALDO_BURSATIL) > ' || RANGO || ' AND ' ||
                       '   SUM(SDI_SALDO_BURSATIL) <= ' || RANGO_MAX ||
                       ') OR ' || '  (SUM(SDI_SALDO_CANJE) > ' || RANGO ||
                       ' AND ' || '   SUM(SDI_SALDO_CANJE) <= ' ||
                       RANGO_MAX || ') OR ' ||
                       '  (SUM(SDI_SALDO_CANJE_CC) > ' || RANGO || ' AND ' ||
                       '   SUM(SDI_SALDO_CANJE_CC) <= ' || RANGO_MAX ||
                       ') OR ' || '  (SUM(SDI_SALDO_A_CONTADO) > ' || RANGO ||
                       ' AND ' || '   SUM(SDI_SALDO_A_CONTADO) <= ' ||
                       RANGO_MAX || ') OR ' || '  (SUM(SDD_MDD_SALDO) > ' ||
                       RANGO || ' AND ' || '   SUM(SDD_MDD_SALDO) <= ' ||
                       RANGO_MAX || ') OR ' || '  (SUM(SDV_SALDO) > ' ||
                       RANGO || ' AND ' || '   SUM(SDV_SALDO) <= ' ||
                       RANGO_MAX || ') OR ' || '  (SUM(MCD_SALDO) > ' ||
                       RANGO || ' AND ' || '   SUM(MCD_SALDO) <= ' ||
                       RANGO_MAX || ') OR ' || '  (SUM(SALDO_GARANTIAS) > ' ||
                       RANGO || ' AND ' || '   SUM(SALDO_GARANTIAS) <= ' ||
                       RANGO_MAX || ') OR ';
      END IF;

      IF NVL(RANGO_MAX1, 0) = 0 THEN
        P_CONDICION := P_CONDICION || ' SUM(SDI_SALDO_CAPITAL) < ' ||
                       -RANGO1 || ' OR ' || ' SUM(SDI_SALDO_A_PLAZO) <' ||
                       -RANGO1 || ' OR ' ||
                       ' SUM(SDI_SALDO_ADMON_VALORES) <' || -RANGO1 ||
                       ' OR ' || ' SUM(SDI_SALDO_CC) <' || -RANGO1 ||
                       ' OR ' || ' SUM(SDI_SALDO_BURSATIL) <' || -RANGO1 ||
                       ' OR ' || ' SUM(SDI_SALDO_CANJE) <' || -RANGO1 ||
                       ' OR ' || ' SUM(SDI_SALDO_CANJE_CC) <' || -RANGO1 ||
                       ' OR ' || ' SUM(SDI_SALDO_A_CONTADO) < ' || -RANGO1 ||
                       ' OR ' || ' SUM(SDD_MDD_SALDO) < ' || -RANGO1 ||
                       ' OR ' || ' SUM(SDV_SALDO) < ' || -RANGO1 || ' OR ' ||
                       ' SUM(MCD_SALDO) < ' || -RANGO1 || ' OR ' ||
                       ' SUM(SALDO_GARANTIAS) < ' || -RANGO1;
      ELSE
        P_CONDICION := P_CONDICION || ' (SUM(SDI_SALDO_CAPITAL) < ' ||
                       -RANGO1 || ' AND ' || '  SUM(SDI_SALDO_CAPITAL) >=' ||
                       -RANGO_MAX1 || ') OR ' ||
                       ' (SUM(SDI_SALDO_A_PLAZO) < ' || -RANGO1 || ' AND ' ||
                       '  SUM(SDI_SALDO_A_PLAZO) >=' || -RANGO_MAX1 ||
                       ') OR ' || ' (SUM(SDI_SALDO_ADMON_VALORES) <' ||
                       -RANGO1 || ' AND ' ||
                       '  SUM(SDI_SALDO_ADMON_VALORES) >=' || -RANGO_MAX1 ||
                       ') OR ' || ' (SUM(SDI_SALDO_CC) <' || -RANGO1 ||
                       ' AND ' || '  SUM(SDI_SALDO_CC) >=' || -RANGO_MAX1 ||
                       ') OR ' || ' (SUM(SDI_SALDO_BURSATIL) <' || -RANGO1 ||
                       ' AND ' || '  SUM(SDI_SALDO_BURSATIL) >=' ||
                       -RANGO_MAX1 || ') OR ' || ' (SUM(SDI_SALDO_CANJE) <' ||
                       -RANGO1 || ' AND ' || '  SUM(SDI_SALDO_CANJE) >=' ||
                       -RANGO_MAX1 || ') OR ' ||
                       ' (SUM(SDI_SALDO_CANJE_CC) <' || -RANGO1 || ' AND ' ||
                       '  SUM(SDI_SALDO_CANJE_CC) >=' || -RANGO_MAX1 ||
                       ') OR ' || ' (SUM(SDI_SALDO_A_CONTADO) <' || -RANGO1 ||
                       ' AND ' || '  SUM(SDI_SALDO_A_CONTADO) >=' ||
                       -RANGO_MAX1 || ') OR ' || ' (SUM(SDD_MDD_SALDO) <' ||
                       -RANGO1 || ' AND ' || '  SUM(SDD_MDD_SALDO) >=' ||
                       -RANGO_MAX1 || ') OR ' || ' (SUM(SDV_SALDO) <' ||
                       -RANGO1 || ' AND ' || '  SUM(SDV_SALDO) >=' ||
                       -RANGO_MAX1 || ') OR ' || ' (SUM(MCD_SALDO) <' ||
                       -RANGO1 || ' AND ' || '  SUM(MCD_SALDO) >=' ||
                       -RANGO_MAX1 || ') OR ' ||
                       ' (SUM(SALDO_GARANTIAS) < ' || -RANGO1 || ' AND ' ||
                       '  SUM(SALDO_GARANTIAS) >=' || -RANGO_MAX1 || ') ';
      END IF;

      -- LLENADO DE TABLA GL_MOVIMIENTOS_CUENTA
      X_TEM := 'INSERT INTO GL_MOVIMIENTOS_CUENTA ' || '(MCC_FECHA ' ||
               ',CCC_NOMBRE_CUENTA ' || ',MCC_SALDO_CAPITAL ' ||
               ',MCC_SALDO_A_CONTADO ' || ',MCC_SALDO_A_PLAZO ' ||
               ',MCC_SALDO_ADMON_VALORES ' || ',MCC_SALDO_CC ' ||
               ',MCC_SALDO_BURSATIL ' || ',MCC_SALDO_CANJE ' ||
               ',MCC_SALDO_CANJE_CC ' || ',MDD_SALDO ' ||
               ',MCM_SALDO_MONETIZAR ' || ',SALDO_DOLARES ' ||
               ',SALDO_REMESAS ' || ',SALDO_GARANTIAS ' ||
               ',FECHA_ULT_MOV_CAPITAL ' || ',FECHA_ULT_MOV_CONTADO ' ||
               ',FECHA_ULT_MOV_PLAZO ' || ',FECHA_ULT_MOV_ADVAL ' ||
               ',FECHA_ULT_MOV_CC ' || ',FECHA_ULT_MOV_CANJE ' ||
               ',FECHA_ULT_MOV_CANJE_CC ' || ',FECHA_ULT_MOV_BURSATIL ' ||
               ',FECHA_ULT_MOV_DERIVADOS ' || ',FECHA_ULT_MOV_MONETIZAR ' ||
               ',FECHA_ULT_MOV_DOLARES ' || ',FECHA_ULT_MOV_REMESAS ' ||
               ',FECHA_ULT_MOV_GARANTIAS ' || ',CCC_CLI_PER_NUM_IDEN ' ||
               ',CCC_CLI_PER_TID_CODIGO ' || ',CCC_NUMERO_CUENTA ' ||
               ',CCC_PER_NUM_IDEN ' || ',CCC_PER_TID_CODIGO ) ' ||
               'SELECT SYSDATE, ' || ''' ''CCC_NOMBRE_CUENTA, ' ||
               'SUM(SDI_SALDO_CAPITAL), ' || 'SUM(SDI_SALDO_A_CONTADO), ' ||
               'SUM(SDI_SALDO_A_PLAZO), ' ||
               'SUM(SDI_SALDO_ADMON_VALORES), ' || 'SUM(SDI_SALDO_CC), ' ||
               'SUM(SDI_SALDO_BURSATIL), ' || 'SUM(SDI_SALDO_CANJE), ' ||
               'SUM(SDI_SALDO_CANJE_CC), ' || 'SUM(SDD_MDD_SALDO), ' ||
               'SUM(SDV_SALDO), ' || 'SUM(MCD_SALDO), ' ||
               'SUM(SALDO_REMESAS), ' || 'SUM(SALDO_GARANTIAS), ' ||
               'MAX(FECHA_SALDO_CAPITAL), ' ||
               'MAX(FECHA_SALDO_A_CONTADO), ' ||
               'MAX(FECHA_SALDO_A_PLAZO), ' ||
               'MAX(FECHA_SALDO_ADMON_VALORES), ' ||
               'MAX(FECHA_SALDO_CC), ' || 'MAX(FECHA_SALDO_BURSATIL), ' ||
               'MAX(FECHA_SALDO_CANJE), ' || 'MAX(FECHA_SALDO_CANJE_CC), ' ||
               'MAX(FECHA_SDD_MDD_SALDO), ' || 'MAX(FECHA_SDV_SALDO), ' ||
               'MAX(FECHA_MCD_SALDO), ' || 'MAX(FECHA_REMESAS), ' ||
               'MAX(FECHA_GARANTIAS), ' || 'CCC_CLI_PER_NUM_IDEN, ' ||
               'CCC_CLI_PER_TID_CODIGO, ' || 'CCC_NUMERO_CUENTA, ' ||
               'CCC_PER_NUM_IDEN, ' || 'CCC_PER_TID_CODIGO ' ||
               'FROM (SELECT SDI.SDI_SALDO_CAPITAL, ' ||
               'SDI.SDI_SALDO_A_CONTADO, ' || 'SDI.SDI_SALDO_A_PLAZO, ' ||
               'SDI.SDI_SALDO_ADMON_VALORES, ' || 'SDI.SDI_SALDO_CC, ' ||
               'NVL(SDI.SDI_SALDO_BURSATIL,0) SDI_SALDO_BURSATIL, ' ||
               'SDI.SDI_SALDO_CANJE, ' ||
               'SDI.SDI_SALDO_CANJE_CC SDI_SALDO_CANJE_CC, ' ||
               '0 SDD_MDD_SALDO, ' || '0 SDV_SALDO, ' || '0 MCD_SALDO, ' ||
               '0 SALDO_REMESAS, ' || '0 SALDO_GARANTIAS, ' ||
               'SDI_FECHA_ULT_MOV_CAPITAL FECHA_SALDO_CAPITAL, ' ||
               'SDI_FECHA_ULT_MOV_CONTADO FECHA_SALDO_A_CONTADO, ' ||
               'SDI_FECHA_ULT_MOV_PLAZO FECHA_SALDO_A_PLAZO, ' ||
               'SDI_FECHA_ULT_MOV_ADVAL FECHA_SALDO_ADMON_VALORES, ' ||
               'SDI_FECHA_ULT_MOV_CC FECHA_SALDO_CC, ' ||
               'SDI_FECHA_ULT_MOV_BURSATIL FECHA_SALDO_BURSATIL, ' ||
               'SDI_FECHA_ULT_MOV_CANJE FECHA_SALDO_CANJE, ' ||
               'SDI_FECHA_ULT_MOV_CC FECHA_SALDO_CANJE_CC, ' ||
               'NULL FECHA_SDD_MDD_SALDO, ' || 'NULL FECHA_SDV_SALDO, ' ||
               'NULL FECHA_MCD_SALDO, ' || 'NULL FECHA_REMESAS, ' ||
               'NULL FECHA_GARANTIAS, ' || 'CCC.CCC_CLI_PER_NUM_IDEN, ' ||
               'CCC.CCC_CLI_PER_TID_CODIGO, ' || 'CCC.CCC_NUMERO_CUENTA, ' ||
               'CCC.CCC_PER_NUM_IDEN, ' || 'CCC.CCC_PER_TID_CODIGO ' ||
               ' FROM CUENTAS_CLIENTE_CORREDORES CCC, ' ||
               'SALDOS_DIARIOS_CLIENTE SDI ' ||
               'WHERE CCC.CCC_CLI_PER_NUM_IDEN = SDI.SDI_CCC_CLI_PER_NUM_IDEN ' ||
               'AND   CCC.CCC_CLI_PER_TID_CODIGO = SDI.SDI_CCC_CLI_PER_TID_CODIGO ' ||
               'AND   CCC.CCC_NUMERO_CUENTA = SDI.SDI_CCC_NUMERO_CUENTA ' ||
               'AND  SDI.SDI_FECHA_SALDO = ' || CHR(39) ||
               TO_CHAR(FECHA, 'DD-MON-YYYY') || CHR(39) || ' UNION ALL ' ||
               ' SELECT 0 SDI_SALDO_CAPITAL,  ' ||
               '0 SDI_SALDO_A_CONTADO, ' || '0 SDI_SALDO_A_PLAZO, ' ||
               '0 SDI_SALDO_ADMON_VALORES, ' || '0 SDI_SALDO_CC, ' ||
               '0 SDI_SALDO_BURSATIL, ' || '0 SDI_SALDO_CANJE, ' ||
               '0 SDI_SALDO_CANJE_CC, ' || 'SDD_MDD_SALDO, ' ||
               '0 SDV_SALDO, ' || '0 MCD_SALDO, ' || '0 SALDO_REMESAS, ' ||
               '0 SALDO_GARANTIAS, ' || 'NULL FECHA_SALDO_CAPITAL, ' ||
               'NULL FECHA_SALDO_A_CONTADO, ' ||
               'NULL FECHA_SALDO_A_PLAZO, ' ||
               'NULL FECHA_SALDO_ADMON_VALORES, ' ||
               'NULL FECHA_SALDO_CC, ' || 'NULL FECHA_SALDO_BURSATIL, ' ||
               'NULL FECHA_SALDO_CANJE, ' || 'NULL FECHA_SALDO_CANJE_CC, ' ||
               'SDD.SDD_MDD_FECHA FECHA_SDD_MDD_SALDO, ' ||
               'NULL FECHA_SDV_SALDO, ' || 'NULL FECHA_MCD_SALDO, ' ||
               'NULL FECHA_REMESAS, ' || 'NULL FECHA_GARANTIAS, ' ||
               'CCC.CCC_CLI_PER_NUM_IDEN, ' ||
               'CCC.CCC_CLI_PER_TID_CODIGO, ' || 'CCC.CCC_NUMERO_CUENTA, ' ||
               'CCC.CCC_PER_NUM_IDEN, ' || 'CCC.CCC_PER_TID_CODIGO ' ||
               ' FROM CUENTAS_CLIENTE_CORREDORES CCC, ' ||
               'SALDOS_DIARIOS_DERIVADOS SDD ' ||
               'WHERE CCC.CCC_CLI_PER_NUM_IDEN = SDD.SDD_CDD_CCC_CLI_PER_NUM_IDEN ' ||
               'AND   CCC.CCC_CLI_PER_TID_CODIGO = SDD.SDD_CDD_CCC_CLI_PER_TID_CODIGO ' ||
               'AND   CCC.CCC_NUMERO_CUENTA = SDD.SDD_CDD_CCC_NUMERO_CUENTA  ' ||
               'AND  SDD.SDD_FECHA_SALDO = ' || CHR(39) ||
               TO_CHAR(FECHA, 'DD-MON-YYYY') || CHR(39) || ' UNION ALL ' ||
               ' SELECT 0 SDI_SALDO_CAPITAL,  ' ||
               '0 SDI_SALDO_A_CONTADO, ' || '0 SDI_SALDO_A_PLAZO, ' ||
               '0 SDI_SALDO_ADMON_VALORES, ' || '0 SDI_SALDO_CC, ' ||
               '0 SDI_SALDO_BURSATIL, ' || '0 SDI_SALDO_CANJE, ' ||
               '0 SDI_SALDO_CANJE_CC, ' || '0 SDD_MDD_SALDO, ' ||
               'SDV_SALDO, ' || '0 MCD_SALDO, ' || '0 SALDO_REMESAS, ' ||
               '0 SALDO_GARANTIAS, ' || 'NULL FECHA_SALDO_CAPITAL, ' ||
               'NULL FECHA_SALDO_A_CONTADO, ' ||
               'NULL FECHA_SALDO_A_PLAZO, ' ||
               'NULL FECHA_SALDO_ADMON_VALORES, ' ||
               'NULL FECHA_SALDO_CC, ' || 'NULL FECHA_SALDO_BURSATIL, ' ||
               'NULL FECHA_SALDO_CANJE, ' || 'NULL FECHA_SALDO_CANJE_CC, ' ||
               'NULL FECHA_SDD_MDD_SALDO, ' ||
               'SDV_FECHA_SALDO FECHA_SDV_SALDO, ' ||
               'NULL FECHA_MCD_SALDO, ' || 'NULL FECHA_REMESAS, ' ||
               'NULL FECHA_GARANTIAS, ' || 'CCC.CCC_CLI_PER_NUM_IDEN, ' ||
               'CCC.CCC_CLI_PER_TID_CODIGO, ' || 'CCC.CCC_NUMERO_CUENTA, ' ||
               'CCC.CCC_PER_NUM_IDEN, ' || 'CCC.CCC_PER_TID_CODIGO ' ||
               ' FROM CUENTAS_CLIENTE_CORREDORES CCC, ' ||
               'SALDOS_CLIENTES_DIVISAS SDV ' ||
               'WHERE CCC.CCC_CLI_PER_NUM_IDEN = SDV.SDV_SCM_CCC_CLI_PER_NUM_IDEN ' ||
               'AND   CCC.CCC_CLI_PER_TID_CODIGO = SDV.SDV_SCM_CCC_CLI_PER_TID_CODIGO ' ||
               'AND   CCC.CCC_NUMERO_CUENTA = SDV.SDV_SCM_CCC_NUMERO_CUENTA ' ||
               'AND  SDV.SDV_FECHA_SALDO = ' || CHR(39) ||
               TO_CHAR(FECHA, 'DD-MON-YYYY') || CHR(39) || ' UNION ALL ' ||
               ' SELECT 0 SDI_SALDO_CAPITAL,  ' ||
               '0 SDI_SALDO_A_CONTADO, ' || '0 SDI_SALDO_A_PLAZO, ' ||
               '0 SDI_SALDO_ADMON_VALORES, ' || '0 SDI_SALDO_CC, ' ||
               '0 SDI_SALDO_BURSATIL, ' || '0 SDI_SALDO_CANJE, ' ||
               '0 SDI_SALDO_CANJE_CC, ' || '0 SDD_MDD_SALDO, ' ||
               '0 SDV_SALDO, ' ||
               'MCOM_SALDO * CBM_VALOR * PMO_TASA_CONVERSION MCD_SALDO, ' ||
               '0 SALDO_REMESAS, ' || '0 SALDO_GARANTIAS, ' ||
               'NULL FECHA_SALDO_CAPITAL, ' ||
               'NULL FECHA_SALDO_A_CONTADO, ' ||
               'NULL FECHA_SALDO_A_PLAZO, ' ||
               'NULL FECHA_SALDO_ADMON_VALORES, ' ||
               'NULL FECHA_SALDO_CC, ' || 'NULL FECHA_SALDO_BURSATIL, ' ||
               'NULL FECHA_SALDO_CANJE, ' || 'NULL FECHA_SALDO_CANJE_CC, ' ||
               'NULL FECHA_SDD_MDD_SALDO, ' || 'NULL FECHA_SDV_SALDO, ' ||
               'MCOM_FECHA FECHA_MCD_SALDO, ' || 'NULL FECHA_REMESAS, ' ||
               'NULL FECHA_GARANTIAS, ' || 'CCC.CCC_CLI_PER_NUM_IDEN, ' ||
               'CCC.CCC_CLI_PER_TID_CODIGO, ' || 'CCC.CCC_NUMERO_CUENTA, ' ||
               'CCC.CCC_PER_NUM_IDEN, ' || 'CCC.CCC_PER_TID_CODIGO ' ||
               ' FROM MOVIMIENTOS_CUENTAS_OTRAS_MONE M, ' ||
               'POSICIONES_MONEDAS, ' || 'COTIZACIONES_BASE_MONETARIAS, ' ||
               'CUENTAS_CLIENTE_CORREDORES CCC ' ||
               'WHERE MCOM_CCOM_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN ' ||
               'AND MCOM_CCOM_CCC_CLI_PER_TID_CODI = CCC.CCC_CLI_PER_TID_CODIGO ' ||
               'AND MCOM_CCOM_CCC_NUMERO_CUENTA   = CCC.CCC_NUMERO_CUENTA ' ||
               'AND M.MCOM_CONSECUTIVO = (SELECT MAX(M2.MCOM_CONSECUTIVO) ' ||
               'FROM MOVIMIENTOS_CUENTAS_OTRAS_MONE M2  ' ||
               'WHERE  M2.MCOM_FECHA = (SELECT MAX(M1.MCOM_FECHA) ' ||
               'FROM   MOVIMIENTOS_CUENTAS_OTRAS_MONE M1 ' ||
               'WHERE  M1.MCOM_FECHA < ' || CHR(39) ||
               TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               'AND    M1.MCOM_CCOM_CCC_CLI_PER_NUM_IDEN = M.MCOM_CCOM_CCC_CLI_PER_NUM_IDEN ' ||
               'AND    M1.MCOM_CCOM_CCC_CLI_PER_TID_CODI = M.MCOM_CCOM_CCC_CLI_PER_TID_CODI ' ||
               'AND    M1.MCOM_CCOM_CCC_NUMERO_CUENTA    = M.MCOM_CCOM_CCC_NUMERO_CUENTA ' ||
               'AND    M1.MCOM_CCOM_BMO_MNEMONICO = M.MCOM_CCOM_BMO_MNEMONICO)) ' ||
               'AND MCOM_CCOM_BMO_MNEMONICO = PMO_BMO_MNEMONICO ' ||
               'AND PMO_FECHA = ' || CHR(39) ||
               TO_CHAR(FECHA, 'DD-MON-YYYY') || CHR(39) ||
               'AND CBM_BMO_MNEMONICO = ''DOLAR'' ' || 'AND CBM_FECHA = ' ||
               CHR(39) || TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               ' UNION ALL ' || ' SELECT 0 SDI_SALDO_CAPITAL,  ' ||
               '0 SDI_SALDO_A_CONTADO, ' || '0 SDI_SALDO_A_PLAZO, ' ||
               '0 SDI_SALDO_ADMON_VALORES, ' || '0 SDI_SALDO_CC, ' ||
               '0 SDI_SALDO_BURSATIL, ' || '0 SDI_SALDO_CANJE, ' ||
               '0 SDI_SALDO_CANJE_CC, ' || '0 SDD_MDD_SALDO, ' ||
               '0 SDV_SALDO, ' ||
               '(MCD_SALDO + MCD_SALDO_RESTRINGIDO) * CBM_VALOR MCD_SALDO, ' ||
               '0 SALDO_REMESAS, ' || '0 SALDO_GARANTIAS, ' ||
               'NULL FECHA_SALDO_CAPITAL, ' ||
               'NULL FECHA_SALDO_A_CONTADO, ' ||
               'NULL FECHA_SALDO_A_PLAZO, ' ||
               'NULL FECHA_SALDO_ADMON_VALORES, ' ||
               'NULL FECHA_SALDO_CC, ' || 'NULL FECHA_SALDO_BURSATIL, ' ||
               'NULL FECHA_SALDO_CANJE, ' || 'NULL FECHA_SALDO_CANJE_CC, ' ||
               'NULL FECHA_SDD_MDD_SALDO, ' || 'NULL FECHA_SDV_SALDO, ' ||
               'MCD_FECHA FECHA_MCD_SALDO, ' || 'NULL FECHA_REMESAS, ' ||
               'NULL FECHA_GARANTIAS, ' || 'CCC.CCC_CLI_PER_NUM_IDEN, ' ||
               'CCC.CCC_CLI_PER_TID_CODIGO, ' || 'CCC.CCC_NUMERO_CUENTA, ' ||
               'CCC.CCC_PER_NUM_IDEN, ' || 'CCC.CCC_PER_TID_CODIGO ' ||
               ' FROM CUENTAS_CLIENTE_CORREDORES CCC, ' ||
               'MOVIMIENTOS_CUENTAS_DIVISAS M, ' ||
               'COTIZACIONES_BASE_MONETARIAS CBM ' ||
               'WHERE CCC.CCC_CLI_PER_NUM_IDEN = M.MCD_CDV_CCC_CLI_PER_NUM_IDEN ' ||
               'AND CCC.CCC_CLI_PER_TID_CODIGO = M.MCD_CDV_CCC_CLI_PER_TID_CODIGO ' ||
               'AND CCC.CCC_NUMERO_CUENTA = M.MCD_CDV_CCC_NUMERO_CUENTA ' ||
               'AND M.MCD_FECHA = (SELECT MAX(M1.MCD_FECHA) ' ||
               'FROM   MOVIMIENTOS_CUENTAS_DIVISAS M1 ' ||
               'WHERE  M1.MCD_FECHA < ' || CHR(39) ||
               TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               'AND    M1.MCD_CDV_CCC_CLI_PER_NUM_IDEN   = M.MCD_CDV_CCC_CLI_PER_NUM_IDEN ' ||
               'AND    M1.MCD_CDV_CCC_CLI_PER_TID_CODIGO = M.MCD_CDV_CCC_CLI_PER_TID_CODIGO ' ||
               'AND    M1.MCD_CDV_CCC_NUMERO_CUENTA      = M.MCD_CDV_CCC_NUMERO_CUENTA) ' ||
               'AND MCD_CDV_BMO_MNEMONICO = CBM_BMO_MNEMONICO ' ||
               'AND CBM_FECHA = ' || CHR(39) ||
               TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               ' UNION ALL ' || ' SELECT 0 SDI_SALDO_CAPITAL,  ' ||
               '0 SDI_SALDO_A_CONTADO, ' || '0 SDI_SALDO_A_PLAZO, ' ||
               '0 SDI_SALDO_ADMON_VALORES, ' || '0 SDI_SALDO_CC, ' ||
               '0 SDI_SALDO_BURSATIL, ' || '0 SDI_SALDO_CANJE, ' ||
               '0 SDI_SALDO_CANJE_CC, ' || '0 SDD_MDD_SALDO, ' ||
               '0 SDV_SALDO, ' || '0 MCD_SALDO, ' || '0 SALDO_REMESAS, ' ||
               'SUM(VALOR_ODP) - SUM(VALOR_RCA) SALDO_GARANTIAS, ' ||
               'NULL FECHA_SALDO_CAPITAL, ' ||
               'NULL FECHA_SALDO_A_CONTADO, ' ||
               'NULL FECHA_SALDO_A_PLAZO, ' ||
               'NULL FECHA_SALDO_ADMON_VALORES, ' ||
               'NULL FECHA_SALDO_CC, ' || 'NULL FECHA_SALDO_BURSATIL, ' ||
               'NULL FECHA_SALDO_CANJE, ' || 'NULL FECHA_SALDO_CANJE_CC, ' ||
               'NULL FECHA_SDD_MDD_SALDO, ' || 'NULL FECHA_SDV_SALDO, ' ||
               'NULL FECHA_MCD_SALDO, ' || 'NULL FECHA_REMESAS, ' ||
               'MAX(FECHA) FECHA_GARANTIAS, ' ||
               'CCC.CCC_CLI_PER_NUM_IDEN, ' ||
               'CCC.CCC_CLI_PER_TID_CODIGO, ' || 'CCC.CCC_NUMERO_CUENTA, ' ||
               'CCC.CCC_PER_NUM_IDEN, ' || 'CCC.CCC_PER_TID_CODIGO ' ||
               'FROM (SELECT  RCA_FECHA FECHA, ' ||
               'NVL(CCA_MONTO,0) VALOR_RCA, ' || '0 VALOR_ODP, ' ||
               'RCA_CCC_CLI_PER_NUM_IDEN CLI_PER_NUM_IDEN, ' ||
               'RCA_CCC_CLI_PER_TID_CODIGO CLI_PER_TID_CODIGO, ' ||
               'RCA_CCC_NUMERO_CUENTA CCC_NUMERO_CUENTA ' ||
               'FROM   RECIBOS_DE_CAJA, ' || 'CHEQUES_CAJA ' ||
               'WHERE  RCA_SUC_CODIGO= CCA_RCA_SUC_CODIGO  ' ||
               'AND    RCA_NEG_CONSECUTIVO = CCA_RCA_NEG_CONSECUTIVO  ' ||
               'AND    RCA_CONSECUTIVO = CCA_RCA_CONSECUTIVO ' ||
               'AND    RCA_ES_CLIENTE = ''S'' ' ||
               'AND    RCA_REVERSADO = ''N'' ' ||
               'AND    RCA_COT_MNEMONICO = ''RGCE'' ' ||
               'AND    RCA_FECHA > ''01-AGO-2006'' ' ||
               'AND    RCA_FECHA < ' || CHR(39) ||
               TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               'AND    CCA_MONTO != 0 ' || 'UNION ALL ' ||
               'SELECT RCA_FECHA FECHA, ' || 'NVL(CCJ_MONTO,0) VALOR_RCA, ' ||
               '0 VALOR_ODP, ' ||
               'RCA_CCC_CLI_PER_NUM_IDEN CLI_PER_NUM_IDEN, ' ||
               'RCA_CCC_CLI_PER_TID_CODIGO CLI_PER_TID_CODIGO, ' ||
               'RCA_CCC_NUMERO_CUENTA CCC_NUMERO_CUENTA ' ||
               'FROM   RECIBOS_DE_CAJA, ' || 'CONSIGNACIONES_CAJA ' ||
               'WHERE  RCA_SUC_CODIGO= CCJ_RCA_SUC_CODIGO ' ||
               'AND    RCA_NEG_CONSECUTIVO = CCJ_RCA_NEG_CONSECUTIVO ' ||
               'AND    RCA_CONSECUTIVO = CCJ_RCA_CONSECUTIVO ' ||
               'AND    RCA_ES_CLIENTE = ''S'' ' ||
               'AND    RCA_REVERSADO = ''N'' ' ||
               'AND    RCA_COT_MNEMONICO = ''RGCE'' ' ||
               'AND    RCA_FECHA >  ''01-AGO-2006'' ' ||
               'AND    RCA_FECHA < ' || CHR(39) ||
               TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               'AND    CCJ_MONTO != 0 ' || 'UNION ALL ' ||
               'SELECT RCA_FECHA FECHA, ' || 'NVL(TRC_MONTO,0) VALOR_RCA, ' ||
               '0 VALOR_ODP, ' ||
               'RCA_CCC_CLI_PER_NUM_IDEN CLI_PER_NUM_IDEN, ' ||
               'RCA_CCC_CLI_PER_TID_CODIGO CLI_PER_TID_CODIGO, ' ||
               'RCA_CCC_NUMERO_CUENTA CCC_NUMERO_CUENTA ' ||
               'FROM   RECIBOS_DE_CAJA, ' || 'TRANSFERENCIAS_CAJA ' ||
               'WHERE  RCA_SUC_CODIGO= TRC_RCA_SUC_CODIGO ' ||
               'AND    RCA_NEG_CONSECUTIVO = TRC_RCA_NEG_CONSECUTIVO ' ||
               'AND    RCA_CONSECUTIVO = TRC_RCA_CONSECUTIVO ' ||
               'AND    RCA_ES_CLIENTE = ''S'' ' ||
               'AND    RCA_REVERSADO = ''N'' ' ||
               'AND    RCA_COT_MNEMONICO = ''RGCE'' ' ||
               'AND    RCA_FECHA >  ''01-AGO-2006'' ' ||
               'AND    RCA_FECHA < ' || CHR(39) ||
               TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               'AND    TRC_MONTO != 0 ' || 'UNION ALL ' ||
               'SELECT RCA_FECHA FECHA, ' ||
               'NVL(RCA_MONTO_EN_EFECTIVO,0) VALOR_RCA, ' ||
               '0 VALOR_ODP, ' ||
               'RCA_CCC_CLI_PER_NUM_IDEN CLI_PER_NUM_IDEN, ' ||
               'RCA_CCC_CLI_PER_TID_CODIGO CLI_PER_TID_CODIGO, ' ||
               'RCA_CCC_NUMERO_CUENTA CCC_NUMERO_CUENTA ' ||
               'FROM   RECIBOS_DE_CAJA ' ||
               'WHERE  RCA_ES_CLIENTE = ''S'' ' ||
               'AND    RCA_REVERSADO = ''N'' ' ||
               'AND    RCA_COT_MNEMONICO = ''RGCE''  ' ||
               'AND    RCA_FECHA >  ''01-AGO-2006''  ' ||
               'AND    RCA_FECHA < ' || CHR(39) ||
               TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               'AND    RCA_MONTO_EN_EFECTIVO != 0 ' || 'UNION ALL ' ||
               'SELECT  ODP_FECHA_EJECUCION FECHA, ' || '0 VALOR_RCA, ' ||
               'NVL(ODP_MONTO_ORDEN,0) VALOR_ODP, ' ||
               'ODP_CCC_CLI_PER_NUM_IDEN  CLI_PER_NUM_IDEN, ' ||
               'ODP_CCC_CLI_PER_TID_CODIGO CLI_PER_TID_CODIGO, ' ||
               'ODP_CCC_NUMERO_CUENTA CCC_NUMERO_CUENTA ' ||
               'FROM   ORDENES_DE_PAGO ' || 'WHERE ODP_ESTADO = ''APR'' ' ||
               'AND   ODP_ES_CLIENTE = ''S'' ' ||
               'AND   ODP_COT_MNEMONICO = ''GOPCE'' ' ||
               'AND   ODP_FECHA >  ''01-AGO-2006'' ' ||
               'AND   ODP_FECHA_EJECUCION < ' || CHR(39) ||
               TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               'AND   ODP_MONTO_ORDEN != 0 ' || 'UNION ALL ' ||
               'SELECT  RCA_FECHA FECHA, ' ||
               'NVL(CCA_MONTO,0) VALOR_RCA, ' || '0 VALOR_ODP, ' ||
               'RCA_CCC_CLI_PER_NUM_IDEN CLI_PER_NUM_IDEN, ' ||
               'RCA_CCC_CLI_PER_TID_CODIGO CLI_PER_TID_CODIGO, ' ||
               'RCA_CCC_NUMERO_CUENTA CCC_NUMERO_CUENTA ' ||
               'FROM   RECIBOS_DE_CAJA, ' || 'CHEQUES_CAJA ' ||
               'WHERE  RCA_SUC_CODIGO= CCA_RCA_SUC_CODIGO  ' ||
               'AND    RCA_NEG_CONSECUTIVO = CCA_RCA_NEG_CONSECUTIVO  ' ||
               'AND    RCA_CONSECUTIVO = CCA_RCA_CONSECUTIVO ' ||
               'AND    RCA_ES_CLIENTE = ''S'' ' ||
               'AND    RCA_REVERSADO = ''N'' ' ||
               'AND    RCA_COT_MNEMONICO = ''RGCF'' ' ||
               'AND    RCA_FECHA >  ''01-AGO-2006'' ' ||
               'AND    RCA_FECHA < ' || CHR(39) ||
               TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               'AND    CCA_MONTO != 0 ' || 'UNION ALL ' ||
               'SELECT  RCA_FECHA FECHA, ' ||
               'NVL(CCJ_MONTO,0) VALOR_RCA, ' || '0 VALOR_ODP, ' ||
               'RCA_CCC_CLI_PER_NUM_IDEN CLI_PER_NUM_IDEN, ' ||
               'RCA_CCC_CLI_PER_TID_CODIGO CLI_PER_TID_CODIGO, ' ||
               'RCA_CCC_NUMERO_CUENTA CCC_NUMERO_CUENTA ' ||
               'FROM   RECIBOS_DE_CAJA, ' || 'CONSIGNACIONES_CAJA ' ||
               'WHERE  RCA_SUC_CODIGO= CCJ_RCA_SUC_CODIGO ' ||
               'AND    RCA_NEG_CONSECUTIVO = CCJ_RCA_NEG_CONSECUTIVO ' ||
               'AND    RCA_CONSECUTIVO = CCJ_RCA_CONSECUTIVO ' ||
               'AND    RCA_ES_CLIENTE = ''S'' ' ||
               'AND    RCA_REVERSADO = ''N'' ' ||
               'AND    RCA_COT_MNEMONICO = ''RGCF'' ' ||
               'AND    RCA_FECHA >  ''01-AGO-2006'' ' ||
               'AND    RCA_FECHA < ' || CHR(39) ||
               TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               'AND    CCJ_MONTO != 0 ' || 'UNION ALL ' ||
               'SELECT  RCA_FECHA FECHA, ' ||
               'NVL(TRC_MONTO,0) VALOR_RCA, ' || '0 VALOR_ODP, ' ||
               'RCA_CCC_CLI_PER_NUM_IDEN CLI_PER_NUM_IDEN, ' ||
               'RCA_CCC_CLI_PER_TID_CODIGO CLI_PER_TID_CODIGO, ' ||
               'RCA_CCC_NUMERO_CUENTA CCC_NUMERO_CUENTA ' ||
               'FROM   RECIBOS_DE_CAJA, ' || 'TRANSFERENCIAS_CAJA ' ||
               'WHERE  RCA_SUC_CODIGO= TRC_RCA_SUC_CODIGO ' ||
               'AND    RCA_NEG_CONSECUTIVO = TRC_RCA_NEG_CONSECUTIVO ' ||
               'AND    RCA_CONSECUTIVO = TRC_RCA_CONSECUTIVO ' ||
               'AND    RCA_ES_CLIENTE = ''S'' ' ||
               'AND    RCA_REVERSADO = ''N'' ' ||
               'AND    RCA_COT_MNEMONICO = ''RGCF'' ' ||
               'AND    RCA_FECHA >  ''01-AGO-2006'' ' ||
               'AND    RCA_FECHA < ' || CHR(39) ||
               TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               'AND    TRC_MONTO != 0 ' || 'UNION ALL ' ||
               'SELECT RCA_FECHA FECHA, ' ||
               'NVL(RCA_MONTO_EN_EFECTIVO,0) VALOR_RCA, ' ||
               '0 VALOR_ODP, ' ||
               'RCA_CCC_CLI_PER_NUM_IDEN  CLI_PER_NUM_IDEN, ' ||
               'RCA_CCC_CLI_PER_TID_CODIGO CLI_PER_TID_CODIGO, ' ||
               'RCA_CCC_NUMERO_CUENTA CCC_NUMERO_CUENTA ' ||
               'FROM   RECIBOS_DE_CAJA ' ||
               'WHERE  RCA_ES_CLIENTE = ''S'' ' ||
               'AND    RCA_REVERSADO = ''N'' ' ||
               'AND    RCA_COT_MNEMONICO = ''RGCF''  ' ||
               'AND    RCA_FECHA > ''01-AGO-2006'' ' ||
               'AND    RCA_FECHA < ' || CHR(39) ||
               TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               'AND    RCA_MONTO_EN_EFECTIVO != 0 ' || 'UNION ALL ' ||
               'SELECT ODP_FECHA_EJECUCION FECHA, ' || '0 VALOR_RCA, ' ||
               'NVL(ODP_MONTO_ORDEN,0) VALOR_ODP, ' ||
               'ODP_CCC_CLI_PER_NUM_IDEN  CLI_PER_NUM_IDEN, ' ||
               'ODP_CCC_CLI_PER_TID_CODIGO CLI_PER_TID_CODIGO, ' ||
               'ODP_CCC_NUMERO_CUENTA CCC_NUMERO_CUENTA ' ||
               'FROM   ORDENES_DE_PAGO ' || 'WHERE ODP_ESTADO = ''APR'' ' ||
               'AND   ODP_ES_CLIENTE = ''S'' ' ||
               'AND   ODP_COT_MNEMONICO = ''GOPCF'' ' ||
               'AND   ODP_FECHA >  ''01-AGO-2006'' ' ||
               'AND   ODP_FECHA_EJECUCION < ' || CHR(39) ||
               TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               'AND   ODP_MONTO_ORDEN != 0 ' || 'UNION ALL ' ||
               'SELECT RCA_FECHA FECHA, ' || 'NVL(CCA_MONTO,0) VALOR_RCA, ' ||
               '0 VALOR_ODP, ' ||
               'RCA_CCC_CLI_PER_NUM_IDEN CLI_PER_NUM_IDEN, ' ||
               'RCA_CCC_CLI_PER_TID_CODIGO CLI_PER_TID_CODIGO, ' ||
               'RCA_CCC_NUMERO_CUENTA  CCC_NUMERO_CUENTA ' ||
               'FROM   RECIBOS_DE_CAJA, ' || 'CHEQUES_CAJA ' ||
               'WHERE    RCA_SUC_CODIGO= CCA_RCA_SUC_CODIGO  ' ||
               'AND    RCA_NEG_CONSECUTIVO = CCA_RCA_NEG_CONSECUTIVO ' ||
               'AND    RCA_CONSECUTIVO = CCA_RCA_CONSECUTIVO ' ||
               'AND    RCA_ES_CLIENTE = ''S'' ' ||
               'AND    RCA_REVERSADO = ''N'' ' ||
               'AND    RCA_COT_MNEMONICO = ''DGDE'' ' ||
               'AND    RCA_FECHA >  ''01-AGO-2006'' ' ||
               'AND    RCA_FECHA < ' || CHR(39) ||
               TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               'AND    CCA_MONTO != 0 ' || 'UNION ALL ' ||
               'SELECT RCA_FECHA FECHA, ' || 'NVL(CCJ_MONTO,0) VALOR_RCA, ' ||
               '0 VALOR_ODP, ' ||
               'RCA_CCC_CLI_PER_NUM_IDEN CLI_PER_NUM_IDEN, ' ||
               'RCA_CCC_CLI_PER_TID_CODIGO CLI_PER_TID_CODIGO, ' ||
               'RCA_CCC_NUMERO_CUENTA CCC_NUMERO_CUENTA ' ||
               'FROM   RECIBOS_DE_CAJA, ' || 'CONSIGNACIONES_CAJA  ' ||
               'WHERE  RCA_SUC_CODIGO= CCJ_RCA_SUC_CODIGO ' ||
               'AND  RCA_NEG_CONSECUTIVO = CCJ_RCA_NEG_CONSECUTIVO ' ||
               'AND  RCA_CONSECUTIVO = CCJ_RCA_CONSECUTIVO ' ||
               'AND  RCA_ES_CLIENTE = ''S''  ' ||
               'AND  RCA_REVERSADO = ''N'' ' ||
               'AND  RCA_COT_MNEMONICO = ''DGDE''  ' ||
               'AND  RCA_FECHA >  ''01-AGO-2006'' ' || 'AND  RCA_FECHA < ' ||
               CHR(39) || TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               'AND  CCJ_MONTO != 0 ' || 'UNION ALL ' ||
               'SELECT RCA_FECHA FECHA, ' || 'NVL(TRC_MONTO,0) VALOR_RCA, ' ||
               '0 VALOR_ODP, ' ||
               'RCA_CCC_CLI_PER_NUM_IDEN CLI_PER_NUM_IDEN, ' ||
               'RCA_CCC_CLI_PER_TID_CODIGO CLI_PER_TID_CODIGO, ' ||
               'RCA_CCC_NUMERO_CUENTA CCC_NUMERO_CUENTA ' ||
               'FROM   RECIBOS_DE_CAJA, ' || 'TRANSFERENCIAS_CAJA ' ||
               'WHERE  RCA_SUC_CODIGO= TRC_RCA_SUC_CODIGO ' ||
               'AND  RCA_NEG_CONSECUTIVO = TRC_RCA_NEG_CONSECUTIVO ' ||
               'AND  RCA_CONSECUTIVO = TRC_RCA_CONSECUTIVO ' ||
               'AND  RCA_ES_CLIENTE = ''S'' ' ||
               'AND  RCA_REVERSADO = ''N'' ' ||
               'AND  RCA_COT_MNEMONICO = ''DGDE''  ' ||
               'AND  RCA_FECHA >  ''01-AGO-2006''               ' ||
               'AND  RCA_FECHA < ' || CHR(39) ||
               TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               'AND  TRC_MONTO != 0 ' || 'UNION ALL ' ||
               'SELECT RCA_FECHA FECHA, ' ||
               'NVL(RCA_MONTO_EN_EFECTIVO,0) VALOR_RCA, ' ||
               '0 VALOR_ODP, ' ||
               'RCA_CCC_CLI_PER_NUM_IDEN CLI_PER_NUM_IDEN, ' ||
               'RCA_CCC_CLI_PER_TID_CODIGO CLI_PER_TID_CODIGO, ' ||
               'RCA_CCC_NUMERO_CUENTA CCC_NUMERO_CUENTA ' ||
               'FROM   RECIBOS_DE_CAJA ' ||
               'WHERE  RCA_ES_CLIENTE = ''S'' ' ||
               'AND  RCA_REVERSADO = ''N'' ' ||
               'AND  RCA_COT_MNEMONICO = ''DGDE'' ' ||
               'AND  RCA_FECHA >  ''01-AGO-2006'' ' || 'AND  RCA_FECHA < ' ||
               CHR(39) || TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               'AND  RCA_MONTO_EN_EFECTIVO != 0 ' || 'UNION ALL ' ||
               'SELECT ODP_FECHA_EJECUCION FECHA, ' || '0 VALOR_RCA, ' ||
               'NVL(ODP_MONTO_ORDEN,0) VALOR_ODP, ' ||
               'ODP_CCC_CLI_PER_NUM_IDEN CLI_PER_NUM_IDEN, ' ||
               'ODP_CCC_CLI_PER_TID_CODIGO CLI_PER_TID_CODIGO, ' ||
               'ODP_CCC_NUMERO_CUENTA  CCC_NUMERO_CUENTA  ' ||
               'FROM   ORDENES_DE_PAGO ' || 'WHERE ODP_ESTADO = ''APR'' ' ||
               'AND ODP_ES_CLIENTE = ''S'' ' ||
               'AND ODP_COT_MNEMONICO = ''CGDE'' ' ||
               'AND ODP_FECHA >  ''01-AGO-2006'' ' ||
               'AND ODP_FECHA_EJECUCION < ' || CHR(39) ||
               TO_CHAR(FECHA + 1, 'DD-MON-YYYY') || CHR(39) ||
               'AND (ODP_CEG_CONSECUTIVO IS NOT NULL ' ||
               'OR ODP_CGE_CONSECUTIVO IS NOT NULL ' ||
               'OR ODP_TBC_CONSECUTIVO IS NOT NULL ' ||
               'OR ODP_TCC_CONSECUTIVO IS NOT NULL)  ' ||
               'AND ODP_MONTO_ORDEN != 0 ' || ') TMP, ' ||
               ' CUENTAS_CLIENTE_CORREDORES CCC ' ||
               'WHERE TMP.CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN ' ||
               'AND TMP.CLI_PER_TID_CODIGO = CCC.CCC_CLI_PER_TID_CODIGO ' ||
               'AND TMP.CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA ' ||
               'GROUP BY CCC.CCC_CLI_PER_NUM_IDEN,CCC.CCC_CLI_PER_TID_CODIGO, CCC.CCC_NUMERO_CUENTA, CCC.CCC_PER_NUM_IDEN, CCC.CCC_PER_TID_CODIGO, FECHA ' ||
               'HAVING SUM(VALOR_ODP) - SUM(VALOR_RCA)!=0 ' || ' ) TMP2 ' ||
               ' GROUP BY CCC_CLI_PER_NUM_IDEN,CCC_CLI_PER_TID_CODIGO,CCC_NUMERO_CUENTA,CCC_PER_NUM_IDEN,CCC_PER_TID_CODIGO' ||
               ' HAVING ' || P_CONDICION;
      return(X_TEM);

    END;
  BEGIN

    DELETE FROM GL_MOVIMIENTOS_CUENTA;
    DELETE FROM TMP_FIRECA;
    IF FECHA = TRUNC(SYSDATE) THEN
      X_TEM := F_SQL_HOY(FECHA, RANGO, RANGO_MAX, RANGO1, RANGO_MAX1);
    ELSE
      X_TEM := F_SQL_DIAS_ANTERIORES(FECHA,
                                     RANGO,
                                     RANGO_MAX,
                                     RANGO1,
                                     RANGO_MAX1);
    END IF;

    execute immediate X_TEM;
    --nHash := hash (TO_CHAR (SYSDATE, 'YYYYMMDDSSSSS'));
    v_nombre_archivo := TO_CHAR(nHash, 'FM0999999999') || '_' ||
                        TO_CHAR(FECHA, 'DDMMYYYY') || '.csv';

    BUFLINE := 'TID;No ID;Cta;Cliente;Inic.;Sdo Cta Disponible;Ult. Mvto.;Dias;Saldo a Contado;Ult. Mvto.;Dias;' ||
               'Saldo a Plazo;Ult. Mvto.;Dias;Saldo Bursatil;Ult. Mvto.;Dias;Saldo Fondo;Ult. Mvto.;Dias;' ||
               'Sdo Admon Val;Ult. Mvto.;Dias;Sdo Derivados;Ult. Mvto.;Dias;Sdo Monetizado;Ult. Mvto.;Dias;' ||
               'Sdo Otras Moned;Ult. Mvto.;Dias;Sdo Garantżas;Ult. Mvto.;Dias;Sdo Remesas;Ult. Mvto.;Dias;' ||
               'Sdo Canje Corred;Ult. Mvto.;Dias;Sdo Canje Fics;Ult. Mvto.;Dias;PerfilRiesgo;SegmentoCliente';

    --  TEXT_IO.PUTF(ARCH, '%s\n', BUFLINE);

    OPEN C_CARTERA;
    FETCH C_CARTERA
      INTO R_CARTERA;
    WHILE C_CARTERA%FOUND LOOP
      --IF C_CARTERA%FOUND THEN
      --  LOOP

      BEGIN

        SELECT CLI_PERFIL_RIESGO, CLI_BSC_MNEMONICO
          INTO N_CLI_PERFIL_RIESGO, V_CLI_BSC_MNEMONICO
          FROM CLIENTES
         WHERE CLI_PER_NUM_IDEN = R_CARTERA.CCC_CLI_PER_NUM_IDEN
           AND CLI_PER_TID_CODIGO = R_CARTERA.CCC_CLI_PER_TID_CODIGO;

        BEGIN
          SELECT PERI_DESCRIPCION
            INTO P_PERFIL
            FROM PERFILES_RIESGO
           WHERE PERI_CONSECUTIVO = N_CLI_PERFIL_RIESGO;

        EXCEPTION
          WHEN NO_DATA_FOUND THEN
            P_PERFIL := NULL;
        END;

        BEGIN
          SELECT BSC_DESCRIPCION
            INTO P_SEGMENTO
            FROM BI_SEGMENTACION_CLIENTES
           WHERE BSC_MNEMONICO = V_CLI_BSC_MNEMONICO;
        EXCEPTION
          WHEN NO_DATA_FOUND THEN
            P_SEGMENTO := NULL;
        END;

      EXCEPTION
        WHEN OTHERS THEN
          P_PERFIL   := NULL;
          P_SEGMENTO := NULL;
      END;

      BEGIN
        INSERT INTO TMP_FIRECA
        VALUES
          (R_CARTERA.CCC_CLI_PER_TID_CODIGO,
           R_CARTERA.CCC_CLI_PER_NUM_IDEN,
           TO_CHAR(R_CARTERA.CCC_NUMERO_CUENTA),
           R_CARTERA.PER_NOMBRE,
           R_CARTERA.PER_PER_INICIALES_USUARIO,
           R_CARTERA.CCC_SALDO_CAPITAL,
           CASE WHEN R_CARTERA.CCC_SALDO_CAPITAL IS NULL THEN NULL ELSE
           R_CARTERA.FECHA_ULT_MOV_CAPITAL END,
           CASE WHEN R_CARTERA.CCC_SALDO_CAPITAL IS NULL THEN NULL
           ELSE(TRUNC(FECHA) - TRUNC(R_CARTERA.FECHA_ULT_MOV_CAPITAL)) END,
           R_CARTERA.CCC_SALDO_A_CONTADO,
           CASE WHEN R_CARTERA.CCC_SALDO_A_CONTADO IS NULL THEN NULL ELSE
           R_CARTERA.FECHA_ULT_MOV_CONTADO END,
           CASE WHEN R_CARTERA.CCC_SALDO_A_CONTADO IS NULL THEN NULL
           ELSE(TRUNC(FECHA) - TRUNC(R_CARTERA.FECHA_ULT_MOV_CONTADO)) END,
           R_CARTERA.CCC_SALDO_A_PLAZO,
           CASE WHEN R_CARTERA.CCC_SALDO_A_PLAZO IS NULL THEN NULL ELSE
           R_CARTERA.FECHA_ULT_MOV_PLAZO END,
           CASE WHEN R_CARTERA.CCC_SALDO_A_PLAZO IS NULL THEN NULL
           ELSE(TRUNC(FECHA) - TRUNC(R_CARTERA.FECHA_ULT_MOV_PLAZO)) END,
           R_CARTERA.CCC_SALDO_BURSATIL,
           CASE WHEN R_CARTERA.CCC_SALDO_BURSATIL IS NULL THEN NULL ELSE
           R_CARTERA.FECHA_ULT_MOV_BURSATIL END,
           CASE WHEN R_CARTERA.CCC_SALDO_BURSATIL IS NULL THEN NULL
           ELSE(TRUNC(FECHA) - TRUNC(R_CARTERA.FECHA_ULT_MOV_BURSATIL)) END,
           R_CARTERA.CCC_SALDO_CC,
           CASE WHEN R_CARTERA.CCC_SALDO_CC IS NULL THEN NULL ELSE
           R_CARTERA.FECHA_ULT_MOV_CC END,
           CASE WHEN R_CARTERA.CCC_SALDO_CC IS NULL THEN NULL
           ELSE(TRUNC(FECHA) - TRUNC(R_CARTERA.FECHA_ULT_MOV_CC)) END,
           R_CARTERA.CCC_SALDO_ADMON_VALORES,
           CASE WHEN R_CARTERA.CCC_SALDO_ADMON_VALORES IS NULL THEN NULL ELSE
           R_CARTERA.FECHA_ULT_MOV_ADVAL END,
           CASE WHEN R_CARTERA.CCC_SALDO_ADMON_VALORES IS NULL THEN NULL
           ELSE(TRUNC(FECHA) - TRUNC(R_CARTERA.FECHA_ULT_MOV_ADVAL)) END,
           R_CARTERA.MDD_SALDO,
           CASE WHEN R_CARTERA.MDD_SALDO IS NULL THEN NULL ELSE
           R_CARTERA.FECHA_ULT_MOV_DERIVADOS END,
           CASE WHEN R_CARTERA.MDD_SALDO IS NULL THEN NULL
           ELSE(TRUNC(FECHA) - TRUNC(R_CARTERA.FECHA_ULT_MOV_DERIVADOS)) END,
           R_CARTERA.MCM_SALDO_MONETIZAR,
           CASE WHEN R_CARTERA.MCM_SALDO_MONETIZAR IS NULL THEN NULL ELSE
           R_CARTERA.FECHA_ULT_MOV_MONETIZAR END,
           CASE WHEN R_CARTERA.MCM_SALDO_MONETIZAR IS NULL THEN NULL
           ELSE(TRUNC(FECHA) - TRUNC(R_CARTERA.FECHA_ULT_MOV_MONETIZAR)) END,
           R_CARTERA.SALDO_DOLARES,
           CASE WHEN R_CARTERA.SALDO_DOLARES IS NULL THEN NULL ELSE
           R_CARTERA.FECHA_ULT_MOV_DOLARES END,
           CASE WHEN R_CARTERA.SALDO_DOLARES IS NULL THEN NULL
           ELSE(TRUNC(FECHA) - TRUNC(R_CARTERA.FECHA_ULT_MOV_DOLARES)) END,
           R_CARTERA.SALDO_GARANTIA,
           CASE WHEN R_CARTERA.SALDO_GARANTIA IS NULL THEN NULL ELSE
           R_CARTERA.FECHA_ULT_MOV_GARANTIAS END,
           CASE WHEN R_CARTERA.SALDO_GARANTIA IS NULL THEN NULL
           ELSE(TRUNC(FECHA) - TRUNC(R_CARTERA.FECHA_ULT_MOV_GARANTIAS)) END,
           R_CARTERA.SALDO_REMESAS,
           CASE WHEN R_CARTERA.SALDO_REMESAS IS NULL THEN NULL ELSE
           R_CARTERA.FECHA_ULT_MOV_MONETIZAR END,
           CASE WHEN R_CARTERA.SALDO_REMESAS IS NULL THEN NULL
           ELSE(TRUNC(FECHA) - TRUNC(R_CARTERA.FECHA_ULT_MOV_MONETIZAR)) END,
           R_CARTERA.CCC_SALDO_CANJE,
           CASE WHEN R_CARTERA.CCC_SALDO_CANJE IS NULL THEN NULL ELSE
           R_CARTERA.FECHA_ULT_MOV_CANJE END,
           CASE WHEN R_CARTERA.CCC_SALDO_CANJE IS NULL THEN NULL
           ELSE(TRUNC(FECHA) - TRUNC(R_CARTERA.FECHA_ULT_MOV_CANJE)) END,
           R_CARTERA.CCC_SALDO_CANJE_CC,
           CASE WHEN R_CARTERA.CCC_SALDO_CANJE_CC IS NULL THEN NULL ELSE
           R_CARTERA.FECHA_ULT_MOV_CANJE_CC END,
           CASE WHEN R_CARTERA.CCC_SALDO_CANJE_CC IS NULL THEN NULL
           ELSE(TRUNC(FECHA) - TRUNC(R_CARTERA.FECHA_ULT_MOV_CANJE_CC)) END,
           P_PERFIL,
           P_SEGMENTO);
        P_PERFIL   := NULL;
        P_SEGMENTO := NULL;
        COMMIT;
      EXCEPTION
        WHEN OTHERS THEN
          DBMS_OUTPUT.PUT_LINE(SQLERRM || 'ERROR');
      END;
      -- TEXT_IO.PUTF(ARCH, '%s\n', BUFLINE);
      FETCH C_CARTERA
        INTO R_CARTERA;
      -- EXIT WHEN C_CARTERA%NOTFOUND;
    END LOOP;
    CLOSE C_CARTERA;
    V_RUTA           := '\\nas.corredor.local\Riesgo\CONFIDENCIAL\Reportes Excel Coeasy\';
    V_NOMBRE_ARCHIVO := 'CARTERA_' || TO_CHAR(SYSDATE - 1, 'DDMMYYYY');

    --LLAMADO AL PROGRAMA QUE CREA EL XSLX
    P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => V_RUTA,
                                   P_NOMBRE_ARCHIVO => V_NOMBRE_ARCHIVO,
                                   P_QUERY          => 'SELECT *  FROM TMP_FIRECA',
                                   P_CODIGO         => P_CODIGO,
                                   P_RESPUESTA      => P_RESPUESTA);
    IF P_CODIGO = '0000' THEN
      DBMS_OUTPUT.PUT_LINE('Se ha generado el archivo, en la ruta ' ||
                           V_RUTA);
    END IF;

  EXCEPTION
    WHEN OTHERS THEN
      DBMS_OUTPUT.PUT_LINE('Se ha generado el archivo, en la ruta ' ||
                           V_RUTA);
  END P_EJECUTA_FIRECA;

  PROCEDURE P_EJECUTA_RFLVNF IS
    CURSOR C2 IS -- FLUJOS TODOS LOS FONDOS
      SELECT DISTINCT TFO_FON_CODIGO,
                      TFO_CODIGO,
                      TFO_NUMERO_TITULO_FISICO,
                      DECODE(TFO_TYPE,
                             'TRF',
                             TFO_VALOR_NOMINAL,
                             TFO_CANTIDAD) TFO_NOMINAL_CANTIDAD,
                      DECODE(TFO_TRE_MNEMONICO,
                             NULL,
                             TO_CHAR(TFO_TASA_FACIAL * 100, '99.999'),
                             TFO_TRE_MNEMONICO || '+' ||
                             TO_CHAR(TFO_PUNTOS_ADICIONALES, '9.99')) TFO_TASA,
                      TFO_LTI_MNEMONICO,
                      GNA_MNEMONICO GNA_MNEMONICO,
                      EMI_DESCRIPCION EMI_DESCRIPCION,
                      ENA_MNEMONICO ENA_MNEMONICO,
                      MAC3.MAC_FECHA MV_FECHA,
                      MAC3.MAC_TMT_MNEMONICO MV_TMT_MNEMONICO,
                      TMT_DESCRIPCION,
                      0 MV_CAPITAL,
                      0 MV_INTERES,
                      MAC3.MAC_MONTO MV_DIVIDENDOS,
                      MAC3.MAC_UTILIDAD - MAC3.MAC_PERDIDA MV_UTILIDAD_PERDIDA,
                      MAC3.MAC_TFO_CODIGO MV_TFO_CODIGO,
                      TFO_FECHA_OPERACION MV_FECHA_OPERACION
        FROM MVTOS_ACCION MAC3,
             TITULOS_FONDOS,
             TIPOS_MOVIMIENTOS_TITULOS,
             ESPECIES_NACIONALES,
             GRUPOS_NACIONALES,
             EMISORES
       WHERE MAC3.MAC_FECHA >= TRUNC(SYSDATE) - 1
         AND MAC3.MAC_FECHA < TRUNC(SYSDATE)
         AND MAC3.MAC_TMT_MNEMONICO = 'CDV'
         AND MAC3.MAC_TFO_FON_CODIGO = TFO_FON_CODIGO
         AND MAC3.MAC_TFO_CODIGO = TFO_CODIGO
         AND MAC3.MAC_TMT_MNEMONICO = TMT_MNEMONICO
         AND ENA_MNEMONICO = TFO_ENA_MNEMONICO
            --AND EMI_MNEMONICO = :FILTRO.EMISOR
         AND EMI_MNEMONICO = ENA_EMI_MNEMONICO
            --AND GNA_MNEMONICO = :FILTRO.ESPECIE
         AND GNA_MNEMONICO = ENA_GNA_MNEMONICO
      UNION
      SELECT DISTINCT TFO_FON_CODIGO,
                      TFO_CODIGO,
                      TFO_NUMERO_TITULO_FISICO,
                      DECODE(TFO_TYPE,
                             'TRF',
                             TFO_VALOR_NOMINAL,
                             TFO_CANTIDAD) TFO_NOMINAL_CANTIDAD,
                      DECODE(TFO_TRE_MNEMONICO,
                             NULL,
                             TO_CHAR(TFO_TASA_FACIAL * 100, '99.999'),
                             TFO_TRE_MNEMONICO || '+' ||
                             TO_CHAR(TFO_PUNTOS_ADICIONALES, '9.99')) TFO_TASA,
                      TFO_LTI_MNEMONICO,
                      GNA_MNEMONICO GNA_MNEMONICO,
                      EMI_DESCRIPCION EMI_DESCRIPCION,
                      ENA_MNEMONICO ENA_MNEMONICO,
                      MRF4.MRF_FECHA MV_FECHA,
                      MRF4.MRF_TMT_MNEMONICO MV_TMT_MNEMONICO,
                      TMT_DESCRIPCION,
                      MRF4.MRF_CAPITAL MV_CAPITAL,
                      MRF4.MRF_INTERES MV_INTERES,
                      0 MV_DIVIDENDOS,
                      MRF4.MRF_UTILIDAD + MRF4.MRF_PERDIDA MV_UTILIDAD_PERDIDA,
                      MRF4.MRF_TFO_CODIGO MV_TFO_CODIGO,
                      TFO_FECHA_OPERACION MV_FECHA_OPERACION
        FROM MVTOS_RENTA_FIJA MRF4,
             TIPOS_MOVIMIENTOS_TITULOS,
             TITULOS_FONDOS,
             ESPECIES_NACIONALES,
             GRUPOS_NACIONALES,
             EMISORES
       WHERE MRF4.MRF_FECHA >= TRUNC(SYSDATE) - 1
         AND MRF4.MRF_FECHA < TRUNC(SYSDATE)
         AND MRF4.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
         AND MRF4.MRF_TFO_CODIGO = TFO_CODIGO
         AND MRF4.MRF_TMT_MNEMONICO = TMT_MNEMONICO
         AND TMT_MNEMONICO IN ('RED', 'REN', 'CDV', 'AMR')
         AND ENA_MNEMONICO = TFO_ENA_MNEMONICO
            -- AND EMI_MNEMONICO = :FILTRO.EMISOR
         AND EMI_MNEMONICO = ENA_EMI_MNEMONICO
            --AND GNA_MNEMONICO = :FILTRO.ESPECIE
         AND GNA_MNEMONICO = ENA_GNA_MNEMONICO;

    --  IN_FILE            TEXT_IO.FILE_TYPE;
    LINEA             VARCHAR2(1000);
    LINEA_AUX         VARCHAR2(1000);
    BUFLINE           VARCHAR2(30);
    mi_nombre_archivo VARCHAR2(100);
    nHash             NUMBER;
    V_OPERACION       VARCHAR2(100);
    V_TIPO_ACTIVO     VARCHAR2(10);
    V_NOMBRE          VARCHAR2(1000);
    V_TMT_MNEMO       VARCHAR2(100);

    P_CODIGO         VARCHAR2(200);
    P_RESPUESTA      VARCHAR2(200);
    V_RUTA           VARCHAR2(100);
    V_NOMBRE_ARCHIVO VARCHAR2(1000);

    FUNCTION NOMBRE_FONDO(P_FONDO VARCHAR2) RETURN VARCHAR2 IS
      V_NOMBRE VARCHAR2(100);
    BEGIN
      SELECT FON_RAZON_SOCIAL
        INTO V_NOMBRE
        FROM FONDOS
       WHERE FON_CODIGO = P_FONDO;
      RETURN V_NOMBRE;
    EXCEPTION
      WHEN NO_DATA_FOUND THEN
        V_NOMBRE := NULL;
        RETURN V_NOMBRE;
    END;
    FUNCTION RF_RV(P_NEMOTECNICO VARCHAR2) RETURN VARCHAR2 IS
      V_TIPO VARCHAR2(10);
    BEGIN
      SELECT DISTINCT DECODE(TFO_TYPE, 'TAC', 'RV', 'TRF', 'RF')
        INTO V_TIPO
        FROM TITULOS_FONDOS
       WHERE TFO_ENA_MNEMONICO = P_NEMOTECNICO
         AND ROWNUM = 1;
      RETURN V_TIPO;
    EXCEPTION
      WHEN NO_DATA_FOUND THEN
        V_TIPO := NULL;
        RETURN V_TIPO;
    END;
  BEGIN

    DELETE FROM GL_RFLVNF;

    FOR R2 IN C2 LOOP
      BEGIN
        SELECT MRF_TMT_MNEMONICO
          INTO V_TMT_MNEMO
          FROM MVTOS_RENTA_FIJA
         WHERE MRF_TFO_CODIGO = R2.TFO_CODIGO
           AND MRF_TFO_FON_CODIGO = R2.TFO_FON_CODIGO
           AND MRF_FECHA =
               (SELECT MIN(MRF_FECHA)
                  FROM MVTOS_RENTA_FIJA
                 WHERE MRF_TFO_CODIGO = R2.TFO_CODIGO
                   AND MRF_TFO_FON_CODIGO = R2.TFO_FON_CODIGO)
           AND ROWNUM = 1;
      EXCEPTION
        WHEN OTHERS THEN
          V_TMT_MNEMO := NULL;
      END;

      IF V_TMT_MNEMO = 'OCO' THEN
        V_OPERACION := 'OBLIG.COMPRA';
      ELSIF V_TMT_MNEMO = 'DVE' THEN
        V_OPERACION := 'DEREC.VENTA';
      ELSIF V_TMT_MNEMO = 'FAF' THEN
        V_OPERACION := 'SIM. ACTIVA';
      ELSIF V_TMT_MNEMO = 'FPF' THEN
        V_OPERACION := 'SIM. PASIVA';
      ELSIF V_TMT_MNEMO = 'VRF' THEN
        V_OPERACION := 'VENTA RENTA FIJA';
      ELSIF V_TMT_MNEMO = 'CRV' THEN
        V_OPERACION := 'COMPRA RENTA VARIABLE';
      ELSIF V_TMT_MNEMO = 'CRF' THEN
        V_OPERACION := 'COMPRA RENTA FIJA';
      ELSIF V_TMT_MNEMO = 'VRV' THEN
        V_OPERACION := 'VENTA RENTA VARIABLE';
      ELSE
        V_OPERACION := NULL;
      END IF;
      --V_OPERACION := NULL;
      V_TIPO_ACTIVO := RF_RV(R2.ENA_MNEMONICO);
      V_NOMBRE      := NOMBRE_FONDO(R2.TFO_FON_CODIGO);
      INSERT INTO GL_RFLVNF
        (NIT_FONDO,
         NOMBRE_FONDO,
         TIPO_MOVIMIENTO,
         TIPO_ACTIVO,
         FECHA_OPERACION,
         FECHA,
         TFO_CODIGO,
         GNA_MNEMONICO,
         EMI_DESCRIPCION,
         ENA_MNEMONICO,
         NOMINAL_CANTIDAD,
         TFO_TASA,
         CAPITAL,
         INTERES,
         DIVIDENDOS,
         UTILIDAD_PERDIDA,
         TIPO_OPERACION)
      VALUES
        (R2.TFO_FON_CODIGO,
         V_NOMBRE,
         R2.MV_TMT_MNEMONICO,
         V_TIPO_ACTIVO,
         TRUNC(R2.MV_FECHA_OPERACION),
         TRUNC(R2.MV_FECHA),
         R2.TFO_CODIGO,
         R2.GNA_MNEMONICO,
         R2.EMI_DESCRIPCION,
         R2.ENA_MNEMONICO,
         R2.TFO_NOMINAL_CANTIDAD,
         R2.TFO_TASA,
         R2.MV_CAPITAL,
         R2.MV_INTERES,
         R2.MV_DIVIDENDOS,
         R2.MV_UTILIDAD_PERDIDA,
         V_OPERACION);
    END LOOP;
    COMMIT;

    V_RUTA           := '\\nas.corredor.local\Riesgo\CONFIDENCIAL\Reportes Excel Coeasy\';
    V_NOMBRE_ARCHIVO := 'RFLVNF_' || TO_CHAR(SYSDATE - 1, 'DDMMYYYY');

    --LLAMADO AL PROGRAMA QUE CREA EL XSLX
    P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => V_RUTA,
                                   P_NOMBRE_ARCHIVO => V_NOMBRE_ARCHIVO,
                                   P_QUERY          => 'SELECT *  FROM GL_RFLVNF',
                                   P_CODIGO         => P_CODIGO,
                                   P_RESPUESTA      => P_RESPUESTA);
    IF P_CODIGO = '0000' THEN
      DBMS_OUTPUT.PUT_LINE('Se ha generado el archivo, en la ruta ' ||
                           V_RUTA);
    END IF;
  END P_EJECUTA_RFLVNF;

  PROCEDURE P_EJECUTA_REINEG IS

    CURSOR C5 IS -- TODOS LOS TIPOS TODOS LOS FONDOS
      SELECT OIE_PYG_FECHA,
             OIE_PYG_FON_CODIGO,
             OIE_CIE_MNEMONICO,
             OIE_MONTO
        FROM OTROS_INGRESOS_EGRESOS
       WHERE EXISTS (SELECT 'X'
                FROM CONCEPTOS_OTRO_INGRESO_EGRESO
               WHERE CIE_MNEMONICO = OIE_CIE_MNEMONICO)
         AND OIE_PYG_FECHA >= TRUNC(SYSDATE - 1) -- VAGTUD975-6
         AND OIE_PYG_FECHA < TRUNC(SYSDATE); -- VAGTUD975-6

    C_TODOS C5%ROWTYPE;

    CURSOR ING_EGR IS
      SELECT FON_CODIGO, CONCEPTO, MONTO FROM GL_REINEG1;

    --IN_FILE            TEXT_IO.FILE_TYPE;
    LINEA             VARCHAR2(1000);
    LINEA_AUX         VARCHAR2(1000);
    BUFLINE           VARCHAR2(30);
    mi_nombre_archivo VARCHAR2(100);
    nHash             NUMBER;
    REGISTROS         NUMBER;
    V_COMERCIAL       VARCHAR2(100);
    V_FECHA_PAGO      DATE;
    V_IBA             NUMBER;
    V_IBC             NUMBER;
    V_NOMBRE          VARCHAR2(500);
    V_TIPO            VARCHAR2(10);
    V_DESCRIPCION     VARCHAR2(500);
    V_COMPONENTE      NUMBER;
    V_DESC            VARCHAR2(1000);
    V_TIPO_C          VARCHAR2(10);
    V_GC              VARCHAR2(10);
    --
    P_CODIGO          VARCHAR2(200);
    P_RESPUESTA       VARCHAR2(200);
    V_RUTA            VARCHAR2(100);
    V_NOMBRE_ARCHIVO  VARCHAR2(1000);
    V_NOMBRE_ARCHIVO2 VARCHAR2(1000);

    FUNCTION RAZON_SOCIAL(P_NIT VARCHAR2) RETURN VARCHAR2 IS
      V_NOMBRE VARCHAR2(100);
    BEGIN
      SELECT FON_RAZON_SOCIAL
        INTO V_NOMBRE
        FROM FONDOS
       WHERE FON_CODIGO = P_NIT;
      RETURN V_NOMBRE;
    EXCEPTION
      WHEN NO_DATA_FOUND THEN
        V_NOMBRE := NULL;
        RETURN V_NOMBRE;
    END;
    --
    FUNCTION TIPO(P_MNEMONICO VARCHAR2) RETURN VARCHAR2 IS
      V_TIPO VARCHAR2(20);
    BEGIN
      SELECT DECODE(CIE_TIPO, 'EGR', 'EGRESO', 'ING', 'INGRESO')
        INTO V_TIPO
        FROM CONCEPTOS_OTRO_INGRESO_EGRESO
       WHERE CIE_MNEMONICO = P_MNEMONICO;

      RETURN V_TIPO;
    EXCEPTION
      WHEN NO_DATA_FOUND THEN
        V_TIPO := NULL;
        RETURN V_TIPO;
    END;
    --
    FUNCTION P_N_CONCEPTO(P_MNEMONICO VARCHAR2, P_FONDO VARCHAR2)
      RETURN VARCHAR2 IS
      V_DESCRIPCION VARCHAR2(500);
    BEGIN

      SELECT DISTINCT CIE_DESCRIPCION --DECODE(CIR_TIPO,'GC', CIR_DESCRIPCION, CIE_DESCRIPCION)
        INTO V_DESCRIPCION
        FROM COMPONENTES_INVERSION_RETEFUEN,
             CONCEPTOS_OTRO_INGRESO_EGRESO,
             OTROS_INGRESOS_EGRESOS
       WHERE CIR_MNEMONICO(+) = CIE_CIR_MNEMONICO
         AND CIE_MNEMONICO = OIE_CIE_MNEMONICO
         AND OIE_PYG_FECHA >= TRUNC(SYSDATE - 1) -- VAGTUD975-6
         AND OIE_PYG_FECHA < TRUNC(SYSDATE) -- VAGTUD975-6
         AND OIE_PYG_FON_CODIGO = P_FONDO
         AND CIE_MNEMONICO = P_MNEMONICO;

      RETURN V_DESCRIPCION;
    EXCEPTION
      WHEN NO_DATA_FOUND THEN
        V_DESCRIPCION := NULL;
        RETURN V_DESCRIPCION;
    END;
    --
    FUNCTION COMPONENTE(P_MNEMONICO VARCHAR2, P_FONDO VARCHAR2) RETURN NUMBER IS
      V_COMPONENTE NUMBER;
    BEGIN
      SELECT DISTINCT CIE_CIR_MNEMONICO
        INTO V_COMPONENTE
        FROM COMPONENTES_INVERSION_RETEFUEN,
             CONCEPTOS_OTRO_INGRESO_EGRESO,
             OTROS_INGRESOS_EGRESOS
       WHERE CIR_MNEMONICO(+) = CIE_CIR_MNEMONICO
         AND CIE_MNEMONICO = OIE_CIE_MNEMONICO
         AND OIE_PYG_FECHA >= TRUNC(SYSDATE - 1) -- VAGTUD975-6
         AND OIE_PYG_FECHA < TRUNC(SYSDATE) -- VAGTUD975-6
         AND OIE_PYG_FON_CODIGO = P_FONDO
         AND CIE_MNEMONICO = P_MNEMONICO;
      RETURN V_COMPONENTE;
    EXCEPTION
      WHEN NO_DATA_FOUND THEN
        V_COMPONENTE := NULL;
        RETURN V_COMPONENTE;
    END;
    --
    FUNCTION DESCR_COMPONENTE(P_MNEMONICO VARCHAR2, P_FONDO VARCHAR2)
      RETURN VARCHAR2 IS
      V_DESCR VARCHAR2(500);
      --V_GC    VARCHAR2(10);
    BEGIN

      SELECT DISTINCT CIR_DESCRIPCION --DECODE(CIE_GASTO_COMUN,'N', CIR_DESCRIPCION, 'S',CIE_DESCRIPCION)
        INTO V_DESCR
        FROM COMPONENTES_INVERSION_RETEFUEN,
             CONCEPTOS_OTRO_INGRESO_EGRESO,
             OTROS_INGRESOS_EGRESOS
       WHERE CIR_MNEMONICO(+) = CIE_CIR_MNEMONICO
         AND CIE_MNEMONICO = OIE_CIE_MNEMONICO
         AND OIE_PYG_FECHA >= TRUNC(SYSDATE - 1) -- VAGTUD975-6
         AND OIE_PYG_FECHA < TRUNC(SYSDATE) -- VAGTUD975-6
         AND OIE_PYG_FON_CODIGO = P_FONDO
         AND CIE_MNEMONICO = P_MNEMONICO;
      RETURN V_DESCR;
    EXCEPTION
      WHEN NO_DATA_FOUND THEN
        V_DESCR := NULL;
        RETURN V_DESCR;
    END;
    --
    FUNCTION TIPO_CONCEPTO(P_MNEMO VARCHAR2, P_FONDO VARCHAR2)
      RETURN VARCHAR2 IS
      V_TIPO VARCHAR2(10);
    BEGIN
      SELECT DISTINCT CIR_TIPO
        INTO V_TIPO
        FROM COMPONENTES_INVERSION_RETEFUEN,
             CONCEPTOS_OTRO_INGRESO_EGRESO,
             OTROS_INGRESOS_EGRESOS
       WHERE CIR_MNEMONICO(+) = CIE_CIR_MNEMONICO
         AND CIE_MNEMONICO = OIE_CIE_MNEMONICO
         AND OIE_PYG_FECHA >= TRUNC(SYSDATE - 1) -- VAGTUD975-6
         AND OIE_PYG_FECHA < TRUNC(SYSDATE) -- VAGTUD975-6
         AND OIE_PYG_FON_CODIGO = P_FONDO
         AND CIE_MNEMONICO = P_MNEMO;
      RETURN V_TIPO;
    EXCEPTION
      WHEN NO_DATA_FOUND THEN
        V_TIPO := NULL;
        RETURN V_TIPO;
    END;
    --
    FUNCTION GC(P_MNEMO VARCHAR2, P_FONDO VARCHAR2) RETURN VARCHAR2 IS
      V_GC VARCHAR2(10);
    BEGIN
      SELECT DISTINCT CIE_GASTO_COMUN
        INTO V_GC
        FROM COMPONENTES_INVERSION_RETEFUEN,
             CONCEPTOS_OTRO_INGRESO_EGRESO,
             OTROS_INGRESOS_EGRESOS
       WHERE CIR_MNEMONICO(+) = CIE_CIR_MNEMONICO
         AND CIE_MNEMONICO = OIE_CIE_MNEMONICO
         AND OIE_PYG_FECHA >= TRUNC(SYSDATE - 1) -- VAGTUD975-6
         AND OIE_PYG_FECHA < TRUNC(SYSDATE) -- VAGTUD975-6
         AND OIE_PYG_FON_CODIGO = P_FONDO
         AND CIE_MNEMONICO = P_MNEMO;
      RETURN V_GC;
    EXCEPTION
      WHEN NO_DATA_FOUND THEN
        V_GC := NULL;
        RETURN V_GC;
    END;
  BEGIN

    DELETE FROM GL_REINEG1;
    COMMIT;

    OPEN C5;
    FETCH C5
      INTO C_TODOS;
    WHILE C5%FOUND LOOP
      INSERT INTO GL_REINEG1
        (FON_CODIGO, CONCEPTO, MONTO, FECHA)
      VALUES
        (C_TODOS.OIE_PYG_FON_CODIGO,
         C_TODOS.OIE_CIE_MNEMONICO,
         C_TODOS.OIE_MONTO,
         TRUNC(C_TODOS.OIE_PYG_FECHA));
      FETCH C5
        INTO C_TODOS;
    END LOOP;
    CLOSE C5;
    COMMIT;

    FOR R1 IN ING_EGR LOOP

      V_NOMBRE      := RAZON_SOCIAL(R1.FON_CODIGO);
      V_TIPO        := TIPO(R1.CONCEPTO);
      V_DESCRIPCION := P_N_CONCEPTO(R1.CONCEPTO, R1.FON_CODIGO);
      V_COMPONENTE  := COMPONENTE(R1.CONCEPTO, R1.FON_CODIGO);
      V_DESC        := DESCR_COMPONENTE(R1.CONCEPTO, R1.FON_CODIGO);
      V_TIPO_C      := TIPO_CONCEPTO(R1.CONCEPTO, R1.FON_CODIGO);
      V_GC          := GC(R1.CONCEPTO, R1.FON_CODIGO);

      UPDATE GL_REINEG1
         SET RAZON_SOCIAL           = V_NOMBRE,
             TIPO_I_E               = V_TIPO,
             DESCRIPCION            = V_DESCRIPCION,
             COMPONENTE             = V_COMPONENTE,
             DESCRIPCION_COMPONENTE = V_DESC,
             TIPO                   = V_TIPO_C,
             GC                     = V_GC
       WHERE FON_CODIGO = R1.FON_CODIGO
         AND CONCEPTO = R1.CONCEPTO;
      COMMIT;

    END LOOP;

    V_RUTA            := '\\nas.corredor.local\Riesgo\CONFIDENCIAL\Reportes Excel Coeasy\';
    V_NOMBRE_ARCHIVO  := 'REINEG_' || TO_CHAR(SYSDATE - 1, 'DDMMYYYY');
    V_NOMBRE_ARCHIVO2 := 'REINEG_' || TO_CHAR(SYSDATE - 1, 'YYYYMMDD'); -- VAGTUD975-6 ARCHIVO PARA CONTABILIDAD

    --LLAMADO AL PROGRAMA QUE CREA EL XSLX
    P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => V_RUTA,
                                   P_NOMBRE_ARCHIVO => V_NOMBRE_ARCHIVO,
                                   P_QUERY          => 'SELECT *  FROM GL_REINEG1',
                                   P_CODIGO         => P_CODIGO,
                                   P_RESPUESTA      => P_RESPUESTA);
    IF P_CODIGO = '0000' THEN
      DBMS_OUTPUT.PUT_LINE('Se ha generado el archivo, en la ruta ' ||
                           V_RUTA);
    END IF;

    -- VAGTUD975-6 Se adiciona carpeta de contabilidad
    V_RUTA := '\\nas.corredor.local\contabilidad\PRIVADA\Reportes transmisiones\Diarios\';
    P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => V_RUTA,
                                   P_NOMBRE_ARCHIVO => V_NOMBRE_ARCHIVO2,
                                   P_QUERY          => 'SELECT *  FROM GL_REINEG1',
                                   P_CODIGO         => P_CODIGO,
                                   P_RESPUESTA      => P_RESPUESTA);
    IF P_CODIGO = '0000' THEN
      DBMS_OUTPUT.PUT_LINE('Se ha generado el archivo, en la ruta ' ||
                           V_RUTA);
    END IF;

  END P_EJECUTA_REINEG;

  PROCEDURE P_EJECUTA_MANSIM IS
    P_CALIFICACION_COR           VARCHAR2(10);
    P_PPO_FUG_ISI_MNEMONICO      VARCHAR2(10);
    P_CODIGO_SUPER               NUMBER;
    P_CODIGO_CALIFICADORA        VARCHAR2(10);
    P_CODIGO_SUPER_COR           VARCHAR2(10);
    P_CODIGO_CALIFICADORA_COR    VARCHAR2(10);
    P_EXTERNA_INTERNA            VARCHAR2(10);
    P_ESTADO_CALIFICA            VARCHAR2(100);
    P_DSP_CALIFICACION           VARCHAR2(10);
    P_DSP_TASA_PIP               NUMBER(9, 5);
    P_DSP_TASA_INF               NUMBER(12, 5);
    P_DSP_TOTAL_POSICION         VARCHAR2(22);
    P_DSP_TOTAL_PORTAFOLIO       VARCHAR2(22);
    P_DSP_COSTO_PROM_COMPRA_FIN  NUMBER(22, 2);
    P_DSP_DISTRIBUIR             VARCHAR2(22);
    P_DSP_VALOR_DISTRIBUIR       VARCHAR2(22);
    P_DSP_TOTAL_POSICION_DEFINI  VARCHAR2(22);
    P_DSP_VALOR_GIRO             VARCHAR2(22);
    P_DSP_TOTAL_SIMULTANEAS      VARCHAR2(22);
    P_DSP_TOTAL_FONDEOS_INTERNOS VARCHAR2(22);
    P_DSP_TOTAL_POSICION_T1      VARCHAR2(22);
    P_DSP_TOTAL_POSICION_T2      VARCHAR2(22);
    P_DSP_TOTAL_POSICION_T3      VARCHAR2(22);
    P_DSP_TOTAL_POSICION_TN      VARCHAR2(22);

    V_RUTA         VARCHAR2(100);
    NOMBRE_ARCHIVO VARCHAR2(100);
    P_CODIGO       VARCHAR2(200);
    P_RESPUESTA    VARCHAR2(200);
    NOMBRE         VARCHAR2(100);

    CURSOR C_COMERCIAL IS
      SELECT PER1.PER_NUM_IDEN,
             PER1.PER_TID_CODIGO,
             PCP_CPR_MNEMONICO,
             PER1.PER_PRIMER_APELLIDO
        FROM CENTROS_PRODUCCION,
             PERSONAS_CENTROS_PRODUCCION,
             PERSONAS                    PER1,
             FILTRO_PERSONAS             PER2
       WHERE CPR_ESTADO = 'A'
         AND CPR_MNEMONICO = PCP_CPR_MNEMONICO
         AND PCP_PER_NUM_IDEN = PER1.PER_NUM_IDEN
         AND PCP_PER_TID_CODIGO = PER1.PER_TID_CODIGO
         AND PCP_PRINCIPAL = 'S'
         AND PER1.PER_NUM_IDEN = PER2.PER_NUM_IDEN
         AND PER1.PER_TID_CODIGO = PER2.PER_TID_CODIGO
         AND PER1.PER_NUM_IDEN IN
             ('860079174-1', '8600790174-2', '860079174-3', '8600791749')
         AND PER1.PER_TID_CODIGO = 'CC'
         AND PER1.PER_ES_CORREDOR = 'S'
       ORDER BY PER2.PER_NOMBRE;
    R_COMERCIAL C_COMERCIAL%ROWTYPE;

    CURSOR C_PORTAFOLIO_POSI(P_PER_NUM_IDEN   VARCHAR2,
                             P_PER_TID_CODIGO VARCHAR2) IS
      SELECT PPO_ENA_MNEMONICO,
             PPO_FUG_ISI_MNEMONICO,
             PPO_PORTAFOLIO_CERRADO,
             PPO_FECHA_VENCIMIENTO,
             PPO_TASA_EFECTIVA,
             PPO_VALOR_MIL_MILLONES,
             PPO_TOTAL_SIMULTANEAS,
             PPO_TOTAL_FONDEOS_INTERNOS,
             PPO_TOTAL_POSICION_T1,
             PPO_TOTAL_POSICION_T2,
             PPO_TOTAL_POSICION_T3,
             PPO_TOTAL_POSICION_TN,
             PPO_FECHA_EMISION,
             PPO_TASA_FACIAL,
             PPO_TRE_MNEMONICO,
             PPO_PUNTOS_ADICIONALES,
             PPO_PERIODICIDAD_TASA,
             PPO_MODALIDAD_TASA,
             PPO_CODIGO_PERIODO,
             PPO_BASE_CALCULO,
             PPO_TIPO_PAGO_FLUJO,
             PPO_CAPITALIZABLE,
             PPO_AMORTIZABLE,
             PPO_BMO_MNEMONICO,
             PPO_TFO_CODIGO,
             PPO_CONSECUTIVO,
             PPO_NPO_CONSECUTIVO,
             PPO_PER_NUM_IDEN,
             PPO_PER_TID_CODIGO,
             PPO_COSTO_PROM_COMPRA_INICIAL,
             PPO_TOTAL_NOMINAL_INICIAL,
             PPO_PRECIO_LIMPIO
        FROM PORTAFOLIOS_POSICION
       WHERE PPO_FECHA >= TRUNC(SYSDATE - 1)
         AND PPO_FECHA < TRUNC(SYSDATE)
         AND PPO_TIPO = 'POS'
         AND PPO_PER_NUM_IDEN = P_PER_NUM_IDEN
         AND PPO_PER_TID_CODIGO = P_PER_TID_CODIGO
       ORDER BY PPO_ENA_MNEMONICO;
    R_PORTAFOLIO_POSI C_PORTAFOLIO_POSI%ROWTYPE;

    CURSOR C_DIA_HABIL(P_FECHA_P DATE) IS
      SELECT 'X'
        FROM DIAS_NO_HABILES
       WHERE TRUNC(DNH_FECHA) = TRUNC(P_FECHA_P);
    COND VARCHAR2(1);

    -- Cursor que trae los datos de la valoracion del dia anterior
    CURSOR C_MRF(P_FECHA DATE, P_PPO_TFO_CODIGO VARCHAR2) IS
      SELECT MRF_TASA_DESCUENTO,
             MRF_PROV_PRINCIPAL,
             MRF_TASA_DESCUENTO_ALT,
             MRF_PROV_ALTERNO
        FROM MVTOS_RENTA_FIJA
       WHERE TRUNC(MRF_FECHA) >= TRUNC(P_FECHA)
         AND TRUNC(MRF_FECHA) < TRUNC(P_FECHA + 1)
         AND MRF_TFO_FON_CODIGO = '860079174'
         AND MRF_TMT_MNEMONICO = 'VAF'
         AND MRF_TFO_CODIGO = P_PPO_TFO_CODIGO;
    MRF1    C_MRF%ROWTYPE;
    V_FECHA DATE;
    ---
    FUNCTION FN_CALCULA_PRECIO_PROMEDIO(P_PPO_NPO_CONSECUTIVO       NUMBER,
                                        P_FECHA                     DATE,
                                        P_PPO_ENA_MNEMONICO         VARCHAR2,
                                        P_PPO_BMO_MNEMONICO         VARCHAR2,
                                        P_PPO_FECHA_EMISION         DATE,
                                        P_PPO_FECHA_VENCIMIENTO     DATE,
                                        P_PPO_PERIODICIDAD_TASA     NUMBER,
                                        P_PPO_BASE_CALCULO          VARCHAR2,
                                        P_PPO_MODALIDAD_TASA        VARCHAR2,
                                        P_PPO_TASA_FACIAL           NUMBER,
                                        P_PPO_TRE_MNEMONICO         VARCHAR2,
                                        P_PPO_PUNTOS_ADICIONALES    NUMBER,
                                        P_PPO_TIPO_PAGO_FLUJO       VARCHAR2,
                                        P_PPO_AMORTIZABLE           VARCHAR2,
                                        P_PPO_CAPITALIZABLE         VARCHAR2,
                                        P_PPO_CODIGO_PERIODO        VARCHAR2,
                                        P_PPO_PER_NUM_IDEN          VARCHAR2,
                                        P_PPO_PER_TID_CODIGO        VARCHAR2,
                                        P_PPO_COSTO_PROM_COMPRA_INI NUMBER,
                                        P_PPO_TOTAL_NOMINAL_INICIAL NUMBER)
      RETURN NUMBER IS
      CURSOR C_NPO_PPO IS
        SELECT NPO_CONSECUTIVO,
               NPO_PPO_CONSECUTIVO,
               NPO_ENA_MNEMONICO,
               NPO_TIPO_OPERACION,
               NPO_VALOR_NOMINAL,
               NPO_VALOR_PESOS,
               NPO_COMISION_INTRAMESA,
               NPO_CLASE_OPERACION,
               NPO_TIPO_REGISTRO
          FROM NEGOCIOS_POSICION
         WHERE NPO_CONSECUTIVO = P_PPO_NPO_CONSECUTIVO;
      NPO1 C_NPO_PPO%ROWTYPE;

      CURSOR C_NPO IS
        SELECT NPO_CONSECUTIVO,
               NPO_FECHA,
               NPO_PPO_CONSECUTIVO,
               NPO_ENA_MNEMONICO,
               NPO_TIPO_OPERACION,
               NPO_VALOR_NOMINAL,
               NPO_VALOR_PESOS,
               NPO_COMISION_INTRAMESA,
               NPO_CLASE_OPERACION,
               NPO_TIPO_REGISTRO
          FROM NEGOCIOS_POSICION, PORTAFOLIOS_POSICION
         WHERE NPO_ESTADO != 'ANU'
           AND NPO_PPO_CONSECUTIVO = PPO_CONSECUTIVO
           AND TRUNC(NPO_FECHA_FUTURA) = TRUNC(P_FECHA)
           AND NVL(PPO_ENA_MNEMONICO, ' ') = NVL(P_PPO_ENA_MNEMONICO, ' ')
           AND NVL(PPO_BMO_MNEMONICO, ' ') = NVL(P_PPO_BMO_MNEMONICO, ' ')
           AND NVL(PPO_FECHA_EMISION, TRUNC(SYSDATE - 10000)) =
               NVL(P_PPO_FECHA_EMISION, TRUNC(SYSDATE - 10000))
           AND NVL(PPO_FECHA_VENCIMIENTO, TRUNC(SYSDATE - 10000)) =
               NVL(P_PPO_FECHA_VENCIMIENTO, TRUNC(SYSDATE - 10000))
           AND NVL(PPO_PERIODICIDAD_TASA, -1) =
               NVL(P_PPO_PERIODICIDAD_TASA, -1)
           AND NVL(PPO_BASE_CALCULO, -1) = NVL(P_PPO_BASE_CALCULO, -1)
           AND NVL(PPO_MODALIDAD_TASA, ' ') =
               NVL(P_PPO_MODALIDAD_TASA, ' ')
           AND NVL(PPO_TASA_FACIAL, -1) = NVL(P_PPO_TASA_FACIAL, -1)
           AND NVL(PPO_TRE_MNEMONICO, ' ') = NVL(P_PPO_TRE_MNEMONICO, ' ')
           AND NVL(PPO_PUNTOS_ADICIONALES, -1) =
               NVL(P_PPO_PUNTOS_ADICIONALES, -1)
           AND NVL(PPO_TIPO_PAGO_FLUJO, 'XX') =
               NVL(P_PPO_TIPO_PAGO_FLUJO, 'XX')
           AND NVL(PPO_AMORTIZABLE, 'N') = NVL(P_PPO_AMORTIZABLE, 'N')
           AND NVL(PPO_CAPITALIZABLE, 'N') = NVL(P_PPO_CAPITALIZABLE, 'N')
           AND NVL(PPO_CODIGO_PERIODO, 'XX') =
               NVL(P_PPO_CODIGO_PERIODO, 'XX')
           AND NVL(PPO_PER_NUM_IDEN, ' ') = NVL(P_PPO_PER_NUM_IDEN, ' ')
           AND NVL(PPO_PER_TID_CODIGO, ' ') =
               NVL(P_PPO_PER_TID_CODIGO, ' ')
           AND TRUNC(NPO_FECHA) >= TRUNC(P_FECHA) -- DE LAS OPERACIONES QUE SE GENEREN EN EL DIA
         ORDER BY NPO_FECHA, NPO_CONSECUTIVO;
      NPO2 C_NPO%ROWTYPE;

      V_COSTO_PROM    NUMBER;
      V_TOTAL_NOMINAL NUMBER;
      V_VALOR_PESOS   NUMBER;

    BEGIN
      IF TRUNC(P_FECHA) = TRUNC(SYSDATE - 1) THEN
        V_COSTO_PROM    := NVL(P_PPO_COSTO_PROM_COMPRA_INI, 0);
        V_TOTAL_NOMINAL := NVL(P_PPO_TOTAL_NOMINAL_INICIAL, 0);

        OPEN C_NPO;
        FETCH C_NPO
          INTO NPO2;
        WHILE C_NPO%FOUND LOOP
          IF NPO2.NPO_TIPO_OPERACION = 'C' THEN
            IF NPO2.NPO_CLASE_OPERACION = 'CON' AND
               NPO2.NPO_TIPO_REGISTRO = 'INTME' THEN
              V_VALOR_PESOS := NPO2.NPO_VALOR_PESOS +
                               NVL(NPO2.NPO_COMISION_INTRAMESA, 0);
            ELSE
              V_VALOR_PESOS := NPO2.NPO_VALOR_PESOS;
            END IF;

            IF (V_TOTAL_NOMINAL + NPO2.NPO_VALOR_NOMINAL) != 0 THEN
              V_COSTO_PROM := ((V_COSTO_PROM * V_TOTAL_NOMINAL) +
                              V_VALOR_PESOS) /
                              (V_TOTAL_NOMINAL + NPO2.NPO_VALOR_NOMINAL);
            END IF;
            V_TOTAL_NOMINAL := V_TOTAL_NOMINAL + NPO2.NPO_VALOR_NOMINAL;
          ELSIF NPO1.NPO_TIPO_OPERACION = 'V' THEN
            V_TOTAL_NOMINAL := V_TOTAL_NOMINAL - NPO2.NPO_VALOR_NOMINAL;
          END IF;
          FETCH C_NPO
            INTO NPO2;
        END LOOP;
        CLOSE C_NPO;

        RETURN V_COSTO_PROM * 100;
      END IF;
    END;

  BEGIN
    OPEN C_COMERCIAL;
    FETCH C_COMERCIAL
      INTO R_COMERCIAL;
    WHILE C_COMERCIAL%FOUND LOOP

      EXECUTE IMMEDIATE 'TRUNCATE TABLE TMP_MANSIM';

      OPEN C_PORTAFOLIO_POSI(R_COMERCIAL.PER_NUM_IDEN,
                             R_COMERCIAL.PER_TID_CODIGO);
      FETCH C_PORTAFOLIO_POSI
        INTO R_PORTAFOLIO_POSI;
      WHILE C_PORTAFOLIO_POSI%FOUND LOOP

        P_CALIFICACION_COR        := NULL;
        P_CODIGO_SUPER            := NULL;
        P_CODIGO_CALIFICADORA     := NULL;
        P_CODIGO_SUPER_COR        := NULL;
        P_CODIGO_CALIFICADORA_COR := NULL;
        P_EXTERNA_INTERNA         := NULL;
        P_ESTADO_CALIFICA         := NULL;
        P_DSP_CALIFICACION        := NULL;
        P_DSP_DISTRIBUIR          := 'S';
        P_DSP_VALOR_DISTRIBUIR    := 0;

        P_TITULOS.P_CALIFICACION_ESPECIE(P_ESPECIE                 => R_PORTAFOLIO_POSI.PPO_ENA_MNEMONICO,
                                         P_FECHA                   => SYSDATE,
                                         P_CALIFICACION            => P_DSP_CALIFICACION,
                                         P_CALIFICACION_COR        => P_CALIFICACION_COR,
                                         P_CODIGO_SUPER            => P_CODIGO_SUPER,
                                         P_CODIGO_CALIFICADORA     => P_CODIGO_CALIFICADORA,
                                         P_CODIGO_SUPER_COR        => P_CODIGO_SUPER_COR,
                                         P_CODIGO_CALIFICADORA_COR => P_CODIGO_CALIFICADORA_COR,
                                         P_EXTERNA_INTERNA         => P_EXTERNA_INTERNA,
                                         P_ESTADO_CALIFICA         => P_ESTADO_CALIFICA);

        P_DSP_TASA_PIP := NULL;
        P_DSP_TASA_INF := NULL;

        -- Trae los datos de valoracion del dia anterior para traer las tasas de descuento PIP e INFOVALMER
        -- Calcula el dia habil anterior para traer la valoracion.

        /* Proceso para determinar la fecha desde la cual se debe hacer el calculo */
        V_FECHA := SYSDATE - 1;
        BEGIN
          IF R_PORTAFOLIO_POSI.PPO_TFO_CODIGO IS NOT NULL THEN
            OPEN C_MRF(V_FECHA, R_PORTAFOLIO_POSI.PPO_TFO_CODIGO);
            FETCH C_MRF
              INTO MRF1;
            IF C_MRF%FOUND THEN
              IF NVL(MRF1.MRF_PROV_PRINCIPAL, ' ') = 'INF' THEN
                P_DSP_TASA_INF := MRF1.MRF_TASA_DESCUENTO;
                P_DSP_TASA_PIP := MRF1.MRF_TASA_DESCUENTO_ALT;
              ELSE
                P_DSP_TASA_PIP := MRF1.MRF_TASA_DESCUENTO;
                P_DSP_TASA_INF := MRF1.MRF_TASA_DESCUENTO_ALT;
              END IF;
            END IF;
            FETCH C_MRF
              INTO MRF1;
            CLOSE C_MRF;
          END IF;

        EXCEPTION
          WHEN OTHERS THEN

            DBMS_OUTPUT.PUT_LINE('fallo --->> ' || sqlerrm);
        END;

        -----------------------------------------------
        P_NEGOCIOS_POSICION.CALCULAR_SALDOS_SIMULTANEAS(P_PPO_CONSECUTIVO       => R_PORTAFOLIO_POSI.PPO_CONSECUTIVO,
                                                        P_TOTAL_PORTAFOLIO      => P_DSP_TOTAL_PORTAFOLIO,
                                                        P_TOTAL_FONDEOS         => P_DSP_TOTAL_FONDEOS_INTERNOS,
                                                        P_TOTAL_POSICION_DEFINI => P_DSP_TOTAL_POSICION_DEFINI,
                                                        P_TOTAL_SIMULTANEAS     => P_DSP_TOTAL_SIMULTANEAS,
                                                        P_TOTAL_POSICION_T1     => P_DSP_TOTAL_POSICION_T1,
                                                        P_TOTAL_POSICION_T2     => P_DSP_TOTAL_POSICION_T2,
                                                        P_TOTAL_POSICION_T3     => P_DSP_TOTAL_POSICION_T3,
                                                        P_TOTAL_POSICION_TN     => P_DSP_TOTAL_POSICION_TN);

        P_DSP_VALOR_GIRO             := NVL(P_DSP_TOTAL_PORTAFOLIO, 0) *
                                        NVL(R_PORTAFOLIO_POSI.PPO_VALOR_MIL_MILLONES,
                                            0) / 1000000000;
        P_DSP_TOTAL_SIMULTANEAS      := NVL(R_PORTAFOLIO_POSI.PPO_TOTAL_SIMULTANEAS,
                                            0) +
                                        NVL(P_DSP_TOTAL_SIMULTANEAS, 0);
        P_DSP_TOTAL_FONDEOS_INTERNOS := R_PORTAFOLIO_POSI.PPO_TOTAL_FONDEOS_INTERNOS +
                                        P_DSP_TOTAL_FONDEOS_INTERNOS;
        P_DSP_TOTAL_POSICION_T1      := NVL(R_PORTAFOLIO_POSI.PPO_TOTAL_POSICION_T1,
                                            0) +
                                        NVL(P_DSP_TOTAL_POSICION_T1, 0);
        P_DSP_TOTAL_POSICION_T2      := NVL(R_PORTAFOLIO_POSI.PPO_TOTAL_POSICION_T2,
                                            0) +
                                        NVL(P_DSP_TOTAL_POSICION_T2, 0);
        P_DSP_TOTAL_POSICION_T3      := NVL(R_PORTAFOLIO_POSI.PPO_TOTAL_POSICION_T3,
                                            0) +
                                        NVL(P_DSP_TOTAL_POSICION_T3, 0);
        P_DSP_TOTAL_POSICION_TN      := NVL(R_PORTAFOLIO_POSI.PPO_TOTAL_POSICION_TN,
                                            0) +
                                        NVL(P_DSP_TOTAL_POSICION_TN, 0);
        -----------------------------------------------
        P_DSP_TOTAL_POSICION        := P_DSP_TOTAL_PORTAFOLIO +
                                       P_DSP_TOTAL_POSICION_T1 +
                                       P_DSP_TOTAL_POSICION_T2 +
                                       P_DSP_TOTAL_POSICION_T3 +
                                       P_DSP_TOTAL_POSICION_TN;
        P_DSP_COSTO_PROM_COMPRA_FIN := FN_CALCULA_PRECIO_PROMEDIO(R_PORTAFOLIO_POSI.PPO_NPO_CONSECUTIVO,
                                                                  V_FECHA,
                                                                  R_PORTAFOLIO_POSI.PPO_ENA_MNEMONICO,
                                                                  R_PORTAFOLIO_POSI.PPO_BMO_MNEMONICO,
                                                                  R_PORTAFOLIO_POSI.PPO_FECHA_EMISION,
                                                                  R_PORTAFOLIO_POSI.PPO_FECHA_VENCIMIENTO,
                                                                  R_PORTAFOLIO_POSI.PPO_PERIODICIDAD_TASA,
                                                                  R_PORTAFOLIO_POSI.PPO_BASE_CALCULO,
                                                                  R_PORTAFOLIO_POSI.PPO_MODALIDAD_TASA,
                                                                  R_PORTAFOLIO_POSI.PPO_TASA_FACIAL,
                                                                  R_PORTAFOLIO_POSI.PPO_TRE_MNEMONICO,
                                                                  R_PORTAFOLIO_POSI.PPO_PUNTOS_ADICIONALES,
                                                                  R_PORTAFOLIO_POSI.PPO_TIPO_PAGO_FLUJO,
                                                                  R_PORTAFOLIO_POSI.PPO_AMORTIZABLE,
                                                                  R_PORTAFOLIO_POSI.PPO_CAPITALIZABLE,
                                                                  R_PORTAFOLIO_POSI.PPO_CODIGO_PERIODO,
                                                                  R_PORTAFOLIO_POSI.PPO_PER_NUM_IDEN,
                                                                  R_PORTAFOLIO_POSI.PPO_PER_TID_CODIGO,
                                                                  R_PORTAFOLIO_POSI.PPO_COSTO_PROM_COMPRA_INICIAL,
                                                                  R_PORTAFOLIO_POSI.PPO_TOTAL_NOMINAL_INICIAL);

        --------------------------------------------------------------
        IF P_DSP_TOTAL_PORTAFOLIO = 0 THEN
          P_DSP_VALOR_DISTRIBUIR := 0;
          P_DSP_DISTRIBUIR       := 'N';
        ELSE
          P_DSP_VALOR_DISTRIBUIR := P_DSP_TOTAL_PORTAFOLIO;
        END IF;

        ------------------------------------------------------------------

        INSERT INTO TMP_MANSIM
        VALUES
          (R_PORTAFOLIO_POSI.PPO_ENA_MNEMONICO,
           R_PORTAFOLIO_POSI.PPO_FUG_ISI_MNEMONICO,
           R_PORTAFOLIO_POSI.PPO_PORTAFOLIO_CERRADO,
           P_DSP_CALIFICACION,
           R_PORTAFOLIO_POSI.PPO_FECHA_VENCIMIENTO,
           P_DSP_TOTAL_POSICION,
           P_DSP_TOTAL_PORTAFOLIO,
           P_DSP_COSTO_PROM_COMPRA_FIN,
           P_DSP_TASA_PIP,
           P_DSP_TASA_INF,
           P_DSP_DISTRIBUIR,
           P_DSP_VALOR_DISTRIBUIR,
           R_PORTAFOLIO_POSI.PPO_TASA_EFECTIVA,
           R_PORTAFOLIO_POSI.PPO_PRECIO_LIMPIO,
           R_PORTAFOLIO_POSI.PPO_VALOR_MIL_MILLONES,
           P_DSP_VALOR_GIRO,
           P_DSP_TOTAL_SIMULTANEAS,
           P_DSP_TOTAL_FONDEOS_INTERNOS,
           P_DSP_TOTAL_POSICION_T1,
           P_DSP_TOTAL_POSICION_T2,
           P_DSP_TOTAL_POSICION_T3,
           P_DSP_TOTAL_POSICION_TN,
           R_PORTAFOLIO_POSI.PPO_FECHA_EMISION,
           R_PORTAFOLIO_POSI.PPO_TASA_FACIAL,
           R_PORTAFOLIO_POSI.PPO_TRE_MNEMONICO,
           R_PORTAFOLIO_POSI.PPO_PUNTOS_ADICIONALES,
           R_PORTAFOLIO_POSI.PPO_PERIODICIDAD_TASA,
           R_PORTAFOLIO_POSI.PPO_MODALIDAD_TASA,
           R_PORTAFOLIO_POSI.PPO_CODIGO_PERIODO,
           R_PORTAFOLIO_POSI.PPO_BASE_CALCULO,
           R_PORTAFOLIO_POSI.PPO_TIPO_PAGO_FLUJO,
           R_PORTAFOLIO_POSI.PPO_CAPITALIZABLE,
           R_PORTAFOLIO_POSI.PPO_AMORTIZABLE,
           R_PORTAFOLIO_POSI.PPO_BMO_MNEMONICO);

        COMMIT;
        FETCH C_PORTAFOLIO_POSI
          INTO R_PORTAFOLIO_POSI;
      END LOOP;
      CLOSE C_PORTAFOLIO_POSI;

      V_RUTA := '\\nas.corredor.local\Riesgo\CONFIDENCIAL\Reportes Excel Coeasy\';
      IF R_COMERCIAL.PER_NUM_IDEN = '8600791749' THEN
        NOMBRE := 'RP';
      ELSE
        NOMBRE := R_COMERCIAL.PER_PRIMER_APELLIDO;
      END IF;
      NOMBRE_ARCHIVO := 'MANSIM_INVENTARIO_' || NOMBRE || '_' ||
                        TO_CHAR(SYSDATE - 1, 'DDMMYYYY');

      --LLAMADO AL PROGRAMA QUE CREA EL XSLX
      P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => V_RUTA,
                                     P_NOMBRE_ARCHIVO => NOMBRE_ARCHIVO,
                                     P_QUERY          => 'SELECT PPO_ENA_MNEMONICO NEMONICO ' ||
                                                         '     , PPO_PORTAFOLIO_CERRADO FIN_DIA ' ||
                                                         '     , PPO_FUG_ISI_MNEMONICO ISIN ' ||
                                                         '     , DSP_CALIFICACION CALIFICACION ' ||
                                                         '     , PPO_FECHA_VENCIMIENTO FECHA_VENCIMIENTO ' ||
                                                         '     , DSP_TOTAL_POSICION TOTAL_POSICION' ||
                                                         '     , DSP_TOTAL_PORTAFOLIO TOTAL_VENCIMIENTO_HOY ' ||
                                                         '     , DSP_COSTO_PROM_COMPRA_FINAL PRECIO_PROM_COMPRA ' ||
                                                         '     , DSP_TASA_PIP TASA_DESC_PIP' ||
                                                         '     , DSP_TASA_INF TASA_DESC_INF' ||
                                                         '     , DSP_DISTRIBUIR DISTRIBUIR' ||
                                                         '     , DSP_VALOR_DISTRIBUIR VALOR_DISTRIBUIR' ||
                                                         '     , PPO_TASA_EFECTIVA TIR' ||
                                                         '     , PPO_PRECIO_LIMPIO PRECIO_LIMPIO ' ||
                                                         '     , PPO_VALOR_MIL_MILLONES VALOR_1000_MILLONES ' ||
                                                         '     , DSP_VALOR_GIRO VALOR_GIRO_POSICION ' ||
                                                         '     , DSP_TOTAL_SIMULTANEAS TOTAL_SIMULTANEAS' ||
                                                         '     , DSP_TOTAL_FONDEOS_INTERNOS TOTAL_FONDEOS_INTERNOS' ||
                                                         '     , DSP_TOTAL_POSICION_T1 TOTAL_POSICION_T1' ||
                                                         '     , DSP_TOTAL_POSICION_T2 TOTAL_POSICION_T2 ' ||
                                                         '     , DSP_TOTAL_POSICION_T3 TOTAL_POSICION_T3' ||
                                                         '     , DSP_TOTAL_POSICION_TN TOTAL_POSICION_TN ' ||
                                                         '     , PPO_FECHA_EMISION  FECHA_EMISION' ||
                                                         '     , PPO_TASA_FACIAL TASA_FACIAL' ||
                                                         '     , PPO_TRE_MNEMONICO TASA_REF ' ||
                                                         '     , PPO_PUNTOS_ADICIONALES PUNTOS ' ||
                                                         '     , PPO_PERIODICIDAD_TASA  PERIODO' ||
                                                         '     , PPO_MODALIDAD_TASA MODALIDAD' ||
                                                         '     , PPO_CODIGO_PERIODO DESCUENTO_PERIODO' ||
                                                         '     , PPO_BASE_CALCULO BASE_CALCULO' ||
                                                         '     , PPO_TIPO_PAGO_FLUJO TIPO_PAGO_FLUJO' ||
                                                         '     , PPO_CAPITALIZABLE CAPITALIZABLE' ||
                                                         '     , PPO_AMORTIZABLE AMORTIZABLE' ||
                                                         '     , PPO_BMO_MNEMONICO MONEDA' ||
                                                         '  FROM TMP_MANSIM',
                                     P_CODIGO         => P_CODIGO,
                                     P_RESPUESTA      => P_RESPUESTA);
      IF P_CODIGO = '0000' THEN
        DBMS_OUTPUT.PUT_LINE('Se ha generado el archivo, en la ruta ' ||
                             V_RUTA);
      END IF;

      FETCH C_COMERCIAL
        INTO R_COMERCIAL;
    END LOOP;
    CLOSE C_COMERCIAL;
  END P_EJECUTA_MANSIM;

  PROCEDURE P_EJECUTA_MANSIM_NEG IS
    CURSOR C_CONSULTA_NEG IS
      SELECT NPO_ESTADO,
             NPO_CONSECUTIVO,
             NPO_ENA_MNEMONICO,
             NPO_TIPO_NEGOCIO,
             NPO_TIPO_OPERACION,
             NPO_CLASE_OPERACION,
             NPO_VALOR_NOMINAL,
             NPO_VALOR_PESOS,
             NPO_NUMERO_OPERACION,
             NPO_COMISION_INTRAMESA,
             NPO_DEPOSITO,
             NPO_TIPO_RANGO,
             NPO_TASA_NEGOCIACION,
             NPO_PLAZO_T1,
             NPO_PLAZO_T2,
             NPO_PLAZO_T3,
             NPO_MONTO_MINIMO,
             NPO_FRACCION_MINIMA,
             NPO_MINIMO_ULTIMO,
             NPO_FECHA_FUTURA,
             NPO_VALOR_FUTURO,
             NPO_TIPO_REGISTRO,
             NPO_FIC_PER_NUM_IDEN,
             NPO_FECHA,
             NPO_ABRIR_HORARIO,
             NPO_CUPON,
             NPO_CORTO,
             NPO_PROPORCION_CORTO,
             NPO_NOMINAL_CORTO,
             NPO_OVE_CONSECUTIVO,
             NPO_OCO_CONSECUTIVO,
             NPO_FIC_PER_TID_CODIGO,
             NPO_PER_NUM_IDEN,
             NPO_FIC_CODIGO_BOLSA,
             NPO_PER_TID_CODIGO
        FROM NEGOCIOS_POSICION
       WHERE NPO_ESTADO != 'ANU'
         AND NPO_FECHA >= TRUNC(TRUNC(SYSDATE) - 1)
         AND NPO_FECHA < TRUNC(SYSDATE)
         AND EXISTS (SELECT 'X'
                FROM PORTAFOLIOS_POSICION
               WHERE PPO_CONSECUTIVO = NPO_PPO_CONSECUTIVO
                 AND PPO_TIPO = 'POS'
                 AND PPO_PER_NUM_IDEN IN ('860079174-3')
                 AND PPO_PER_TID_CODIGO = 'CC');
    R_CONSULTA_NEG C_CONSULTA_NEG%ROWTYPE;

    CURSOR C_TOTAL_CAPTADO(P_NPO_CONSECUTIVO VARCHAR2) IS
      SELECT SUM(OFD_NOMINAL_ADQUIRIDO), SUM(OFD_VALOR_PESOS_ADQUIRIDO)
        FROM OFERTAS_DEMANDAS_POSICION
       WHERE OFD_NPO_CONSECUTIVO = P_NPO_CONSECUTIVO
         AND OFD_ESTADO != 'ANU';
    TOTAL_CAPTADO         NUMBER;
    TOTAL_NOMINAL_CAPTADO NUMBER;

    CURSOR C_FIRMA(P_NPO_FIC_PER_NUM_IDEN   VARCHAR2,
                   P_NPO_FIC_PER_TID_CODIGO VARCHAR2,
                   P_NPO_FIC_CODIGO_BOLSA   VARCHAR2) IS
      SELECT PER_NOMBRE FIC_NOMBRE
        FROM FIRMAS_COMISIONISTAS, FILTRO_PERSONAS
       WHERE FIC_PER_NUM_IDEN = PER_NUM_IDEN
         AND FIC_PER_TID_CODIGO = PER_TID_CODIGO
         AND FIC_PER_NUM_IDEN = P_NPO_FIC_PER_NUM_IDEN
         AND FIC_PER_TID_CODIGO = P_NPO_FIC_PER_TID_CODIGO
         AND FIC_CODIGO_BOLSA = P_NPO_FIC_CODIGO_BOLSA;

    CURSOR C_COMERCIAL(P_NPO_PER_NUM_IDEN   VARCHAR2,
                       P_NPO_PER_TID_CODIGO VARCHAR2) IS
      SELECT PER_NOMBRE_USUARIO
        FROM PERSONAS
       WHERE PER_NUM_IDEN = P_NPO_PER_NUM_IDEN
         AND PER_TID_CODIGO = P_NPO_PER_TID_CODIGO;

    CURSOR C_NUMERO_OPERACION(P_NPO_NUMERO_OPERACION NUMBER) IS
      SELECT LIC_OCO_CONSECUTIVO, LIC_OVE_CONSECUTIVO
        FROM LIQUIDACIONES_COMERCIAL
       WHERE LIC_NUMERO_OPERACION = P_NPO_NUMERO_OPERACION
         AND LIC_TIPO_OPERACION = 'C'
         AND LIC_NIT_1 = '860079174'
         AND LIC_TIPO_IDENTIFICACION_1 = 'NIT';
    LIC1 C_NUMERO_OPERACION%ROWTYPE;

    CURSOR C_PPO(P_NPO_CONSECUTIVO VARCHAR2) IS
      SELECT PPO_FUG_ISI_MNEMONICO, PPO_FECHA_VENCIMIENTO
        FROM NEGOCIOS_POSICION, PORTAFOLIOS_POSICION
       WHERE NPO_CONSECUTIVO = P_NPO_CONSECUTIVO
         AND NPO_PPO_CONSECUTIVO = PPO_CONSECUTIVO
         AND PPO_FUG_ISI_MNEMONICO IS NOT NULL;
    V_ISIN              VARCHAR2(12);
    V_FECHA_VENCIMIENTO DATE;

    CURSOR C_TFO(P_NPO_CONSECUTIVO VARCHAR2, P_NPO_FECHA DATE) IS
      SELECT TFO_FUG_ISI_MNEMONICO, PPO_FECHA_VENCIMIENTO
        FROM NEGOCIOS_POSICION    AA,
             PORTAFOLIOS_POSICION PPO1,
             TITULOS_FONDOS       BB
       WHERE NPO_CONSECUTIVO = P_NPO_CONSECUTIVO
         AND NPO_PPO_CONSECUTIVO = PPO1.PPO_CONSECUTIVO
         AND TFO_FON_CODIGO = '860079174'
         AND NVL(TFO_ENA_MNEMONICO, ' ') = NVL(PPO1.PPO_ENA_MNEMONICO, ' ')
         AND NVL(TFO_FECHA_EMISION, TRUNC(SYSDATE - 10000)) =
             NVL(PPO1.PPO_FECHA_EMISION, TRUNC(SYSDATE - 10000))
         AND NVL(TFO_FECHA_VENCIMIENTO, TRUNC(SYSDATE - 10000)) =
             NVL(PPO1.PPO_FECHA_VENCIMIENTO, TRUNC(SYSDATE - 10000))
         AND NVL(TFO_BMO_MNEMONICO, ' ') = NVL(PPO1.PPO_BMO_MNEMONICO, ' ')
         AND NVL(TFO_PERIODICIDAD_TASA, -1) =
             NVL(PPO1.PPO_PERIODICIDAD_TASA, -1)
         AND NVL(TFO_BASE_CALCULO, -1) = NVL(PPO1.PPO_BASE_CALCULO, -1)
         AND NVL(TFO_MODALIDAD_TASA, ' ') =
             NVL(PPO1.PPO_MODALIDAD_TASA, ' ')
         AND NVL(TFO_TASA_FACIAL, -1) = NVL(PPO1.PPO_TASA_FACIAL / 100, -1)
         AND NVL(TFO_TRE_MNEMONICO, ' ') = NVL(PPO1.PPO_TRE_MNEMONICO, ' ')
         AND NVL(TFO_PUNTOS_ADICIONALES, -1) =
             NVL(PPO1.PPO_PUNTOS_ADICIONALES, -1)
         AND NVL(TFO_TIPO_PAGO_FLUJO, 'XX') =
             NVL(PPO1.PPO_TIPO_PAGO_FLUJO, 'XX')
         AND NVL(TFO_AMORTIZABLE, 'N') = NVL(PPO1.PPO_AMORTIZABLE, 'N')
         AND NVL(TFO_CAPITALIZABLE, 'N') = NVL(PPO1.PPO_CAPITALIZABLE, 'N')
         AND NVL(TFO_CODIGO_PERIODO, 'XX') =
             NVL(PPO1.PPO_CODIGO_PERIODO, 'XX')
         AND TRUNC(TFO_FECHA_OPERACION) <= TRUNC(P_NPO_FECHA)
         AND TFO_FUG_ISI_MNEMONICO IS NOT NULL
       ORDER BY TFO_FECHA_OPERACION DESC, NPO_CONSECUTIVO;

    DSP_CONSECUTIVO         NUMBER;
    SALDO_PENDIENTE         NUMBER;
    SALDO_NOMINAL_PENDIENTE NUMBER;
    DSP_FIRMA               VARCHAR2(60 BYTE);
    DSP_COMERCIAL           VARCHAR2(20 BYTE);

    V_RUTA         VARCHAR2(100);
    NOMBRE_ARCHIVO VARCHAR2(100);
    P_CODIGO       VARCHAR2(200);
    P_RESPUESTA    VARCHAR2(200);
    NOMBRE         VARCHAR2(100);
    N_QUERY        VARCHAR2(4000);
  BEGIN
    EXECUTE IMMEDIATE 'TRUNCATE TABLE TMP_MANSIM_CON_NEG';

    OPEN C_CONSULTA_NEG;
    FETCH C_CONSULTA_NEG
      INTO R_CONSULTA_NEG;
    WHILE C_CONSULTA_NEG%FOUND LOOP

      ---------INICIALIZA VARIABLES

      DSP_CONSECUTIVO         := 0;
      SALDO_PENDIENTE         := 0;
      SALDO_NOMINAL_PENDIENTE := 0;
      DSP_FIRMA               := NULL;
      -------------------------------

      DSP_CONSECUTIVO := NVL(R_CONSULTA_NEG.NPO_OVE_CONSECUTIVO,
                             R_CONSULTA_NEG.NPO_OCO_CONSECUTIVO);
      IF R_CONSULTA_NEG.NPO_TIPO_NEGOCIO = 'DIS' THEN
        OPEN C_TOTAL_CAPTADO(R_CONSULTA_NEG.NPO_CONSECUTIVO);
        FETCH C_TOTAL_CAPTADO
          INTO TOTAL_NOMINAL_CAPTADO, TOTAL_CAPTADO;
        CLOSE C_TOTAL_CAPTADO;
        SALDO_PENDIENTE         := NVL(R_CONSULTA_NEG.NPO_VALOR_PESOS, 0) -
                                   NVL(TOTAL_CAPTADO, 0);
        SALDO_NOMINAL_PENDIENTE := NVL(R_CONSULTA_NEG.NPO_VALOR_NOMINAL, 0) -
                                   NVL(TOTAL_NOMINAL_CAPTADO, 0);
      END IF;

      IF R_CONSULTA_NEG.NPO_FIC_PER_NUM_IDEN IS NOT NULL AND
         R_CONSULTA_NEG.NPO_FIC_PER_TID_CODIGO IS NOT NULL AND
         R_CONSULTA_NEG.NPO_FIC_CODIGO_BOLSA IS NOT NULL THEN
        OPEN C_FIRMA(R_CONSULTA_NEG.NPO_FIC_PER_NUM_IDEN,
                     R_CONSULTA_NEG.NPO_FIC_PER_TID_CODIGO,
                     R_CONSULTA_NEG.NPO_FIC_CODIGO_BOLSA);
        FETCH C_FIRMA
          INTO DSP_FIRMA;
        CLOSE C_FIRMA;
      END IF;

      IF R_CONSULTA_NEG.NPO_PER_NUM_IDEN IS NOT NULL AND
         R_CONSULTA_NEG.NPO_PER_TID_CODIGO IS NOT NULL THEN
        OPEN C_COMERCIAL(R_CONSULTA_NEG.NPO_PER_NUM_IDEN,
                         R_CONSULTA_NEG.NPO_PER_TID_CODIGO);
        FETCH C_COMERCIAL
          INTO DSP_COMERCIAL;
        CLOSE C_COMERCIAL;
      END IF;

      IF R_CONSULTA_NEG.NPO_TIPO_OPERACION = 'C' THEN
        IF R_CONSULTA_NEG.NPO_NUMERO_OPERACION IS NOT NULL THEN
          OPEN C_NUMERO_OPERACION(R_CONSULTA_NEG.NPO_NUMERO_OPERACION);
          FETCH C_NUMERO_OPERACION
            INTO LIC1;
          CLOSE C_NUMERO_OPERACION;
          DSP_CONSECUTIVO := LIC1.LIC_OCO_CONSECUTIVO;
        END IF;
      ELSIF R_CONSULTA_NEG.NPO_TIPO_OPERACION = 'V' THEN
        IF R_CONSULTA_NEG.NPO_NUMERO_OPERACION IS NOT NULL THEN
          OPEN C_NUMERO_OPERACION(R_CONSULTA_NEG.NPO_NUMERO_OPERACION);
          FETCH C_NUMERO_OPERACION
            INTO LIC1;
          CLOSE C_NUMERO_OPERACION;
          DSP_CONSECUTIVO := LIC1.LIC_OVE_CONSECUTIVO;
        END IF;
      END IF;

      V_ISIN := NULL;
      OPEN C_PPO(R_CONSULTA_NEG.NPO_CONSECUTIVO);
      FETCH C_PPO
        INTO V_ISIN, V_FECHA_VENCIMIENTO;
      CLOSE C_PPO;
      IF V_ISIN IS NULL THEN
        OPEN C_TFO(R_CONSULTA_NEG.NPO_CONSECUTIVO,
                   R_CONSULTA_NEG.NPO_FECHA);
        FETCH C_TFO
          INTO V_ISIN, V_FECHA_VENCIMIENTO;
        CLOSE C_TFO;
      END IF;
      --DSP_ISIN := V_ISIN;
      --FECHA_VENCIMIENTO := V_FECHA_VENCIMIENTO;
      INSERT INTO TMP_MANSIM_CON_NEG
      VALUES
        (R_CONSULTA_NEG.NPO_CONSECUTIVO,
         R_CONSULTA_NEG.NPO_ESTADO, --OK
         R_CONSULTA_NEG.NPO_ENA_MNEMONICO, --OK
         V_ISIN, --OK
         R_CONSULTA_NEG.NPO_TIPO_NEGOCIO,
         R_CONSULTA_NEG.NPO_TIPO_OPERACION,
         R_CONSULTA_NEG.NPO_CLASE_OPERACION,
         R_CONSULTA_NEG.NPO_VALOR_NOMINAL,
         R_CONSULTA_NEG.NPO_VALOR_PESOS,
         R_CONSULTA_NEG.NPO_NUMERO_OPERACION,
         R_CONSULTA_NEG.NPO_COMISION_INTRAMESA,
         DSP_COMERCIAL,
         SALDO_NOMINAL_PENDIENTE,
         SALDO_PENDIENTE,
         R_CONSULTA_NEG.NPO_DEPOSITO,
         R_CONSULTA_NEG.NPO_TIPO_RANGO,
         R_CONSULTA_NEG.NPO_TASA_NEGOCIACION,
         R_CONSULTA_NEG.NPO_PLAZO_T1,
         R_CONSULTA_NEG.NPO_PLAZO_T2,
         R_CONSULTA_NEG.NPO_PLAZO_T3,
         R_CONSULTA_NEG.NPO_MONTO_MINIMO,
         R_CONSULTA_NEG.NPO_FRACCION_MINIMA,
         R_CONSULTA_NEG.NPO_MINIMO_ULTIMO,
         R_CONSULTA_NEG.NPO_FECHA_FUTURA,
         R_CONSULTA_NEG.NPO_VALOR_FUTURO,
         DSP_CONSECUTIVO,
         R_CONSULTA_NEG.NPO_TIPO_REGISTRO,
         R_CONSULTA_NEG.NPO_FIC_PER_NUM_IDEN,
         DSP_FIRMA,
         R_CONSULTA_NEG.NPO_FECHA,
         R_CONSULTA_NEG.NPO_ABRIR_HORARIO,
         V_FECHA_VENCIMIENTO,
         R_CONSULTA_NEG.NPO_CUPON,
         R_CONSULTA_NEG.NPO_CORTO,
         R_CONSULTA_NEG.NPO_PROPORCION_CORTO,
         R_CONSULTA_NEG.NPO_NOMINAL_CORTO);
      COMMIT;
      FETCH C_CONSULTA_NEG
        INTO R_CONSULTA_NEG;
    END LOOP;
    CLOSE C_CONSULTA_NEG;

    V_RUTA         := '\\nas.corredor.local\Riesgo\CONFIDENCIAL\Reportes Excel Coeasy\';
    NOMBRE_ARCHIVO := 'MANSIM_DERIVADOS_RF_' ||
                      TO_CHAR(SYSDATE - 1, 'DDMMYYYY');

    N_QUERY := 'SELECT NPO_CONSECUTIVO        CONSECUTIVO' ||
               '     , COPIA_ESTADO            ESTADO' ||
               '     , NPO_ENA_MNEMONICO       MNEMONICO' ||
               '     , DSP_ISIN                ISIN' ||
               '     , NPO_TIPO_NEGOCIO        TIPO_NEGOCIO' ||
               '     , NPO_TIPO_OPERACION      TIPO_OPERACION' ||
               '     , NPO_CLASE_OPERACION     CLASE_OPERACION' ||
               '     , NPO_VALOR_NOMINAL       CANTIDAD_NOMINAL' ||
               '     , NPO_VALOR_PESOS         VALOR_PESOS' ||
               '     , NPO_NUMERO_OPERACION    FOLIO' ||
               '     , NPO_COMISION_INTRAMESA  COMISION' ||
               '     , DSP_COMERCIAL           COMERCIAL' ||
               '     , SALDO_NOMINAL_PENDIENTE SALDO_NOMINAL_PENDIENTE' ||
               '     , SALDO_PENDIENTE         SALDO_PENDIENTE_PESOS' ||
               '     , NPO_DEPOSITO            DEPOSITO' ||
               '     , NPO_TIPO_RANGO          TASA_POR_MONTO_PLAZO' ||
               '     , NPO_TASA_NEGOCIACION    TASA_NEGOCIACION' ||
               '     , NPO_PLAZO_T1            T1' ||
               '     , NPO_PLAZO_T2            T2' ||
               '     , NPO_PLAZO_T3            T3' ||
               '     , NPO_MONTO_MINIMO        MONTO_MINIMO' ||
               '     , NPO_FRACCION_MINIMA     FRACCION_MINIMA' ||
               '     , NPO_MINIMO_ULTIMO       VALOR_ULTIMA_OPERACION' ||
               '     , NPO_FECHA_FUTURA        FECHA_FUTURA' ||
               '     , NPO_VALOR_FUTURO        VALOR_FUTURO' ||
               '     , DSP_CONSECUTIVO         ORDEN' ||
               '     , NPO_TIPO_REGISTRO       REGISTRO' ||
               '     , DSP_FIRMA               FIRMA' ||
               '     , NPO_FECHA               FECHA_OFERTA ' ||
               '     , NPO_ABRIR_HORARIO       HORARIO_EXT' ||
               '     , FECHA_VENCIMIENTO       FECHA_VENCIMIENTO' ||
               '     , NPO_CUPON               VALOR_CUPON' ||
               '     , NPO_CORTO               SIMULTANEA_EN_CORTO' ||
               '     , NPO_PROPORCION_CORTO    PROPORCION_CORTO' ||
               '     , NPO_NOMINAL_CORTO       VALOR_NOMINAL_CORTO' ||
               '  FROM TMP_MANSIM_CON_NEG';

    --LLAMADO AL PROGRAMA QUE CREA EL XSLX
    P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => V_RUTA,
                                   P_NOMBRE_ARCHIVO => NOMBRE_ARCHIVO,
                                   P_QUERY          => N_QUERY,
                                   P_CODIGO         => P_CODIGO,
                                   P_RESPUESTA      => P_RESPUESTA);

    IF P_CODIGO = '0000' THEN
      DBMS_OUTPUT.PUT_LINE('Se ha generado el archivo, en la ruta ' ||
                           V_RUTA || '---' || N_QUERY);
    END IF;

  END P_EJECUTA_MANSIM_NEG;

  PROCEDURE P_EJECUTA_DATCLI IS
    V_RUTA           VARCHAR2(100);
    V_NOMBRE_ARCHIVO VARCHAR2(100);
    P_CODIGO         VARCHAR2(100);
    P_RESPUESTA      VARCHAR2(100);
  BEGIN

    P_SARIC.PR_GENERA_PLANO_INTEGRADO(TRUNC(SYSDATE - 1),
                                      SYSDATE,
                                      '%',
                                      '%',
                                      '%',
                                      'B');

    V_RUTA           := '\\nas.corredor.local\Riesgo\CONFIDENCIAL\Reportes Excel Coeasy\';
    V_NOMBRE_ARCHIVO := 'DATOS_BASICOS_CLIENTES_' ||
                        TO_CHAR(SYSDATE - 1, 'DDMMYYYYhh24mm');
    --LLAMADO AL PROGRAMA QUE CREA EL XSLX
    P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => V_RUTA,
                                   P_NOMBRE_ARCHIVO => V_NOMBRE_ARCHIVO,
                                   P_QUERY          => 'SELECT * FROM TMP_PLANO_INTEGRADO',
                                   P_CODIGO         => P_CODIGO,
                                   P_RESPUESTA      => P_RESPUESTA);
    IF P_CODIGO = '0000' THEN
      DBMS_OUTPUT.PUT_LINE('Se ha generado el archivo, en la ruta ' ||
                           V_RUTA);
    END IF;

  END P_EJECUTA_DATCLI;

  --INICIO VAGTUD978 - Arbitraje
  PROCEDURE OPCONTADO_INVINT_AUTO IS

    CURSOR C_FON(P_FECHA DATE) IS
      SELECT DISTINCT (MOF_OCI_FON_CODIGO) FONDO,
                      FON_RAZON_SOCIAL RAZON_SOCIAL
        FROM FONDOS, MVTOS_OPCONTADO_INT_FONDOS
       WHERE FON_CODIGO = MOF_OCI_FON_CODIGO
         AND TRUNC(MOF_FECHA) >= P_FECHA
         AND TRUNC(MOF_FECHA) < P_FECHA + 1;
    R_FON C_FON%ROWTYPE;

    CURSOR C_OCI(P_FECHA DATE, P_FONDO VARCHAR2) IS
      SELECT TO_CHAR(MOF_FECHA, 'DD/MM/YYYY') FECHA_VALORACION,
             MOF_OCI_FON_CODIGO NIT_FONDO,
             (SELECT NVL(FON_NOMBRE_CORTO, FON_RAZON_SOCIAL)
                FROM FONDOS
               WHERE FON_CODIGO = P_FONDO) NOMBRE_FONDO,
             MOF_OCI_NUMERO_OPERACION NUMERO_OPERACION,
             ENA_MNEMONICO ESPECIE,
             OCI_BMO_MNEMONICO MONEDA,
             OCI_FUG_ISI_MNEMONICO ISIN,
             GNA_DESCRIPCION TIPO,
             TO_CHAR(OCI_FECHA_OPERACION, 'DD-MON-YYYY') FECHA_OPERACION,
             TO_CHAR(OCI_FECHA_CUMPLIMIENTO, 'DD-MON-YYYY') FECHA_CUMPLIMIENTO,
             TO_CHAR(OCI_FECHA_NAV, 'DD-MON-YYYY') FECHA_NAV,
             OCI_TIPO_OPERACION TIPO_OPERACION,
             MOF_VALOR_NOMINAL CANTIDAD,
             (SELECT TMT_DESCRIPCION
                FROM TIPOS_MOVIMIENTOS_TITULOS
               WHERE TMT_MNEMONICO = MOF_TMT_MNEMONICO) MOVIMIENTO,
             OCI_PRECIO_OPERACION_USD PRECIO_OPERACION_USD,
             OCI_VALOR_OPERACION_USD VALOR_BRUTO_OPERACION_USD,
             NVL(OCI_VALOR_COMISION_USD, 0) VALOR_COMISION_USD,
             (NVL(OCI_VALOR_TAXES_USD, 0) + NVL(OCI_VALOR_STAMP_USD, 0) +
             NVL(OCI_VALOR_EXCHANGE_FEE_USD, 0) +
             NVL(OCI_VALOR_GASTOS_USD, 0)) VALOR_GASTOS_USD,
             OCI_VALOR_NETO_OP_USD VALOR_NETO_OPERACION_USD,
             MOF_PRECIO_CIERRE_USD PRECIO_CIERRE_USD,
             MOF_TRM_CIERRE TRM_DE_CIERRE,
             (SELECT CBM_VALOR
                FROM COTIZACIONES_BASE_MONETARIAS
               WHERE CBM_BMO_MNEMONICO = 'DOLAR'
                 AND TRUNC(CBM_FECHA) = TRUNC(MOF_FECHA + 1)) TRM_DIA_ANTERIOR,
             CASE
               WHEN OCI_TIPO_OPERACION = 'C' THEN
                MOF_VALOR_DERECHO_COP
               WHEN OCI_TIPO_OPERACION = 'V' THEN
                MOF_VALOR_OBLIGACION_COP
             END VALORACION_AL_CIERRE_PESOS,
             MOF_DIST_DIA_COP_TOTAL DISTR_DIA_TOTAL_COP,
             MOF_DIST_DIA_COP_DERECHO DISTR_DIA_COP_DERECHO,
             MOF_DIST_DIA_COP_OBLIGACION DISTR_DIA_COP_OBLIGACION,
             MOF_DIST_DIA_USD DISTR_DIA_USD,
             MOF_DIST_ACUMULADA_USD GANANCIA_ACUMULADA_USD_REEXP,
             MOF_DIST_DIA_COP_PRECIO DIST_DIA_COP_PRECIO,
             MOF_DIST_DIA_COP_DIFCAMBIO DIST_DIA_COP_DIFCAMBIO,
             MOF_VALOR_DERECHO_USD VALOR_DERECHO_USD,
             MOF_VALOR_OBLIGACION_USD VALOR_OBLIGACION_USD,
             MOF_VALOR_DERECHO_COP VALOR_DERECHO_COP,
             MOF_VALOR_OBLIGACION_COP VALOR_OBLIGACION_COP,
             MOF_VALOR_COMISION_COP VALOR_COMISION_COP,
             MOF_DIST_DIF_CAMBIO_COMISION DIST_DIA_COMISION,
             MOF_VALOR_OTROS_GASTOS_COP OTROS_GASTOS_COP,
             MOF_DIST_DIF_CAMBIO_GASTOS DIST_DIA_OTROS_GASTOS,
             (SELECT TMK_DESCRIPCION MARKET
                FROM TIPOS_MARKET_INVERSIONES_INT
               WHERE TMK_CODIGO = ENA_TMK_CODIGO) MARKET,
             (SELECT CII_DESCRIPCION CLASE_ACTIVO
                FROM CLASES_ACTIVOS_INVERSIONES_INT
               WHERE CII_CODIGO = ENA_CII_CODIGO) CLASE_ACTIVO,
             ENA_TICKER_BLOOMBERG TICKER_BLOOMBERG,
             CASE
               WHEN OCI_ESTADO = 'REG' THEN
                'REGISTRADA'
               WHEN OCI_ESTADO = 'PEJ' THEN
                'POR EJECUTAR'
               WHEN OCI_ESTADO = 'PCU' THEN
                'POR CUMPLIR'
               WHEN OCI_ESTADO = 'CUM' THEN
                'CUMPLIDA'
               WHEN OCI_ESTADO = 'CAN' THEN
                'CANCELADA'
             END ESTADO_OPERACION,
             EMI_DESCRIPCION EMISOR,
             TO_CHAR(SYSDATE, 'DD/MM/YYYY HH24:MI') FECHA_REPORTE
        FROM OPERACIONES_CONTADO_INVINT_FON,
             MVTOS_OPCONTADO_INT_FONDOS,
             FUNGIBLES,
             ESPECIES_NACIONALES,
             GRUPOS_NACIONALES,
             EMISORES
       WHERE OCI_NUMERO_OPERACION = MOF_OCI_NUMERO_OPERACION
         AND OCI_FON_CODIGO = MOF_OCI_FON_CODIGO
         AND OCI_FUG_ISI_MNEMONICO = FUG_ISI_MNEMONICO
         AND OCI_FUG_MNEMONICO = FUG_MNEMONICO
         AND FUG_ENA_MNEMONICO = ENA_MNEMONICO
         AND ENA_EMI_MNEMONICO = EMI_MNEMONICO
         AND ENA_GNA_MNEMONICO = GNA_MNEMONICO
         AND TRUNC(MOF_FECHA) >= P_FECHA
         AND TRUNC(MOF_FECHA) < P_FECHA + 1
         AND MOF_OCI_FON_CODIGO = P_FONDO
         AND MOF_TMT_MNEMONICO IN ('VYR', 'CAO')
       ORDER BY MOF_FECHA, MOF_OCI_FON_CODIGO, MOF_OCI_NUMERO_OPERACION;
    R_OCI C_OCI%ROWTYPE;

    P_CODIGO         VARCHAR2(200);
    P_RESPUESTA      VARCHAR2(200);
    V_RUTA           VARCHAR2(100);
    V_NOMBRE_ARCHIVO VARCHAR2(100);
    V_FECHA          VARCHAR2(30);
    V_FONDO          VARCHAR2(15);
    V_ARCHIVO        VARCHAR2(10);
    P_NUM_INI        NUMBER;
    P_NUM_FIN        NUMBER;
  BEGIN
    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('OPCONTADO_INVINT_AUTO',
                                                      'INI');

    V_FECHA := SYSDATE - 1;

    DELETE FROM TMP_OPCONTADO_INVINT;

    OPEN C_FON(V_FECHA);
    FETCH C_FON
      INTO R_FON;
    WHILE C_FON%FOUND LOOP

      OPEN C_OCI(V_FECHA, R_FON.FONDO);
      FETCH C_OCI
        INTO R_OCI;
      WHILE C_OCI%FOUND LOOP
        INSERT INTO TMP_OPCONTADO_INVINT
          (FECHA_VALORACION,
           NIT_FONDO,
           NOMBRE_FONDO,
           NUMERO_OPERACION,
           ESPECIE,
           MONEDA,
           ISIN,
           TIPO,
           FECHA_OPERACION,
           FECHA_CUMPLIMIENTO,
           FECHA_NAV -- VAGTUD881-6 FONDOS MUTUOS
          ,
           TIPO_OPERACION,
           CANTIDAD,
           MOVIMIENTO -- VAGTUD881-5
          ,
           PRECIO_OPERACION_USD,
           VALOR_BRUTO_OPERACION_USD,
           VALOR_COMISION_USD,
           VALOR_GASTOS_USD,
           VALOR_NETO_OPERACION_USD,
           PRECIO_CIERRE_USD,
           TRM_DE_CIERRE,
           TRM_DIA_ANTERIOR,
           VALORACION_AL_CIERRE_PESOS,
           DISTR_DIA_TOTAL_COP,
           DISTR_DIA_COP_DERECHO,
           DISTR_DIA_COP_OBLIGACION,
           DISTR_DIA_USD,
           GANANCIA_ACUMULADA_USD_REEXP,
           DIST_DIA_COP_PRECIO,
           DIST_DIA_COP_DIFCAMBIO,
           VALOR_DERECHO_USD,
           VALOR_OBLIGACION_USD,
           VALOR_DERECHO_COP,
           VALOR_OBLIGACION_COP,
           VALOR_COMISION_COP,
           DIST_DIA_COMISION,
           OTROS_GASTOS_COP,
           DIST_DIA_OTROS_GASTOS,
           MARKET,
           CLASE_ACTIVO,
           TICKER_BLOOMBERG,
           ESTADO_OPERACION,
           EMISOR,
           FECHA_REPORTE)
        VALUES
          (R_OCI.FECHA_VALORACION,
           R_OCI.NIT_FONDO,
           R_OCI.NOMBRE_FONDO,
           R_OCI.NUMERO_OPERACION,
           R_OCI.ESPECIE,
           R_OCI.MONEDA,
           R_OCI.ISIN,
           R_OCI.TIPO,
           R_OCI.FECHA_OPERACION,
           R_OCI.FECHA_CUMPLIMIENTO,
           R_OCI.FECHA_NAV -- VAGTUD881-6 FONDOS MUTUOS
          ,
           R_OCI.TIPO_OPERACION,
           R_OCI.CANTIDAD,
           R_OCI.MOVIMIENTO -- VAGTUD881-5
          ,
           R_OCI.PRECIO_OPERACION_USD,
           R_OCI.VALOR_BRUTO_OPERACION_USD,
           R_OCI.VALOR_COMISION_USD,
           R_OCI.VALOR_GASTOS_USD,
           R_OCI.VALOR_NETO_OPERACION_USD,
           R_OCI.PRECIO_CIERRE_USD,
           R_OCI.TRM_DE_CIERRE,
           R_OCI.TRM_DIA_ANTERIOR,
           R_OCI.VALORACION_AL_CIERRE_PESOS,
           R_OCI.DISTR_DIA_TOTAL_COP,
           R_OCI.DISTR_DIA_COP_DERECHO,
           R_OCI.DISTR_DIA_COP_OBLIGACION,
           R_OCI.DISTR_DIA_USD,
           R_OCI.GANANCIA_ACUMULADA_USD_REEXP,
           R_OCI.DIST_DIA_COP_PRECIO,
           R_OCI.DIST_DIA_COP_DIFCAMBIO,
           R_OCI.VALOR_DERECHO_USD,
           R_OCI.VALOR_OBLIGACION_USD,
           R_OCI.VALOR_DERECHO_COP,
           R_OCI.VALOR_OBLIGACION_COP,
           R_OCI.VALOR_COMISION_COP,
           R_OCI.DIST_DIA_COMISION,
           R_OCI.OTROS_GASTOS_COP,
           R_OCI.DIST_DIA_OTROS_GASTOS,
           R_OCI.MARKET,
           R_OCI.CLASE_ACTIVO,
           R_OCI.TICKER_BLOOMBERG,
           R_OCI.ESTADO_OPERACION,
           R_OCI.EMISOR,
           R_OCI.FECHA_REPORTE);
        FETCH C_OCI
          INTO R_OCI;
      END LOOP;
      CLOSE C_OCI;

      FETCH C_FON
        INTO R_FON;
    END LOOP;
    CLOSE C_FON;
    COMMIT;

    V_RUTA := '\\nas.corredor.local\contabilidad\PRIVADA\Reportes transmisiones\Diarios\';

    V_NOMBRE_ARCHIVO := 'OPCONTADO_INVINT_AUTO_' ||
                        TO_CHAR(SYSDATE - 1, 'DDMMYYYY_hh24mmss');

    BEGIN
      P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => V_RUTA,
                                     P_NOMBRE_ARCHIVO => V_NOMBRE_ARCHIVO,
                                     P_QUERY          => 'SELECT FECHA_VALORACION             ' ||
                                                         '      ,NIT_FONDO                    ' ||
                                                         '      ,NOMBRE_FONDO                 ' ||
                                                         '      ,NUMERO_OPERACION             ' ||
                                                         '      ,ESPECIE                      ' ||
                                                         '      ,MONEDA                       ' ||
                                                         '      ,ISIN                         ' ||
                                                         '      ,TIPO                         ' ||
                                                         '      ,FECHA_OPERACION              ' ||
                                                         '      ,FECHA_CUMPLIMIENTO           ' ||
                                                         '      ,FECHA_NAV                    ' ||
                                                         '      ,TIPO_OPERACION               ' ||
                                                         '      ,CANTIDAD                     ' ||
                                                         '      ,MOVIMIENTO                   ' ||
                                                         '      ,PRECIO_OPERACION_USD         ' ||
                                                         '      ,VALOR_BRUTO_OPERACION_USD    ' ||
                                                         '      ,VALOR_COMISION_USD           ' ||
                                                         '      ,VALOR_GASTOS_USD             ' ||
                                                         '      ,VALOR_NETO_OPERACION_USD     ' ||
                                                         '      ,PRECIO_CIERRE_USD            ' ||
                                                         '      ,TRM_DE_CIERRE                ' ||
                                                         '      ,TRM_DIA_ANTERIOR             ' ||
                                                         '      ,VALORACION_AL_CIERRE_PESOS   ' ||
                                                         '      ,DISTR_DIA_TOTAL_COP          ' ||
                                                         '      ,DISTR_DIA_COP_DERECHO        ' ||
                                                         '      ,DISTR_DIA_COP_OBLIGACION     ' ||
                                                         '      ,DISTR_DIA_USD                ' ||
                                                         '      ,GANANCIA_ACUMULADA_USD_REEXP ' ||
                                                         '      ,DIST_DIA_COP_PRECIO          ' ||
                                                         '      ,DIST_DIA_COP_DIFCAMBIO       ' ||
                                                         '      ,VALOR_DERECHO_USD            ' ||
                                                         '      ,VALOR_OBLIGACION_USD         ' ||
                                                         '      ,VALOR_DERECHO_COP            ' ||
                                                         '      ,VALOR_OBLIGACION_COP         ' ||
                                                         '      ,VALOR_COMISION_COP           ' ||
                                                         '      ,DIST_DIA_COMISION            ' ||
                                                         '      ,OTROS_GASTOS_COP             ' ||
                                                         '      ,DIST_DIA_OTROS_GASTOS        ' ||
                                                         '      ,MARKET                       ' ||
                                                         '      ,CLASE_ACTIVO                 ' ||
                                                         '      ,TICKER_BLOOMBERG             ' ||
                                                         '      ,ESTADO_OPERACION             ' ||
                                                         '      ,EMISOR                       ' ||
                                                         '      ,FECHA_REPORTE                ' ||
                                                         '  FROM TMP_OPCONTADO_INVINT',
                                     P_CODIGO         => P_CODIGO,
                                     P_RESPUESTA      => P_RESPUESTA);

      IF P_CODIGO = '0000' THEN
        DBMS_OUTPUT.PUT_LINE('Se ha generado el archivo ' ||
                             V_NOMBRE_ARCHIVO || ' en la ruta ' || V_RUTA);
      END IF;
    END;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('OPCONTADO_INVINT_AUTO',
                                                      'FIN');
  EXCEPTION
    WHEN OTHERS THEN
      P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('Fallo OPCONTADO_INVINT_AUTO error; ' ||
                                                        SQLERRM,
                                                        'FIN');
      COMMIT;
      RAISE_APPLICATION_ERROR(-20060,
                              'No se genero el archivo, comuniquese con soporte, error: ' ||
                              SQLERRM);
  END OPCONTADO_INVINT_AUTO;

  PROCEDURE PORTAFOLIO_INVERSIONESINT IS

    CURSOR C_FON(P_FECHA DATE) IS
      SELECT DISTINCT (MIF_IIF_FON_CODIGO) FONDO,
                      FONDOS.FON_RAZON_SOCIAL RAZON_SOCIAL
        FROM FONDOS, MVTOS_INV_INTNAL_FONDOS
       WHERE FON_CODIGO = MIF_IIF_FON_CODIGO
         AND TRUNC(MIF_FECHA) >= P_FECHA --'23-ENE-2024'
         AND TRUNC(MIF_FECHA) < P_FECHA + 1; --'23-ENE-2024';
    R_FON C_FON%ROWTYPE;

    CURSOR C_IIF(P_FECHA DATE, P_FONDO VARCHAR2) IS
      SELECT MIF_FECHA FECHA_VALORACION,
             MIF_IIF_FON_CODIGO NIT_FONDO,
             (SELECT NVL(FON_NOMBRE_CORTO, FON_RAZON_SOCIAL)
                FROM FONDOS
               WHERE FON_CODIGO = P_FONDO) NOMBRE_FONDO,
             MIF_IIF_CODIGO CODIGO_PORTAFOLIO,
             ENA_MNEMONICO ESPECIE,
             IIF_BMO_MNEMONICO MONEDA,
             IIF_FUG_ISI_MNEMONICO ISIN,
             GNA_DESCRIPCION TIPO,
             MIF_TOTAL_VALOR_NOMINAL NOMINAL,
             MIF_PRECIO_CIERRE_USD PRECIO_DE_CIERRE_USD,
             MIF_TRM_CIERRE TRM_DE_CIERRE,
             NVL(MIF_PRECIO_CIERRE_USD, 0) * NVL(MIF_TRM_CIERRE, 0) PRECIO_DE_CIERRE_COP,
             MIF_VALOR_CIERRE_USD VALOR_EN_USD_AL_CIERRE,
             MIF_VALOR_CIERRE_COP VALOR_EN_COP_AL_CIERRE,
             MIF_DIST_DIA_TOTAL_COP DISTR_DIA_COP,
             MIF_DIST_USD_PRECIO DISTR_DIA_USD_POR_PRECIO,
             MIF_DIST_COP_PRECIO DISTR_DIA_COP_POR_PRECIO,
             MIF_QANT_TRMHOY_PRECIO INSUMO_DIF_CAMBIO_HOY,
             MIF_QANT_TRMANT_PRECIO INSUMO_DIF_CAMBIO_AYER,
             MIF_DIST_DIF_CAMBIO DISTR_DIA_POR_DIF_CAMBIO,
             (SELECT TMK_DESCRIPCION MARKET
                FROM TIPOS_MARKET_INVERSIONES_INT
               WHERE TMK_CODIGO = ENA_TMK_CODIGO) MARKET,
             (SELECT CII_DESCRIPCION CLASE_ACTIVO
                FROM CLASES_ACTIVOS_INVERSIONES_INT
               WHERE CII_CODIGO = ENA_CII_CODIGO) CLASE_ACTIVO,
             ENA_TICKER_BLOOMBERG TICKER_BLOOMBERG,
             MIF_PRECIO_PROM_COMPRA_USD PRECIO_PROM_COMPRA_USD,
             MIF_PRECIO_PROM_COMPRA_COP PRECIO_PROM_COMPRA_COP,
             EMI_DESCRIPCION EMISOR,
             TO_CHAR(SYSDATE, 'DD/MM/YYYY HH24:MI') FECHA_REPORTE
        FROM INVERSIONES_INTNAL_FONDOS,
             MVTOS_INV_INTNAL_FONDOS,
             FUNGIBLES,
             ESPECIES_NACIONALES,
             GRUPOS_NACIONALES,
             EMISORES
       WHERE IIF_CODIGO = MIF_IIF_CODIGO
         AND IIF_FON_CODIGO = MIF_IIF_FON_CODIGO
         AND IIF_FUG_ISI_MNEMONICO = FUG_ISI_MNEMONICO
         AND IIF_FUG_MNEMONICO = FUG_MNEMONICO
         AND FUG_ENA_MNEMONICO = ENA_MNEMONICO
         AND ENA_EMI_MNEMONICO = EMI_MNEMONICO
         AND ENA_GNA_MNEMONICO = GNA_MNEMONICO
         AND TRUNC(MIF_FECHA) >= P_FECHA --'23-ENE-2024'
         AND TRUNC(MIF_FECHA) < P_FECHA + 1 --'24-ENE-2024'
         AND MIF_IIF_FON_CODIGO = P_FONDO --'860079174'
         AND MIF_TMT_MNEMONICO IN ('VYR');
    R_IIF C_IIF%ROWTYPE;

    P_CODIGO             VARCHAR2(200);
    P_RESPUESTA          VARCHAR2(200);
    V_RUTA               VARCHAR2(100);
    V_NOMBRE_ARCHIVO     VARCHAR2(100);
    V_FECHA              VARCHAR2(30);
    V_FONDO              VARCHAR2(15);
    V_ARCHIVO            VARCHAR2(10);
    V_SALDO_NOMINAL      NUMBER;
    V_COMPRAS_PENDIENTES NUMBER;
    V_VENTAS_PENDIENTES  NUMBER;
    P_NUM_INI            NUMBER;
    P_NUM_FIN            NUMBER;

  BEGIN
    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('PORTAFOLIO_INVERSIONESINT_AUTO',
                                                      'INI');

    V_FECHA := SYSDATE - 1;
    --V_FECHA := '12-JUN-2023';
    --P_FONDO := '860079174';

    DELETE FROM TMP_PORTAFOLIO_INVINT;

    OPEN C_FON(V_FECHA);
    FETCH C_FON
      INTO R_FON;
    WHILE C_FON%FOUND LOOP

      V_SALDO_NOMINAL      := 0;
      V_COMPRAS_PENDIENTES := 0;
      V_VENTAS_PENDIENTES  := 0;

      OPEN C_IIF(V_FECHA, R_FON.FONDO);
      FETCH C_IIF
        INTO R_IIF;
      WHILE C_IIF%FOUND LOOP
        IF TRUNC(R_IIF.FECHA_VALORACION) = TRUNC(SYSDATE - 1) /*AND TRUNC(R_IIF.FECHA_VALORACION) < TRUNC(SYSDATE)*/
         THEN
          V_SALDO_NOMINAL := P_INVINT_FONDOS.FN_SALDO_NOMINAL(R_IIF.ISIN,
                                                              R_FON.FONDO);
          P_INVINT_FONDOS.PR_NOMINAL_PENDIENTE(P_ISIN               => R_IIF.ISIN,
                                               P_FONDO              => R_FON.FONDO,
                                               P_COMPRAS_PENDIENTES => V_COMPRAS_PENDIENTES,
                                               P_VENTAS_PENDIENTES  => V_VENTAS_PENDIENTES);
        END IF;

        INSERT INTO TMP_PORTAFOLIO_INVINT
          (FECHA_VALORACION,
           NIT_FONDO,
           NOMBRE_FONDO,
           CODIGO_PORTAFOLIO,
           ESPECIE,
           MONEDA,
           ISIN,
           TIPO,
           NOMINAL,
           PRECIO_DE_CIERRE_USD,
           TRM_DE_CIERRE,
           PRECIO_DE_CIERRE_COP,
           VALOR_EN_USD_AL_CIERRE,
           VALOR_EN_COP_AL_CIERRE,
           DISTR_DIA_COP,
           DISTR_DIA_USD_POR_PRECIO,
           DISTR_DIA_COP_POR_PRECIO,
           INSUMO_DIF_CAMBIO_HOY,
           INSUMO_DIF_CAMBIO_AYER,
           DISTR_DIA_POR_DIF_CAMBIO,
           NOMINAL_MAS_OPVIGENTES,
           COMPRAS_PENDIENTES,
           VENTAS_PENDIENTES,
           MARKET,
           CLASE_ACTIVO,
           TICKER_BLOOMBERG,
           PRECIO_PROM_COMPRA_USD,
           PRECIO_PROM_COMPRA_COP,
           EMISOR,
           FECHA_REPORTE)
        VALUES
          (TO_CHAR(R_IIF.FECHA_VALORACION, 'DD/MM/YYYY'),
           R_IIF.NIT_FONDO,
           R_IIF.NOMBRE_FONDO,
           R_IIF.CODIGO_PORTAFOLIO,
           R_IIF.ESPECIE,
           R_IIF.MONEDA,
           R_IIF.ISIN,
           R_IIF.TIPO,
           R_IIF.NOMINAL,
           R_IIF.PRECIO_DE_CIERRE_USD,
           R_IIF.TRM_DE_CIERRE,
           R_IIF.PRECIO_DE_CIERRE_COP,
           R_IIF.VALOR_EN_USD_AL_CIERRE,
           R_IIF.VALOR_EN_COP_AL_CIERRE,
           R_IIF.DISTR_DIA_COP,
           R_IIF.DISTR_DIA_USD_POR_PRECIO,
           R_IIF.DISTR_DIA_COP_POR_PRECIO,
           R_IIF.INSUMO_DIF_CAMBIO_HOY,
           R_IIF.INSUMO_DIF_CAMBIO_AYER,
           R_IIF.DISTR_DIA_POR_DIF_CAMBIO,
           V_SALDO_NOMINAL + V_COMPRAS_PENDIENTES - V_VENTAS_PENDIENTES --R_IIF.NOMINAL_MAS_OPVIGENTES
          ,
           V_COMPRAS_PENDIENTES --R_IIF.COMPRAS_PENDIENTES
          ,
           V_VENTAS_PENDIENTES --R_IIF.VENTAS_PENDIENTES
          ,
           R_IIF.MARKET,
           R_IIF.CLASE_ACTIVO,
           R_IIF.TICKER_BLOOMBERG,
           R_IIF.PRECIO_PROM_COMPRA_USD,
           R_IIF.PRECIO_PROM_COMPRA_COP,
           R_IIF.EMISOR,
           R_IIF.FECHA_REPORTE);
        FETCH C_IIF
          INTO R_IIF;
      END LOOP;
      CLOSE C_IIF;

      FETCH C_FON
        INTO R_FON;
    END LOOP;
    CLOSE C_FON;
    COMMIT;

    V_RUTA           := '\\nas.corredor.local\contabilidad\PRIVADA\Reportes transmisiones\Diarios\';
    V_NOMBRE_ARCHIVO := 'PORTAFOLIO_INVERSIONESINT_AUTO_' ||
                        TO_CHAR(SYSDATE - 1, 'DDMMYYYY_hh24mmss');

    BEGIN
      P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => V_RUTA,
                                     P_NOMBRE_ARCHIVO => V_NOMBRE_ARCHIVO,
                                     P_QUERY          => 'SELECT FECHA_VALORACION         ' ||
                                                         '      ,NIT_FONDO                ' ||
                                                         '      ,NOMBRE_FONDO             ' ||
                                                         '      ,CODIGO_PORTAFOLIO        ' ||
                                                         '      ,ESPECIE                  ' ||
                                                         '      ,MONEDA                   ' ||
                                                         '      ,ISIN                     ' ||
                                                         '      ,TIPO                     ' ||
                                                         '      ,NOMINAL                  ' ||
                                                         '      ,PRECIO_DE_CIERRE_USD     ' ||
                                                         '      ,TRM_DE_CIERRE            ' ||
                                                         '      ,PRECIO_DE_CIERRE_COP     ' ||
                                                         '      ,VALOR_EN_USD_AL_CIERRE   ' ||
                                                         '      ,VALOR_EN_COP_AL_CIERRE   ' ||
                                                         '      ,DISTR_DIA_COP            ' ||
                                                         '      ,DISTR_DIA_USD_POR_PRECIO ' ||
                                                         '      ,DISTR_DIA_COP_POR_PRECIO ' ||
                                                         '      ,INSUMO_DIF_CAMBIO_HOY    ' ||
                                                         '      ,INSUMO_DIF_CAMBIO_AYER   ' ||
                                                         '      ,DISTR_DIA_POR_DIF_CAMBIO ' ||
                                                         '      ,NOMINAL_MAS_OPVIGENTES   ' ||
                                                         '      ,COMPRAS_PENDIENTES       ' ||
                                                         '      ,VENTAS_PENDIENTES        ' ||
                                                         '      ,MARKET                   ' ||
                                                         '      ,CLASE_ACTIVO             ' ||
                                                         '      ,TICKER_BLOOMBERG         ' ||
                                                         '      ,PRECIO_PROM_COMPRA_USD   ' ||
                                                         '      ,PRECIO_PROM_COMPRA_COP   ' ||
                                                         '      ,EMISOR                   ' ||
                                                         '      ,FECHA_REPORTE            ' ||
                                                         '  FROM TMP_PORTAFOLIO_INVINT',
                                     P_CODIGO         => P_CODIGO,
                                     P_RESPUESTA      => P_RESPUESTA);

      IF P_CODIGO = '0000' THEN
        DBMS_OUTPUT.PUT_LINE('Se ha generado el archivo ' ||
                             V_NOMBRE_ARCHIVO || ' en la ruta ' || V_RUTA);
      END IF;
    END;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('PORTAFOLIO_INVERSIONESINT',
                                                      'FIN');
  EXCEPTION
    WHEN OTHERS THEN
      P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('Fallo PORTAFOLIO_INVERSIONESINT_AUTO error; ' ||
                                                        SQLERRM,
                                                        'FIN');
      COMMIT;
      RAISE_APPLICATION_ERROR(-20059,
                              'No se genero el archivo, comuniquese con soporte, error: ' ||
                              SQLERRM);
  END PORTAFOLIO_INVERSIONESINT;

  PROCEDURE PR_REPORTE_RECBEF(P_USERID IN VARCHAR2) IS

    P_CONDICION  VARCHAR2(5000);
    P_MOVIMIENTO VARCHAR2(5000);
    P_TIPO       VARCHAR2(150);
    P_FECHAS     VARCHAR2(150);
    P_FECHA_INI  VARCHAR2(150);
    P_FECHA_FIN  VARCHAR2(150);

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_RECBEF',
                                                      'INI');

    SELECT TO_CHAR(TRUNC(SYSDATE - 1),
                   'DD-MON-YYYY',
                   'nls_date_language = ''LATIN AMERICAN SPANISH''')
      INTO P_FECHA_INI
      FROM DUAL;

    SELECT TO_CHAR(TRUNC(SYSDATE),
                   'DD-MON-YYYY',
                   'nls_date_language = ''LATIN AMERICAN SPANISH''')
      INTO P_FECHA_FIN
      FROM DUAL;

    P_CONDICION := 'CBEF.CBEF_FON_CODIGO%20LIKE%20%27%25%27%20AND%20CBEF.CBEF_ESTADO%20=%20%27A%27%20AND';
    P_TIPO      := '%27Resumido%27';
    P_FECHAS    := 'MCE.MCE_FECHA%20%3E=%20%27%27' || P_FECHA_INI ||
                   '%27%27%20AND%20MCE.MCE_FECHA%20%3C%20%27%27' ||
                   P_FECHA_FIN || '%27%27';

    SELECT TO_CHAR(TRUNC(SYSDATE - 1),
                   'DD-MON-YYYY',
                   'nls_date_language = ''LATIN AMERICAN SPANISH''')
      INTO P_FECHA_FIN
      FROM DUAL;

    P_TOOLS.PR_CREAR_REPORTE(P_REPORT     => 'RECBEF',
                             P_USERID     => P_USERID,
                             P_FORMATO    => 'PDF',
                             P_PARAMETROS => '+P_CONDICION=' || P_CONDICION ||
                                             '+P_FECHAS=' || P_FECHAS ||
                                             '+P_FECHA_INI=%27' ||
                                             P_FECHA_INI ||
                                             '%27+P_FECHA_FIN=%27' ||
                                             P_FECHA_FIN || '%27+P_TIPO=' ||
                                             P_TIPO || '',
                             P_ARCHIVO    => '/apps/rep_nocturnos/diarios/RECBEF_' ||
                                             P_FECHA_INI);

    P_TOOLS.PR_CREAR_REPORTE(P_REPORT     => 'RECBEF',
                             P_USERID     => P_USERID,
                             P_FORMATO    => 'TXT',
                             P_PARAMETROS => '+P_CONDICION=' || P_CONDICION ||
                                             '+P_FECHAS=' || P_FECHAS ||
                                             '+P_FECHA_INI=%27' ||
                                             P_FECHA_INI ||
                                             '%27+P_FECHA_FIN=%27' ||
                                             P_FECHA_FIN || '%27+P_TIPO=' ||
                                             P_TIPO || '',
                             P_ARCHIVO    => '/apps/rep_nocturnos/diarios/RECBEF_' ||
                                             P_FECHA_INI --'\\nas\contabilidad\PRIVADA\Reportes transmisiones\Diarios\RECBEF_'||P_FECHA_INI'
                             );

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_RECBEF',
                                                      'FIN');

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PR_REPORTE_RECBEF',
                              SUBSTR(SQLERRM, 1, 80),
                              'procesosnocturnos@corredores.com');
  END PR_REPORTE_RECBEF;
  -- FIN VAGTUD978 - Arbitraje

END P_PROCESOS_NOCTURNOS;

/

  GRANT EXECUTE ON "PROD"."P_PROCESOS_NOCTURNOS" TO "COE_RECURSOS";
  GRANT EXECUTE ON "PROD"."P_PROCESOS_NOCTURNOS" TO "RESOURCE";
