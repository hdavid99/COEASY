  /******************PROCEDIMIENTO DE EJECUCIżN DIARIA**************************/
  PROCEDURE PR_GENERA_REPORTES_DIARIO(P_USERID IN VARCHAR2) AS
  BEGIN
    PR_REPORTE_NEXT_DAY(P_USERID);
    PORTAFOLIO_VALORACION;
    PR_REPORTE_COPORF_CD(P_USERID);
    PR_REPORTE_COPORF_VL(P_USERID);
    PR_REPORTE_RCVTCR(P_USERID);
    PR_REPORTE_REXCLS1_PP(P_USERID);
    PR_REPORTE_RECOFU(P_USERID);
    PR_REPORTE_RVALCO(P_USERID);
    PR_REPORTE_RPYGFO(P_USERID);
    PR_REPORTE_RECAFO(P_USERID);
    PR_REPORTE_RORRDS(P_USERID);
    PR_REPORTE_LIFVES_FF(P_USERID);
    PR_REPORTE_LIFVES_FG(P_USERID);
    PR_REPORTE_CSVFO(P_USERID);
    PR_REPORTE_COMFCP;
    PR_REPORTE_CBNOCO;
    PR_REPORTE_COMODE;
    PR_REPORTE_ROPDER(P_USERID);
    PR_REPORTE_RMOVBA(P_USERID);
    PR_REPORTE_RCMVTF(P_USERID);
    PR_REPORTE_RCONRV(P_USERID);
    PR_REPORTE_RINVRV(P_USERID);
    PR_REPORTE_RREPRV(P_USERID);
    PR_REPORTE_RSINRV(P_USERID);
    --ARBITRAJE VAGTUD978
    PR_REPORTE_RECBEF(P_USERID);
    --FIN ARBITRAJE

  END;
  /******************PROCEDIMIENTO DE EJECUCIżN MENSUAL**************************/
  PROCEDURE PR_GENERA_REPORTES_MENSUAL(P_USERID IN VARCHAR2) AS
  BEGIN
    PR_REPORTE_REXCLF_MES(P_USERID);
    PR_REPORTE_REXCLF_ACUM(P_USERID);
    PR_REPORTE_REXCLS(P_USERID);
    PR_REPORTE_REXCLS3(P_USERID);
    -----DINAMICAS CONTABLES FASE 1---
    PR_GENERA_REPORTES_DINAMICAS(P_USERID);
  END;
  /*******************************FIN REPORTES NOCTURNOS*********************************/

  /*******************************INICIO REPORTES NOCTURNOS A2*********************************/
  PROCEDURE PR_REPORTE_RORRDS_A2(P_USERID IN VARCHAR2) IS

    VAR      VARCHAR2(2000);
    V_FECHA  VARCHAR2(20);
    V_FECHAN VARCHAR2(20);

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN
    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_RORRDS_A2',
                                                      'INI');

    SELECT TO_CHAR(TRUNC(P_TOOLS.DIA_HABIL_SIGUIENTE(SYSDATE - 1)),
                   'DD-MON-YYYY',
                   'nls_date_language = ''LATIN AMERICAN SPANISH''')
      INTO V_FECHA
      FROM DUAL;

    SELECT TO_CHAR(TRUNC(SYSDATE - 1),
                   'DD-MON-YYYY',
                   'nls_date_language = ''LATIN AMERICAN SPANISH''')
      INTO V_FECHAN
      FROM DUAL;
    /*P_MAIL.ENVIO_MAIL_ERROR('Inicio genera reporte RORRDS ',
    '<br>'||'Fecha consultada del reporte: '||V_FECHA||,
    DESTINATARIOS); */

    P_TOOLS.PR_CREAR_REPORTE(P_REPORT     => 'RORRDS2',
                             P_USERID     => P_USERID,
                             P_FORMATO    => 'PDF',
                             P_PARAMETROS => '+P_FECHA_INICIAL=' || V_FECHA ||
                                             '+P_FECHA_FINAL=' || V_FECHA,
                             P_ARCHIVO    => '/apps/rep_nocturnos_a2/RORRDS_A2_' ||
                                             V_FECHAN);

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PR_REPORTE_RORRDS_A2',
                              SUBSTR(SQLERRM, 1, 80),
                              'procesosnocturnos@corredores.com');
  END PR_REPORTE_RORRDS_A2;

  PROCEDURE PR_REPORTE_REMOCL_A2(P_USERID IN VARCHAR2) IS

    VAR         VARCHAR2(2000);
    V_FECHA     VARCHAR2(20);
    V_FECHAS    VARCHAR2(1000);
    V_FECHAS1   VARCHAR2(20);
    V_FECHASN   VARCHAR2(20);
    V_CONDICION VARCHAR2(1000);

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN
    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_REMOCL_A2',
                                                      'INI');

    SELECT TO_CHAR(P_TOOLS.CF_DIA_HABIL_ANTERIOR(SYSDATE),
                   'DD-MON-YYYY',
                   'nls_date_language = ''LATIN AMERICAN SPANISH'''),
           TO_CHAR(SYSDATE,
                   'DD-MON-YYYY',
                   'nls_date_language = ''LATIN AMERICAN SPANISH''')
      INTO V_FECHAS, V_FECHAS1
      FROM DUAL;

    SELECT TO_CHAR(trunc(SYSDATE - 1), 'DDMMYYYY')
      INTO V_FECHASN
      FROM DUAL;

    V_CONDICION := '%20MCC.MCC_TMC_MNEMONICO%20IN(%20%27ABO%27%20,%20%27CAR%27%20)AND';
    /*P_MAIL.ENVIO_MAIL_ERROR('Inicio genera reporte REMOCL ',
    '<br>'||'Fecha consultada del reporte: '||V_FECHA||,
    DESTINATARIOS); */

    P_TOOLS.PR_CREAR_REPORTE(P_REPORT     => 'REMOCL',
                             P_USERID     => P_USERID,
                             P_FORMATO    => 'XLS',
                             P_PARAMETROS => '+P_FECHAS=MCC.MCC_FECHA%20%3E=%27' ||
                                             V_FECHAS ||
                                             '%27AND%20MCC.MCC_FECHA%3C%27' ||
                                             V_FECHAS1 ||
                                             '%27%20AND+P_TIPO=Detallado+P_CONDICION=' ||
                                             V_CONDICION,
                             P_ARCHIVO    => '/apps/rep_nocturnos_a2/REMOCL_A2_' ||
                                             V_FECHASN);

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PR_REPORTE_REMOCL_A2',
                              SUBSTR(SQLERRM, 1, 80),
                              'procesosnocturnos@corredores.com');
  END PR_REPORTE_REMOCL_A2;

