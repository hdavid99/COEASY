  /*****************************************************************************************************************************************
  ***  PROCEDIMIENTO  P_PROCESOS_NOCTURNOS.PR_SALDOS_CMA                                                                           **
  ***     - realiza llamado a proceso  P_NOTIFICACION_CMA.PR_NOTIF_SALDOS :PROCEDIMIENTO PARA LA NOTIFICACIżN DIARIA DE SALDOS A CMA **
  ***     - se corre todos los dias                                                                                                       **
  ***     -         **
  /*************************************************************************************************************************************** */
  PROCEDURE PR_SALDOS_CMA IS

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_SALDOS_CMA',
                                                      'INI');

    BEGIN
      P_MAIL.ENVIO_MAIL_ERROR('Inicio proceso nocturno P_NOTIFICACION_CMA.PR_NOTIF_SALDOS . ',
                              '<br>' || 'Fecha Proceso: ' || SYSDATE,
                              DESTINATARIOS);
    EXCEPTION
      WHEN OTHERS THEN
        DBMS_OUTPUT.PUT_LINE('-20001 Fallo el llamado al paquete de Mail. ' ||
                             SQLERRM);
    END;
    P_NOTIFICACION_CMA.PR_NOTIF_SALDOS;
    P_MAIL.ENVIO_MAIL_ERROR('Proceso finalizado con EXITO : P_NOTIFICACION_CMA.PR_NOTIF_SALDOS . ',
                            '<br>' || 'Fecha Proceso: ' || SYSDATE,
                            DESTINATARIOS);

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_SALDOS_CMA',
                                                      'FIN');
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('P_NOTIFICACION_CMA.PR_NOTIF_SALDOS . Fecha de Proceso' ||
                              SYSDATE || ' ' || SUBSTR(SQLERRM, 1, 80),
                              DESTINATARIOS);
  END PR_SALDOS_CMA;

  /*****************************************************************************************************************************************
  ***  PROCEDIMIENTO  P_PROCESOS_NOCTURNOS.PR_BLOQUEA_CLI_PLV                                                                           **
  ***     - deja en estado BAA y motivos BCS a todos los clientes creados por PLV
  ***     - se corre todos los dias durante le ejecucion de la OPA                                                                                                       **
  ***     -         **
  /*************************************************************************************************************************************** */

  PROCEDURE PR_BLOQUEA_CLI_PLV IS
    V_VALOR      CONSTANTES.CON_VALOR%TYPE;
    V_VALOR_DATE CONSTANTES.CON_VALOR_DATE%TYPE;
    V_VALOR_CHAR CONSTANTES.CON_VALOR_CHAR%TYPE;

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_BLOQUEA_CLI_PLV',
                                                      'INI');

    P_MAIL.ENVIO_MAIL_ERROR('Inicio proceso nocturno PR_BLOQUEA_CLI_PLV. ',
                            '<br>' || 'Fecha Proceso: ' || SYSDATE,
                            DESTINATARIOS);
    V_VALOR      := NULL;
    V_VALOR_DATE := NULL;
    V_VALOR_CHAR := NULL;
    P_TOOLS.CONSULTARCONSTANTE(P_CONSTANTE  => 'FIO',
                               P_VALOR      => V_VALOR,
                               P_VALOR_DATE => V_VALOR_DATE,
                               P_VALOR_CHAR => V_VALOR_CHAR);

    IF TRUNC(SYSDATE) <= TRUNC(V_VALOR_DATE) THEN
      DBMS_OUTPUT.PUT_LINE('INACTIVANDO CLIENTES PLV');
      BEGIN
        UPDATE CLIENTES
           SET CLI_ECL_MNEMONICO = 'BAA', CLI_MOI_MNEMONICO = 'BCS'
         WHERE CLI_ECL_MNEMONICO = 'ACC'
           AND EXISTS (SELECT 'X'
                  FROM PERSONAS
                 WHERE PER_NUM_IDEN = CLI_PER_NUM_IDEN
                   AND PER_TID_CODIGO = CLI_PER_TID_CODIGO
                   AND NVL(PER_ORIGEN, ' ') = 'PLV');
      END;
      COMMIT;
    END IF;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_BLOQUEA_CLI_PLV',
                                                      'FIN');
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('P_PROCESOS_NOCTURNOS.PR_BLOQUEA_CLI_PLV . Fecha de Proceso' ||
                              SYSDATE || ' ' || SUBSTR(SQLERRM, 1, 80),
                              DESTINATARIOS);

  END PR_BLOQUEA_CLI_PLV;

  PROCEDURE PR_GENERACION_VISTAS_OPEN IS

    P_CALCULAR_SALDO_INICIAL VARCHAR2(200);
    P_CODIGO_TIPO_PRODUCTO   VARCHAR2(200);
    P_FECHA_INI              DATE;
    P_FECHA_FIN              DATE;
    P_BORRA_HISTORIA         VARCHAR2(200);

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_GENERACION_VISTAS_OPEN',
                                                      'INI');

    P_MAIL.ENVIO_MAIL_ERROR('Inicio proceso GENERACION VISTAS OPEN',
                            '<br>' || 'Fecha Proceso: ' || SYSDATE,
                            DESTINATARIOS);
    P_CALCULAR_SALDO_INICIAL := 'N';
    P_CODIGO_TIPO_PRODUCTO   := '%';
    P_FECHA_INI              := TRUNC(SYSDATE - 10);
    P_FECHA_FIN              := TRUNC(SYSDATE - 1);
    P_BORRA_HISTORIA         := 'S';

    P_OPEN_FINANCE.P_SALDOS_MOVIMIENTOS(P_CALCULAR_SALDO_INICIAL => P_CALCULAR_SALDO_INICIAL,
                                        P_CODIGO_TIPO_PRODUCTO   => P_CODIGO_TIPO_PRODUCTO,
                                        P_FECHA_INI              => P_FECHA_INI,
                                        P_FECHA_FIN              => P_FECHA_FIN,
                                        P_BORRA_HISTORIA         => P_BORRA_HISTORIA);
    P_MAIL.ENVIO_MAIL_ERROR('Fin proceso GENERACION VISTAS OPEN',
                            '<br>' ||
                            'Proceso finaliza con exito. Fecha Proceso: ' ||
                            SYSDATE,
                            DESTINATARIOS);

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_GENERACION_VISTAS_OPEN',
                                                      'FIN');
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Proceso GENERACION VISTAS OPEN . Fecha de Proceso' ||
                              SYSDATE || ' ' || SUBSTR(SQLERRM, 1, 80),
                              DESTINATARIOS);
  END PR_GENERACION_VISTAS_OPEN;

  PROCEDURE PR_MARCACION_ADMON_VAL IS
    V_DIAMES VARCHAR2(4);

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_MARCACION_ADMON_VAL',
                                                      'INI');

    SELECT TO_CHAR(SYSDATE, 'DD') || TO_CHAR(SYSDATE, 'MM')
      INTO V_DIAMES
      FROM DUAL;

    IF V_DIAMES = '0101' THEN
      -- EJECUTA TODOS LOS 01-ENERO (0101)
      BEGIN
        DBMS_OUTPUT.PUT_LINE('EJECUTANDO PROCESO DE MARCACION ');
        P_CLIENTES.PR_MARCAR_ADMON_VAL;

        P_MAIL.ENVIO_MAIL_ERROR('Proceso Nocturno PR_MARCACION_ADMON_VAL',
                                'El proceso de marcaciżn de los clientes para cobro de Admon Valores ' ||
                                'ha sido ejecutado exitosamente. ',
                                DESTINATARIOS_ADMON_VAL);

      EXCEPTION
        WHEN OTHERS THEN
          P_MAIL.ENVIO_MAIL_ERROR('Error Proceso Nocturno PR_MARCACION_ADMON_VAL',
                                  'Se ha generado un Error en el proceso ' ||
                                  'de marcaciżn de los clientes para cobro de Admon Valores ' ||
                                  SUBSTR(SQLERRM, 1, 80),
                                  DESTINATARIOS_ADMON_VAL);
      END;
    ELSE
      NULL;
    END IF;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_MARCACION_ADMON_VAL',
                                                      'FIN');
    COMMIT;

  END PR_MARCACION_ADMON_VAL;

  PROCEDURE MAIL_TID_CER_PENDIENTES_COMER(P_TX IN NUMBER DEFAULT NULL) IS

    CURSOR C_TTC IS
      SELECT CON_VALOR FROM CONSTANTES WHERE CON_MNEMONICO = 'TTC';
    TTC NUMBER;

    CURSOR C_COM IS
      SELECT CCC.CCC_PER_NUM_IDEN,
             CCC.CCC_PER_TID_CODIGO,
             COM.PER_MAIL_CORREDOR
        FROM ESPECIES_NACIONALES        ENA,
             FUNGIBLES                  FUG,
             CUENTAS_FUNGIBLE_CLIENTE   CFC,
             FILTRO_PERSONAS            PER,
             CUENTAS_CLIENTE_CORREDORES CCC,
             FILTRO_COMERCIALES         COM
       WHERE ENA.ENA_MNEMONICO = FUG.FUG_ENA_MNEMONICO
         AND CFC_FUG_ISI_MNEMONICO = FUG.FUG_ISI_MNEMONICO
         AND CFC_FUG_MNEMONICO = FUG.FUG_MNEMONICO
         AND CFC.CFC_CCC_CLI_PER_NUM_IDEN = PER.PER_NUM_IDEN
         AND CFC.CFC_CCC_CLI_PER_TID_CODIGO = PER.PER_TID_CODIGO
         AND CFC.CFC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
         AND CFC.CFC_CCC_CLI_PER_TID_CODIGO = CCC.CCC_CLI_PER_TID_CODIGO
         AND CFC.CFC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA
         AND CCC.CCC_PER_TID_CODIGO = COM.PER_TID_CODIGO
         AND CCC.CCC_PER_NUM_IDEN = COM.PER_NUM_IDEN
         AND ENA.ENA_GNA_MNEMONICO IN ('TID', 'CER')
         AND FUG.FUG_FECHA_VENCIMIENTO >= TRUNC(SYSDATE)
         AND FUG.FUG_FECHA_VENCIMIENTO <= TRUNC(SYSDATE + TTC)
         AND CFC.CFC_SALDO_DCVAL_DISPONIBLE <> 0
      UNION
      SELECT CCC.CCC_PER_NUM_IDEN,
             CCC.CCC_PER_TID_CODIGO,
             COM.PER_MAIL_CORREDOR
        FROM TITULOS                    TLO,
             CUENTAS_CLIENTE_CORREDORES CCC,
             FILTRO_PERSONAS            PER,
             FILTRO_COMERCIALES         COM,
             ESPECIES_NACIONALES        ENA
       WHERE PER.PER_TID_CODIGO = TLO.TLO_CCC_CLI_PER_TID_CODIGO
         AND PER.PER_NUM_IDEN = TLO.TLO_CCC_CLI_PER_NUM_IDEN
         AND TLO.TLO_CCC_CLI_PER_TID_CODIGO = CCC.CCC_CLI_PER_TID_CODIGO
         AND TLO.TLO_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
         AND CCC.CCC_PER_TID_CODIGO = COM.PER_TID_CODIGO
         AND CCC.CCC_PER_NUM_IDEN = COM.PER_NUM_IDEN
         AND TLO.TLO_ENA_MNEMONICO = ENA.ENA_BST_MNEMONICO
         AND ENA.ENA_GNA_MNEMONICO IN ('TID', 'CER')
         AND TLO.TLO_FECHA_VENCIMIENTO >= TRUNC(SYSDATE)
         AND TLO.TLO_FECHA_VENCIMIENTO <= TRUNC(SYSDATE + TTC)
         AND TLO.TLO_PORTAFOLIO = 'S';
    R_COM C_COM%ROWTYPE;

    CURSOR C_TIT IS
      SELECT CFC.CFC_CCC_CLI_PER_NUM_IDEN,
             CFC.CFC_CCC_CLI_PER_TID_CODIGO,
             PER.PER_NOMBRE,
             ENA.ENA_MNEMONICO ESPECIE,
             CFC.CFC_SALDO_DCVAL_DISPONIBLE VALOR,
             FUG.FUG_FECHA_VENCIMIENTO FECHA_VENCIMIENTO,
             'DECEVAL' DEPOSITO
        FROM ESPECIES_NACIONALES        ENA,
             FUNGIBLES                  FUG,
             CUENTAS_FUNGIBLE_CLIENTE   CFC,
             FILTRO_PERSONAS            PER,
             CUENTAS_CLIENTE_CORREDORES CCC,
             FILTRO_COMERCIALES         COM
       WHERE ENA.ENA_MNEMONICO = FUG.FUG_ENA_MNEMONICO
         AND CFC_FUG_ISI_MNEMONICO = FUG.FUG_ISI_MNEMONICO
         AND CFC_FUG_MNEMONICO = FUG.FUG_MNEMONICO
         AND CFC.CFC_CCC_CLI_PER_NUM_IDEN = PER.PER_NUM_IDEN
         AND CFC.CFC_CCC_CLI_PER_TID_CODIGO = PER.PER_TID_CODIGO
         AND CFC.CFC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
         AND CFC.CFC_CCC_CLI_PER_TID_CODIGO = CCC.CCC_CLI_PER_TID_CODIGO
         AND CFC.CFC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA
         AND CCC.CCC_PER_TID_CODIGO = COM.PER_TID_CODIGO
         AND CCC.CCC_PER_NUM_IDEN = COM.PER_NUM_IDEN
         AND COM.PER_TID_CODIGO = R_COM.CCC_PER_TID_CODIGO
         AND COM.PER_NUM_IDEN = R_COM.CCC_PER_NUM_IDEN
         AND ENA.ENA_GNA_MNEMONICO IN ('TID', 'CER')
         AND FUG.FUG_FECHA_VENCIMIENTO >= TRUNC(SYSDATE)
         AND FUG.FUG_FECHA_VENCIMIENTO <= TRUNC(SYSDATE + TTC)
         AND CFC.CFC_SALDO_DCVAL_DISPONIBLE <> 0
      UNION
      SELECT TLO.TLO_CCC_CLI_PER_NUM_IDEN,
             TLO.TLO_CCC_CLI_PER_TID_CODIGO,
             PER.PER_NOMBRE,
             TLO.TLO_ENA_MNEMONICO ESPECIE,
             TLO.TLO_VALOR_NOMINAL,
             TLO.TLO_FECHA_VENCIMIENTO,
             'DCV' DEPOSITO
        FROM TITULOS                    TLO,
             CUENTAS_CLIENTE_CORREDORES CCC,
             FILTRO_PERSONAS            PER,
             FILTRO_COMERCIALES         COM,
             ESPECIES_NACIONALES        ENA
       WHERE PER.PER_TID_CODIGO = TLO.TLO_CCC_CLI_PER_TID_CODIGO
         AND PER.PER_NUM_IDEN = TLO.TLO_CCC_CLI_PER_NUM_IDEN
         AND TLO.TLO_CCC_CLI_PER_TID_CODIGO = CCC.CCC_CLI_PER_TID_CODIGO
         AND TLO.TLO_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
         AND CCC.CCC_PER_TID_CODIGO = COM.PER_TID_CODIGO
         AND CCC.CCC_PER_NUM_IDEN = COM.PER_NUM_IDEN
         AND TLO.TLO_ENA_MNEMONICO = ENA.ENA_BST_MNEMONICO
         AND COM.PER_TID_CODIGO = R_COM.CCC_PER_TID_CODIGO
         AND COM.PER_NUM_IDEN = R_COM.CCC_PER_NUM_IDEN
         AND ENA.ENA_GNA_MNEMONICO IN ('TID', 'CER')
         AND TLO.TLO_FECHA_VENCIMIENTO >= TRUNC(SYSDATE)
         AND TLO.TLO_FECHA_VENCIMIENTO <= TRUNC(SYSDATE + TTC)
         AND TLO.TLO_PORTAFOLIO = 'S';
    R_TIT C_TIT%ROWTYPE;

    CONN UTL_SMTP.CONNECTION;
    REQ  UTL_HTTP.REQ;
    RESP UTL_HTTP.RESP;

    DIRECCION         VARCHAR2(1000);
    FECHA             DATE;
    V_BUFLINE         VARCHAR2(4000);
    V_ARCHIVO_DETALLE VARCHAR2(500);
    CRLF              VARCHAR2(2) := CHR(13) || CHR(10);
    N                 VARCHAR2(20);

    N_ID_PROCESO NUMBER;
    N_TX NUMBER;

  BEGIN

    --se asigna el consecutivo del proceso(tabla PARAMETRIZACION_PROCESOS)
    N_ID_PROCESO := P_TRAZA_CORE.FN_ID_PROCESO('P_PROCESOS_NOCTURNOS.MAIL_TID_CER_PENDIENTES_COMER');

    --se Asigna consecutivo para la transaccion, si el proceso es el primero que se llama, reinicia el consecutivo
    N_TX := P_TRAZA_CORE.FN_TRAE_TX(P_TX);

    --Registra Traza
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'I',
                                    'Inicio proceso P_PROCESOS_NOCTURNOS.MAIL_TID_CER_PENDIENTES_COMER. Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss') || 'Rango de fechas procesado: ' ||
                                    TO_CHAR(SYSDATE, 'DD-MON-YYYY') || ' a ' ||
                                    TO_CHAR(SYSDATE + TTC, 'DD-MON-YYYY'),
                                    N_TX);                            

    OPEN C_TTC;
    FETCH C_TTC
      INTO TTC;
    CLOSE C_TTC;

    OPEN C_COM;
    FETCH C_COM
      INTO R_COM;
    WHILE C_COM%FOUND LOOP

      SELECT TO_CHAR(SYSDATE, 'DDMMYYYYHH24MISS') || '_' ||
             lpad((1 + ABS(MOD(dbms_random.random, 99999))), 5, '0')
        INTO N
        FROM DUAL;
      V_ARCHIVO_DETALLE := 'VPC_' || N;
      DIRECCION         := R_COM.PER_MAIL_CORREDOR;

      CONN := P_MAIL.BEGIN_MAIL(SENDER     => 'administrador@corredores.com',
                                RECIPIENTS => DIRECCION,
                                SUBJECT    => 'Lista de TIDIS y CERT proximos a vencer al- ' ||
                                              TO_CHAR(TRUNC(SYSDATE + TTC),
                                                      'dd-Mon-yyyy'),
                                MIME_TYPE  => P_MAIL.MULTIPART_MIME_TYPE);

      P_MAIL.BEGIN_ATTACHMENT(CONN         => CONN,
                              mime_type    => v_archivo_detalle || '/txt',
                              INLINE       => TRUE,
                              FILENAME     => V_ARCHIVO_DETALLE || '.txt',
                              TRANSFER_ENC => 'text');

      -- ENCABEZADOS
      V_BUFLINE := 'NOMBRE CLIENTE' || ';' || 'ESPECIE' || ';' || 'VALOR' || ';' ||
                   'FECHA VENCIMIENTO' || ';' || 'DEPOSITO';
      P_MAIL.WRITE_MB_TEXT(CONN, V_BUFLINE || CRLF);

      --OPERACIONES
      OPEN C_TIT;
      FETCH C_TIT
        INTO R_TIT;
      WHILE C_TIT%FOUND LOOP
        V_BUFLINE := R_TIT.PER_NOMBRE || ';' || R_TIT.ESPECIE || ';' ||
                     R_TIT.VALOR || ';' || R_TIT.FECHA_VENCIMIENTO || ';' ||
                     R_TIT.DEPOSITO;
        P_MAIL.WRITE_MB_TEXT(CONN, V_BUFLINE || CRLF);
        FETCH C_TIT
          INTO R_TIT;
      END LOOP;
      CLOSE C_TIT;
      P_MAIL.END_ATTACHMENT(CONN => CONN);
      P_MAIL.END_MAIL(CONN => CONN);
      FETCH C_COM
        INTO R_COM;
    END LOOP;
    CLOSE C_COM;

      --Registra Traza
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'F',
                                    'Fin proceso P_PROCESOS_NOCTURNOS.MAIL_TID_CER_PENDIENTES_COMER. Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss') || 'Rango de fechas procesado: ' ||
                                    TO_CHAR(SYSDATE, 'DD-MON-YYYY') || ' a ' ||
                                    TO_CHAR(SYSDATE + TTC, 'DD-MON-YYYY')|| ' Proceso terminado con exito',
                                    N_TX);                                                             
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
       P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                          'E',
                                          'Error proceso P_PROCESOS_NOCTURNOS.MAIL_TID_CER_PENDIENTES_COMER. Fecha Proceso: ' ||
                                          TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss') 
                                          ||'Error: '||SQLERRM,
                                          N_TX);                                
  END MAIL_TID_CER_PENDIENTES_COMER;

  PROCEDURE MAIL_TID_CER_PENDIENTES_COORD(P_TX IN NUMBER DEFAULT NULL) IS

    CURSOR C_TTJ IS
      SELECT CON_VALOR FROM CONSTANTES WHERE CON_MNEMONICO = 'TTJ';
    TTJ NUMBER;

    CURSOR C_MES IS
      SELECT SUM(CANTIDAD), CENTRO_PRODUCCION
        FROM (SELECT COUNT(*) CANTIDAD,
                     PCP.PCP_CPR_MNEMONICO CENTRO_PRODUCCION
                FROM ESPECIES_NACIONALES         ENA,
                     FUNGIBLES                   FUG,
                     CUENTAS_FUNGIBLE_CLIENTE    CFC,
                     FILTRO_PERSONAS             PER,
                     CUENTAS_CLIENTE_CORREDORES  CCC,
                     FILTRO_COMERCIALES          COM,
                     PERSONAS_CENTROS_PRODUCCION PCP
               WHERE ENA.ENA_MNEMONICO = FUG.FUG_ENA_MNEMONICO
                 AND CFC_FUG_ISI_MNEMONICO = FUG.FUG_ISI_MNEMONICO
                 AND CFC_FUG_MNEMONICO = FUG.FUG_MNEMONICO
                 AND CFC.CFC_CCC_CLI_PER_NUM_IDEN = PER.PER_NUM_IDEN
                 AND CFC.CFC_CCC_CLI_PER_TID_CODIGO = PER.PER_TID_CODIGO
                 AND CFC.CFC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                 AND CFC.CFC_CCC_CLI_PER_TID_CODIGO =
                     CCC.CCC_CLI_PER_TID_CODIGO
                 AND CFC.CFC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA
                 AND PCP.PCP_PER_NUM_IDEN = COM.PER_NUM_IDEN
                 AND PCP.PCP_PER_TID_CODIGO = COM.PER_TID_CODIGO
                 AND CCC.CCC_PER_TID_CODIGO = COM.PER_TID_CODIGO
                 AND CCC.CCC_PER_NUM_IDEN = COM.PER_NUM_IDEN
                 AND PCP.PCP_PRINCIPAL = 'S'
                 AND ENA.ENA_GNA_MNEMONICO IN ('TID', 'CER')
                 AND FUG.FUG_FECHA_VENCIMIENTO >= TRUNC(SYSDATE)
                 AND FUG.FUG_FECHA_VENCIMIENTO <= TRUNC(SYSDATE + TTJ)
                 AND CFC.CFC_SALDO_DCVAL_DISPONIBLE <> 0
               GROUP BY PCP.PCP_CPR_MNEMONICO
              UNION
              SELECT COUNT(*) CANTIDAD,
                     PCP.PCP_CPR_MNEMONICO CENTRO_PRODUCCION
                FROM TITULOS                     TLO,
                     CUENTAS_CLIENTE_CORREDORES  CCC,
                     FILTRO_PERSONAS             PER,
                     FILTRO_COMERCIALES          COM,
                     ESPECIES_NACIONALES         ENA,
                     PERSONAS_CENTROS_PRODUCCION PCP
               WHERE PER.PER_TID_CODIGO = TLO.TLO_CCC_CLI_PER_TID_CODIGO
                 AND PER.PER_NUM_IDEN = TLO.TLO_CCC_CLI_PER_NUM_IDEN
                 AND TLO.TLO_CCC_CLI_PER_TID_CODIGO =
                     CCC.CCC_CLI_PER_TID_CODIGO
                 AND TLO.TLO_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                 AND PCP.PCP_PER_NUM_IDEN = COM.PER_NUM_IDEN
                 AND PCP.PCP_PER_TID_CODIGO = COM.PER_TID_CODIGO
                 AND CCC.CCC_PER_TID_CODIGO = COM.PER_TID_CODIGO
                 AND CCC.CCC_PER_NUM_IDEN = COM.PER_NUM_IDEN
                 AND TLO.TLO_ENA_MNEMONICO = ENA.ENA_BST_MNEMONICO
                 AND ENA.ENA_GNA_MNEMONICO IN ('TID', 'CER')
                 AND PCP.PCP_PRINCIPAL = 'S'
                 AND TLO.TLO_FECHA_VENCIMIENTO >= TRUNC(SYSDATE)
                 AND TLO.TLO_FECHA_VENCIMIENTO <= TRUNC(SYSDATE + TTJ)
                 AND TLO.TLO_PORTAFOLIO = 'S'
               GROUP BY PCP.PCP_CPR_MNEMONICO)
       GROUP BY CENTRO_PRODUCCION;
    R_MES C_MES%ROWTYPE;

    CURSOR C_JEFE IS
      SELECT PER_TIPO_COMERCIAL, PER_NUM_IDEN, PER_MAIL_CORREDOR
        FROM PERSONAS, CENTROS_PRODUCCION
       WHERE PER_TID_CODIGO = CPR_PER_TID_CODIGO_JEFE
         AND PER_NUM_IDEN = CPR_PER_NUM_IDEN_JEFE
         AND CPR_MNEMONICO = R_MES.CENTRO_PRODUCCION
         AND PER_TIPO_COMERCIAL = 'C'
         AND PER_ESTADO = 'A';
    R_JEFE C_JEFE%ROWTYPE;

    CURSOR C_TIT IS
      SELECT COM.PER_NOMBRE_USUARIO COMERCIAL,
             CFC.CFC_CCC_CLI_PER_NUM_IDEN,
             CFC.CFC_CCC_CLI_PER_TID_CODIGO,
             PER.PER_NOMBRE,
             ENA.ENA_MNEMONICO ESPECIE,
             CFC.CFC_SALDO_DCVAL_DISPONIBLE VALOR,
             FUG.FUG_FECHA_VENCIMIENTO FECHA_VENCIMIENTO,
             'DECEVAL' DEPOSITO
        FROM ESPECIES_NACIONALES         ENA,
             FUNGIBLES                   FUG,
             CUENTAS_FUNGIBLE_CLIENTE    CFC,
             FILTRO_PERSONAS             PER,
             CUENTAS_CLIENTE_CORREDORES  CCC,
             FILTRO_COMERCIALES          COM,
             PERSONAS_CENTROS_PRODUCCION PCP
       WHERE ENA.ENA_MNEMONICO = FUG.FUG_ENA_MNEMONICO
         AND CFC_FUG_ISI_MNEMONICO = FUG.FUG_ISI_MNEMONICO
         AND CFC_FUG_MNEMONICO = FUG.FUG_MNEMONICO
         AND CFC.CFC_CCC_CLI_PER_NUM_IDEN = PER.PER_NUM_IDEN
         AND CFC.CFC_CCC_CLI_PER_TID_CODIGO = PER.PER_TID_CODIGO
         AND CFC.CFC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
         AND CFC.CFC_CCC_CLI_PER_TID_CODIGO = CCC.CCC_CLI_PER_TID_CODIGO
         AND CFC.CFC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA
         AND CCC.CCC_PER_TID_CODIGO = COM.PER_TID_CODIGO
         AND CCC.CCC_PER_NUM_IDEN = COM.PER_NUM_IDEN
         AND PCP.PCP_PER_NUM_IDEN = COM.PER_NUM_IDEN
         AND PCP.PCP_PER_TID_CODIGO = COM.PER_TID_CODIGO
         AND PCP.PCP_CPR_MNEMONICO = R_MES.CENTRO_PRODUCCION
         AND ENA.ENA_GNA_MNEMONICO IN ('TID', 'CER')
         AND FUG.FUG_FECHA_VENCIMIENTO >= TRUNC(SYSDATE)
         AND FUG.FUG_FECHA_VENCIMIENTO <= TRUNC(SYSDATE + TTJ)
         AND CFC.CFC_SALDO_DCVAL_DISPONIBLE <> 0
      UNION
      SELECT COM.PER_NOMBRE_USUARIO COMERCIAL,
             TLO.TLO_CCC_CLI_PER_NUM_IDEN,
             TLO.TLO_CCC_CLI_PER_TID_CODIGO,
             PER.PER_NOMBRE,
             TLO.TLO_ENA_MNEMONICO ESPECIE,
             TLO.TLO_VALOR_NOMINAL VALOR,
             TLO.TLO_FECHA_VENCIMIENTO FECHA_VENCIMIENTO,
             'DCV' DEPOSITO
        FROM TITULOS                     TLO,
             CUENTAS_CLIENTE_CORREDORES  CCC,
             FILTRO_PERSONAS             PER,
             FILTRO_COMERCIALES          COM,
             ESPECIES_NACIONALES         ENA,
             PERSONAS_CENTROS_PRODUCCION PCP
       WHERE PER.PER_TID_CODIGO = TLO.TLO_CCC_CLI_PER_TID_CODIGO
         AND PER.PER_NUM_IDEN = TLO.TLO_CCC_CLI_PER_NUM_IDEN
         AND TLO.TLO_CCC_CLI_PER_TID_CODIGO = CCC.CCC_CLI_PER_TID_CODIGO
         AND TLO.TLO_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
         AND CCC.CCC_PER_TID_CODIGO = COM.PER_TID_CODIGO
         AND CCC.CCC_PER_NUM_IDEN = COM.PER_NUM_IDEN
         AND TLO.TLO_ENA_MNEMONICO = ENA.ENA_BST_MNEMONICO
         AND PCP.PCP_PER_NUM_IDEN = COM.PER_NUM_IDEN
         AND PCP.PCP_PER_TID_CODIGO = COM.PER_TID_CODIGO
         AND PCP.PCP_CPR_MNEMONICO = R_MES.CENTRO_PRODUCCION
         AND ENA.ENA_GNA_MNEMONICO IN ('TID', 'CER')
         AND TLO.TLO_FECHA_VENCIMIENTO >= TRUNC(SYSDATE)
         AND TLO.TLO_FECHA_VENCIMIENTO <= TRUNC(SYSDATE + TTJ)
         AND TLO.TLO_PORTAFOLIO = 'S';

    R_TIT C_TIT%ROWTYPE;

    conn utl_smtp.connection;
    req  utl_http.req;
    resp utl_http.resp;

    DIRECCION         VARCHAR2(1000);
    FECHA             DATE;
    v_bufline         VARCHAR2(4000);
    v_archivo_detalle VARCHAR2(500);
    CRLF              VARCHAR2(2) := CHR(13) || CHR(10);
    N                 VARCHAR2(20);

    N_ID_PROCESO NUMBER;
    N_TX         NUMBER;

  BEGIN

    --se asigna el consecutivo del proceso(tabla PARAMETRIZACION_PROCESOS)
    N_ID_PROCESO := P_TRAZA_CORE.FN_ID_PROCESO('P_PROCESOS_NOCTURNOS.MAIL_TID_CER_PENDIENTES_COORD');

    --se Asigna consecutivo para la transaccion, si el proceso es el primero que se llama, reinicia el consecutivo
    N_TX := P_TRAZA_CORE.FN_TRAE_TX(P_TX);

    --Registra Traza
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'I',
                                    'Inicio proceso P_PROCESOS_NOCTURNOS.MAIL_TID_CER_PENDIENTES_COORD. Rango de fechas procesado: ' ||
                                      TO_CHAR(SYSDATE, 'DD-MON-YYYY') || ' a ' ||
                                      TO_CHAR(SYSDATE + TTJ, 'DD-MON-YYYY')||' Fecha Proceso: ' ||
                                      TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss'),
                                      N_TX);
    OPEN C_TTJ;
    FETCH C_TTJ
      INTO TTJ;
    CLOSE C_TTJ;

    OPEN C_MES;
    FETCH C_MES
      INTO R_MES;
    WHILE C_MES%FOUND LOOP

      SELECT TO_CHAR(SYSDATE, 'DDMMYYYYHH24MISS') || '_' ||
             lpad((1 + ABS(MOD(dbms_random.random, 99999))), 5, '0')
        INTO N
        FROM DUAL;
      V_ARCHIVO_DETALLE := 'VPC_' || N;

      DIRECCION := NULL;

      OPEN C_JEFE;
      FETCH C_JEFE
        INTO R_JEFE;
      CLOSE C_JEFE;

      DIRECCION := R_JEFE.PER_MAIL_CORREDOR;

      CONN := P_MAIL.BEGIN_MAIL(SENDER     => 'administrador@corredores.com',
                                RECIPIENTS => DIRECCION,
                                SUBJECT    => 'Lista de TIDIS y CERT prżximos a vencer al - ' ||
                                              TO_CHAR(TRUNC(SYSDATE + TTJ),
                                                      'dd-Mon-yyyy'),
                                MIME_TYPE  => P_MAIL.MULTIPART_MIME_TYPE);

      P_MAIL.BEGIN_ATTACHMENT(CONN         => CONN,
                              MIME_TYPE    => V_ARCHIVO_DETALLE || '/txt',
                              INLINE       => TRUE,
                              FILENAME     => V_ARCHIVO_DETALLE || '.txt',
                              TRANSFER_ENC => 'text');

      -- ENCABEZADOS
      V_BUFLINE := 'COMERCIAL' || ';' || 'NOMBRE CLIENTE' || ';' ||
                   'ESPECIE' || ';' || 'VALOR' || ';' ||
                   'FECHA VENCIMIENTO' || ';' || 'DEPOSITO';
      P_MAIL.WRITE_MB_TEXT(CONN, V_BUFLINE || CRLF);

      --OPERACIONES
      OPEN C_TIT;
      FETCH C_TIT
        INTO R_TIT;
      WHILE C_TIT%FOUND LOOP
        V_BUFLINE := R_TIT.COMERCIAL || ';' || R_TIT.PER_NOMBRE || ';' ||
                     R_TIT.ESPECIE || ';' || R_TIT.VALOR || ';' ||
                     R_TIT.FECHA_VENCIMIENTO || ';' || R_TIT.DEPOSITO;
        P_MAIL.WRITE_MB_TEXT(CONN, V_BUFLINE || CRLF);

        FETCH C_TIT
          INTO R_TIT;
      END LOOP;
      CLOSE C_TIT;
      P_MAIL.END_ATTACHMENT(CONN => CONN);

      P_MAIL.END_MAIL(CONN => CONN);
      FETCH C_MES
        INTO R_MES;
    END LOOP;
    CLOSE C_MES;

     --Registra Traza
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'F',
                                    'Fin proceso P_PROCESOS_NOCTURNOS.MAIL_TID_CER_PENDIENTES_COORD. Rango de fechas procesado: ' ||
                                      TO_CHAR(SYSDATE, 'DD-MON-YYYY') || ' a ' ||
                                      TO_CHAR(SYSDATE + TTJ, 'DD-MON-YYYY')||'Proceso terminado con exito, Fecha Proceso: ' ||
                                      TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss'),
                                      N_TX);                                                      
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
       --Registra Traza ERROR
     P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'E',
                                    'P_PROCESOS_NOCTURNOS.MAIL_TID_CER_PENDIENTES_COORD. Fecha: ' ||
                                    TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss') || ' ' ||
                                    SQLERRM,
                                    N_TX);                              

  END MAIL_TID_CER_PENDIENTES_COORD;

  PROCEDURE P_NOC_FORMATO_519 IS

    P_NUM_INI  NUMBER;
    P_NUM_FIN  NUMBER;
    V_DIAS_DIF NUMBER; -- VAGTUD881

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_NOC_FORMATO_519',
                                                      'INI');

    BEGIN
      P_MAIL.ENVIO_MAIL_ERROR('Inicio proceso nocturno P_FORMATO519',
                              '<br>' || 'Fecha Proceso: ' || SYSDATE,
                              DESTINATARIOS);
    EXCEPTION
      WHEN OTHERS THEN
        DBMS_OUTPUT.PUT_LINE('-20001 Fallo el llamado al paquete de Mail. ' ||
                             SQLERRM);
    END;
    -- VAGTUD881 - SOLO SE EJECUTA EL SIGUIENTE DIA NO HABIL DESPUES DEL DIA HABIL
    V_DIAS_DIF := TRUNC(SYSDATE) -
                  P_TOOLS.RESTAR_HABILES_A_FECHA(TRUNC(SYSDATE), 1); -- VAGTUD881
    IF V_DIAS_DIF = 1 THEN
      P_FORMATO_519.INSERTAR_TMP_519;
      P_FORMATO_519.UNIDAD_CAP02;
      P_FORMATO_519.UNIDAD_CAP03;
      P_FORMATO_519.UNIDAD_CAP04;
      P_FORMATO_519.UNIDAD_CAP07;
      P_FORMATO_519.UNIDAD_CAP08;
      P_FORMATO_519.UNIDAD_CAP09;
      BEGIN
        P_MAIL.ENVIO_MAIL_ERROR('Fin proceso nocturno P_FORMATO519',
                                '<br>' || 'Fecha Proceso: ' || SYSDATE,
                                DESTINATARIOS);

        P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_NOC_FORMATO_519',
                                                          'FIN');
        COMMIT;

      EXCEPTION
        WHEN OTHERS THEN
          DBMS_OUTPUT.PUT_LINE('-20001 Fallo el llamado al paquete de Mail. ' ||
                               SQLERRM);
      END;
    ELSIF V_DIAS_DIF > 1 THEN

      INSERT INTO TMP_REGISTROS_519
        (FECHA,
         REPORTE,
         TFO_FON_CODIGO,
         PFRF_MRF_VALOR_TITULO_TM,
         VALORACION_HOY,
         RETIROS,
         APORTES,
         ANULACIONES,
         VALOR_DIA)
      VALUES
        (SYSDATE - 1, 'ING_EGR', '901609535', 0, 1, 0, 0, 0, 1);

      INSERT INTO TMP_REGISTROS_519
        (FECHA,
         REPORTE,
         TFO_FON_CODIGO,
         PFRF_MRF_VALOR_TITULO_TM,
         VALORACION_HOY,
         RETIROS,
         APORTES,
         ANULACIONES,
         VALOR_DIA)
      VALUES
        (SYSDATE - 1, 'ING_EGR', '800154697', 0, 1, 0, 0, 0, 1);
      COMMIT;

      BEGIN
        P_MAIL.ENVIO_MAIL_ERROR('Fin proceso nocturno P_FORMATO519 Inclusiżn dżas no hżbiles',
                                '<br>' || 'Fecha Proceso: ' || SYSDATE,
                                DESTINATARIOS);

        P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_NOC_FORMATO_519',
                                                          'FIN');
        COMMIT;

      EXCEPTION
        WHEN OTHERS THEN
          DBMS_OUTPUT.PUT_LINE('-20001 Fallo el llamado al paquete de Mail. ' ||
                               SQLERRM);
      END;
    END IF; -- VAGTUD881

  END P_NOC_FORMATO_519;
  -- -------------------------------------------------------
  --  P_BORRADOS_DIARIOS
  -- -------------------------------------------------------
  PROCEDURE P_BORRADOS_DIARIOS(P_TX IN NUMBER DEFAULT NULL) IS

    P_NUM_INI    NUMBER;
    P_NUM_FIN    NUMBER;
    N_TX         NUMBER;
    N_ID_PROCESO NUMBER;

  BEGIN

    --se asignar el consecutivo del proceso(tabla PARAMETRIZACION_PROCESOS)
    N_ID_PROCESO := P_TRAZA_CORE.FN_ID_PROCESO('P_PROCESOS_NOCTURNOS.P_BORRADOS_DIARIOS');

    --se Asigna consecutivo para la transaccion, si el proceso es el primero que se llama, reinicia el consecutivo
    N_TX := P_TRAZA_CORE.FN_TRAE_TX(P_TX);

    --Registra Traza
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'I',
                                    'Inicio proceso  P_PROCESOS_NOCTURNOS.P_BORRADOS_DIARIOS . Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE,
                                            'DD-MM-YYYY HH24:mi:ss'),
                                    N_TX);

    -- BORRADO DE TABLAS DE CRUCE CON CUSTODIO: SE DEJA INFORMACION DE LOS ULTIMOS 3 MESES
    DELETE FROM TMP_CRUCE_COEASY_CDS
     WHERE TMCC_FECHA_GENERACION <= TRUNC(SYSDATE - 90);

    DELETE FROM TMP_CRUCE_COEASY_DECEVAL
     WHERE TO_DATE(TMCD_FECHA_GENERACION, 'YYYYMMDD') <=
           TRUNC(SYSDATE - 90);

    -- Estructura DAPI
    --****** Aca se deben borrar los registros
    --****** una vez se determine la regla de Negocio.

    UPDATE OPERACIONES_SETFX
       SET OPSE_ESTADO = 'PROCESADO'
     WHERE OPSE_ESTADO = 'POR_PROCESAR'
       AND OPSE_O_D IN ('D', 'O')
       AND (OPSE_BANDERA IN ('R', 'L') OR OPSE_BANDERA IS NULL)
       AND OPSE_MERCADO IN (71, 75, 76)
       AND OPSE_CLASE_MENSAJE IN (' 42', ' 1', ' 5', ' 50', '43')
       AND (OPSE_BAND_FISICO_COMPEN IS NULL OR
           OPSE_BAND_FISICO_COMPEN IN ('16'))
       AND OPSE_NUMERO_TRANSADO != 0
       AND OPSE_FECHA < TRUNC(SYSDATE)
       AND OPSE_CONSECUTIVO IN
           (SELECT TLS_OPSE_CONSECUTIVO FROM TMP_LIQUIDACIONES_SET_FX);

    --Registra Traza
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'F',
                                    'Fin proceso P_PROCESOS_NOCTURNOS.P_BORRADOS_DIARIOS. Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE,
                                            'DD-MM-YYYY HH24:mi:ss'),
                                    N_TX);
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
      --Registra Traza
      P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                      'E',
                                      'P_PROCESOS_NOCTURNOS.P_BORRADOS_DIARIOS . Fecha: ' ||
                                      TO_CHAR(SYSDATE,
                                              'DD-MM-YYYY HH24:mi:ss') || ' ' ||
                                      SUBSTR(SQLERRM, 1, 80),
                                      N_TX);
  END;

  PROCEDURE P_SALDOS_NO_DISPO_APE IS

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_SALDOS_NO_DISPO_APE',
                                                      'INI');
    P_ORDENES_FONDOS.P_SALDOS_NO_DISPONIBLES_APE(sysdate);
    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_SALDOS_NO_DISPO_APE',
                                                      'FIN');
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
      DBMS_OUTPUT.PUT_LINE('Error proceso P_PROCESOS_NOCTURNOS.P_SALDOS_NO_DISPO_APE. ' ||
                           SQLERRM);

  END P_SALDOS_NO_DISPO_APE;

  -- Proyecto 716-1 Renta Fija
  PROCEDURE PR_LIMPIAR_INFOVALMER(P_TX IN NUMBER DEFAULT NULL) IS

    N_ID_PROCESO NUMBER;
    N_TX         NUMBER;

  BEGIN

     --se asigna el consecutivo del proceso(tabla PARAMETRIZACION_PROCESOS)
    N_ID_PROCESO := P_TRAZA_CORE.FN_ID_PROCESO('P_PROCESOS_NOCTURNOS.PR_LIMPIAR_INFOVALMER');

    --se Asigna consecutivo para la transaccion, si el proceso es el primero que se llama, reinicia el consecutivo
    N_TX := P_TRAZA_CORE.FN_TRAE_TX(P_TX);

    --Registra Traza
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'I',
                                    'Inicio proceso P_PROCESOS_NOCTURNOS.PR_LIMPIAR_INFOVALMER. Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss'),
                                    N_TX);

    P_CARGUES_INF.PR_LIMPIA_TABLAS_INF;

     --Registra Traza
        P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                        'F',
                                        'Fin proceso P_PROCESOS_NOCTURNOS.PR_LIMPIAR_INFOVALMER. Fecha Proceso: ' ||
                                        TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss'),
                                        N_TX);                                                      
    COMMIT;

  END PR_LIMPIAR_INFOVALMER;

  PROCEDURE PR_BORRAR_INF_PIP(P_TX IN NUMBER DEFAULT NULL) IS
    -- PROCEDIMIENTO QUE BORRA EL HISTORICO DE PRECIOS CARGADOS PARA PIP E INFOVALMER
    N_ID_PROCESO NUMBER;
    N_TX         NUMBER;

  BEGIN

    --se asigna el consecutivo del proceso(tabla PARAMETRIZACION_PROCESOS)
    N_ID_PROCESO := P_TRAZA_CORE.FN_ID_PROCESO('P_PROCESOS_NOCTURNOS.PR_BORRAR_INF_PIP');

    --se Asigna consecutivo para la transaccion, si el proceso es el primero que se llama, reinicia el consecutivo
    N_TX := P_TRAZA_CORE.FN_TRAE_TX(P_TX);

    --Registra Traza
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'I',
                                    'Inicio proceso P_PROCESOS_NOCTURNOS.PR_BORRAR_INF_PIP. Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss'),
                                    N_TX);                            

    DELETE FROM PRECIOS_VALORACION_PIP
     WHERE TRUNC(PVPI_FECHA_REGISTRO) < TRUNC(SYSDATE - 360);

    DELETE FROM PRECIOS_VALORACION_INF
     WHERE TRUNC(PVIF_FECHA_REGISTRO) < TRUNC(SYSDATE - 360);

    DELETE FROM TMP_PRECIOS_VALORACION
     WHERE TRUNC(TPV_FECHA_REGISTRO) < TRUNC(SYSDATE - 360);

    DELETE FROM TMP_INDICES_VALORACION
     WHERE TRUNC(TIV_FECHA) < TRUNC(SYSDATE - 360);

    DELETE FROM INDICES_VALORACION_PIP
     WHERE TRUNC(IVPI_FECHA) < TRUNC(SYSDATE - 360);

    DELETE FROM INDICES_VALORACION_INF
     WHERE TRUNC(IVIF_FECHA) < TRUNC(SYSDATE - 360);

    DELETE FROM TMP_CERO_CUPON_VALORACION
     WHERE TRUNC(CCV_FECHA_OPERACION) < TRUNC(SYSDATE - 360);

    DELETE FROM CERO_CUPON_VALORACION_PIP
     WHERE TRUNC(CCPI_FECHA_OPERACION) < TRUNC(SYSDATE - 360);

    DELETE FROM CERO_CUPON_VALORACION_INF
     WHERE TRUNC(CCIF_FECHA_OPERACION) < TRUNC(SYSDATE - 360);

    /** NO SE PUEDEN BORRAR LOS PRECIOS POR EL PROCESO DE VALORACION DE CLIENTES
    DELETE FROM PRECIOS_ESPECIES_BOLSA
    WHERE  TRUNC(PEB_FECHA) < TRUNC(SYSDATE - 360);

    DELETE FROM PRECIOS_ESPECIES_BOLSA_PIP
    WHERE  TRUNC(PEPI_FECHA) < TRUNC(SYSDATE - 360);

    DELETE FROM PRECIOS_ESPECIES_BOLSA_INF
    WHERE  TRUNC(PEIF_FECHA) < TRUNC(SYSDATE - 360);
    ***/

    DELETE FROM HIST_ACCIONES_INF
     WHERE TRUNC(HAIF_FECHA) < TRUNC(SYSDATE - 360);

    DELETE FROM HIST_ACCIONES_INTERNAL_INF
     WHERE TRUNC(HXIF_FECHA) < TRUNC(SYSDATE - 360);

    COMMIT;

    --Registra Traza
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'F',
                                    'Fin proceso P_PROCESOS_NOCTURNOS.PR_BORRAR_INF_PIP. Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss'),
                                    N_TX);                                                       
    COMMIT;

  END PR_BORRAR_INF_PIP;

  PROCEDURE P_NOC_FORMATO_230 IS
    DIA_HABIL VARCHAR2(1);

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_NOC_FORMATO_230',
                                                      'INI');

    BEGIN
      P_MAIL.ENVIO_MAIL_ERROR('Inicio proceso nocturno P_FORMATO230',
                              '<br>' || 'Fecha Proceso: ' || SYSDATE,
                              DESTINATARIOS);
    EXCEPTION
      WHEN OTHERS THEN
        DBMS_OUTPUT.PUT_LINE('-20001 Fallo el llamado al paquete de Mail. ' ||
                             SQLERRM);
    END;

    DIA_HABIL := P_TOOLS.FN_ES_DIA_HABIL(SYSDATE);

    IF NVL(DIA_HABIL, ' ') = 'S' THEN
      P_FORMATO_230.NEXT_DAY;
      P_FORMATO_230.YANKEES(TRUNC(P_TOOLS.RESTAR_HABILES_A_FECHA(TRUNC(SYSDATE),
                                                                 1)));
      P_FORMATO_230.NEGOCIOS_INTERNACIONALES(TRUNC(P_TOOLS.RESTAR_HABILES_A_FECHA(TRUNC(SYSDATE),
                                                                                  1)));
      P_FORMATO_230.ACTIVOS_INTERNACIONALES; --OSJBOHORQUEZ ARBITRAJE INTERNACIONAL

      UPDATE CONFIRMACIONES_FORMATO_230
         SET CFOR_YANKEE = 'S'
       WHERE CFOR_FECHA >=
             TRUNC(P_TOOLS.RESTAR_HABILES_A_FECHA(TRUNC(SYSDATE), 1))
         AND CFOR_FECHA <
             TRUNC(P_TOOLS.RESTAR_HABILES_A_FECHA(TRUNC(SYSDATE), 1)) + 1;

      COMMIT;
    END IF;
    BEGIN
      P_MAIL.ENVIO_MAIL_ERROR('Fin proceso nocturno P_FORMATO230',
                              '<br>' || 'Fecha Proceso: ' || SYSDATE,
                              DESTINATARIOS);
    EXCEPTION
      WHEN OTHERS THEN
        DBMS_OUTPUT.PUT_LINE('-20001 Fallo el llamado al paquete de Mail. ' ||
                             SQLERRM);
    END;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_NOC_FORMATO_230',
                                                      'FIN');
    COMMIT;

  END P_NOC_FORMATO_230;

  PROCEDURE P_PORTAFOLIO_CLIENTES(P_FECHA DATE) IS

    CURSOR C_DATOS IS
      SELECT HST_CONSECUTIVO,
             HST_FECHA,
             HST_CCC_CLI_PER_NUM_IDEN,
             HST_CCC_CLI_PER_TID_CODIGO,
             HST_CCC_NUMERO_CUENTA,
             HST_SALDO_DISPONIBLE,
             HST_SALDO_GARANTIA,
             HST_SALDO_EMBARGO,
             HST_VALOR_TM_DISPONIBLE,
             HST_VALOR_TM_GARANTIA,
             HST_VALOR_TM_EMBARGO,
             HST_CFC_FUG_ISI_MNEMONICO,
             HST_CFC_FUG_MNEMONICO,
             HST_CFC_CUENTA_DECEVAL,
             HST_TLO_CODIGO,
             HST_INDICADOR_VALORACION,
             HST_TASA_VALORACION,
             HST_TASA_DESCUENTO,
             HST_SALDO_GARANTIA_REPO,
             HST_SALDO_POR_CUMPLIR,
             HST_COSTO_PROMEDIO_COMPRA,
             HST_SALDO_TRANSITO_ING,
             HST_SALDO_TRANSITO_RET,
             HST_SALDO_GARANTIA_DER,
             HST_VALOR_TM_GARREPO,
             HST_VALOR_TM_XCUMPLIR,
             HST_VALOR_TM_TRANING,
             HST_VALOR_TM_TRANRET,
             HST_VALOR_TM_GARDER,
             HST_VALOR_TM_CPR_X_CUMPLIR,
             HST_SALDO_CPR_X_CUMPLIR,
             DSP_ENA_MNEMONICO,
             SEGMENTACION,
             PERFIL,
             FECHA_COMPRA,
             FECHA_EMISION,
             TASA_FACIAL
        FROM VW_HST_TITULOS
       WHERE HST_SALDO_DISPONIBLE <> 0
          OR HST_SALDO_GARANTIA <> 0
          OR HST_SALDO_EMBARGO <> 0
          OR HST_SALDO_GARANTIA_REPO <> 0
          OR HST_SALDO_GARANTIA_DER <> 0
       ORDER BY HST_CONSECUTIVO;
    C_DAT C_DATOS%ROWTYPE;

    CURSOR C_CLIENTE IS
      SELECT PER_NOMBRE
        FROM FILTRO_PERSONAS
       WHERE PER_NUM_IDEN = C_DAT.HST_CCC_CLI_PER_NUM_IDEN
         AND PER_TID_CODIGO = C_DAT.HST_CCC_CLI_PER_TID_CODIGO;
    C_CLI C_CLIENTE%ROWTYPE;

    CURSOR C_ESPECIES IS
      SELECT ENA_DESCRIPCION,
             DECODE(ENA_TIPO_ESPECIE, 'F', 'RF', 'V', 'ACC') ENA_TIPO_ESPECIE,
             ENA_TRE_MNEMONICO
        FROM ESPECIES_NACIONALES
       WHERE ENA_MNEMONICO = C_DAT.DSP_ENA_MNEMONICO;
    C_ESP C_ESPECIES%ROWTYPE;

    CURSOR C_LOCALIZACION IS
      SELECT LTI_DESCRIPCION,
             DECODE(TLO_TYPE, 'TFC', 'RF', 'TVC', 'ACC') TLO_TYPE,
             TLO_FECHA_VENCIMIENTO
        FROM TITULOS, LOCALIZACIONES_TITULOS
       WHERE TLO_LTI_MNEMONICO = LTI_MNEMONICO
         AND TLO_CODIGO = C_DAT.HST_TLO_CODIGO;
    C_LOC C_LOCALIZACION%ROWTYPE;

    CURSOR C_CUENTA_DCV IS
      SELECT CDC_CUENTA_DCV
        FROM CUENTAS_DCV
       WHERE CDC_CLI_PER_NUM_IDEN = C_DAT.HST_CCC_CLI_PER_NUM_IDEN
         AND CDC_CLI_PER_TID_CODIGO = C_DAT.HST_CCC_CLI_PER_TID_CODIGO;
    C_DCV C_CUENTA_DCV%ROWTYPE;

    CURSOR C_ISIN IS
      SELECT FUG_ISI_MNEMONICO, FUG_FECHA_VENCIMIENTO
        FROM FUNGIBLES, TITULOS
       WHERE FUG_ENA_MNEMONICO = C_DAT.DSP_ENA_MNEMONICO
         AND FUNGIBLES.FUG_ENA_MNEMONICO = TITULOS.TLO_ENA_MNEMONICO
         AND FUNGIBLES.FUG_FECHA_VENCIMIENTO =
             TITULOS.TLO_FECHA_VENCIMIENTO
         AND TLO_CODIGO = C_DAT.HST_TLO_CODIGO
         AND FUG_ESTADO = 'A';
    C_ISI C_ISIN%ROWTYPE;

    CURSOR C_ISIN2(ISIN2 VARCHAR2) IS
      SELECT FUG_FECHA_VENCIMIENTO
        FROM FUNGIBLES
       WHERE FUG_ISI_MNEMONICO = ISIN2
         AND FUG_ESTADO = 'A';
    C_ISI2 C_ISIN2%ROWTYPE;
    -- inicio VAGTUS046694, se elimina la relaciżn con HISTORICOS_SALDOS_TITULOS debido a que los datos
    -- del cliente se obtienen previamente en el cursor principal C_DAT
    CURSOR C_COMERCIAL IS
      SELECT PER_NUM_IDEN, PER_NOMBRE
        FROM --HISTORICOS_SALDOS_TITULOS,
             CUENTAS_CLIENTE_CORREDORES,
             FILTRO_PERSONAS
       WHERE --HST_CCC_CLI_PER_NUM_IDEN = CCC_CLI_PER_NUM_IDEN
      -- AND HST_CCC_CLI_PER_TID_CODIGO = CCC_CLI_PER_TID_CODIGO
      -- AND HST_CCC_NUMERO_CUENTA = CCC_NUMERO_CUENTA
      --AND
       CCC_PER_NUM_IDEN = PER_NUM_IDEN
       AND CCC_PER_TID_CODIGO = PER_TID_CODIGO
       AND CCC_CLI_PER_NUM_IDEN = C_DAT.HST_CCC_CLI_PER_NUM_IDEN
       AND CCC_CLI_PER_TID_CODIGO = C_DAT.HST_CCC_CLI_PER_TID_CODIGO
       AND CCC_NUMERO_CUENTA = C_DAT.HST_CCC_NUMERO_CUENTA;
    --AND HST_FECHA >= P_FECHA
    --AND HST_FECHA < P_FECHA + 1;
    C_COM C_COMERCIAL%ROWTYPE;
    -- fin VAGTUS046694

    CURSOR C_MESA(NROID VARCHAR2) IS
      SELECT CPR_DESCRIPCION
        FROM PERSONAS_CENTROS_PRODUCCION, CENTROS_PRODUCCION
       WHERE PCP_CPR_MNEMONICO = CPR_MNEMONICO
         AND PCP_PER_NUM_IDEN = NROID
         AND PCP_PRINCIPAL = 'S'
         AND CPR_ESTADO = 'A';

    CURSOR C_FONDOS IS
      SELECT FON_CODIGO,
             FON_RAZON_SOCIAL,
             FON_TIPO_ADMINISTRACION,
             FON_CAPITAL_PRIVADO,
             FON_ESTADO
        FROM FONDOS
       WHERE FON_TIPO = 'A'
         AND FON_CODIGO = C_DAT.HST_CCC_CLI_PER_NUM_IDEN;
    C_FON C_FONDOS%ROWTYPE;

    CURSOR C_CUENTA_APT IS
      SELECT 'X'
        FROM CUENTAS_CLIENTE_CORREDORES
       WHERE CCC_CLI_PER_NUM_IDEN = C_DAT.HST_CCC_CLI_PER_NUM_IDEN
         AND CCC_CLI_PER_TID_CODIGO = C_DAT.HST_CCC_CLI_PER_TID_CODIGO
         AND CCC_NUMERO_CUENTA = C_DAT.HST_CCC_NUMERO_CUENTA
         AND CCC_CUENTA_APT = 'S';

    CURSOR C_CUENTA_APT_V IS
      SELECT 'X'
        FROM CUENTAS_CLIENTE_CORREDORES
       WHERE CCC_CLI_PER_NUM_IDEN = C_DAT.HST_CCC_CLI_PER_NUM_IDEN
         AND CCC_CLI_PER_TID_CODIGO = C_DAT.HST_CCC_CLI_PER_TID_CODIGO
         AND CCC_NUMERO_CUENTA = C_DAT.HST_CCC_NUMERO_CUENTA
         AND CCC_CUENTA_APT = 'S';
    V_APT VARCHAR2(1);

    DSP_NOMBRE_CLIENTE        VARCHAR2(80);
    DSP_ENA_DESCRIPCION       VARCHAR2(80);
    DSP_TASA_REF              VARCHAR2(5);
    DSP_NOMBRE_DEPOSITO       VARCHAR2(15);
    DSP_TIPO                  VARCHAR2(3);
    DSP_FECHA_VENCIMIENTO     DATE;
    DSP_CUENTA_DEPOSITO       VARCHAR2(35); --MB MIT DCV BANCO DE LA REPUBLICA -- NUMBER(9);
    DSP_CFC_FUG_ISI_MNEMONICO VARCHAR2(12);
    DSP_ID_COMERCIAL          VARCHAR2(15);
    DSP_NOMBRE_COMERCIAL      VARCHAR2(62);
    DSP_MESA                  VARCHAR2(40);
    DSP_TIPO_CLIENTE          VARCHAR2(20);

    TIPO_CLIENTE VARCHAR2(20);

    TIP_ARCHIVO        UTL_FILE.FILE_TYPE;
    ARCHIVO_PORTAFOLIO VARCHAR2(100);
    LINEA              VARCHAR2(5000);

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

    CURSOR ROPEFE(P_HST_CCC_CLI_PER_NUM_IDEN   VARCHAR2,
                  P_HST_CCC_CLI_PER_TID_CODIGO VARCHAR2,
                  P_HST_CCC_NUMERO_CUENTA      NUMBER,
                  P_DSP_ENA_MNEMONICO          VARCHAR2,
                  P_FECHA_DESDE                DATE,
                  P_HST_FECHA                  DATE) IS
      SELECT LIC_FECHA_OPERACION,
             CCC_CLI_PER_TID_CODIGO,
             CCC_CLI_PER_NUM_IDEN,
             CCC_NUMERO_CUENTA,
             OVE_ENA_MNEMONICO,
             SUM(LIC_CANTIDAD_TOTAL_OPERACION) SUMA,
             PEB_PRECIO_BOLSA,
             SUM(LIC_CANTIDAD_TOTAL_OPERACION) * PEB_PRECIO_BOLSA TM
        FROM EMISORES,
             ESPECIES_NACIONALES,
             PERSONAS                    PER,
             CUENTAS_CLIENTE_CORREDORES,
             ORDENES_VENTA,
             LIQUIDACIONES_COMERCIAL     LIC,
             PERSONAS                    PER1,
             PERSONAS_CENTROS_PRODUCCION,
             CENTROS_PRODUCCION,
             PRECIOS_ESPECIES_BOLSA
       WHERE --EMI_MNEMONICO LIKE :EMISOR
      --AND
       ENA_EMI_MNEMONICO = EMI_MNEMONICO
      --AND        ENA_MNEMONICO LIKE :ESPECIE
       AND LIC_MNEMOTECNICO_TITULO = ENA_MNEMONICO
       AND CCC_PER_NUM_IDEN = PER.PER_NUM_IDEN
       AND CCC_PER_TID_CODIGO = PER.PER_TID_CODIGO
      --&P_CONDICION_ESPECULATIVA
       AND OVE_CCC_CLI_PER_NUM_IDEN = CCC_CLI_PER_NUM_IDEN
       AND OVE_CCC_CLI_PER_TID_CODIGO = CCC_CLI_PER_TID_CODIGO
       AND OVE_CCC_NUMERO_CUENTA = CCC_NUMERO_CUENTA
       AND OVE_PER_NUM_IDEN = PER1.PER_NUM_IDEN
       AND OVE_PER_TID_CODIGO = PER1.PER_TID_CODIGO
       AND LIC_BOL_MNEMONICO = OVE_BOL_MNEMONICO
       AND LIC_OVE_COC_CTO_MNEMONICO = OVE_COC_CTO_MNEMONICO
       AND LIC_OVE_CONSECUTIVO = OVE_CONSECUTIVO
      --&P_CONDICION
       AND LIC_TIPO_OPERACION = 'V'
      --AND        LIC_MERCADO LIKE :MERCADO
      --AND        LIC_BOL_MNEMONICO LIKE :BOLSA
       AND CCC_PER_NUM_IDEN = PCP_PER_NUM_IDEN
       AND CCC_PER_TID_CODIGO = PCP_PER_TID_CODIGO
       AND PCP_PRINCIPAL = 'S'
       AND PCP_CPR_MNEMONICO = CPR_MNEMONICO
       AND LIC_FECHA_OPERACION <= P_FECHA_DESDE --'01-SEP-2020'
       AND TRUNC(LIC_FECHA_CUMPLIMIENTO) > TRUNC(P_HST_FECHA)
       AND CCC_CLI_PER_NUM_IDEN = P_HST_CCC_CLI_PER_NUM_IDEN
       AND CCC_CLI_PER_TID_CODIGO = P_HST_CCC_CLI_PER_TID_CODIGO
       AND CCC_NUMERO_CUENTA = P_HST_CCC_NUMERO_CUENTA
       AND OVE_ENA_MNEMONICO = P_DSP_ENA_MNEMONICO
       AND LIC_FECHA_VENCIMIENTO IS NULL
       AND TRUNC(PEB_FECHA) = TRUNC(P_FECHA_DESDE)
       AND PEB_ENA_MNEMONICO = OVE_ENA_MNEMONICO
       GROUP BY LIC_FECHA_OPERACION,
                CCC_CLI_PER_TID_CODIGO,
                CCC_CLI_PER_NUM_IDEN,
                CCC_NUMERO_CUENTA,
                OVE_ENA_MNEMONICO,
                PEB_PRECIO_BOLSA;
    P_ROPEFE ROPEFE%ROWTYPE;

    SALDO_COMPROMISO_RV    NUMBER;
    VALOR_TM_COMPROMISO_RV NUMBER;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_PORTAFOLIO_CLIENTES',
                                                      'INI');

    DELETE FROM GL_FECHAS;

    INSERT INTO GL_FECHAS VALUES (P_FECHA, P_FECHA);

    EXECUTE IMMEDIATE 'CREATE OR REPLACE FORCE VIEW "VW_HST_TITULOS" ("HST_CONSECUTIVO","HST_FECHA","HST_CCC_CLI_PER_NUM_IDEN"
                            , "HST_CCC_CLI_PER_TID_CODIGO", "HST_CCC_NUMERO_CUENTA", "HST_SALDO_DISPONIBLE"
                            , "HST_SALDO_GARANTIA", "HST_SALDO_EMBARGO", "HST_VALOR_TM_DISPONIBLE"
                            , "HST_VALOR_TM_GARANTIA", "HST_VALOR_TM_EMBARGO", "HST_CFC_FUG_ISI_MNEMONICO"
                            , "HST_CFC_FUG_MNEMONICO", "HST_CFC_CUENTA_DECEVAL", "HST_TLO_CODIGO"
                            , "HST_INDICADOR_VALORACION", "HST_TASA_VALORACION", "HST_TASA_DESCUENTO"
                            , "HST_SALDO_GARANTIA_REPO", "HST_SALDO_POR_CUMPLIR", "HST_COSTO_PROMEDIO_COMPRA"
                            , "HST_SALDO_TRANSITO_ING", "HST_SALDO_TRANSITO_RET", "HST_SALDO_GARANTIA_DER"
                            , "HST_VALOR_TM_GARREPO", "HST_VALOR_TM_XCUMPLIR", "HST_VALOR_TM_TRANING"
                            , "HST_VALOR_TM_TRANRET", "HST_VALOR_TM_GARDER", "HST_VALOR_TM_CPR_X_CUMPLIR"
                            , "HST_SALDO_CPR_X_CUMPLIR", "DSP_ENA_MNEMONICO","SEGMENTACION","PERFIL"
                            ,"FECHA_COMPRA","FECHA_EMISION","TASA_FACIAL")  AS
   SELECT /*+ INDEX (HISTORICOS_SALDOS_TITULOS HST_NUM_IDEN_TID_COD_FECH)*/ HST_CONSECUTIVO ,
          HST_FECHA ,
          HST_CCC_CLI_PER_NUM_IDEN ,
          HST_CCC_CLI_PER_TID_CODIGO ,
          HST_CCC_NUMERO_CUENTA ,
          DECODE(HST_CCC_CLI_PER_NUM_IDEN,''860079174'',--VAGTUS045900
           HST_SALDO_DISPONIBLE
            --+HST_SALDO_GARANTIA
            --+HST_SALDO_EMBARGO
            --+HST_SALDO_GARANTIA_REPO
            +HST_SALDO_POR_CUMPLIR
            +HST_SALDO_TRANSITO_ING
            +HST_SALDO_TRANSITO_RET
            --+HST_SALDO_GARANTIA_DER
            +HST_SALDO_CPR_X_CUMPLIR
            +HST_CFC_SALDO_TTV_COMPRA_FINAL
            +HST_CFC_SALDO_TTV_VENTA_FINAL
            +HST_CFC_SALDO_TTV_GARANT_REC
            +HST_CFC_SALDO_TTV_GARANT_COL ,HST_SALDO_DISPONIBLE) HST_SALDO_DISPONIBLE,
          HST_SALDO_GARANTIA ,
          HST_SALDO_EMBARGO ,
            DECODE(HST_CCC_CLI_PER_NUM_IDEN,''860079174'',--VAGTUS045900
          NVL((SELECT PEB_PRECIO_BOLSA*(HST_SALDO_DISPONIBLE
            --+HST_SALDO_GARANTIA
            --+HST_SALDO_EMBARGO
            --+HST_SALDO_GARANTIA_REPO
            +HST_SALDO_POR_CUMPLIR
            +HST_SALDO_TRANSITO_ING
            +HST_SALDO_TRANSITO_RET
           -- +HST_SALDO_GARANTIA_DER
            +HST_SALDO_CPR_X_CUMPLIR
            +HST_CFC_SALDO_TTV_COMPRA_FINAL
            +HST_CFC_SALDO_TTV_VENTA_FINAL
            +HST_CFC_SALDO_TTV_GARANT_REC
            +HST_CFC_SALDO_TTV_GARANT_COL)
            FROM PRECIOS_ESPECIES_BOLSA A
            WHERE PEB_ENA_MNEMONICO = FUG_ENA_MNEMONICO
           AND TRUNC(PEB_FECHA) = TRUNC(GL.FECHA_DESDE)
           AND ROWNUM = 1),HST_VALOR_TM_DISPONIBLE),HST_VALOR_TM_DISPONIBLE) HST_VALOR_TM_DISPONIBLE,
          HST_VALOR_TM_GARANTIA ,
          HST_VALOR_TM_EMBARGO ,
          HST_CFC_FUG_ISI_MNEMONICO ,
          HST_CFC_FUG_MNEMONICO ,
          HST_CFC_CUENTA_DECEVAL ,
          HST_TLO_CODIGO ,
          HST_INDICADOR_VALORACION ,
          HST_TASA_VALORACION ,
          HST_TASA_DESCUENTO ,
          HST_SALDO_GARANTIA_REPO ,
          HST_SALDO_POR_CUMPLIR ,
          HST_COSTO_PROMEDIO_COMPRA ,
          HST_SALDO_TRANSITO_ING ,
          HST_SALDO_TRANSITO_RET ,
          HST_SALDO_GARANTIA_DER ,
          HST_VALOR_TM_GARREPO ,
          HST_VALOR_TM_XCUMPLIR ,
          HST_VALOR_TM_TRANING ,
          HST_VALOR_TM_TRANRET ,
          HST_VALOR_TM_GARDER ,
          HST_VALOR_TM_CPR_X_CUMPLIR ,
          HST_SALDO_CPR_X_CUMPLIR ,
          FUG_ENA_MNEMONICO DSP_ENA_MNEMONICO,
          BSC_DESCRIPCION SEGMENTACION,
          DECODE(CLI_PERFIL_RIESGO, 10,''CONSERVADOR'',20,''MODERADO'', 30,''ARRIESGADO'') PERFIL,
          NULL FECHA_COMPRA,
          FUG_FECHA_EMISION FECHA_EMISION,
          FUG_TASA_FACIAL TASA_FACIAL
     FROM HISTORICOS_SALDOS_TITULOS ,
          CUENTAS_FUNGIBLE_CLIENTE,
          FUNGIBLES,
          CLIENTES,
          BI_SEGMENTACION_CLIENTES,
          GL_FECHAS GL
    WHERE HST_CFC_CUENTA_DECEVAL  = CFC_CUENTA_DECEVAL
      AND HST_CFC_FUG_ISI_MNEMONICO = CFC_FUG_ISI_MNEMONICO
      AND HST_CFC_FUG_MNEMONICO     = CFC_FUG_MNEMONICO
      AND CFC_FUG_ISI_MNEMONICO     = FUG_ISI_MNEMONICO
      AND CFC_FUG_MNEMONICO         = FUG_MNEMONICO
      AND BSC_BCC_MNEMONICO         = CLI_BSC_BCC_MNEMONICO
      AND BSC_MNEMONICO             = CLI_BSC_MNEMONICO
      AND CLI_PER_NUM_IDEN          = HST_CCC_CLI_PER_NUM_IDEN
      AND CLI_PER_TID_CODIGO        = HST_CCC_CLI_PER_TID_CODIGO
      --AND CFC_CCC_CLI_PER_NUM_IDEN =  HST_CCC_CLI_PER_NUM_IDEN --VAGTUS046067
      --and CFC_CCC_CLI_PER_TID_CODIGO = HST_CCC_CLI_PER_TID_CODIGO --VAGTUS046067
      AND HST_FECHA                 >= TRUNC(GL.FECHA_DESDE)
      AND HST_FECHA                 < TRUNC(GL.FECHA_HASTA + 1)
          UNION ALL
   SELECT /*+ INDEX (HISTORICOS_SALDOS_TITULOS HST_NUM_IDEN_TID_COD_FECH)*/ HST_CONSECUTIVO ,
          HST_FECHA ,
          HST_CCC_CLI_PER_NUM_IDEN ,
          HST_CCC_CLI_PER_TID_CODIGO ,
          HST_CCC_NUMERO_CUENTA ,
          DECODE(HST_CCC_CLI_PER_NUM_IDEN,''860079174'',--VAGTUS045900
           HST_SALDO_DISPONIBLE
            --+HST_SALDO_GARANTIA
            --+HST_SALDO_EMBARGO
            --+HST_SALDO_GARANTIA_REPO
            +HST_SALDO_POR_CUMPLIR
            +HST_SALDO_TRANSITO_ING
            +HST_SALDO_TRANSITO_RET
         --   +HST_SALDO_GARANTIA_DER
            +HST_SALDO_CPR_X_CUMPLIR
            +HST_CFC_SALDO_TTV_COMPRA_FINAL
            +HST_CFC_SALDO_TTV_VENTA_FINAL
            +HST_CFC_SALDO_TTV_GARANT_REC
            +HST_CFC_SALDO_TTV_GARANT_COL ,HST_SALDO_DISPONIBLE) HST_SALDO_DISPONIBLE,
          HST_SALDO_GARANTIA ,
          HST_SALDO_EMBARGO ,
             DECODE(HST_CCC_CLI_PER_NUM_IDEN,''860079174'',--VAGTUS045900
          NVL((SELECT PEB_PRECIO_BOLSA*(HST_SALDO_DISPONIBLE
            --+HST_SALDO_GARANTIA
            --+HST_SALDO_EMBARGO
            --+HST_SALDO_GARANTIA_REPO
            +HST_SALDO_POR_CUMPLIR
            +HST_SALDO_TRANSITO_ING
            +HST_SALDO_TRANSITO_RET
          --  +HST_SALDO_GARANTIA_DER
            +HST_SALDO_CPR_X_CUMPLIR
            +HST_CFC_SALDO_TTV_COMPRA_FINAL
            +HST_CFC_SALDO_TTV_VENTA_FINAL
            +HST_CFC_SALDO_TTV_GARANT_REC
            +HST_CFC_SALDO_TTV_GARANT_COL)
            FROM PRECIOS_ESPECIES_BOLSA A
            WHERE PEB_ENA_MNEMONICO = TLO_ENA_MNEMONICO
           AND TRUNC(PEB_FECHA) = TRUNC(GL.FECHA_DESDE)
           AND ROWNUM = 1),HST_VALOR_TM_DISPONIBLE),HST_VALOR_TM_DISPONIBLE) HST_VALOR_TM_DISPONIBLE,
          HST_VALOR_TM_GARANTIA ,
          HST_VALOR_TM_EMBARGO ,
          HST_CFC_FUG_ISI_MNEMONICO ,
          HST_CFC_FUG_MNEMONICO ,
          HST_CFC_CUENTA_DECEVAL ,
          HST_TLO_CODIGO ,
          HST_INDICADOR_VALORACION ,
          HST_TASA_VALORACION ,
          HST_TASA_DESCUENTO ,
          HST_SALDO_GARANTIA_REPO ,
          HST_SALDO_POR_CUMPLIR ,
          HST_COSTO_PROMEDIO_COMPRA ,
          HST_SALDO_TRANSITO_ING ,
          HST_SALDO_TRANSITO_RET ,
          HST_SALDO_GARANTIA_DER ,
          HST_VALOR_TM_GARREPO ,
          HST_VALOR_TM_XCUMPLIR ,
          HST_VALOR_TM_TRANING ,
          HST_VALOR_TM_TRANRET ,
          HST_VALOR_TM_GARDER ,
          HST_VALOR_TM_CPR_X_CUMPLIR ,
          HST_SALDO_CPR_X_CUMPLIR ,
          TLO_ENA_MNEMONICO DSP_ENA_MNEMONICO,
          BSC_DESCRIPCION,
          DECODE(CLI_PERFIL_RIESGO, 10,''CONSERVADOR'',20,''MODERADO'', 30,''ARRIESGADO''),
          TLO_FECHA_OPERACION,
          TLO_FECHA_EMISION,
          TLO_TASA_FACIAL
     FROM HISTORICOS_SALDOS_TITULOS ,
          TITULOS,
          CLIENTES,
          BI_SEGMENTACION_CLIENTES,
          GL_FECHAS GL
    WHERE HST_TLO_CODIGO = TLO_CODIGO
      AND CLI_PER_NUM_IDEN          = HST_CCC_CLI_PER_NUM_IDEN
      AND CLI_PER_TID_CODIGO        = HST_CCC_CLI_PER_TID_CODIGO
      AND BSC_BCC_MNEMONICO         = CLI_BSC_BCC_MNEMONICO
      AND BSC_MNEMONICO             = CLI_BSC_MNEMONICO
      AND TLO_CCC_CLI_PER_NUM_IDEN  = HST_CCC_CLI_PER_NUM_IDEN
      AND TLO_CCC_CLI_PER_TID_CODIGO = HST_CCC_CLI_PER_TID_CODIGO
      AND HST_FECHA      >=  TRUNC(GL.FECHA_DESDE)
      AND HST_FECHA      < TRUNC(GL.FECHA_HASTA + 1)';

    COMMIT;

    ARCHIVO_PORTAFOLIO := 'PORTAFOLIO_VALORACION' || '.csv';
    TIP_ARCHIVO        := UTL_FILE.FOPEN('VALORACION',
                                         ARCHIVO_PORTAFOLIO,
                                         'W',
                                         10000);
    LINEA              := 'FECHA;NUM_IDEN;TIPO_IDEN;NOMBRE_CLIENTE;CUENTA;SALDO_DISPONIBLE;VALOR_TM_DISPONIBLE;SALDO_GARANTIA;VALOR_TM_GARANTIA;SALDO_GARANTIA_REPO;VALOR_TM_GARREPO;SALDO_EMBARGO;VALOR_TM_EMBARGO;SALDO_GARANTIA_DER;VALOR_TM_GARDER;NOMINAL_COMPROMISO_V_RV;TM_COMPROMISO_V_RV;ISIN;FUNGIBLE;CTA_DEPOSITO;DEPOSITO;TITULO;MERCADO;IND_VALORACION;TASA;TASA_DESCUENTO;MNEMO;ESPECIE;NID_COMERCIAL;NOMBRE_COMERCIAL;MESA_COMERCIAL;TASA_REF;FECHA_VENC;TIPO_CLIENTE;SEGMENTACION;PERFIL';
    UTL_FILE.PUT_LINE(TIP_ARCHIVO, LINEA);

    TIPO_CLIENTE     := ' ';
    DSP_TIPO_CLIENTE := ' ';

    OPEN C_DATOS;
    FETCH C_DATOS
      INTO C_DAT;
    WHILE C_DATOS%FOUND LOOP

      OPEN C_CLIENTE;
      FETCH C_CLIENTE
        INTO C_CLI;
      CLOSE C_CLIENTE;
      C_CLI.PER_NOMBRE   := NVL(C_CLI.PER_NOMBRE, ' ');
      DSP_NOMBRE_CLIENTE := C_CLI.PER_NOMBRE;

      OPEN C_ESPECIES;
      FETCH C_ESPECIES
        INTO C_ESP;
      CLOSE C_ESPECIES;
      C_ESP.ENA_DESCRIPCION := NVL(C_ESP.ENA_DESCRIPCION, ' ');
      DSP_ENA_DESCRIPCION   := C_ESP.ENA_DESCRIPCION;
      DSP_TASA_REF          := C_ESP.ENA_TRE_MNEMONICO;

      OPEN C_LOCALIZACION;
      FETCH C_LOCALIZACION
        INTO C_LOC;
      IF C_LOCALIZACION%FOUND THEN
        DSP_NOMBRE_DEPOSITO   := C_LOC.LTI_DESCRIPCION;
        DSP_TIPO              := C_LOC.TLO_TYPE;
        DSP_FECHA_VENCIMIENTO := C_LOC.TLO_FECHA_VENCIMIENTO;
        IF C_LOC.LTI_DESCRIPCION = 'DCV' THEN
          OPEN C_CUENTA_DCV;
          FETCH C_CUENTA_DCV
            INTO DSP_CUENTA_DEPOSITO;
          CLOSE C_CUENTA_DCV;
        ELSIF C_LOC.LTI_DESCRIPCION = 'DECEVAL' THEN
          DSP_CUENTA_DEPOSITO := C_DAT.HST_CFC_CUENTA_DECEVAL;
        END IF;
      ELSE
        DSP_TIPO := C_ESP.ENA_TIPO_ESPECIE;
      END IF;
      CLOSE C_LOCALIZACION;

      IF C_DAT.HST_CFC_CUENTA_DECEVAL IS NOT NULL THEN
        DSP_NOMBRE_DEPOSITO := 'DECEVAL';
        DSP_CUENTA_DEPOSITO := C_DAT.HST_CFC_CUENTA_DECEVAL;
      END IF;

      IF DSP_NOMBRE_DEPOSITO = 'DECEVAL' THEN
        DSP_CFC_FUG_ISI_MNEMONICO := C_DAT.HST_CFC_FUG_ISI_MNEMONICO;
        OPEN C_ISIN2(C_DAT.HST_CFC_FUG_ISI_MNEMONICO);
        FETCH C_ISIN2
          INTO C_ISI2;
        CLOSE C_ISIN2;
        DSP_FECHA_VENCIMIENTO := C_ISI2.FUG_FECHA_VENCIMIENTO;
      ELSE
        C_ISI := NULL; --SS
        OPEN C_ISIN;
        FETCH C_ISIN
          INTO C_ISI;
        CLOSE C_ISIN;
        C_ISI.FUG_ISI_MNEMONICO   := NVL(C_ISI.FUG_ISI_MNEMONICO, ' '); --SS
        DSP_CFC_FUG_ISI_MNEMONICO := NVL(C_ISI.FUG_ISI_MNEMONICO, ' ');
      END IF;

      OPEN C_COMERCIAL;
      FETCH C_COMERCIAL
        INTO C_COM;
      CLOSE C_COMERCIAL;
      DSP_ID_COMERCIAL     := C_COM.PER_NUM_IDEN;
      DSP_NOMBRE_COMERCIAL := C_COM.PER_NOMBRE;

      OPEN C_MESA(C_COM.PER_NUM_IDEN);
      FETCH C_MESA
        INTO DSP_MESA;
      CLOSE C_MESA;

      OPEN C_FONDOS;
      FETCH C_FONDOS
        INTO C_FON;
      IF C_FONDOS%FOUND THEN
        IF NVL(C_FON.FON_TIPO_ADMINISTRACION, ' ') = 'A' THEN
          IF NVL(C_FON.FON_ESTADO, ' ') = 'A' THEN
            V_APT := '';
            OPEN C_CUENTA_APT;
            FETCH C_CUENTA_APT
              INTO V_APT;
            CLOSE C_CUENTA_APT;

            IF NVL(V_APT, 'Y') = 'X' THEN
              TIPO_CLIENTE := 'APT';
            ELSE
              TIPO_CLIENTE := 'CLIENTE';
            END IF;
          ELSE
            TIPO_CLIENTE := 'CLIENTE';
          END IF;
        ELSIF NVL(C_FON.FON_TIPO_ADMINISTRACION, ' ') = 'C' THEN
          TIPO_CLIENTE := 'POSICION PROPIA';
        ELSIF NVL(C_FON.FON_TIPO_ADMINISTRACION, ' ') = 'R' THEN
          TIPO_CLIENTE := 'RECURSOS PROPIOS';
        ELSIF NVL(C_FON.FON_TIPO_ADMINISTRACION, ' ') = 'F' THEN
          TIPO_CLIENTE := 'FONDO INVERSION';
        ELSE
          TIPO_CLIENTE := 'CLIENTE';
        END IF;
      ELSE

        OPEN C_CUENTA_APT_V;
        FETCH C_CUENTA_APT_V
          INTO V_APT;
        IF NVL(V_APT, 'Y') = 'X' THEN
          TIPO_CLIENTE := 'APT';
        ELSE
          TIPO_CLIENTE := 'CLIENTE';
        END IF;
        CLOSE C_CUENTA_APT_V;
      END IF;
      CLOSE C_FONDOS;

      DSP_TIPO_CLIENTE := TIPO_CLIENTE;

      SALDO_COMPROMISO_RV    := 0;
      VALOR_TM_COMPROMISO_RV := 0;

      OPEN ROPEFE(C_DAT.HST_CCC_CLI_PER_NUM_IDEN,
                  C_DAT.HST_CCC_CLI_PER_TID_CODIGO,
                  C_DAT.HST_CCC_NUMERO_CUENTA,
                  C_DAT.DSP_ENA_MNEMONICO,
                  P_FECHA,
                  C_DAT.HST_FECHA);
      FETCH ROPEFE
        INTO P_ROPEFE;
      SALDO_COMPROMISO_RV    := P_ROPEFE.SUMA;
      VALOR_TM_COMPROMISO_RV := P_ROPEFE.TM;
      IF ROPEFE%NOTFOUND THEN
        SALDO_COMPROMISO_RV    := 0;
        VALOR_TM_COMPROMISO_RV := 0;
      END IF;
      CLOSE ROPEFE;

      LINEA := '';
      LINEA := C_DAT.HST_FECHA || ';' || C_DAT.HST_CCC_CLI_PER_NUM_IDEN || ';' ||
               C_DAT.HST_CCC_CLI_PER_TID_CODIGO || ';' ||
               DSP_NOMBRE_CLIENTE || ';' || C_DAT.HST_CCC_NUMERO_CUENTA || ';' ||
               REPLACE(C_DAT.HST_SALDO_DISPONIBLE, ',', '.') || ';' ||
               REPLACE(C_DAT.HST_VALOR_TM_DISPONIBLE, ',', '.') || ';' ||
               REPLACE(C_DAT.HST_SALDO_GARANTIA, ',', '.') || ';' ||
               REPLACE(C_DAT.HST_VALOR_TM_GARANTIA, ',', '.') || ';' ||
               REPLACE(C_DAT.HST_SALDO_GARANTIA_REPO, ',', '.') || ';' ||
               REPLACE(C_DAT.HST_VALOR_TM_GARREPO, ',', '.') || ';' ||
               REPLACE(C_DAT.HST_SALDO_EMBARGO, ',', '.') || ';' ||
               REPLACE(C_DAT.HST_VALOR_TM_EMBARGO, ',', '.') || ';' ||
               REPLACE(C_DAT.HST_SALDO_GARANTIA_DER, ',', '.') || ';' ||
               REPLACE(C_DAT.HST_VALOR_TM_GARDER, ',', '.') || ';' ||
               REPLACE(SALDO_COMPROMISO_RV, ',', '.') || ';' ||
               REPLACE(VALOR_TM_COMPROMISO_RV, ',', '.') || ';' ||
               DSP_CFC_FUG_ISI_MNEMONICO --C_DAT.HST_CFC_FUG_ISI_MNEMONICO
               || ';' || C_DAT.HST_CFC_FUG_MNEMONICO || ';' ||
               DSP_CUENTA_DEPOSITO || ';' || DSP_NOMBRE_DEPOSITO || ';' ||
               C_DAT.HST_TLO_CODIGO || ';' || DSP_TIPO || ';' ||
               C_DAT.HST_INDICADOR_VALORACION || ';' ||
               REPLACE(C_DAT.HST_TASA_VALORACION, ',', '.') || ';' ||
               REPLACE(C_DAT.HST_TASA_DESCUENTO, ',', '.') || ';' ||
               C_DAT.DSP_ENA_MNEMONICO || ';' || DSP_ENA_DESCRIPCION || ';' ||
               DSP_ID_COMERCIAL || ';' || DSP_NOMBRE_COMERCIAL || ';' ||
               DSP_MESA || ';' || REPLACE(DSP_TASA_REF, ',', '.') || ';' ||
               TO_CHAR(DSP_FECHA_VENCIMIENTO, 'DD/MM/YYYY') || ';' ||
               DSP_TIPO_CLIENTE || ';' || C_DAT.SEGMENTACION || ';' ||
               C_DAT.PERFIL || ';' || C_DAT.TASA_FACIAL;

      UTL_FILE.PUT_LINE(TIP_ARCHIVO, LINEA);

      FETCH C_DATOS
        INTO C_DAT;
    END LOOP;
    CLOSE C_DATOS;

    UTL_FILE.FCLOSE(TIP_ARCHIVO);

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_PORTAFOLIO_CLIENTES',
                                                      'FIN');
    COMMIT;

  END P_PORTAFOLIO_CLIENTES;

  PROCEDURE P_CONSULTA_PORTAFOLIO IS

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_CONSULTA_PORTAFOLIO',
                                                      'INI');

    BEGIN
      P_MAIL.ENVIO_MAIL_ERROR('Inicio proceso nocturno P_PORTAFOLIO_CLIENTES',
                              '<br>' || 'Fecha Proceso: ' || SYSDATE,
                              DESTINATARIOS);
    EXCEPTION
      WHEN OTHERS THEN
        DBMS_OUTPUT.PUT_LINE('-20001 Fallo el llamado al paquete de Mail. ' ||
                             SQLERRM);
    END;

    P_PORTAFOLIO_CLIENTES(TRUNC(P_TOOLS.RESTAR_HABILES_A_FECHA(SYSDATE, 1)));

    BEGIN
      P_MAIL.ENVIO_MAIL_ERROR('Fin proceso nocturno P_PORTAFOLIO_CLIENTES',
                              '<br>' || 'Fecha Proceso: ' || SYSDATE,
                              DESTINATARIOS);
    EXCEPTION
      WHEN OTHERS THEN
        DBMS_OUTPUT.PUT_LINE('-20001 Fallo el llamado al paquete de Mail. ' ||
                             SQLERRM);
    END;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_CONSULTA_PORTAFOLIO',
                                                      'FIN');
    COMMIT;

  END P_CONSULTA_PORTAFOLIO;

  --Permite enviar a sarlaft la notificaciżn de las transacciones realizadas en Coeasy en el dża, para realizar la validaciżn con respecto a VIGIA
  PROCEDURE PR_MAIL_TRANS_VIGIA IS
    P_CANT_TRANSACCIONES   INT;
    P_CANT_TRANS_DERIVADOS INT;
    P_CANT_RCA_CHE         INT;
    P_CANT_CON_CHE         INT;
    P_CANT_RCA_TB          INT;
    P_CANT_RCA_EFE         INT;
    P_MAIL_SENDER          VARCHAR(50);
    P_MAIL_NOTIFICA        VARCHAR(100);
    P_FECHA_PROCESO        DATE;

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_MAIL_TRANS_VIGIA',
                                                      'INI');

    P_MAIL_SENDER   := 'administradorvigia@corredores.com';
    P_MAIL_NOTIFICA := 'sistemavigia@corredores.com';
    P_FECHA_PROCESO := TRUNC(SYSDATE - 1);

    --TODAS LAS TRANSACCIONES
    SELECT COUNT(1)
      INTO P_CANT_TRANSACCIONES
      FROM prod.VW_VIGIA_TRANSACCIONES
     WHERE FECHA >= P_FECHA_PROCESO
       AND FECHA < TRUNC(SYSDATE);

    --DERIVADOS
    SELECT COUNT(*)
      INTO P_CANT_TRANS_DERIVADOS
      FROM OPERACIONES_DE_DERIVADOS
     WHERE ODE_LID_FECHA_OPERACION >= P_FECHA_PROCESO
       AND ODE_LID_FECHA_OPERACION < TRUNC(SYSDATE);

    --Sumatoria de transacciones
    --P_CANT_TRANSACCIONES := P_CANT_TRANSACCIONES + P_CANT_CON_CHE + P_CANT_RCA_CHE + P_CANT_RCA_EFE + P_CANT_RCA_TB;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_MAIL_TRANS_VIGIA',
                                                      'FIN');
    COMMIT;

    P_MAIL.MAIL(P_MAIL_SENDER,
                P_MAIL_NOTIFICA,
                'Transacciones procesadas Coeasy',
                '<br>' || 'En la fecha de proceso: ' || P_FECHA_PROCESO ||
                'se realizaron ' || P_CANT_TRANSACCIONES ||
                ' transacciones y ' || P_CANT_TRANS_DERIVADOS ||
                ' transacciones de derivados.');
    --P_MAIL.ENVIO_MAIL_ERROR('Transacciones procesadas Coeasy','<br>'||'En la fecha de proceso: '||P_FECHA_PROCESO||'se realizaron '||P_CANT_TRANSACCIONES||' transacciones y '||P_CANT_TRANS_DERIVADOS||' transacciones de derivados.',P_MAIL_NOTIFICA);
  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Proceso notificaciżn transacciones coeasy a Sarlaft (PR_MAIL_TRANS_VIGIA). Fecha de Proceso' ||
                              sysdate || ' ' || SUBSTR(SQLERRM, 1, 80),
                              DESTINATARIOS);

  END PR_MAIL_TRANS_VIGIA;

