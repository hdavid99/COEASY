  END P_REOPRV;

  PROCEDURE P_EJECUTA_REPGAR_BVC IS
    P_CODIGO       VARCHAR2(200);
    P_RESPUESTA    VARCHAR2(200);
    V_RUTA         VARCHAR2(100);
    NOMBRE_ARCHIVO VARCHAR2(100);

    V_DATOS   P_GARANTIAS.V_DATOS_REFCUR;
    V_PRIMERO VARCHAR(1);

    TYPE TIPO_REG IS RECORD(
      V_CCC_CLI_PER_NUM_IDEN   VARCHAR2(15),
      V_CCC_CLI_PER_TID_CODIGO VARCHAR(3),
      V_CCC_NUMERO_CUENTA      NUMBER,
      V_CCC_NOMBRE_CUENTA      VARCHAR(62),
      V_RC_CHEQUES             NUMBER,
      V_RC_CONSIG_CAJA         NUMBER,
      V_RC_TRANSF_CAJA         NUMBER,
      V_RC_CAJA                NUMBER,
      V_ODP                    NUMBER);

    V_REC TIPO_REG;

    CURSOR C_GAR IS
      SELECT TRG_CCC_CLI_PER_NUM_IDEN,
             TRG_CCC_CLI_PER_TID_CODIGO,
             TRG_CCC_NUMERO_CUENTA,
             TRG_CCC_NOMBRE_CUENTA,
             TRG_RC_CHEQUES,
             TRG_RC_CONSIG_CAJA,
             TRG_RC_TRANSF_CAJA,
             TRG_RC_CAJA,
             TRG_ODP,
             TRG_ODP_SCB,
             CCC_CUENTA_CRCC,
             TRG_FECHA,
             TRG_REPORTE
        FROM TMP_REPORTES_GARANTIAS, CUENTAS_CLIENTE_CORREDORES
       WHERE TRG_CCC_CLI_PER_NUM_IDEN = CCC_CLI_PER_NUM_IDEN
         AND TRG_CCC_CLI_PER_TID_CODIGO = CCC_CLI_PER_TID_CODIGO
         AND TRG_CCC_NUMERO_CUENTA = CCC_NUMERO_CUENTA
         AND TRG_CCC_CLI_PER_NUM_IDEN = CCC_CLI_PER_NUM_IDEN
         AND TRG_CCC_CLI_PER_TID_CODIGO = CCC_CLI_PER_TID_CODIGO;
    R_GAR C_GAR%ROWTYPE;

    V_FECHA   DATE;
    V_DIF     NUMBER;
    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;
  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_GENERA_REPORTES_RIESGOS - P_EJECUTA_REPGAR_BVC',
                                                      'INI');

    DELETE FROM TMP_REPORTES_GARANTIAS;
    COMMIT;

    V_FECHA := SYSDATE - 1;
    P_GARANTIAS.P_VALOR_GARANTIA_OPCE(V_FECHA, V_DATOS);
    LOOP
      FETCH V_DATOS
        INTO V_REC;
      EXIT WHEN V_DATOS%NOTFOUND;
      INSERT INTO TMP_REPORTES_GARANTIAS
      VALUES
        (V_FECHA,
         V_REC.V_CCC_CLI_PER_NUM_IDEN,
         V_REC.V_CCC_CLI_PER_TID_CODIGO,
         V_REC.V_CCC_NUMERO_CUENTA,
         V_REC.V_CCC_NOMBRE_CUENTA,
         V_REC.V_RC_CHEQUES,
         V_REC.V_RC_CONSIG_CAJA,
         V_REC.V_RC_TRANSF_CAJA,
         V_REC.V_RC_CAJA,
         V_REC.V_ODP,
         NULL,
         'BVC');
      COMMIT;

    END LOOP;
    V_FECHA := V_FECHA + 1;

    V_RUTA         := '\\nas.corredor.local\Riesgo\CONFIDENCIAL\Reportes Excel Coeasy\';
    NOMBRE_ARCHIVO := 'GARANTIAS_BVC' ||
                      TO_CHAR(SYSDATE - 1, 'DDMMYYYY_hh24mmss');

    P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => V_RUTA,
                                   P_NOMBRE_ARCHIVO => NOMBRE_ARCHIVO,
                                   P_QUERY          => 'SELECT TO_CHAR(TRG_FECHA,''DD/MM/YYYY'') Fecha, TRG_CCC_CLI_PER_NUM_IDEN Identificacion, ' ||
                                                       '       TRG_CCC_CLI_PER_TID_CODIGO Tipo_Id, ' ||
                                                       '       TRG_CCC_NUMERO_CUENTA Numero_Cuenta, ' ||
                                                       '       TRG_CCC_NOMBRE_CUENTA Nombre_Portafolio, ' ||
                                                       '       SUBSTR(CCC_CUENTA_CRCC,0,3) Cuenta_CRCC, ' ||
                                                       '       TRG_RC_CHEQUES Cheques, ' ||
                                                       '       TRG_RC_CONSIG_CAJA Consignaciones, ' ||
                                                       '       TRG_RC_TRANSF_CAJA Transferencias, ' ||
                                                       '       TRG_RC_CAJA Consig_Efectivo, ' ||
                                                       '       TRG_ODP Odp, ' ||
                                                       '       (TRG_ODP+(TRG_RC_CHEQUES+TRG_RC_CONSIG_CAJA+TRG_RC_TRANSF_CAJA+TRG_RC_CAJA)) Saldo_Garantias, ' ||
                                                       '       TRG_REPORTE Tipo_Garantias ' ||
                                                       '  FROM TMP_REPORTES_GARANTIAS,CUENTAS_CLIENTE_CORREDORES ' ||
                                                       ' WHERE TRG_CCC_CLI_PER_NUM_IDEN = CCC_CLI_PER_NUM_IDEN ' ||
                                                       '   AND TRG_CCC_CLI_PER_TID_CODIGO = CCC_CLI_PER_TID_CODIGO ' ||
                                                       '   AND TRG_CCC_NUMERO_CUENTA = CCC_NUMERO_CUENTA ' ||
                                                       ' ORDER BY TRG_FECHA',
                                   P_CODIGO         => P_CODIGO,
                                   P_RESPUESTA      => P_RESPUESTA);
    IF P_CODIGO = '0000' THEN
      DBMS_OUTPUT.PUT_LINE('Se ha generado el archivo, en la ruta ' ||
                           V_RUTA);
    END IF;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_GENERA_REPORTES_RIESGOS - P_EJECUTA_REPGAR_BVC',
                                                      'FIN');
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20059,
                              'No se genero reporte, comuniquese con soporte, error: ' ||
                              SQLERRM);
  END P_EJECUTA_REPGAR_BVC;

  PROCEDURE P_EJECUTA_REPGAR_DCRCC IS
    P_CODIGO       VARCHAR2(200);
    P_RESPUESTA    VARCHAR2(200);
    V_RUTA         VARCHAR2(100);
    NOMBRE_ARCHIVO VARCHAR2(100);

    V_DATOS_CRCC P_GARANTIAS.V_DATOS_REFCUR5;
    V_PRIMERO    VARCHAR(1);

    TYPE TIPO_REG IS RECORD(
      V_CCC_CLI_PER_NUM_IDEN   VARCHAR2(15),
      V_CCC_CLI_PER_TID_CODIGO VARCHAR(3),
      V_CCC_NUMERO_CUENTA      NUMBER,
      V_CCC_NOMBRE_CUENTA      VARCHAR(62),
      V_RC_CHEQUES             NUMBER,
      V_RC_CONSIG_CAJA         NUMBER,
      V_RC_TRANSF_CAJA         NUMBER,
      V_RC_CAJA                NUMBER,
      V_ODP                    NUMBER);

    V_REC TIPO_REG;

    CURSOR C_GAR IS
      SELECT TRG_CCC_CLI_PER_NUM_IDEN,
             TRG_CCC_CLI_PER_TID_CODIGO,
             TRG_CCC_NUMERO_CUENTA,
             TRG_CCC_NOMBRE_CUENTA,
             TRG_RC_CHEQUES,
             TRG_RC_CONSIG_CAJA,
             TRG_RC_TRANSF_CAJA,
             TRG_RC_CAJA,
             TRG_ODP,
             TRG_ODP_SCB,
             CCC_CUENTA_CRCC,
             TRG_FECHA,
             TRG_REPORTE
        FROM TMP_REPORTES_GARANTIAS, CUENTAS_CLIENTE_CORREDORES
       WHERE TRG_CCC_CLI_PER_NUM_IDEN = CCC_CLI_PER_NUM_IDEN
         AND TRG_CCC_CLI_PER_TID_CODIGO = CCC_CLI_PER_TID_CODIGO
         AND TRG_CCC_NUMERO_CUENTA = CCC_NUMERO_CUENTA
         AND TRG_CCC_CLI_PER_NUM_IDEN = CCC_CLI_PER_NUM_IDEN
         AND TRG_CCC_CLI_PER_TID_CODIGO = CCC_CLI_PER_TID_CODIGO;
    R_GAR C_GAR%ROWTYPE;

    V_FECHA   DATE;
    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;
  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_GENERA_REPORTES_RIESGOS - P_EJECUTA_REPGAR_DCRCC',
                                                      'INI');

    DELETE FROM TMP_REPORTES_GARANTIAS;
    COMMIT;

    V_FECHA := SYSDATE - 1;
    P_GARANTIAS.P_VALOR_GARANTIA_CRCC(V_FECHA, V_DATOS_CRCC);
    LOOP
      FETCH V_DATOS_CRCC
        INTO V_REC;
      EXIT WHEN V_DATOS_CRCC%NOTFOUND;
      INSERT INTO TMP_REPORTES_GARANTIAS
      VALUES
        (V_FECHA,
         V_REC.V_CCC_CLI_PER_NUM_IDEN,
         V_REC.V_CCC_CLI_PER_TID_CODIGO,
         V_REC.V_CCC_NUMERO_CUENTA,
         V_REC.V_CCC_NOMBRE_CUENTA,
         V_REC.V_RC_CHEQUES,
         V_REC.V_RC_CONSIG_CAJA,
         V_REC.V_RC_TRANSF_CAJA,
         V_REC.V_RC_CAJA,
         V_REC.V_ODP,
         NULL,
         'GARANTIAS CRCC');
      COMMIT;

    END LOOP;
    V_FECHA := V_FECHA + 1;

    V_RUTA         := '\\nas.corredor.local\Riesgo\CONFIDENCIAL\Reportes Excel Coeasy\';
    NOMBRE_ARCHIVO := 'GARANTIAS_CRCC' ||
                      TO_CHAR(SYSDATE - 1, 'DDMMYYYY_hh24mmss');

    P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => V_RUTA,
                                   P_NOMBRE_ARCHIVO => NOMBRE_ARCHIVO,
                                   P_QUERY          => 'SELECT TO_CHAR(TRG_FECHA,''DD/MM/YYYY'') Fecha, ' ||
                                                       '       TRG_CCC_CLI_PER_NUM_IDEN Identificacion, ' ||
                                                       '       TRG_CCC_CLI_PER_TID_CODIGO Tipo_Id, ' ||
                                                       '       TRG_CCC_NUMERO_CUENTA Numero_Cuenta, ' ||
                                                       '       TRG_CCC_NOMBRE_CUENTA Nombre_Portafolio, ' ||
                                                       '       SUBSTR(CCC_CUENTA_CRCC,0,3) Cuenta_CRCC, ' ||
                                                       '       TRG_RC_CHEQUES Cheques, ' ||
                                                       '       TRG_RC_CONSIG_CAJA Consignaciones, ' ||
                                                       '       TRG_RC_TRANSF_CAJA Transferencias, ' ||
                                                       '       TRG_RC_CAJA Consig_Efectivo, ' ||
                                                       '       TRG_ODP Odp, ' ||
                                                       '       (TRG_ODP+(TRG_RC_CHEQUES+TRG_RC_CONSIG_CAJA+TRG_RC_TRANSF_CAJA+TRG_RC_CAJA)) Saldo_Garantias, ' ||
                                                       '       TRG_REPORTE Tipo_Garantias ' ||
                                                       '  FROM TMP_REPORTES_GARANTIAS,CUENTAS_CLIENTE_CORREDORES ' ||
                                                       ' WHERE TRG_CCC_CLI_PER_NUM_IDEN = CCC_CLI_PER_NUM_IDEN ' ||
                                                       '   AND TRG_CCC_CLI_PER_TID_CODIGO = CCC_CLI_PER_TID_CODIGO ' ||
                                                       '   AND TRG_CCC_NUMERO_CUENTA = CCC_NUMERO_CUENTA ' ||
                                                       ' ORDER BY TRG_FECHA',
                                   P_CODIGO         => P_CODIGO,
                                   P_RESPUESTA      => P_RESPUESTA);
    IF P_CODIGO = '0000' THEN
      DBMS_OUTPUT.PUT_LINE('Se ha generado el archivo, en la ruta ' ||
                           V_RUTA);
    END IF;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_GENERA_REPORTES_RIESGOS - P_EJECUTA_REPGAR_DCRCC',
                                                      'FIN');
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
