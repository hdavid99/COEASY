                                             V_FECHA ||
                                             '%27+P_FILTRO=Fecha_Operacion+BOLSA=%25+P_SUCURSAL=%25+P_UBICACION=%25+P_VIG=Todas+P_PAGO=%25',
                             P_ARCHIVO    => '/apps/rep_nocturnos_a3/REPCUM_' ||
