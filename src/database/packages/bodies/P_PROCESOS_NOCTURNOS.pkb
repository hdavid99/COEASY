  PROCEDURE REMOCL(P_USERID IN VARCHAR2) AS

    VAR           VARCHAR2(2000);
    V_FECHA       VARCHAR2(20);
    V_FECHA2      VARCHAR2(20);
    V_FECHAN      VARCHAR2(20);
    V_CONDICION   VARCHAR2(5000);
    V_FECHAS      VARCHAR2(1000);
    V_FECHAS1     VARCHAR2(1000);
    V_FECHA_INI   VARCHAR2(1000);
    V_MOVIMIENTO  VARCHAR2(5000) := ' ';
    V_MOVIMIENTO1 VARCHAR2(5000) := ' ';
    P_PARAMETROS  VARCHAR2(2000);

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN
    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_RMOVBA',
                                                      'INI');
    --V_CONDICION := 'CBA.CBA_NEG_CONSECUTIVO%20LIKE%20%27%25%27%20AND%20CBA.CBA_ESTADO%20 =%20%27A%27%20AND';
    /*SELECT P_TOOLS.FN_ES_DIA_HABIL(SYSDATE)
    INTO V_DIA_HABIL
    FROM DUAL;   */
    IF P_TOOLS.FN_ES_DIA_HABIL(SYSDATE) != 'N' THEN
      IF P_TOOLS.FN_ES_DIA_HABIL(SYSDATE) != 'N' AND
         P_TOOLS.FN_ES_DIA_HABIL(SYSDATE - 1) != 'N' THEN
        SELECT TO_CHAR(P_TOOLS.CF_DIA_HABIL_ANTERIOR(SYSDATE),
                       'DD-MON-YYYY',
                       'nls_date_language = ''LATIN AMERICAN SPANISH'''),
               TO_CHAR(TRUNC(SYSDATE),
                       'DD-MON-YYYY',
                       'nls_date_language = ''LATIN AMERICAN SPANISH''')
          INTO V_FECHA, V_FECHA2
          FROM DUAL;

        SELECT TO_CHAR(TRUNC((SYSDATE - 1)), 'DDMMYYYY')
          INTO V_FECHAN
          FROM DUAL;

        P_TOOLS.PR_CREAR_REPORTE(P_REPORT     => 'REMOCL',
                                 P_USERID     => P_USERID,
                                 P_FORMATO    => 'TXT',
                                 P_PARAMETROS => '+P_CONDICION=%20MCC.MCC_TMC_MNEMONICO%20IN%20(%27COC%27%20,%27COV%27%20,%27RCOC%27%20,%27RCOV%27)%20AND%20+P_MOVIMIENTO=""%20+P_FECHAS=%20MCC.MCC_FECHA%20>=%20%27' ||
                                                 V_FECHA ||
                                                 '%27%20%20AND%20MCC.MCC_FECHA%20<%20%27' ||
                                                 V_FECHA2 ||
                                                 '%27%20%20AND%20+P_TIPO=Detallado',
                                 P_ARCHIVO    => '/apps/rep_nocturnos_a3/REMOCL_' ||
                                                 V_FECHAN);
      ELSIF P_TOOLS.FN_ES_DIA_HABIL(SYSDATE) != 'N' AND
            P_TOOLS.FN_ES_DIA_HABIL(SYSDATE - 1) = 'N' THEN
        SELECT TO_CHAR(P_TOOLS.CF_DIA_HABIL_ANTERIOR(SYSDATE),
                       'DD-MON-YYYY',
                       'nls_date_language = ''LATIN AMERICAN SPANISH''')
          INTO V_FECHA
          FROM DUAL;

        SELECT TO_CHAR((SYSDATE - 1),
                       'DD-MON-YYYY',
                       'nls_date_language = ''LATIN AMERICAN SPANISH''')
          INTO V_FECHA2
          FROM DUAL;

        SELECT TO_CHAR(TRUNC((SYSDATE - 1)), 'DDMMYYYY')
          INTO V_FECHAN
          FROM DUAL;

        P_TOOLS.PR_CREAR_REPORTE(P_REPORT     => 'REMOCL',
                                 P_USERID     => P_USERID,
                                 P_FORMATO    => 'TXT',
                                 P_PARAMETROS => '+P_CONDICION=%20MCC.MCC_TMC_MNEMONICO%20IN%20(%27COC%27%20,%27COV%27%20,%27RCOC%27%20,%27RCOV%27)%20AND%20+P_MOVIMIENTO=""%20+P_FECHAS=%20MCC.MCC_FECHA%20>=%20%27' ||
                                                 V_FECHA ||
                                                 '%27%20%20AND%20MCC.MCC_FECHA%20<%20%27' ||
                                                 V_FECHA2 ||
                                                 '%27%20%20AND%20+P_TIPO=Detallado',
                                 P_ARCHIVO    => '/apps/rep_nocturnos_a3/REMOCL_' ||
                                                 V_FECHAN);

      END IF;
    END IF;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_RMOVBA',
                                                      'FIN');

  EXCEPTION
    WHEN OTHERS THEN
      --  P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PR_REPORTE_RMOVBA',SUBSTR(SQLERRM,1,80),'procesosnocturnos@corredores.com');
      NULL;
  END REMOCL;

  PROCEDURE RCIDIV(P_USERID IN VARCHAR2) AS

    CURSOR C1 IS
      SELECT A.CDI_FECHA_DIA,
             A.CDI_FECHA_PROCESO,
             A.CDI_INVENTARIO_INICIAL_USD,
             A.CDI_INVENTARIO_INICIAL_PESOS,
             A.CDI_COMPRAS_USD,
             A.CDI_COMPRAS_PESOS,
             A.CDI_VENTAS_USD,
             A.CDI_VENTAS_PESOS,
             A.CDI_INVENTARIO_FINAL_USD,
             A.CDI_INVENTARIO_FINAL_PESOS,
             A.CDI_VALOR_TPC_DIA,
             A.CDI_UTILIDAD_OPERATIVA,
             A.CDI_COMISION,
             A.CDI_COMISION_COMERCIAL,
             A.CDI_GASTOS_GIRO,
             A.CDI_VALOR_TPC_DIA_CHEQUES,
             A.CDI_VALOR_TPC_DIA_EFECTIVO,
             A.CDI_OVER_NIGHT,
             A.CDI_COMPRA_OTRA_MONEDA,
             A.CDI_VENTA_GASTO_SOBREGIRO,
             A.CDI_EGRESOS_CORRESPONSAL,
             A.CDI_VENTA_OTRA_MONEDA
        FROM CIERRE_DIVISAS A
       WHERE TRUNC(A.CDI_FECHA_PROCESO) =
             (SELECT TRUNC(B.CDI_FECHA_PROCESO)
                FROM CIERRE_DIVISAS B
               WHERE TRUNC(B.CDI_FECHA_DIA) = TRUNC(SYSDATE));

    CURSOR C2 IS
      SELECT NVL(SUM(A.CDI_COMISION), 0) CDI_COMISION,
             NVL(SUM(A.CDI_COMISION_COMERCIAL), 0) CDI_COMISION_COMERCIAL,
             NVL(SUM(A.CDI_GASTOS_GIRO), 0) CDI_GASTOS_GIRO,
             NVL(SUM(A.CDI_UTILIDAD_OPERATIVA), 0) CDI_UTILIDAD_OPERATIVA,
             NVL(SUM(A.CDI_OVER_NIGHT), 0) CDI_OVER_NIGHT,
             NVL(SUM(A.CDI_COMPRA_OTRA_MONEDA), 0) CDI_COMPRA_OTRA_MONEDA,
             NVL(SUM(A.CDI_VENTA_OTRA_MONEDA), 0) CDI_VENTA_OTRA_MONEDA,
             NVL(SUM(A.CDI_EGRESOS_CORRESPONSAL), 0) CDI_EGRESOS_CORRESPONSAL,
             NVL(SUM(A.CDI_VENTA_GASTO_SOBREGIRO), 0) CDI_VENTA_GASTO_SOBREGIRO
        FROM CIERRE_DIVISAS A
       WHERE TRUNC(A.CDI_FECHA_PROCESO) >=
             TO_DATE('01-' || TO_CHAR(SYSDATE, 'MON-YYYY'), 'DD-MON-YYYY')
         AND TRUNC(A.CDI_FECHA_PROCESO) < TRUNC(SYSDATE) - 1;

    VAR           VARCHAR2(2000);
    V_FECHA       VARCHAR2(20);
    V_FECHA2      VARCHAR2(20);
    V_FECHAN      VARCHAR2(20);
    V_CONDICION   VARCHAR2(5000);
    V_FECHAS      VARCHAR2(1000);
    V_FECHAS1     VARCHAR2(1000);
    V_FECHA_INI   VARCHAR2(1000);
    V_MOVIMIENTO  VARCHAR2(5000) := ' ';
    V_MOVIMIENTO1 VARCHAR2(5000) := ' ';
    P_PARAMETROS  VARCHAR2(2000);

    P_NUM_INI       NUMBER;
    P_NUM_FIN       NUMBER;
    V_TASA_COMPRAS  NUMBER;
    V_TASA_VENTAS   NUMBER;
    V_TASA_FINAL    NUMBER;
    V_TASA_INICIAL  NUMBER;
    V_CBM           NUMBER;
    V_SOBREGIRO_MES NUMBER;
    V_EGRESOS       NUMBER;
    V_VENTA_OTRA    NUMBER;
    V_OTRA_MONEDA   NUMBER;
    V_OVER_N        NUMBER;
    V_UTILIDAD_MES  NUMBER;
    ---------------------------------------
    V_COMISION NUMBER;

    CDI_COMISION              NUMBER;
    CDI_COMISION_COMERCIAL    NUMBER;
    CDI_GASTOS_GIRO           NUMBER;
    CDI_UTILIDAD_OPERATIVA    NUMBER;
    CDI_OVER_NIGHT            NUMBER;
    CDI_COMPRA_OTRA_MONEDA    NUMBER;
    CDI_VENTA_OTRA_MONEDA     NUMBER;
    CDI_EGRESOS_CORRESPONSAL  NUMBER;
    CDI_VENTA_GASTO_SOBREGIRO number;

    P_PARAMETRO varchar2(2000);

  BEGIN
    execute immediate ('alter session set NLS_NUMERIC_CHARACTERS = ''.,'' ');
    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_RMOVBA',
                                                      'INI');
    --V_CONDICION := 'CBA.CBA_NEG_CONSECUTIVO%20LIKE%20%27%25%27%20AND%20CBA.CBA_ESTADO%20 =%20%27A%27%20AND';
    SELECT TO_CHAR((SYSDATE) - 1,
                   'DD-MON-YYYY',
                   'nls_date_language = ''LATIN AMERICAN SPANISH'''),
           (SYSDATE)
      INTO V_FECHA, V_FECHA2
      FROM DUAL;

    SELECT TO_CHAR(TRUNC((SYSDATE) - 1), 'DDMMYYYY')
      INTO V_FECHAN
      FROM DUAL;

    FOR R1 IN C1 LOOP

      OPEN C2;
      FETCH C2
        INTO CDI_COMISION,
             CDI_COMISION_COMERCIAL,
             CDI_GASTOS_GIRO,
             CDI_UTILIDAD_OPERATIVA,
             CDI_OVER_NIGHT,
             CDI_COMPRA_OTRA_MONEDA,
             CDI_VENTA_OTRA_MONEDA,
             CDI_EGRESOS_CORRESPONSAL,
             CDI_VENTA_GASTO_SOBREGIRO;
      CLOSE C2;

      IF NVL(R1.CDI_COMPRAS_USD, 0) = 0 THEN
        V_TASA_COMPRAS := R1.CDI_COMPRAS_PESOS / 1;
      ELSE
        V_TASA_COMPRAS := R1.CDI_COMPRAS_PESOS / R1.CDI_COMPRAS_USD;
      END IF;

      IF R1.CDI_INVENTARIO_FINAL_USD = 0 THEN
        V_TASA_FINAL := (R1.CDI_INVENTARIO_FINAL_PESOS / 1);
      ELSE
        V_TASA_FINAL := (R1.CDI_INVENTARIO_FINAL_PESOS /
                        R1.CDI_INVENTARIO_FINAL_USD);
      END IF;

      IF R1.CDI_INVENTARIO_INICIAL_USD = 0 THEN
        V_TASA_INICIAL := R1.CDI_INVENTARIO_INICIAL_PESOS / 1;
      ELSE
        V_TASA_INICIAL := R1.CDI_INVENTARIO_FINAL_PESOS /
                          R1.CDI_INVENTARIO_FINAL_USD;
      END IF;

      IF NVL(R1.CDI_VENTAS_USD, 0) = 0 THEN
        V_TASA_VENTAS := R1.CDI_VENTAS_PESOS / 1;
      ELSE
        V_TASA_VENTAS := R1.CDI_VENTAS_PESOS / R1.CDI_VENTAS_USD;
      END IF;

      SELECT CBM_VALOR
        INTO V_CBM
        FROM COTIZACIONES_BASE_MONETARIAS
       WHERE CBM_BMO_MNEMONICO = 'DOLAR'
         AND TRUNC(CBM_FECHA) = TRUNC(SYSDATE);

      V_UTILIDAD_MES  := CDI_UTILIDAD_OPERATIVA;
      V_OVER_N        := CDI_OVER_NIGHT + CDI_OVER_NIGHT;
      V_OTRA_MONEDA   := CDI_COMPRA_OTRA_MONEDA + CDI_COMPRA_OTRA_MONEDA;
      V_VENTA_OTRA    := CDI_VENTA_OTRA_MONEDA + CDI_VENTA_OTRA_MONEDA;
      V_EGRESOS       := CDI_EGRESOS_CORRESPONSAL;
      V_SOBREGIRO_MES := CDI_VENTA_GASTO_SOBREGIRO +
                         CDI_VENTA_GASTO_SOBREGIRO;

      P_TOOLS.PR_CREAR_REPORTE(P_REPORT  => 'RCIDIV',
                               P_USERID  => P_USERID,
                               P_FORMATO => 'PDF',
                               -- P_PARAMETROS =>'+P_COMISION_ACUMULADA='||CDI_COMISION||'+P_COMISION_COMERCIAL_ACUMULA='||CDI_COMISION_COMERCIAL||'+P_GASTOS_GIRO_ACUMULADA='||CDI_GASTOS_GIRO||'+P_COMISION_MES='||CDI_COMISION||'+P_COMISION_COMERCIAL_MES='||CDI_COMISION_COMERCIAL||'+P_GASTOS_GIRO_MES='||CDI_GASTOS_GIRO||'+P_FECHA_PROCESO='||V_FECHA||'+P_TASA_COMPRAS=0+P_TASA_FINAL='||V_TASA_FINAL||'+P_TASA_INICIAL='||V_TASA_INICIAL||'+P_TASA_VENTAS=0+P_TPC_INICIO_DIA='||R1.CDI_VALOR_TPC_DIA||'+P_TPC_INICIO_CHE='||R1.CDI_VALOR_TPC_DIA_CHEQUES||'+P_TPC_INICIO_EFE='||R1.CDI_VALOR_TPC_DIA_EFECTIVO||'+P_TRM='||V_CBM||'+P_UTILIDAD_ACUMULADA='||CDI_UTILIDAD_OPERATIVA||'+P_UTILIDAD_MES='||V_UTILIDAD_MES||'+P_OVER_NIGHT_ACUMULADA='||CDI_OVER_NIGHT||'+P_OVER_NIGHT_MES='||V_OVER_N||'+P_OTRA_MONEDA_ACUMULADA='||CDI_COMPRA_OTRA_MONEDA||'+P_OTRA_MONEDA_MES='||V_OTRA_MONEDA||'+P_VENTA_OTRA_MONEDA_ACUM='||CDI_VENTA_OTRA_MONEDA||'+P_VENTA_OTRA_MONEDA_MES='||V_VENTA_OTRA||'+P_EGRESOS_CORRESPONSAL_ACUM='||CDI_EGRESOS_CORRESPONSAL||'+P_EGRESOS_CORRESPONSAL_MES='||V_EGRESOS||'+P_VENTA_GASTO_SOBREGIRO_ACUM='||CDI_VENTA_GASTO_SOBREGIRO||'+P_VENTA_GASTO_SOBREGIRO_MES=0',
                               P_PARAMETROS => '+P_COMISION_ACUMULADA=' ||
                                               CDI_COMISION ||
                                               '%20+P_COMISION_COMERCIAL_ACUMULA=' ||
                                               CDI_COMISION_COMERCIAL ||
                                               '+P_GASTOS_GIRO_ACUMULADA=' ||
                                               CDI_GASTOS_GIRO ||
                                               '+P_COMISION_MES=' ||
                                               CDI_COMISION ||
                                               '%20+P_COMISION_COMERCIAL_MES=' ||
                                               CDI_COMISION_COMERCIAL ||
                                               '+P_GASTOS_GIRO_MES=' ||
                                               CDI_GASTOS_GIRO ||
                                               '+P_FECHA_PROCESO=' ||
                                               V_FECHA ||
                                               '%20+P_TASA_COMPRAS=0+P_TASA_FINAL=' ||
                                               V_TASA_FINAL ||
                                               '+P_TASA_INICIAL=' ||
                                               V_TASA_INICIAL ||
                                               '%20+P_TASA_VENTAS=0+P_TPC_INICIO_DIA=' ||
                                               R1.CDI_VALOR_TPC_DIA ||
                                               '+P_TPC_INICIO_CHE=' ||
                                               R1.CDI_VALOR_TPC_DIA_CHEQUES ||
                                               '+P_TPC_INICIO_EFE=' ||
                                               R1.CDI_VALOR_TPC_DIA_EFECTIVO ||
                                               '+P_TRM=' || V_CBM ||
                                               '+P_UTILIDAD_ACUMULADA=' ||
                                               CDI_UTILIDAD_OPERATIVA ||
                                               '+P_UTILIDAD_MES=' ||
                                               V_UTILIDAD_MES ||
                                               '+P_OVER_NIGHT_ACUMULADA=' ||
                                               CDI_OVER_NIGHT ||
                                               '+P_OVER_NIGHT_MES=' ||
                                               V_OVER_N ||
                                               '+P_OTRA_MONEDA_ACUMULADA=' ||
                                               CDI_COMPRA_OTRA_MONEDA ||
                                               '+P_OTRA_MONEDA_MES=' ||
                                               V_OTRA_MONEDA ||
                                               '+P_VENTA_OTRA_MONEDA_ACUM=' ||
                                               CDI_VENTA_OTRA_MONEDA ||
                                               '+P_VENTA_OTRA_MONEDA_MES=' ||
                                               V_VENTA_OTRA ||
                                               '+P_EGRESOS_CORRESPONSAL_ACUM=' ||
                                               CDI_EGRESOS_CORRESPONSAL ||
                                               '+P_EGRESOS_CORRESPONSAL_MES=' ||
                                               V_EGRESOS ||
                                               '+P_VENTA_GASTO_SOBREGIRO_ACUM=' ||
                                               CDI_VENTA_GASTO_SOBREGIRO ||
                                               '%20+P_VENTA_GASTO_SOBREGIRO_MES=0',
                               P_ARCHIVO    => '/apps/rep_nocturnos_a3/RCIDIV_' ||
                                               V_FECHAN);
    END LOOP;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_RMOVBA',
                                                      'FIN');

  EXCEPTION
    WHEN OTHERS THEN
      --  P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PR_REPORTE_RMOVBA',SUBSTR(SQLERRM,1,80),'procesosnocturnos@corredores.com');
      NULL;
  END RCIDIV;

  PROCEDURE PR_REPORTE_RPYGFO_3(P_USERID IN VARCHAR2) IS

    VAR      VARCHAR2(2000);
    P_FONDO  VARCHAR2(1);
    V_FECHA  VARCHAR2(20);
    V_FECHAN VARCHAR2(20);

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_RPYGFO_3',
                                                      'INI');

    SELECT TO_CHAR(TRUNC(SYSDATE - 1),
                   'DD-MON-YYYY',
                   'nls_date_language = ''LATIN AMERICAN SPANISH''')
      INTO V_FECHA
      FROM DUAL;

    SELECT TO_CHAR(TRUNC(SYSDATE - 1), 'DDMMYYYY') INTO V_FECHAN FROM DUAL;
    /*P_MAIL.ENVIO_MAIL_ERROR('Inicio genera reporte RPYGFO ',
    '<br>'||'Fecha consultada del reporte: '||V_FECHA||,
    DESTINATARIOS); */

    P_TOOLS.PR_CREAR_REPORTE(P_REPORT     => 'RPYGFO',
                             P_USERID     => P_USERID,
                             P_FORMATO    => 'TXT',
                             P_PARAMETROS => '+FECHA_DESDE=' || V_FECHA ||
                                             '+FONDO=%25+FECHA_HASTA=' ||
                                             V_FECHA,
                             P_ARCHIVO    => '/apps/rep_nocturnos_a3/RPYGFO_3_' ||
                                             V_FECHAN);

    P_TOOLS.PR_CREAR_REPORTE(P_REPORT     => 'RPYGFO',
                             P_USERID     => P_USERID,
                             P_FORMATO    => 'PDF',
                             P_PARAMETROS => '+FECHA_DESDE=' || V_FECHA ||
                                             '+FONDO=%25+FECHA_HASTA=' ||
                                             V_FECHA,
                             P_ARCHIVO    => '/apps/rep_nocturnos_a3/RPYGFO_3_' ||
                                             V_FECHAN);

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_RPYGFO_3',
                                                      'FIN');

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PR_REPORTE_RPYGFO_3',
                              SUBSTR(SQLERRM, 1, 80),
                              'procesosnocturnos@corredores.com');
  END PR_REPORTE_RPYGFO_3;

  ----------------------------FIN VAGTUD755-33------------------------------------
  PROCEDURE PR_GENERA_REPORTES_A2(P_USERID IN VARCHAR2) AS
  BEGIN
    PR_REPORTE_RORRDS_A2(P_USERID);
    PR_REPORTE_REMOCL_A2(P_USERID);
    PR_REPORTE_RTIPVE_A2(P_USERID);
    PR_REPORTE_RMOVBA_A2(P_USERID);
    PR_REPORTE_RMOVBA_CE_A2(P_USERID);
    PR_REPORTE_RECACL_A2(P_USERID);
    PR_REPORTE_RECACL_CON_A2(P_USERID);
    PORTAFOLIO_VALORACION_A2; --COPOVA
    PR_REPORTE_RECADE_A2(P_USERID);
    OPERACIONES_ESPECIALES;
    RMOVBA_S3(P_USERID);
    CONCILIACION_NEGOCIOS;
    ROPEFE_S3(P_USERID);
    REPCUM(P_USERID);
    RCIDIV(P_USERID);
    REMOCL(P_USERID);
    PR_REPORTE_RPYGFO_3(P_USERID);
  END;
