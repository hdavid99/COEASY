  /********************************
  Ingeniero : Daniel Pedraza
  Fecha ; 29/10/2019
  Descripcion : Se crea esta funcion PR_REPORTES_FINACIERA para generar estos reportes para el area finaciera para la generacion automatica de un  ruta para alimentacion de Drive
  /*********************************/

  PROCEDURE PR_REPORTES_FINACIERA(P_USERID IN VARCHAR2) IS

    V_DIA_HABIL VARCHAR2(5);
    P_FONDO     VARCHAR2(1);
    V_FECHA     VARCHAR2(20);
    V_FECHAN    VARCHAR2(20);

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTES_FINACIERA',
                                                      'INI');

    SELECT TO_CHAR(TRUNC(SYSDATE - 1),
                   'DD-MON-YYYY',
                   'nls_date_language = ''LATIN AMERICAN SPANISH''')
      INTO V_FECHA
      FROM DUAL;

    V_DIA_HABIL := P_TOOLS.FN_ES_DIA_HABIL(V_FECHA);

    IF V_DIA_HABIL = 'S' THEN
      /******************/
      BEGIN

        P_TOOLS.PR_CREAR_REPORTE(P_REPORT     => 'COPORF',
                                 P_USERID     => P_USERID,
                                 P_FORMATO    => 'TXT',
                                 P_PARAMETROS => '+P_P_TGA=Si+P_MONTO=Sin_Validacion+P_TIPO=PESOS+QUEFECHA=' ||
                                                 V_FECHA ||
                                                 '+P_VAL=Cierre Dia+QueFondo=860079174',
                                 P_ARCHIVO    => '/u02/apps/scripts/COPORF_1'
                                 ----/apps/rep_nocturnos/diarios
                                 );
      EXCEPTION
        WHEN OTHERS THEN
          P_MAIL.ENVIO_MAIL_ERROR('Error al Generar el reporte COPORF - Proceso Nocturno PR_REPORTES_FINACIERA ',
                                  SUBSTR(SQLERRM, 1, 80),
                                  'procesosnocturnos@corredores.com');
      END;
    END IF;
    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTES_FINACIERA',
                                                      'FIN');

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PR_REPORTES_FINACIERA = RPYGFO',
                              SUBSTR(SQLERRM, 1, 80),
                              'procesosnocturnos@corredores.com');
  END PR_REPORTES_FINACIERA;

  ---ENVIż DE EXTRACTOS DERIVADOS
  PROCEDURE PR_ENVIO_EXTRACTOS_DERIVADOS(P_FECHA  IN DATE,
                                         P_USERID IN VARCHAR2) IS

    CURSOR C_EXTRACTOS IS
      SELECT CEXT_CLI_PER_NUM_IDEN,
             CEXT_CLI_PER_TID_CODIGO,
             LISTAGG(CEXT_DIRECCION_EMAIL, ',') WITHIN GROUP(ORDER BY CEXT_DIRECCION_EMAIL) CEXT_DIRECCION_EMAIL
        FROM CLIENTES_EXTRACTOS_DERIVADOS CED
       WHERE EXISTS
       (SELECT 'X'
                FROM LIQUIDACIONES_DERIVADOS
               WHERE CED.CEXT_CLI_PER_NUM_IDEN = LID_CCC_CLI_PER_NUM_IDEN
                 AND LID_FECHA_OPERACION >= TRUNC(P_FECHA)
                 AND LID_FECHA_OPERACION < TRUNC(P_FECHA + 1))
       GROUP BY CEXT_CLI_PER_NUM_IDEN, CEXT_CLI_PER_TID_CODIGO;

    C_EXTRACTO C_EXTRACTOS%ROWTYPE;

  BEGIN

    OPEN C_EXTRACTOS;
    FETCH C_EXTRACTOS
      INTO C_EXTRACTO;
    WHILE C_EXTRACTOS%FOUND LOOP
      P_TOOLS.PR_ENVIAR_REPORTE_PDF_MAIL(P_REPORT     => 'EXTDER.rep',
                                         P_USERID     => P_USERID,
                                         P_DESNAME    => C_EXTRACTO.CEXT_DIRECCION_EMAIL,
                                         P_FROM       => 'notificaciones@corredores.com',
                                         P_BCC        => 'ostflorez@corredores.com,osgnavarrete@corredores.com',
                                         P_SUBJECT    => 'Davivienda Corredores | Extracto Derivados',
                                         P_PARAMETROS => 'P_CLIENTE=' ||
                                                         C_EXTRACTO.CEXT_CLI_PER_NUM_IDEN ||
                                                         '+P_FECHA=' ||
                                                         (TO_CHAR(P_FECHA,
                                                                  'dd-Mon-yyyy',
                                                                  'NLS_DATE_LANGUAGE=''SPANISH''')));
      FETCH C_EXTRACTOS
        INTO C_EXTRACTO;
    END LOOP;
    CLOSE C_EXTRACTOS;
  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PR_ENVIO_EXTRACTOS_DERIVADOS',
                              SUBSTR(SQLERRM, 1, 80),
                              'ostflorez@corredores.com');
  END PR_ENVIO_EXTRACTOS_DERIVADOS;
  /*
    osmmelo
    Junio 2019
    VAGTUD661-14 Ajustes Instrucciones de pago
  */
  PROCEDURE PR_REVERSAR_INSTRUCCIONES(P_ERROR OUT VARCHAR2) IS
    CURSOR LC_INS IS
      SELECT CRCF_CONSECUTIVO,
             CRCF_CCF_FON_CODIGO,
             CRCF_CCF_CLI_PER_NUM_IDEN,
             CRCF_CCF_CLI_PER_TID_CODIGO,
             CRCF_CCF_FECHA_RADICA_ADHESION,
             CRCF_TIPO_CUENTA,
             CRCF_ESTADO,
             CRCF_CFO_FON_CODIGO,
             CRCF_CFO_CODIGO,
             CRCF_CFO_CCC_NUMERO_CUENTA,
             CRCF_CBC_NUMERO_CUENTA,
             CRCF_CBC_TCB_MNEMONICO,
             CRCF_CBC_BAN_CODIGO,
             CRCF_NOMBRE_BANCO,
             CRCF_NOMBRE_FONDO,
             CRCF_CCF_CCC_NUMERO_CUENTA,
             CRCF_CCF_CFO_CODIGO
        FROM CUENTAS_RENDIMIENTOS_CLIENTES
       WHERE CRCF_TIPO_CUENTA = 'ABO'
         AND CRCF_MODIFICA_INST_ABO = 'S'
         AND CRCF_INSTRUCCION_DEFAULT = 'PA';
  BEGIN
    FOR LR_INS IN LC_INS LOOP
      UPDATE CUENTAS_RENDIMIENTOS_CLIENTES
         SET CRCF_CCC_NUMERO_CUENTA   = NULL,
             CRCF_INSTRUCCION_DEFAULT = NULL,
             CRCF_MODIFICA_INST_ABO   = NULL,
             CRCF_TIPO_CUENTA         = 'FIC'
       WHERE CRCF_CONSECUTIVO = LR_INS.CRCF_CONSECUTIVO;
      INSERT INTO AUD_CUENTAS_RENDIMIENTOS
        (ACRC_FECHA,
         ACRC_CRCF_CONSECUTIVO,
         ACRC_CRCF_CCF_CLI_PER_NUM,
         ACRC_CRCF_CCF_CLI_PER_TID,
         ACRC_CRCF_CCF_FON_CODIGO,
         ACRC_CRCF_CCF_CCC_NUMERO,
         ACRC_CRCF_CCF_CFO_CODIGO,
         ACRC_CRCF_TIPO_CUENTA,
         ACRC_CRCF_CFO_FON_CODIGO,
         ACRC_CRCF_CFO_CODIGO,
         ACRC_CRCF_CFO_CCC_NUM_CUE)
      VALUES
        (SYSDATE,
         LR_INS.CRCF_CONSECUTIVO,
         LR_INS.CRCF_CCF_CLI_PER_NUM_IDEN,
         LR_INS.CRCF_CCF_CLI_PER_TID_CODIGO,
         LR_INS.CRCF_CCF_FON_CODIGO,
         LR_INS.CRCF_CCF_CCC_NUMERO_CUENTA,
         LR_INS.CRCF_CCF_CFO_CODIGO,
         LR_INS.CRCF_TIPO_CUENTA,
         LR_INS.CRCF_CFO_FON_CODIGO,
         LR_INS.CRCF_CFO_CODIGO,
         LR_INS.CRCF_CFO_CCC_NUMERO_CUENTA);
    END LOOP;
    COMMIT;
  EXCEPTION
    WHEN OTHERS THEN
      P_ERROR := SUBSTR('Error reversando instrucciones: ' || SQLERRM,
                        1,
                        2000);
      ROLLBACK;
  END PR_REVERSAR_INSTRUCCIONES;

  PROCEDURE PR_CONFIRMA_ORDEN_PRI(P_TX IN NUMBER DEFAULT NULL) IS

    CURSOR C_PROGRAMACION IS
      SELECT 'X'
        FROM PROGRAMACION_PAGOS_RENDIM_INMO
       WHERE PPRI_ESTADO = 'APR'
         AND PPRI_FECHA_PAGO >= TRUNC(SYSDATE)
         AND PPRI_FECHA_PAGO < TRUNC(SYSDATE + 1);

    CURSOR C_MOVIMIENTOS_CCC IS
      SELECT COUNT(*)
        FROM MOVIMIENTOS_CUENTA_CORREDORES
       WHERE MCC_TMC_MNEMONICO = 'PRFI'
         AND (MCC_FECHA) >= TRUNC(SYSDATE)
         AND (MCC_FECHA) < TRUNC(SYSDATE + 1);

    EXISTE     VARCHAR2(1);
    CONTEO_CCC NUMBER(5);
    P_NUM_INI  NUMBER;
    P_NUM_FIN  NUMBER;
    --
    LV_MENSAJE_ERROR VARCHAR2(4000);
    LN_DIAS          NUMBER := 0;
    LD_FECHA_PAGO    PROGRAMACION_PAGOS_RENDIM_INMO.PPRI_FECHA_PAGO%TYPE;
    LE_EXCEPTION EXCEPTION;
    N_ID_PROCESO NUMBER;
    N_TX NUMBER;

  BEGIN

    OPEN C_PROGRAMACION;
    FETCH C_PROGRAMACION
      INTO EXISTE;
    CLOSE C_PROGRAMACION;

    N_ID_PROCESO := P_TRAZA_CORE.FN_ID_PROCESO('P_PROCESOS_NOCTURNOS.PR_CONFIRMA_ORDEN_PRI');

    --se Asigna consecutivo para la transaccion, si el proceso es el primero que se llama, reinicia el consecutivo
    N_TX := P_TRAZA_CORE.FN_TRAE_TX(P_TX);

    --Registra Traza
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'I',
                                    'Inicio proceso P_PROCESOS_NOCTURNOS.PR_CONFIRMA_ORDEN_PRI. Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss'),
                                    N_TX);


    IF NVL(EXISTE, ' ') = 'X' THEN
      P_INMOBILIARIO.P_CONFIRMA_ORDEN_PRI;

      OPEN C_MOVIMIENTOS_CCC;
      FETCH C_MOVIMIENTOS_CCC
        INTO CONTEO_CCC;
      CLOSE C_MOVIMIENTOS_CCC;

      IF NVL(CONTEO_CCC, 0) > 0 THEN
           P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'T',
                                    'Traza Proceso de pago de rendimientos fondo Inmobiliario para el dia: ' ||
                                    TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss')|| 
                                    ' Proceso de pago de Rendimientos fondos Inmobiliario, terminado con exito',
                                    N_TX);                        
      ELSE
        /*P_MAIL.ENVIO_MAIL_ERROR('Error en el proceso de Pago de rendimientos Fondo Inmobiliario para el dia: ' ||
                                TO_CHAR(sysdate, 'DD-MON-YYYY'),
                                '<br>' ||
                                'Se copia correo al Ingeniero de desarrollo para revision',
                                'stecnico@corredores.com, smorales@corredores.com,fmunozc@corredores.com');*/
        P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'E',
                                    'Error en el proceso de Pago de rendimientos Fondo Inmobiliario para el dia: ' ||
                                    TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss')|| 
                                    'Proceso de pago de Rendimientos fondos Inmobiliario, terminado con Error',
                                    N_TX);    

      END IF;
    ELSE
      /*P_MAIL.ENVIO_MAIL_ERROR('Proceso de pago de rendimientos fondo Inmobiliario para el dia : ' ||
                              TO_CHAR(sysdate, 'DD-MON-YYYY'),
                              '<br>' ||
                              'Proceso terminado con exito. No existe programacion de pago de rendimientos Fondo Inmobiliario para hoy',
                              'stecnico@corredores.com');*/
      P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'T',
                                    'Traza Proceso de pago de rendimientos fondo Inmobiliario para el dia: ' ||
                                    TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss')|| 
                                    ' Proceso terminado con exito. No existe programacion de pago de rendimientos Fondo Inmobiliario para hoy',
                                    N_TX);                            
    END IF;

    /* osmmelo
       Reversar instrucciones modificadas por proceso de pago de rendimientos
    */
    BEGIN

      SELECT CON_VALOR
        INTO LN_DIAS
        FROM CONSTANTES
       WHERE CON_MNEMONICO = 'DRI';

      SELECT MAX(PPRI_FECHA_PAGO)
        INTO LD_FECHA_PAGO
        FROM PROGRAMACION_PAGOS_RENDIM_INMO
       WHERE PPRI_ESTADO = 'APR';

      IF TRUNC(SYSDATE) =
         P_TOOLS.SUMAR_HABILES_A_FECHA(LD_FECHA_PAGO, LN_DIAS + 1) THEN
        PR_REVERSAR_INSTRUCCIONES(LV_MENSAJE_ERROR);
        IF LV_MENSAJE_ERROR IS NOT NULL THEN
          RAISE LE_EXCEPTION;
        ELSE
          /*P_MAIL.ENVIO_MAIL_ERROR('Reversa de instrucciones : ' ||
                                  TO_CHAR(SYSDATE, 'DD-MON-YYYY'),
                                  '<br>' ||
                                  'Se reversaron instrucciones modificadas por proceso de pago de rendimientos. ',
                                  'stecnico@corredores.com, procesosnocturnos@corredores.com,fmunozc@corredores.com');*/
           P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'T',
                                    'Traza Proceso de pago de rendimientos fondo Inmobiliario para el dia: ' ||
                                    TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss')|| 
                                    'Reversa de instrucciones : Proceso terminado con exito. Se reversaron instrucciones modificadas por proceso de pago de rendimientos.',
                                    N_TX);                          

        END IF;
      END IF;

    EXCEPTION
      when LE_EXCEPTION THEN

        /*P_MAIL.ENVIO_MAIL_ERROR('Erorr proceso reversa de instrucciones : ' ||
                                TO_CHAR(SYSDATE, 'DD-MON-YYYY'),
                                '<br>' || 'Error ' || LV_MENSAJE_ERROR,
                                'stecnico@corredores.com,procesosnocturnos@corredores.com,fmunozc@corredores.com');*/
       P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'E',
                                    'Error proceso PR_CONFIRMA_ORDEN_PRI reversa de instrucciones para el dia: ' ||
                                    TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss')|| 
                                    ' Error: ' || LV_MENSAJE_ERROR,
                                    N_TX);  
      WHEN OTHERS THEN

        /*P_MAIL.ENVIO_MAIL_ERROR('Erorr proceso reversa de instrucciones : ' ||
                                TO_CHAR(sysdate, 'DD-MON-YYYY'),
                                '<br>' || 'Error ' || TO_CHAR(SQLERRM),
                                'stecnico@corredores.com,procesosnocturnos@corredores.com,fmunozc@corredores.com');*/
        P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'E',
                                    'Error proceso PR_CONFIRMA_ORDEN_PRI reversa de instrucciones para el dia: ' ||
                                    TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss')|| 
                                    ' Error: ' || sqlerrm,
                                    N_TX);                                  

    END;
      --Registra Traza
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'F',
                                    'Fin proceso P_PROCESOS_NOCTURNOS.PR_CONFIRMA_ORDEN_PRI. Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss'),
                                    N_TX);
  END PR_CONFIRMA_ORDEN_PRI;

PROCEDURE PR_NOTIFICACION_MULTIESCALA IS
    CURSOR C_COMERCIAL(F_INICIO DATE, F_FINAL DATE, V_NEGOCIO VARCHAR2) IS
      SELECT DISTINCT ID_COMERCIAL, TID_COMERCIAL, MAIL_COMERCIAL
        FROM (SELECT CCC.CCC_CLI_PER_NUM_IDEN   ID_CLIENTE,
                     CCC.CCC_CLI_PER_TID_CODIGO TID_CLIENTE,
                     FC.PER_NUM_IDEN            ID_COMERCIAL,
                     FC.PER_TID_CODIGO          TID_COMERCIAL,
                     FC.PER_NOMBRE              NOMBRE_COMERCIAL,
                     FC.PER_MAIL_CORREDOR       MAIL_COMERCIAL
                FROM FILTRO_COMERCIALES         FC,
                     CUENTAS_CLIENTE_CORREDORES CCC,
                     CUENTAS_FONDOS             CFO
               WHERE CCC.CCC_CLI_PER_NUM_IDEN = CFO.CFO_CCC_CLI_PER_NUM_IDEN
                 AND CCC.CCC_CLI_PER_TID_CODIGO =
                     CFO.CFO_CCC_CLI_PER_TID_CODIGO
                 AND CCC.CCC_NUMERO_CUENTA = CFO.CFO_CCC_NUMERO_CUENTA
                 AND CCC.CCC_PER_NUM_IDEN = FC.PER_NUM_IDEN
                 AND CCC.CCC_PER_TID_CODIGO = FC.PER_TID_CODIGO
                 AND CFO.CFO_FON_CODIGO LIKE V_NEGOCIO || '%'
                 AND CFO.CFO_SALDO_INVER > 0
                 AND EXISTS
               (SELECT 'X'
                        FROM UNIDADES_PENALIZACIONES_FONDOS UPF
                       WHERE UPF.UPF_CFO_CCC_CLI_PER_NUM_IDEN =
                             CCC.CCC_CLI_PER_NUM_IDEN
                         AND UPF.UPF_CFO_CCC_CLI_PER_TID_CODIGO =
                             CCC.CCC_CLI_PER_TID_CODIGO
                         AND UPF.UPF_FECHA_DISPONIBLE >= F_INICIO
                         AND UPF.UPF_FECHA_DISPONIBLE < F_FINAL + 1
                         AND UPF.UPF_CFO_FON_CODIGO LIKE V_NEGOCIO || '%'
                         AND UPF.UPF_EOF_CODIGO = 'APR'
                         AND UPF.UPF_UNIDADES_POR_PENALIZAR > 0));
    R_COM C_COMERCIAL%ROWTYPE;

    CURSOR C_COM_BACKUP(NUM_ID_BKP VARCHAR2, TID_COD_BKP VARCHAR2) IS
      SELECT P2.PER_NUM_IDEN      ID_BKP_COMERCIAL,
             P2.PER_TID_CODIGO    TID_BKP_COMERCIAL,
             P2.PER_MAIL_CORREDOR MAIL_BKP_COMERCIAL
        FROM PERSONAS P1, PERSONAS P2
       WHERE P1.PER_PER_NUM_IDEN = P2.PER_NUM_IDEN
         AND P1.PER_PER_TID_CODIGO = P2.PER_TID_CODIGO
         AND P1.PER_NUM_IDEN = NUM_ID_BKP
         AND P1.PER_TID_CODIGO = TID_COD_BKP;
    R_COM_BKP C_COM_BACKUP%ROWTYPE;

    CURSOR C_ASISTENTE IS
      SELECT PER.PER_MAIL_CORREDOR MAIL_ASISTENTE
        FROM ASISTENTES_COMERCIALES AC, PERSONAS PER
       WHERE AC.ASC_PER_NUM_IDEN = PER.PER_NUM_IDEN
         AND AC.ASC_PER_TID_CODIGO = PER.PER_TID_CODIGO
         AND AC.ASC_COM_PER_NUM_IDEN = R_COM.ID_COMERCIAL
         AND AC.ASC_COM_PER_TID_CODIGO = R_COM.TID_COMERCIAL;
    R_ASIS C_ASISTENTE%ROWTYPE;

    CURSOR C_PROXIMOS_PAGOS(F_INICIO  DATE,
                            F_FINAL   DATE,
                            V_NEGOCIO VARCHAR2) IS
      SELECT FC.PER_NOMBRE,
             FC.PER_TID_CODIGO,
             FC.PER_NUM_IDEN,
             UPF.UPF_FECHA_DISPONIBLE,
             UPF.UPF_FECHA_PAGO,
             UPF.UPF_UNIDADES_POR_PENALIZAR,
             UPF.UPF_CFO_FON_CODIGO,
             UPF.UPF_CFO_CCC_NUMERO_CUENTA,
             UPF.UPF_CFO_CODIGO,
             UPF.UPF_PEN_FON_CODIGO,
             UPF.UPF_PEN_CONSECUTIVO
        FROM UNIDADES_PENALIZACIONES_FONDOS UPF, FILTRO_PERSONAS FC
       WHERE UPF.UPF_CFO_FON_CODIGO LIKE V_NEGOCIO || '%'
         AND FC.PER_NUM_IDEN = UPF.UPF_CFO_CCC_CLI_PER_NUM_IDEN
         AND FC.PER_TID_CODIGO = UPF.UPF_CFO_CCC_CLI_PER_TID_CODIGO
         AND UPF.UPF_EOF_CODIGO = 'APR'
         AND UPF.UPF_UNIDADES_POR_PENALIZAR > 0
         AND UPF.UPF_FECHA_DISPONIBLE >= F_INICIO
         AND UPF.UPF_FECHA_DISPONIBLE < F_FINAL + 1
         AND EXISTS
       (SELECT 'X'
                FROM CUENTAS_CLIENTE_CORREDORES CCC
               WHERE CCC.CCC_CLI_PER_NUM_IDEN =
                     UPF.UPF_CFO_CCC_CLI_PER_NUM_IDEN
                 AND CCC.CCC_CLI_PER_TID_CODIGO =
                     UPF.UPF_CFO_CCC_CLI_PER_TID_CODIGO
                 AND CCC.CCC_NUMERO_CUENTA = UPF.UPF_CFO_CCC_NUMERO_CUENTA
                 AND CCC.CCC_PER_NUM_IDEN = R_COM.ID_COMERCIAL
                 AND CCC.CCC_PER_TID_CODIGO = R_COM.TID_COMERCIAL);
    R_UPF C_PROXIMOS_PAGOS%ROWTYPE;

    CURSOR C_VALORACION IS
      SELECT VFO_VALOR
        FROM VALORIZACIONES_FONDO
       WHERE VFO_FON_CODIGO = R_UPF.UPF_CFO_FON_CODIGO
         AND VFO_FECHA_VALORIZACION >= TRUNC(SYSDATE) - 1
         AND VFO_FECHA_VALORIZACION < TRUNC(SYSDATE);
    R_VFO C_VALORACION%ROWTYPE;

    CURSOR C_PENALIZACION IS
      SELECT PEN_PORCENTAJE
        FROM PENALIZACIONES
       WHERE PEN_FON_CODIGO = R_UPF.UPF_PEN_FON_CODIGO
         AND PEN_CONSECUTIVO = R_UPF.UPF_PEN_CONSECUTIVO;
    PEN1 C_PENALIZACION%ROWTYPE;

    CURSOR C_NEGOCIO IS
      SELECT FON.FON_CODIGO, FON.FON_RAZON_SOCIAL
        FROM FONDOS FON
       WHERE FON.FON_CODIGO IN ('900041269', '901199089', '901416550');
    R_NEG C_NEGOCIO%ROWTYPE;

    CONN UTL_SMTP.CONNECTION;
    REQ  UTL_HTTP.REQ;
    RESP UTL_HTTP.RESP;

    V_NOMBRE_MAIL      VARCHAR2(200);
    V_NOMBRES_MAIL     VARCHAR2(1000);
    V_NOMBRES_MAIL_BKP VARCHAR2(1000);
    TEXTO_CUERPO       VARCHAR2(4000);
    V_ARCHIVO_DETALLE  VARCHAR2(500);
    LINEA3             VARCHAR2(5000);
    CRLF               VARCHAR2(2) := CHR(13) || CHR(10);
    VR_NETO            NUMBER(15, 3);
    VR_DIA             NUMBER(15, 3);
    VR_PEN             NUMBER(15, 3);
    F_INI              DATE;
    F_FIN              DATE;
    DIA_INI            NUMBER(1);
    DIA_HABIL          VARCHAR2(1);
    COND               VARCHAR2(1);
    P_NUM_INI          NUMBER;
    P_NUM_FIN          NUMBER;
    CONT               NUMBER;

    V_PRFONDO VARCHAR2(256);

  BEGIN
    F_INI := TRUNC(SYSDATE);
    SELECT TO_NUMBER(TO_CHAR(TRUNC(F_INI), 'D')) INTO DIA_INI FROM DUAL;

    COND := 'N';
    -- Verifica si el dia es lunes y es habil, si el dia no es habil
    -- el martes verifica que el lunes fue festivo y ejecuta el proceso

    IF DIA_INI = 2 THEN
      F_INI     := TRUNC(SYSDATE); -- LUNES
      F_FIN     := TRUNC(SYSDATE) + 4; -- VIERNES
      DIA_HABIL := P_TOOLS.FN_ES_DIA_HABIL(F_INI);
      IF DIA_HABIL = 'S' THEN
        COND := 'S';
      ELSE
        COND := 'N';
      END IF;
    ELSIF DIA_INI = 3 AND COND = 'N' THEN
      DIA_HABIL := P_TOOLS.FN_ES_DIA_HABIL(F_INI - 1);
      IF DIA_HABIL = 'N' THEN
        F_INI := TRUNC(SYSDATE) - 1; -- LUNES
        F_FIN := F_INI + 4; -- VIERNES
        COND  := 'S';
      ELSE
        COND := 'N';
      END IF;
    END IF;

    OPEN C_NEGOCIO;
    FETCH C_NEGOCIO
      INTO R_NEG;
    WHILE C_NEGOCIO%FOUND LOOP

      IF R_NEG.FON_CODIGO = '900041269' THEN
        V_PRFONDO := 'MULTIESCALA';
      ELSIF R_NEG.FON_CODIGO = '901199089' THEN
        V_PRFONDO := 'RENTA_FIJA_LP';
      ELSIF R_NEG.FON_CODIGO = '901416550' THEN
        V_PRFONDO := 'ALTERNATIVO_120';
      ELSE
        V_PRFONDO := '';
      END IF;

      P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_NOTIFICACION_MULTIESCALA',
                                                        'INI');

      P_MAIL.ENVIO_MAIL_ERROR('Inicio proceso PR_NOTIFICACION_' ||
                              V_PRFONDO || ',<br>' ||
                              'Rango de fechas procesado: ' || F_INI ||
                              ' a ' || F_FIN,
                              DESTINATARIOS);
      IF COND = 'S' THEN
        CONT := 0;
        R_COM:=NULL;
        OPEN C_COMERCIAL(F_INI, F_FIN, R_NEG.FON_CODIGO);
        FETCH C_COMERCIAL
          INTO R_COM;
        WHILE C_COMERCIAL%FOUND LOOP
          BEGIN

            V_NOMBRES_MAIL    := R_COM.MAIL_COMERCIAL;
            TEXTO_CUERPO      := 'Apreciado Asesor de Inversiżn' || '<br>' ||
                                 '<br>' ||
                                 'Adjunto encontrarż los vencimientos del Fondo ' ||
                                 R_NEG.FON_RAZON_SOCIAL ||
                                 ' de la semana comprendida entre el ' ||
                                 F_INI || ' y el ' || F_FIN;
            V_ARCHIVO_DETALLE := V_PRFONDO || '_' || F_INI || '_AL_' ||
                                 F_FIN;

            CONN := P_MAIL.BEGIN_MAIL(SENDER     => 'administrador@corredores.com',
                                      RECIPIENTS => V_NOMBRES_MAIL,
                                      SUBJECT    => 'VENCIMIENTOS ' ||
                                                    V_PRFONDO ||
                                                    ' SEMANA DEL ' || F_INI ||
                                                    ' AL ' || F_FIN,
                                      MIME_TYPE  => P_MAIL.MULTIPART_MIME_TYPE);

            P_MAIL.ATTACH_TEXT(CONN      => CONN,
                               DATA      => TEXTO_CUERPO,
                               MIME_TYPE => 'TEXT/HTML');

            --ADJUNTO
            P_MAIL.BEGIN_ATTACHMENT(CONN         => CONN,
                                    MIME_TYPE    => V_ARCHIVO_DETALLE ||
                                                    '/CSV',
                                    INLINE       => TRUE,
                                    FILENAME     => V_ARCHIVO_DETALLE ||
                                                    '.csv',
                                    TRANSFER_ENC => 'TEXT');
            LINEA3 := 'NOMBRE_CLIENTE' || ';' || 'TIPO_ID' || ';' ||
                      'ID_CLIENTE' || ';' || 'FECHA_VENCIMIENTO' || ';' ||
                      'FECHA_PAGO' || ';' || 'VALOR_NETO' || ';' ||
                      'CODIGO_FONDO';
            p_mail.write_mb_text(conn, LINEA3 || CRLF);

            -- PROXIMOS PAGOS
            R_UPF:=NULL;
            OPEN C_PROXIMOS_PAGOS(F_INI, F_FIN, R_NEG.FON_CODIGO);
            FETCH C_PROXIMOS_PAGOS
              INTO R_UPF;
            WHILE C_PROXIMOS_PAGOS%FOUND LOOP

              OPEN C_VALORACION;
              FETCH C_VALORACION
                INTO R_VFO;
              CLOSE C_VALORACION;

              OPEN C_PENALIZACION;
              FETCH C_PENALIZACION
                INTO PEN1;
              CLOSE C_PENALIZACION;

              VR_DIA  := ROUND(R_UPF.UPF_UNIDADES_POR_PENALIZAR *
                               R_VFO.VFO_VALOR,
                               2);
              VR_PEN  := NVL(ROUND(VR_DIA * PEN1.PEN_PORCENTAJE, 2), 0);
              VR_NETO := VR_DIA - VR_PEN;

              LINEA3 := R_UPF.PER_NOMBRE || ';' || R_UPF.PER_TID_CODIGO || ';' ||
                        R_UPF.PER_NUM_IDEN || ';' ||
                        R_UPF.UPF_FECHA_DISPONIBLE || ';' ||
                        R_UPF.UPF_FECHA_PAGO || ';' || VR_NETO || ';' ||
                        R_UPF.UPF_CFO_FON_CODIGO;
              P_MAIL.WRITE_MB_TEXT(CONN, LINEA3 || CRLF);
              FETCH C_PROXIMOS_PAGOS
                INTO R_UPF;
            END LOOP;
            CLOSE C_PROXIMOS_PAGOS;

            P_MAIL.END_ATTACHMENT(CONN => CONN);
            P_MAIL.END_MAIL(CONN => CONN);

            CONT := CONT + 1;

          EXCEPTION
            WHEN OTHERS THEN
              DBMS_OUTPUT.PUT_LINE(R_COM.MAIL_COMERCIAL);
          END;
          FETCH C_COMERCIAL
            INTO R_COM;
        END LOOP;
        CLOSE C_COMERCIAL;

        -- Correo para el Backup del comercial
        R_COM:=NULL;
        OPEN C_COMERCIAL(F_INI, F_FIN, R_NEG.FON_CODIGO);
        FETCH C_COMERCIAL
          INTO R_COM;
        WHILE C_COMERCIAL%FOUND LOOP
          BEGIN
            R_COM_BKP:=null;
            OPEN C_COM_BACKUP(R_COM.ID_COMERCIAL, R_COM.TID_COMERCIAL);
            FETCH C_COM_BACKUP
              INTO R_COM_BKP;
            IF C_COM_BACKUP%FOUND THEN              
            V_NOMBRES_MAIL    := R_COM_BKP.MAIL_BKP_COMERCIAL;
            TEXTO_CUERPO      := 'Apreciado Asesor de Inversiżn' || '<br>' ||
                                 '<br>' ||
                                 'Adjunto encontrarż los vencimientos del Fondo ' ||
                                 R_NEG.FON_RAZON_SOCIAL ||
                                 ' de la semana comprendida entre el ' ||
                                 F_INI || ' y el ' || F_FIN;
            V_ARCHIVO_DETALLE := V_PRFONDO || '_' || F_INI || '_AL_' ||
                                 F_FIN;

            CONN := P_MAIL.BEGIN_MAIL(SENDER     => 'administrador@corredores.com',
                                      RECIPIENTS => V_NOMBRES_MAIL,
                                      SUBJECT    => 'VENCIMIENTOS ' ||
                                                    V_PRFONDO ||
                                                    ' BACKUP DEL COMERCIAL ' ||
                                                    R_COM.MAIL_COMERCIAL ||
                                                    ' SEMANA DEL ' || F_INI ||
                                                    ' AL ' || F_FIN,
                                      MIME_TYPE  => P_MAIL.MULTIPART_MIME_TYPE);

            P_MAIL.ATTACH_TEXT(CONN      => CONN,
                               DATA      => TEXTO_CUERPO,
                               MIME_TYPE => 'TEXT/HTML');

            --ADJUNTO
            P_MAIL.BEGIN_ATTACHMENT(CONN         => CONN,
                                    MIME_TYPE    => V_ARCHIVO_DETALLE ||
                                                    '/CSV',
                                    INLINE       => TRUE,
                                    FILENAME     => V_ARCHIVO_DETALLE ||
                                                    '.csv',
                                    TRANSFER_ENC => 'TEXT');
            LINEA3 := 'NOMBRE_CLIENTE' || ';' || 'TIPO_ID' || ';' ||
                      'ID_CLIENTE' || ';' || 'FECHA_VENCIMIENTO' || ';' ||
                      'FECHA_PAGO' || ';' || 'VALOR_NETO' || ';' ||
                      'CODIGO_FONDO';
            p_mail.write_mb_text(conn, LINEA3 || CRLF);

            -- PROXIMOS PAGOS
            R_UPF:=NULL;
            OPEN C_PROXIMOS_PAGOS(F_INI, F_FIN, R_NEG.FON_CODIGO);
            FETCH C_PROXIMOS_PAGOS
              INTO R_UPF;
            WHILE C_PROXIMOS_PAGOS%FOUND LOOP

              OPEN C_VALORACION;
              FETCH C_VALORACION
                INTO R_VFO;
              CLOSE C_VALORACION;

              OPEN C_PENALIZACION;
              FETCH C_PENALIZACION
                INTO PEN1;
              CLOSE C_PENALIZACION;

              VR_DIA  := ROUND(R_UPF.UPF_UNIDADES_POR_PENALIZAR *
                               R_VFO.VFO_VALOR,
                               2);
              VR_PEN  := NVL(ROUND(VR_DIA * PEN1.PEN_PORCENTAJE, 2), 0);
              VR_NETO := VR_DIA - VR_PEN;

              LINEA3 := R_UPF.PER_NOMBRE || ';' || R_UPF.PER_TID_CODIGO || ';' ||
                        R_UPF.PER_NUM_IDEN || ';' ||
                        R_UPF.UPF_FECHA_DISPONIBLE || ';' ||
                        R_UPF.UPF_FECHA_PAGO || ';' || VR_NETO || ';' ||
                        R_UPF.UPF_CFO_FON_CODIGO;
              P_MAIL.WRITE_MB_TEXT(CONN, LINEA3 || CRLF);
              FETCH C_PROXIMOS_PAGOS
                INTO R_UPF;
            END LOOP;
            CLOSE C_PROXIMOS_PAGOS;

           P_MAIL.END_ATTACHMENT(CONN => CONN);
           P_MAIL.END_MAIL(CONN => CONN);
    END IF;

            CLOSE C_COM_BACKUP;


          EXCEPTION
            WHEN OTHERS THEN
              DBMS_OUTPUT.PUT_LINE(R_COM_BKP.MAIL_BKP_COMERCIAL);
          END; -- EXCEPTION

          FETCH C_COMERCIAL
            INTO R_COM;
        END LOOP;
        CLOSE C_COMERCIAL;

        --- Correo para el Asistente
        R_COM:=NULL;
        OPEN C_COMERCIAL(F_INI, F_FIN, R_NEG.FON_CODIGO);
        FETCH C_COMERCIAL
          INTO R_COM;
        WHILE C_COMERCIAL%FOUND LOOP
          BEGIN
            R_ASIS:=null;
            OPEN C_ASISTENTE;
            FETCH C_ASISTENTE
              INTO R_ASIS;
            IF C_ASISTENTE%FOUND THEN                
            V_NOMBRES_MAIL    := R_ASIS.MAIL_ASISTENTE;
            TEXTO_CUERPO      := 'Apreciado Asesor de Inversiżn' || '<br>' ||
                                 '<br>' ||
                                 'Adjunto encontrarż los vencimientos del Fondo ' ||
                                 R_NEG.FON_RAZON_SOCIAL ||
                                 ' de la semana comprendida entre el ' ||
                                 F_INI || ' y el ' || F_FIN;
            V_ARCHIVO_DETALLE := V_PRFONDO || '_' || F_INI || '_AL_' ||
                                 F_FIN;

            CONN := P_MAIL.BEGIN_MAIL(SENDER     => 'administrador@corredores.com',
                                      RECIPIENTS => V_NOMBRES_MAIL,
                                      SUBJECT    => 'VENCIMIENTOS ' ||
                                                    V_PRFONDO ||
                                                    ' COMERCIAL ' ||
                                                    R_COM.MAIL_COMERCIAL ||
                                                    ' SEMANA DEL ' || F_INI ||
                                                    ' AL ' || F_FIN,
                                      MIME_TYPE  => P_MAIL.MULTIPART_MIME_TYPE);

            P_MAIL.ATTACH_TEXT(CONN      => CONN,
                               DATA      => TEXTO_CUERPO,
                               MIME_TYPE => 'TEXT/HTML');

            --ADJUNTO
            P_MAIL.BEGIN_ATTACHMENT(CONN         => CONN,
                                    MIME_TYPE    => V_ARCHIVO_DETALLE ||
                                                    '/CSV',
                                    INLINE       => TRUE,
                                    FILENAME     => V_ARCHIVO_DETALLE ||
                                                    '.csv',
                                    TRANSFER_ENC => 'TEXT');
            LINEA3 := 'NOMBRE_CLIENTE' || ';' || 'TIPO_ID' || ';' ||
                      'ID_CLIENTE' || ';' || 'FECHA_VENCIMIENTO' || ';' ||
                      'FECHA_PAGO' || ';' || 'VALOR_NETO' || ';' ||
                      'CODIGO_FONDO';
            p_mail.write_mb_text(conn, LINEA3 || CRLF);

            -- PROXIMOS PAGOS
            R_UPF:=null;
            OPEN C_PROXIMOS_PAGOS(F_INI, F_FIN, R_NEG.FON_CODIGO);
            FETCH C_PROXIMOS_PAGOS
              INTO R_UPF;
            WHILE C_PROXIMOS_PAGOS%FOUND LOOP

              OPEN C_VALORACION;
              FETCH C_VALORACION
                INTO R_VFO;
              CLOSE C_VALORACION;

              OPEN C_PENALIZACION;
              FETCH C_PENALIZACION
                INTO PEN1;
              CLOSE C_PENALIZACION;

              VR_DIA  := ROUND(R_UPF.UPF_UNIDADES_POR_PENALIZAR *
                               R_VFO.VFO_VALOR,
                               2);
              VR_PEN  := NVL(ROUND(VR_DIA * PEN1.PEN_PORCENTAJE, 2), 0);
              VR_NETO := VR_DIA - VR_PEN;

              LINEA3 := R_UPF.PER_NOMBRE || ';' || R_UPF.PER_TID_CODIGO || ';' ||
                        R_UPF.PER_NUM_IDEN || ';' ||
                        R_UPF.UPF_FECHA_DISPONIBLE || ';' ||
                        R_UPF.UPF_FECHA_PAGO || ';' || VR_NETO || ';' ||
                        R_UPF.UPF_CFO_FON_CODIGO;
              P_MAIL.WRITE_MB_TEXT(CONN, LINEA3 || CRLF);
              FETCH C_PROXIMOS_PAGOS
                INTO R_UPF;
            END LOOP;
            CLOSE C_PROXIMOS_PAGOS;

           P_MAIL.END_ATTACHMENT(CONN => CONN);
           P_MAIL.END_MAIL(CONN => CONN);
    END IF;
            CLOSE C_ASISTENTE;

          EXCEPTION
            WHEN OTHERS THEN
              DBMS_OUTPUT.PUT_LINE(R_ASIS.MAIL_ASISTENTE);
          END; -- EXCEPTION
          FETCH C_COMERCIAL
            INTO R_COM;
        END LOOP;
        CLOSE C_COMERCIAL;
      END IF;

      IF NVL(CONT, 0) >= 1 THEN
        V_NOMBRE_MAIL := 'osdsilva@corredores.com';
        TEXTO_CUERPO  := 'Proceso VENCIMIENTOS ' || V_PRFONDO ||
                         ' generado. Cant. correos ' || CONT;
        CONN          := P_MAIL.BEGIN_MAIL(SENDER     => 'administrador@corredores.com',
                                           RECIPIENTS => V_NOMBRE_MAIL,
                                           SUBJECT    => 'VENCIMIENTOS ' ||
                                                         V_PRFONDO ||
                                                         ' SEMANA DEL ' ||
                                                         F_INI || ' AL ' ||
                                                         F_FIN,
                                           MIME_TYPE  => P_MAIL.MULTIPART_MIME_TYPE);
        P_MAIL.ATTACH_TEXT(CONN      => CONN,
                           DATA      => TEXTO_CUERPO,
                           MIME_TYPE => 'TEXT/HTML');
        P_MAIL.END_MAIL(CONN => CONN);



      END IF;

      P_MAIL.ENVIO_MAIL_ERROR('Fin proceso PR_NOTIFICACION_' || V_PRFONDO ||
                              ',<br>' || 'Rango de fechas procesado: ' ||
                              F_INI || ' a ' || F_FIN || '<br>' ||
                              'Proceso terminado con exito',
                              DESTINATARIOS);

      P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_NOTIFICACION_MULTIESCALA',
                                                        'FIN');

 COMMIT;                                                        

      FETCH C_NEGOCIO
        INTO R_NEG;
    END LOOP;
    CLOSE C_NEGOCIO;

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error proceso P_PROCESOS_NOCTURNOS.PR_NOTIFICACION_MULTIESCALA.',SQLERRM);


END PR_NOTIFICACION_MULTIESCALA;

  -----------------------------REPORTES NOCTURNOS------------------------
  PROCEDURE PR_REPORTE_NEXT_DAY(
                                -- P_FECHA       IN DATE,
                                P_USERID IN VARCHAR2) IS

    VAR      VARCHAR2(2000);
    V_FECHA  VARCHAR2(20);
    V_FECHAN VARCHAR2(20);

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_NEXT_DAY',
                                                      'INI');

    SELECT TO_CHAR(TRUNC(P_TOOLS.CF_DIA_HABIL_ANTERIOR(SYSDATE)),
                   'DD-MON-YYYY',
                   'nls_date_language = ''LATIN AMERICAN SPANISH''')
      INTO V_FECHA
      FROM DUAL;
    SELECT TO_CHAR(TRUNC(SYSDATE - 1), 'DDMMYYY') INTO V_FECHAN FROM DUAL;
    /*P_MAIL.ENVIO_MAIL_ERROR('Inicio gerea reporte ROCOND ',
    '<br>'||'Fecha consultada del reporte: '||V_FECHA||,
    DESTINATARIOS); */

    P_TOOLS.PR_CREAR_REPORTE(P_REPORT     => 'ROCOND',
                             P_USERID     => P_USERID,
                             P_FORMATO    => 'PDF',
                             P_PARAMETROS => '+P_FECHA=' || V_FECHA,
                             P_ARCHIVO    => '/apps/rep_nocturnos/diarios/ROCOND' ||
                                             V_FECHAN);

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_NEXT_DAY',
                                                      'FIN');
  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PR_REPORTE_NEXT_DAY',
                              SUBSTR(SQLERRM, 1, 80),
                              'procesosnocturnos@corredores.com');
  END PR_REPORTE_NEXT_DAY;

  PROCEDURE PORTAFOLIO_VALORACION AS

    CURSOR C_DATOS IS
      SELECT HST_CONSECUTIVO,
             HST_FECHA,
             HST_CCC_CLI_PER_NUM_IDEN,
             HST_CCC_CLI_PER_TID_CODIGO,
             HST_CCC_NUMERO_CUENTA,
             HST_SALDO_DISPONIBLE,
             HST_SALDO_GARANTIA,
             HST_SALDO_EMBARGO,
             HST_VALOR_TM_DISPONIBLE,
             HST_VALOR_TM_GARANTIA,
             HST_VALOR_TM_EMBARGO,
             HST_CFC_FUG_ISI_MNEMONICO,
             HST_CFC_FUG_MNEMONICO,
             HST_CFC_CUENTA_DECEVAL,
             HST_TLO_CODIGO,
             HST_INDICADOR_VALORACION,
             HST_TASA_VALORACION,
             HST_TASA_DESCUENTO,
             HST_SALDO_GARANTIA_REPO,
             HST_SALDO_POR_CUMPLIR,
             HST_COSTO_PROMEDIO_COMPRA,
             HST_SALDO_TRANSITO_ING,
             HST_SALDO_TRANSITO_RET,
             HST_SALDO_GARANTIA_DER,
             HST_VALOR_TM_GARREPO,
             HST_VALOR_TM_XCUMPLIR,
             HST_VALOR_TM_TRANING,
             HST_VALOR_TM_TRANRET,
             HST_VALOR_TM_GARDER,
             HST_VALOR_TM_CPR_X_CUMPLIR,
             HST_SALDO_CPR_X_CUMPLIR,
             DSP_ENA_MNEMONICO,
             FECHA_COMPRA,
             FECHA_EMISION,
             TASA_FACIAL
        FROM VW_HST_TITULOS
       WHERE HST_SALDO_DISPONIBLE <> 0
          OR HST_SALDO_GARANTIA <> 0
          OR HST_SALDO_EMBARGO <> 0
          OR HST_SALDO_GARANTIA_REPO <> 0
          OR HST_SALDO_GARANTIA_DER <> 0
       ORDER BY HST_CONSECUTIVO;
    C_DAT C_DATOS%ROWTYPE;

    CURSOR C_CLIENTE IS
      SELECT PER_NOMBRE
        FROM FILTRO_PERSONAS
       WHERE PER_NUM_IDEN = C_DAT.HST_CCC_CLI_PER_NUM_IDEN
         AND PER_TID_CODIGO = C_DAT.HST_CCC_CLI_PER_TID_CODIGO;
    C_CLI C_CLIENTE%ROWTYPE;

    CURSOR C_ESPECIES IS
      SELECT ENA_DESCRIPCION,
             DECODE(ENA_TIPO_ESPECIE, 'F', 'RF', 'V', 'ACC') ENA_TIPO_ESPECIE,
             ENA_TRE_MNEMONICO
        FROM ESPECIES_NACIONALES
       WHERE ENA_MNEMONICO = C_DAT.DSP_ENA_MNEMONICO;
    C_ESP C_ESPECIES%ROWTYPE;

    CURSOR C_LOCALIZACION IS
      SELECT LTI_DESCRIPCION,
             DECODE(TLO_TYPE, 'TFC', 'RF', 'TVC', 'ACC') TLO_TYPE,
             TLO_FECHA_VENCIMIENTO
        FROM TITULOS, LOCALIZACIONES_TITULOS
       WHERE TLO_LTI_MNEMONICO = LTI_MNEMONICO
         AND TLO_CODIGO = C_DAT.HST_TLO_CODIGO;
    C_LOC C_LOCALIZACION%ROWTYPE;

    CURSOR C_CUENTA_DCV IS
      SELECT CDC_CUENTA_DCV
        FROM CUENTAS_DCV
       WHERE CDC_CLI_PER_NUM_IDEN = C_DAT.HST_CCC_CLI_PER_NUM_IDEN
         AND CDC_CLI_PER_TID_CODIGO = C_DAT.HST_CCC_CLI_PER_TID_CODIGO;
    C_DCV C_CUENTA_DCV%ROWTYPE;

    CURSOR C_ISIN IS
      SELECT FUG_ISI_MNEMONICO, FUG_FECHA_VENCIMIENTO
        FROM FUNGIBLES, TITULOS
       WHERE FUG_ENA_MNEMONICO = C_DAT.DSP_ENA_MNEMONICO
         AND FUNGIBLES.FUG_ENA_MNEMONICO = TITULOS.TLO_ENA_MNEMONICO
         AND FUNGIBLES.FUG_FECHA_VENCIMIENTO =
             TITULOS.TLO_FECHA_VENCIMIENTO
         AND TLO_CODIGO = C_DAT.HST_TLO_CODIGO
         AND FUG_ESTADO = 'A';
    C_ISI C_ISIN%ROWTYPE;

    CURSOR C_ISIN2(ISIN2 VARCHAR2) IS
      SELECT FUG_FECHA_VENCIMIENTO
        FROM FUNGIBLES
       WHERE FUG_ISI_MNEMONICO = ISIN2
         AND FUG_ESTADO = 'A';
    C_ISI2 C_ISIN2%ROWTYPE;

    CURSOR C_COMERCIAL IS
      SELECT PER_NUM_IDEN, PER_NOMBRE
        FROM CUENTAS_CLIENTE_CORREDORES, FILTRO_PERSONAS
       WHERE CCC_PER_NUM_IDEN = PER_NUM_IDEN
         AND CCC_PER_TID_CODIGO = PER_TID_CODIGO
         AND CCC_CLI_PER_NUM_IDEN = C_DAT.HST_CCC_CLI_PER_NUM_IDEN
         AND CCC_CLI_PER_TID_CODIGO = C_DAT.HST_CCC_CLI_PER_TID_CODIGO
         AND CCC_NUMERO_CUENTA = C_DAT.HST_CCC_NUMERO_CUENTA;
    C_COM C_COMERCIAL%ROWTYPE;

    CURSOR C_MESA(NROID VARCHAR2) IS
      SELECT CPR_DESCRIPCION
        FROM PERSONAS_CENTROS_PRODUCCION, CENTROS_PRODUCCION
       WHERE PCP_CPR_MNEMONICO = CPR_MNEMONICO
         AND PCP_PER_NUM_IDEN = NROID
         AND PCP_PRINCIPAL = 'S'
         AND CPR_ESTADO = 'A';

    CURSOR C_FONDOS IS
      SELECT FON_CODIGO,
             FON_RAZON_SOCIAL,
             FON_TIPO_ADMINISTRACION,
             FON_CAPITAL_PRIVADO,
             FON_ESTADO
        FROM FONDOS
       WHERE FON_TIPO = 'A'
         AND FON_CODIGO = C_DAT.HST_CCC_CLI_PER_NUM_IDEN;
    C_FON C_FONDOS%ROWTYPE;

    CURSOR C_CUENTA_APT IS
      SELECT 'X'
        FROM CUENTAS_CLIENTE_CORREDORES
       WHERE CCC_CLI_PER_NUM_IDEN = C_DAT.HST_CCC_CLI_PER_NUM_IDEN
         AND CCC_CLI_PER_TID_CODIGO = C_DAT.HST_CCC_CLI_PER_TID_CODIGO
         AND CCC_NUMERO_CUENTA = C_DAT.HST_CCC_NUMERO_CUENTA
         AND CCC_CUENTA_APT = 'S';
    V_APT VARCHAR2(1);

    CURSOR ROPEFE IS
      SELECT LIC_FECHA_OPERACION,
             CCC_CLI_PER_TID_CODIGO,
             CCC_CLI_PER_NUM_IDEN,
             CCC_NUMERO_CUENTA,
             OVE_ENA_MNEMONICO,
             SUM(LIC_CANTIDAD_TOTAL_OPERACION) SUMA,
             PEB_PRECIO_BOLSA,
             SUM(LIC_CANTIDAD_TOTAL_OPERACION) * PEB_PRECIO_BOLSA TM
        FROM EMISORES,
             ESPECIES_NACIONALES,
             PERSONAS                    PER,
             CUENTAS_CLIENTE_CORREDORES,
             ORDENES_VENTA,
             LIQUIDACIONES_COMERCIAL     LIC,
             PERSONAS                    PER1,
             PERSONAS_CENTROS_PRODUCCION,
             CENTROS_PRODUCCION,
             PRECIOS_ESPECIES_BOLSA,
             GL_FECHAS                   GL
       WHERE ENA_EMI_MNEMONICO = EMI_MNEMONICO
         AND LIC_MNEMOTECNICO_TITULO = ENA_MNEMONICO
         AND CCC_PER_NUM_IDEN = PER.PER_NUM_IDEN
         AND CCC_PER_TID_CODIGO = PER.PER_TID_CODIGO
         AND OVE_CCC_CLI_PER_NUM_IDEN = CCC_CLI_PER_NUM_IDEN
         AND OVE_CCC_CLI_PER_TID_CODIGO = CCC_CLI_PER_TID_CODIGO
         AND OVE_CCC_NUMERO_CUENTA = CCC_NUMERO_CUENTA
         AND OVE_PER_NUM_IDEN = PER1.PER_NUM_IDEN
         AND OVE_PER_TID_CODIGO = PER1.PER_TID_CODIGO
         AND LIC_BOL_MNEMONICO = OVE_BOL_MNEMONICO
         AND LIC_OVE_COC_CTO_MNEMONICO = OVE_COC_CTO_MNEMONICO
         AND LIC_OVE_CONSECUTIVO = OVE_CONSECUTIVO
         AND LIC_TIPO_OPERACION = 'V'
         AND CCC_PER_NUM_IDEN = PCP_PER_NUM_IDEN
         AND CCC_PER_TID_CODIGO = PCP_PER_TID_CODIGO
         AND PCP_PRINCIPAL = 'S'
         AND PCP_CPR_MNEMONICO = CPR_MNEMONICO
         AND LIC_FECHA_OPERACION <= TRUNC(GL.FECHA_DESDE) --:CONTROL.FECHA_DESDE--'01-SEP-2020'
         AND TRUNC(LIC_FECHA_CUMPLIMIENTO) > TRUNC(C_DAT.HST_FECHA)
         AND CCC_CLI_PER_NUM_IDEN = C_DAT.HST_CCC_CLI_PER_NUM_IDEN
         AND CCC_CLI_PER_TID_CODIGO = C_DAT.HST_CCC_CLI_PER_TID_CODIGO
         AND CCC_NUMERO_CUENTA = C_DAT.HST_CCC_NUMERO_CUENTA
         AND OVE_ENA_MNEMONICO = C_DAT.DSP_ENA_MNEMONICO
         AND LIC_FECHA_VENCIMIENTO IS NULL
         AND TRUNC(PEB_FECHA) = TRUNC(GL.FECHA_DESDE) --TRUNC(:CONTROL.FECHA_DESDE)
         AND PEB_ENA_MNEMONICO = OVE_ENA_MNEMONICO
         AND (LIC_INDICADOR_SWAP != 'S' AND LIC_INDICADOR_CARRUSEL != 'S' AND
             LIC_TIPO_OFERTA NOT IN
             ('A', 'R', 'P', '1', '2', '3', '4', '5', '6'))
       GROUP BY LIC_FECHA_OPERACION,
                CCC_CLI_PER_TID_CODIGO,
                CCC_CLI_PER_NUM_IDEN,
                CCC_NUMERO_CUENTA,
                OVE_ENA_MNEMONICO,
                PEB_PRECIO_BOLSA;
    P_ROPEFE ROPEFE%ROWTYPE;

    DSP_NOMBRE_CLIENTE         VARCHAR2(80);
    DSP_ENA_DESCRIPCION        VARCHAR2(80);
    DSP_TASA_REF               VARCHAR2(5);
    DSP_NOMBRE_DEPOSITO        VARCHAR2(15);
    DSP_TIPO                   VARCHAR2(3);
    DSP_FECHA_VENCIMIENTO      DATE;
    DSP_CUENTA_DEPOSITO        VARCHAR2(35); --MB MIT DCV BANCO DE LA REPUBLICA -- NUMBER(9);
    DSP_CFC_FUG_ISI_MNEMONICO  VARCHAR2(12);
    DSP_ID_COMERCIAL           VARCHAR2(15);
    DSP_NOMBRE_COMERCIAL       VARCHAR2(62);
    DSP_MESA                   VARCHAR2(40);
    DSP_TIPO_CLIENTE           VARCHAR2(20);
    DSP_SALDO_COMPROMISO_RV    NUMBER;
    DSP_VALOR_TM_COMPROMISO_RV NUMBER;

    TIPO_CLIENTE VARCHAR2(20);

    TIP_ARCHIVO        UTL_FILE.FILE_TYPE;
    ARCHIVO_PORTAFOLIO VARCHAR2(100);
    LINEA              VARCHAR2(5000);

    P_FECHA  DATE;
    P_FECHA2 VARCHAR2(20);

    P_CODIGO         VARCHAR2(200);
    P_RESPUESTA      VARCHAR2(200);
    V_RUTA           VARCHAR2(100);
    V_NOMBRE_ARCHIVO VARCHAR2(100);

  BEGIN
    SELECT TRUNC(SYSDATE - 1) INTO P_FECHA FROM DUAL;
    DELETE FROM GL_FECHAS;

    DELETE FROM GL_COPOVA;

    INSERT INTO GL_FECHAS VALUES (P_FECHA, P_FECHA);

    EXECUTE IMMEDIATE 'CREATE OR REPLACE FORCE VIEW "VW_HST_TITULOS" ("HST_CONSECUTIVO","HST_FECHA","HST_CCC_CLI_PER_NUM_IDEN"
                            , "HST_CCC_CLI_PER_TID_CODIGO", "HST_CCC_NUMERO_CUENTA", "HST_SALDO_DISPONIBLE"
                            , "HST_SALDO_GARANTIA", "HST_SALDO_EMBARGO", "HST_VALOR_TM_DISPONIBLE"
                            , "HST_VALOR_TM_GARANTIA", "HST_VALOR_TM_EMBARGO", "HST_CFC_FUG_ISI_MNEMONICO"
                            , "HST_CFC_FUG_MNEMONICO", "HST_CFC_CUENTA_DECEVAL", "HST_TLO_CODIGO"
                            , "HST_INDICADOR_VALORACION", "HST_TASA_VALORACION", "HST_TASA_DESCUENTO"
                            , "HST_SALDO_GARANTIA_REPO", "HST_SALDO_POR_CUMPLIR", "HST_COSTO_PROMEDIO_COMPRA"
                            , "HST_SALDO_TRANSITO_ING", "HST_SALDO_TRANSITO_RET", "HST_SALDO_GARANTIA_DER"
                            , "HST_VALOR_TM_GARREPO", "HST_VALOR_TM_XCUMPLIR", "HST_VALOR_TM_TRANING"
                            , "HST_VALOR_TM_TRANRET", "HST_VALOR_TM_GARDER", "HST_VALOR_TM_CPR_X_CUMPLIR"
                            , "HST_SALDO_CPR_X_CUMPLIR", "DSP_ENA_MNEMONICO","SEGMENTACION","PERFIL"
                            ,"FECHA_COMPRA","FECHA_EMISION","TASA_FACIAL")  AS
   SELECT /*+ INDEX (HISTORICOS_SALDOS_TITULOS HST_NUM_IDEN_TID_COD_FECH)*/ HST_CONSECUTIVO ,
          HST_FECHA ,
          HST_CCC_CLI_PER_NUM_IDEN ,
          HST_CCC_CLI_PER_TID_CODIGO ,
          HST_CCC_NUMERO_CUENTA ,
           DECODE(HST_CCC_CLI_PER_NUM_IDEN,''860079174'',--VAGTUS045900
           HST_SALDO_DISPONIBLE
            --+HST_SALDO_GARANTIA
            --+HST_SALDO_EMBARGO
            --+HST_SALDO_GARANTIA_REPO
            +HST_SALDO_POR_CUMPLIR
            +HST_SALDO_TRANSITO_ING
            +HST_SALDO_TRANSITO_RET
            --+HST_SALDO_GARANTIA_DER
            +HST_SALDO_CPR_X_CUMPLIR
            +HST_CFC_SALDO_TTV_COMPRA_FINAL
            +HST_CFC_SALDO_TTV_VENTA_FINAL
            +HST_CFC_SALDO_TTV_GARANT_REC
            +HST_CFC_SALDO_TTV_GARANT_COL ,HST_SALDO_DISPONIBLE) HST_SALDO_DISPONIBLE,
          HST_SALDO_GARANTIA ,
          HST_SALDO_EMBARGO ,
          DECODE(HST_CCC_CLI_PER_NUM_IDEN,''860079174'',--VAGTUS045900
          NVL((SELECT PEB_PRECIO_BOLSA*(HST_SALDO_DISPONIBLE
            --+HST_SALDO_GARANTIA
            --+HST_SALDO_EMBARGO
            --+HST_SALDO_GARANTIA_REPO
            +HST_SALDO_POR_CUMPLIR
            +HST_SALDO_TRANSITO_ING
            +HST_SALDO_TRANSITO_RET
            --+HST_SALDO_GARANTIA_DER
            +HST_SALDO_CPR_X_CUMPLIR
            +HST_CFC_SALDO_TTV_COMPRA_FINAL
            +HST_CFC_SALDO_TTV_VENTA_FINAL
            +HST_CFC_SALDO_TTV_GARANT_REC
            +HST_CFC_SALDO_TTV_GARANT_COL)
            FROM PRECIOS_ESPECIES_BOLSA A
            WHERE PEB_ENA_MNEMONICO = FUG_ENA_MNEMONICO
           AND TRUNC(PEB_FECHA) = TRUNC(GL.FECHA_DESDE)
           AND ROWNUM = 1),HST_VALOR_TM_DISPONIBLE),HST_VALOR_TM_DISPONIBLE) HST_VALOR_TM_DISPONIBLE,
          HST_VALOR_TM_GARANTIA ,
          HST_VALOR_TM_EMBARGO ,
          HST_CFC_FUG_ISI_MNEMONICO ,
          HST_CFC_FUG_MNEMONICO ,
          HST_CFC_CUENTA_DECEVAL ,
          HST_TLO_CODIGO ,
          HST_INDICADOR_VALORACION ,
          HST_TASA_VALORACION ,
          HST_TASA_DESCUENTO ,
          HST_SALDO_GARANTIA_REPO ,
          HST_SALDO_POR_CUMPLIR ,
          HST_COSTO_PROMEDIO_COMPRA ,
          HST_SALDO_TRANSITO_ING ,
          HST_SALDO_TRANSITO_RET ,
          HST_SALDO_GARANTIA_DER ,
          HST_VALOR_TM_GARREPO ,
          HST_VALOR_TM_XCUMPLIR ,
          HST_VALOR_TM_TRANING ,
          HST_VALOR_TM_TRANRET ,
          HST_VALOR_TM_GARDER ,
          HST_VALOR_TM_CPR_X_CUMPLIR ,
          HST_SALDO_CPR_X_CUMPLIR ,
          FUG_ENA_MNEMONICO DSP_ENA_MNEMONICO,
          BSC_DESCRIPCION SEGMENTACION,
          DECODE(CLI_PERFIL_RIESGO, 10,''CONSERVADOR'',20,''MODERADO'', 30,''ARRIESGADO'') PERFIL,
          NULL FECHA_COMPRA,
          FUG_FECHA_EMISION FECHA_EMISION,
          FUG_TASA_FACIAL TASA_FACIAL
     FROM HISTORICOS_SALDOS_TITULOS ,
          CUENTAS_FUNGIBLE_CLIENTE,
          FUNGIBLES,
          CLIENTES,
          BI_SEGMENTACION_CLIENTES,
          GL_FECHAS GL
    WHERE HST_CFC_CUENTA_DECEVAL  = CFC_CUENTA_DECEVAL
      AND HST_CFC_FUG_ISI_MNEMONICO = CFC_FUG_ISI_MNEMONICO
      AND HST_CFC_FUG_MNEMONICO     = CFC_FUG_MNEMONICO
      AND CFC_FUG_ISI_MNEMONICO     = FUG_ISI_MNEMONICO
      AND CFC_FUG_MNEMONICO         = FUG_MNEMONICO
      AND BSC_BCC_MNEMONICO         = CLI_BSC_BCC_MNEMONICO
      AND BSC_MNEMONICO             = CLI_BSC_MNEMONICO
      AND CLI_PER_NUM_IDEN          = HST_CCC_CLI_PER_NUM_IDEN
      AND CLI_PER_TID_CODIGO        = HST_CCC_CLI_PER_TID_CODIGO
      --AND CFC_CCC_CLI_PER_NUM_IDEN =  HST_CCC_CLI_PER_NUM_IDEN --VAGTUS046067
      --and CFC_CCC_CLI_PER_TID_CODIGO = HST_CCC_CLI_PER_TID_CODIGO --VAGTUS046067
      AND HST_FECHA                 >= TRUNC(GL.FECHA_DESDE)
      AND HST_FECHA                 < TRUNC(GL.FECHA_HASTA + 1)
          UNION ALL
   SELECT /*+ INDEX (HISTORICOS_SALDOS_TITULOS HST_NUM_IDEN_TID_COD_FECH)*/ HST_CONSECUTIVO ,
          HST_FECHA ,
          HST_CCC_CLI_PER_NUM_IDEN ,
          HST_CCC_CLI_PER_TID_CODIGO ,
          HST_CCC_NUMERO_CUENTA ,
           DECODE(HST_CCC_CLI_PER_NUM_IDEN,''860079174'',--VAGTUS045900
           HST_SALDO_DISPONIBLE
            --+HST_SALDO_GARANTIA
            --+HST_SALDO_EMBARGO
            --+HST_SALDO_GARANTIA_REPO
            +HST_SALDO_POR_CUMPLIR
            +HST_SALDO_TRANSITO_ING
            +HST_SALDO_TRANSITO_RET
           -- +HST_SALDO_GARANTIA_DER
            +HST_SALDO_CPR_X_CUMPLIR
            +HST_CFC_SALDO_TTV_COMPRA_FINAL
            +HST_CFC_SALDO_TTV_VENTA_FINAL
            +HST_CFC_SALDO_TTV_GARANT_REC
            +HST_CFC_SALDO_TTV_GARANT_COL ,HST_SALDO_DISPONIBLE) HST_SALDO_DISPONIBLE,
          HST_SALDO_GARANTIA ,
          HST_SALDO_EMBARGO ,
           DECODE(HST_CCC_CLI_PER_NUM_IDEN,''860079174'',
          NVL((SELECT PEB_PRECIO_BOLSA*(HST_SALDO_DISPONIBLE
            --+HST_SALDO_GARANTIA
            --+HST_SALDO_EMBARGO
            --+HST_SALDO_GARANTIA_REPO
            +HST_SALDO_POR_CUMPLIR
            +HST_SALDO_TRANSITO_ING
            +HST_SALDO_TRANSITO_RET
           -- +HST_SALDO_GARANTIA_DER
            +HST_SALDO_CPR_X_CUMPLIR
            +HST_CFC_SALDO_TTV_COMPRA_FINAL
            +HST_CFC_SALDO_TTV_VENTA_FINAL
            +HST_CFC_SALDO_TTV_GARANT_REC
            +HST_CFC_SALDO_TTV_GARANT_COL)
            FROM PRECIOS_ESPECIES_BOLSA A
            WHERE PEB_ENA_MNEMONICO = TLO_ENA_MNEMONICO
           AND TRUNC(PEB_FECHA) = TRUNC(GL.FECHA_DESDE)
           AND ROWNUM = 1),HST_VALOR_TM_DISPONIBLE),HST_VALOR_TM_DISPONIBLE) HST_VALOR_TM_DISPONIBLE,
          HST_VALOR_TM_GARANTIA ,
          HST_VALOR_TM_EMBARGO ,
          HST_CFC_FUG_ISI_MNEMONICO ,
          HST_CFC_FUG_MNEMONICO ,
          HST_CFC_CUENTA_DECEVAL ,
          HST_TLO_CODIGO ,
          HST_INDICADOR_VALORACION ,
          HST_TASA_VALORACION ,
          HST_TASA_DESCUENTO ,
          HST_SALDO_GARANTIA_REPO ,
          HST_SALDO_POR_CUMPLIR ,
          HST_COSTO_PROMEDIO_COMPRA ,
          HST_SALDO_TRANSITO_ING ,
          HST_SALDO_TRANSITO_RET ,
          HST_SALDO_GARANTIA_DER ,
          HST_VALOR_TM_GARREPO ,
          HST_VALOR_TM_XCUMPLIR ,
          HST_VALOR_TM_TRANING ,
          HST_VALOR_TM_TRANRET ,
          HST_VALOR_TM_GARDER ,
          HST_VALOR_TM_CPR_X_CUMPLIR ,
          HST_SALDO_CPR_X_CUMPLIR ,
          TLO_ENA_MNEMONICO DSP_ENA_MNEMONICO,
          BSC_DESCRIPCION,
          DECODE(CLI_PERFIL_RIESGO, 10,''CONSERVADOR'',20,''MODERADO'', 30,''ARRIESGADO''),
          TLO_FECHA_OPERACION,
          TLO_FECHA_EMISION,
          TLO_TASA_FACIAL
     FROM HISTORICOS_SALDOS_TITULOS ,
          TITULOS,
          CLIENTES,
          BI_SEGMENTACION_CLIENTES,
          GL_FECHAS GL
    WHERE HST_TLO_CODIGO = TLO_CODIGO
      AND CLI_PER_NUM_IDEN          = HST_CCC_CLI_PER_NUM_IDEN
      AND CLI_PER_TID_CODIGO        = HST_CCC_CLI_PER_TID_CODIGO
      AND BSC_BCC_MNEMONICO         = CLI_BSC_BCC_MNEMONICO
      AND BSC_MNEMONICO             = CLI_BSC_MNEMONICO
      AND TLO_CCC_CLI_PER_NUM_IDEN  = HST_CCC_CLI_PER_NUM_IDEN
      AND TLO_CCC_CLI_PER_TID_CODIGO = HST_CCC_CLI_PER_TID_CODIGO
      AND HST_FECHA      >=  TRUNC(GL.FECHA_DESDE)
      AND HST_FECHA      < TRUNC(GL.FECHA_HASTA + 1)';

    COMMIT;

    SELECT TO_CHAR(P_FECHA, 'DDMMYYYY') INTO P_FECHA2 FROM DUAL;

    ARCHIVO_PORTAFOLIO := 'COPOVA_PORTAFOLIO_VALORACION_' || P_FECHA2 ||
                          '.csv';
    TIP_ARCHIVO        := UTL_FILE.FOPEN('REP_NOCTURNOS',
                                         ARCHIVO_PORTAFOLIO,
                                         'W',
                                         10000);
    LINEA              := 'FECHA;NUM_IDEN;TIPO_IDEN;CUENTA;NOMBRE_CLIENTE;SALDO_DISPONIBLE;VALOR_TM_DISPONIBLE;SALDO_GARANTIA;VALOR_TM_GARANTIA;SALDO_GARANTIA_REPO;VALOR_TM_GARREPO;SALDO_EMBARGO;VALOR_TM_EMBARGO;SALDO_GARANTIA_DER;VALOR_TM_GARDER;NOMINAL_COMPR_V_RV;TM_COMPR_V_RV;ISIN;FUNGIBLE;CTA_INVERSIONISTA;TITULO;IND_VALORACION;TASA;TASA_DESCUENTO;MNEMO;ESPECIE;DEPOSITO;MERCADO;NID_COMERCIAL;NOMBRE_COMERCIAL;MESA_COMERCIAL;TASA_REF;FECHA_VENC;TIPO_CLIENTE;FECHA_COMPRA;FECHA_EMISION;TASA_FACIAL;';
    UTL_FILE.PUT_LINE(TIP_ARCHIVO, LINEA);

    TIPO_CLIENTE     := ' ';
    DSP_TIPO_CLIENTE := ' ';

    OPEN C_DATOS;
    FETCH C_DATOS
      INTO C_DAT;
    WHILE C_DATOS%FOUND LOOP

      OPEN C_CLIENTE;
      FETCH C_CLIENTE
        INTO C_CLI;
      CLOSE C_CLIENTE;
      C_CLI.PER_NOMBRE   := NVL(C_CLI.PER_NOMBRE, ' ');
      DSP_NOMBRE_CLIENTE := C_CLI.PER_NOMBRE;

      OPEN C_ESPECIES;
      FETCH C_ESPECIES
        INTO C_ESP;
      CLOSE C_ESPECIES;
      C_ESP.ENA_DESCRIPCION := NVL(C_ESP.ENA_DESCRIPCION, ' ');
      DSP_ENA_DESCRIPCION   := C_ESP.ENA_DESCRIPCION;
      DSP_TASA_REF          := C_ESP.ENA_TRE_MNEMONICO;

      OPEN C_LOCALIZACION;
      FETCH C_LOCALIZACION
        INTO C_LOC;
      IF C_LOCALIZACION%FOUND THEN
        DSP_NOMBRE_DEPOSITO   := C_LOC.LTI_DESCRIPCION;
        DSP_TIPO              := C_LOC.TLO_TYPE;
        DSP_FECHA_VENCIMIENTO := C_LOC.TLO_FECHA_VENCIMIENTO;
        IF C_LOC.LTI_DESCRIPCION = 'DCV' THEN
          OPEN C_CUENTA_DCV;
          FETCH C_CUENTA_DCV
            INTO DSP_CUENTA_DEPOSITO;
          CLOSE C_CUENTA_DCV;
        ELSIF C_LOC.LTI_DESCRIPCION = 'DECEVAL' THEN
          DSP_CUENTA_DEPOSITO := C_DAT.HST_CFC_CUENTA_DECEVAL;
        END IF;
      ELSE
        DSP_TIPO := C_ESP.ENA_TIPO_ESPECIE;
      END IF;
      CLOSE C_LOCALIZACION;

      IF C_DAT.HST_CFC_CUENTA_DECEVAL IS NOT NULL THEN
        DSP_NOMBRE_DEPOSITO := 'DECEVAL';
        DSP_CUENTA_DEPOSITO := C_DAT.HST_CFC_CUENTA_DECEVAL;
      END IF;

      IF DSP_NOMBRE_DEPOSITO = 'DECEVAL' THEN
        DSP_CFC_FUG_ISI_MNEMONICO := C_DAT.HST_CFC_FUG_ISI_MNEMONICO;
        OPEN C_ISIN2(C_DAT.HST_CFC_FUG_ISI_MNEMONICO);
        FETCH C_ISIN2
          INTO C_ISI2;
        CLOSE C_ISIN2;
        DSP_FECHA_VENCIMIENTO := C_ISI2.FUG_FECHA_VENCIMIENTO;
      ELSE
        OPEN C_ISIN;
        FETCH C_ISIN
          INTO C_ISI;
        CLOSE C_ISIN;

        DSP_CFC_FUG_ISI_MNEMONICO := NVL(C_ISI.FUG_ISI_MNEMONICO, ' ');
      END IF;

      OPEN C_COMERCIAL;
      FETCH C_COMERCIAL
        INTO C_COM;
      CLOSE C_COMERCIAL;
      DSP_ID_COMERCIAL     := C_COM.PER_NUM_IDEN;
      DSP_NOMBRE_COMERCIAL := C_COM.PER_NOMBRE;

      OPEN C_MESA(C_COM.PER_NUM_IDEN);
      FETCH C_MESA
        INTO DSP_MESA;
      CLOSE C_MESA;

      OPEN ROPEFE;
      FETCH ROPEFE
        INTO P_ROPEFE;
      IF ROPEFE%FOUND THEN
        DSP_SALDO_COMPROMISO_RV    := P_ROPEFE.SUMA;
        DSP_VALOR_TM_COMPROMISO_RV := P_ROPEFE.TM;
      ELSE
        DSP_SALDO_COMPROMISO_RV    := 0;
        DSP_VALOR_TM_COMPROMISO_RV := .00;
      END IF;
      CLOSE ROPEFE;

      OPEN C_FONDOS;
      FETCH C_FONDOS
        INTO C_FON;
      IF C_FONDOS%FOUND THEN
        IF NVL(C_FON.FON_TIPO_ADMINISTRACION, ' ') = 'A' THEN
          IF NVL(C_FON.FON_ESTADO, ' ') = 'A' THEN
            V_APT := '';
            OPEN C_CUENTA_APT;
            FETCH C_CUENTA_APT
              INTO V_APT;
            CLOSE C_CUENTA_APT;

            IF NVL(V_APT, 'Y') = 'X' THEN
              TIPO_CLIENTE := 'APT';
            ELSE
              TIPO_CLIENTE := 'CLIENTE';
            END IF;
          ELSE
            TIPO_CLIENTE := 'CLIENTE';
          END IF;
        ELSIF NVL(C_FON.FON_TIPO_ADMINISTRACION, ' ') = 'C' THEN
          TIPO_CLIENTE := 'POSICION PROPIA';
        ELSIF NVL(C_FON.FON_TIPO_ADMINISTRACION, ' ') = 'R' THEN
          TIPO_CLIENTE := 'RECURSOS PROPIOS';
        ELSIF NVL(C_FON.FON_TIPO_ADMINISTRACION, ' ') = 'F' THEN
          TIPO_CLIENTE := 'FONDO INVERSION';
        ELSE
          V_APT := '';
          OPEN C_CUENTA_APT;
          FETCH C_CUENTA_APT
            INTO V_APT;
          CLOSE C_CUENTA_APT;

          IF NVL(V_APT, 'Y') = 'X' THEN
            TIPO_CLIENTE := 'APT';
          ELSE
            TIPO_CLIENTE := 'CLIENTE';
          END IF;
        END IF;
      ELSE
        TIPO_CLIENTE := 'CLIENTE';
      END IF;
      CLOSE C_FONDOS;

      DSP_TIPO_CLIENTE := TIPO_CLIENTE;

      LINEA := '';
      LINEA := C_DAT.HST_FECHA || ';' || C_DAT.HST_CCC_CLI_PER_NUM_IDEN || ';' ||
               C_DAT.HST_CCC_CLI_PER_TID_CODIGO || ';' ||
               C_DAT.HST_CCC_NUMERO_CUENTA || ';' || DSP_NOMBRE_CLIENTE || ';' ||
               REPLACE(C_DAT.HST_SALDO_DISPONIBLE, ',', '.') || ';' ||
               REPLACE(C_DAT.HST_VALOR_TM_DISPONIBLE, ',', '.') || ';' ||
               REPLACE(C_DAT.HST_SALDO_GARANTIA, ',', '.') || ';' ||
               REPLACE(C_DAT.HST_VALOR_TM_GARANTIA, ',', '.') || ';' ||
               REPLACE(C_DAT.HST_SALDO_GARANTIA_REPO, ',', '.') || ';' ||
               REPLACE(C_DAT.HST_VALOR_TM_GARREPO, ',', '.') || ';' ||
               REPLACE(C_DAT.HST_SALDO_EMBARGO, ',', '.') || ';' ||
               REPLACE(C_DAT.HST_VALOR_TM_EMBARGO, ',', '.') || ';' ||
               REPLACE(C_DAT.HST_SALDO_GARANTIA_DER, ',', '.') || ';' ||
               REPLACE(C_DAT.HST_VALOR_TM_GARDER, ',', '.') || ';' ||
               DSP_SALDO_COMPROMISO_RV || ';' || DSP_VALOR_TM_COMPROMISO_RV || ';' ||
               DSP_CFC_FUG_ISI_MNEMONICO --C_DAT.HST_CFC_FUG_ISI_MNEMONICO
               || ';' || C_DAT.HST_CFC_FUG_MNEMONICO || ';' ||
               DSP_CUENTA_DEPOSITO || ';' || C_DAT.HST_TLO_CODIGO || ';' ||
               C_DAT.HST_INDICADOR_VALORACION || ';' ||
               REPLACE(C_DAT.HST_TASA_VALORACION, ',', '.') || ';' ||
               REPLACE(C_DAT.HST_TASA_DESCUENTO, ',', '.') || ';' ||
               C_DAT.DSP_ENA_MNEMONICO || ';' || DSP_ENA_DESCRIPCION || ';' ||
               DSP_NOMBRE_DEPOSITO || ';' || DSP_TIPO || ';' ||
               DSP_ID_COMERCIAL || ';' || DSP_NOMBRE_COMERCIAL || ';' ||
               DSP_MESA || ';' || REPLACE(DSP_TASA_REF, ',', '.') || ';' ||
               TO_CHAR(DSP_FECHA_VENCIMIENTO, 'DD/MM/YYYY') || ';' ||
               DSP_TIPO_CLIENTE || ';' ||
               TO_CHAR(C_DAT.FECHA_COMPRA, 'DD/MM/YYYY') || ';' ||
               TO_CHAR(C_DAT.FECHA_EMISION, 'DD/MM/YYYY') || ';' ||
               REPLACE(C_DAT.TASA_FACIAL, ',', '.');

      UTL_FILE.PUT_LINE(TIP_ARCHIVO, LINEA);

      --VAGTUD990-CSVELASQUEZ - PLANO INTEGRADO 8
      INSERT INTO GL_COPOVA
      VALUES
        (C_DAT.HST_FECHA,
         C_DAT.HST_CCC_CLI_PER_NUM_IDEN,
         C_DAT.HST_CCC_CLI_PER_TID_CODIGO,
         C_DAT.HST_CCC_NUMERO_CUENTA,
         DSP_NOMBRE_CLIENTE,
         C_DAT.HST_SALDO_DISPONIBLE,
         C_DAT.HST_VALOR_TM_DISPONIBLE,
         C_DAT.HST_SALDO_GARANTIA,
         C_DAT.HST_VALOR_TM_GARANTIA,
         C_DAT.HST_SALDO_GARANTIA_REPO,
         C_DAT.HST_VALOR_TM_GARREPO,
         C_DAT.HST_SALDO_EMBARGO,
         C_DAT.HST_VALOR_TM_EMBARGO,
         C_DAT.HST_SALDO_GARANTIA_DER,
         C_DAT.HST_VALOR_TM_GARDER,
         DSP_SALDO_COMPROMISO_RV,
         DSP_VALOR_TM_COMPROMISO_RV,
         DSP_CFC_FUG_ISI_MNEMONICO,
         C_DAT.HST_CFC_FUG_MNEMONICO,
         DSP_CUENTA_DEPOSITO,
         C_DAT.HST_TLO_CODIGO,
         C_DAT.HST_INDICADOR_VALORACION,
         C_DAT.HST_TASA_VALORACION,
         C_DAT.HST_TASA_DESCUENTO,
         C_DAT.DSP_ENA_MNEMONICO,
         DSP_ENA_DESCRIPCION,
         DSP_NOMBRE_DEPOSITO,
         DSP_TIPO,
         DSP_ID_COMERCIAL,
         DSP_NOMBRE_COMERCIAL,
         DSP_MESA,
         DSP_TASA_REF,
         DSP_FECHA_VENCIMIENTO,
         DSP_TIPO_CLIENTE,
         C_DAT.FECHA_COMPRA,
         C_DAT.FECHA_EMISION,
         C_DAT.TASA_FACIAL);
      COMMIT;

      FETCH C_DATOS
        INTO C_DAT;
    END LOOP;
    CLOSE C_DATOS;

    UTL_FILE.FCLOSE(TIP_ARCHIVO);

    V_RUTA           := '\\nas.corredor.local\Riesgo\CONFIDENCIAL\Reportes Excel Coeasy\';
    V_NOMBRE_ARCHIVO := 'COPOVA_' || TO_CHAR(SYSDATE, 'DDMMYYYY');

    --LLAMADO AL PROGRAMA QUE CREA EL XSLX
    P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => V_RUTA,
                                   P_NOMBRE_ARCHIVO => V_NOMBRE_ARCHIVO,
                                   P_QUERY          => 'SELECT HST_FECHA FECHA' ||
                                                       '     , HST_CCC_CLI_PER_NUM_IDEN NUM_IDEN' ||
                                                       '     , HST_CCC_CLI_PER_TID_CODIGO TIPO_IDEN' ||
                                                       '     , DSP_NOMBRE_CLIENTE NOMBRE_CLIENTE' ||
                                                       '     , HST_CCC_NUMERO_CUENTA CUENTA' ||
                                                       '     , HST_SALDO_DISPONIBLE SALDO_DISPONIBLE' ||
                                                       '     , HST_VALOR_TM_DISPONIBLE VALOR_TM_DISPONIBLE' ||
                                                       '     , HST_SALDO_GARANTIA SALDO_GARANTIA' ||
                                                       '     , HST_VALOR_TM_GARANTIA  VALOR_TM_GARANTIA' ||
                                                       '     , HST_SALDO_GARANTIA_REPO SALDO_GARANTIA_REPO' ||
                                                       '     , HST_VALOR_TM_GARREPO VALOR_TM_GARREPO' ||
                                                       '     , HST_SALDO_EMBARGO SALDO_EMBARGO' ||
                                                       '     , HST_VALOR_TM_EMBARGO VALOR_TM_EMBARGO' ||
                                                       '     , HST_SALDO_GARANTIA_DER SALDO_GARANTIA_DER' ||
                                                       '     , HST_VALOR_TM_GARDER VALOR_TM_GARDER' ||
                                                       '     , DSP_SALDO_COMPROMISO_RV NOMINAL_COMPR_V_RV' ||
                                                       '     , DSP_VALOR_TM_COMPROMISO_RV TM_COMPR_V_RV' ||
                                                       '     , DSP_CFC_FUG_ISI_MNEMONICO ISIN' ||
                                                       '     , HST_CFC_FUG_MNEMONICO FUNGIBLE' ||
                                                       '     , DSP_CUENTA_DEPOSITO CTA_INVERSIONISTA' ||
                                                       '     , HST_TLO_CODIGO TITULO' ||
                                                       '     , HST_INDICADOR_VALORACION IND_VALORACION' ||
                                                       '     , HST_TASA_VALORACION TASA' ||
                                                       '     , HST_TASA_DESCUENTO TASA_DESCUENTO' ||
                                                       '     , DSP_ENA_MNEMONICO MNEMO' ||
                                                       '     , DSP_ENA_DESCRIPCION ESPECIE' ||
                                                       '     , DSP_NOMBRE_DEPOSITO DEPOSITO' ||
                                                       '     , DSP_TIPO MERCADO' ||
                                                       '     , DSP_ID_COMERCIAL NID_COMERCIAL' ||
                                                       '     , DSP_NOMBRE_COMERCIAL NOMBRE_COMERCIAL' ||
                                                       '     , DSP_MESA MESA_COMERCIAL' ||
                                                       '     , DSP_TASA_REF TASA_REF' ||
                                                       '     , DSP_FECHA_VENCIMIENTO FECHA_VENC' ||
                                                       '     , DSP_TIPO_CLIENTE TIPO_CLIENTE' ||
                                                       '     , FECHA_COMPRA ' ||
                                                       '     , FECHA_EMISION ' ||
                                                       '     , TASA_FACIAL ' ||
                                                       '  FROM GL_COPOVA',
                                   P_CODIGO         => P_CODIGO,
                                   P_RESPUESTA      => P_RESPUESTA);
    IF P_CODIGO = '0000' THEN
      DBMS_OUTPUT.PUT_LINE('Se ha generado el archivo, en la ruta ' ||
                           V_RUTA);
    END IF;

  END PORTAFOLIO_VALORACION;

  PROCEDURE PR_REPORTE_COPORF_CD( /*P_FECHA  IN DATE,*/P_USERID IN VARCHAR2) IS

    VAR          VARCHAR2(2000);
    V_FECHA      VARCHAR2(20);
    V_FECHAN     VARCHAR2(20);
    V_PORTAFOLIO VARCHAR2(20) := 'Cierre Dia';

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_COPORF_CD',
                                                      'INI');

    SELECT TO_CHAR(TRUNC(SYSDATE - 1),
                   'DD-MON-YYYY',
                   'nls_date_language = ''LATIN AMERICAN SPANISH''')
      INTO V_FECHA
      FROM DUAL;

    SELECT TO_CHAR(TRUNC(SYSDATE - 1), 'DDMMYYYY') INTO V_FECHAN FROM DUAL;

    /*P_MAIL.ENVIO_MAIL_ERROR('Inicio genera reporte COPORF_CD ',
    '<br>'||'Fecha consultada del reporte: '||V_FECHA||,
    DESTINATARIOS); */
    --COPORF PDF - CIERRE DżA
    P_TOOLS.PR_CREAR_REPORTE(P_REPORT     => 'COPORF',
                             P_USERID     => P_USERID,
                             P_FORMATO    => 'PDF',
                             P_PARAMETROS => '+P_P_TGA=Si+P_MONTO=Sin_Validacion+P_TIPO=PESOS+QUEFECHA=' ||
                                             V_FECHA || '+P_VAL=' ||
                                             V_PORTAFOLIO,
                             P_ARCHIVO    => '/apps/rep_nocturnos/diarios/COPORF_CD_' ||
                                             V_FECHAN);
    --COPORF  - TXT - CIERRE DżA
    P_TOOLS.PR_CREAR_REPORTE(P_REPORT     => 'COPORF',
                             P_USERID     => P_USERID,
                             P_FORMATO    => 'TXT',
                             P_PARAMETROS => '+P_P_TGA=Si+P_MONTO=Sin_Validacion+P_TIPO=PESOS+QUEFECHA=' ||
                                             V_FECHA || '+P_VAL=' ||
                                             V_PORTAFOLIO,
                             P_ARCHIVO    => '/apps/rep_nocturnos/diarios/COPORF_CD_' ||
                                             V_FECHAN);

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_COPORF_CD',
                                                      'FIN');

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PR_REPORTE_COPORF_CD',
                              SUBSTR(SQLERRM, 1, 80),
                              'procesosnocturnos@corredores.com');
  END PR_REPORTE_COPORF_CD;

