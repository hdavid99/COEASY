  PROCEDURE PR_REPORTE_RMOVBA_A2(P_USERID IN VARCHAR2) IS

    VAR           VARCHAR2(2000);
    V_FECHA       VARCHAR2(20);
    V_CONDICION   VARCHAR2(5000);
    V_FECHAS      VARCHAR2(1000);
    V_FECHAS1     VARCHAR2(1000);
    V_FECHA_INI   VARCHAR2(1000);
    V_MOVIMIENTO  VARCHAR2(5000) := ' ';
    V_MOVIMIENTO1 VARCHAR2(5000) := ' ';
    V_FECHA_N     VARCHAR2(20);
    V_FECHAN      VARCHAR2(20);

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN
    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_RMOVBA_A2',
                                                      'INI');

    SELECT TO_CHAR(P_TOOLS.CF_DIA_HABIL_ANTERIOR(SYSDATE),
                   'DD-MON-YYYY',
                   'nls_date_language = ''LATIN AMERICAN SPANISH'''),
           TO_CHAR(TRUNC((SYSDATE)),
                   'DD-MON-YYYY',
                   'nls_date_language = ''LATIN AMERICAN SPANISH''')
      INTO V_FECHA, V_FECHA_N
      FROM DUAL;

    SELECT TO_CHAR(TRUNC(SYSDATE - 1), 'DDMMYYYY') INTO V_FECHAN FROM DUAL;

    V_CONDICION := 'CBA.CBA_BAN_CODIGO%20IN%20(SELECT%20DISTINCT%20BAN.BAN_CODIGO%20FROM%20CUENTAS_BANCARIAS_CORREDORES%20CBA%20,BANCOS%20BAN%20WHERE%20CBA.CBA_BAN_CODIGO%20=%20BAN.BAN_CODIGO%20AND%20BAN.BAN_ESTADO%20=%20%27A%27)%20AND%20CBA.CBA_NEG_CONSECUTIVO%20=%272%27%20AND%20CBA.CBA_ESTADO=%27A%27AND%20';

    /*P_MAIL.ENVIO_MAIL_ERROR('Inicio genera reporte RMOVBA ',
    '<br>'||'Fecha consultada del reporte: '||V_FECHA||,
    DESTINATARIOS); */

    P_TOOLS.PR_CREAR_REPORTE(P_REPORT     => 'RMOVBA',
                             P_USERID     => P_USERID,
                             P_FORMATO    => 'PDF',
                             P_PARAMETROS => '+P_FECHAS=MCB.MCB_FECHA%20%3E%20%27%27' ||
                                             V_FECHA ||
                                             '%27%27%20AND%20MCB.MCB_FECHA%20%3C%20%27%27' ||
                                             V_FECHA_N ||
                                             '%27%27+P_FECHAS1=%20PCB.PCB_FECHA%20%3E=%20%27%27' ||
                                             V_FECHA ||
                                             '%27%27%20AND%20PCB.PCB_FECHA%20%3C%20%27%27' ||
                                             V_FECHA ||
                                             '%27%27+P_FECHA_INI=' ||
                                             V_FECHA || '+P_CONDICION=' ||
                                             V_CONDICION ||
                                             '+P_TIPO=Resumido+P_PREVIOS=Con Previos',
                             P_ARCHIVO    => '/apps/rep_nocturnos_a2/RMOVBA_A2_' ||
                                             V_FECHAN);

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PR_REPORTE_RMOVBA_A2',
                              SUBSTR(SQLERRM, 1, 80),
                              'procesosnocturnos@corredores.com');
  END PR_REPORTE_RMOVBA_A2;

  PROCEDURE PR_REPORTE_RMOVBA_CE_A2(P_USERID IN VARCHAR2) IS

    VAR           VARCHAR2(2000);
    V_FECHA       VARCHAR2(20);
