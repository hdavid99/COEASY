  /*******************************VALIDACION DE PROCESO DE DILUCION******************************/
  -----------------------------------------------------------------------------------------------------------------------
  PROCEDURE P_VALIDA_APERTURA IS

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

    CURSOR C_VALIDA IS
      SELECT COUNT(*) CUENTA
        FROM ORDENES_FONDOS
       WHERE OFO_CFO_FON_CODIGO = '900908192'
         AND OFO_TTO_TOF_CODIGO IN ('ING', 'INC')
         AND OFO_FECHA_CAPTURA >= SYSDATE - 1
         AND OFO_FECHA_CAPTURA < SYSDATE;
    R_VALIDA C_VALIDA%ROWTYPE;

  BEGIN
    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_VALIDA_APERTURA',
                                                      'INI');

    OPEN C_VALIDA;
    FETCH C_VALIDA
      INTO R_VALIDA;
    IF R_VALIDA.CUENTA <> 0 THEN
      P_INMOBILIARIO.P_REDISTRIBUCION_FICI;
    END IF;
    CLOSE C_VALIDA;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_VALIDA_APERTURA',
                                                      'FIN');

    COMMIT;
  EXCEPTION
    WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20059,
                              'Error al validar los datos de apertura del fondo inmobiliario, P_VALIDA_APERTURA: ' ||
                              SQLERRM);

  END P_VALIDA_APERTURA;
  -------------------------------------------------DINżMICAS CONTABLES FASE 1------------------------------------------------------------------------------------
  PROCEDURE PR_REPORTE_RMOVRE_MES(P_USERID IN VARCHAR2) IS

    CURSOR C1 IS
      SELECT FON_CODIGO
        FROM FONDOS, CUENTAS_FONDOS
       WHERE CFO_FON_CODIGO = FON_CODIGO
         AND FON_TIPO_ADMINISTRACION = 'A'
         AND FON_ESTADO = 'A';

    V_VAR         VARCHAR2(5000);
    V_FECHA_HASTA VARCHAR2(20);
    V_FECHA_DESDE VARCHAR2(20);
    P_NUM_INI     NUMBER;
    P_NUM_FIN     NUMBER;

    V_CODIGO  NUMBER;
    V_MENSAJE VARCHAR2(200);
    NO_REPORTE              EXCEPTION;
    RAISE_APPLICATION_ERROR EXCEPTION;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_RMOVRE_MES',
                                                      'INI');
    utl_http.set_transfer_timeout(1200);
    SELECT to_char(trunc((add_months(SYSDATE, -1)), 'MM'),
                   'DD-MON-RRRR',
                   'nls_date_language = ''LATIN AMERICAN SPANISH''')
      INTO V_FECHA_DESDE
      from dual;

    SELECT TO_CHAR(LAST_DAY(TO_DATE((add_months(SYSDATE, -1)), 'DD/MM/RRRR')),
                   'DD-MON-YYYY',
                   'nls_date_language = ''LATIN AMERICAN SPANISH''')
      INTO V_FECHA_HASTA
      FROM DUAL;

    P_PORTAFOLIO_APT.PR_GENERA_SALDOS_RMOVRE(V_FECHA_DESDE, V_FECHA_HASTA); --WGONZALEZ VAGTUD944-2

    P_REPORTES_APT.PR_GENERA_PDF_RMOVRE(V_FECHA_DESDE,
                                        V_FECHA_HASTA,
                                        NULL,
                                        NULL,
                                        NULL,
                                        1,
                                        V_CODIGO,
                                        V_MENSAJE);

    IF V_CODIGO = 200 THEN
      DBMS_OUTPUT.PUT_LINE('Se ha generado el reporte en la ruta establecida. ');
    ELSE
      RAISE NO_REPORTE;
    END IF;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_RMOVRE_MES',
                                                      'FIN');

  EXCEPTION
    WHEN NO_REPORTE THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PR_REPORTE_RMOVRE_MES' ||
                              V_CODIGO || '-' || V_MENSAJE,
                              SUBSTR(SQLERRM, 1, 80),
                              'procesosnocturnos@corredores.com');
    WHEN OTHERS THEN
      --P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PR_REPORTE_RMOVRE_MES',SUBSTR(SQLERRM,1,80),'procesosnocturnos@corredores.com');
      NULL;

  END PR_REPORTE_RMOVRE_MES;
  ----
  PROCEDURE PR_REPORTE_RMOVRE_ACUM(P_USERID IN VARCHAR2) IS

    CURSOR C1 IS
      SELECT FON_CODIGO
        FROM FONDOS, CUENTAS_FONDOS
       WHERE CFO_FON_CODIGO = FON_CODIGO
         AND FON_TIPO_ADMINISTRACION = 'A'
         AND FON_ESTADO = 'A';

    V_VAR         VARCHAR2(5000);
    V_FECHA_HASTA VARCHAR2(20);
    V_FECHA_DESDE VARCHAR2(20);
    P_NUM_INI     NUMBER;
    P_NUM_FIN     NUMBER;

    V_CODIGO  NUMBER;
    V_MENSAJE VARCHAR2(200);
    NO_REPORTE              EXCEPTION;
    RAISE_APPLICATION_ERROR EXCEPTION;
  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_RMOVRE_ACUM',
                                                      'INI');
    utl_http.set_transfer_timeout(1200);
    UTL_HTTP.SET_TRANSFER_TIMEOUT(1200);

    SELECT '01-ENE-' || TO_CHAR(SYSDATE, 'YYYY')
      INTO V_FECHA_DESDE
      from dual;

    SELECT TO_CHAR(LAST_DAY(TO_DATE((add_months(SYSDATE, -1)), 'DD/MM/RRRR')),
                   'DD-MON-YYYY',
                   'nls_date_language = ''LATIN AMERICAN SPANISH''')
      INTO V_FECHA_HASTA
      FROM DUAL;

    P_REPORTES_APT.PR_GENERA_PDF_RMOVRE(V_FECHA_DESDE,
                                        V_FECHA_HASTA,
                                        NULL,
                                        NULL,
                                        NULL,
                                        2,
                                        V_CODIGO,
                                        V_MENSAJE);

    IF V_CODIGO = 200 THEN
      DBMS_OUTPUT.PUT_LINE('Se ha generado el reporte en la ruta establecida. ');
    ELSE
      RAISE NO_REPORTE;
    END IF;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_RMOVRE_ACUM',
                                                      'FIN');

  EXCEPTION
    WHEN NO_REPORTE THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PR_REPORTE_RMOVRE_MES' ||
                              V_CODIGO || '-' || V_MENSAJE,
                              SUBSTR(SQLERRM, 1, 80),
                              'procesosnocturnos@corredores.com');
    WHEN OTHERS THEN
      --P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PR_REPORTE_RMOVRE_MES',SUBSTR(SQLERRM,1,80),'procesosnocturnos@corredores.com');
      NULL;

  END PR_REPORTE_RMOVRE_ACUM;
