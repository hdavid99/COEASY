  PROCEDURE PORTAFOLIO_VALORACION_A2 AS

    CURSOR C_DATOS IS
      SELECT HST_CONSECUTIVO,
             HST_FECHA,
             HST_CCC_CLI_PER_NUM_IDEN,
             HST_CCC_CLI_PER_TID_CODIGO,
             HST_CCC_NUMERO_CUENTA,
             HST_SALDO_DISPONIBLE,
             HST_SALDO_GARANTIA,
             HST_SALDO_EMBARGO,
             HST_VALOR_TM_DISPONIBLE,
             HST_VALOR_TM_GARANTIA,
             HST_VALOR_TM_EMBARGO,
             HST_CFC_FUG_ISI_MNEMONICO,
             HST_CFC_FUG_MNEMONICO,
             HST_CFC_CUENTA_DECEVAL,
             HST_TLO_CODIGO,
             HST_INDICADOR_VALORACION,
             HST_TASA_VALORACION,
             HST_TASA_DESCUENTO,
             HST_SALDO_GARANTIA_REPO,
             HST_SALDO_POR_CUMPLIR,
             HST_COSTO_PROMEDIO_COMPRA,
             HST_SALDO_TRANSITO_ING,
             HST_SALDO_TRANSITO_RET,
             HST_SALDO_GARANTIA_DER,
             HST_VALOR_TM_GARREPO,
             HST_VALOR_TM_XCUMPLIR,
             HST_VALOR_TM_TRANING,
             HST_VALOR_TM_TRANRET,
             HST_VALOR_TM_GARDER,
             HST_VALOR_TM_CPR_X_CUMPLIR,
             HST_SALDO_CPR_X_CUMPLIR,
             DSP_ENA_MNEMONICO,
             FECHA_COMPRA,
             FECHA_EMISION,
             TASA_FACIAL
        FROM VW_HST_TITULOS
       WHERE HST_SALDO_DISPONIBLE <> 0
          OR HST_SALDO_GARANTIA <> 0
          OR HST_SALDO_EMBARGO <> 0
          OR HST_SALDO_GARANTIA_REPO <> 0
          OR HST_SALDO_GARANTIA_DER <> 0
       ORDER BY HST_CONSECUTIVO;
    C_DAT C_DATOS%ROWTYPE;

    CURSOR C_CLIENTE IS
      SELECT PER_NOMBRE
        FROM FILTRO_PERSONAS
       WHERE PER_NUM_IDEN = C_DAT.HST_CCC_CLI_PER_NUM_IDEN
         AND PER_TID_CODIGO = C_DAT.HST_CCC_CLI_PER_TID_CODIGO;
    C_CLI C_CLIENTE%ROWTYPE;

    CURSOR C_ESPECIES IS
      SELECT ENA_DESCRIPCION,
             DECODE(ENA_TIPO_ESPECIE, 'F', 'RF', 'V', 'ACC') ENA_TIPO_ESPECIE,
             ENA_TRE_MNEMONICO
        FROM ESPECIES_NACIONALES
       WHERE ENA_MNEMONICO = C_DAT.DSP_ENA_MNEMONICO;
    C_ESP C_ESPECIES%ROWTYPE;

    CURSOR C_LOCALIZACION IS
      SELECT LTI_DESCRIPCION,
             DECODE(TLO_TYPE, 'TFC', 'RF', 'TVC', 'ACC') TLO_TYPE,
             TLO_FECHA_VENCIMIENTO
        FROM TITULOS, LOCALIZACIONES_TITULOS
       WHERE TLO_LTI_MNEMONICO = LTI_MNEMONICO
         AND TLO_CODIGO = C_DAT.HST_TLO_CODIGO;
    C_LOC C_LOCALIZACION%ROWTYPE;

    CURSOR C_CUENTA_DCV IS
      SELECT CDC_CUENTA_DCV
        FROM CUENTAS_DCV
       WHERE CDC_CLI_PER_NUM_IDEN = C_DAT.HST_CCC_CLI_PER_NUM_IDEN
         AND CDC_CLI_PER_TID_CODIGO = C_DAT.HST_CCC_CLI_PER_TID_CODIGO;
    C_DCV C_CUENTA_DCV%ROWTYPE;

    CURSOR C_ISIN IS
      SELECT FUG_ISI_MNEMONICO, FUG_FECHA_VENCIMIENTO
        FROM FUNGIBLES, TITULOS
       WHERE FUG_ENA_MNEMONICO = C_DAT.DSP_ENA_MNEMONICO
         AND FUNGIBLES.FUG_ENA_MNEMONICO = TITULOS.TLO_ENA_MNEMONICO
         AND FUNGIBLES.FUG_FECHA_VENCIMIENTO =
             TITULOS.TLO_FECHA_VENCIMIENTO
         AND TLO_CODIGO = C_DAT.HST_TLO_CODIGO
         AND FUG_ESTADO = 'A';
    C_ISI C_ISIN%ROWTYPE;

    CURSOR C_ISIN2(ISIN2 VARCHAR2) IS
      SELECT FUG_FECHA_VENCIMIENTO
        FROM FUNGIBLES
       WHERE FUG_ISI_MNEMONICO = ISIN2
         AND FUG_ESTADO = 'A';
    C_ISI2 C_ISIN2%ROWTYPE;

    CURSOR C_COMERCIAL IS
      SELECT PER_NUM_IDEN, PER_NOMBRE
        FROM CUENTAS_CLIENTE_CORREDORES, FILTRO_PERSONAS
       WHERE CCC_PER_NUM_IDEN = PER_NUM_IDEN
         AND CCC_PER_TID_CODIGO = PER_TID_CODIGO
         AND CCC_CLI_PER_NUM_IDEN = C_DAT.HST_CCC_CLI_PER_NUM_IDEN
         AND CCC_CLI_PER_TID_CODIGO = C_DAT.HST_CCC_CLI_PER_TID_CODIGO
         AND CCC_NUMERO_CUENTA = C_DAT.HST_CCC_NUMERO_CUENTA;
    C_COM C_COMERCIAL%ROWTYPE;

    CURSOR C_MESA(NROID VARCHAR2) IS
      SELECT CPR_DESCRIPCION
        FROM PERSONAS_CENTROS_PRODUCCION, CENTROS_PRODUCCION
       WHERE PCP_CPR_MNEMONICO = CPR_MNEMONICO
         AND PCP_PER_NUM_IDEN = NROID
         AND PCP_PRINCIPAL = 'S'
         AND CPR_ESTADO = 'A';

    CURSOR C_FONDOS IS
      SELECT FON_CODIGO,
             FON_RAZON_SOCIAL,
             FON_TIPO_ADMINISTRACION,
             FON_CAPITAL_PRIVADO,
             FON_ESTADO
        FROM FONDOS
       WHERE FON_TIPO = 'A'
         AND FON_CODIGO = C_DAT.HST_CCC_CLI_PER_NUM_IDEN;
    C_FON C_FONDOS%ROWTYPE;

    CURSOR C_CUENTA_APT IS
      SELECT 'X'
        FROM CUENTAS_CLIENTE_CORREDORES
       WHERE CCC_CLI_PER_NUM_IDEN = C_DAT.HST_CCC_CLI_PER_NUM_IDEN
         AND CCC_CLI_PER_TID_CODIGO = C_DAT.HST_CCC_CLI_PER_TID_CODIGO
         AND CCC_NUMERO_CUENTA = C_DAT.HST_CCC_NUMERO_CUENTA
         AND CCC_CUENTA_APT = 'S';
    V_APT VARCHAR2(1);

    CURSOR ROPEFE IS
      SELECT LIC_FECHA_OPERACION,
             CCC_CLI_PER_TID_CODIGO,
             CCC_CLI_PER_NUM_IDEN,
             CCC_NUMERO_CUENTA,
             OVE_ENA_MNEMONICO,
             SUM(LIC_CANTIDAD_TOTAL_OPERACION) SUMA,
             PEB_PRECIO_BOLSA,
             SUM(LIC_CANTIDAD_TOTAL_OPERACION) * PEB_PRECIO_BOLSA TM
        FROM EMISORES,
             ESPECIES_NACIONALES,
             PERSONAS                    PER,
             CUENTAS_CLIENTE_CORREDORES,
             ORDENES_VENTA,
             LIQUIDACIONES_COMERCIAL     LIC,
             PERSONAS                    PER1,
             PERSONAS_CENTROS_PRODUCCION,
             CENTROS_PRODUCCION,
             PRECIOS_ESPECIES_BOLSA,
             GL_FECHAS                   GL
       WHERE ENA_EMI_MNEMONICO = EMI_MNEMONICO
         AND LIC_MNEMOTECNICO_TITULO = ENA_MNEMONICO
         AND CCC_PER_NUM_IDEN = PER.PER_NUM_IDEN
         AND CCC_PER_TID_CODIGO = PER.PER_TID_CODIGO
         AND OVE_CCC_CLI_PER_NUM_IDEN = CCC_CLI_PER_NUM_IDEN
         AND OVE_CCC_CLI_PER_TID_CODIGO = CCC_CLI_PER_TID_CODIGO
         AND OVE_CCC_NUMERO_CUENTA = CCC_NUMERO_CUENTA
         AND OVE_PER_NUM_IDEN = PER1.PER_NUM_IDEN
         AND OVE_PER_TID_CODIGO = PER1.PER_TID_CODIGO
         AND LIC_BOL_MNEMONICO = OVE_BOL_MNEMONICO
         AND LIC_OVE_COC_CTO_MNEMONICO = OVE_COC_CTO_MNEMONICO
         AND LIC_OVE_CONSECUTIVO = OVE_CONSECUTIVO
         AND LIC_TIPO_OPERACION = 'V'
         AND CCC_PER_NUM_IDEN = PCP_PER_NUM_IDEN
         AND CCC_PER_TID_CODIGO = PCP_PER_TID_CODIGO
         AND PCP_PRINCIPAL = 'S'
         AND PCP_CPR_MNEMONICO = CPR_MNEMONICO
         AND LIC_FECHA_OPERACION <= TRUNC(GL.FECHA_DESDE) --:CONTROL.FECHA_DESDE--'01-SEP-2020'
         AND TRUNC(LIC_FECHA_CUMPLIMIENTO) > TRUNC(C_DAT.HST_FECHA)
         AND CCC_CLI_PER_NUM_IDEN = C_DAT.HST_CCC_CLI_PER_NUM_IDEN
         AND CCC_CLI_PER_TID_CODIGO = C_DAT.HST_CCC_CLI_PER_TID_CODIGO
         AND CCC_NUMERO_CUENTA = C_DAT.HST_CCC_NUMERO_CUENTA
         AND OVE_ENA_MNEMONICO = C_DAT.DSP_ENA_MNEMONICO
         AND LIC_FECHA_VENCIMIENTO IS NULL
         AND TRUNC(PEB_FECHA) = TRUNC(GL.FECHA_DESDE) --TRUNC(:CONTROL.FECHA_DESDE)
         AND PEB_ENA_MNEMONICO = OVE_ENA_MNEMONICO
         AND (LIC_INDICADOR_SWAP != 'S' AND LIC_INDICADOR_CARRUSEL != 'S' AND
             LIC_TIPO_OFERTA NOT IN
             ('A', 'R', 'P', '1', '2', '3', '4', '5', '6'))
       GROUP BY LIC_FECHA_OPERACION,
                CCC_CLI_PER_TID_CODIGO,
                CCC_CLI_PER_NUM_IDEN,
                CCC_NUMERO_CUENTA,
                OVE_ENA_MNEMONICO,
                PEB_PRECIO_BOLSA;
    P_ROPEFE ROPEFE%ROWTYPE;

    DSP_NOMBRE_CLIENTE         VARCHAR2(80);
    DSP_ENA_DESCRIPCION        VARCHAR2(80);
    DSP_TASA_REF               VARCHAR2(5);
    DSP_NOMBRE_DEPOSITO        VARCHAR2(15);
    DSP_TIPO                   VARCHAR2(3);
    DSP_FECHA_VENCIMIENTO      DATE;
    DSP_CUENTA_DEPOSITO        VARCHAR2(35); --MB MIT DCV BANCO DE LA REPUBLICA -- NUMBER(9);
    DSP_CFC_FUG_ISI_MNEMONICO  VARCHAR2(12);
    DSP_ID_COMERCIAL           VARCHAR2(15);
    DSP_NOMBRE_COMERCIAL       VARCHAR2(62);
    DSP_MESA                   VARCHAR2(40);
    DSP_TIPO_CLIENTE           VARCHAR2(20);
    DSP_SALDO_COMPROMISO_RV    NUMBER;
    DSP_VALOR_TM_COMPROMISO_RV NUMBER;

    TIPO_CLIENTE VARCHAR2(20);

    TIP_ARCHIVO        UTL_FILE.FILE_TYPE;
    ARCHIVO_PORTAFOLIO VARCHAR2(100);
    LINEA              VARCHAR2(5000);

    P_FECHA  DATE;
    P_FECHA2 VARCHAR2(20);

  BEGIN
    SELECT TRUNC(SYSDATE - 1) INTO P_FECHA FROM DUAL;
    DELETE FROM GL_FECHAS;

    INSERT INTO GL_FECHAS VALUES (P_FECHA, P_FECHA);

    EXECUTE IMMEDIATE 'CREATE OR REPLACE FORCE VIEW "VW_HST_TITULOS" ("HST_CONSECUTIVO","HST_FECHA","HST_CCC_CLI_PER_NUM_IDEN"
                            , "HST_CCC_CLI_PER_TID_CODIGO", "HST_CCC_NUMERO_CUENTA", "HST_SALDO_DISPONIBLE"
                            , "HST_SALDO_GARANTIA", "HST_SALDO_EMBARGO", "HST_VALOR_TM_DISPONIBLE"
                            , "HST_VALOR_TM_GARANTIA", "HST_VALOR_TM_EMBARGO", "HST_CFC_FUG_ISI_MNEMONICO"
                            , "HST_CFC_FUG_MNEMONICO", "HST_CFC_CUENTA_DECEVAL", "HST_TLO_CODIGO"
                            , "HST_INDICADOR_VALORACION", "HST_TASA_VALORACION", "HST_TASA_DESCUENTO"
                            , "HST_SALDO_GARANTIA_REPO", "HST_SALDO_POR_CUMPLIR", "HST_COSTO_PROMEDIO_COMPRA"
                            , "HST_SALDO_TRANSITO_ING", "HST_SALDO_TRANSITO_RET", "HST_SALDO_GARANTIA_DER"
                            , "HST_VALOR_TM_GARREPO", "HST_VALOR_TM_XCUMPLIR", "HST_VALOR_TM_TRANING"
                            , "HST_VALOR_TM_TRANRET", "HST_VALOR_TM_GARDER", "HST_VALOR_TM_CPR_X_CUMPLIR"
                            , "HST_SALDO_CPR_X_CUMPLIR", "DSP_ENA_MNEMONICO","SEGMENTACION","PERFIL"
                            ,"FECHA_COMPRA","FECHA_EMISION","TASA_FACIAL")  AS
   SELECT /*+ INDEX (HISTORICOS_SALDOS_TITULOS HST_NUM_IDEN_TID_COD_FECH)*/ HST_CONSECUTIVO ,
          HST_FECHA ,
          HST_CCC_CLI_PER_NUM_IDEN ,
          HST_CCC_CLI_PER_TID_CODIGO ,
          HST_CCC_NUMERO_CUENTA ,
          DECODE(HST_CCC_CLI_PER_NUM_IDEN,''860079174'',--VAGTUS045900
           HST_SALDO_DISPONIBLE
            --+HST_SALDO_GARANTIA
            --+HST_SALDO_EMBARGO
            --+HST_SALDO_GARANTIA_REPO
            +HST_SALDO_POR_CUMPLIR
            +HST_SALDO_TRANSITO_ING
            +HST_SALDO_TRANSITO_RET
            --+HST_SALDO_GARANTIA_DER
            +HST_SALDO_CPR_X_CUMPLIR
            +HST_CFC_SALDO_TTV_COMPRA_FINAL
            +HST_CFC_SALDO_TTV_VENTA_FINAL
            +HST_CFC_SALDO_TTV_GARANT_REC
            +HST_CFC_SALDO_TTV_GARANT_COL ,HST_SALDO_DISPONIBLE) HST_SALDO_DISPONIBLE,
          HST_SALDO_GARANTIA ,
          HST_SALDO_EMBARGO ,
          DECODE(HST_CCC_CLI_PER_NUM_IDEN,''860079174'',--VAGTUS045900
          NVL((SELECT PEB_PRECIO_BOLSA*(HST_SALDO_DISPONIBLE
            --+HST_SALDO_GARANTIA
            --+HST_SALDO_EMBARGO
            --+HST_SALDO_GARANTIA_REPO
            +HST_SALDO_POR_CUMPLIR
            +HST_SALDO_TRANSITO_ING
            +HST_SALDO_TRANSITO_RET
            --+HST_SALDO_GARANTIA_DER
            +HST_SALDO_CPR_X_CUMPLIR
            +HST_CFC_SALDO_TTV_COMPRA_FINAL
            +HST_CFC_SALDO_TTV_VENTA_FINAL
            +HST_CFC_SALDO_TTV_GARANT_REC
            +HST_CFC_SALDO_TTV_GARANT_COL)
            FROM PRECIOS_ESPECIES_BOLSA A
            WHERE PEB_ENA_MNEMONICO = FUG_ENA_MNEMONICO
           AND TRUNC(PEB_FECHA) = TRUNC(GL.FECHA_DESDE)
           AND ROWNUM = 1),HST_VALOR_TM_DISPONIBLE),HST_VALOR_TM_DISPONIBLE) HST_VALOR_TM_DISPONIBLE,
          HST_VALOR_TM_GARANTIA ,
          HST_VALOR_TM_EMBARGO ,
          HST_CFC_FUG_ISI_MNEMONICO ,
          HST_CFC_FUG_MNEMONICO ,
          HST_CFC_CUENTA_DECEVAL ,
          HST_TLO_CODIGO ,
          HST_INDICADOR_VALORACION ,
          HST_TASA_VALORACION ,
          HST_TASA_DESCUENTO ,
          HST_SALDO_GARANTIA_REPO ,
          HST_SALDO_POR_CUMPLIR ,
          HST_COSTO_PROMEDIO_COMPRA ,
          HST_SALDO_TRANSITO_ING ,
          HST_SALDO_TRANSITO_RET ,
          HST_SALDO_GARANTIA_DER ,
          HST_VALOR_TM_GARREPO ,
          HST_VALOR_TM_XCUMPLIR ,
          HST_VALOR_TM_TRANING ,
          HST_VALOR_TM_TRANRET ,
          HST_VALOR_TM_GARDER ,
          HST_VALOR_TM_CPR_X_CUMPLIR ,
          HST_SALDO_CPR_X_CUMPLIR ,
          FUG_ENA_MNEMONICO DSP_ENA_MNEMONICO,
          BSC_DESCRIPCION SEGMENTACION,
          DECODE(CLI_PERFIL_RIESGO, 10,''CONSERVADOR'',20,''MODERADO'', 30,''ARRIESGADO'') PERFIL,
          NULL FECHA_COMPRA,
          FUG_FECHA_EMISION FECHA_EMISION,
          FUG_TASA_FACIAL TASA_FACIAL
     FROM HISTORICOS_SALDOS_TITULOS ,
          CUENTAS_FUNGIBLE_CLIENTE,
          FUNGIBLES,
          CLIENTES,
          BI_SEGMENTACION_CLIENTES,
          GL_FECHAS GL
    WHERE HST_CFC_CUENTA_DECEVAL  = CFC_CUENTA_DECEVAL
      AND HST_CFC_FUG_ISI_MNEMONICO = CFC_FUG_ISI_MNEMONICO
      AND HST_CFC_FUG_MNEMONICO     = CFC_FUG_MNEMONICO
      AND CFC_FUG_ISI_MNEMONICO     = FUG_ISI_MNEMONICO
      AND CFC_FUG_MNEMONICO         = FUG_MNEMONICO
      AND BSC_BCC_MNEMONICO         = CLI_BSC_BCC_MNEMONICO
      AND BSC_MNEMONICO             = CLI_BSC_MNEMONICO
      AND CLI_PER_NUM_IDEN          = HST_CCC_CLI_PER_NUM_IDEN
      AND CLI_PER_TID_CODIGO        = HST_CCC_CLI_PER_TID_CODIGO
     --AND CFC_CCC_CLI_PER_NUM_IDEN =  HST_CCC_CLI_PER_NUM_IDEN --VAGTUS046067
      --and CFC_CCC_CLI_PER_TID_CODIGO = HST_CCC_CLI_PER_TID_CODIGO --VAGTUS046067
      AND HST_FECHA                 >= TRUNC(GL.FECHA_DESDE)
      AND HST_FECHA                 < TRUNC(GL.FECHA_HASTA + 1)
          UNION ALL
   SELECT /*+ INDEX (HISTORICOS_SALDOS_TITULOS HST_NUM_IDEN_TID_COD_FECH)*/ HST_CONSECUTIVO ,
          HST_FECHA ,
          HST_CCC_CLI_PER_NUM_IDEN ,
          HST_CCC_CLI_PER_TID_CODIGO ,
          HST_CCC_NUMERO_CUENTA ,
           DECODE(HST_CCC_CLI_PER_NUM_IDEN,''860079174'',--VAGTUS045900
           HST_SALDO_DISPONIBLE
            --+HST_SALDO_GARANTIA
            --+HST_SALDO_EMBARGO
            --+HST_SALDO_GARANTIA_REPO
            +HST_SALDO_POR_CUMPLIR
            +HST_SALDO_TRANSITO_ING
            +HST_SALDO_TRANSITO_RET
            --+HST_SALDO_GARANTIA_DER
            +HST_SALDO_CPR_X_CUMPLIR
            +HST_CFC_SALDO_TTV_COMPRA_FINAL
            +HST_CFC_SALDO_TTV_VENTA_FINAL
            +HST_CFC_SALDO_TTV_GARANT_REC
            +HST_CFC_SALDO_TTV_GARANT_COL ,HST_SALDO_DISPONIBLE) HST_SALDO_DISPONIBLE,
          HST_SALDO_GARANTIA ,
          HST_SALDO_EMBARGO ,
            DECODE(HST_CCC_CLI_PER_NUM_IDEN,''860079174'',--VAGTUS045900
          NVL((SELECT PEB_PRECIO_BOLSA*(HST_SALDO_DISPONIBLE
            --+HST_SALDO_GARANTIA
            --+HST_SALDO_EMBARGO
            --+HST_SALDO_GARANTIA_REPO
            +HST_SALDO_POR_CUMPLIR
            +HST_SALDO_TRANSITO_ING
            +HST_SALDO_TRANSITO_RET
            --+HST_SALDO_GARANTIA_DER
            +HST_SALDO_CPR_X_CUMPLIR
            +HST_CFC_SALDO_TTV_COMPRA_FINAL
            +HST_CFC_SALDO_TTV_VENTA_FINAL
            +HST_CFC_SALDO_TTV_GARANT_REC
            +HST_CFC_SALDO_TTV_GARANT_COL)
            FROM PRECIOS_ESPECIES_BOLSA A
            WHERE PEB_ENA_MNEMONICO = TLO_ENA_MNEMONICO
           AND TRUNC(PEB_FECHA) = TRUNC(GL.FECHA_DESDE)
           AND ROWNUM = 1),HST_VALOR_TM_DISPONIBLE),HST_VALOR_TM_DISPONIBLE) HST_VALOR_TM_DISPONIBLE,
          HST_VALOR_TM_GARANTIA ,
          HST_VALOR_TM_EMBARGO ,
          HST_CFC_FUG_ISI_MNEMONICO ,
          HST_CFC_FUG_MNEMONICO ,
          HST_CFC_CUENTA_DECEVAL ,
          HST_TLO_CODIGO ,
          HST_INDICADOR_VALORACION ,
          HST_TASA_VALORACION ,
          HST_TASA_DESCUENTO ,
          HST_SALDO_GARANTIA_REPO ,
          HST_SALDO_POR_CUMPLIR ,
          HST_COSTO_PROMEDIO_COMPRA ,
          HST_SALDO_TRANSITO_ING ,
          HST_SALDO_TRANSITO_RET ,
          HST_SALDO_GARANTIA_DER ,
          HST_VALOR_TM_GARREPO ,
          HST_VALOR_TM_XCUMPLIR ,
          HST_VALOR_TM_TRANING ,
          HST_VALOR_TM_TRANRET ,
          HST_VALOR_TM_GARDER ,
          HST_VALOR_TM_CPR_X_CUMPLIR ,
          HST_SALDO_CPR_X_CUMPLIR ,
          TLO_ENA_MNEMONICO DSP_ENA_MNEMONICO,
          BSC_DESCRIPCION,
          DECODE(CLI_PERFIL_RIESGO, 10,''CONSERVADOR'',20,''MODERADO'', 30,''ARRIESGADO''),
          TLO_FECHA_OPERACION,
          TLO_FECHA_EMISION,
          TLO_TASA_FACIAL
     FROM HISTORICOS_SALDOS_TITULOS ,
          TITULOS,
          CLIENTES,
          BI_SEGMENTACION_CLIENTES,
          GL_FECHAS GL
    WHERE HST_TLO_CODIGO = TLO_CODIGO
      AND CLI_PER_NUM_IDEN          = HST_CCC_CLI_PER_NUM_IDEN
      AND CLI_PER_TID_CODIGO        = HST_CCC_CLI_PER_TID_CODIGO
      AND BSC_BCC_MNEMONICO         = CLI_BSC_BCC_MNEMONICO
      AND BSC_MNEMONICO             = CLI_BSC_MNEMONICO
      AND TLO_CCC_CLI_PER_NUM_IDEN  = HST_CCC_CLI_PER_NUM_IDEN
      AND TLO_CCC_CLI_PER_TID_CODIGO = HST_CCC_CLI_PER_TID_CODIGO
      AND HST_FECHA      >=  TRUNC(GL.FECHA_DESDE)
      AND HST_FECHA      < TRUNC(GL.FECHA_HASTA + 1)';

    COMMIT;

    SELECT TO_CHAR(P_FECHA, 'DDMMYYYY') INTO P_FECHA2 FROM DUAL;

    ARCHIVO_PORTAFOLIO := 'COPOVA_PORTAFOLIO_VALORACION_' || P_FECHA2 ||
                          '.csv';
    TIP_ARCHIVO        := UTL_FILE.FOPEN('REP_NOCTURNOS_A2',
                                         ARCHIVO_PORTAFOLIO,
                                         'W',
                                         10000);
    LINEA              := 'FECHA;NUM_IDEN;TIPO_IDEN;CUENTA;NOMBRE_CLIENTE;SALDO_DISPONIBLE;VALOR_TM_DISPONIBLE;SALDO_GARANTIA;VALOR_TM_GARANTIA;SALDO_GARANTIA_REPO;VALOR_TM_GARREPO;SALDO_EMBARGO;VALOR_TM_EMBARGO;SALDO_GARANTIA_DER;VALOR_TM_GARDER;NOMINAL_COMPR_V_RV;TM_COMPR_V_RV;ISIN;FUNGIBLE;CTA_INVERSIONISTA;TITULO;IND_VALORACION;TASA;TASA_DESCUENTO;MNEMO;ESPECIE;DEPOSITO;MERCADO;NID_COMERCIAL;NOMBRE_COMERCIAL;MESA_COMERCIAL;TASA_REF;FECHA_VENC;TIPO_CLIENTE;FECHA_COMPRA;FECHA_EMISION;TASA_FACIAL;';

    UTL_FILE.PUT_LINE(TIP_ARCHIVO, LINEA);

    TIPO_CLIENTE     := ' ';
    DSP_TIPO_CLIENTE := ' ';

    OPEN C_DATOS;
    FETCH C_DATOS
      INTO C_DAT;
    WHILE C_DATOS%FOUND LOOP

      OPEN C_CLIENTE;
      FETCH C_CLIENTE
        INTO C_CLI;
      CLOSE C_CLIENTE;
      C_CLI.PER_NOMBRE   := NVL(C_CLI.PER_NOMBRE, ' ');
      DSP_NOMBRE_CLIENTE := C_CLI.PER_NOMBRE;

      OPEN C_ESPECIES;
      FETCH C_ESPECIES
        INTO C_ESP;
      CLOSE C_ESPECIES;
      C_ESP.ENA_DESCRIPCION := NVL(C_ESP.ENA_DESCRIPCION, ' ');
      DSP_ENA_DESCRIPCION   := C_ESP.ENA_DESCRIPCION;
      DSP_TASA_REF          := C_ESP.ENA_TRE_MNEMONICO;

      OPEN C_LOCALIZACION;
      FETCH C_LOCALIZACION
        INTO C_LOC;
      IF C_LOCALIZACION%FOUND THEN
        DSP_NOMBRE_DEPOSITO   := C_LOC.LTI_DESCRIPCION;
        DSP_TIPO              := C_LOC.TLO_TYPE;
        DSP_FECHA_VENCIMIENTO := C_LOC.TLO_FECHA_VENCIMIENTO;
        IF C_LOC.LTI_DESCRIPCION = 'DCV' THEN
          OPEN C_CUENTA_DCV;
          FETCH C_CUENTA_DCV
            INTO DSP_CUENTA_DEPOSITO;
          CLOSE C_CUENTA_DCV;
        ELSIF C_LOC.LTI_DESCRIPCION = 'DECEVAL' THEN
          DSP_CUENTA_DEPOSITO := C_DAT.HST_CFC_CUENTA_DECEVAL;
        END IF;
      ELSE
        DSP_TIPO := C_ESP.ENA_TIPO_ESPECIE;
      END IF;
      CLOSE C_LOCALIZACION;

      IF C_DAT.HST_CFC_CUENTA_DECEVAL IS NOT NULL THEN
        DSP_NOMBRE_DEPOSITO := 'DECEVAL';
        DSP_CUENTA_DEPOSITO := C_DAT.HST_CFC_CUENTA_DECEVAL;
      END IF;

      IF DSP_NOMBRE_DEPOSITO = 'DECEVAL' THEN
        DSP_CFC_FUG_ISI_MNEMONICO := C_DAT.HST_CFC_FUG_ISI_MNEMONICO;
        OPEN C_ISIN2(C_DAT.HST_CFC_FUG_ISI_MNEMONICO);
        FETCH C_ISIN2
          INTO C_ISI2;
        CLOSE C_ISIN2;
        DSP_FECHA_VENCIMIENTO := C_ISI2.FUG_FECHA_VENCIMIENTO;
      ELSE
        OPEN C_ISIN;
        FETCH C_ISIN
          INTO C_ISI;
        CLOSE C_ISIN;

        DSP_CFC_FUG_ISI_MNEMONICO := NVL(C_ISI.FUG_ISI_MNEMONICO, ' ');
      END IF;

      OPEN C_COMERCIAL;
      FETCH C_COMERCIAL
        INTO C_COM;
      CLOSE C_COMERCIAL;
      DSP_ID_COMERCIAL     := C_COM.PER_NUM_IDEN;
      DSP_NOMBRE_COMERCIAL := C_COM.PER_NOMBRE;

      OPEN C_MESA(C_COM.PER_NUM_IDEN);
      FETCH C_MESA
        INTO DSP_MESA;
      CLOSE C_MESA;

      OPEN ROPEFE;
      FETCH ROPEFE
        INTO P_ROPEFE;
      IF ROPEFE%FOUND THEN
        DSP_SALDO_COMPROMISO_RV    := P_ROPEFE.SUMA;
        DSP_VALOR_TM_COMPROMISO_RV := P_ROPEFE.TM;
      ELSE
        DSP_SALDO_COMPROMISO_RV    := 0;
        DSP_VALOR_TM_COMPROMISO_RV := .00;
      END IF;
      CLOSE ROPEFE;

      OPEN C_FONDOS;
      FETCH C_FONDOS
        INTO C_FON;
      IF C_FONDOS%FOUND THEN
        IF NVL(C_FON.FON_TIPO_ADMINISTRACION, ' ') = 'A' THEN
          IF NVL(C_FON.FON_ESTADO, ' ') = 'A' THEN
            V_APT := '';
            OPEN C_CUENTA_APT;
            FETCH C_CUENTA_APT
              INTO V_APT;
            CLOSE C_CUENTA_APT;

            IF NVL(V_APT, 'Y') = 'X' THEN
              TIPO_CLIENTE := 'APT';
            ELSE
              TIPO_CLIENTE := 'CLIENTE';
            END IF;
          ELSE
            TIPO_CLIENTE := 'CLIENTE';
          END IF;
        ELSIF NVL(C_FON.FON_TIPO_ADMINISTRACION, ' ') = 'C' THEN
          TIPO_CLIENTE := 'POSICION PROPIA';
        ELSIF NVL(C_FON.FON_TIPO_ADMINISTRACION, ' ') = 'R' THEN
          TIPO_CLIENTE := 'RECURSOS PROPIOS';
        ELSIF NVL(C_FON.FON_TIPO_ADMINISTRACION, ' ') = 'F' THEN
          TIPO_CLIENTE := 'FONDO INVERSION';
        ELSE
          V_APT := '';
          OPEN C_CUENTA_APT;
          FETCH C_CUENTA_APT
            INTO V_APT;
          CLOSE C_CUENTA_APT;

          IF NVL(V_APT, 'Y') = 'X' THEN
            TIPO_CLIENTE := 'APT';
          ELSE
            TIPO_CLIENTE := 'CLIENTE';
          END IF;
        END IF;
      ELSE
        TIPO_CLIENTE := 'CLIENTE';
      END IF;
      CLOSE C_FONDOS;

      DSP_TIPO_CLIENTE := TIPO_CLIENTE;

      LINEA := '';
      LINEA := C_DAT.HST_FECHA || ';' || C_DAT.HST_CCC_CLI_PER_NUM_IDEN || ';' ||
               C_DAT.HST_CCC_CLI_PER_TID_CODIGO || ';' ||
               C_DAT.HST_CCC_NUMERO_CUENTA || ';' || DSP_NOMBRE_CLIENTE || ';' ||
               REPLACE(C_DAT.HST_SALDO_DISPONIBLE, ',', '.') || ';' ||
               REPLACE(C_DAT.HST_VALOR_TM_DISPONIBLE, ',', '.') || ';' ||
               REPLACE(C_DAT.HST_SALDO_GARANTIA, ',', '.') || ';' ||
               REPLACE(C_DAT.HST_VALOR_TM_GARANTIA, ',', '.') || ';' ||
               REPLACE(C_DAT.HST_SALDO_GARANTIA_REPO, ',', '.') || ';' ||
               REPLACE(C_DAT.HST_VALOR_TM_GARREPO, ',', '.') || ';' ||
               REPLACE(C_DAT.HST_SALDO_EMBARGO, ',', '.') || ';' ||
               REPLACE(C_DAT.HST_VALOR_TM_EMBARGO, ',', '.') || ';' ||
               REPLACE(C_DAT.HST_SALDO_GARANTIA_DER, ',', '.') || ';' ||
               REPLACE(C_DAT.HST_VALOR_TM_GARDER, ',', '.') || ';' ||
               DSP_SALDO_COMPROMISO_RV || ';' || DSP_VALOR_TM_COMPROMISO_RV || ';' ||
               DSP_CFC_FUG_ISI_MNEMONICO --C_DAT.HST_CFC_FUG_ISI_MNEMONICO
               || ';' || C_DAT.HST_CFC_FUG_MNEMONICO || ';' ||
               DSP_CUENTA_DEPOSITO || ';' || C_DAT.HST_TLO_CODIGO || ';' ||
               C_DAT.HST_INDICADOR_VALORACION || ';' ||
               REPLACE(C_DAT.HST_TASA_VALORACION, ',', '.') || ';' ||
               REPLACE(C_DAT.HST_TASA_DESCUENTO, ',', '.') || ';' ||
               C_DAT.DSP_ENA_MNEMONICO || ';' || DSP_ENA_DESCRIPCION || ';' ||
               DSP_NOMBRE_DEPOSITO || ';' || DSP_TIPO || ';' ||
               DSP_ID_COMERCIAL || ';' || DSP_NOMBRE_COMERCIAL || ';' ||
               DSP_MESA || ';' || REPLACE(DSP_TASA_REF, ',', '.') || ';' ||
               TO_CHAR(DSP_FECHA_VENCIMIENTO, 'DD/MM/YYYY') || ';' ||
               DSP_TIPO_CLIENTE || ';' ||
               TO_CHAR(C_DAT.FECHA_COMPRA, 'DD/MM/YYYY') || ';' ||
               TO_CHAR(C_DAT.FECHA_EMISION, 'DD/MM/YYYY') || ';' ||
               REPLACE(C_DAT.TASA_FACIAL, ',', '.');

      UTL_FILE.PUT_LINE(TIP_ARCHIVO, LINEA);

      FETCH C_DATOS
        INTO C_DAT;
    END LOOP;
    CLOSE C_DATOS;

    UTL_FILE.FCLOSE(TIP_ARCHIVO);

  END PORTAFOLIO_VALORACION_A2;
  -----------------------------VAGTUD755-33-------------------------------------------------

  PROCEDURE OPERACIONES_ESPECIALES AS

    CURSOR C_DATOS(P_FECHA_DESDE DATE, P_FECHA DATE) IS
      SELECT 'PLAZO LIC' ROTULO,
             PER_NUM_IDEN NUM,
             PER_TID_CODIGO TID,
             PER_NOMBRE NOMBRE,
             MCC_CCC_NUMERO_CUENTA CUENTA,
             MCC_LIC_NUMERO_OPERACION OPERACION,
             MCC_LIC_NUMERO_FRACCION FRACCION,
             MCC_LIC_TIPO_OPERACION TIPO_OPERACION,
             MCC_LIC_BOL_MNEMONICO BOLSA,
             LIC_COD_CMSNSTA_CMPRDOR COMISIONISTA_COMPRADOR,
             LIC_COD_CMSNSTA_VNDDOR COMISIONISTA_VENDEDOR,
             LIC_FECHA_CUMPLIMIENTO FECHA_CUMPLIMIENTO,
             LIC_SERVICIO_BOLSA_FIJO SERVICIO_BOLSA_FIJO,
             LIC_SERVICIO_BOLSA_VOLUMEN SERVICIO_BOLSA_VOLUMEN,
             LIC_VALOR_COMISION COMISION,
             LIC_TIPO_OFERTA TIPO_OFERTA,
             MONTO_A_PLAZO(PER_NUM_IDEN,
                           PER_TID_CODIGO,
                           MCC_LIC_BOL_MNEMONICO,
                           MCC_LIC_NUMERO_OPERACION,
                           MCC_LIC_NUMERO_FRACCION,
                           MCC_LIC_TIPO_OPERACION) MONTO_NETO,
             SUM(MCC_MONTO_A_PLAZO) MONTO
        FROM MOVIMIENTOS_CUENTA_CORREDORES,
             FILTRO_PERSONAS,
             LIQUIDACIONES_COMERCIAL
       WHERE PER_NUM_IDEN = MCC_CCC_CLI_PER_NUM_IDEN
         AND PER_TID_CODIGO = MCC_CCC_CLI_PER_TID_CODIGO
         AND LIC_BOL_MNEMONICO = MCC_LIC_BOL_MNEMONICO
         AND LIC_NUMERO_OPERACION = MCC_LIC_NUMERO_OPERACION
         AND LIC_NUMERO_FRACCION = MCC_LIC_NUMERO_FRACCION
         AND LIC_TIPO_OPERACION = MCC_LIC_TIPO_OPERACION
         AND MCC_MONTO_A_PLAZO <> 0
         AND MCC_FECHA >= P_FECHA_DESDE
         AND MCC_FECHA <= P_FECHA + 1 --:CONTROL.FECHA_HASTA + 1
         AND MCC_LIC_NUMERO_OPERACION IS NOT NULL
         AND LIC_FECHA_CUMPLIMIENTO > P_FECHA
       GROUP BY PER_NUM_IDEN,
                PER_TID_CODIGO,
                PER_NOMBRE,
                MCC_CCC_NUMERO_CUENTA,
                MCC_LIC_NUMERO_OPERACION,
                MCC_LIC_NUMERO_FRACCION,
                MCC_LIC_TIPO_OPERACION,
                MCC_LIC_BOL_MNEMONICO,
                LIC_COD_CMSNSTA_CMPRDOR,
                LIC_COD_CMSNSTA_VNDDOR,
                LIC_FECHA_CUMPLIMIENTO,
                LIC_TIPO_OFERTA,
                LIC_SERVICIO_BOLSA_FIJO,
                LIC_SERVICIO_BOLSA_VOLUMEN,
                LIC_VALOR_COMISION,
                MONTO_A_PLAZO(PER_NUM_IDEN,
                              PER_TID_CODIGO,
                              MCC_LIC_BOL_MNEMONICO,
                              MCC_LIC_NUMERO_OPERACION,
                              MCC_LIC_NUMERO_FRACCION,
                              MCC_LIC_TIPO_OPERACION)
      HAVING SUM(MCC_MONTO_A_PLAZO) != 0
      UNION
      SELECT 'PLAZO LOP' ROTULO,
             PER_NUM_IDEN NUM,
             PER_TID_CODIGO TID,
             PER_NOMBRE NOMBRE,
             MCC_CCC_NUMERO_CUENTA CUENTA,
             MCC_LOP_NUMERO_OPERACION OPERACION,
             MCC_LOP_NUMERO_FRACCION FRACCION,
             MCC_LOP_PUNTA TIPO_OPERACION,
             MCC_LOP_BOL_MNEMONICO BOLSA,
             LOP_COD_COMISIONISTA_COMPRA COMISIONISTA_COMPRADOR,
             LOP_COD_COMISIONISTA_VENTA COMISIONISTA_VENDEDOR,
             LOP_FECHA_CUMPLIMIENTO FECHA_CUMPLIMIENTO,
             LOP_SERVICIO_BOLSA_FIJO SERVICIO_BOLSA_FIJO,
             LOP_SERVICIO_BOLSA_VARIABLE SERVICIO_BOLSA_VOLUMEN,
             LOP_VALOR_COMISION COMISION,
             NULL TIPO_OFERTA,
             NULL MONTO_NETO,
             SUM(MCC_MONTO_A_PLAZO) MONTO
        FROM MOVIMIENTOS_CUENTA_CORREDORES,
             OPCF_LIQUIDACIONES,
             FILTRO_PERSONAS
       WHERE PER_NUM_IDEN = MCC_CCC_CLI_PER_NUM_IDEN
         AND PER_TID_CODIGO = MCC_CCC_CLI_PER_TID_CODIGO
         AND LOP_NUMERO_OPERACION = MCC_LOP_NUMERO_OPERACION
         AND LOP_NUMERO_FRACCION = MCC_LOP_NUMERO_FRACCION
         AND LOP_PUNTA = MCC_LOP_PUNTA
         AND LOP_BOL_MNEMONICO = MCC_LOP_BOL_MNEMONICO
         AND MCC_MONTO_A_PLAZO <> 0
         AND MCC_FECHA >= P_FECHA_DESDE
         AND MCC_FECHA <= P_FECHA + 1 --:CONTROL.FECHA_HASTA + 1
         AND MCC_LOP_NUMERO_OPERACION IS NOT NULL
         AND LOP_FECHA_CUMPLIMIENTO > P_FECHA
       GROUP BY PER_NUM_IDEN,
                PER_TID_CODIGO,
                PER_NOMBRE,
                MCC_CCC_NUMERO_CUENTA,
                MCC_LOP_NUMERO_OPERACION,
                MCC_LOP_NUMERO_FRACCION,
                MCC_LOP_PUNTA,
                MCC_LOP_BOL_MNEMONICO,
                LOP_COD_COMISIONISTA_COMPRA,
                LOP_COD_COMISIONISTA_VENTA,
                LOP_FECHA_CUMPLIMIENTO,
                LOP_SERVICIO_BOLSA_FIJO,
                LOP_SERVICIO_BOLSA_VARIABLE,
                LOP_VALOR_COMISION
      HAVING SUM(MCC_MONTO_A_PLAZO) != 0
      UNION
      SELECT 'CONTADO LIQ' ROTULO,
             PER_NUM_IDEN NUM,
             PER_TID_CODIGO TID,
             PER_NOMBRE NOMBRE,
             MCC_CCC_NUMERO_CUENTA CUENTA,
             LIC_NUMERO_OPERACION OPERACION,
             LIC_NUMERO_FRACCION FRACCION,
             LIC_TIPO_OPERACION TIPO_OPERACION,
             LIC_BOL_MNEMONICO BOLSA,
             LIC_COD_CMSNSTA_CMPRDOR COMISIONISTA_COMPRADOR,
             LIC_COD_CMSNSTA_VNDDOR COMISIONISTA_VENDEDOR,
             LIC_FECHA_CUMPLIMIENTO FECHA_CUMPLIMIENTO,
             LIC_SERVICIO_BOLSA_FIJO SERVICIO_BOLSA_FIJO,
             LIC_SERVICIO_BOLSA_VOLUMEN SERVICIO_BOLSA_VOLUMEN,
             LIC_VALOR_COMISION COMISION,
             LIC_TIPO_OFERTA TIPO_OFERTA,
             MONTO_A_PLAZO(PER_NUM_IDEN,
                           PER_TID_CODIGO,
                           MCC_LIC_BOL_MNEMONICO,
                           MCC_LIC_NUMERO_OPERACION,
                           MCC_LIC_NUMERO_FRACCION,
                           MCC_LIC_TIPO_OPERACION) MONTO_NETO,
             SUM(MCC_MONTO_A_CONTADO) MONTO
        FROM MOVIMIENTOS_CUENTA_CORREDORES,
             LIQUIDACIONES_COMERCIAL,
             FILTRO_PERSONAS
       WHERE PER_NUM_IDEN = MCC_CCC_CLI_PER_NUM_IDEN
         AND PER_TID_CODIGO = MCC_CCC_CLI_PER_TID_CODIGO
         AND LIC_BOL_MNEMONICO = MCC_LIC_BOL_MNEMONICO
         AND LIC_NUMERO_OPERACION = MCC_LIC_NUMERO_OPERACION
         AND LIC_NUMERO_FRACCION = MCC_LIC_NUMERO_FRACCION
         AND LIC_TIPO_OPERACION = MCC_LIC_TIPO_OPERACION
         AND MCC_MONTO_A_CONTADO <> 0
         AND MCC_FECHA >= P_FECHA_DESDE
         AND MCC_FECHA <= P_FECHA + 1 --:CONTROL.FECHA_HASTA + 1
         AND LIC_FECHA_CUMPLIMIENTO > P_FECHA
       GROUP BY PER_NUM_IDEN,
                PER_TID_CODIGO,
                PER_NOMBRE,
                MCC_CCC_NUMERO_CUENTA,
                LIC_NUMERO_OPERACION,
                LIC_NUMERO_FRACCION,
                LIC_TIPO_OPERACION,
                LIC_BOL_MNEMONICO,
                LIC_COD_CMSNSTA_CMPRDOR,
                LIC_COD_CMSNSTA_VNDDOR,
                LIC_FECHA_CUMPLIMIENTO,
                LIC_TIPO_OFERTA,
                LIC_SERVICIO_BOLSA_FIJO,
                LIC_SERVICIO_BOLSA_VOLUMEN,
                LIC_VALOR_COMISION,
                MONTO_A_PLAZO(PER_NUM_IDEN,
                              PER_TID_CODIGO,
                              MCC_LIC_BOL_MNEMONICO,
                              MCC_LIC_NUMERO_OPERACION,
                              MCC_LIC_NUMERO_FRACCION,
                              MCC_LIC_TIPO_OPERACION)
      HAVING SUM(MCC_MONTO_A_CONTADO) != 0;

    CURSOR C_RTEFUENTE(P_OPERACION      NUMBER,
                       P_FRACCION       NUMBER,
                       P_TIPO_OPERACION VARCHAR2,
                       P_BOLSA          VARCHAR2) IS
      SELECT MCC_MONTO_A_PLAZO, MCC_MONTO_A_CONTADO
        FROM MOVIMIENTOS_CUENTA_CORREDORES
       WHERE MCC_LIC_NUMERO_OPERACION = P_OPERACION
         AND MCC_LIC_NUMERO_FRACCION = P_FRACCION
         AND MCC_LIC_TIPO_OPERACION = P_TIPO_OPERACION
         AND MCC_LIC_BOL_MNEMONICO = P_BOLSA
         AND MCC_TMC_MNEMONICO = 'RFV'
         AND MCC_MCC_CONSECUTIVO IS NULL;

    CURSOR C_IVA(P_OPERACION      NUMBER,
                 P_FRACCION       NUMBER,
                 P_TIPO_OPERACION VARCHAR2,
                 P_BOLSA          VARCHAR2) IS
      SELECT MCC_MONTO_A_PLAZO, MCC_MONTO_A_CONTADO
        FROM MOVIMIENTOS_CUENTA_CORREDORES
       WHERE MCC_LIC_NUMERO_OPERACION = P_OPERACION
         AND MCC_LIC_NUMERO_FRACCION = P_FRACCION
         AND MCC_LIC_TIPO_OPERACION = P_TIPO_OPERACION
         AND MCC_LIC_BOL_MNEMONICO = P_BOLSA
         AND MCC_TMC_MNEMONICO IN ('IVAV', 'IVAC')
         AND MCC_MCC_CONSECUTIVO IS NULL;

    FECHA_INI          DATE;
    FECHA_FIN          DATE;
    LINEA              VARCHAR2(1800);
    RTEFUENTE          NUMBER;
    RTEFUENTE_P        NUMBER;
    RTEFUENTE_C        NUMBER;
    IVA                NUMBER;
    IVA_P              NUMBER;
    IVA_C              NUMBER;
    nHash              NUMBER;
    TIP_ARCHIVO        UTL_FILE.FILE_TYPE;
    ARCHIVO_PORTAFOLIO VARCHAR2(100);
    mi_nombre_archivo  VARCHAR2(100);
    V_TIPO_OFERTA      VARCHAR2(50);
    P_FECHA2           VARCHAR2(20);

  BEGIN

    SELECT TO_CHAR(SYSDATE - 1, 'RRRRMMDD') INTO P_FECHA2 FROM DUAL;

    ARCHIVO_PORTAFOLIO := 'OPERACIONES_ESPECIALES_' || P_FECHA2 || '.txt';
    TIP_ARCHIVO        := UTL_FILE.FOPEN('REP_NOCTURNOS_A2',
                                         ARCHIVO_PORTAFOLIO,
                                         'W',
                                         10000);
    LINEA              := 'TIPO; IDENTIFICACION; TI; NOMBRE; CUENTA; OPERACION;' ||
                          'FRACCION; TIPO OPERACION; BOLSA; COMISIONISTA COMPRADOR; ' ||
                          'COMISIONISTA VENDEDOR; FECHA CUMPLIMIENTO OPERACION; ' ||
                          'TIPO OFERTA; MONTO NETO; MONTO;SERVICIO BOLSA FIJO; SERVICIO BOLSA VARIABLE; COMISION; RETEFUENTE; IVA';
    UTL_FILE.PUT_LINE(TIP_ARCHIVO, LINEA);

    SELECT TO_CHAR(TRUNC(P_TOOLS.CF_DIA_HABIL_ANTERIOR(SYSDATE)),
                   'DD/MM/YYYY',
                   'nls_date_language = ''LATIN AMERICAN SPANISH''')
      INTO FECHA_FIN
      FROM DUAL;

    FECHA_INI := '01/11/2013';

    FOR R_DATOS IN C_DATOS(FECHA_INI, FECHA_FIN) LOOP
      RTEFUENTE   := 0;
      RTEFUENTE_P := 0;
      RTEFUENTE_C := 0;
      OPEN C_RTEFUENTE(R_DATOS.OPERACION,
                       R_DATOS.FRACCION,
                       R_DATOS.TIPO_OPERACION,
                       R_DATOS.BOLSA);
      FETCH C_RTEFUENTE
        INTO RTEFUENTE_P, RTEFUENTE_C;
      CLOSE C_RTEFUENTE;
      IF RTEFUENTE_P != 0 THEN
        RTEFUENTE := RTEFUENTE_P;
      ELSIF RTEFUENTE_C != 0 THEN
        RTEFUENTE := RTEFUENTE_C;
      END IF;
      IVA   := 0;
      IVA_P := 0;
      IVA_C := 0;
      OPEN C_IVA(R_DATOS.OPERACION,
                 R_DATOS.FRACCION,
                 R_DATOS.TIPO_OPERACION,
                 R_DATOS.BOLSA);
      FETCH C_IVA
        INTO IVA_P, IVA_C;
      CLOSE C_IVA;
      IF IVA_P != 0 THEN
        IVA := IVA_P;
      ELSIF IVA_C != 0 THEN
        IVA := IVA_C;
      END IF;

      LINEA := R_DATOS.ROTULO || ';' || R_DATOS.NUM || ';' || R_DATOS.TID || ';' ||
               R_DATOS.NOMBRE || ';' || R_DATOS.CUENTA || ';' ||
               R_DATOS.OPERACION || ';' || R_DATOS.FRACCION || ';' ||
               R_DATOS.TIPO_OPERACION || ';' || R_DATOS.BOLSA || ';' ||
               R_DATOS.COMISIONISTA_COMPRADOR || ';' ||
               R_DATOS.COMISIONISTA_VENDEDOR || ';' ||
               R_DATOS.FECHA_CUMPLIMIENTO || ';' || R_DATOS.TIPO_OFERTA || ';' ||
               R_DATOS.MONTO_NETO || ';' || R_DATOS.MONTO || ';' ||
               R_DATOS.SERVICIO_BOLSA_FIJO || ';' ||
               R_DATOS.SERVICIO_BOLSA_VOLUMEN || ';' || R_DATOS.COMISION || ';' ||
               NVL(RTEFUENTE, 0) || ';' || NVL(IVA, 0) || ';';
      UTL_FILE.PUT_LINE(TIP_ARCHIVO, LINEA);
    END LOOP;

    UTL_FILE.FCLOSE(TIP_ARCHIVO);
  EXCEPTION
    WHEN OTHERS THEN
      --P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PRC_SALDOS_DISPONIBLES_LVA',SUBSTR(SQLERRM,1,80),'procesosnocturnos@corredores.com');
      NULL;
  END OPERACIONES_ESPECIALES;

  PROCEDURE RMOVBA_S3(P_USERID IN VARCHAR2) AS
    VAR           VARCHAR2(2000);
    V_FECHA       VARCHAR2(20);
    V_FECHA2      VARCHAR2(20);
    V_FECHAN      VARCHAR2(20);
    V_CONDICION   VARCHAR2(5000);
    V_FECHAS      VARCHAR2(1000);
    V_FECHAS1     VARCHAR2(1000);
    V_FECHA_INI   VARCHAR2(1000);
    V_MOVIMIENTO  VARCHAR2(5000) := ' ';
    V_MOVIMIENTO1 VARCHAR2(5000) := ' ';
    P_PARAMETROS  VARCHAR2(2000);

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN
    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_RMOVBA',
                                                      'INI');
    --V_CONDICION := 'CBA.CBA_NEG_CONSECUTIVO%20LIKE%20%27%25%27%20AND%20CBA.CBA_ESTADO%20 =%20%27A%27%20AND';

    SELECT TO_CHAR(TRUNC((SYSDATE - 1)),
                   'DD-MON-YYYY',
                   'nls_date_language = ''LATIN AMERICAN SPANISH'''),
           TO_CHAR(TRUNC((SYSDATE)),
                   'DD-MON-YYYY',
                   'nls_date_language = ''LATIN AMERICAN SPANISH''')
      INTO V_FECHA, V_FECHA2
      FROM DUAL;

    SELECT TO_CHAR(TRUNC((SYSDATE - 1)), 'DDMMYYYY')
      INTO V_FECHAN
      FROM DUAL;
    --P_USERID := 'prod/pagil2018@coepru11g'   ;

    P_TOOLS.PR_CREAR_REPORTE(P_REPORT     => 'RMOVBA',
                             P_USERID     => P_USERID,
                             P_FORMATO    => 'PDF',
                             P_PARAMETROS => '+P_CONDICION=CBA.CBA_NEG_CONSECUTIVO%20LIKE%20%272%27%20AND%20CBA.CBA_ESTADO%20=%20%27A%27%20AND%20+P_MOVIMIENTO=%20AND%20MCB.MCB_TMB_MNEMONICO%20IN%20(%27IVA%27,%27IVAC%27,%27RIVA%27,%27RIVAC%27)%20+P_MOVIMIENTO1=%20AND%20PCB.PCB_TMB_MNEMONICO%20IN%20(%27IVA%27,%27IVAC%27,%27RIVA%27,%27RIVAC%27)%20+P_FECHAS=%20MCB.MCB_FECHA%20%3E=%20%27' ||
                                             V_FECHA ||
                                             '%27%20AND%20MCB.MCB_FECHA%20%3C%20%27' ||
                                             V_FECHA2 ||
                                             '%27%20+P_FECHAS1=%20PCB.PCB_FECHA%20%3E=%20%27' ||
                                             V_FECHA ||
                                             '%27%20AND%20PCB.PCB_FECHA%20%3C%20%27' ||
                                             V_FECHA2 ||
                                             '%27%20+P_FECHA_INI=%27' ||
                                             V_FECHA || '%27',
                             P_ARCHIVO    => '/apps/rep_nocturnos_a2/RMOVBA_S3_' ||
                                             V_FECHAN);

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_RMOVBA',
                                                      'FIN');

  EXCEPTION
    WHEN OTHERS THEN
      --  P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PR_REPORTE_RMOVBA',SUBSTR(SQLERRM,1,80),'procesosnocturnos@corredores.com');
      NULL;
  END RMOVBA_S3;

  PROCEDURE CONCILIACION_NEGOCIOS AS

    -- Selecciona los datos adicionales de las cuentas bancarias
    CURSOR C_DATOS IS
      SELECT CBA_BAN_CODIGO,
             (11 || CBA_CODIGO_CTA_MAYOR || CBA_CODIGO_SUBCUENTA ||
             CBA_CODIGO_CONTABLE) CTA_CONTAB,
             CBA_NUMERO_CUENTA,
             DECODE(CBA_TCB_MNEMONICO, 'CAH', 'AHORROS', 'CCO', 'CORRIENTE') TIPO_CTA,
             BAN_NOMBRE,
             NEG_DESCRIPCION
        FROM CUENTAS_BANCARIAS_CORREDORES, BANCOS, NEGOCIOS
       WHERE CBA_BAN_CODIGO = BAN_CODIGO
         AND CBA_NEG_CONSECUTIVO = NEG_CONSECUTIVO
         AND CBA_ESTADO = 'A'
         AND CBA_NEG_CONSECUTIVO = 2;
    C_DAT C_DATOS%ROWTYPE;

    --  Selecciona el Saldo de Extracto de la cuenta bancaria
    CURSOR C_SALDO_EXTRACTOS(P_FECHA_INI DATE, P_FECHA_FIN DATE) IS
      SELECT SCC_SALDO_EN_BANCOS
        FROM SALDOS_CTA_BANCARIA_CORREDORES
       WHERE SCC_CBA_BAN_CODIGO = C_DAT.CBA_BAN_CODIGO
         AND SCC_CBA_NUMERO_CUENTA = C_DAT.CBA_NUMERO_CUENTA
         AND SCC_FECHA >= P_FECHA_INI + 1
         AND SCC_FECHA < P_FECHA_FIN + 2;
    C_SDOEXT C_SALDO_EXTRACTOS%ROWTYPE;

    --  Selecciona el Saldo de Libros de la cuenta bancaria
    CURSOR C_SALDO(P_FECHA DATE) IS
      SELECT SCC_SALDO_MVTOS_CONCILIADOS + SCC_SALDO_MVTOS_NO_CONCILIADOS SCC_SALDO,
             SCC_FECHA
        FROM SALDOS_CTA_BANCARIA_CORREDORES
       WHERE SCC_CBA_BAN_CODIGO = C_DAT.CBA_BAN_CODIGO
         AND SCC_CBA_NUMERO_CUENTA = C_DAT.CBA_NUMERO_CUENTA
         AND SCC_FECHA < TRUNC(P_FECHA) + 1
         AND SCC_CONFIRMADO = 'S'
       ORDER BY SCC_FECHA DESC;
    C_SCC C_SALDO%ROWTYPE;

    CURSOR C_MOVIMIENTOS(P_FECHA DATE) IS
      SELECT SUM(MCB_MONTO)
        FROM MOVIMIENTOS_CUENTAS_BANCARIAS
       WHERE MCB_CBA_BAN_CODIGO = C_DAT.CBA_BAN_CODIGO
         AND MCB_CBA_NUMERO_CUENTA = C_DAT.CBA_NUMERO_CUENTA
         AND MCB_FECHA >= TRUNC(C_SCC.SCC_FECHA)
         AND MCB_FECHA < TRUNC(P_FECHA) + 1;

    CURSOR C_MOVIMIENTOS1(P_FECHA DATE) IS
      SELECT SUM(MCB_MONTO)
        FROM MOVIMIENTOS_CUENTAS_BANCARIAS
       WHERE MCB_CBA_BAN_CODIGO = C_DAT.CBA_BAN_CODIGO
         AND MCB_CBA_NUMERO_CUENTA = C_DAT.CBA_NUMERO_CUENTA
         AND MCB_FECHA < TRUNC(P_FECHA) + 1;

    CURSOR C_MVTOS(P_BANC VARCHAR2, P_CTA VARCHAR2, P_FECHA DATE) IS
      SELECT TMB_DESCRIPCION, SUM(MCB_MONTO) MCB_MONTO
        FROM (SELECT P_BANCOS.F_TRAE_CONCEPTO(TRIM(TMB_DESCRIPCION)) TMB_DESCRIPCION,
                     SUM(ABS(MCB_MONTO)) MCB_MONTO
                FROM MOVIMIENTOS_CUENTAS_BANCARIAS,
                     TIPOS_MOVIMIENTOS_BANCOS,
                     COMPROBANTES_DE_EGRESO
               WHERE MCB_TMB_MNEMONICO = TMB_MNEMONICO
                 AND MCB_CEG_CONSECUTIVO = CEG_CONSECUTIVO(+)
                 AND MCB_CBA_BAN_CODIGO = CEG_CBA_BAN_CODIGO(+)
                 AND MCB_CBA_NUMERO_CUENTA = CEG_CBA_NUMERO_CUENTA(+)
                 AND MCB_SUC_CODIGO = CEG_SUC_CODIGO(+)
                 AND MCB_NEG_CONSECUTIVO = CEG_NEG_CONSECUTIVO(+)
                 AND MCB_FECHA < TRUNC(P_FECHA) + 1
                 AND ((MCB_CONCILIADO = 'N') OR
                     (MCB_CONCILIADO = 'S' AND
                     MCB_FECHA_CONCILIACION >= TRUNC(P_FECHA) + 2))
                 AND MCB_CBA_BAN_CODIGO = C_DAT.CBA_BAN_CODIGO
                 AND MCB_CBA_NUMERO_CUENTA = C_DAT.CBA_NUMERO_CUENTA
               GROUP BY TMB_DESCRIPCION, MCB_TMB_MNEMONICO
              UNION ALL
              SELECT P_BANCOS.F_TRAE_CONCEPTO(TRIM(NVL(MEB_NOMBRE_TRANSACCION,
                                                       DECODE(TMB_MNEMONICO,
                                                              'CON',
                                                              'CREDITO',
                                                              'RET',
                                                              'DEBITO',
                                                              ' ')))) TMB_DESCRIPCION,
                     SUM(ABS(MEB_MONTO)) MCB_MONTO
                FROM TIPOS_MOVIMIENTOS_BANCOS, MOVIMIENTOS_EXTRACTO_BANCARIO
               WHERE TMB_MNEMONICO = MEB_TMB_MNEMONICO
                 AND MEB_FECHA < TRUNC(P_FECHA) + 1
                 AND ((MEB_CONCILIADO = 'N') OR
                     (MEB_CONCILIADO = 'S' AND
                     MEB_FECHA_CONCILIACION >= TRUNC(P_FECHA) + 2))
                 AND MEB_CBA_BAN_CODIGO = C_DAT.CBA_BAN_CODIGO
                 AND MEB_CBA_NUMERO_CUENTA = C_DAT.CBA_NUMERO_CUENTA
               GROUP BY MEB_NOMBRE_TRANSACCION,
                        MEB_TMB_MNEMONICO,
                        MEB_CBA_NUMERO_CUENTA)
       GROUP BY TMB_DESCRIPCION;

    C_MOV C_MVTOS%ROWTYPE;

    --  Selecciona la columna donde tiene que acumular el monto de la operacion
    CURSOR C_DETALLES(DETALLE VARCHAR2) IS
      SELECT MAD_COLUMNA
        FROM MATRIZ_DETALLES_CONCILIACION
       WHERE MAD_DESCRIPCION LIKE DETALLE;
    C_DET C_DETALLES%ROWTYPE;

    P_FECHA_INI  DATE;
    P_FECHA_FIN  DATE;
    MONTO        NUMBER;
    REGISTROS    NUMBER;
    SALDO_LIBROS NUMBER;

    LINEA              VARCHAR2(1000);
    nHash              NUMBER;
    mi_nombre_archivo  VARCHAR2(100);
    ARCHIVO_PORTAFOLIO VARCHAR2(100);
    LINEA_AUX          VARCHAR2(1000);
    LC1                VARCHAR2(1000);
    LD2                VARCHAR2(1000);
    LG1                VARCHAR2(1000);
    LH1                VARCHAR2(1000);
    LC2                VARCHAR2(1000);
    LG2                VARCHAR2(1000);
    LH2                VARCHAR2(1000);
    LD1                VARCHAR2(1000);

    COLUMNA     VARCHAR2(3);
    C1          NUMBER;
    D2          NUMBER;
    G1          NUMBER;
    H1          NUMBER;
    C2          NUMBER;
    G2          NUMBER;
    H2          NUMBER;
    D1          NUMBER;
    VALIDACION  NUMBER;
    TIP_ARCHIVO UTL_FILE.FILE_TYPE;
    V_BANC      VARCHAR2(10);
    V_CTA       VARCHAR2(100);
    V_MONTO     NUMBER;

    ----
    CONT     NUMBER;
    P_FECHA2 VARCHAR2(20);
  BEGIN

    CONT      := 0;
    REGISTROS := 0;

    SELECT TO_CHAR(SYSDATE - 1, 'RRRRMMDD') INTO P_FECHA2 FROM DUAL;

    ARCHIVO_PORTAFOLIO := 'CONCILIACION_NEGOCIOS_' || P_FECHA2 || '.txt';
    TIP_ARCHIVO        := UTL_FILE.FOPEN('REP_NOCTURNOS_A2',
                                         ARCHIVO_PORTAFOLIO,
                                         'W',
                                         10000);
    LINEA              := 'Cuenta Contable;Cuenta Bancaria;Tipo de Cuenta;Banco;Negocio;Saldo extracto;Saldo libros; CONSIG NO REG EN LIBROS C-1;' ||
                          'CHEQUES PENDIENTES DE COBRO D-2;ND NO REGISTRADAS EN LIBROS G-1;' ||
                          'NC NO REGISTRADA EN LIBROS H1;CONSIG PTES REG EN EXTRACTO C2;ND NO REGISTRADAS EN EXTRACTO G2;' ||
                          'NC NO REGISTRADA EN EXTRACTO H2;CH PEND DE REG EN LIBROS D1; Validaciżn';
    UTL_FILE.PUT_LINE(TIP_ARCHIVO, LINEA);

    SELECT P_TOOLS.CF_DIA_HABIL_ANTERIOR(SYSDATE),
           P_TOOLS.CF_DIA_HABIL_ANTERIOR(SYSDATE)
      INTO P_FECHA_INI, P_FECHA_FIN
      FROM DUAL;

    OPEN C_DATOS;
    FETCH C_DATOS
      INTO C_DAT;
    WHILE C_DATOS%FOUND LOOP

      -- Saldo de Extractos
      OPEN C_SALDO_EXTRACTOS(P_FECHA_INI, P_FECHA_FIN);
      FETCH C_SALDO_EXTRACTOS
        INTO C_SDOEXT;

      -- Saldo de Libros
      OPEN C_SALDO(P_FECHA_INI);
      FETCH C_SALDO
        INTO C_SCC;
      CLOSE C_SALDO;
      IF C_SCC.SCC_FECHA IS NULL THEN
        OPEN C_MOVIMIENTOS1(P_FECHA_INI);
        FETCH C_MOVIMIENTOS1
          INTO MONTO;
        CLOSE C_MOVIMIENTOS1;
        SALDO_LIBROS := NVL(MONTO, 0);
      ELSE
        IF TRUNC(C_SCC.SCC_FECHA) = TRUNC(P_FECHA_INI + 1) THEN
          SALDO_LIBROS := NVL(C_SCC.SCC_SALDO, 0);
        ELSE
          OPEN C_MOVIMIENTOS(P_FECHA_INI);
          FETCH C_MOVIMIENTOS
            INTO MONTO;
          CLOSE C_MOVIMIENTOS;
          SALDO_LIBROS := NVL(C_SCC.SCC_SALDO, 0) + NVL(MONTO, 0);
        END IF;
      END IF;
      V_BANC := C_DAT.CBA_BAN_CODIGO;
      V_CTA  := C_DAT.CBA_NUMERO_CUENTA;

      FOR R_MVTOS IN C_MVTOS(V_BANC, V_CTA, P_FECHA_INI) LOOP
        COLUMNA := NULL;
        V_MONTO := ABS(R_MVTOS.MCB_MONTO);

        IF R_MVTOS.TMB_DESCRIPCION = 'C1' THEN
          LC1 := TO_CHAR(V_MONTO);
          C1  := V_MONTO;
        ELSIF R_MVTOS.TMB_DESCRIPCION = 'D2' THEN
          LD2 := TO_CHAR(V_MONTO);
          D2  := V_MONTO;

        ELSIF R_MVTOS.TMB_DESCRIPCION = 'G1' THEN
          LG1 := TO_CHAR(V_MONTO);
          G1  := V_MONTO;

        ELSIF R_MVTOS.TMB_DESCRIPCION = 'H1' THEN
          LH1 := TO_CHAR(V_MONTO);
          H1  := V_MONTO;
        ELSIF R_MVTOS.TMB_DESCRIPCION = 'C2' THEN
          LC2 := TO_CHAR(V_MONTO);
          C2  := V_MONTO;
        ELSIF R_MVTOS.TMB_DESCRIPCION = 'G2' THEN
          LG2 := TO_CHAR(V_MONTO);
          G2  := V_MONTO;
        ELSIF R_MVTOS.TMB_DESCRIPCION = 'H2' THEN
          LH2 := TO_CHAR(V_MONTO);
          H2  := V_MONTO;
        ELSIF R_MVTOS.TMB_DESCRIPCION = 'D1' THEN
          LD1 := TO_CHAR(V_MONTO);
          D1  := V_MONTO;
        END IF;

        LINEA_AUX := NVL(LC1, '') || ';' || NVL(LD2, '') || ';' ||
                     NVL(LG1, '') || ';' || NVL(LH1, '') || ';' ||
                     NVL(LC2, '') || ';' || NVL(LG2, '') || ';' ||
                     NVL(LH2, '') || ';' || NVL(LD1, '');

      END LOOP;
      LINEA_AUX  := NVL(LC1, '') || ';' || NVL(LD2, '') || ';' ||
                    NVL(LG1, '') || ';' || NVL(LH1, '') || ';' ||
                    NVL(LC2, '') || ';' || NVL(LG2, '') || ';' ||
                    NVL(LH2, '') || ';' || NVL(LD1, '');
      VALIDACION := NVL(C_SDOEXT.SCC_SALDO_EN_BANCOS, 0) - SALDO_LIBROS -
                    NVL(C1, 0) - NVL(D2, 0) + NVL(G1, 0) - NVL(H1, 0) +
                    NVL(C2, 0) - NVL(G2, 0) + NVL(H2, 0) - NVL(D1, 0);

      LINEA := C_DAT.CTA_CONTAB || ';' || C_DAT.CBA_NUMERO_CUENTA || ';' ||
               C_DAT.TIPO_CTA || ';' || C_DAT.BAN_NOMBRE || ';' ||
               C_DAT.NEG_DESCRIPCION || ';' || C_SDOEXT.SCC_SALDO_EN_BANCOS || ';' ||
               SALDO_LIBROS || ';' || LINEA_AUX || ';' || VALIDACION;
      UTL_FILE.PUT_LINE(TIP_ARCHIVO, LINEA);
      REGISTROS := REGISTROS + 1;

      C1         := 0;
      D2         := 0;
      G1         := 0;
      H1         := 0;
      C2         := 0;
      G2         := 0;
      H2         := 0;
      D1         := 0;
      LC1        := NULL;
      LD2        := NULL;
      LG1        := NULL;
      LH1        := NULL;
      LC2        := NULL;
      LG2        := NULL;
      LH2        := NULL;
      LD1        := NULL;
      VALIDACION := NULL;
      LINEA_AUX  := NULL;

      FETCH C_DATOS
        INTO C_DAT;
      CLOSE C_SALDO_EXTRACTOS;
    END LOOP;
    CLOSE C_DATOS;

    UTL_FILE.FCLOSE(TIP_ARCHIVO);
  END CONCILIACION_NEGOCIOS;

  PROCEDURE ROPEFE_S3(P_USERID IN VARCHAR2) AS

    VAR           VARCHAR2(2000);
    V_FECHA       VARCHAR2(20);
    V_FECHA2      VARCHAR2(20);
    V_FECHAN      VARCHAR2(20);
    V_CONDICION   VARCHAR2(5000);
    V_FECHAS      VARCHAR2(1000);
    V_FECHAS1     VARCHAR2(1000);
    V_FECHA_INI   VARCHAR2(1000);
    V_MOVIMIENTO  VARCHAR2(5000) := ' ';
    V_MOVIMIENTO1 VARCHAR2(5000) := ' ';
    P_PARAMETROS  VARCHAR2(2000);

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN
    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_RMOVBA',
                                                      'INI');
    --V_CONDICION := 'CBA.CBA_NEG_CONSECUTIVO%20LIKE%20%27%25%27%20AND%20CBA.CBA_ESTADO%20 =%20%27A%27%20AND';

    SELECT TO_CHAR(P_TOOLS.CF_DIA_HABIL_ANTERIOR(SYSDATE),
                   'DD-MON-YYYY',
                   'nls_date_language = ''LATIN AMERICAN SPANISH'''),
           P_TOOLS.CF_DIA_HABIL_ANTERIOR(SYSDATE)
      INTO V_FECHA, V_FECHA2
      FROM DUAL;

    SELECT TO_CHAR(TRUNC((SYSDATE - 1)), 'DDMMYYYY')
      INTO V_FECHAN
      FROM DUAL;

    P_TOOLS.PR_CREAR_REPORTE(P_REPORT     => 'ROPEFE',
                             P_USERID     => P_USERID,
                             P_FORMATO    => 'TXT',
                             P_PARAMETROS => '+FECHA_DESDE=%27' || V_FECHA ||
                                             '%27+FECHA_HASTA=%27' ||
                                             V_FECHA ||
                                             '%27+P_FILTRO=Fecha Operacion+P_ESPECULATIVA=No',
                             P_ARCHIVO    => '/apps/rep_nocturnos_a3/ROPEFE_' ||
                                             V_FECHAN);

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_RMOVBA',
                                                      'FIN');

  EXCEPTION
    WHEN OTHERS THEN
      --  P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PR_REPORTE_RMOVBA',SUBSTR(SQLERRM,1,80),'procesosnocturnos@corredores.com');
      NULL;
  END ROPEFE_S3;

