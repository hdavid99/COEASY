      COMMIT;

    ELSIF V_CAMPO = 'LIT_CONSUMO_ACCIONES_C' THEN
      SELECT MAX(LIT_FECHA_CARGUE)
        INTO VALF
        FROM PROD.ARCHIVO_LIMITE_CONTRAPARTE;
      INSERT INTO PROD.LIMITES_CONSUMO_CONTRAPARTES
