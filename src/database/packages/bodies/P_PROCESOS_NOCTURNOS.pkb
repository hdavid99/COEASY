        INTO V_MOSTRAR373;
      CLOSE C_MOSTRAR373;

      UPDATE PERSONAS
         SET PER_LIMITE = V_MOSTRAR373.LIMITE
       WHERE PER_NUM_IDEN = V_MOSTRAR373.IDEN
         AND PER_TIPO = 'PJU'
         AND PER_CCT_MNEMONICO IS NOT NULL;
      COMMIT;

    ELSIF COLUMNAS = 374 THEN
      OPEN C_MOSTRAR374;
      FETCH C_MOSTRAR374
        INTO V_MOSTRAR374;
      CLOSE C_MOSTRAR374;

      UPDATE PERSONAS
         SET PER_LIMITE = V_MOSTRAR374.LIMITE
       WHERE PER_NUM_IDEN = V_MOSTRAR374.IDEN
         AND PER_TIPO = 'PJU'
         AND PER_CCT_MNEMONICO IS NOT NULL;
      COMMIT;

    ELSIF COLUMNAS = 375 THEN
      OPEN C_MOSTRAR375;
      FETCH C_MOSTRAR375
        INTO V_MOSTRAR375;
      CLOSE C_MOSTRAR375;

      UPDATE PERSONAS
         SET PER_LIMITE = V_MOSTRAR375.LIMITE
       WHERE PER_NUM_IDEN = V_MOSTRAR375.IDEN
         AND PER_TIPO = 'PJU'
         AND PER_CCT_MNEMONICO IS NOT NULL;
      COMMIT;

    ELSIF COLUMNAS = 376 THEN
      OPEN C_MOSTRAR376;
      FETCH C_MOSTRAR376
        INTO V_MOSTRAR376;
      CLOSE C_MOSTRAR376;

      UPDATE PERSONAS
         SET PER_LIMITE = V_MOSTRAR376.LIMITE
       WHERE PER_NUM_IDEN = V_MOSTRAR376.IDEN
         AND PER_TIPO = 'PJU'
         AND PER_CCT_MNEMONICO IS NOT NULL;
      COMMIT;

    END IF;

    OPEN C_LIMITE_NAT;
    FETCH C_LIMITE_NAT
      INTO V_LIMITE_NAT;
    WHILE C_LIMITE_NAT%FOUND LOOP
      UPDATE PERSONAS
         SET PER_LIMITE = V_LIMITE_NAT.LIMITE
       WHERE PER_NUM_IDEN = V_LIMITE_NAT.IDEN
         AND PER_TID_CODIGO = V_LIMITE_NAT.TID
         AND PER_CCT_MNEMONICO IS NOT NULL
      --AND PER_TIPO       = 'PNA'
      ;
      COMMIT;
      FETCH C_LIMITE_NAT
        INTO V_LIMITE_NAT;
    END LOOP;
    CLOSE C_LIMITE_NAT;

    OPEN C_NOMBRE;
    FETCH C_NOMBRE
      INTO V_NOMBRE;
    WHILE C_NOMBRE%FOUND LOOP
      OPEN C_CONTRAPARTE(V_NOMBRE.IDEN);
      FETCH C_CONTRAPARTE
        INTO V_CONTRAPARTE;
      IF C_CONTRAPARTE%FOUND THEN
        UPDATE PERSONAS
           SET PER_LIMITE = V_CONTRAPARTE
         WHERE PER_TIPO = 'PJU'
           AND PER_TID_CODIGO != 'SSN'
           AND PER_NUM_IDEN = V_NOMBRE.IDEN
           AND PER_TID_CODIGO = V_NOMBRE.TID
           AND PER_CCT_MNEMONICO IS NOT NULL
           AND EXISTS (SELECT 'X'
                  FROM CLIENTES
                 WHERE CLI_PER_NUM_IDEN = PER_NUM_IDEN
                   AND CLI_PER_TID_CODIGO = PER_TID_CODIGO)
           AND NOT EXISTS
         (SELECT 'X'
                  FROM LIMITE_SARIC L
                 WHERE L.LISA_CLI_PER_NUM_IDEN = PER_NUM_IDEN
                   AND L.LISA_CLI_PER_TID_CODIGO = PER_TID_CODIGO
                   AND L.LISA_ESTADO = 'A');
        COMMIT;
      END IF;
      CLOSE C_CONTRAPARTE;
      FETCH C_NOMBRE
        INTO V_NOMBRE;
    END LOOP;
    CLOSE C_NOMBRE;

    OPEN C_LIMITES;
    FETCH C_LIMITES
      INTO V_LIMITES;
    WHILE C_LIMITES%FOUND LOOP
      UPDATE PERSONAS
         SET PER_TIPO_LIMITE = NULL
       WHERE PER_NUM_IDEN = V_LIMITES.IDEN
         AND PER_TID_CODIGO = V_LIMITES.TID;
      COMMIT;
      FETCH C_LIMITES
        INTO V_LIMITES;
    END LOOP;
    CLOSE C_LIMITES;

  END P_LIMITES_CLIENTES;

  PROCEDURE P_LIMCOS IS

    CURSOR C_CAMPO IS
      SELECT C.CLC_COLUMNA_CAMPO
        FROM PROD.COLUMNAS_LIMITE_CONTRAPARTE C,
             PROD.PARAMETRO_BASE_LIMITE       E
       WHERE E.PBL_PILC_COLUMNA = C.CLC_ID_COLUMNA
         AND E.PBL_LIT_FECHA_CARGUE =
             (SELECT MAX(PBL_LIT_FECHA_CARGUE)
                FROM PROD.PARAMETRO_BASE_LIMITE)
         AND (E.PBL_DLC_DESCRIPCION_LIMITE LIKE '%ontrapa%' OR
             E.PBL_DLC_DESCRIPCION_LIMITE LIKE '%CONTRAPA%')
         AND E.PBL_DLC_DESCRIPCION_LIMITE NOT LIKE '%robroke%'
         AND E.PBL_DLC_DESCRIPCION_LIMITE NOT LIKE '%ROBROKE%'
         AND E.PBL_PLC_PORCENTAJE = 95
         AND (E.PBL_PTLC_TIPO_REGISTRO LIKE '%ont%' OR
             E.PBL_PTLC_TIPO_REGISTRO LIKE '%ONT%')
         AND E.PBL_BASEMONETARIA = 'Pesos'
       ORDER BY C.CLC_ID_COLUMNA;

    V_CAMPO VARCHAR2(50);

    CURSOR C_CAMPO1 IS
      SELECT C.CLC_COLUMNA_CAMPO
        FROM PROD.COLUMNAS_LIMITE_CONTRAPARTE C,
             PROD.PARAMETRO_BASE_LIMITE       E
       WHERE E.PBL_PILC_COLUMNA = C.CLC_ID_COLUMNA
         AND E.PBL_LIT_FECHA_CARGUE =
             (SELECT MAX(PBL_LIT_FECHA_CARGUE)
                FROM PROD.PARAMETRO_BASE_LIMITE)
         AND (E.PBL_DLC_DESCRIPCION_LIMITE LIKE '%ontrapa%' OR
             E.PBL_DLC_DESCRIPCION_LIMITE LIKE '%CONTRAPA%')
         AND E.PBL_DLC_DESCRIPCION_LIMITE NOT LIKE '%robroke%'
         AND E.PBL_DLC_DESCRIPCION_LIMITE NOT LIKE '%ROBROKE%'
         AND E.PBL_PLC_PORCENTAJE = 95
         AND (E.PBL_PTLC_TIPO_REGISTRO LIKE '%ont%' OR
             E.PBL_PTLC_TIPO_REGISTRO LIKE '%ONT%')
         AND E.PBL_BASEMONETARIA = 'Dolar'
       ORDER BY C.CLC_ID_COLUMNA;

    V_CAMPO1 VARCHAR2(50);

    CURSOR C_CONSUMO(VAR1 DATE) IS
      SELECT LCCT_FECHA, LCCT_NIT_CONTRAPARTE, LCCT_MONEDA
        FROM LIMITES_CONSUMO_CONTRAPARTES, ARCHIVO_LIMITE_CONTRAPARTE
       WHERE LCCT_FECHA = LIT_FECHA_CARGUE
         AND LCCT_NIT_CONTRAPARTE = LIT_IDENTIFICACION_I
         AND LCCT_FECHA = VAR1
         AND LCCT_MONEDA = 'COP';

    V_CONSUMO C_CONSUMO%ROWTYPE;

    VALF DATE;

  BEGIN

    DELETE FROM PROD.LIMITES_CONSUMO_CONTRAPARTES
     WHERE LCCT_FECHA = TRUNC(SYSDATE - 1);
    COMMIT;

    OPEN C_CAMPO;
    FETCH C_CAMPO
      INTO V_CAMPO;
    CLOSE C_CAMPO;

    IF V_CAMPO = 'LIT_LIMITE_INVERSION_PP_100_C' THEN
      SELECT MAX(LIT_FECHA_CARGUE)
        INTO VALF
        FROM PROD.ARCHIVO_LIMITE_CONTRAPARTE;
      INSERT INTO PROD.LIMITES_CONSUMO_CONTRAPARTES
        (LCCT_CONSECUTIVO,
         LCCT_FECHA,
         LCCT_MONEDA,
         LCCT_NIT_CONTRAPARTE,
         LCCT_CONTRAPARTE,
         LCCT_LIMITE_CONTRA_95_COP)
        SELECT PROD.LCCT_SEQ.NEXTVAL,
               TRUNC(SYSDATE - 1),
               'COP',
               A.LIT_IDENTIFICACION_I,
               A.LIT_COMPANIA_I,
               LIT_LIMITE_INVERSION_PP_100_C
          FROM PROD.ARCHIVO_LIMITE_CONTRAPARTE A
         WHERE LIT_FECHA_CARGUE = VALF;
      COMMIT;

    ELSIF V_CAMPO = 'LIT_LIMITE_INVERSION_PP_95_C' THEN
      SELECT MAX(LIT_FECHA_CARGUE)
        INTO VALF
        FROM PROD.ARCHIVO_LIMITE_CONTRAPARTE;
      INSERT INTO PROD.LIMITES_CONSUMO_CONTRAPARTES
        (LCCT_CONSECUTIVO,
         LCCT_FECHA,
         LCCT_MONEDA,
         LCCT_NIT_CONTRAPARTE,
         LCCT_CONTRAPARTE,
         LCCT_LIMITE_CONTRA_95_COP)
        SELECT PROD.LCCT_SEQ.NEXTVAL,
               TRUNC(SYSDATE - 1),
               'COP',
               A.LIT_IDENTIFICACION_I,
               A.LIT_COMPANIA_I,
               LIT_LIMITE_INVERSION_PP_95_C
          FROM PROD.ARCHIVO_LIMITE_CONTRAPARTE A
         WHERE LIT_FECHA_CARGUE = VALF;
      COMMIT;

    ELSIF V_CAMPO = 'LIT_CONSUMO_INVERSION_C' THEN
      SELECT MAX(LIT_FECHA_CARGUE)
        INTO VALF
        FROM PROD.ARCHIVO_LIMITE_CONTRAPARTE;
      INSERT INTO PROD.LIMITES_CONSUMO_CONTRAPARTES
        (LCCT_CONSECUTIVO,
         LCCT_FECHA,
         LCCT_MONEDA,
         LCCT_NIT_CONTRAPARTE,
         LCCT_CONTRAPARTE,
         LCCT_LIMITE_CONTRA_95_COP)
        SELECT PROD.LCCT_SEQ.NEXTVAL,
               TRUNC(SYSDATE - 1),
