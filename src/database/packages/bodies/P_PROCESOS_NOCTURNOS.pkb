               A.LIT_COMPANIA_I,
               LIT_CONSUMO_INVERSION_C
          FROM PROD.ARCHIVO_LIMITE_CONTRAPARTE A
         WHERE LIT_FECHA_CARGUE = VALF;
      COMMIT;

    ELSIF V_CAMPO = 'LIT_DISPONIBLE_INVERSION_C' THEN
