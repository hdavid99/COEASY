  PROCEDURE PR_NOTIFICA_VCTOS_SEMANAL IS
    P_FECHA_INICIO DATE;
    P_FECHA_FIN    DATE;
  BEGIN
    SELECT TRUNC(SYSDATE), TRUNC(SYSDATE) + 7
      INTO P_FECHA_INICIO, P_FECHA_FIN
      FROM DUAL;

    P_NOTIFICACIONES_CLIENTE.PR_NOTIFICA_VCTOS_SEMANAL_LI(P_FECHA_INICIO,
                                                          P_FECHA_FIN);
    P_NOTIFICACIONES_CLIENTE.PR_NOTIFICA_VCTOS_SEMANAL_RF(P_FECHA_INICIO,
                                                          P_FECHA_FIN);
  END PR_NOTIFICA_VCTOS_SEMANAL;

  PROCEDURE PR_NOTIFICA_VCTO_ACT_DATOS IS
  BEGIN
    P_NOTIFICACIONES_CLIENTE.PR_NOTIFICA_VCTO_ACT_DATOS();
  END PR_NOTIFICA_VCTO_ACT_DATOS;
  /*******************************INICIO SALDOS CUENTAS BANCARIAS LDA******************************/
  PROCEDURE PRC_SALDOS_DISPONIBLES_LVA AS

    -- CURSOR QUE TRAE LOS FONDOS
    CURSOR C1 IS
      SELECT FON_CODIGO, FON_RAZON_SOCIAL
        FROM FONDOS
       WHERE FON_CAPITAL_PRIVADO = 'N'
         AND FON_TIPO_ADMINISTRACION = 'F'
         AND FON_ESTADO = 'A'
         AND FON_TIPO = 'A'
         AND FON_NOMBRE_CORTO IS NOT NULL
         AND FON_CODIGO_SUPERVALORES NOT IN (63935, 66082, 59201)
       ORDER BY 2;

    -- CURSOR QUE TRAE LAS CUENTAS BANCARIAS LOCALES DE CADA FONDO
    CURSOR C2(P_FONDO VARCHAR2) IS
      SELECT CBF_FON_CODIGO,
             CBF_NUMERO_CUENTA,
             CBF_BAN_CODIGO,
             DECODE(CBF_TIPO_CUENTA, 'A', 'Ahorro', 'C', 'Corriente') TIPO
        FROM CUENTAS_BANCARIAS_FONDOS, BANCOS
       WHERE CBF_FON_CODIGO = P_FONDO
         AND CBF_BAN_CODIGO = BAN_CODIGO
         AND BAN_CODIGO <> 0
         AND BAN_ESTADO = 'A'
         AND CBF_ESTADO = 'A';

    -- MES - 814-DIVISAS FICS
    -- CURSOR QUE TRAE LAS CUENTAS BANCARIAS EXTRANJERAS DE FICS
    CURSOR C_CBEF(P_FONDO VARCHAR2) IS
      SELECT CBEF_FON_CODIGO,
             CBEF_BEX_MNEMONICO,
             CBEF_NUMERO_CUENTA,
             CBEF_BMO_MNEMONICO,
             DECODE(CBEF_TIPO_CUENTA, 'A', 'Ahorro', 'C', 'Corriente') TIPO
        FROM CUENTAS_BANCARIAS_EXT_FONDOS
       WHERE CBEF_FON_CODIGO = P_FONDO
         AND CBEF_ESTADO = 'A';

    CURSOR C3 IS
      SELECT TSC_BAN_NOMBRE, TSC_CBF_NUMERO_CUENTA, BAN_CODIGO
        FROM TMP_SALDOS_CUENTAS, BANCOS
       WHERE TSC_BAN_NOMBRE = BAN_NOMBRE
         AND BAN_ESTADO = 'A'
         AND TSC_LOCAL_EXTFIC = 'L';

    -- MES - 814-DIVISAS FONDOS
    -- CURSOR QUE TRAE EL SALDO DE CIERRE EN TESORERIA REEXPRESADO EN PESOS
    CURSOR C3_EXT IS
      SELECT TSC_CBEF_NUMERO_CUENTA, TSC_BEX_MNEMONICO
        FROM TMP_SALDOS_CUENTAS
       WHERE TSC_LOCAL_EXTFIC = 'E';

    CURSOR C_SALDIA_EXT(QBEX VARCHAR2, QCUENTA VARCHAR2) IS
      SELECT NVL(MCE_SALDO, 0) * MCE_TASA_USD_COP
        FROM MVTOS_CUENTAS_BANCARIAS_EXTFON
       WHERE MCE_CBEF_BEX_MNEMONICO = QBEX
         AND MCE_CBEF_NUMERO_CUENTA = QCUENTA
         AND TRUNC(MCE_FECHA) >= TRUNC(SYSDATE - 1)
         AND TRUNC(MCE_FECHA) < TRUNC(SYSDATE)
         AND MCE_TMB_MNEMONICO IN ('CREXP', 'DREXP');

    V_SALDO NUMBER;

    -- CURSOR PARA CUENTAS LOCALES
    CURSOR C4 IS
      SELECT TSC_BAN_NOMBRE,
             TSC_FON_RAZON_SOCIAL,
             SUM(TSC_SALDO_DIARIO) TSC_SALDO_DIARIO,
             TSC_FON_CODIGO
        FROM TMP_SALDOS_CUENTAS
       GROUP BY TSC_BAN_NOMBRE, TSC_FON_RAZON_SOCIAL, TSC_FON_CODIGO;

    -- CURSOR PARA CUENTAS EXTRANJERAS
    CURSOR C_SAL_EXT IS
      SELECT TSC_BEX_MNEMONICO,
             TSC_FON_CODIGO,
             SUM(TSC_SALDO_DIARIO) TSC_SALDO_DIARIO
        FROM TMP_SALDOS_CUENTAS
       WHERE TSC_LOCAL_EXTFIC = 'E'
       GROUP BY TSC_BEX_MNEMONICO, TSC_FON_CODIGO;

    -- CURSOR QUE TRAE LOS DATOS DEL FONDO
    CURSOR C_FONDOS(QFONDO VARCHAR2) IS
      SELECT FON_CODIGO_SUPERVALORES FROM FONDOS WHERE FON_CODIGO = QFONDO;

    -- 814-CURSOR QUE TRAE EL NIT DEL BANCO EXTERIOR
    CURSOR C_BEX(QBEX VARCHAR2) IS
      SELECT BEX_NIT, BEX_NOMBRE
        FROM BANCOS_EXTERIOR
       WHERE BEX_MNEMONICO = QBEX;

    CURSOR C_DATOS IS
      SELECT TIPO_ENTIDAD,
             COD_ENTIDAD,
             COD_NEGOCIO,
             NIT_BANCO,
             NOMBRE_BANCO,
             ENTIDAD_CALIFICADORA,
             CALIFICACION_RIESGO,
             REPLACE(TO_CHAR(VALOR_NOMINAL), ',', '.') VALOR_NOMINAL
      --VALOR_NOMINAL
        FROM TMP_ARCHIVO_LVA
       ORDER BY COD_NEGOCIO;
    C_DAT C_DATOS%ROWTYPE;

    DSP_TIPO_CLIENTE   VARCHAR2(20);
    TIPO_CLIENTE       VARCHAR2(20);
    TIP_ARCHIVO        UTL_FILE.FILE_TYPE;
    ARCHIVO_PORTAFOLIO VARCHAR2(100);
    LINEA              VARCHAR2(5000);
    V_NOMBRE           VARCHAR2(150);
    V_BANCO            VARCHAR2(40);
    V_NEGOCIO          NUMBER;
    V_NIT              VARCHAR2(100);
    V_NIT_E            NUMBER;
    V_ENTIDAD          VARCHAR2(10);
    V_CALIFICACION     VARCHAR2(10);
    V_SECUENCIAL       NUMBER;
    V_CALIF            VARCHAR2(20);
    V_CALIFICA         VARCHAR2(20);
    P_FECHA            DATE;
    P_FECHA2           VARCHAR2(20);
    V_ESTADO           VARCHAR2(100);

  BEGIN
    --LLENADO INICIAL DE CUENTAS
    DELETE TMP_SALDOS_CUENTAS;
    COMMIT;
    FOR R1 IN C1 LOOP
      BEGIN
        SELECT FON_RAZON_SOCIAL
          INTO V_NOMBRE
          FROM FONDOS
         WHERE FON_CODIGO = R1.FON_CODIGO;
      EXCEPTION
        WHEN NO_DATA_FOUND THEN
          V_NOMBRE := NULL;
      END;

      FOR R2 IN C2(R1.FON_CODIGO) LOOP
        BEGIN
          SELECT BAN_NOMBRE
            INTO V_BANCO
            FROM BANCOS
           WHERE BAN_CODIGO = R2.CBF_BAN_CODIGO
             AND BAN_ESTADO = 'A';
        EXCEPTION
          WHEN NO_DATA_FOUND THEN
            V_BANCO := NULL;
        END;

        V_ESTADO := 'INSERTANDO SALDO CTA ' || R2.CBF_NUMERO_CUENTA;
        INSERT INTO TMP_SALDOS_CUENTAS
          (TSC_FON_RAZON_SOCIAL,
           TSC_BAN_NOMBRE,
           TSC_TIPO_CUENTA,
           TSC_LOCAL_EXTFIC,
           TSC_CBF_NUMERO_CUENTA)
        VALUES
          (V_NOMBRE, V_BANCO, R2.TIPO, 'L', R2.CBF_NUMERO_CUENTA);
      END LOOP;

      -- 814- CURSOR QUE TRAE LOS DATOS DE LAS CUENTAS BANCARIAS EXTERIORES DE FICS
      FOR RE1 IN C_CBEF(R1.FON_CODIGO) LOOP
        BEGIN
          V_ESTADO := 'DATOS BANCO ' || RE1.CBEF_BEX_MNEMONICO;
          SELECT BEX_NOMBRE
            INTO V_BANCO
            FROM BANCOS_EXTERIOR
           WHERE BEX_MNEMONICO = RE1.CBEF_BEX_MNEMONICO
             AND BEX_ESTADO = 'A';
        EXCEPTION
          WHEN NO_DATA_FOUND THEN
            V_BANCO := NULL;
        END;

        V_ESTADO := 'INSERTANDO SALDO CTA ' || RE1.CBEF_BMO_MNEMONICO;
        INSERT INTO TMP_SALDOS_CUENTAS
          (TSC_FON_RAZON_SOCIAL,
           TSC_FON_CODIGO,
           TSC_BAN_NOMBRE,
           TSC_BEX_MNEMONICO,
           TSC_CBEF_NUMERO_CUENTA,
           TSC_TIPO_CUENTA,
           TSC_LOCAL_EXTFIC,
           TSC_BMO_MNEMONICO)
        VALUES
          (V_NOMBRE,
           RE1.CBEF_FON_CODIGO,
           V_BANCO,
           RE1.CBEF_BEX_MNEMONICO,
           RE1.CBEF_NUMERO_CUENTA,
           RE1.TIPO,
           'E',
           RE1.CBEF_BMO_MNEMONICO);
      END LOOP;

    END LOOP;
    COMMIT;
    -- FIN LLENADO INICIAL DE CUENTAS

    --CARGUE SALDOS DIARIOS POR CUENTA
    -- PARA CUENTAS LOCALES
    FOR R3 IN C3 LOOP
      V_SALDO := P_CONT_BANCOS.FC_TOTAL_SALDOS_CTA(R3.BAN_CODIGO,
                                                   R3.TSC_CBF_NUMERO_CUENTA,
                                                   SYSDATE - 1);

      UPDATE TMP_SALDOS_CUENTAS
         SET TSC_SALDO_DIARIO = V_SALDO
       WHERE TSC_CBF_NUMERO_CUENTA = R3.TSC_CBF_NUMERO_CUENTA;
      COMMIT;

    END LOOP;

    -- PARA CUENTAS EXTERIORES DE FICS
    FOR RE3 IN C3_EXT LOOP
      V_SALDO  := NULL;
      V_ESTADO := 'SALDO-E CTA ' || RE3.TSC_CBEF_NUMERO_CUENTA;
      OPEN C_SALDIA_EXT(RE3.TSC_BEX_MNEMONICO, RE3.TSC_CBEF_NUMERO_CUENTA);
      FETCH C_SALDIA_EXT
        INTO V_SALDO;
      CLOSE C_SALDIA_EXT;
      V_SALDO := NVL(V_SALDO, 0);

      V_ESTADO := 'ACT SALDO-E CTA ' || RE3.TSC_CBEF_NUMERO_CUENTA;
      UPDATE TMP_SALDOS_CUENTAS
         SET TSC_SALDO_DIARIO = V_SALDO
       WHERE TSC_CBEF_NUMERO_CUENTA = RE3.TSC_CBEF_NUMERO_CUENTA
         AND TSC_BEX_MNEMONICO = RE3.TSC_BEX_MNEMONICO;
      COMMIT;

    END LOOP;

    --FIN CARGUE SALDOS DIARIOS POR CUENTA

    --CREACIżN DATOS ARCHIVO LVA
    DELETE TMP_ARCHIVO_LVA;
    COMMIT;

    -- CURSOR PARA DATOS DE LAS CUENTAS BANCARIAS LOCALES
    FOR R4 IN C4 LOOP
      BEGIN
        SELECT FON_CODIGO_SUPERVALORES
          INTO V_NEGOCIO
          FROM FONDOS
         WHERE FON_RAZON_SOCIAL = R4.TSC_FON_RAZON_SOCIAL;
      EXCEPTION
        WHEN NO_DATA_FOUND THEN
          V_NEGOCIO := 0;
      END;
      BEGIN
        SELECT BAN_NIT --DECODE(TO_CHAR(PER_DIGITO_CONTROL), NULL,TO_CHAR(BAN_NIT), TO_CHAR(BAN_NIT||'-'||TO_CHAR(PER_DIGITO_CONTROL)))
          INTO V_NIT
          FROM BANCOS, PERSONAS
         WHERE TO_CHAR(BAN_NIT) = PER_NUM_IDEN
           AND BAN_NOMBRE = R4.TSC_BAN_NOMBRE
           AND BAN_NIT IS NOT NULL;
        --AND ROWNUM = 1;
      EXCEPTION
        WHEN NO_DATA_FOUND THEN
          V_NIT := NULL;
      END;

      BEGIN
        SELECT PER_CLF_SECUENCIAL
          INTO V_SECUENCIAL
          FROM PERSONAS
         WHERE PER_NUM_IDEN = V_NIT;
      EXCEPTION
        WHEN NO_DATA_FOUND THEN
          V_SECUENCIAL := 0;
      END;
      BEGIN
        SELECT L_CLF.CLF_CAL_MNEMONICO
          INTO V_ENTIDAD
          FROM CALIFICACIONES L_CLF, CALIFICADORAS L_CAL
         WHERE L_CLF.CLF_SECUENCIAL = V_SECUENCIAL
           AND L_CAL.CAL_MNEMONICO(+) = L_CLF.CLF_CAL_MNEMONICO;
      EXCEPTION
        WHEN NO_DATA_FOUND THEN
          V_ENTIDAD := NULL;
      END;
      BEGIN
        SELECT L_CLF.CLF_CALIFICACION
          INTO V_CALIFICACION
          FROM CALIFICACIONES L_CLF, CALIFICADORAS L_CAL
         WHERE L_CLF.CLF_SECUENCIAL = V_SECUENCIAL
           AND L_CAL.CAL_MNEMONICO(+) = L_CLF.CLF_CAL_MNEMONICO;
      EXCEPTION
        WHEN NO_DATA_FOUND THEN
          V_CALIFICACION := NULL;
      END;

      INSERT INTO TMP_ARCHIVO_LVA
      VALUES
        (85,
         26,
         V_NEGOCIO,
         V_NIT,
         R4.TSC_BAN_NOMBRE,
         V_ENTIDAD,
         V_CALIFICACION,
         R4.TSC_SALDO_DIARIO);
      COMMIT;
    END LOOP;

    -- LOOP PARA LOS DATOS DE LAS CUENTAS EXTERIORES FICS
    FOR R5 IN C_SAL_EXT LOOP
      V_ESTADO := 'NEG DEL FONDO ' || R5.TSC_FON_CODIGO;
      OPEN C_FONDOS(R5.TSC_FON_CODIGO);
      FETCH C_FONDOS
        INTO V_NEGOCIO;
      CLOSE C_FONDOS;
      V_NEGOCIO := NVL(V_NEGOCIO, 0);

      V_NIT          := NULL;
      V_NIT_E        := NULL;
      V_SECUENCIAL   := NULL;
      V_ENTIDAD      := NULL;
      V_CALIFICACION := NULL;
      V_ESTADO       := 'DATOS BANCO-E ' || R5.TSC_BEX_MNEMONICO;
      OPEN C_BEX(R5.TSC_BEX_MNEMONICO);
      FETCH C_BEX
        INTO V_NIT_E, V_BANCO;
      CLOSE C_BEX;

      V_NIT := TO_CHAR(V_NIT_E);

      IF V_NIT IS NOT NULL THEN
        V_ESTADO := 'CALIFICACION ' || V_NIT;
        BEGIN
          SELECT PER_CLF_SECUENCIAL
            INTO V_SECUENCIAL
            FROM PERSONAS
           WHERE PER_NUM_IDEN = V_NIT
             AND NVL(PER_ESTADO, 'A') = 'A'
             AND PER_CLF_SECUENCIAL IS NOT NULL;
        EXCEPTION
          WHEN NO_DATA_FOUND THEN
            V_SECUENCIAL := 0;
        END;

        BEGIN
          SELECT L_CLF.CLF_CAL_MNEMONICO
            INTO V_ENTIDAD
            FROM CALIFICACIONES L_CLF, CALIFICADORAS L_CAL
           WHERE L_CLF.CLF_SECUENCIAL = V_SECUENCIAL
             AND L_CAL.CAL_MNEMONICO(+) = L_CLF.CLF_CAL_MNEMONICO;
        EXCEPTION
          WHEN NO_DATA_FOUND THEN
            V_ENTIDAD := NULL;
        END;

        BEGIN
          SELECT L_CLF.CLF_CALIFICACION
            INTO V_CALIFICACION
            FROM CALIFICACIONES L_CLF, CALIFICADORAS L_CAL
           WHERE L_CLF.CLF_SECUENCIAL = V_SECUENCIAL
             AND L_CAL.CAL_MNEMONICO(+) = L_CLF.CLF_CAL_MNEMONICO;
        EXCEPTION
          WHEN NO_DATA_FOUND THEN
            V_CALIFICACION := NULL;
        END;
      END IF;
      V_ESTADO := 'INSERT LVA ' || V_BANCO;
      INSERT INTO TMP_ARCHIVO_LVA
      VALUES
        (85,
         26,
         V_NEGOCIO,
         V_NIT,
         V_BANCO,
         V_ENTIDAD,
         V_CALIFICACION,
         R5.TSC_SALDO_DIARIO);
      COMMIT;
    END LOOP;

    -- FIN CREACIżN DATOS ARCHIVO LVA

    SELECT TO_CHAR(SYSDATE - 1, 'RRRRMMDD') INTO P_FECHA2 FROM DUAL;

    ARCHIVO_PORTAFOLIO := 'CRDDAV_BANCOS_CALIFICACIONES_' || P_FECHA2 ||
                          '.csv';
    TIP_ARCHIVO        := UTL_FILE.FOPEN('SALDOSLVA',
                                         ARCHIVO_PORTAFOLIO,
                                         'W',
                                         10000);
    LINEA              := 'TIPO_ENTIDAD;COD_ENTIDAD;COD_NEGOCIO;NIT_BANCO;NOMBRE_BANCO;ENTIDAD_CALIFICADORA;CALIFICACIżN_RIESGO;VALOR_NOMINAL';
    UTL_FILE.PUT_LINE(TIP_ARCHIVO, LINEA);

    TIPO_CLIENTE     := ' ';
    DSP_TIPO_CLIENTE := ' ';

    OPEN C_DATOS;
    FETCH C_DATOS
      INTO C_DAT;
    WHILE C_DATOS%FOUND LOOP

      LINEA := '';
      LINEA := C_DAT.TIPO_ENTIDAD || ';' || C_DAT.COD_ENTIDAD || ';' ||
               C_DAT.COD_NEGOCIO || ';' || C_DAT.NIT_BANCO || ';' ||
               C_DAT.NOMBRE_BANCO || ';' || C_DAT.ENTIDAD_CALIFICADORA || ';' ||
               C_DAT.CALIFICACION_RIESGO || ';' || C_DAT.VALOR_NOMINAL;

      UTL_FILE.PUT_LINE(TIP_ARCHIVO, LINEA);

      FETCH C_DATOS
        INTO C_DAT;
    END LOOP;
    CLOSE C_DATOS;

    UTL_FILE.FCLOSE(TIP_ARCHIVO);
  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PRC_SALDOS_DISPONIBLES_LVA',
                              SUBSTR(SQLERRM, 1, 80),
                              'procesosnocturnos@corredores.com');
  END PRC_SALDOS_DISPONIBLES_LVA;
