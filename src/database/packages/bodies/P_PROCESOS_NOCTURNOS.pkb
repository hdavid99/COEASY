  -------------------------------------------------FIN DINżMICAS CONTABLES FASE 1------------------------------------------------------------------------------------

  /*******************************PROCEDIMIENTO P_RECALCULO_SALDOS ******************************/

  PROCEDURE P_RECALCULO_SALDOS IS

    CURSOR CUR_CTA IS
      SELECT DISTINCT CCC_CLI_PER_NUM_IDEN,
                      CCC_CLI_PER_TID_CODIGO,
                      CCC_NUMERO_CUENTA
        FROM CUENTAS_CLIENTE_CORREDORES, MOVIMIENTOS_CUENTA_CORREDORES
       WHERE CCC_CLI_PER_NUM_IDEN = MCC_CCC_CLI_PER_NUM_IDEN
         AND CCC_CLI_PER_TID_CODIGO = MCC_CCC_CLI_PER_TID_CODIGO
         AND CCC_NUMERO_CUENTA = MCC_CCC_NUMERO_CUENTA
         AND MCC_FECHA >= TRUNC(SYSDATE - 4);

    CURSOR C_SALDO_ANTERIOR(P_CCC_CLI_PER_NUM_IDEN   VARCHAR2,
                            P_CCC_CLI_PER_TID_CODIGO VARCHAR2,
                            P_CCC_NUMERO_CUENTA      NUMBER) IS
      SELECT MCC_SALDO,
             MCC_SALDO_CANJE,
             MCC_SALDO_A_PLAZO,
             MCC_SALDO_A_CONTADO,
             MCC_SALDO_ADMON_VALORES,
             MCC_SALDO_CC,
             MCC_SALDO_CANJE_CC,
             MCC_SALDO_BURSATIL
        FROM MOVIMIENTOS_CUENTA_CORREDORES
       WHERE MCC_FECHA < TRUNC(SYSDATE - 4)
         AND MCC_CCC_CLI_PER_NUM_IDEN = P_CCC_CLI_PER_NUM_IDEN
         AND MCC_CCC_CLI_PER_TID_CODIGO = P_CCC_CLI_PER_TID_CODIGO
         AND MCC_CCC_NUMERO_CUENTA = P_CCC_NUMERO_CUENTA
       ORDER BY MCC_CONSECUTIVO DESC;

    CURSOR C_MOVIMIENTOS(P_CCC_CLI_PER_NUM_IDEN   VARCHAR2,
                         P_CCC_CLI_PER_TID_CODIGO VARCHAR2,
                         P_CCC_NUMERO_CUENTA      NUMBER) IS
      SELECT MCC_FECHA,
             MCC_MONTO,
             MCC_MONTO_CANJE,
             MCC_MONTO_A_PLAZO,
             MCC_MONTO_A_CONTADO,
             MCC_MONTO_ADMON_VALORES,
             MCC_CONSECUTIVO,
             MCC_MONTO_CARTERA,
             MCC_MONTO_CANJE_CC,
             MCC_MONTO_BURSATIL
        FROM MOVIMIENTOS_CUENTA_CORREDORES
       WHERE MCC_FECHA >= TRUNC(SYSDATE - 4)
         AND MCC_CCC_CLI_PER_NUM_IDEN = P_CCC_CLI_PER_NUM_IDEN
         AND MCC_CCC_CLI_PER_TID_CODIGO = P_CCC_CLI_PER_TID_CODIGO
         AND MCC_CCC_NUMERO_CUENTA = P_CCC_NUMERO_CUENTA
       ORDER BY MCC_CONSECUTIVO;

    FECHA DATE;

    CURSOR C_ERRORES IS
      SELECT COUNT(*) T
        FROM ERRORES_PROCESOS
       WHERE ERP_FECHA_ERROR >= TRUNC(FECHA)
         AND ERP_PROCESO = 'P_PROCESOS_NOCTURNOS.P_RECALCULO SALDOS';

    NUM_ERRORES NUMBER;

    SALDO               NUMBER;
    SALDO_CANJE         NUMBER;
    SALDO_A_PLAZO       NUMBER;
    SALDO_A_CONTADO     NUMBER;
    SALDO_ADMON_VALORES NUMBER;
    SALDO_CC            NUMBER;
    SALDO_CANJE_CC      NUMBER;
    SALDO_BURSATIL      NUMBER;
    PROCESO             VARCHAR2(40);
    NOMBRE_TABLA        VARCHAR2(30);
    CAMPO               VARCHAR2(40);
    NOM_ERROR           VARCHAR2(255);
    P_NUM_INI           NUMBER;
    P_NUM_FIN           NUMBER;

  BEGIN
    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_RECALCULO_SALDOS',
                                                      'INI');

    SELECT TRUNC(SYSDATE) INTO FECHA FROM DUAL;
    PROCESO      := 'P_PROCESOS_NOCTURNOS.P_RECALCULO SALDOS';
    NOMBRE_TABLA := 'MOVIMIENTOS_CUENTA_CORREDORES';

    FOR CCC1 IN CUR_CTA LOOP
      BEGIN
        SAVEPOINT NO_RECALCULO;
        SALDO               := 0;
        SALDO_CANJE         := 0;
        SALDO_A_PLAZO       := 0;
        SALDO_A_CONTADO     := 0;
        SALDO_ADMON_VALORES := 0;
        SALDO_CC            := 0;
        SALDO_CANJE_CC      := 0;
        SALDO_BURSATIL      := 0;

        OPEN C_SALDO_ANTERIOR(CCC1.CCC_CLI_PER_NUM_IDEN,
                              CCC1.CCC_CLI_PER_TID_CODIGO,
                              CCC1.CCC_NUMERO_CUENTA);
        FETCH C_SALDO_ANTERIOR
          INTO SALDO,
               SALDO_CANJE,
               SALDO_A_PLAZO,
               SALDO_A_CONTADO,
               SALDO_ADMON_VALORES,
               SALDO_CC,
               SALDO_CANJE_CC,
               SALDO_BURSATIL;
        CLOSE C_SALDO_ANTERIOR;

        SALDO               := NVL(SALDO, 0);
        SALDO_CANJE         := NVL(SALDO_CANJE, 0);
        SALDO_A_PLAZO       := NVL(SALDO_A_PLAZO, 0);
        SALDO_A_CONTADO     := NVL(SALDO_A_CONTADO, 0);
        SALDO_ADMON_VALORES := NVL(SALDO_ADMON_VALORES, 0);
        SALDO_CC            := NVL(SALDO_CC, 0);
        SALDO_CANJE_CC      := NVL(SALDO_CANJE_CC, 0);
        SALDO_BURSATIL      := NVL(SALDO_BURSATIL, 0);

        FOR MCC1 IN C_MOVIMIENTOS(CCC1.CCC_CLI_PER_NUM_IDEN,
                                  CCC1.CCC_CLI_PER_TID_CODIGO,
                                  CCC1.CCC_NUMERO_CUENTA) LOOP
          SALDO               := SALDO + NVL(MCC1.MCC_MONTO, 0);
          SALDO_CANJE         := SALDO_CANJE + NVL(MCC1.MCC_MONTO_CANJE, 0);
          SALDO_A_PLAZO       := SALDO_A_PLAZO +
                                 NVL(MCC1.MCC_MONTO_A_PLAZO, 0);
          SALDO_A_CONTADO     := SALDO_A_CONTADO +
                                 NVL(MCC1.MCC_MONTO_A_CONTADO, 0);
          SALDO_ADMON_VALORES := SALDO_ADMON_VALORES +
                                 NVL(MCC1.MCC_MONTO_ADMON_VALORES, 0);
          SALDO_CC            := SALDO_CC + NVL(MCC1.MCC_MONTO_CARTERA, 0);
          SALDO_CANJE_CC      := SALDO_CANJE_CC +
                                 NVL(MCC1.MCC_MONTO_CANJE_CC, 0);
          SALDO_BURSATIL      := SALDO_BURSATIL +
                                 NVL(MCC1.MCC_MONTO_BURSATIL, 0);

          UPDATE MOVIMIENTOS_CUENTA_CORREDORES
             SET MCC_SALDO               = SALDO,
                 MCC_SALDO_CANJE         = SALDO_CANJE,
                 MCC_SALDO_A_CONTADO     = SALDO_A_CONTADO,
                 MCC_SALDO_A_PLAZO       = SALDO_A_PLAZO,
                 MCC_SALDO_ADMON_VALORES = SALDO_ADMON_VALORES,
                 MCC_SALDO_CC            = SALDO_CC,
                 MCC_SALDO_CANJE_CC      = SALDO_CANJE_CC,
                 MCC_SALDO_BURSATIL      = SALDO_BURSATIL
           WHERE MCC_CONSECUTIVO = MCC1.MCC_CONSECUTIVO;
        END LOOP;

        UPDATE CUENTAS_CLIENTE_CORREDORES
           SET CCC_SALDO_CAPITAL       = SALDO,
               CCC_SALDO_CANJE         = SALDO_CANJE,
               CCC_SALDO_A_PLAZO       = SALDO_A_PLAZO,
               CCC_SALDO_A_CONTADO     = SALDO_A_CONTADO,
               CCC_SALDO_ADMON_VALORES = SALDO_ADMON_VALORES,
               CCC_SALDO_CC            = SALDO_CC,
               CCC_SALDO_CANJE_CC      = SALDO_CANJE_CC,
               CCC_SALDO_BURSATIL      = SALDO_BURSATIL
         WHERE CCC_CLI_PER_NUM_IDEN = CCC1.CCC_CLI_PER_NUM_IDEN
           AND CCC_CLI_PER_TID_CODIGO = CCC1.CCC_CLI_PER_TID_CODIGO
           AND CCC_NUMERO_CUENTA = CCC1.CCC_NUMERO_CUENTA;

        COMMIT;

      EXCEPTION
        WHEN OTHERS THEN
          ROLLBACK TO NO_RECALCULO;
          NOM_ERROR := SUBSTR(SQLERRM, 1, 80);
          P_OPERACIONES.INSERTA_ERROR(P_PROCESO     => PROCESO,
                                      P_ERROR       => NOM_ERROR,
                                      P_TABLA_ERROR => NOMBRE_TABLA);
          COMMIT;
      END;
    END LOOP;
    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_RECALCULO_SALDOS',
                                                      'FIN');
    COMMIT;

    --PROCESO QUE VERIFICA SI HAY ERRORES--
    OPEN C_ERRORES;
    FETCH C_ERRORES
      INTO NUM_ERRORES;
    CLOSE C_ERRORES;

    IF NUM_ERRORES != 0 THEN
      P_MAIL.ENVIO_MAIL_ERROR('P_PROCESOS_NOCTURNOS.P_RECALCULO SALDOS  F A L L O !!!',
                              ' Se corrio procedimiento y genero errores. Verificar en la tabla ERRORES_PROCESO');
    ELSE
      P_MAIL.ENVIO_MAIL_ERROR('P_PROCESOS_NOCTURNOS.P_RECALCULO SALDOS EXITOSO',
                              'Recalculo Saldos : EXITOSO');
    END IF;

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('P_PROCESOS_NOCTURNOS.P_RECALCULO SALDOS',
                              substr(sqlerrm, 1, 80));
  END P_RECALCULO_SALDOS;

  /*************************VAGTUS043686.AjusteModuloCargueListas Cruce de listas de cautela*****************************/
  PROCEDURE P_CALL_GENERA_CRUCE_PER_CAU IS
    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;
    V_ERROR   VARCHAR2(4000);

  BEGIN
    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_CALL_GENERA_CRUCE_PER_CAU',
                                                      'INI');
    P_GENERA_CRUCE_PER_CAU(V_ERROR);
    P_MAIL_CRUCE_CAU_FACT;
    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_CALL_GENERA_CRUCE_PER_CAU',
                                                      'FIN');

    IF LENGTH(V_ERROR) > 0 THEN
      P_MAIL.ENVIO_MAIL_ERROR('P_PROCESOS_NOCTURNOS.P_CALL_GENERA_CRUCE_PER_CAU Finalizado con error.',
                              ' Error: ' || V_ERROR);
    END IF;

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('P_PROCESOS_NOCTURNOS.P_CALL_GENERA_CRUCE_PER_CAU Finalizado con error.',
                              ' Error: ' || SQLERRM);

  END P_CALL_GENERA_CRUCE_PER_CAU;

  PROCEDURE P_MAIL_CRUCE_CAU_FACT IS

    CURSOR C_MAIL IS
      SELECT /*+ PARALLEL(10) */
      DISTINCT P.PER_TID_CODIGO,
               P.PER_NUM_IDEN,
               P.PER_TIPO,
               P.PER_RAZON_SOCIAL,
               P.PER_NOMBRE,
               P.PER_PRIMER_APELLIDO,
               P.PER_SEGUNDO_APELLIDO,
               L.LCC_TID_CODIGO,
               L.LCC_NUM_IDEN,
               L.LCC_NOMBRE,
               L.LCC_TIPO_LISTA,
               L.LCC_OBSERVACIONES,
               CASE
                 WHEN P.PER_TIPO = 'PNA' THEN
                  UTL_MATCH.JARO_WINKLER_SIMILARITY(P.PER_NOMBRE || ' ' ||
                                                    P.PER_PRIMER_APELLIDO || ' ' ||
                                                    P.PER_SEGUNDO_APELLIDO,
                                                    L.LCC_NOMBRE) || '%'
                 ELSE
                  UTL_MATCH.JARO_WINKLER_SIMILARITY(P.Per_Razon_Social,
                                                    L.LCC_NOMBRE) || '%'
               END AS "COINCIDENCIA",
               CASE
                 WHEN P.PER_FACTORING = 'S' THEN
                  'SI'
                 WHEN P.PER_FACTORING = 'N' THEN
                  'NO'
                 ELSE
                  ''
               END AS "FACTORING",
               CASE
                 WHEN P.PER_FACTORING = 'S' THEN
                  'NO'
                 WHEN P.PER_FACTORING = 'N' THEN
                  'NO'
                 ELSE
                  ''
               END AS "EMISOR",
               CASE
                 WHEN P.PER_FACTORING = 'S' THEN
                  'SI'
                 WHEN P.PER_FACTORING = 'N' THEN
                  'NO'
                 ELSE
                  ''
               END AS "PAGADOR",
               CASE
                 WHEN P.PER_ES_BENEFICIARIO = 'S' THEN
                  'SI'
                 WHEN P.PER_ES_BENEFICIARIO = 'N' THEN
                  'NO'
                 ELSE
                  ''
               END AS "BENEFICIARIO"
        FROM PERSONAS P, LISTA_CAUTELA_CLIENTES L
       WHERE ((P.PER_NOMBRE || ' ' || P.PER_PRIMER_APELLIDO = L.LCC_NOMBRE AND
             P.PER_TIPO = 'PNA') OR
             (P.PER_RAZON_SOCIAL = L.LCC_NOMBRE AND P.PER_TIPO = 'PJU'))
         AND P.PER_FACTORING IS NOT NULL
      UNION
      SELECT /*+ PARALLEL(10) */
      DISTINCT P.PER_TID_CODIGO,
               P.PER_NUM_IDEN,
               P.PER_TIPO,
               P.PER_RAZON_SOCIAL,
               P.PER_NOMBRE,
               P.PER_PRIMER_APELLIDO,
               P.PER_SEGUNDO_APELLIDO,
               L.LCC_TID_CODIGO,
               L.LCC_NUM_IDEN,
               L.LCC_NOMBRE,
               L.LCC_TIPO_LISTA,
               L.LCC_OBSERVACIONES,
               CASE
                 WHEN P.PER_TIPO = 'PNA' THEN
                  UTL_MATCH.JARO_WINKLER_SIMILARITY(P.PER_NOMBRE || ' ' ||
                                                    P.PER_PRIMER_APELLIDO || ' ' ||
                                                    P.PER_SEGUNDO_APELLIDO,
                                                    L.LCC_NOMBRE) || '%'
                 ELSE
                  UTL_MATCH.JARO_WINKLER_SIMILARITY(P.Per_Razon_Social,
                                                    L.LCC_NOMBRE) || '%'
               END AS "COINCIDENCIA",
               CASE
                 WHEN P.PER_FACTORING = 'S' THEN
                  'SI'
                 WHEN P.PER_FACTORING = 'N' THEN
                  'NO'
                 ELSE
                  ''
               END AS "FACTORING",
               CASE
                 WHEN P.PER_FACTORING = 'S' THEN
                  'NO'
                 WHEN P.PER_FACTORING = 'N' THEN
                  'NO'
                 ELSE
                  ''
               END AS "EMISOR",
               CASE
                 WHEN P.PER_FACTORING = 'S' THEN
                  'SI'
                 WHEN P.PER_FACTORING = 'N' THEN
                  'NO'
                 ELSE
                  ''
               END AS "PAGADOR",
               CASE
                 WHEN P.PER_ES_BENEFICIARIO = 'S' THEN
                  'SI'
                 WHEN P.PER_ES_BENEFICIARIO = 'N' THEN
                  'NO'
                 ELSE
                  ''
               END AS "BENEFICIARIO"
        FROM PERSONAS P, LISTA_CAUTELA_CLIENTES L
       WHERE P_TOOLS.OBTENER_SUBCADENA_POR_TOKEN(P.PER_NOMBRE, 1, ' ') || ' ' ||
             P.PER_PRIMER_APELLIDO || ' ' || P.PER_SEGUNDO_APELLIDO =
             L.LCC_NOMBRE
         AND P.PER_TIPO = 'PNA'
         AND P.PER_FACTORING IS NOT NULL
      UNION
      SELECT /*+ PARALLEL(10) */
      DISTINCT P.PER_TID_CODIGO,
               P.PER_NUM_IDEN,
               P.PER_TIPO,
               P.PER_RAZON_SOCIAL,
               P.PER_NOMBRE,
               P.PER_PRIMER_APELLIDO,
               P.PER_SEGUNDO_APELLIDO,
               L.LCC_TID_CODIGO,
               L.LCC_NUM_IDEN,
               L.LCC_NOMBRE,
               L.LCC_TIPO_LISTA,
               L.LCC_OBSERVACIONES,
               CASE
                 WHEN P.PER_TIPO = 'PNA' THEN
                  UTL_MATCH.JARO_WINKLER_SIMILARITY(P.PER_NOMBRE || ' ' ||
                                                    P.PER_PRIMER_APELLIDO || ' ' ||
                                                    P.PER_SEGUNDO_APELLIDO,
                                                    L.LCC_NOMBRE) || '%'
                 ELSE
                  UTL_MATCH.JARO_WINKLER_SIMILARITY(P.Per_Razon_Social,
                                                    L.LCC_NOMBRE) || '%'
               END AS "COINCIDENCIA",
               CASE
                 WHEN P.PER_FACTORING = 'S' THEN
                  'SI'
                 WHEN P.PER_FACTORING = 'N' THEN
                  'NO'
                 ELSE
                  ''
               END AS "FACTORING",
               CASE
                 WHEN P.PER_FACTORING = 'S' THEN
                  'NO'
                 WHEN P.PER_FACTORING = 'N' THEN
                  'NO'
                 ELSE
                  ''
               END AS "EMISOR",
               CASE
                 WHEN P.PER_FACTORING = 'S' THEN
                  'SI'
                 WHEN P.PER_FACTORING = 'N' THEN
                  'NO'
                 ELSE
                  ''
               END AS "PAGADOR",
               CASE
                 WHEN P.PER_ES_BENEFICIARIO = 'S' THEN
                  'SI'
                 WHEN P.PER_ES_BENEFICIARIO = 'N' THEN
                  'NO'
                 ELSE
                  ''
               END AS "BENEFICIARIO"
        FROM PERSONAS P, LISTA_CAUTELA_CLIENTES L
       WHERE P_TOOLS.OBTENER_SUBCADENA_POR_TOKEN(P.PER_NOMBRE, 2, ' ') || ' ' ||
             P.PER_PRIMER_APELLIDO || ' ' || P.PER_SEGUNDO_APELLIDO =
             L.LCC_NOMBRE
         AND P.PER_TIPO = 'PNA'
         AND P.PER_FACTORING IS NOT NULL
      --FACTORING
      UNION
      SELECT /*+ PARALLEL(10) */
      DISTINCT 'NIT' PER_TID_CODIGO,
               TO_CHAR(E.EMI_NUMERO_IDENTIFICACION) PER_NUM_IDEN,
               'PJU',
               E.EMI_DESCRIPCION,
               '',
               '',
               '',
               L.LCC_TID_CODIGO,
               L.LCC_NUM_IDEN,
               L.LCC_NOMBRE,
               L.LCC_TIPO_LISTA,
               L.LCC_OBSERVACIONES,
               UTL_MATCH.JARO_WINKLER_SIMILARITY(E.EMI_DESCRIPCION,
                                                 L.LCC_NOMBRE) || '%' "COINCIDENCIA",
               CASE
                 WHEN E.EMI_FACTORING = 'S' THEN
                  'SI'
                 ELSE
                  'NO'
               END AS "FACTORING",
               CASE
                 WHEN E.EMI_FACTORING = 'S' THEN
                  'SI'
                 ELSE
                  'NO'
               END AS "EMISOR",
               CASE
                 WHEN E.EMI_FACTORING = 'S' THEN
                  'NO'
                 ELSE
                  'NO'
               END AS "PAGADOR",
               'NO' AS "BENEFICIARIO"
        FROM EMISORES E, LISTA_CAUTELA_CLIENTES L
       WHERE (E.EMI_DESCRIPCION = L.LCC_NOMBRE)
         AND E.EMI_FACTORING IS NOT NULL
       ORDER BY PER_TID_CODIGO, PER_NUM_IDEN;
    V_MAIL C_MAIL%ROWTYPE;

    P_CLI_PER_TID_CODIGO NOTIFICACIONES_MAIL_CORREDORES.NMC_CLI_PER_TID_CODIGO%TYPE;
    P_CLI_PER_NUM_IDEN   NOTIFICACIONES_MAIL_CORREDORES.NMC_CLI_PER_NUM_IDEN%TYPE;
    P_SERVICIO           NOTIFICACIONES_MAIL_CORREDORES.NMC_SERVICIO%TYPE;
    P_DE                 NOTIFICACIONES_MAIL_CORREDORES.NMC_DE%TYPE;
    P_PARA               NOTIFICACIONES_MAIL_CORREDORES.NMC_PARA%TYPE;
    P_ASUNTO             NOTIFICACIONES_MAIL_CORREDORES.NMC_ASUNTO%TYPE;
    P_MENSAJE            NOTIFICACIONES_MAIL_CORREDORES.NMC_CUERPO%TYPE;
    P_CLOB               CLOB;
    P_MENSAJE_CLOB       CLOB;
    V_ARCHIVO            VARCHAR2(150);
    V_LINEA              VARCHAR2(4000);
    OUT_FILE             UTL_FILE.FILE_TYPE;
    V_RESULTADO          VARCHAR2(20);
    V_LISTA              VARCHAR2(20);

  BEGIN

    V_ARCHIVO := 'CRUCE_PERSONAS_LISTAS_' ||
                 TO_CHAR(SYSDATE - 1, 'DDMONYYYY') || '.csv';
    OUT_FILE  := UTL_FILE.FOPEN('NTFMAILATT', V_ARCHIVO, 'W');
    V_LINEA   := 'TIPO_IDENTIFICACION' || ';' || 'NUM_IDENTIFICACION' || ';' ||
                 'TIPO' || ';' || 'RAZON_SOCIAL' || ';' || 'NOMBRE' || ';' ||
                 'PRIMER_APELLIDO' || ';' || 'SEGUNDO_APELLIDO' || ';' ||
                 'LCC_TIPO_IDENTIFICACION' || ';' ||
                 'LCC_NUM_IDENTIFICACION' || ';' || 'LCC_NOMBRE' || ';' ||
                 'LCC_TIPO_LISTA' || ';' || 'LCC_OBSERVACIONES' || ';' ||
                 'COINCIDENCIA' || ';' || 'FACTORING' || ';' || 'EMISOR' || ';' ||
                 'PAGADOR' || ';' || 'BENEFICIARIO' || ';' || 'LISTA';
    UTL_FILE.PUTF(OUT_FILE, '%s\n', V_LINEA);
    OPEN C_MAIL;
    FETCH C_MAIL
      INTO V_MAIL;

    IF C_MAIL%FOUND THEN
      WHILE C_MAIL%FOUND LOOP
        P_UTILIDADES.PR_VALIDA_LISTAS_CAUTELA(V_MAIL.PER_NUM_IDEN,
                                              V_RESULTADO,
                                              V_LISTA);
        V_LINEA := V_MAIL.PER_TID_CODIGO || ';' || V_MAIL.PER_NUM_IDEN || ';' ||
                   V_MAIL.PER_TIPO || ';' || V_MAIL.PER_RAZON_SOCIAL || ';' ||
                   V_MAIL.PER_NOMBRE || ';' || V_MAIL.PER_PRIMER_APELLIDO || ';' ||
                   V_MAIL.PER_SEGUNDO_APELLIDO || ';' ||
                   V_MAIL.LCC_TID_CODIGO || ';' || V_MAIL.LCC_NUM_IDEN || ';' ||
                   V_MAIL.LCC_NOMBRE || ';' || V_MAIL.LCC_TIPO_LISTA || ';' ||
                   V_MAIL.LCC_OBSERVACIONES || ';' || V_MAIL.COINCIDENCIA || ';' ||
                   V_MAIL.FACTORING || ';' || V_MAIL.EMISOR || ';' ||
                   V_MAIL.PAGADOR || ';' || V_MAIL.BENEFICIARIO || ';' ||
                   V_LISTA;
        UTL_FILE.PUTF(OUT_FILE, '%s\n', V_LINEA);
        FETCH C_MAIL
          INTO V_MAIL;
      END LOOP;
      CLOSE C_MAIL;

      UTL_FILE.FCLOSE(OUT_FILE);
      P_CLI_PER_TID_CODIGO := '0';
      P_CLI_PER_NUM_IDEN   := '0';
      P_SERVICIO           := 'CRUCE_PERSONAS_LISTAS';
      P_DE                 := 'notificaciones@corredores.com';
      P_PARA               := 'sarlaft@corredores.com,jsalcedop@corredores.com';
      P_ASUNTO             := 'Notificaciżn Cruce Listas de Cautela Facoring';
      P_MENSAJE            := 'Se presenta coincidencia en las listas de cautela con los siguientes Emisores/Pagadores:<br/><br/>';
      P_MENSAJE            := P_MENSAJE ||
                              'Por favor validar si los Emisores/Pagadores deben desactivarse. <br/>';
      P_NOTIFICACIONES_MAIL.PR_ENVIO_MAIL(P_CLI_PER_TID_CODIGO,
                                          P_CLI_PER_NUM_IDEN,
                                          P_SERVICIO,
                                          P_DE,
                                          P_PARA,
                                          P_ASUNTO,
                                          P_MENSAJE,
                                          P_CLOB,
                                          P_MENSAJE_CLOB,
                                          V_ARCHIVO);

    ELSE
      CLOSE C_MAIL;
    END IF;

  END P_MAIL_CRUCE_CAU_FACT;

  /**********************************************************************************************************************/

  /*************************VAGTUS045614.ControlInformacionCierrePortafolios*********************************************/
  PROCEDURE P_CALL_VERIFICA_CIERRE IS
    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;
    V_FECHA   VARCHAR2(255);
    V_ERROR   VARCHAR2(2);
    V_MENSAJE VARCHAR2(4000);

  BEGIN
    SELECT TO_CHAR(SYSDATE - 1, 'dd/mm/yyyy') INTO V_FECHA FROM DUAL;

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_CALL_VERIFICA_CIERRE',
                                                      'INI');
    P_VERIFICA_CIERRE.PR_MAIL_VRFCIERRE(P_FECHA   => V_FECHA,
                                        P_ERROR   => V_ERROR,
                                        P_MENSAJE => V_MENSAJE);
    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_CALL_VERIFICA_CIERRE',
                                                      'FIN');

    IF V_ERROR = 'S' THEN
      P_MAIL.ENVIO_MAIL_ERROR('P_PROCESOS_NOCTURNOS.P_CALL_VERIFICA_CIERRE Finalizado con error.',
                              ' Error: ' || V_MENSAJE);
    END IF;

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('P_PROCESOS_NOCTURNOS.P_CALL_VERIFICA_CIERRE Finalizado con error.',
                              ' Error: ' || SQLERRM);

  END P_CALL_VERIFICA_CIERRE;

  /**********************************************************************************************************************/

  /**********************VAGTUS048046.AutomatizacionProcesoInactivacionClientes******************************************/
  PROCEDURE P_CALL_INACTIVAR_CLIENTES IS
    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;
    V_FECHA   VARCHAR2(256);
    V_USUARIO VARCHAR2(256);
    V_CNTINAC NUMBER;
    V_ERROR   VARCHAR2(2);
    V_MENSAJE VARCHAR2(4000);

    V_FECEX DATE;
    V_FRSTD DATE;
    V_LASTD DATE;
    V_HABIL CHAR := 'N';

  BEGIN
    SELECT TRUNC(SYSDATE) INTO V_FECEX FROM DUAL;

    --determina el primer dia habil del mes.
    BEGIN
      SELECT TRUNC(SYSDATE) - (TO_NUMBER(TO_CHAR(SYSDATE, 'DD')) - 1)
        INTO V_FRSTD
        FROM DUAL;
      SELECT LAST_DAY(SYSDATE) INTO V_LASTD FROM DUAL;

      V_HABIL := P_TOOLS.FN_ES_DIA_HABIL(V_FRSTD);

      WHILE V_HABIL = 'N' AND V_FRSTD <= V_LASTD LOOP
        V_FRSTD := V_FRSTD + 1;
        V_HABIL := P_TOOLS.FN_ES_DIA_HABIL(V_FRSTD);
      END LOOP;

    EXCEPTION
      WHEN OTHERS THEN
        V_ERROR   := 'S';
        V_MENSAJE := 'No se pudo determinar si es primer dia habil del mes ' ||
                     SQLCODE;
    END;

    --Solo si es el primer dia habil se ejecuta
    IF V_FECEX = V_FRSTD THEN
      V_USUARIO := USER;
      SELECT ADD_MONTHS(V_FECEX, -13) INTO V_FECHA FROM DUAL;

      P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_CALL_INACTIVAR_CLIENTES',
                                                        'INI');
      PROD.P_CLIENTES.PR_INACTIVAR_CLIENTES(P_FECHA   => V_FECHA,
                                            P_USUARIO => V_USUARIO,
                                            P_CNTINAC => V_CNTINAC,
                                            P_ERROR   => V_ERROR,
                                            P_MENSAJE => V_MENSAJE);
      P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_CALL_INACTIVAR_CLIENTES',
                                                        'FIN');
    ELSE
      V_ERROR   := 'N';
      V_MENSAJE := 'Este proceso solo se puede ejecutar el primer dża hżbil del mes';
    END IF;

    IF V_ERROR = 'S' THEN
      P_MAIL.ENVIO_MAIL_ERROR('P_PROCESOS_NOCTURNOS.P_CALL_INACTIVAR_CLIENTES Finalizado con error.',
                              ' Error: ' || V_MENSAJE);
    END IF;

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('P_PROCESOS_NOCTURNOS.P_CALL_INACTIVAR_CLIENTES Finalizado con error.',
                              ' Error: ' || SQLERRM);

  END P_CALL_INACTIVAR_CLIENTES;

  /**********************************************************************************************************************/

  /*************************VAGTUS045745.ReporteInformacionDavivienda****************************************************/
  PROCEDURE P_CALL_GNRA_REPCIERRE IS
    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;
    V_FECHA   VARCHAR2(64);
    V_USUARIO VARCHAR2(64);
    V_ERROR   VARCHAR2(2);
    V_MENSAJE VARCHAR2(4000);

  BEGIN
    SELECT TO_CHAR(SYSDATE - 1, 'dd/mm/yyyy') FECHA, USER USUARIO
      INTO V_FECHA, V_USUARIO
      FROM DUAL;

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_CALL_GNRA_REPCIERRE',
                                                      'INI');
    P_VERIFICA_CIERRE.PR_GNRA_REPCIERRE(P_REPORTE => NULL,
                                        P_FECHA   => V_FECHA,
                                        P_USUARIO => V_USUARIO,
                                        P_ERROR   => V_ERROR,
                                        P_MENSAJE => V_MENSAJE);
    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_CALL_GNRA_REPCIERRE',
                                                      'FIN');

    IF V_ERROR = 'S' THEN
      P_MAIL.ENVIO_MAIL_ERROR('P_PROCESOS_NOCTURNOS.P_CALL_GNRA_REPCIERRE Finalizado con error.',
                              ' Error: ' || V_MENSAJE);
    END IF;

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('P_PROCESOS_NOCTURNOS.P_CALL_GNRA_REPCIERRE Finalizado con error.',
                              ' Error: ' || SQLERRM);

  END P_CALL_GNRA_REPCIERRE;

  /**********************************************************************************************************************/

  -------------------------------------REPORTES PLANO INTEGRADO V------------------------------------
  FUNCTION NUMERO_OPE_OBLIG(P_FONDO      VARCHAR2,
                            P_TITULO     NUMBER,
                            P_TITULO_OBL NUMBER) RETURN NUMBER IS

    CURSOR C_MOVIMIENTO(FONDO VARCHAR, TITULO NUMBER) IS
      SELECT DISTINCT MRF_TMT_MNEMONICO
        FROM MVTOS_RENTA_FIJA
       WHERE MRF_TFO_FON_CODIGO = FONDO
         AND MRF_TFO_CODIGO = TITULO
         AND MRF_TMT_MNEMONICO IN ('FPA', 'DCO', 'FPF');
    MRF1 C_MOVIMIENTO%ROWTYPE;

    V_ENA_MNEMO           VARCHAR2(20);
    V_NIT                 VARCHAR2(20);
    V_TITULO              NUMBER;
    V_PRC_PRF_CONSECUTIVO NUMBER;
    V_PRC_CONSECUTIVO     NUMBER;
    V_PRV_PRF_CONSECUTIVO NUMBER;
    V_PRV_CONSECUTIVO     NUMBER;
    V_NUMERO_OP           NUMBER;
    NUMERO_OP_OBLIG       NUMBER;

  BEGIN
    BEGIN
      SELECT TFO_FON_CODIGO,
             TFO_CODIGO,
             TFO_PRC_PRF_CONSECUTIVO,
             TFO_PRC_CONSECUTIVO,
             TFO_PRV_PRF_CONSECUTIVO,
             TFO_PRV_CONSECUTIVO
        INTO V_NIT,
             V_TITULO,
             V_PRC_PRF_CONSECUTIVO,
             V_PRC_CONSECUTIVO,
             V_PRV_PRF_CONSECUTIVO,
             V_PRV_CONSECUTIVO
        FROM (SELECT TFO_FON_CODIGO,
                     TFO_CODIGO,
                     TFO_PRC_PRF_CONSECUTIVO,
                     TFO_PRC_CONSECUTIVO,
                     TFO_PRV_PRF_CONSECUTIVO,
                     TFO_PRV_CONSECUTIVO
                FROM MVTOS_RENTA_FIJA, TITULOS_FONDOS, FONDOS
               WHERE TFO_FON_CODIGO = FON_CODIGO
                 AND TFO_FON_CODIGO = MRF_TFO_FON_CODIGO
                 AND TFO_CODIGO = MRF_TFO_CODIGO
                 AND MRF_FECHA_VALORIZACION IS NOT NULL
                 AND TFO_CODIGO = P_TITULO_OBL
                 AND TFO_FON_CODIGO = P_FONDO
                 AND NOT EXISTS (SELECT 'X'
                        FROM FONDOS, PARAMETROS_FONDOS
                       WHERE PFO_FON_CODIGO = FON_CODIGO
                         AND PFO_PAR_CODIGO in (70)
                         AND NVL(PFO_RANGO_MIN_CHAR, 'N') = 'S'
                         AND FON_CODIGO = TFO_FON_CODIGO)
                 AND ROWNUM = 1);
    EXCEPTION
      WHEN NO_DATA_FOUND THEN
        V_NIT                 := NULL;
        V_TITULO              := NULL;
        V_PRC_PRF_CONSECUTIVO := NULL;
        V_PRC_CONSECUTIVO     := NULL;
        V_PRV_PRF_CONSECUTIVO := NULL;
        V_PRV_CONSECUTIVO     := NULL;
    END;

    BEGIN
      SELECT PRC_NUMERO_OPERACION
        INTO NUMERO_OP_OBLIG
        FROM (SELECT PRV_NUMERO_OPERACION PRC_NUMERO_OPERACION
                FROM PREORDENES_FONDOS, PREORDENES_VENTA
               WHERE PRF_FON_CODIGO = PRV_PRF_FON_CODIGO
                 AND PRF_CONSECUTIVO = PRV_PRF_CONSECUTIVO
                 AND PRV_PRF_FON_CODIGO = V_NIT
                 AND PRV_PRF_CONSECUTIVO = V_PRV_PRF_CONSECUTIVO
                 AND PRV_CONSECUTIVO = V_PRV_CONSECUTIVO
              UNION
              SELECT PRC_NUMERO_OPERACION
                FROM PREORDENES_FONDOS, PREORDENES_COMPRA
               WHERE PRF_FON_CODIGO = PRC_PRF_FON_CODIGO
                 AND PRF_CONSECUTIVO = PRC_PRF_CONSECUTIVO
                 AND PRC_PRF_FON_CODIGO = V_NIT
                 AND PRC_PRF_CONSECUTIVO = V_PRC_PRF_CONSECUTIVO
                 AND PRC_CONSECUTIVO = V_PRC_CONSECUTIVO)
       WHERE ROWNUM = 1;
    EXCEPTION
      WHEN NO_DATA_FOUND THEN
        NUMERO_OP_OBLIG := NULL;
    END;

    RETURN NUMERO_OP_OBLIG;
  END NUMERO_OPE_OBLIG;

  FUNCTION VALORIZACION_OBL(P_FECHA  DATE,
                            P_TITULO NUMBER,
                            P_FONDO  VARCHAR2,
                            P_ENA    VARCHAR2) RETURN NUMBER IS
    VALORIZACION     NUMBER;
    VLR_DERECHO      NUMBER;
    VLR_OBLIGACION   NUMBER;
    V_TIR            NUMBER;
    V_FONDO          VARCHAR2(20);
    V_BMO            NUMBER;
    V_BASE_MONETARIA VARCHAR2(20);
    VALORIZACION_OBL NUMBER;
  BEGIN
    BEGIN
      SELECT DISTINCT MRF_TIR365_M
        INTO V_TIR
        FROM MVTOS_RENTA_FIJA
       WHERE MRF_TFO_CODIGO = P_TITULO
         AND MRF_FECHA >= TRUNC(P_FECHA)
         AND MRF_FECHA < TRUNC(P_FECHA + 1)
         AND ROWNUM = 1;
    EXCEPTION
      WHEN NO_DATA_FOUND THEN
        V_TIR := 0;
    END;

    BEGIN
      SELECT DISTINCT TFO_BMO_MNEMONICO
        INTO V_BASE_MONETARIA
        FROM TITULOS_FONDOS
       WHERE TFO_CODIGO = P_TITULO
         AND TFO_FON_CODIGO = P_FONDO
         AND TFO_ENA_MNEMONICO = P_ENA;
    EXCEPTION
      WHEN NO_DATA_FOUND THEN
        V_BASE_MONETARIA := NULL;
    END;

    BEGIN
      SELECT NVL(P_TITULOS.VPN_TIT_M365_RF_MG(P_FONDO,
                                              P_TITULO,
                                              0,
                                              P_FECHA,
                                              V_TIR),
                 0)
        INTO VALORIZACION
        FROM DUAL;
    EXCEPTION
      WHEN NO_DATA_FOUND THEN
        VALORIZACION := 0;
    END;

    BEGIN
      SELECT ROUND(CBM_VALOR * VALORIZACION, 2)
        INTO V_BMO
        FROM COTIZACIONES_BASE_MONETARIAS
       WHERE CBM_BMO_MNEMONICO = V_BASE_MONETARIA
         AND CBM_FECHA >= TRUNC(P_FECHA)
         AND CBM_FECHA < TRUNC(P_FECHA + 1)
         AND ROWNUM = 1;
    EXCEPTION
      WHEN NO_DATA_FOUND THEN
        V_BMO := 0;
    END;

    RETURN V_BMO;
  END;

  FUNCTION TITULO_OBL(P_TITULO NUMBER, P_FONDO VARCHAR2) RETURN NUMBER IS
    V_CONSEC   NUMBER;
    V_CONS_TFO NUMBER;
    TITULO_OBL NUMBER;
  BEGIN
    BEGIN
      SELECT DECODE(TFO_PRC_PRF_CONSECUTIVO,
                    NULL,
                    TFO_PRV_PRF_CONSECUTIVO,
                    TFO_PRC_PRF_CONSECUTIVO),
             DECODE(TFO_PRV_CONSECUTIVO,
                    NULL,
                    TFO_PRC_CONSECUTIVO,
                    TFO_PRV_CONSECUTIVO)
        INTO V_CONSEC, V_CONS_TFO
        FROM TITULOS_FONDOS
       WHERE TFO_CODIGO = P_TITULO
         AND TFO_FON_CODIGO = P_FONDO
         AND ROWNUM = 1;

    EXCEPTION
      WHEN NO_DATA_FOUND THEN
        V_CONSEC := 0;
    END;

    BEGIN
      TITULO_OBL := NULL;

      SELECT TFO_CODIGO
        INTO TITULO_OBL
        FROM TITULOS_FONDOS
       WHERE (TFO_PRC_PRF_CONSECUTIVO = V_CONSEC OR
             TFO_PRV_PRF_CONSECUTIVO = V_CONSEC)
         AND TFO_ETI_CODIGO <> 'VEN'
         AND TFO_CODIGO <> P_TITULO
         AND TFO_FON_CODIGO = P_FONDO
         AND (TFO_PRV_CONSECUTIVO = V_CONS_TFO OR
             TFO_PRC_CONSECUTIVO = V_CONS_TFO)
         AND ROWNUM = 1
       ORDER BY TFO_CODIGO ASC;

      RETURN TITULO_OBL;

    EXCEPTION
      WHEN NO_DATA_FOUND THEN
        TITULO_OBL := NULL;
    END;

  END TITULO_OBL;

  FUNCTION VALORIZACION(P_FONDO  VARCHAR2,
                        P_TITULO NUMBER,
                        P_FECHA  DATE,
                        P_365    NUMBER,
                        P_BMO    VARCHAR2) RETURN NUMBER IS
    VALORIZACION     NUMBER;
    VLR_DERECHO      NUMBER;
    VLR_OBLIGACION   NUMBER;
    V_BMO            NUMBER;
    VALORIZACION_DER NUMBER;
  BEGIN
    SELECT NVL(P_TITULOS.VPN_TIT_M365_RF_MG(P_FONDO,
                                            P_TITULO,
                                            0,
                                            P_FECHA,
                                            P_365),
               0)
      INTO VALORIZACION
      FROM DUAL;

    IF P_BMO != 'PESOS' THEN
      SELECT CBM_VALOR
        INTO V_BMO
        FROM COTIZACIONES_BASE_MONETARIAS
       WHERE CBM_BMO_MNEMONICO = P_BMO
         AND CBM_FECHA >= TRUNC(P_FECHA)
         AND CBM_FECHA < TRUNC(P_FECHA + 1);

      VALORIZACION_DER := VALORIZACION * V_BMO;
    ELSE
      VALORIZACION_DER := VALORIZACION;
    END IF;

    RETURN VALORIZACION_DER;
  END VALORIZACION;

  FUNCTION FECHA_ORIG_CUMPLI(P_TITULO NUMBER) RETURN DATE IS
    CURSOR C_FECHA_PRC(TITULO NUMBER) IS
      SELECT MIN(AAP_FECHA_ANTERIOR) FECHA_INICIO
        FROM APLAZAMIENTOS_ANTICIPOS_PREORD, TITULOS_FONDOS
       WHERE AAP_PRF_CONSECUTIVO = TFO_PRC_PRF_CONSECUTIVO
         AND AAP_PRC_CONSECUTIVO = TFO_PRC_CONSECUTIVO
         AND TFO_BMO_MNEMONICO = 'DOLAR'
         AND TFO_CODIGO = TITULO
         AND AAP_ESTADO = 'APR';

    CURSOR C_FECHA_PRV(TITULO NUMBER) IS
      SELECT MIN(AAP_FECHA_ANTERIOR) FECHA_INICIO
        FROM APLAZAMIENTOS_ANTICIPOS_PREORD, TITULOS_FONDOS
       WHERE AAP_PRF_CONSECUTIVO = TFO_PRV_PRF_CONSECUTIVO
         AND AAP_PRV_CONSECUTIVO = TFO_PRV_CONSECUTIVO
         AND TFO_BMO_MNEMONICO = 'DOLAR'
         AND TFO_CODIGO = TITULO
         AND AAP_ESTADO = 'APR';

    FECHA_CUMPLIMIENTO DATE;
  BEGIN
    OPEN C_FECHA_PRC(P_TITULO);
    FETCH C_FECHA_PRC
      INTO FECHA_CUMPLIMIENTO;
    CLOSE C_FECHA_PRC;

    IF FECHA_CUMPLIMIENTO IS NULL THEN
      OPEN C_FECHA_PRV(P_TITULO);
      FETCH C_FECHA_PRV
        INTO FECHA_CUMPLIMIENTO;
      CLOSE C_FECHA_PRV;
    END IF;

    RETURN FECHA_CUMPLIMIENTO;
  END FECHA_ORIG_CUMPLI;

  PROCEDURE GENERA_RECOFU_TODOS IS
    CURSOR C_COMPRAS IS
      SELECT FON.FON_RAZON_SOCIAL,
             EMI.EMI_DESCRIPCION,
             TFO.TFO_ENA_MNEMONICO,
             ENA.ENA_DESCRIPCION,
             TFO.TFO_VALOR_NOMINAL,
             TFO.TFO_FECHA_EMISION,
             TFO.TFO_FECHA_VENCIMIENTO TFO_FECHA_VENCIMIENTO,
             DECODE(TFO.TFO_TASA_FACIAL,
                    NULL,
                    TFO.TFO_TRE_MNEMONICO || ' + ' ||
                    TO_CHAR(TFO.TFO_PUNTOS_ADICIONALES),
                    TO_CHAR(TFO.TFO_TASA_FACIAL * 100)) INTERES_NOMINAL,
             DECODE(TFO.TFO_PERIODICIDAD_TASA,
                    30,
                    'M',
                    60,
                    'B',
                    90,
                    'T',
                    120,
                    'C',
                    180,
                    'S',
                    360,
                    'A',
                    365,
                    'A',
                    'P') || TFO.TFO_MODALIDAD_TASA MODALIDAD,
             TFO.TFO_BMO_MNEMONICO,
             TFO.TFO_CODIGO,
             MRF.MRF_VALOR_TITULO_TM MRF_VALOR_TITULO_TM,
             NVL(MRF.MRF_FECHA_VALORIZACION, MRF.MRF_FECHA) MRF_FECHA_VALORIZACION,
             TFO.TFO_FON_CODIGO TFO_FON_CODIGO,
             TFO.TFO_PRC_PRF_CONSECUTIVO TFO_PRC_PRF_CONSECUTIVO,
             TFO.TFO_PRC_CONSECUTIVO TFO_PRC_CONSECUTIVO,
             TFO.TFO_PRV_PRF_CONSECUTIVO TFO_PRV_PRF_CONSECUTIVO,
             TFO.TFO_PRV_CONSECUTIVO TFO_PRV_CONSECUTIVO,
             TFO.TFO_VALOR_OPERACION TFO_VALOR_OPERACION,
             MRF_TIR365_M,
             MRF.MRF_FECHA FECHA
        FROM FONDOS              FON,
             EMISORES            EMI,
             ESPECIES_NACIONALES ENA,
             TITULOS_FONDOS      TFO,
             MVTOS_RENTA_FIJA    MRF
       WHERE FON.FON_CODIGO = TFO.TFO_FON_CODIGO
         AND EMI.EMI_MNEMONICO = ENA.ENA_EMI_MNEMONICO
         AND ENA.ENA_MNEMONICO = TFO.TFO_ENA_MNEMONICO
         AND NVL(ENA.ENA_YANKEE, 'N') IN ('N', 'S')
         AND EXISTS
       (SELECT 'X'
                FROM MVTOS_RENTA_FIJA MRF1
               WHERE MRF1.MRF_TFO_FON_CODIGO = TFO.TFO_FON_CODIGO
                 AND MRF1.MRF_TFO_CODIGO = TFO.TFO_CODIGO
                 AND MRF1.MRF_TMT_MNEMONICO IN ('FPA', 'DCO'))
         AND TFO.TFO_FON_CODIGO = MRF.MRF_TFO_FON_CODIGO
         AND TFO.TFO_CODIGO = MRF.MRF_TFO_CODIGO
         AND MRF.MRF_FECHA >= SYSDATE - 1
         AND MRF.MRF_FECHA < SYSDATE
         AND ('Cierre Dia' = 'Cierre Dia' AND
             MRF.MRF_FECHA =
             (SELECT MAX(MRF2.MRF_FECHA)
                 FROM MVTOS_RENTA_FIJA MRF2
                WHERE MRF2.MRF_TFO_FON_CODIGO = MRF.MRF_TFO_FON_CODIGO
                  AND MRF2.MRF_TFO_CODIGO = MRF.MRF_TFO_CODIGO
                  AND MRF2.MRF_FECHA >= SYSDATE - 1
                  AND MRF2.MRF_FECHA < SYSDATE) AND
             ((EXISTS
              (SELECT 'X'
                   FROM CONFIRMACION_FONDOS_DIA
                  WHERE CFD_FON_CODIGO = TFO_FON_CODIGO
                    AND CFD_FECHA >= SYSDATE
                    AND CFD_FECHA < SYSDATE + 1
                    AND CFD_VALORIZACION_PORTAFOLIO = 'S') AND EXISTS
              (SELECT 'X'
                   FROM MVTOS_RENTA_FIJA MRF3
                  WHERE MRF3.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                    AND MRF3.MRF_TFO_CODIGO = TFO_CODIGO
                    AND MRF3.MRF_FECHA >= SYSDATE
                    AND MRF3.MRF_FECHA < SYSDATE + 1
                    AND MRF3.MRF_TMT_MNEMONICO = 'VAF') AND
              TFO_FECHA_OPERACION < SYSDATE) OR
             (NOT EXISTS (SELECT 'X'
                              FROM CONFIRMACION_FONDOS_DIA
                             WHERE CFD_FON_CODIGO = TFO_FON_CODIGO
                               AND CFD_FECHA >= SYSDATE
                               AND CFD_FECHA < SYSDATE + 1
                               AND CFD_VALORIZACION_PORTAFOLIO = 'S') AND
              TFO_DIA_SIGUIENTE = 'S') OR
             (EXISTS
              (SELECT 'X'
                   FROM MVTOS_RENTA_FIJA MRF4
                  WHERE MRF4.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                    AND MRF4.MRF_TFO_CODIGO = TFO_CODIGO
                    AND MRF4.MRF_FECHA >= SYSDATE - 1
                    AND MRF4.MRF_FECHA < SYSDATE
                    AND MRF4.MRF_TMT_MNEMONICO IN ('VAF', 'CRF')
                    AND MRF4.MRF_FECHA =
                        (SELECT MAX(MRF5.MRF_FECHA)
                           FROM MVTOS_RENTA_FIJA MRF5
                          WHERE MRF5.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                            AND MRF5.MRF_TFO_CODIGO = TFO_CODIGO)) AND
              TFO_ETI_CODIGO IN ('UNI', 'FRC') AND EXISTS
              (SELECT 'X'
                   FROM MVTOS_RENTA_FIJA MRF4, FRACCIONAMIENTOS_UNIFICACIONES
                  WHERE MRF4.MRF_TFO_FON_CODIGO =
                        FUN_TFO_FON_CODIGO_ES_PRODUCID
                    AND MRF4.MRF_TFO_CODIGO = FUN_TFO_CODIGO_ES_PRODUCIDA
                    AND MRF4.MRF_FECHA >= SYSDATE
                    AND MRF4.MRF_FECHA < SYSDATE + 1
                    AND MRF4.MRF_TMT_MNEMONICO IN
                        ('UNI', 'FRA', 'DCO', 'OCO', 'OVE', 'DVE')
                    AND FUN_TFO_FON_CODIGO = TFO_FON_CODIGO
                    AND FUN_TFO_CODIGO = TFO_CODIGO))))
       ORDER BY 4, 3;

    CURSOR RANGO_FECHAS IS
      SELECT DISTINCT TRUNC(MRF_FECHA) FECHA
        FROM MVTOS_RENTA_FIJA
       WHERE TRUNC(MRF_FECHA) >= SYSDATE
         AND TRUNC(MRF_FECHA) < SYSDATE + 1;

    CURSOR C_PARAMETRO(P_FONDO VARCHAR2) IS
      SELECT 'X'
        FROM PARAMETROS_FONDOS
       WHERE PFO_FON_CODIGO = P_FONDO
         AND PFO_PAR_CODIGO IN (19, 27);
    POS_POP VARCHAR2(1);

    CURSOR C_COTIZACION(P_FECHA DATE, P_BMO VARCHAR2) IS
      SELECT CBM_VALOR
        FROM COTIZACIONES_BASE_MONETARIAS
       WHERE CBM_BMO_MNEMONICO = P_BMO
         AND CBM_FECHA >= TRUNC(P_FECHA)
         AND CBM_FECHA < TRUNC(P_FECHA + 1);
    CBM1 C_COTIZACION%ROWTYPE;

    CURSOR C_MOVIMIENTO(P_FONDO VARCHAR2, P_TITULO NUMBER) IS
      SELECT MRF_TMT_MNEMONICO
        FROM MVTOS_RENTA_FIJA
       WHERE MRF_TFO_FON_CODIGO = P_FONDO
         AND MRF_TFO_CODIGO = P_TITULO
         AND MRF_TMT_MNEMONICO IN ('FPA', 'DCO');
    MRF1 C_MOVIMIENTO%ROWTYPE;

    CURSOR C_NEGOCIO(P_FONDO VARCHAR, P_PRC_PRF NUMBER, P_PRC NUMBER) IS
      SELECT DECODE(PRC_CNE_MNEMONICO,
                    'CON',
                    'CONT',
                    'PLZ',
                    'PRF',
                    'CAR',
                    'CARR',
                    'SWP',
                    'SWAP',
                    PRC_CNE_MNEMONICO) PRC_CNE_MNEMONICO,
             PRC_BOL_MNEMONICO,
             PRF_FECHA_OPERACION,
             PRC_FECHA_CUMPLIMIENTO,
             PRC_MONTO,
             PRC_CLI_PER_NUM_IDEN,
             PRC_CLI_PER_TID_CODIGO,
             PRC_PER_NUM_IDEN_CONTRAPARTE,
             PRC_PER_TID_CODIGO_CONTRAPARTE,
             PRC_PRF_CONSECUTIVO,
             PRC_NUMERO_OPERACION,
             PRC_REGISTRA_CLIENTE
        FROM PREORDENES_FONDOS, PREORDENES_COMPRA
       WHERE PRF_FON_CODIGO = PRC_PRF_FON_CODIGO
         AND PRF_CONSECUTIVO = PRC_PRF_CONSECUTIVO
         AND PRC_PRF_FON_CODIGO = P_FONDO
         AND PRC_PRF_CONSECUTIVO = P_PRC_PRF
         AND PRC_CONSECUTIVO = P_PRC;
    PRC1 C_NEGOCIO%ROWTYPE;

    CURSOR C_NEGOCIO_V(P_FONDO VARCHAR, P_PRV_PRF NUMBER, P_PRV NUMBER) IS
      SELECT DECODE(PRC_CNE_MNEMONICO,
                    'CON',
                    'CONT',
                    'PLZ',
                    'PRF',
                    'CAR',
                    'CARR',
                    'SWP',
                    'SWAP',
                    PRC_CNE_MNEMONICO) PRC_CNE_MNEMONICO,
             PRC_BOL_MNEMONICO,
             PRF_FECHA_OPERACION,
             PRV_FECHA_COMPRA_FUTURA,
             PRV_TASA_FUTURA,
             PRV_MONTO,
             PRV_VALOR_FUTURO,
             PRC_CLI_PER_NUM_IDEN,
             PRC_CLI_PER_TID_CODIGO,
             PRC_PER_NUM_IDEN_CONTRAPARTE,
             PRC_PER_TID_CODIGO_CONTRAPARTE,
             PRV_PRF_CONSECUTIVO,
             PRC_NUMERO_OPERACION PRC_NUMERO_OPERACION,
             PRC_REGISTRA_CLIENTE
        FROM PREORDENES_COMPRA, PREORDENES_FONDOS, PREORDENES_VENTA
       WHERE PRC_PRF_FON_CODIGO = PRV_PRF_FON_CODIGO
         AND PRC_PRF_CONSECUTIVO = PRV_PRC_PRF_CONSECUTIVO
         AND PRC_CONSECUTIVO = PRV_PRC_CONSECUTIVO
         AND PRF_FON_CODIGO = PRV_PRF_FON_CODIGO
         AND PRF_CONSECUTIVO = PRV_PRF_CONSECUTIVO
         AND PRV_PRF_FON_CODIGO = P_FONDO
         AND PRV_PRF_CONSECUTIVO = P_PRV_PRF
         AND PRV_CONSECUTIVO = P_PRV;
    PRV1 C_NEGOCIO_V%ROWTYPE;

    CURSOR C_CONTRAPARTE(P_PER_NUM_IDEN   VARCHAR2,
                         P_PER_TID_CODIGO VARCHAR2) IS
      SELECT PER_NOMBRE, PER_TIPO
        FROM FILTRO_PERSONAS
       WHERE PER_NUM_IDEN = P_PER_NUM_IDEN
         AND PER_TID_CODIGO = P_PER_TID_CODIGO;
    TIPO VARCHAR2(5);

    CURSOR C_COMERCIAL(P_FONDO VARCHAR2, P_CONSECUTIVO NUMBER) IS
      SELECT PER_INICIALES_USUARIO
        FROM PERSONAS, PARTICIPACIONES_PREORDENES
       WHERE PER_NUM_IDEN = PAP_PER_NUM_IDEN
         AND PER_TID_CODIGO = PAP_PER_TID_CODIGO
         AND PAP_PRF_FON_CODIGO = P_FONDO
         AND PAP_PRF_CONSECUTIVO = P_CONSECUTIVO;
    PER1 C_COMERCIAL%ROWTYPE;

    CURSOR C_EFECTIVO(P_FECHA   DATE,
                      P_FONDO   VARCHAR2,
                      P_PRC_PRF NUMBER,
                      P_PRC     NUMBER) IS
      SELECT MRF.MRF_VALOR_TITULO_TM
        FROM MVTOS_RENTA_FIJA MRF, TITULOS_FONDOS
       WHERE MRF.MRF_FECHA >= TRUNC(P_FECHA)
         AND MRF.MRF_FECHA < TRUNC(P_FECHA + 1)
         AND MRF.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
         AND MRF.MRF_TFO_CODIGO = TFO_CODIGO
         AND TFO_FON_CODIGO = P_FONDO
         AND TFO_PRC_PRF_CONSECUTIVO = P_PRC_PRF
         AND TFO_PRC_CONSECUTIVO = P_PRC
         AND TFO_FONDEO = 'S'
         AND TFO_DERIVADO = 'S'
         AND (('Cierre Dia' = 'Cierre Dia' AND
             MRF.MRF_FECHA =
             (SELECT MAX(MRF2.MRF_FECHA)
                  FROM MVTOS_RENTA_FIJA MRF2
                 WHERE MRF2.MRF_TFO_FON_CODIGO = MRF.MRF_TFO_FON_CODIGO
                   AND MRF2.MRF_TFO_CODIGO = MRF.MRF_TFO_CODIGO
                   AND MRF2.MRF_FECHA >= TRUNC(P_FECHA)
                   AND MRF2.MRF_FECHA < TRUNC(P_FECHA + 1)) AND
             ((EXISTS
              (SELECT 'X'
                    FROM CONFIRMACION_FONDOS_DIA
                   WHERE CFD_FON_CODIGO = TFO_FON_CODIGO
                     AND CFD_FECHA >= TRUNC(P_FECHA + 1)
                     AND CFD_FECHA < TRUNC(P_FECHA + 2)
                     AND CFD_VALORIZACION_PORTAFOLIO = 'S') AND EXISTS
              (SELECT 'X'
                    FROM MVTOS_RENTA_FIJA MRF3
                   WHERE MRF3.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                     AND MRF3.MRF_TFO_CODIGO = TFO_CODIGO
                     AND MRF3.MRF_FECHA >= TRUNC(P_FECHA + 1)
                     AND MRF3.MRF_FECHA < TRUNC(P_FECHA + 2)
                     AND MRF3.MRF_TMT_MNEMONICO = 'VAF') AND
              TFO_FECHA_OPERACION < TRUNC(P_FECHA + 1)) OR
             (NOT EXISTS (SELECT 'X'
                               FROM CONFIRMACION_FONDOS_DIA
                              WHERE CFD_FON_CODIGO = TFO_FON_CODIGO
                                AND CFD_FECHA >= TRUNC(P_FECHA + 1)
                                AND CFD_FECHA < TRUNC(P_FECHA + 2)
                                AND CFD_VALORIZACION_PORTAFOLIO = 'S') AND
              TFO_DIA_SIGUIENTE = 'S') OR
             (EXISTS
              (SELECT 'X'
                    FROM MVTOS_RENTA_FIJA MRF4
                   WHERE MRF4.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                     AND MRF4.MRF_TFO_CODIGO = TFO_CODIGO
                     AND MRF4.MRF_FECHA >= TRUNC(P_FECHA)
                     AND MRF4.MRF_FECHA < TRUNC(P_FECHA + 1)
                     AND MRF4.MRF_TMT_MNEMONICO IN ('VAF', 'CRF')
                     AND MRF4.MRF_FECHA =
                         (SELECT MAX(MRF5.MRF_FECHA)
                            FROM MVTOS_RENTA_FIJA MRF5
                           WHERE MRF5.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                             AND MRF5.MRF_TFO_CODIGO = TFO_CODIGO)) AND
              TFO_ETI_CODIGO IN ('UNI', 'FRC') AND EXISTS
              (SELECT 'X'
                    FROM MVTOS_RENTA_FIJA MRF4,
                         FRACCIONAMIENTOS_UNIFICACIONES
                   WHERE MRF4.MRF_TFO_FON_CODIGO =
                         FUN_TFO_FON_CODIGO_ES_PRODUCID
                     AND MRF4.MRF_TFO_CODIGO = FUN_TFO_CODIGO_ES_PRODUCIDA
                     AND MRF4.MRF_FECHA >= TRUNC(P_FECHA + 1)
                     AND MRF4.MRF_FECHA < TRUNC(P_FECHA + 2)
                     AND MRF4.MRF_TMT_MNEMONICO IN
                         ('UNI', 'FRA', 'DCO', 'OCO', 'OVE', 'DVE')
                     AND FUN_TFO_FON_CODIGO = TFO_FON_CODIGO
                     AND FUN_TFO_CODIGO = TFO_CODIGO)))));

    CURSOR C_EFECTIVO_V(P_FECHA   DATE,
                        P_FONDO   VARCHAR2,
                        P_PRV_PRF NUMBER,
                        P_PRV     NUMBER) IS
      SELECT MRF.MRF_VALOR_TITULO_TM
        FROM MVTOS_RENTA_FIJA MRF, TITULOS_FONDOS
       WHERE MRF.MRF_FECHA >= TRUNC(P_FECHA)
         AND MRF.MRF_FECHA < TRUNC(P_FECHA + 1)
         AND MRF.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
         AND MRF.MRF_TFO_CODIGO = TFO_CODIGO
         AND TFO_FON_CODIGO = P_FONDO
         AND TFO_PRV_PRF_CONSECUTIVO = P_PRV_PRF
         AND TFO_PRV_CONSECUTIVO = P_PRV
         AND TFO_FONDEO = 'S'
         AND (('Cierre Dia' = 'Cierre Dia' AND
             MRF.MRF_FECHA =
             (SELECT MAX(MRF2.MRF_FECHA)
                  FROM MVTOS_RENTA_FIJA MRF2
                 WHERE MRF2.MRF_TFO_FON_CODIGO = MRF.MRF_TFO_FON_CODIGO
                   AND MRF2.MRF_TFO_CODIGO = MRF.MRF_TFO_CODIGO
                   AND MRF2.MRF_FECHA >= TRUNC(P_FECHA)
                   AND MRF2.MRF_FECHA < TRUNC(P_FECHA + 1)) AND
             ((EXISTS
              (SELECT 'X'
                    FROM CONFIRMACION_FONDOS_DIA
                   WHERE CFD_FON_CODIGO = TFO_FON_CODIGO
                     AND CFD_FECHA >= TRUNC(P_FECHA + 1)
                     AND CFD_FECHA < TRUNC(P_FECHA + 2)
                     AND CFD_VALORIZACION_PORTAFOLIO = 'S') AND EXISTS
              (SELECT 'X'
                    FROM MVTOS_RENTA_FIJA MRF3
                   WHERE MRF3.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                     AND MRF3.MRF_TFO_CODIGO = TFO_CODIGO
                     AND MRF3.MRF_FECHA >= TRUNC(P_FECHA + 1)
                     AND MRF3.MRF_FECHA < TRUNC(P_FECHA + 2)
                     AND MRF3.MRF_TMT_MNEMONICO = 'VAF') AND
              TFO_FECHA_OPERACION < TRUNC(P_FECHA + 1)) OR
             (NOT EXISTS (SELECT 'X'
                               FROM CONFIRMACION_FONDOS_DIA
                              WHERE CFD_FON_CODIGO = TFO_FON_CODIGO
                                AND CFD_FECHA >= TRUNC(P_FECHA + 1)
                                AND CFD_FECHA < TRUNC(P_FECHA + 2)
                                AND CFD_VALORIZACION_PORTAFOLIO = 'S') AND
              TFO_DIA_SIGUIENTE = 'S') OR
             (EXISTS
              (SELECT 'X'
                    FROM MVTOS_RENTA_FIJA MRF4
                   WHERE MRF4.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                     AND MRF4.MRF_TFO_CODIGO = TFO_CODIGO
                     AND MRF4.MRF_FECHA >= TRUNC(P_FECHA)
                     AND MRF4.MRF_FECHA < TRUNC(P_FECHA + 1)
                     AND MRF4.MRF_TMT_MNEMONICO IN ('VAF', 'CRF')
                     AND MRF4.MRF_FECHA =
                         (SELECT MAX(MRF5.MRF_FECHA)
                            FROM MVTOS_RENTA_FIJA MRF5
                           WHERE MRF5.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                             AND MRF5.MRF_TFO_CODIGO = TFO_CODIGO)) AND
              TFO_ETI_CODIGO IN ('UNI', 'FRC') AND EXISTS
              (SELECT 'X'
                    FROM MVTOS_RENTA_FIJA MRF4,
                         FRACCIONAMIENTOS_UNIFICACIONES
                   WHERE MRF4.MRF_TFO_FON_CODIGO =
                         FUN_TFO_FON_CODIGO_ES_PRODUCID
                     AND MRF4.MRF_TFO_CODIGO = FUN_TFO_CODIGO_ES_PRODUCIDA
                     AND MRF4.MRF_FECHA >= TRUNC(P_FECHA + 1)
                     AND MRF4.MRF_FECHA < TRUNC(P_FECHA + 2)
                     AND MRF4.MRF_TMT_MNEMONICO IN
                         ('UNI', 'FRA', 'DCO', 'OCO', 'OVE', 'DVE')
                     AND FUN_TFO_FON_CODIGO = TFO_FON_CODIGO
                     AND FUN_TFO_CODIGO = TFO_CODIGO)))));

    COND VARCHAR2(1);

    VALOR_TITULO_TM         NUMBER;
    NEGOCIO                 NUMBER;
    BOLSA                   CHAR(5);
    FECHA_REGISTRO          DATE;
    FECHA_CUMPLIMIENTO      DATE;
    VALOR_INICIAL           NUMBER;
    VALOR_CUMPLIMIENTO      NUMBER;
    NUMERO_OPERACION        NUMBER;
    CONTRAPARTE             VARCHAR2(100);
    REGISTRA_CLIENTE        CHAR(2);
    COMERCIAL               VARCHAR2(100);
    VALOR_PRESENTE_EFECTIVO NUMBER;
    TIPO_OPERACION          CHAR(5);
    TASA_FUTURA             NUMBER;
    FECHA_ORIG              DATE;

    VALORIZACION_DERECHO    NUMBER;
    TITULO_OBLIGACION       NUMBER;
    VALORIZACION_OBLIGACION NUMBER;
    NUMERO_OPERACION_OBLIG  NUMBER;

  BEGIN
    DELETE TMP_RECOFU_COMPRAS;
    COMMIT;

    FOR R_COMPRAS IN C_COMPRAS LOOP
      TASA_FUTURA := NULL;
      IF R_COMPRAS.TFO_BMO_MNEMONICO = 'PESOS' THEN
        CBM1.CBM_VALOR := 1;
      ELSE
        IF R_COMPRAS.TFO_BMO_MNEMONICO = 'DOLAR' THEN
          OPEN C_COTIZACION(R_COMPRAS.MRF_FECHA_VALORIZACION + 1,
                            R_COMPRAS.TFO_BMO_MNEMONICO);
          FETCH C_COTIZACION
            INTO CBM1;
          CLOSE C_COTIZACION;
        ELSE
          OPEN C_COTIZACION(R_COMPRAS.MRF_FECHA_VALORIZACION,
                            R_COMPRAS.TFO_BMO_MNEMONICO);
          FETCH C_COTIZACION
            INTO CBM1;
          CLOSE C_COTIZACION;
        END IF;

        /* FETCH C_COTIZACION INTO CBM1;
        IF C_COTIZACION%NOTFOUND THEN
           CLOSE C_COTIZACION;
              NULL;
        END IF;*/
      END IF; --FIN BMO

      VALOR_TITULO_TM := R_COMPRAS.MRF_VALOR_TITULO_TM * CBM1.CBM_VALOR;

      OPEN C_MOVIMIENTO(R_COMPRAS.TFO_FON_CODIGO, R_COMPRAS.TFO_CODIGO);
      FETCH C_MOVIMIENTO
        INTO MRF1;
      IF C_MOVIMIENTO%NOTFOUND THEN
        CLOSE C_MOVIMIENTO;
        NULL;
      END IF;

      CLOSE C_MOVIMIENTO;
      IF MRF1.MRF_TMT_MNEMONICO = 'DCO' THEN
        OPEN C_NEGOCIO(R_COMPRAS.TFO_FON_CODIGO,
                       R_COMPRAS.TFO_PRC_PRF_CONSECUTIVO,
                       R_COMPRAS.TFO_PRC_CONSECUTIVO);
        FETCH C_NEGOCIO
          INTO PRC1;
        IF C_NEGOCIO%NOTFOUND THEN
          CLOSE C_NEGOCIO;
          NULL;
        END IF;
        CLOSE C_NEGOCIO;
        NEGOCIO            := PRC1.PRC_PRF_CONSECUTIVO;
        BOLSA              := PRC1.PRC_BOL_MNEMONICO;
        FECHA_REGISTRO     := PRC1.PRF_FECHA_OPERACION;
        FECHA_CUMPLIMIENTO := PRC1.PRC_FECHA_CUMPLIMIENTO;
        VALOR_INICIAL      := R_COMPRAS.TFO_VALOR_OPERACION;
        VALOR_CUMPLIMIENTO := PRC1.PRC_MONTO;
        NUMERO_OPERACION   := PRC1.PRC_NUMERO_OPERACION;
        CONTRAPARTE        := NULL;
        REGISTRA_CLIENTE   := NVL(PRC1.PRC_REGISTRA_CLIENTE, ' ');
        POS_POP            := NULL;
        OPEN C_PARAMETRO(R_COMPRAS.TFO_FON_CODIGO);
        FETCH C_PARAMETRO
          INTO POS_POP;
        CLOSE C_PARAMETRO;
        IF NVL(POS_POP, ' ') = 'X' AND
           PRC1.PRC_CLI_PER_NUM_IDEN = '860079174' AND
           PRC1.PRC_CLI_PER_TID_CODIGO = 'NIT' THEN
          OPEN C_CONTRAPARTE(PRC1.PRC_PER_NUM_IDEN_CONTRAPARTE,
                             PRC1.PRC_PER_TID_CODIGO_CONTRAPARTE);
          FETCH C_CONTRAPARTE
            INTO CONTRAPARTE, TIPO;
          IF C_CONTRAPARTE%NOTFOUND THEN
            NULL;
          END IF;
          IF TIPO = 'PNA' THEN
            CONTRAPARTE := 'PERSONA NATURAL';
          END IF;
          CLOSE C_CONTRAPARTE;
        ELSE
          OPEN C_CONTRAPARTE(PRC1.PRC_CLI_PER_NUM_IDEN,
                             PRC1.PRC_CLI_PER_TID_CODIGO);
          FETCH C_CONTRAPARTE
            INTO CONTRAPARTE, TIPO;
          IF C_CONTRAPARTE%NOTFOUND THEN
            NULL;
          END IF;
          IF TIPO = 'PNA' THEN
            CONTRAPARTE := 'PERSONA NATURAL';
          END IF;
          CLOSE C_CONTRAPARTE;
        END IF;
        COMERCIAL := ' ';
        COND      := 'N';
        OPEN C_COMERCIAL(R_COMPRAS.TFO_FON_CODIGO,
                         R_COMPRAS.TFO_PRC_PRF_CONSECUTIVO);
        FETCH C_COMERCIAL
          INTO PER1;
        WHILE C_COMERCIAL%FOUND LOOP
          IF COND = 'S' THEN
            COMERCIAL := COMERCIAL || ' - ';
          END IF;
          COMERCIAL := COMERCIAL || PER1.PER_INICIALES_USUARIO;
          COND      := 'S';
          FETCH C_COMERCIAL
            INTO PER1;
        END LOOP;
        CLOSE C_COMERCIAL;
        COMERCIAL := LTRIM(COMERCIAL);
        OPEN C_EFECTIVO(R_COMPRAS.FECHA /*:FILTRO.FECHA*/,
                        R_COMPRAS.TFO_FON_CODIGO,
                        R_COMPRAS.TFO_PRC_PRF_CONSECUTIVO,
                        R_COMPRAS.TFO_PRC_CONSECUTIVO);
        FETCH C_EFECTIVO
          INTO VALOR_PRESENTE_EFECTIVO;
        CLOSE C_EFECTIVO;
        VALOR_PRESENTE_EFECTIVO := NVL(VALOR_PRESENTE_EFECTIVO, 0);
        TIPO_OPERACION          := NVL(PRC1.PRC_CNE_MNEMONICO, ' ');
      ELSIF MRF1.MRF_TMT_MNEMONICO = 'FPA' THEN
        OPEN C_NEGOCIO_V(R_COMPRAS.TFO_FON_CODIGO,
                         R_COMPRAS.TFO_PRV_PRF_CONSECUTIVO,
                         R_COMPRAS.TFO_PRV_CONSECUTIVO);
        FETCH C_NEGOCIO_V
          INTO PRV1;
        IF C_NEGOCIO_V%NOTFOUND THEN
          CLOSE C_NEGOCIO_V;
          NULL;

        END IF;
        CLOSE C_NEGOCIO_V;
        NEGOCIO            := PRV1.PRV_PRF_CONSECUTIVO;
        BOLSA              := PRV1.PRC_BOL_MNEMONICO;
        FECHA_REGISTRO     := PRV1.PRF_FECHA_OPERACION;
        FECHA_CUMPLIMIENTO := PRV1.PRV_FECHA_COMPRA_FUTURA;
        TASA_FUTURA        := ROUND(PRV1.PRV_TASA_FUTURA, 3);
        VALOR_INICIAL      := PRV1.PRV_MONTO;
        VALOR_CUMPLIMIENTO := PRV1.PRV_VALOR_FUTURO;
        NUMERO_OPERACION   := PRV1.PRC_NUMERO_OPERACION;
        REGISTRA_CLIENTE   := NVL(PRV1.PRC_REGISTRA_CLIENTE, ' ');
        CONTRAPARTE        := NULL;
        POS_POP            := NULL;
        FECHA_ORIG         := FECHA_ORIG_CUMPLI(R_COMPRAS.TFO_CODIGO);
        OPEN C_PARAMETRO(R_COMPRAS.TFO_FON_CODIGO);
        FETCH C_PARAMETRO
          INTO POS_POP;
        CLOSE C_PARAMETRO;
        IF NVL(POS_POP, ' ') = 'X' AND
           PRV1.PRC_CLI_PER_NUM_IDEN = '860079174' AND
           PRV1.PRC_CLI_PER_TID_CODIGO = 'NIT' THEN
          OPEN C_CONTRAPARTE(PRV1.PRC_PER_NUM_IDEN_CONTRAPARTE,
                             PRV1.PRC_PER_TID_CODIGO_CONTRAPARTE);
          FETCH C_CONTRAPARTE
            INTO CONTRAPARTE, TIPO;
          IF C_CONTRAPARTE%NOTFOUND THEN
            NULL;
          END IF;
          IF TIPO = 'PNA' THEN
            CONTRAPARTE := 'PERSONA NATURAL';
          END IF;
          CLOSE C_CONTRAPARTE;
        ELSE
          OPEN C_CONTRAPARTE(PRV1.PRC_CLI_PER_NUM_IDEN,
                             PRV1.PRC_CLI_PER_TID_CODIGO);
          FETCH C_CONTRAPARTE
            INTO CONTRAPARTE, TIPO;
          IF C_CONTRAPARTE%NOTFOUND THEN
            NULL;
          END IF;
          IF TIPO = 'PNA' THEN
            CONTRAPARTE := 'PERSONA NATURAL';
          END IF;
          CLOSE C_CONTRAPARTE;
        END IF;
        COMERCIAL := ' ';
        COND      := 'N';
        OPEN C_COMERCIAL(R_COMPRAS.TFO_FON_CODIGO,
                         R_COMPRAS.TFO_PRV_PRF_CONSECUTIVO);
        FETCH C_COMERCIAL
          INTO PER1;
        WHILE C_COMERCIAL%FOUND LOOP
          IF COND = 'S' THEN
            COMERCIAL := COMERCIAL || ' - ';
          END IF;
          COMERCIAL := COMERCIAL || PER1.PER_INICIALES_USUARIO;
          COND      := 'S';
          FETCH C_COMERCIAL
            INTO PER1;
        END LOOP;
        CLOSE C_COMERCIAL;
        COMERCIAL := LTRIM(COMERCIAL);
        OPEN C_EFECTIVO_V(R_COMPRAS.FECHA /*:FILTRO.FECHA*/,
                          R_COMPRAS.TFO_FON_CODIGO,
                          R_COMPRAS.TFO_PRV_PRF_CONSECUTIVO,
                          R_COMPRAS.TFO_PRV_CONSECUTIVO);
        FETCH C_EFECTIVO_V
          INTO VALOR_PRESENTE_EFECTIVO;
        CLOSE C_EFECTIVO_V;
        VALOR_PRESENTE_EFECTIVO := NVL(VALOR_PRESENTE_EFECTIVO, 0);
        TIPO_OPERACION          := NVL(PRV1.PRC_CNE_MNEMONICO, ' ');
      END IF;

      VALORIZACION_DERECHO := VALORIZACION(R_COMPRAS.TFO_FON_CODIGO,
                                           R_COMPRAS.TFO_CODIGO,
                                           R_COMPRAS.FECHA,
                                           R_COMPRAS.MRF_TIR365_M,
                                           R_COMPRAS.TFO_BMO_MNEMONICO);

      TITULO_OBLIGACION       := TITULO_OBL(R_COMPRAS.TFO_CODIGO,
                                            R_COMPRAS.TFO_FON_CODIGO);
      VALORIZACION_OBLIGACION := VALORIZACION_OBL(R_COMPRAS.FECHA,
                                                  TITULO_OBLIGACION,
                                                  R_COMPRAS.TFO_FON_CODIGO,
                                                  R_COMPRAS.TFO_ENA_MNEMONICO);
      NUMERO_OPERACION_OBLIG  := NUMERO_OPE_OBLIG(R_COMPRAS.TFO_FON_CODIGO,
                                                  R_COMPRAS.TFO_CODIGO,
                                                  TITULO_OBL(R_COMPRAS.TFO_CODIGO,
                                                             R_COMPRAS.TFO_FON_CODIGO));

      INSERT INTO TMP_RECOFU_COMPRAS
        (FECHA_REPORTE,
         OPERACION,
         NUMERO_OPERACION,
         FONDO,
         EMISOR_COMPROMISO,
         NEMOTECNICO,
         ESPECIE,
         VALOR_NOMINAL,
         FECHA_EMISION,
         FECHA_VENCIMIENTO,
         INTERES_NOMINAL,
         MODALIDAD,
         TIPO_OPERACION,
         TASA_FUTURA,
         BOLSA,
         FECHA_REGISTRO,
         FECHA_ORIG_CUMPLIMIENTO,
         FECHA_CUMPL_COMPROMISO,
         VALOR_OPERACION_INICIAL,
         VALOR_CUMPLIMIENTO,
         NOMBRE_CONTRAPARTE,
         COMERCIAL,
         VALOR_PRESENTE_DERECHO,
         VALOR_PRESENTE_OBLIG,
         DIF_DERECHO_OBLIGACION,
         REGISTRA_CLIENTE,
         BASE_MONETARIA,
         TITULO_DERECHO,
         VALORIZACION_DERECHO,
         TITULO_OBLIGACION,
         VALORIZACION_OBLIGACION,
         NUMERO_OPERACION_OBLIG)
      VALUES
        (SYSDATE,
         'COMPRAS',
         NUMERO_OPERACION,
         R_COMPRAS.FON_RAZON_SOCIAL,
         R_COMPRAS.EMI_DESCRIPCION,
         R_COMPRAS.TFO_ENA_MNEMONICO,
         R_COMPRAS.ENA_DESCRIPCION,
         R_COMPRAS.TFO_VALOR_NOMINAL,
         R_COMPRAS.TFO_FECHA_EMISION,
         R_COMPRAS.TFO_FECHA_VENCIMIENTO,
         R_COMPRAS.INTERES_NOMINAL,
         R_COMPRAS.MODALIDAD,
         TIPO_OPERACION,
         TASA_FUTURA,
         BOLSA,
         FECHA_REGISTRO,
         FECHA_ORIG,
         FECHA_CUMPLIMIENTO,
         VALOR_INICIAL,
         VALOR_CUMPLIMIENTO,
         CONTRAPARTE,
         COMERCIAL,
         VALOR_TITULO_TM,
         VALOR_PRESENTE_EFECTIVO,
         (ABS(VALOR_TITULO_TM) - ABS(VALOR_PRESENTE_EFECTIVO)),
         REGISTRA_CLIENTE,
         R_COMPRAS.TFO_BMO_MNEMONICO,
         R_COMPRAS.TFO_CODIGO,
         VALORIZACION_DERECHO,
         TITULO_OBLIGACION,
         VALORIZACION_OBLIGACION,
         NUMERO_OPERACION_OBLIG);
      COMMIT;
    END LOOP;
  END GENERA_RECOFU_TODOS;

  PROCEDURE GENERA_RECOFU_VENTAS_TODOS IS
    CURSOR C_VENTAS IS
      SELECT FON.FON_RAZON_SOCIAL FON_RAZON_SOCIAL,
             EMI.EMI_DESCRIPCION EMI_DESCRIPCION,
             TFO.TFO_ENA_MNEMONICO TFO_ENA_MNEMONICO,
             ENA.ENA_DESCRIPCION ENA_DESCRIPCION,
             ABS(TFO.TFO_VALOR_NOMINAL) TFO_VALOR_NOMINAL,
             TFO.TFO_FECHA_EMISION TFO_FECHA_EMISION,
             TFO.TFO_FECHA_VENCIMIENTO TFO_FECHA_VENCIMIENTO,
             DECODE(TFO.TFO_TASA_FACIAL,
                    NULL,
                    TFO.TFO_TRE_MNEMONICO || ' + ' ||
                    TO_CHAR(TFO.TFO_PUNTOS_ADICIONALES),
                    TO_CHAR(TFO.TFO_TASA_FACIAL * 100)) INTERES_NOMINAL,
             DECODE(TFO.TFO_PERIODICIDAD_TASA,
                    30,
                    'M',
                    60,
                    'B',
                    90,
                    'T',
                    120,
                    'C',
                    180,
                    'S',
                    360,
                    'A',
                    365,
                    'A',
                    'P') || TFO.TFO_MODALIDAD_TASA MODALIDAD,
             TFO.TFO_BMO_MNEMONICO TFO_BMO_MNEMONICO,
             MRF.MRF_VALOR_TITULO_TM MRF_VALOR_TITULO_TM,
             NVL(MRF.MRF_FECHA_VALORIZACION, MRF.MRF_FECHA) MRF_FECHA_VALORIZACION,
             TFO.TFO_FON_CODIGO TFO_FON_CODIGO,
             TFO.TFO_CODIGO TFO_CODIGO,
             TFO.TFO_PRV_PRF_CONSECUTIVO TFO_PRV_PRF_CONSECUTIVO,
             TFO.TFO_PRV_CONSECUTIVO TFO_PRV_CONSECUTIVO,
             TFO.TFO_PRC_PRF_CONSECUTIVO TFO_PRC_PRF_CONSECUTIVO,
             TFO.TFO_PRC_CONSECUTIVO TFO_PRC_CONSECUTIVO,
             TFO.TFO_VALOR_OPERACION TFO_VALOR_OPERACION,
             MRF_TIR365_M,
             MRF.MRF_FECHA FECHA
        FROM FONDOS              FON,
             EMISORES            EMI,
             ESPECIES_NACIONALES ENA,
             TITULOS_FONDOS      TFO,
             MVTOS_RENTA_FIJA    MRF
       WHERE FON.FON_CODIGO = TFO.TFO_FON_CODIGO
         AND EMI.EMI_MNEMONICO = ENA.ENA_EMI_MNEMONICO
         AND ENA.ENA_MNEMONICO = TFO.TFO_ENA_MNEMONICO
         AND EXISTS
       (SELECT 'X'
                FROM MVTOS_RENTA_FIJA MRF1
               WHERE MRF1.MRF_TFO_FON_CODIGO = TFO.TFO_FON_CODIGO
                 AND MRF1.MRF_TFO_CODIGO = TFO.TFO_CODIGO
                 AND MRF1.MRF_TMT_MNEMONICO IN ('OVE'))
         AND TFO.TFO_FON_CODIGO = MRF.MRF_TFO_FON_CODIGO
         AND TFO.TFO_CODIGO = MRF.MRF_TFO_CODIGO
         AND MRF.MRF_FECHA >= SYSDATE - 1
         AND MRF.MRF_FECHA < SYSDATE
         AND ('Cierre Dia' = 'Cierre Dia' AND
             MRF.MRF_FECHA =
             (SELECT MAX(MRF2.MRF_FECHA)
                 FROM MVTOS_RENTA_FIJA MRF2
                WHERE MRF2.MRF_TFO_FON_CODIGO = MRF.MRF_TFO_FON_CODIGO
                  AND MRF2.MRF_TFO_CODIGO = MRF.MRF_TFO_CODIGO
                  AND MRF2.MRF_FECHA >= SYSDATE - 1
                  AND MRF2.MRF_FECHA < SYSDATE) AND
             ((EXISTS
              (SELECT 'X'
                   FROM CONFIRMACION_FONDOS_DIA
                  WHERE CFD_FON_CODIGO = TFO_FON_CODIGO
                    AND CFD_FECHA >= SYSDATE
                    AND CFD_FECHA < SYSDATE + 1
                    AND CFD_VALORIZACION_PORTAFOLIO = 'S') AND EXISTS
              (SELECT 'X'
                   FROM MVTOS_RENTA_FIJA MRF3
                  WHERE MRF3.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                    AND MRF3.MRF_TFO_CODIGO = TFO_CODIGO
                    AND MRF3.MRF_FECHA >= SYSDATE
                    AND MRF3.MRF_FECHA < SYSDATE + 1
                    AND MRF3.MRF_TMT_MNEMONICO = 'VAF') AND
              TFO_FECHA_OPERACION < SYSDATE) OR
             (NOT EXISTS (SELECT 'X'
                              FROM CONFIRMACION_FONDOS_DIA
                             WHERE CFD_FON_CODIGO = TFO_FON_CODIGO
                               AND CFD_FECHA >= SYSDATE
                               AND CFD_FECHA < SYSDATE + 1
                               AND CFD_VALORIZACION_PORTAFOLIO = 'S') AND
              TFO_DIA_SIGUIENTE = 'S') OR
             (EXISTS
              (SELECT 'X'
                   FROM MVTOS_RENTA_FIJA MRF4
                  WHERE MRF4.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                    AND MRF4.MRF_TFO_CODIGO = TFO_CODIGO
                    AND MRF4.MRF_FECHA >= SYSDATE - 1
                    AND MRF4.MRF_FECHA < SYSDATE
                    AND MRF4.MRF_TMT_MNEMONICO IN ('VAF', 'CRF')
                    AND MRF4.MRF_FECHA =
                        (SELECT MAX(MRF5.MRF_FECHA)
                           FROM MVTOS_RENTA_FIJA MRF5
                          WHERE MRF5.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                            AND MRF5.MRF_TFO_CODIGO = TFO_CODIGO)) AND
              TFO_ETI_CODIGO IN ('UNI', 'FRC') AND EXISTS
              (SELECT 'X'
                   FROM MVTOS_RENTA_FIJA MRF4, FRACCIONAMIENTOS_UNIFICACIONES
                  WHERE MRF4.MRF_TFO_FON_CODIGO =
                        FUN_TFO_FON_CODIGO_ES_PRODUCID
                    AND MRF4.MRF_TFO_CODIGO = FUN_TFO_CODIGO_ES_PRODUCIDA
                    AND MRF4.MRF_FECHA >= SYSDATE
                    AND MRF4.MRF_FECHA < SYSDATE + 1
                    AND MRF4.MRF_TMT_MNEMONICO IN
                        ('UNI', 'FRA', 'DCO', 'OCO', 'OVE', 'DVE')
                    AND FUN_TFO_FON_CODIGO = TFO_FON_CODIGO
                    AND FUN_TFO_CODIGO = TFO_CODIGO))))
      UNION
      SELECT FON.FON_RAZON_SOCIAL FON_RAZON_SOCIAL,
             EMI.EMI_DESCRIPCION EMI_DESCRIPCION,
             TFO.TFO_ENA_MNEMONICO TFO_ENA_MNEMONICO,
             ENA.ENA_DESCRIPCION ENA_DESCRIPCION,
             ABS(TFO.TFO_VALOR_NOMINAL) TFO_VALOR_NOMINAL,
             TFO.TFO_FECHA_EMISION TFO_FECHA_EMISION,
             TFO.TFO_FECHA_VENCIMIENTO TFO_FECHA_VENCIMIENTO,
             DECODE(TFO.TFO_TASA_FACIAL,
                    NULL,
                    TFO.TFO_TRE_MNEMONICO || ' + ' ||
                    TO_CHAR(TFO.TFO_PUNTOS_ADICIONALES),
                    TO_CHAR(TFO.TFO_TASA_FACIAL * 100)) INTERES_NOMINAL,
             DECODE(TFO.TFO_PERIODICIDAD_TASA,
                    30,
                    'M',
                    60,
                    'B',
                    90,
                    'T',
                    120,
                    'C',
                    180,
                    'S',
                    360,
                    'A',
                    365,
                    'A',
                    'P') || TFO.TFO_MODALIDAD_TASA MODALIDAD,
             TFO.TFO_BMO_MNEMONICO TFO_BMO_MNEMONICO,
             MRF.MRF_VALOR_TITULO_TM MRF_VALOR_TITULO_TM,
             NVL(MRF.MRF_FECHA_VALORIZACION, MRF.MRF_FECHA) MRF_FECHA_VALORIZACION1,
             TFO.TFO_FON_CODIGO TFO_FON_CODIGO,
             TFO.TFO_CODIGO TFO_CODIGO,
             TFO.TFO_PRV_PRF_CONSECUTIVO TFO_PRV_PRF_CONSECUTIVO,
             TFO.TFO_PRV_CONSECUTIVO TFO_PRV_CONSECUTIVO,
             TFO.TFO_PRC_PRF_CONSECUTIVO TFO_PRC_PRF_CONSECUTIVO,
             TFO.TFO_PRC_CONSECUTIVO TFO_PRC_CONSECUTIVO,
             TFO.TFO_VALOR_OPERACION TFO_VALOR_OPERACION,
             MRF1.MRF_TIR365_M MRF_TIR365_M1,
             MRF1.MRF_FECHA FECHA
        FROM FONDOS              FON,
             EMISORES            EMI,
             ESPECIES_NACIONALES ENA,
             TITULOS_FONDOS      TFO,
             MVTOS_RENTA_FIJA    MRF,
             TITULOS_FONDOS      TFO1,
             MVTOS_RENTA_FIJA    MRF1
       WHERE FON.FON_CODIGO = TFO.TFO_FON_CODIGO
         AND EMI.EMI_MNEMONICO = ENA.ENA_EMI_MNEMONICO
         AND ENA.ENA_MNEMONICO = TFO.TFO_ENA_MNEMONICO
         AND TFO.TFO_FON_CODIGO = MRF.MRF_TFO_FON_CODIGO
         AND TFO.TFO_CODIGO = MRF.MRF_TFO_CODIGO
         AND MRF.MRF_TMT_MNEMONICO = 'FAC'
         AND TFO1.TFO_FONDEO = 'S'
         AND TFO.TFO_FON_CODIGO = TFO1.TFO_FON_CODIGO
         AND TFO.TFO_PRC_PRF_CONSECUTIVO = TFO1.TFO_PRC_PRF_CONSECUTIVO
         AND TFO.TFO_PRC_CONSECUTIVO = TFO1.TFO_PRC_CONSECUTIVO
         AND MRF1.MRF_TFO_FON_CODIGO = TFO1.TFO_FON_CODIGO
         AND MRF1.MRF_TFO_CODIGO = TFO1.TFO_CODIGO
         AND MRF1.MRF_FECHA >= SYSDATE - 1
         AND MRF1.MRF_FECHA < SYSDATE
         AND ('Cierre Dia' = 'Cierre Dia' AND
             MRF1.MRF_FECHA =
             (SELECT MAX(MRF2.MRF_FECHA)
                 FROM MVTOS_RENTA_FIJA MRF2
                WHERE MRF2.MRF_TFO_FON_CODIGO = MRF1.MRF_TFO_FON_CODIGO
                  AND MRF2.MRF_TFO_CODIGO = MRF1.MRF_TFO_CODIGO
                  AND MRF2.MRF_FECHA >= SYSDATE - 1
                  AND MRF2.MRF_FECHA < SYSDATE) AND
             ((EXISTS
              (SELECT 'X'
                   FROM CONFIRMACION_FONDOS_DIA
                  WHERE CFD_FON_CODIGO = TFO1.TFO_FON_CODIGO
                    AND CFD_FECHA >= SYSDATE
                    AND CFD_FECHA < SYSDATE + 1
                    AND CFD_VALORIZACION_PORTAFOLIO = 'S') AND EXISTS
              (SELECT 'X'
                   FROM MVTOS_RENTA_FIJA MRF3
                  WHERE MRF3.MRF_TFO_FON_CODIGO = TFO1.TFO_FON_CODIGO
                    AND MRF3.MRF_TFO_CODIGO = TFO1.TFO_CODIGO
                    AND MRF3.MRF_FECHA >= SYSDATE
                    AND MRF3.MRF_FECHA < SYSDATE + 1
                    AND MRF3.MRF_TMT_MNEMONICO = 'VAF') AND
              TFO1.TFO_FECHA_OPERACION < SYSDATE) OR
             (NOT EXISTS (SELECT 'X'
                              FROM CONFIRMACION_FONDOS_DIA
                             WHERE CFD_FON_CODIGO = TFO1.TFO_FON_CODIGO
                               AND CFD_FECHA >= SYSDATE
                               AND CFD_FECHA < SYSDATE + 1
                               AND CFD_VALORIZACION_PORTAFOLIO = 'S') AND
              TFO1.TFO_DIA_SIGUIENTE = 'S') OR
             (EXISTS
              (SELECT 'X'
                   FROM MVTOS_RENTA_FIJA MRF4
                  WHERE MRF4.MRF_TFO_FON_CODIGO = TFO1.TFO_FON_CODIGO
                    AND MRF4.MRF_TFO_CODIGO = TFO1.TFO_CODIGO
                    AND MRF4.MRF_FECHA >= SYSDATE - 1
                    AND MRF4.MRF_FECHA < SYSDATE
                    AND MRF4.MRF_TMT_MNEMONICO IN ('VAF', 'CRF')
                    AND MRF4.MRF_FECHA =
                        (SELECT MAX(MRF5.MRF_FECHA)
                           FROM MVTOS_RENTA_FIJA MRF5
                          WHERE MRF5.MRF_TFO_FON_CODIGO = TFO1.TFO_FON_CODIGO
                            AND MRF5.MRF_TFO_CODIGO = TFO1.TFO_CODIGO)) AND
              TFO1.TFO_ETI_CODIGO IN ('UNI', 'FRC') AND EXISTS
              (SELECT 'X'
                   FROM MVTOS_RENTA_FIJA MRF4, FRACCIONAMIENTOS_UNIFICACIONES
                  WHERE MRF4.MRF_TFO_FON_CODIGO =
                        FUN_TFO_FON_CODIGO_ES_PRODUCID
                    AND MRF4.MRF_TFO_CODIGO = FUN_TFO_CODIGO_ES_PRODUCIDA
                    AND MRF4.MRF_FECHA >= SYSDATE
                    AND MRF4.MRF_FECHA < SYSDATE + 1
                    AND MRF4.MRF_TMT_MNEMONICO IN
                        ('UNI', 'FRA', 'DCO', 'OCO', 'OVE', 'DVE')
                    AND FUN_TFO_FON_CODIGO = TFO1.TFO_FON_CODIGO
                    AND FUN_TFO_CODIGO = TFO1.TFO_CODIGO))))
       ORDER BY 4, 3;

    CURSOR C_PARAMETRO(P_FONDO VARCHAR2) IS
      SELECT 'X'
        FROM PARAMETROS_FONDOS
       WHERE PFO_FON_CODIGO = P_FONDO
         AND PFO_PAR_CODIGO IN (19, 27);
    POS_POP VARCHAR2(1);

    CURSOR C_COTIZACION(P_FECHA DATE, P_BMO VARCHAR2) IS
      SELECT CBM_VALOR
        FROM COTIZACIONES_BASE_MONETARIAS
       WHERE CBM_BMO_MNEMONICO = P_BMO
         AND CBM_FECHA >= TRUNC(P_FECHA)
         AND CBM_FECHA < TRUNC(P_FECHA + 1);
    CBM1 C_COTIZACION%ROWTYPE;

    CURSOR C_MOVIMIENTO(P_FONDO VARCHAR2, P_TITULO NUMBER) IS
      SELECT MRF_TMT_MNEMONICO
        FROM MVTOS_RENTA_FIJA
       WHERE MRF_TFO_FON_CODIGO = P_FONDO
         AND MRF_TFO_CODIGO = P_TITULO
         AND MRF_TMT_MNEMONICO IN ('OVE', 'FAC');
    MRF1 C_MOVIMIENTO%ROWTYPE;

    CURSOR C_NEGOCIO(P_FONDO VARCHAR2, P_PRV_PRF NUMBER, P_PRV NUMBER) IS
      SELECT DECODE(PRV_CNE_MNEMONICO,
                    'CON',
                    'CONT',
                    'PLZ',
                    'PRF',
                    'CAR',
                    'CARR',
                    'SWP',
                    'SWAP',
                    PRV_CNE_MNEMONICO) PRV_CNE_MNEMONICO,
             PRV_BOL_MNEMONICO,
             PRF_FECHA_OPERACION,
             PRV_FECHA_CUMPLIMIENTO,
             PRV_MONTO,
             PRV_CLI_PER_NUM_IDEN,
             PRV_CLI_PER_TID_CODIGO,
             PRV_PER_NUM_IDEN_CONTRAPARTE,
             PRV_PER_TID_CODIGO_CONTRAPARTE,
             PRV_PRF_CONSECUTIVO,
             PRV_NUMERO_OPERACION,
             PRV_REGISTRA_CLIENTE
        FROM PREORDENES_FONDOS, PREORDENES_VENTA
       WHERE PRF_FON_CODIGO = PRV_PRF_FON_CODIGO
         AND PRF_CONSECUTIVO = PRV_PRF_CONSECUTIVO
         AND PRV_PRF_FON_CODIGO = P_FONDO
         AND PRV_PRF_CONSECUTIVO = P_PRV_PRF
         AND PRV_CONSECUTIVO = P_PRV;
    --AND    NVL(PRV_FRACCIONADA_UNIFICADA,' ') NOT IN ('FRC'); -- SORTIZ APLAZAMIENTO YANKEES
    PRV1 C_NEGOCIO%ROWTYPE;

    CURSOR C_NEGOCIO_C(P_FONDO VARCHAR2, P_PRC_PRF NUMBER, P_PRC NUMBER) IS
      SELECT DECODE(PRV_CNE_MNEMONICO,
                    'CON',
                    'CONT',
                    'PLZ',
                    'PRF',
                    'CAR',
                    'CARR',
                    'SWP',
                    'SWAP',
                    PRV_CNE_MNEMONICO) PRV_CNE_MNEMONICO,
             PRV_BOL_MNEMONICO,
             PRF_FECHA_OPERACION,
             PRC_FECHA_VENTA_FUTURA,
             PRC_TASA_FUTURA,
             PRC_MONTO,
             PRC_VALOR_FUTURO,
             PRV_CLI_PER_NUM_IDEN,
             PRV_CLI_PER_TID_CODIGO,
             PRV_PER_NUM_IDEN_CONTRAPARTE,
             PRV_PER_TID_CODIGO_CONTRAPARTE,
             PRC_PRF_CONSECUTIVO,
             PRV_NUMERO_OPERACION,
             PRV_REGISTRA_CLIENTE
        FROM PREORDENES_VENTA, PREORDENES_FONDOS, PREORDENES_COMPRA
       WHERE PRV_PRF_FON_CODIGO = PRC_PRF_FON_CODIGO
         AND PRV_PRF_CONSECUTIVO = PRC_PRV_PRF_CONSECUTIVO
         AND PRV_CONSECUTIVO = PRC_PRV_CONSECUTIVO
         AND PRF_FON_CODIGO = PRC_PRF_FON_CODIGO
         AND PRF_CONSECUTIVO = PRC_PRF_CONSECUTIVO
         AND PRC_PRF_FON_CODIGO = P_FONDO
         AND PRC_PRF_CONSECUTIVO = P_PRC_PRF
         AND PRC_CONSECUTIVO = P_PRC;
    PRC1 C_NEGOCIO_C%ROWTYPE;

    CURSOR C_TGA(P_FONDO   VARCHAR2,
                 P_PRC_PRF NUMBER,
                 P_PRC     NUMBER,
                 P_FECHA   DATE) IS
      SELECT MRF_VALOR_TITULO_TM,
             NVL(MRF_FECHA_VALORIZACION, MRF_FECHA) MRF_FECHA_VALORIZACION
        FROM MVTOS_RENTA_FIJA, TITULOS_FONDOS
       WHERE MRF_FECHA >= TRUNC(P_FECHA)
         AND MRF_FECHA < TRUNC(P_FECHA + 1)
         AND MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
         AND MRF_TFO_CODIGO = TFO_CODIGO
         AND TFO_ETI_CODIGO IN ('TGA', 'ANU')
         AND TFO_FON_CODIGO = P_FONDO
         AND TFO_PRC_PRF_CONSECUTIVO = P_PRC_PRF
         AND TFO_PRC_CONSECUTIVO = P_PRC
       ORDER BY MRF_FECHA DESC;
    MRF2 C_TGA%ROWTYPE;

    CURSOR C_CONTRAPARTE(P_PER_NUM_IDEN   VARCHAR2,
                         P_PER_TID_CODIGO VARCHAR2) IS
      SELECT PER_NOMBRE, PER_TIPO
        FROM FILTRO_PERSONAS
       WHERE PER_NUM_IDEN = P_PER_NUM_IDEN
         AND PER_TID_CODIGO = P_PER_TID_CODIGO;
    TIPO VARCHAR2(5);

    CURSOR C_COMERCIAL(P_FONDO VARCHAR2, P_CONSECUTIVO NUMBER) IS
      SELECT PER_INICIALES_USUARIO
        FROM PERSONAS, PARTICIPACIONES_PREORDENES
       WHERE PER_NUM_IDEN = PAP_PER_NUM_IDEN
         AND PER_TID_CODIGO = PAP_PER_TID_CODIGO
         AND PAP_PRF_FON_CODIGO = P_FONDO
         AND PAP_PRF_CONSECUTIVO = P_CONSECUTIVO;
    PER1 C_COMERCIAL%ROWTYPE;

    CURSOR C_EFECTIVO(P_FONDO   VARCHAR2,
                      P_PRV_PRF NUMBER,
                      P_PRV     NUMBER,
                      P_FECHA   DATE) IS
      SELECT MRF.MRF_VALOR_TITULO_TM
        FROM MVTOS_RENTA_FIJA MRF, TITULOS_FONDOS
       WHERE MRF.MRF_FECHA >= TRUNC(P_FECHA)
         AND MRF.MRF_FECHA < TRUNC(P_FECHA + 1)
         AND MRF.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
         AND MRF.MRF_TFO_CODIGO = TFO_CODIGO
         AND TFO_FON_CODIGO = P_FONDO
         AND TFO_PRV_PRF_CONSECUTIVO = P_PRV_PRF
         AND TFO_PRV_CONSECUTIVO = P_PRV
         AND TFO_FONDEO = 'S'
         AND TFO_DERIVADO = 'S'
         AND (('Cierre Dia' = 'Cierre Dia' AND
             MRF.MRF_FECHA =
             (SELECT MAX(MRF2.MRF_FECHA)
                  FROM MVTOS_RENTA_FIJA MRF2
                 WHERE MRF2.MRF_TFO_FON_CODIGO = MRF.MRF_TFO_FON_CODIGO
                   AND MRF2.MRF_TFO_CODIGO = MRF.MRF_TFO_CODIGO
                   AND MRF2.MRF_FECHA >= TRUNC(P_FECHA)
                   AND MRF2.MRF_FECHA < TRUNC(P_FECHA + 1)) AND
             ((EXISTS
              (SELECT 'X'
                    FROM CONFIRMACION_FONDOS_DIA
                   WHERE CFD_FON_CODIGO = TFO_FON_CODIGO
                     AND CFD_FECHA >= TRUNC(P_FECHA + 1)
                     AND CFD_FECHA < TRUNC(P_FECHA + 2)
                     AND CFD_VALORIZACION_PORTAFOLIO = 'S') AND EXISTS
              (SELECT 'X'
                    FROM MVTOS_RENTA_FIJA MRF3
                   WHERE MRF3.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                     AND MRF3.MRF_TFO_CODIGO = TFO_CODIGO
                     AND MRF3.MRF_FECHA >= TRUNC(P_FECHA + 1)
                     AND MRF3.MRF_FECHA < TRUNC(P_FECHA + 2)
                     AND MRF3.MRF_TMT_MNEMONICO = 'VAF') AND
              TFO_FECHA_OPERACION < TRUNC(P_FECHA + 1)) OR
             (NOT EXISTS (SELECT 'X'
                               FROM CONFIRMACION_FONDOS_DIA
                              WHERE CFD_FON_CODIGO = TFO_FON_CODIGO
                                AND CFD_FECHA >= TRUNC(P_FECHA + 1)
                                AND CFD_FECHA < TRUNC(P_FECHA + 2)
                                AND CFD_VALORIZACION_PORTAFOLIO = 'S') AND
              TFO_DIA_SIGUIENTE = 'S') OR
             (EXISTS
              (SELECT 'X'
                    FROM MVTOS_RENTA_FIJA MRF4
                   WHERE MRF4.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                     AND MRF4.MRF_TFO_CODIGO = TFO_CODIGO
                     AND MRF4.MRF_FECHA >= TRUNC(P_FECHA)
                     AND MRF4.MRF_FECHA < TRUNC(P_FECHA + 1)
                     AND MRF4.MRF_TMT_MNEMONICO IN ('VAF', 'CRF')
                     AND MRF4.MRF_FECHA =
                         (SELECT MAX(MRF5.MRF_FECHA)
                            FROM MVTOS_RENTA_FIJA MRF5
                           WHERE MRF5.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                             AND MRF5.MRF_TFO_CODIGO = TFO_CODIGO)) AND
              TFO_ETI_CODIGO IN ('UNI', 'FRC') AND EXISTS
              (SELECT 'X'
                    FROM MVTOS_RENTA_FIJA MRF4,
                         FRACCIONAMIENTOS_UNIFICACIONES
                   WHERE MRF4.MRF_TFO_FON_CODIGO =
                         FUN_TFO_FON_CODIGO_ES_PRODUCID
                     AND MRF4.MRF_TFO_CODIGO = FUN_TFO_CODIGO_ES_PRODUCIDA
                     AND MRF4.MRF_FECHA >= TRUNC(P_FECHA + 1)
                     AND MRF4.MRF_FECHA < TRUNC(P_FECHA + 2)
                     AND MRF4.MRF_TMT_MNEMONICO IN
                         ('UNI', 'FRA', 'DCO', 'OCO', 'OVE', 'DVE')
                     AND FUN_TFO_FON_CODIGO = TFO_FON_CODIGO
                     AND FUN_TFO_CODIGO = TFO_CODIGO)))));

    CURSOR C_EFECTIVO_C(P_FECHA   DATE,
                        P_FONDO   VARCHAR2,
                        P_PRC_PRF NUMBER,
                        P_PRC     NUMBER) IS
      SELECT MRF.MRF_VALOR_TITULO_TM
        FROM MVTOS_RENTA_FIJA MRF, TITULOS_FONDOS
       WHERE MRF.MRF_FECHA >= TRUNC(P_FECHA)
         AND MRF.MRF_FECHA < TRUNC(P_FECHA + 1)
         AND MRF.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
         AND MRF.MRF_TFO_CODIGO = TFO_CODIGO
         AND TFO_FON_CODIGO = P_FONDO
         AND TFO_PRC_PRF_CONSECUTIVO = P_PRC_PRF
         AND TFO_PRC_CONSECUTIVO = P_PRC
         AND TFO_FONDEO = 'S'
         AND (('Cierre Dia' = 'Cierre Dia' AND
             MRF.MRF_FECHA =
             (SELECT MAX(MRF2.MRF_FECHA)
                  FROM MVTOS_RENTA_FIJA MRF2
                 WHERE MRF2.MRF_TFO_FON_CODIGO = MRF.MRF_TFO_FON_CODIGO
                   AND MRF2.MRF_TFO_CODIGO = MRF.MRF_TFO_CODIGO
                   AND MRF2.MRF_FECHA >= TRUNC(P_FECHA)
                   AND MRF2.MRF_FECHA < TRUNC(P_FECHA + 1)) AND
             ((EXISTS
              (SELECT 'X'
                    FROM CONFIRMACION_FONDOS_DIA
                   WHERE CFD_FON_CODIGO = TFO_FON_CODIGO
                     AND CFD_FECHA >= TRUNC(P_FECHA + 1)
                     AND CFD_FECHA < TRUNC(P_FECHA + 2)
                     AND CFD_VALORIZACION_PORTAFOLIO = 'S') AND EXISTS
              (SELECT 'X'
                    FROM MVTOS_RENTA_FIJA MRF3
                   WHERE MRF3.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                     AND MRF3.MRF_TFO_CODIGO = TFO_CODIGO
                     AND MRF3.MRF_FECHA >= TRUNC(P_FECHA + 1)
                     AND MRF3.MRF_FECHA < TRUNC(P_FECHA + 2)
                     AND MRF3.MRF_TMT_MNEMONICO = 'VAF') AND
              TFO_FECHA_OPERACION < TRUNC(P_FECHA + 1)) OR
             (NOT EXISTS (SELECT 'X'
                               FROM CONFIRMACION_FONDOS_DIA
                              WHERE CFD_FON_CODIGO = TFO_FON_CODIGO
                                AND CFD_FECHA >= TRUNC(P_FECHA + 1)
                                AND CFD_FECHA < TRUNC(P_FECHA + 2)
                                AND CFD_VALORIZACION_PORTAFOLIO = 'S') AND
              TFO_DIA_SIGUIENTE = 'S') OR
             (EXISTS
              (SELECT 'X'
                    FROM MVTOS_RENTA_FIJA MRF4
                   WHERE MRF4.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                     AND MRF4.MRF_TFO_CODIGO = TFO_CODIGO
                     AND MRF4.MRF_FECHA >= TRUNC(P_FECHA)
                     AND MRF4.MRF_FECHA < TRUNC(P_FECHA + 1)
                     AND MRF4.MRF_TMT_MNEMONICO IN ('VAF', 'CRF')
                     AND MRF4.MRF_FECHA =
                         (SELECT MAX(MRF5.MRF_FECHA)
                            FROM MVTOS_RENTA_FIJA MRF5
                           WHERE MRF5.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                             AND MRF5.MRF_TFO_CODIGO = TFO_CODIGO)) AND
              TFO_ETI_CODIGO IN ('UNI', 'FRC') AND EXISTS
              (SELECT 'X'
                    FROM MVTOS_RENTA_FIJA MRF4,
                         FRACCIONAMIENTOS_UNIFICACIONES
                   WHERE MRF4.MRF_TFO_FON_CODIGO =
                         FUN_TFO_FON_CODIGO_ES_PRODUCID
                     AND MRF4.MRF_TFO_CODIGO = FUN_TFO_CODIGO_ES_PRODUCIDA
                     AND MRF4.MRF_FECHA >= TRUNC(P_FECHA + 1)
                     AND MRF4.MRF_FECHA < TRUNC(P_FECHA + 2)
                     AND MRF4.MRF_TMT_MNEMONICO IN
                         ('UNI', 'FRA', 'DCO', 'OCO', 'OVE', 'DVE')
                     AND FUN_TFO_FON_CODIGO = TFO_FON_CODIGO
                     AND FUN_TFO_CODIGO = TFO_CODIGO)))));
    COND VARCHAR2(1);

    CURSOR C_FECHA(P_FONDO VARCHAR2, P_PRV_PRF NUMBER) IS
      SELECT PRF_FECHA_OPERACION
        FROM PREORDENES_FONDOS, PREORDENES_VENTA
       WHERE PRF_FON_CODIGO = PRV_PRF_FON_CODIGO
         AND PRF_CONSECUTIVO = PRV_PRF_CONSECUTIVO
         AND PRV_PRF_FON_CODIGO = P_FONDO
         AND PRV_PRC_PRF_CONSECUTIVO = P_PRV_PRF;

    VALOR_TITULO_TM         NUMBER;
    NEGOCIO                 NUMBER;
    BOLSA                   VARCHAR2(10);
    FECHA_REGISTRO          DATE;
    FECHA_CUMPLIMIENTO      DATE;
    VALOR_INICIAL           NUMBER;
    VALOR_CUMPLIMIENTO      NUMBER;
    NUMERO_OPERACION        NUMBER;
    CONTRAPARTE             VARCHAR2(100);
    REGISTRA_CLIENTE        VARCHAR2(10);
    COMERCIAL               VARCHAR2(100);
    VALOR_PRESENTE_EFECTIVO NUMBER;
    TIPO_OPERACION          VARCHAR2(5);
    TASA_FUTURA             NUMBER;
    FECHA_ORIG              DATE;

    VALORIZACION_DERECHO    NUMBER;
    TITULO_OBLIGACION       NUMBER;
    VALORIZACION_OBLIGACION NUMBER;
    NUMERO_OPERACION_OBLIG  NUMBER;
    V_TITULO_DERECHO        NUMBER;
    V_TITULO_OBLIGACION     NUMBER;

    FUNCTION TITULO_DERECHO(P_TITULO NUMBER, P_FONDO VARCHAR2) RETURN NUMBER IS
      V_CONSEC              NUMBER;
      PRC_CONSEC            NUMBER;
      V_PRC_PRF_CONSECUTIVO NUMBER;
      V_PRC_CONSECUTIVO     NUMBER;
      V_PRV_PRF_CONSECUTIVO NUMBER;
      V_PRV_CONSECUTIVO     NUMBER;
      V_TITULO              NUMBER;

    begin
      V_TITULO := 0;
      BEGIN
        SELECT TFO_PRC_PRF_CONSECUTIVO,
               TFO_PRC_CONSECUTIVO,
               TFO_PRV_PRF_CONSECUTIVO,
               TFO_PRV_CONSECUTIVO
          INTO V_PRC_PRF_CONSECUTIVO,
               V_PRC_CONSECUTIVO,
               V_PRV_PRF_CONSECUTIVO,
               V_PRV_CONSECUTIVO
          FROM TITULOS_FONDOS
         WHERE tfo_codigo = P_TITULO
           AND TFO_FON_CODIGO = P_FONDO;
      EXCEPTION
        WHEN NO_DATA_FOUND THEN
          V_PRC_PRF_CONSECUTIVO := 0;
          V_PRV_PRF_CONSECUTIVO := 0;
      END;

      IF NVL(V_PRC_PRF_CONSECUTIVO, 0) <> 0 THEN
        BEGIN
          SELECT TFO_CODIGO
            INTO V_TITULO
            FROM TITULOS_FONDOS
           WHERE TFO_PRC_PRF_CONSECUTIVO = V_PRC_PRF_CONSECUTIVO
             AND TFO_ETI_CODIGO NOT IN ('VEN', 'ANU', 'CDC')
             AND TFO_PRC_CONSECUTIVO = V_PRC_CONSECUTIVO
             AND TFO_CODIGO NOT IN (P_TITULO)
             AND TFO_FON_CODIGO = P_FONDO
             AND TFO_VALOR_OPERACION > 0;
        EXCEPTION
          WHEN NO_DATA_FOUND THEN
            V_TITULO := NULL;
        END;
      ELSIF NVL(V_PRV_PRF_CONSECUTIVO, 0) <> 0 THEN
        SELECT TFO_CODIGO
          INTO V_TITULO
          FROM TITULOS_FONDOS
         WHERE TFO_PRV_PRF_CONSECUTIVO = V_PRV_PRF_CONSECUTIVO
           AND TFO_ETI_CODIGO NOT IN ('VEN', 'ANU', 'CDC')
           AND TFO_PRV_CONSECUTIVO = V_PRV_CONSECUTIVO
           AND TFO_CODIGO NOT IN (P_TITULO)
           AND TFO_FON_CODIGO = P_FONDO
           AND TFO_VALOR_OPERACION > 0;
      ELSE
        V_TITULO := 0;
      END IF;

      RETURN V_TITULO;

    END;

    FUNCTION F_TITULO_DERECHO(P_TITULO NUMBER, P_FONDOS VARCHAR2)
      RETURN NUMBER IS
      V_CONSEC   NUMBER;
      PRC_CONSEC NUMBER;
      V_TITULO   NUMBER;
    begin
      BEGIN
        SELECT DECODE(TFO_PRC_PRF_CONSECUTIVO,
                      NULL,
                      TFO_PRV_PRF_CONSECUTIVO,
                      TFO_PRC_PRF_CONSECUTIVO),
               DECODE(TFO_PRC_CONSECUTIVO,
                      NULL,
                      TFO_PRV_CONSECUTIVO,
                      TFO_PRC_CONSECUTIVO)
          INTO V_CONSEC, PRC_CONSEC
          FROM TITULOS_FONDOS
         WHERE tfo_codigo = P_TITULO
           AND TFO_FON_CODIGO = P_FONDOS;
      EXCEPTION
        WHEN NO_DATA_FOUND THEN
          V_CONSEC := 0;
      END;

      IF NVL(V_CONSEC, 0) <> 0 THEN
        BEGIN
          SELECT TFO_CODIGO
            INTO V_TITULO
            FROM TITULOS_FONDOS
           WHERE (TFO_PRC_PRF_CONSECUTIVO = V_CONSEC OR
                 TFO_PRV_PRF_CONSECUTIVO = V_CONSEC)
             AND TFO_ETI_CODIGO NOT IN ('VEN')
             AND (TFO_PRC_CONSECUTIVO = PRC_CONSEC OR
                 TFO_PRV_CONSECUTIVO = PRC_CONSEC)
             AND TFO_FON_CODIGO = P_FONDOS
             AND TFO_VALOR_OPERACION < 0
             AND TFO_FONDEO = 'N'
             AND ROWNUM = 1
           ORDER BY TFO_CODIGO ASC;

        EXCEPTION
          WHEN NO_DATA_FOUND THEN
            V_TITULO := NULL;
        END;
      END IF;

      RETURN V_TITULO;

    END;

    FUNCTION F_VALORIZACION_OBLIGACION(P_TITULO_DER NUMBER,
                                       P_FONDO      VARCHAR2,
                                       P_BMO        VARCHAR2,
                                       P_ENA        VARCHAR2,
                                       P_FECHA      DATE) RETURN NUMBER IS
      VALORIZACION     NUMBER;
      VLR_DERECHO      NUMBER;
      VLR_OBLIGACION   NUMBER;
      V_BMO            NUMBER;
      V_TIR            NUMBER;
      V_BASE_MONETARIA VARCHAR2(10);
      V_FONDO          VARCHAR2(15);
      V_VALOR          NUMBER;

    BEGIN

      BEGIN
        SELECT MRF_TIR365_M
          INTO V_TIR
          FROM MVTOS_RENTA_FIJA, TITULOS_FONDOS, FONDOS
         WHERE TFO_FON_CODIGO = FON_CODIGO
           AND TFO_FON_CODIGO = MRF_TFO_FON_CODIGO
           AND TFO_CODIGO = MRF_TFO_CODIGO
           AND MRF_TFO_CODIGO = P_TITULO_DER
           AND MRF_FECHA >= TRUNC(P_FECHA)
           AND MRF_FECHA < TRUNC(P_FECHA + 1)
           AND MRF_VALOR_TITULO_TM <> 0
           AND NOT EXISTS
         (SELECT 'X'
                  FROM FONDOS, PARAMETROS_FONDOS
                 WHERE PFO_FON_CODIGO = FON_CODIGO
                   AND PFO_PAR_CODIGO in (70)
                   AND NVL(PFO_RANGO_MIN_CHAR, 'N') = 'S'
                   AND FON_CODIGO = TFO_FON_CODIGO)
           AND MRF_TFO_FON_CODIGO = P_FONDO
           AND MRF_FECHA =
               (SELECT MAX(MRF1.MRF_FECHA)
                  FROM MVTOS_RENTA_FIJA MRF1
                 WHERE MRF1.MRF_TFO_FON_CODIGO = P_FONDO
                   AND MRF1.MRF_TFO_CODIGO = TFO_CODIGO
                   AND MRF1.MRF_FECHA >= TRUNC(P_FECHA)
                   AND MRF1.MRF_FECHA < TRUNC(P_FECHA + 1))
           AND ((EXISTS
                (SELECT 'X'
                    FROM CONFIRMACION_FONDOS_DIA
                   WHERE CFD_FON_CODIGO = TFO_FON_CODIGO
                     AND CFD_FECHA >= TRUNC(P_FECHA) + 1
                     AND CFD_FECHA < TRUNC(P_FECHA + 2)
                     AND CFD_VALORIZACION_PORTAFOLIO = 'S') AND EXISTS
                (SELECT 'X'
                    FROM MVTOS_RENTA_FIJA MRF3
                   WHERE MRF3.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                     AND MRF3.MRF_TFO_CODIGO = TFO_CODIGO
                     AND MRF3.MRF_FECHA >= TRUNC(P_FECHA) + 1
                     AND MRF3.MRF_FECHA < TRUNC(P_FECHA + 2)
                     AND (MRF3.MRF_TMT_MNEMONICO = 'VAF' OR
                         (MRF3.MRF_TMT_MNEMONICO = 'VGA' OR
                         MRF3.MRF_TMT_MNEMONICO = 'LRI' OR
                         MRF3.MRF_TMT_MNEMONICO = 'GRI'))) AND
                TFO_FECHA_OPERACION < TRUNC(P_FECHA + 1)) OR
               (NOT EXISTS (SELECT 'X'
                               FROM CONFIRMACION_FONDOS_DIA
                              WHERE CFD_FON_CODIGO = TFO_FON_CODIGO
                                AND CFD_FECHA >= TRUNC(P_FECHA) + 1
                                AND CFD_FECHA < TRUNC(P_FECHA + 2)
                                AND CFD_VALORIZACION_PORTAFOLIO = 'S') AND
                TFO_DIA_SIGUIENTE = 'S') OR
               (EXISTS
                (SELECT 'X'
                    FROM MVTOS_RENTA_FIJA MRF4
                   WHERE MRF4.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                     AND MRF4.MRF_TFO_CODIGO = TFO_CODIGO
                     AND MRF4.MRF_FECHA >= TRUNC(P_FECHA)
                     AND MRF4.MRF_FECHA < TRUNC(P_FECHA + 1)
                     AND MRF4.MRF_TMT_MNEMONICO IN ('VAF', 'CRF', 'REN')
                     AND MRF4.MRF_FECHA =
                         (SELECT MAX(MRF5.MRF_FECHA)
                            FROM MVTOS_RENTA_FIJA MRF5
                           WHERE MRF5.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                             AND MRF5.MRF_TFO_CODIGO = TFO_CODIGO)) AND
                TFO_ETI_CODIGO IN ('UNI', 'FRC') AND EXISTS
                (SELECT 'X'
                    FROM MVTOS_RENTA_FIJA MRF4,
                         FRACCIONAMIENTOS_UNIFICACIONES
                   WHERE MRF4.MRF_TFO_FON_CODIGO =
                         FUN_TFO_FON_CODIGO_ES_PRODUCID
                     AND MRF4.MRF_TFO_CODIGO = FUN_TFO_CODIGO_ES_PRODUCIDA
                     AND MRF4.MRF_FECHA >= TRUNC(P_FECHA) + 1
                     AND MRF4.MRF_FECHA < TRUNC(P_FECHA + 2)
                     AND MRF4.MRF_TMT_MNEMONICO IN ('UNI', 'FRA')
                     AND FUN_TFO_FON_CODIGO = TFO_FON_CODIGO
                     AND FUN_TFO_CODIGO = TFO_CODIGO)

               ) OR
               (EXISTS (SELECT /*+ INDEX (MRF4 MRF_PK) */
                          'X'
                           FROM MVTOS_RENTA_FIJA MRF4
                          WHERE MRF4.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                            AND MRF4.MRF_TFO_CODIGO = TFO_CODIGO
                            AND MRF4.MRF_TMT_MNEMONICO IN ('TGA', 'VGA')
                            AND MRF4.MRF_FECHA >= TRUNC(P_FECHA)
                            AND MRF4.MRF_FECHA < TRUNC(P_FECHA + 1))));
      EXCEPTION
        WHEN NO_DATA_FOUND THEN
          V_TIR := 0;
      END;

      BEGIN
        SELECT DISTINCT TFO_BMO_MNEMONICO
          INTO V_BASE_MONETARIA
          FROM TITULOS_FONDOS
         WHERE TFO_CODIGO = P_TITULO_DER
           AND TFO_ENA_MNEMONICO = P_ENA
           AND ROWNUM = 1;
      EXCEPTION
        WHEN NO_DATA_FOUND THEN
          V_BASE_MONETARIA := NULL;
      END;

      BEGIN
        SELECT TFO_FON_CODIGO
          INTO V_FONDO
          FROM TITULOS_FONDOS
         WHERE tfo_codigo = P_TITULO_DER
           AND ROWNUM = 1;
      EXCEPTION
        WHEN NO_DATA_FOUND THEN
          V_FONDO := NULL;
      END;

      BEGIN
        SELECT NVL(P_TITULOS.VPN_TIT_M365_RF_MG(P_FONDO,
                                                P_TITULO_DER,
                                                0,
                                                TRUNC(P_FECHA),
                                                V_TIR),
                   0)
          INTO VALORIZACION
          FROM DUAL;
      EXCEPTION
        WHEN NO_DATA_FOUND THEN
          VALORIZACION := 0;
      END;

      IF P_BMO != 'PESOS' THEN
        BEGIN
          SELECT CBM_VALOR
            INTO V_BMO
            FROM COTIZACIONES_BASE_MONETARIAS
           WHERE CBM_BMO_MNEMONICO = V_BASE_MONETARIA
             AND CBM_FECHA >= TRUNC(P_FECHA)
             AND CBM_FECHA < TRUNC(P_FECHA + 1);
        EXCEPTION
          WHEN NO_DATA_FOUND THEN
            V_BMO := 0;
        END;
        V_VALOR := VALORIZACION * V_BMO;
      ELSE
        V_VALOR := VALORIZACION;
      END IF;

      RETURN V_VALOR;
    end;

  BEGIN
    DELETE TMP_RECOFU_VENTAS;
    COMMIT;
    FOR R_VENTAS IN C_VENTAS LOOP
      TASA_FUTURA := NULL;
      OPEN C_MOVIMIENTO(R_VENTAS.TFO_FON_CODIGO, R_VENTAS.TFO_CODIGO);
      FETCH C_MOVIMIENTO
        INTO MRF1;
      IF C_MOVIMIENTO%NOTFOUND THEN
        CLOSE C_MOVIMIENTO;
        NULL;
      END IF;
      CLOSE C_MOVIMIENTO;

      IF MRF1.MRF_TMT_MNEMONICO = 'OVE' THEN
        IF R_VENTAS.TFO_BMO_MNEMONICO = 'PESOS' THEN
          CBM1.CBM_VALOR := 1;
        ELSE
          IF R_VENTAS.TFO_BMO_MNEMONICO = 'DOLAR' THEN
            OPEN C_COTIZACION(R_VENTAS.MRF_FECHA_VALORIZACION + 1,
                              R_VENTAS.TFO_BMO_MNEMONICO);
            FETCH C_COTIZACION
              INTO CBM1;
            CLOSE C_COTIZACION;
          ELSE
            OPEN C_COTIZACION(R_VENTAS.MRF_FECHA_VALORIZACION,
                              R_VENTAS.TFO_BMO_MNEMONICO);
            FETCH C_COTIZACION
              INTO CBM1;
            CLOSE C_COTIZACION;
          END IF;

          /*FETCH C_COTIZACION INTO CBM1;
          IF C_COTIZACION%NOTFOUND THEN
             CLOSE C_COTIZACION;
                NULL;
          END IF;*/
        END IF;
        VALOR_TITULO_TM := R_VENTAS.MRF_VALOR_TITULO_TM * CBM1.CBM_VALOR;

        OPEN C_NEGOCIO(R_VENTAS.TFO_FON_CODIGO,
                       R_VENTAS.TFO_PRV_PRF_CONSECUTIVO,
                       R_VENTAS.TFO_PRV_CONSECUTIVO);
        FETCH C_NEGOCIO
          INTO PRV1;
        IF C_NEGOCIO%NOTFOUND THEN
          CLOSE C_NEGOCIO;
          NULL;
        END IF;
        CLOSE C_NEGOCIO;
        NEGOCIO            := PRV1.PRV_PRF_CONSECUTIVO;
        BOLSA              := PRV1.PRV_BOL_MNEMONICO;
        FECHA_REGISTRO     := PRV1.PRF_FECHA_OPERACION;
        FECHA_CUMPLIMIENTO := PRV1.PRV_FECHA_CUMPLIMIENTO;
        VALOR_INICIAL      := -R_VENTAS.TFO_VALOR_OPERACION;
        VALOR_CUMPLIMIENTO := PRV1.PRV_MONTO;
        NUMERO_OPERACION   := PRV1.PRV_NUMERO_OPERACION;
        REGISTRA_CLIENTE   := NVL(PRV1.PRV_REGISTRA_CLIENTE, ' ');
        IF TRUNC(FECHA_REGISTRO) = TRUNC(FECHA_CUMPLIMIENTO) THEN
          OPEN C_FECHA(R_VENTAS.TFO_FON_CODIGO,
                       R_VENTAS.TFO_PRV_PRF_CONSECUTIVO);
          FETCH C_FECHA
            INTO FECHA_REGISTRO;
          CLOSE C_FECHA;
        END IF;
        CONTRAPARTE := NULL;
        POS_POP     := NULL;
        OPEN C_PARAMETRO(R_VENTAS.TFO_FON_CODIGO);
        FETCH C_PARAMETRO
          INTO POS_POP;
        CLOSE C_PARAMETRO;
        IF NVL(POS_POP, ' ') = 'X' AND
           PRV1.PRV_CLI_PER_NUM_IDEN = '860079174' AND
           PRV1.PRV_CLI_PER_TID_CODIGO = 'NIT' THEN
          OPEN C_CONTRAPARTE(PRV1.PRV_PER_NUM_IDEN_CONTRAPARTE,
                             PRV1.PRV_PER_TID_CODIGO_CONTRAPARTE);
          FETCH C_CONTRAPARTE
            INTO CONTRAPARTE, TIPO;
          IF C_CONTRAPARTE%NOTFOUND THEN
            NULL;
          END IF;
          IF TIPO = 'PNA' THEN
            CONTRAPARTE := 'PERSONA NATURAL';
          END IF;
          CLOSE C_CONTRAPARTE;
        ELSE
          OPEN C_CONTRAPARTE(PRV1.PRV_CLI_PER_NUM_IDEN,
                             PRV1.PRV_CLI_PER_TID_CODIGO);
          FETCH C_CONTRAPARTE
            INTO CONTRAPARTE, TIPO;
          IF C_CONTRAPARTE%NOTFOUND THEN
            NULL;
          END IF;
          IF TIPO = 'PNA' THEN
            CONTRAPARTE := 'PERSONA NATURAL';
          END IF;
          CLOSE C_CONTRAPARTE;
        END IF;
        COMERCIAL := ' ';
        COND      := 'N';
        OPEN C_COMERCIAL(R_VENTAS.TFO_FON_CODIGO,
                         R_VENTAS.TFO_PRV_PRF_CONSECUTIVO);
        FETCH C_COMERCIAL
          INTO PER1;
        WHILE C_COMERCIAL%FOUND LOOP
          IF COND = 'S' THEN
            COMERCIAL := COMERCIAL || ' - ';
          END IF;
          COMERCIAL := COMERCIAL || PER1.PER_INICIALES_USUARIO;
          COND      := 'S';
          FETCH C_COMERCIAL
            INTO PER1;
        END LOOP;
        CLOSE C_COMERCIAL;
        COMERCIAL := LTRIM(COMERCIAL);
        OPEN C_EFECTIVO(R_VENTAS.TFO_FON_CODIGO,
                        R_VENTAS.TFO_PRV_PRF_CONSECUTIVO,
                        R_VENTAS.TFO_PRV_CONSECUTIVO,
                        R_VENTAS.FECHA);
        FETCH C_EFECTIVO
          INTO VALOR_PRESENTE_EFECTIVO;
        CLOSE C_EFECTIVO;
        VALOR_PRESENTE_EFECTIVO := NVL(VALOR_PRESENTE_EFECTIVO, 0);
        TIPO_OPERACION          := NVL(PRV1.PRV_CNE_MNEMONICO, ' ');
      ELSIF MRF1.MRF_TMT_MNEMONICO = 'FAC' THEN
        OPEN C_NEGOCIO_C(R_VENTAS.TFO_FON_CODIGO,
                         R_VENTAS.TFO_PRC_PRF_CONSECUTIVO,
                         R_VENTAS.TFO_PRC_CONSECUTIVO);
        FETCH C_NEGOCIO_C
          INTO PRC1;
        IF C_NEGOCIO_C%NOTFOUND THEN
          CLOSE C_NEGOCIO_C;
          NULL;
        END IF;
        CLOSE C_NEGOCIO_C;
        OPEN C_TGA(R_VENTAS.TFO_FON_CODIGO,
                   R_VENTAS.TFO_PRC_PRF_CONSECUTIVO,
                   R_VENTAS.TFO_PRC_CONSECUTIVO,
                   R_VENTAS.FECHA);
        FETCH C_TGA
          INTO MRF2;
        IF C_TGA%FOUND THEN
          IF R_VENTAS.TFO_BMO_MNEMONICO = 'PESOS' THEN
            CBM1.CBM_VALOR := 1;
          ELSE
            IF R_VENTAS.TFO_BMO_MNEMONICO = 'DOLAR' THEN
              OPEN C_COTIZACION(MRF2.MRF_FECHA_VALORIZACION + 1,
                                R_VENTAS.TFO_BMO_MNEMONICO);
              FETCH C_COTIZACION
                INTO CBM1;
              CLOSE C_COTIZACION;
            ELSE
              OPEN C_COTIZACION(MRF2.MRF_FECHA_VALORIZACION,
                                R_VENTAS.TFO_BMO_MNEMONICO);
              FETCH C_COTIZACION
                INTO CBM1;
              CLOSE C_COTIZACION;
            END IF;
            /*FETCH C_COTIZACION INTO CBM1;
            IF C_COTIZACION%NOTFOUND THEN
               CLOSE C_COTIZACION;
                NULL;
            END IF;*/
          END IF;

          VALOR_TITULO_TM := MRF2.MRF_VALOR_TITULO_TM * CBM1.CBM_VALOR;
        ELSE
          VALOR_TITULO_TM := -PRC1.PRC_MONTO;
        END IF;
        CLOSE C_TGA;
        NEGOCIO            := PRC1.PRC_PRF_CONSECUTIVO;
        BOLSA              := PRC1.PRV_BOL_MNEMONICO;
        FECHA_REGISTRO     := PRC1.PRF_FECHA_OPERACION;
        FECHA_CUMPLIMIENTO := PRC1.PRC_FECHA_VENTA_FUTURA;
        TASA_FUTURA        := ROUND(PRC1.PRC_TASA_FUTURA, 3);
        VALOR_INICIAL      := PRC1.PRC_MONTO;
        VALOR_CUMPLIMIENTO := PRC1.PRC_VALOR_FUTURO;
        NUMERO_OPERACION   := PRC1.PRV_NUMERO_OPERACION;
        REGISTRA_CLIENTE   := NVL(PRC1.PRV_REGISTRA_CLIENTE, ' ');
        CONTRAPARTE        := NULL;
        POS_POP            := NULL;
        OPEN C_PARAMETRO(R_VENTAS.TFO_FON_CODIGO);
        FETCH C_PARAMETRO
          INTO POS_POP;
        CLOSE C_PARAMETRO;
        IF NVL(POS_POP, ' ') = 'X' AND
           PRC1.PRV_CLI_PER_NUM_IDEN = '860079174' AND
           PRC1.PRV_CLI_PER_TID_CODIGO = 'NIT' THEN
          OPEN C_CONTRAPARTE(PRC1.PRV_PER_NUM_IDEN_CONTRAPARTE,
                             PRC1.PRV_PER_TID_CODIGO_CONTRAPARTE);
          FETCH C_CONTRAPARTE
            INTO CONTRAPARTE, TIPO;
          IF C_CONTRAPARTE%NOTFOUND THEN
            NULL;
          END IF;
          IF TIPO = 'PNA' THEN
            CONTRAPARTE := 'PERSONA NATURAL';
          END IF;
          CLOSE C_CONTRAPARTE;
        ELSE
          OPEN C_CONTRAPARTE(PRC1.PRV_CLI_PER_NUM_IDEN,
                             PRC1.PRV_CLI_PER_TID_CODIGO);
          FETCH C_CONTRAPARTE
            INTO CONTRAPARTE, TIPO;
          IF C_CONTRAPARTE%NOTFOUND THEN
            NULL;
          END IF;
          IF TIPO = 'PNA' THEN
            CONTRAPARTE := 'PERSONA NATURAL';
          END IF;
          CLOSE C_CONTRAPARTE;
        END IF;
        COMERCIAL := ' ';
        COND      := 'N';
        OPEN C_COMERCIAL(R_VENTAS.TFO_FON_CODIGO,
                         R_VENTAS.TFO_PRC_PRF_CONSECUTIVO);
        FETCH C_COMERCIAL
          INTO PER1;
        WHILE C_COMERCIAL%FOUND LOOP
          IF COND = 'S' THEN
            COMERCIAL := COMERCIAL || ' - ';
          END IF;
          COMERCIAL := COMERCIAL || PER1.PER_INICIALES_USUARIO;
          COND      := 'S';
          FETCH C_COMERCIAL
            INTO PER1;
        END LOOP;
        CLOSE C_COMERCIAL;
        COMERCIAL := LTRIM(COMERCIAL);
        OPEN C_EFECTIVO_C(R_VENTAS.FECHA,
                          R_VENTAS.TFO_FON_CODIGO,
                          R_VENTAS.TFO_PRC_PRF_CONSECUTIVO,
                          R_VENTAS.TFO_PRC_CONSECUTIVO);
        FETCH C_EFECTIVO_C
          INTO VALOR_PRESENTE_EFECTIVO;
        CLOSE C_EFECTIVO_C;
        VALOR_PRESENTE_EFECTIVO := NVL(VALOR_PRESENTE_EFECTIVO, 0);
        TIPO_OPERACION          := NVL(PRC1.PRV_CNE_MNEMONICO, ' ');
      END IF;

      TITULO_OBLIGACION := TITULO_OBL(R_VENTAS.TFO_CODIGO,
                                      R_VENTAS.TFO_FON_CODIGO);

      NUMERO_OPERACION_OBLIG  := NUMERO_OPE_OBLIG(R_VENTAS.TFO_FON_CODIGO,
                                                  R_VENTAS.TFO_CODIGO,
                                                  TITULO_OBL(R_VENTAS.TFO_CODIGO,
                                                             R_VENTAS.TFO_FON_CODIGO));
      FECHA_ORIG              := FECHA_ORIG_CUMPLI(R_VENTAS.TFO_CODIGO);
      V_TITULO_DERECHO        := TITULO_DERECHO(R_VENTAS.TFO_CODIGO,
                                                R_VENTAS.TFO_FON_CODIGO);
      VALORIZACION_OBLIGACION := VALORIZACION_OBL(R_VENTAS.FECHA,
                                                  V_TITULO_DERECHO,
                                                  R_VENTAS.TFO_FON_CODIGO,
                                                  R_VENTAS.TFO_ENA_MNEMONICO);
      V_TITULO_OBLIGACION     := F_TITULO_DERECHO(R_VENTAS.TFO_CODIGO,
                                                  R_VENTAS.TFO_FON_CODIGO);
      VALORIZACION_DERECHO    := F_VALORIZACION_OBLIGACION( /*R_VENTAS.TFO_CODIGO*/V_TITULO_OBLIGACION,
                                                           R_VENTAS.TFO_FON_CODIGO,
                                                           R_VENTAS.TFO_BMO_MNEMONICO,
                                                           R_VENTAS.TFO_ENA_MNEMONICO,
                                                           R_VENTAS.FECHA); --VALORIZACION(R_VENTAS.TFO_FON_CODIGO, R_VENTAS.TFO_CODIGO, :FILTRO.FECHA, R_VENTAS.MRF_TIR365_M, R_VENTAS.TFO_BMO_MNEMONICO);

      INSERT INTO TMP_RECOFU_VENTAS
        (FECHA_REPORTE,
         OPERACION,
         NUMERO_OPERACION,
         FONDO,
         EMISOR_COMPROMISO,
         NEMOTECNICO,
         ESPECIE,
         VALOR_NOMINAL,
         FECHA_EMISION,
         FECHA_VENCIMIENTO,
         INTERES_NOMINAL,
         MODALIDAD,
         TIPO_OPERACION,
         TASA_FUTURA,
         BOLSA,
         FECHA_REGISTRO,
         FECHA_ORIG_CUMPLIMIENTO,
         FECHA_CUMPL_COMPROMISO,
         VALOR_OPERACION_INICIAL,
         VALOR_CUMPLIMIENTO,
         NOMBRE_CONTRAPARTE,
         COMERCIAL,
         VALOR_PRESENTE_DERECHO,
         VALOR_PRESENTE_OBLIG,
         DIF_DERECHO_OBLIGACION,
         REGISTRA_CLIENTE,
         BASE_MONETARIA,
         TITULO_DERECHO,
         VALORIZACION_DERECHO,
         TITULO_OBLIGACION,
         VALORIZACION_OBLIGACION,
         NUMERO_OPERACION_DERECHO)
      VALUES
        (SYSDATE,
         'VENTAS',
         NUMERO_OPERACION,
         R_VENTAS.FON_RAZON_SOCIAL,
         R_VENTAS.EMI_DESCRIPCION,
         R_VENTAS.TFO_ENA_MNEMONICO,
         R_VENTAS.ENA_DESCRIPCION,
         R_VENTAS.TFO_VALOR_NOMINAL,
         R_VENTAS.TFO_FECHA_EMISION,
         R_VENTAS.TFO_FECHA_VENCIMIENTO,
         R_VENTAS.INTERES_NOMINAL,
         R_VENTAS.MODALIDAD,
         TIPO_OPERACION,
         TASA_FUTURA,
         BOLSA,
         FECHA_REGISTRO,
         FECHA_ORIG,
         FECHA_CUMPLIMIENTO,
         VALOR_INICIAL,
         VALOR_CUMPLIMIENTO,
         CONTRAPARTE,
         COMERCIAL,
         VALOR_PRESENTE_EFECTIVO,
         VALOR_TITULO_TM,
         (ABS(VALOR_PRESENTE_EFECTIVO) - ABS(VALOR_TITULO_TM)),
         REGISTRA_CLIENTE,
         R_VENTAS.TFO_BMO_MNEMONICO,
         V_TITULO_DERECHO,
         VALORIZACION_OBLIGACION --VALORIZACION_DERECHO
        ,
         V_TITULO_OBLIGACION,
         VALORIZACION_DERECHO --VALORIZACION_OBLIGACION
        ,
         NUMERO_OPERACION_OBLIG);
      COMMIT;
    END LOOP;
  END GENERA_RECOFU_VENTAS_TODOS;

  PROCEDURE P_EJECUTA_RECOFU IS
    P_CODIGO       VARCHAR2(200);
    P_RESPUESTA    VARCHAR2(200);
    V_RUTA         VARCHAR2(100);
    NOMBRE_ARCHIVO VARCHAR2(100);
    P_NUM_INI      NUMBER;
    P_NUM_FIN      NUMBER;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_GENERA_REPORTES_RIESGOS - P_EJECUTA_RECOFU',
                                                      'INI');

    GENERA_RECOFU_TODOS;
    GENERA_RECOFU_VENTAS_TODOS;
    DELETE TMP_RECOFU;
    COMMIT;

    INSERT INTO TMP_RECOFU
      (FECHA_REPORTE,
       OPERACION,
       NUMERO_OPERACION,
       FONDO,
       EMISOR_COMPROMISO,
       NEMOTECNICO,
       ESPECIE,
       VALOR_NOMINAL,
       FECHA_EMISION,
       FECHA_VENCIMIENTO,
       INTERES_NOMINAL,
       MODALIDAD,
       TIPO_OPERACION,
       TASA_FUTURA,
       BOLSA,
       FECHA_REGISTRO,
       FECHA_ORIG_CUMPLIMIENTO,
       FECHA_CUMPL_COMPROMISO,
       VALOR_OPERACION_INICIAL,
       VALOR_CUMPLIMIENTO,
       NOMBRE_CONTRAPARTE,
       COMERCIAL,
       VALOR_PRESENTE_DERECHO,
       VALOR_PRESENTE_OBLIG,
       DIF_DERECHO_OBLIGACION,
       REGISTRA_CLIENTE,
       BASE_MONETARIA,
       TITULO_DERECHO,
       VALORIZACION_DERECHO,
       TITULO_OBLIGACION,
       VALORIZACION_OBLIGACION,
       NUMERO_OPERACION_OBLIG)
      SELECT FECHA_REPORTE,
             OPERACION,
             NUMERO_OPERACION,
             FONDO,
             EMISOR_COMPROMISO,
             NEMOTECNICO,
             ESPECIE,
             VALOR_NOMINAL,
             FECHA_EMISION,
             FECHA_VENCIMIENTO,
             INTERES_NOMINAL,
             MODALIDAD,
             TIPO_OPERACION,
             TASA_FUTURA,
             BOLSA,
             FECHA_REGISTRO,
             FECHA_ORIG_CUMPLIMIENTO,
             FECHA_CUMPL_COMPROMISO,
             VALOR_OPERACION_INICIAL,
             VALOR_CUMPLIMIENTO,
             NOMBRE_CONTRAPARTE,
             COMERCIAL,
             VALOR_PRESENTE_DERECHO,
             VALOR_PRESENTE_OBLIG,
             DIF_DERECHO_OBLIGACION,
             REGISTRA_CLIENTE,
             BASE_MONETARIA,
             TITULO_DERECHO,
             VALORIZACION_DERECHO,
             TITULO_OBLIGACION,
             VALORIZACION_OBLIGACION,
             NUMERO_OPERACION_OBLIG
        FROM TMP_RECOFU_COMPRAS
      UNION
      SELECT FECHA_REPORTE,
             OPERACION,
             NUMERO_OPERACION,
             FONDO,
             EMISOR_COMPROMISO,
             NEMOTECNICO,
             ESPECIE,
             VALOR_NOMINAL,
             FECHA_EMISION,
             FECHA_VENCIMIENTO,
             INTERES_NOMINAL,
             MODALIDAD,
             TIPO_OPERACION,
             TASA_FUTURA,
             BOLSA,
             FECHA_REGISTRO,
             FECHA_ORIG_CUMPLIMIENTO,
             FECHA_CUMPL_COMPROMISO,
             VALOR_OPERACION_INICIAL,
             VALOR_CUMPLIMIENTO,
             NOMBRE_CONTRAPARTE,
             COMERCIAL,
             VALOR_PRESENTE_DERECHO,
             VALOR_PRESENTE_OBLIG,
             DIF_DERECHO_OBLIGACION,
             REGISTRA_CLIENTE,
             BASE_MONETARIA,
             TITULO_DERECHO,
             VALORIZACION_DERECHO,
             TITULO_OBLIGACION,
             VALORIZACION_OBLIGACION,
             NUMERO_OPERACION_DERECHO
        FROM TMP_RECOFU_VENTAS;
    COMMIT;

    V_RUTA         := '\\nas.corredor.local\Riesgo\CONFIDENCIAL\Reportes Excel Coeasy\';
    NOMBRE_ARCHIVO := 'RECOFU_' ||
                      TO_CHAR(SYSDATE - 1, 'DDMMYYYY_hh24mmss');

    --LLAMADO AL PROGRAMA QUE CREA EL XSLX
    P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => V_RUTA,
                                   P_NOMBRE_ARCHIVO => NOMBRE_ARCHIVO,
                                   P_QUERY          => 'SELECT FECHA_REPORTE ' ||
                                                       '     , OPERACION ' ||
                                                       '     , NUMERO_OPERACION ' ||
                                                       '     , FONDO ' ||
                                                       '     , EMISOR_COMPROMISO ' ||
                                                       '     , NEMOTECNICO ' ||
                                                       '     , ESPECIE ' ||
                                                       '     , VALOR_NOMINAL ' ||
                                                       '     , FECHA_EMISION ' ||
                                                       '     , FECHA_VENCIMIENTO ' ||
                                                       '     , INTERES_NOMINAL ' ||
                                                       '     , MODALIDAD ' ||
                                                       '     , TIPO_OPERACION ' ||
                                                       '     , TASA_FUTURA ' ||
                                                       '     , BOLSA ' ||
                                                       '     , FECHA_REGISTRO ' ||
                                                       '     , FECHA_ORIG_CUMPLIMIENTO ' ||
                                                       '     , FECHA_CUMPL_COMPROMISO ' ||
                                                       '     , VALOR_OPERACION_INICIAL ' ||
                                                       '     , VALOR_CUMPLIMIENTO ' ||
                                                       '     , NOMBRE_CONTRAPARTE ' ||
                                                       '     , COMERCIAL ' ||
                                                       '     , VALOR_PRESENTE_DERECHO ' ||
                                                       '     , VALOR_PRESENTE_OBLIG ' ||
                                                       '     , DIF_DERECHO_OBLIGACION ' ||
                                                       '     , REGISTRA_CLIENTE ' ||
                                                       '     , BASE_MONETARIA ' ||
                                                       '     , TITULO_DERECHO ' ||
                                                       '     , VALORIZACION_DERECHO ' ||
                                                       '     , TITULO_OBLIGACION ' ||
                                                       '     , VALORIZACION_OBLIGACION ' ||
                                                       '     , NUMERO_OPERACION_OBLIG ' ||
                                                       '  FROM TMP_RECOFU',
                                   P_CODIGO         => P_CODIGO,
                                   P_RESPUESTA      => P_RESPUESTA);
    IF P_CODIGO = '0000' THEN
      DBMS_OUTPUT.PUT_LINE('Se ha generado el archivo, en la ruta ' ||
                           V_RUTA);
    END IF;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_GENERA_REPORTES_RIESGOS - P_EJECUTA_RECOFU',
                                                      'FIN');
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
      --DBMS_OUTPUT.PUT_LINE('ERROR SQL: ' || SQLERRM);
      --   DBMS_OUTPUT.PUT_LINE('BACKTRACE: ' || SYS.DBMS_UTILITY.FORMAT_ERROR_BACKTRACE);
      RAISE_APPLICATION_ERROR(-20059,
                              'No se genero reporte, comuniquese con soporte, error: ' ||
                              SQLERRM);
  END P_EJECUTA_RECOFU;

  PROCEDURE GENERA_RCOND IS
    CURSOR C_ROCOND(P_FECHA DATE) IS
      SELECT 'COMPRA' TIPO,
             LSF_FECHA FECHA,
             TO_CHAR(LSF_CONSECUTIVO) CONSECUTIVO,
             LSF_CLI_PER_NUM_IDEN NUM_IDEN,
             LSF_CLI_PER_TID_CODIGO TID_CODIGO,
             PER_NOMBRE CLIENTE,
             LSF_BMO_MNEMONICO BMO_MNEMONICO,
             LSF_FECHA_CUMPLIMIENTO FECHA_CUMPLIMIENTO,
             LSF_PRECIO TASA,
             LSF_NUMERO_TRANSADO DOLARES,
             LSF_NUMERO_TRANSADO *
             P_WEB_EXTRACTO.VALORBMO('DOLAR', P_FECHA + 1) DERECHO,
             LSF_NUMERO_TRANSADO * LSF_PRECIO OBLIGACION
        FROM LIQUIDACIONES_SET_FX, FILTRO_PERSONAS
       WHERE LSF_CLI_PER_NUM_IDEN = PER_NUM_IDEN
         AND LSF_CLI_PER_TID_CODIGO = PER_TID_CODIGO
         AND LSF_NEXT_DAY = 'S'
         AND LSF_ESTADO = 'APL'
            --AND LSF_FECHA >= :FILTRO.FECHA_ROCOND
         AND LSF_FECHA < TRUNC(P_FECHA + 1)
         AND LSF_FECHA_CUMPLIMIENTO > TRUNC(P_FECHA)
         AND ((LSF_OFERTA_DEMANDA = 'D' AND
             (LSF_INSTITUCION_POSTURA LIKE 'CORREDORES ASOCIADOS%' OR
             LSF_INSTITUCION_POSTURA LIKE 'CORREDORES DAVIVIENDA S.A.%')) OR
             (LSF_OFERTA_DEMANDA = 'O' AND
             (LSF_INSTITUCION_ACEPTANTE LIKE 'CORREDORES ASOCIADOS%' OR
             LSF_INSTITUCION_ACEPTANTE LIKE
             'CORREDORES DAVIVIENDA S.A.%')))
      UNION ALL
      SELECT 'COMPRA' TIPO,
             ORD_FECHA_COLOCACION FECHA,
             ORD_SUC_CODIGO || '-' || ORD_CONSECUTIVO CONSECUTIVO,
             ORD_CLI_PER_NUM_IDEN NUM_IDEN,
             ORD_CLI_PER_TID_CODIGO TID_CODIGO,
             PER_NOMBRE CLIENTE,
             NVL((NVL(ORD_BMO_MNEMONICO_FX, ORD_BMO_MNEMONICO_FX_C)),
                 ORD_BMO_MNEMONICO) BMO_MNEMONICO,
             ORD_FECHA_CUMPLIMIENTO FECHA_CUMPLIMIENTO,
             ORD_TASA_CAMBIO TASA,
             ORD_VALOR_DOLARES DOLARES,
             ORD_VALOR_DOLARES *
             P_WEB_EXTRACTO.VALORBMO('DOLAR', P_FECHA + 1) DERECHO,
             ORD_VALOR_DOLARES * ORD_TASA_CAMBIO OBLIGACION
        FROM ORDENES_DIVISAS, FILTRO_PERSONAS
       WHERE ORD_CLI_PER_NUM_IDEN = PER_NUM_IDEN
         AND ORD_CLI_PER_TID_CODIGO = PER_TID_CODIGO
         AND NVL(ORD_DIAS_NEXT_DAY, 0) IN (1, 2, 3)
            --AND ORD_FECHA_COLOCACION >= :FILTRO.FECHA_ROCOND
         AND ORD_FECHA_COLOCACION < TRUNC(P_FECHA + 1)
         AND ORD_FECHA_CUMPLIMIENTO >= TRUNC(P_FECHA + 1)
         AND ORD_TIPO_ORDEN = 'C'
         AND (ORD_EOF_CODIGO IN ('APL', 'APR') OR
             (ORD_EOF_CODIGO = 'REV' AND
             ORD_FECHA_REVERSION > ORD_FECHA_COLOCACION + 1))
      UNION ALL
      SELECT 'VENTA' TIPO,
             LSF_FECHA FECHA,
             TO_CHAR(LSF_CONSECUTIVO) CONSECUTIVO,
             LSF_CLI_PER_NUM_IDEN NUM_IDEN,
             LSF_CLI_PER_TID_CODIGO TID_CODIGO,
             PER_NOMBRE CLIENTE,
             LSF_BMO_MNEMONICO BMO_MNEMONICO,
             LSF_FECHA_CUMPLIMIENTO FECHA_CUMPLIMIENTO,
             LSF_PRECIO TASA,
             LSF_NUMERO_TRANSADO DOLARES,
             LSF_NUMERO_TRANSADO * LSF_PRECIO DERECHO,
             LSF_NUMERO_TRANSADO *
             P_WEB_EXTRACTO.VALORBMO('DOLAR', P_FECHA + 1) OBLIGACION
        FROM LIQUIDACIONES_SET_FX, FILTRO_PERSONAS
       WHERE LSF_CLI_PER_NUM_IDEN = PER_NUM_IDEN
         AND LSF_CLI_PER_TID_CODIGO = PER_TID_CODIGO
         AND LSF_NEXT_DAY = 'S'
         AND LSF_ESTADO = 'APL'
            --AND LSF_FECHA >= :FILTRO.FECHA_ROCOND
         AND LSF_FECHA < TRUNC(P_FECHA + 1)
         AND LSF_FECHA_CUMPLIMIENTO > TRUNC(P_FECHA)
         AND ((LSF_OFERTA_DEMANDA = 'O' AND
             (LSF_INSTITUCION_POSTURA LIKE 'CORREDORES ASOCIADOS%' OR
             LSF_INSTITUCION_POSTURA LIKE 'CORREDORES DAVIVIENDA S.A.%')) OR
             (LSF_OFERTA_DEMANDA = 'D' AND
             (LSF_INSTITUCION_ACEPTANTE LIKE 'CORREDORES ASOCIADOS%' OR
             LSF_INSTITUCION_ACEPTANTE LIKE
             'CORREDORES DAVIVIENDA S.A.%')))
      UNION ALL
      SELECT 'VENTA' TIPO,
             ORD_FECHA_COLOCACION FECHA,
             ORD_SUC_CODIGO || '-' || ORD_CONSECUTIVO CONSECUTIVO,
             ORD_CLI_PER_NUM_IDEN NUM_IDEN,
             ORD_CLI_PER_TID_CODIGO TID_CODIGO,
             PER_NOMBRE CLIENTE,
             NVL(ORD_BMO_MNEMONICO_FX, ORD_BMO_MNEMONICO) BMO_MNEMONICO,
             ORD_FECHA_CUMPLIMIENTO FECHA_CUMPLIMIENTO,
             ORD_TASA_CAMBIO TASA,
             ORD_VALOR_DOLARES DOLARES,
             ORD_VALOR_DOLARES * ORD_TASA_CAMBIO DERECHO,
             ORD_VALOR_DOLARES *
             P_WEB_EXTRACTO.VALORBMO('DOLAR', P_FECHA + 1) OBLIGACION
        FROM ORDENES_DIVISAS, FILTRO_PERSONAS
       WHERE ORD_CLI_PER_NUM_IDEN = PER_NUM_IDEN
         AND ORD_CLI_PER_TID_CODIGO = PER_TID_CODIGO
         AND NVL(ORD_DIAS_NEXT_DAY, 0) IN (1, 2, 3)
            -- AND ORD_FECHA_COLOCACION >= :FILTRO.FECHA_ROCOND
         AND ORD_FECHA_COLOCACION < TRUNC(P_FECHA + 1)
         AND ORD_FECHA_CUMPLIMIENTO >= TRUNC(P_FECHA + 1)
         AND ORD_TIPO_ORDEN = 'V'
         AND (ORD_EOF_CODIGO IN ('APL', 'APR') OR
             (ORD_EOF_CODIGO = 'REV' AND
             ORD_FECHA_REVERSION > ORD_FECHA_COLOCACION + 1));

    CURSOR C_FECHAS IS
      SELECT LSF_FECHA FECHA
        FROM LIQUIDACIONES_SET_FX
       WHERE LSF_FECHA >= TRUNC(SYSDATE - 1)
         AND LSF_FECHA < TRUNC(SYSDATE)
       GROUP BY LSF_FECHA;

  BEGIN
    DELETE TMP_ROCOND;
    COMMIT;
    FOR R_ROCOND IN C_ROCOND(SYSDATE - 1) LOOP
      INSERT INTO TMP_ROCOND
        (FECHA_REPORTE,
         TIPO_OPERACION,
         FECHA_OPERACION,
         CONSECUTIVO,
         NUMERO_IDENTIFICACION,
         TIPO_IDENTIFICACION,
         NOMBRE_CLIENTE,
         BASE_MONETARIA,
         FECHA_CUMPLIMIENTO,
         TASA,
         NOMINAL_DOLARES,
         DERECHO,
         OBLIGACION,
         DIF_DERECHO_OBLIGACION)
      VALUES
        (SYSDATE - 1,
         R_ROCOND.TIPO,
         R_ROCOND.FECHA,
         R_ROCOND.CONSECUTIVO,
         R_ROCOND.NUM_IDEN,
         R_ROCOND.TID_CODIGO,
         R_ROCOND.CLIENTE,
         R_ROCOND.BMO_MNEMONICO,
         R_ROCOND.FECHA_CUMPLIMIENTO,
         R_ROCOND.TASA,
         R_ROCOND.DOLARES,
         R_ROCOND.DERECHO,
         R_ROCOND.OBLIGACION,
         (R_ROCOND.DERECHO - R_ROCOND.OBLIGACION));
      COMMIT;
    END LOOP;
  END GENERA_RCOND;

  PROCEDURE P_EJECUTA_RCOND IS
    P_CODIGO       VARCHAR2(200);
    P_RESPUESTA    VARCHAR2(200);
    V_RUTA         VARCHAR2(100);
    NOMBRE_ARCHIVO VARCHAR2(100);
    P_NUM_INI      NUMBER;
    P_NUM_FIN      NUMBER;
  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_GENERA_REPORTES_RIESGOS - P_EJECUTA_RCOND',
                                                      'INI');

    GENERA_RCOND;
    V_RUTA         := '\\nas.corredor.local\Riesgo\CONFIDENCIAL\Reportes Excel Coeasy\';
    NOMBRE_ARCHIVO := 'ROCOND_' ||
                      TO_CHAR(SYSDATE - 1, 'DDMMYYYY_hh24mmss');

    --LLAMADO AL PROGRAMA QUE CREA EL XSLX
    P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => V_RUTA,
                                   P_NOMBRE_ARCHIVO => NOMBRE_ARCHIVO,
                                   P_QUERY          => 'SELECT FECHA_REPORTE ' ||
                                                       '     , TIPO_OPERACION ' ||
                                                       '     , FECHA_OPERACION ' ||
                                                       '     , CONSECUTIVO ' ||
                                                       '     , NUMERO_IDENTIFICACION ' ||
                                                       '     , TIPO_IDENTIFICACION ' ||
                                                       '     , NOMBRE_CLIENTE ' ||
                                                       '     , BASE_MONETARIA ' ||
                                                       '     , FECHA_CUMPLIMIENTO ' ||
                                                       '     , TASA ' ||
                                                       '     , NOMINAL_DOLARES ' ||
                                                       '     , DERECHO ' ||
                                                       '     , OBLIGACION ' ||
                                                       '     , DIF_DERECHO_OBLIGACION ' ||
                                                       '  FROM TMP_ROCOND',
                                   P_CODIGO         => P_CODIGO,
                                   P_RESPUESTA      => P_RESPUESTA);
    IF P_CODIGO = '0000' THEN
      DBMS_OUTPUT.PUT_LINE('Se ha generado el archivo, en la ruta ' ||
                           V_RUTA);
    END IF;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_GENERA_REPORTES_RIESGOS - P_EJECUTA_RCOND',
                                                      'FIN');
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20059,
                              'No se genero reporte, comuniquese con soporte, error: ' ||
                              SQLERRM);
  END P_EJECUTA_RCOND;

  FUNCTION DIAS_VENCIMIENTO(P_CUMPL    DATE,
                            P_FECHA    DATE,
                            P_CONTRATO VARCHAR2) RETURN NUMBER IS
    DIAS         NUMBER;
    FEC_CONTRATO DATE;
  BEGIN
    DIAS := P_CLIENTES_TITULOS.DIA_HABIL(TRUNC(P_FECHA), TRUNC(P_CUMPL));
    IF DIAS < 0 THEN
      SELECT ESC_FECHA_CUMPLIMIENTO
        INTO FEC_CONTRATO
        FROM ESPECIES_CONTRATOS
       WHERE ESC_MNEMONICO = P_CONTRATO;

      DIAS := P_CLIENTES_TITULOS.DIA_HABIL(TRUNC(P_FECHA),
                                           TRUNC(FEC_CONTRATO));
    END IF;
    RETURN(NVL(DIAS, 0));
  END DIAS_VENCIMIENTO;

  FUNCTION PRECIO_MERCADO_TM1(P_CONTRATO VARCHAR2, P_FECHA DATE)
    RETURN NUMBER IS
    VALOR NUMBER;
    FECHA DATE;
    CURSOR C_ODE(P_CONTR VARCHAR2, P_FECH DATE) IS
      SELECT LID_PRECIO_REFERENCIA
        FROM LIQUIDACIONES_DERIVADOS
       WHERE LID_ESPECIE_CONTRATO = P_CONTR
         AND LID_FECHA_OPERACION >= TRUNC(FECHA)
         AND LID_FECHA_OPERACION < TRUNC(FECHA + 1);

    PRECIO NUMBER;
  BEGIN
    FECHA := P_TOOLS.RESTAR_HABILES_A_FECHA(TRUNC(P_FECHA), 1);

    OPEN C_ODE(P_CONTRATO, P_FECHA);
    FETCH C_ODE
      INTO PRECIO;
    CLOSE C_ODE;
    VALOR := NVL(PRECIO, 0);

    RETURN(VALOR);
  END PRECIO_MERCADO_TM1;

  FUNCTION PRECIO_MERCADO(P_CONTRATO VARCHAR2, P_FECHA DATE) RETURN NUMBER IS
    VALOR NUMBER;

    CURSOR C_ODE(P_CONTR VARCHAR2, P_FECH DATE) IS
      SELECT LID_PRECIO_REFERENCIA
        FROM LIQUIDACIONES_DERIVADOS
       WHERE LID_ESPECIE_CONTRATO = P_CONTR
         AND LID_FECHA_OPERACION >= TRUNC(P_FECHA)
         AND LID_FECHA_OPERACION < TRUNC(P_FECHA + 1);
    PRECIO NUMBER;

  BEGIN
    OPEN C_ODE(P_CONTRATO, P_FECHA);
    FETCH C_ODE
      INTO PRECIO;
    CLOSE C_ODE;

    VALOR := NVL(PRECIO, 0);
    RETURN(VALOR);
  END PRECIO_MERCADO;

  FUNCTION VALOR_MERCADO(P_OBLIG    NUMBER,
                         P_DER      NUMBER,
                         P_CONTRATO NUMBER,
                         P_PUNTA    VARCHAR2) RETURN NUMBER IS
    VALOR NUMBER;
  BEGIN
    IF P_PUNTA = 'VENTA' THEN
      VALOR := P_OBLIG;
    ELSIF P_PUNTA = 'COMPRA' THEN
      VALOR := P_DER;
    ELSE
      VALOR := 0;
    END IF;

    IF P_CONTRATO = 0 THEN
      VALOR := 0;
    END IF;

    RETURN(NVL(VALOR, 0));
  END VALOR_MERCADO;

  PROCEDURE GENERA_ROPDER_TODOS IS
    CURSOR C_ROPDER IS
      SELECT SYT_DESCRIPCION,
             LID_FECHA_OPERACION ODE_FECHA_ORDEN,
             DECODE(LID_PUNTA, 'C', 'COMPRA', 'V', 'VENTA', LID_PUNTA) ODE_PUNTA,
             ESC_SYT_TSU_MNEMONICO SYT_TSU_MNEMONICO,
             SYT_VALOR_CONTRATO,
             LID_ESPECIE_CONTRATO ODE_LID_ESPECIE_CONTRATO,
             LID_CCC_CLI_PER_NUM_IDEN ODE_LID_CCC_CLI_PER_NUM_IDEN,
             LID_CCC_CLI_PER_TID_CODIGO ODE_LID_CCC_CLI_PER_TID_CODIGO,
             PER_NOMBRE NOMBRE_CLIENTE,
             LID_CCC_NUMERO_CUENTA ODE_LID_CCC_NUMERO_CUENTA,
             LID_FECHA_OPERACION ODE_LID_FECHA_OPERACION,
             LID_CANTIDAD_CONTRATOS ODE_CANTIDAD_CONTRATOS,
             LID_CANTIDAD_CONTRATOS * SYT_VALOR_CONTRATO NOMINAL_OPERACION,
             LID_PRECIO_REFERENCIA ODE_PRECIO_REFERENCIA,
             LID_CUENTA_CRCC_DESTINO CUENTA_CRCC,
             ESC_FECHA_ULTIMO_REGISTRO FECHA_ULTIMO_REGISTRO,
             LID_FECHA_CUMPLIMIENTO ODE_FECHA_CUMPLIMIENTO,
             LID_VALOR_LIQUIDACION
        FROM LIQUIDACIONES_DERIVADOS L,
             ESPECIES_CONTRATOS      E,
             SUBYACENTES             S,
             FILTRO_PERSONAS
       WHERE LID_CCC_CLI_PER_NUM_IDEN = PER_NUM_IDEN
         AND LID_CCC_CLI_PER_TID_CODIGO = PER_TID_CODIGO
         AND L.LID_ESPECIE_CONTRATO = E.ESC_MNEMONICO
         AND E.ESC_SYT_MNEMONICO = S.SYT_MNEMONICO
         AND L.LID_FECHA_OPERACION >= TRUNC(SYSDATE) - 1
         AND L.LID_FECHA_OPERACION < TRUNC(SYSDATE)
         AND ESC_FECHA_CUMPLIMIENTO >= TRUNC(SYSDATE) - 1;

    V_OBLIGACION        NUMBER;
    CONTRATOS           NUMBER := 0;
    MONTO_TOTAL_PESOS_V NUMBER := 0;
    MONTO_TOTAL_PESOS_C NUMBER := 0;
    FECHA               DATE;

    CURSOR C_ODE(P_NUM_CLI  VARCHAR2,
                 P_TIPO     VARCHAR2,
                 P_CUENTA   NUMBER,
                 P_CONTRATO VARCHAR2) IS
      SELECT LID_CANTIDAD_CONTRATOS
        FROM LIQUIDACIONES_DERIVADOS
       WHERE LID_CCC_CLI_PER_NUM_IDEN = P_NUM_CLI
         AND LID_CCC_CLI_PER_TID_CODIGO = P_TIPO
         AND LID_CCC_NUMERO_CUENTA = P_CUENTA
         AND LID_ESPECIE_CONTRATO = P_CONTRATO
         AND LID_FECHA_OPERACION >= TRUNC(TRUNC(SYSDATE) - 1)
         AND LID_FECHA_OPERACION < TRUNC(TRUNC(SYSDATE));
    V_DERECHO NUMBER;

    CURSOR C_FTS(P_SUBY VARCHAR2, P_FECHA DATE) IS
      SELECT FTS_FACTOR
        FROM FACTORES_TIPOS_SUBYACENTES
       WHERE FTS_TSU_MNEMONICO = P_SUBY
         AND FTS_FECHA_APLICACION < TRUNC(P_FECHA) + 1
       ORDER BY FTS_FECHA_APLICACION DESC;
    FACTOR     NUMBER;
    EXPOSICION NUMBER;

    V_DIAS_VENC         NUMBER;
    V_PRECIO_MERCADO    NUMBER;
    V_PRECIO_MERCADO_T1 NUMBER;
    V_VALOR_MERCADO     NUMBER;

  BEGIN
    DELETE TMP_ROPDER;
    COMMIT;
    FOR R_ROPDER IN C_ROPDER LOOP
      V_DIAS_VENC         := DIAS_VENCIMIENTO(R_ROPDER.ODE_FECHA_CUMPLIMIENTO,
                                              TRUNC(SYSDATE) - 1,
                                              R_ROPDER.ODE_LID_ESPECIE_CONTRATO);
      V_PRECIO_MERCADO    := PRECIO_MERCADO(R_ROPDER.ODE_LID_ESPECIE_CONTRATO,
                                            TRUNC(SYSDATE) - 1);
      V_PRECIO_MERCADO_T1 := PRECIO_MERCADO_TM1(R_ROPDER.ODE_LID_ESPECIE_CONTRATO,
                                                TRUNC(SYSDATE) - 1);
      --V_VALOR_MERCADO := VALOR_MERCADO(V_OBLIGACION, V_DERECHO,R_ROPDER.ODE_CANTIDAD_CONTRATOS, R_ROPDER.ODE_PUNTA);
      --EXPOSICIżN CREDITICIA
      OPEN C_FTS(R_ROPDER.SYT_TSU_MNEMONICO, TRUNC(SYSDATE) - 1);
      FETCH C_FTS
        INTO FACTOR;
      CLOSE C_FTS;
      FACTOR := NVL(FACTOR, 0);

      IF R_ROPDER.LID_VALOR_LIQUIDACION > 0 THEN
        EXPOSICION := R_ROPDER.LID_VALOR_LIQUIDACION;
      ELSE
        EXPOSICION := 0;
      END IF;

      IF R_ROPDER.SYT_TSU_MNEMONICO = 'TRM' THEN
        EXPOSICION := EXPOSICION + (R_ROPDER.NOMINAL_OPERACION *
                      P_WEB_EXTRACTO.VALORBMO('DOLAR',
                                                            TRUNC(TRUNC(SYSDATE))) *
                      (SQRT(DIAS_VENCIMIENTO(R_ROPDER.ODE_FECHA_CUMPLIMIENTO,
                                                           TRUNC(SYSDATE) - 1,
                                                           R_ROPDER.ODE_LID_ESPECIE_CONTRATO))) *
                      FACTOR);
      ELSIF R_ROPDER.SYT_TSU_MNEMONICO IN ('ACC', 'ELM') THEN
        EXPOSICION := EXPOSICION + (R_ROPDER.NOMINAL_OPERACION *
                      PRECIO_MERCADO(R_ROPDER.ODE_LID_ESPECIE_CONTRATO,
                                                   TRUNC(SYSDATE) - 1) *
                      SQRT(DIAS_VENCIMIENTO(R_ROPDER.ODE_FECHA_CUMPLIMIENTO,
                                                          TRUNC(SYSDATE) - 1,
                                                          R_ROPDER.ODE_LID_ESPECIE_CONTRATO)) *
                      FACTOR);
      ELSE
        EXPOSICION := EXPOSICION + (R_ROPDER.NOMINAL_OPERACION *
                      SQRT(DIAS_VENCIMIENTO(R_ROPDER.ODE_FECHA_CUMPLIMIENTO,
                                                          TRUNC(SYSDATE) - 1,
                                                          R_ROPDER.ODE_LID_ESPECIE_CONTRATO)) *
                      FACTOR);
      END IF;

      --OBLIGACIżN Y DERECHO
      FECHA := P_TOOLS.RESTAR_HABILES_A_FECHA(TRUNC(TRUNC(SYSDATE) - 1), 1);
      OPEN C_ODE(R_ROPDER.ODE_LID_CCC_CLI_PER_NUM_IDEN,
                 R_ROPDER.ODE_LID_CCC_CLI_PER_TID_CODIGO,
                 R_ROPDER.ODE_LID_CCC_NUMERO_CUENTA,
                 R_ROPDER.ODE_LID_ESPECIE_CONTRATO);
      FETCH C_ODE
        INTO CONTRATOS;
      CLOSE C_ODE;

      --OBLIGACIżN
      IF R_ROPDER.ODE_PUNTA = 'COMPRA' OR R_ROPDER.ODE_PUNTA = 'VENTA' THEN
        V_OBLIGACION := R_ROPDER.NOMINAL_OPERACION *
                        PRECIO_MERCADO(R_ROPDER.ODE_LID_ESPECIE_CONTRATO,
                                       TRUNC(SYSDATE) - 1);
      ELSE
        V_OBLIGACION := 0;
      END IF;
      V_OBLIGACION := P_VALORA_DERIVADOS.FN_PRECIO_VALORACION(V_OBLIGACION,
                                                              R_ROPDER.SYT_TSU_MNEMONICO);
      IF R_ROPDER.ODE_PUNTA = 'COMPRA' THEN
        V_OBLIGACION := V_OBLIGACION - R_ROPDER.LID_VALOR_LIQUIDACION;
      END IF;

      IF R_ROPDER.ODE_CANTIDAD_CONTRATOS = 0 THEN
        V_OBLIGACION := 0;
      END IF;

      --DERECHO
      IF R_ROPDER.ODE_PUNTA = 'VENTA' OR R_ROPDER.ODE_PUNTA = 'COMPRA' THEN
        V_DERECHO := (R_ROPDER.NOMINAL_OPERACION *
                     PRECIO_MERCADO(R_ROPDER.ODE_LID_ESPECIE_CONTRATO,
                                     TRUNC(SYSDATE) - 1));
      ELSE
        V_DERECHO := 0;
      END IF;

      V_DERECHO := P_VALORA_DERIVADOS.FN_PRECIO_VALORACION(V_DERECHO,
                                                           R_ROPDER.SYT_TSU_MNEMONICO);
      IF R_ROPDER.ODE_PUNTA = 'VENTA' THEN
        V_DERECHO := V_DERECHO + R_ROPDER.LID_VALOR_LIQUIDACION;
      END IF;

      IF R_ROPDER.ODE_CANTIDAD_CONTRATOS = 0 THEN
        V_DERECHO := 0;
      END IF;

      V_VALOR_MERCADO := VALOR_MERCADO(V_OBLIGACION,
                                       V_DERECHO,
                                       R_ROPDER.ODE_CANTIDAD_CONTRATOS,
                                       R_ROPDER.ODE_PUNTA);

      INSERT INTO TMP_ROPDER
        (FECHA_REPORTE,
         TIPO_SUBYACENTE,
         FECHA_LIQUIDACION,
         PUNTA,
         CONTRATO,
         DIAS_VENC,
         NOMBRE_CLIENTE,
         NUM_IDENTIFICACION,
         TIPO_ID,
         CUENTA,
         CUENTA_CRCC,
         POSICION_NETA,
         NOMINAL_OPERACION,
         PRECIO_MERCADO,
         PRECIO_MERCADO_T1,
         VALOR_MERCADO,
         DERECHO,
         OBLIGACION,
         UP_LIQUIDACION,
         EXPOSICION_CREDITICIA)
      VALUES
        (SYSDATE, --FECHA_REPORTE
         R_ROPDER.SYT_DESCRIPCION, --TIPO_SUBYACENTE
         R_ROPDER.ODE_FECHA_ORDEN, --FECHA_LIQUIDACION
         R_ROPDER.ODE_PUNTA, --PUNTA
         R_ROPDER.ODE_LID_ESPECIE_CONTRATO, --CONTRATO
         V_DIAS_VENC, --DIAS_VENC
         R_ROPDER.NOMBRE_CLIENTE, --NOMBRE_CLIENTE
         R_ROPDER.ODE_LID_CCC_CLI_PER_NUM_IDEN, --NUM_IDENTIFICACION
         R_ROPDER.ODE_LID_CCC_CLI_PER_TID_CODIGO, --TIPO_ID
         R_ROPDER.ODE_LID_CCC_NUMERO_CUENTA, --CUENTA
         R_ROPDER.CUENTA_CRCC, --CUENTA_CRCC
         R_ROPDER.ODE_CANTIDAD_CONTRATOS, --POSICION_NETA
         R_ROPDER.NOMINAL_OPERACION, --NOMINAL_OPERACION
         V_PRECIO_MERCADO, --PRECIO_MERCADO
         V_PRECIO_MERCADO_T1, --PRECIO_MERCADO_T1
         V_VALOR_MERCADO, --VALOR_MERCADO
         V_DERECHO, --DERECHO
         V_OBLIGACION, --OBLIGACION
         R_ROPDER.LID_VALOR_LIQUIDACION, --UP_LIQUIDACION
         EXPOSICION --EXPOSICION_CREDITICIA
         );
      COMMIT;
    END LOOP;
  END GENERA_ROPDER_TODOS;

  PROCEDURE P_EJECUTA_ROPDER IS
    P_CODIGO       VARCHAR2(200);
    P_RESPUESTA    VARCHAR2(200);
    V_RUTA         VARCHAR2(100);
    NOMBRE_ARCHIVO VARCHAR2(100);
    P_NUM_INI      NUMBER;
    P_NUM_FIN      NUMBER;
  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_GENERA_REPORTES_RIESGOS - P_EJECUTA_ROPDER',
                                                      'INI');

    GENERA_ROPDER_TODOS;
    V_RUTA         := '\\nas.corredor.local\Riesgo\CONFIDENCIAL\Reportes Excel Coeasy\';
    NOMBRE_ARCHIVO := 'ROPDER_' ||
                      TO_CHAR(SYSDATE - 1, 'DDMMYYYY_hh24mmss');

    --LLAMADO AL PROGRAMA QUE CREA EL XSLX
    P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => V_RUTA,
                                   P_NOMBRE_ARCHIVO => NOMBRE_ARCHIVO,
                                   P_QUERY          => 'SELECT FECHA_REPORTE ' ||
                                                       '     , TIPO_SUBYACENTE ' ||
                                                       '     , FECHA_LIQUIDACION ' ||
                                                       '     , PUNTA ' ||
                                                       '     , CONTRATO ' ||
                                                       '     , DIAS_VENC ' ||
                                                       '     , NOMBRE_CLIENTE ' ||
                                                       '     , NUM_IDENTIFICACION ' ||
                                                       '     , TIPO_ID ' ||
                                                       '     , CUENTA ' ||
                                                       '     , CUENTA_CRCC ' ||
                                                       '     , POSICION_NETA ' ||
                                                       '     , NOMINAL_OPERACION ' ||
                                                       '     , PRECIO_MERCADO ' ||
                                                       '     , PRECIO_MERCADO_T1 ' ||
                                                       '     , VALOR_MERCADO ' ||
                                                       '     , DERECHO ' ||
                                                       '     , OBLIGACION ' ||
                                                       '     , UP_LIQUIDACION ' ||
                                                       '     , EXPOSICION_CREDITICIA ' ||
                                                       '  FROM TMP_ROPDER',
                                   P_CODIGO         => P_CODIGO,
                                   P_RESPUESTA      => P_RESPUESTA);
    IF P_CODIGO = '0000' THEN
      DBMS_OUTPUT.PUT_LINE('Se ha generado el archivo, en la ruta ' ||
                           V_RUTA);
    END IF;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_GENERA_REPORTES_RIESGOS - P_EJECUTA_ROPDER',
                                                      'FIN');
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20059,
                              'No se genero reporte, comuniquese con soporte, error: ' ||
                              SQLERRM);
  END P_EJECUTA_ROPDER;

  PROCEDURE GENERA_CIDIDI IS
    CURSOR C_CIDIDI IS
      SELECT CDI_FECHA_PROCESO FECHA_PROCESO,
             CDI_VALOR_TPC_DIA,
             CDI_VALOR_TPC_DIA_CHEQUES,
             CDI_VALOR_TPC_DIA_EFECTIVO,
             CDI_INVENTARIO_INICIAL_USD,
             CDI_INVENTARIO_INICIAL_PESOS,
             CDI_COMPRAS_USD,
             CDI_COMPRAS_PESOS,
             CDI_VENTAS_USD,
             CDI_VENTAS_PESOS,
             CDI_INVENTARIO_FINAL_USD,
             CDI_INVENTARIO_FINAL_PESOS,
             CDI_SWAP,
             CDI_INV_FINAL,
             CDI_UTILIDAD_OPERATIVA,
             CDI_COMISION,
             CDI_COMISION_COMERCIAL,
             CDI_GASTOS_GIRO,
             CDI_OVER_NIGHT,
             CDI_COMPRA_OTRA_MONEDA,
             CDI_VENTA_OTRA_MONEDA,
             CDI_EGRESOS_CORRESPONSAL,
             CDI_VENTA_GASTO_SOBREGIRO,
             CDI_SALDO_ORDENES_SIN_PAGOS,
             CDI_SALDO_DEPOSITOS,
             CDI_VALOR_NEXT_DAY,
             CDI_VALOR_NEXT_DAY_CLIENTE,
             CDI_NEXT_INT_COMPRAS,
             CDI_NEXT_INT_VENTAS,
             CDI_VALOR_FIX,
             CDI_FIX_INT_COMPRAS,
             CDI_FIX_INT_VENTAS,
             CDI_DERIVADOS_COMPRAS,
             CDI_DERIVADOS_VENTAS,
             CDI_FORWARD_COMPRAS,
             CDI_FORWARD_VENTAS, /*, CDI_DER_BVC_PP_COM, CDI_DER_BVC_CL_COM, CDI_FORWARD_COMPRAS, CDI_FORWARD_VENTAS,*/
             CDI_DER_BVC_PP_COM,
             CDI_DER_BVC_CL_COM,
             CDI_DER_BVC_PP_VEN,
             CDI_DER_BVC_CL_VEN
        FROM CIERRE_DIVISAS
       WHERE CDI_FECHA_PROCESO >= TRUNC(SYSDATE) - 1
         AND CDI_FECHA_PROCESO < TRUNC(SYSDATE);

    CURSOR COTIZACION_BASE_MONETARIA IS
      SELECT CBM_FECHA,
             CBM_BMO_MNEMONICO,
             CBM_VALOR,
             CBM_VALOR_DOLARES,
             CBM_VALOR_SPOT,
             CBM_VALOR_FIX,
             CBM_PROVEEDOR
        FROM COTIZACIONES_BASE_MONETARIAS
       WHERE CBM_BMO_MNEMONICO = 'DOLAR'
         AND TRUNC(CBM_FECHA) >= TRUNC(TRUNC(SYSDATE) - 1)
         AND TRUNC(CBM_FECHA) < TRUNC(SYSDATE);
    C_COTIZACION_BASE_MONETARIA COTIZACION_BASE_MONETARIA%ROWTYPE;

    CURSOR SALDOS_INICIALES IS
      SELECT A.CDI_FECHA_DIA,
             A.CDI_FECHA_PROCESO,
             A.CDI_INVENTARIO_INICIAL_USD,
             A.CDI_INVENTARIO_INICIAL_PESOS,
             A.CDI_COMPRAS_USD,
             A.CDI_COMPRAS_PESOS,
             A.CDI_VENTAS_USD,
             A.CDI_VENTAS_PESOS,
             A.CDI_INVENTARIO_FINAL_USD,
             A.CDI_INVENTARIO_FINAL_PESOS,
             A.CDI_VALOR_TPC_DIA,
             A.CDI_UTILIDAD_OPERATIVA,
             A.CDI_COMISION,
             A.CDI_COMISION_COMERCIAL,
             A.CDI_GASTOS_GIRO,
             A.CDI_VALOR_TPC_DIA_CHEQUES,
             A.CDI_VALOR_TPC_DIA_EFECTIVO
        FROM CIERRE_DIVISAS A
       WHERE TRUNC(A.CDI_FECHA_PROCESO) IN
             (SELECT TRUNC(B.CDI_FECHA_PROCESO)
                FROM CIERRE_DIVISAS B
               WHERE TRUNC(B.CDI_FECHA_DIA) >= TRUNC(TRUNC(SYSDATE) - 1)
                 AND TRUNC(B.CDI_FECHA_DIA) < TRUNC(SYSDATE));
    C_SALDOS_INICIALES SALDOS_INICIALES%ROWTYPE;

    CURSOR SUMA_COMISION(P_FECHA DATE, P_FECHAI DATE) IS
      SELECT NVL(SUM(A.CDI_COMISION), 0) CDI_COMISION,
             NVL(SUM(A.CDI_COMISION_COMERCIAL), 0) CDI_COMISION_COMERCIAL,
             NVL(SUM(A.CDI_GASTOS_GIRO), 0) CDI_GASTOS_GIRO,
             NVL(SUM(A.CDI_UTILIDAD_OPERATIVA), 0) CDI_UTILIDAD_OPERATIVA,
             NVL(SUM(A.CDI_OVER_NIGHT), 0) CDI_OVER_NIGHT,
             NVL(SUM(A.CDI_COMPRA_OTRA_MONEDA), 0) CDI_COMPRA_OTRA_MONEDA,
             NVL(SUM(A.CDI_VENTA_OTRA_MONEDA), 0) CDI_VENTA_OTRA_MONEDA,
             NVL(SUM(A.CDI_EGRESOS_CORRESPONSAL), 0) CDI_EGRESOS_CORRESPONSAL,
             NVL(SUM(A.CDI_VENTA_GASTO_SOBREGIRO), 0) CDI_VENTA_GASTO_SOBREGIRO
        FROM CIERRE_DIVISAS A
       WHERE TRUNC(A.CDI_FECHA_PROCESO) >= P_FECHAI --TRUNC(P_FECHA)
         AND TRUNC(A.CDI_FECHA_PROCESO) < TRUNC(P_FECHA);
    C_SUMA_COMISION SUMA_COMISION%ROWTYPE;

    CURSOR INT_TOTAL_ACUM(P_FECHA_PROCESO DATE) IS
      SELECT IDE_PORC_ACUM
        FROM INTERESES_DEPOSITO_EXTERIOR
       WHERE IDE_FECHA = P_FECHA_PROCESO;
    C_INT_ACUMULADO INT_TOTAL_ACUM%ROWTYPE;

    CURSOR FIX_CLIENTES IS
      SELECT SUM(VALOR)
        FROM (SELECT SUM(POF_VALOR_DOLARES) VALOR
                FROM PREORDENES_FIX
               WHERE POF_EOF_CODIGO = 'COL'
                 AND POF_TIPO_ORDEN = 'C'
              UNION
              SELECT -SUM(POF_VALOR_DOLARES) VALOR
                FROM PREORDENES_FIX
               WHERE POF_EOF_CODIGO = 'COL'
                 AND POF_TIPO_ORDEN = 'V');

    C_FIX_CLIENTES NUMBER;

    V_VALOR_TRM               NUMBER;
    V_TPC_TRANF_DIA           NUMBER;
    V_CHEQUE_INICIO_DIA       NUMBER;
    V_INVENTARIO_INICIAL_TASA NUMBER;
    V_COMPRAS_VALOR_TASA      NUMBER;
    V_VENTAS_VALOR_TASA       NUMBER;
    V_TASA_VALOR_TASA         NUMBER;
    V_UTILIDAD_ACUMULADA      NUMBER;
    UTILIDAD_DIA_MES          NUMBER;
    V_COMISION_ACUMULADA      NUMBER;
    V_COMISION_DIA_MES        NUMBER;
    V_COMERCIAL_ACUMULADA     NUMBER;
    V_COMISION_COMERCIAL_MES  NUMBER;
    V_GASTOS_GIRO_ACUMULADA   NUMBER;
    V_GIRO_ACUMULADA          NUMBER;
    V_OVER_NIGHT_ACUMULADA    NUMBER;
    V_OVERNIGHT_MES           NUMBER;
    V_OTRA_MONEDA_ACUMULADA   NUMBER;
    INGRESOS_MONEDAS_MES      NUMBER;
    V_VENTA_OTRA_MONEDA_ACUM  NUMBER;
    V_EGRESOS_MONEDAS_ACUM    NUMBER;
    V_CORRESPONSAL_ACUM       NUMBER;
    GASTOS_CORRESPONSAL_MES   NUMBER;
    V_GASTO_SOBREGIRO_ACUM    NUMBER;
    V_GASTOS_SOBREGIRO_MES    NUMBER;
    V_IDE_INTERES             NUMBER;
    V_ND_TOTAL                NUMBER;
    V_FIX_TOTAL               NUMBER;
    V_BVC_TOTAL_COMPRAS       NUMBER;
    V_BVC_TOTAL_VENTAS        NUMBER;

    V_TPC_EFECTIVO_INICIO_DIA NUMBER;
    V_FECHA_INICIO            DATE;

  BEGIN
    DELETE TMP_CIDIDI;
    COMMIT;

    V_FECHA_INICIO := TO_DATE('01-' || TO_CHAR(SYSDATE, 'MON-YYYY'),
                              'DD-MON-YYYY');
    FOR R_CIDIDI IN C_CIDIDI LOOP
      OPEN COTIZACION_BASE_MONETARIA;
      FETCH COTIZACION_BASE_MONETARIA
        INTO C_COTIZACION_BASE_MONETARIA;
      IF COTIZACION_BASE_MONETARIA%FOUND THEN
        V_VALOR_TRM := C_COTIZACION_BASE_MONETARIA.CBM_VALOR;
      ELSE
        V_VALOR_TRM := NULL;
      END IF;
      CLOSE COTIZACION_BASE_MONETARIA;

      -- DETERMINAR VALORES DEL INVENTARIO INICIAL
      OPEN SALDOS_INICIALES;
      FETCH SALDOS_INICIALES
        INTO C_SALDOS_INICIALES;
      IF SALDOS_INICIALES%FOUND THEN
        V_TPC_TRANF_DIA           := C_SALDOS_INICIALES.CDI_VALOR_TPC_DIA;
        V_CHEQUE_INICIO_DIA       := C_SALDOS_INICIALES.CDI_VALOR_TPC_DIA_CHEQUES;
        V_TPC_EFECTIVO_INICIO_DIA := C_SALDOS_INICIALES.CDI_VALOR_TPC_DIA_EFECTIVO;
      ELSE
        V_TPC_TRANF_DIA           := NULL;
        V_CHEQUE_INICIO_DIA       := NULL;
        V_TPC_EFECTIVO_INICIO_DIA := NULL;
      END IF;
      CLOSE SALDOS_INICIALES;

      IF R_CIDIDI.CDI_INVENTARIO_INICIAL_USD = 0 THEN
        V_INVENTARIO_INICIAL_TASA := (R_CIDIDI.CDI_INVENTARIO_INICIAL_PESOS / 1);
      ELSE
        V_INVENTARIO_INICIAL_TASA := (R_CIDIDI.CDI_INVENTARIO_INICIAL_PESOS /
                                     R_CIDIDI.CDI_INVENTARIO_INICIAL_USD);
      END IF;

      IF NVL(R_CIDIDI.CDI_COMPRAS_USD, 0) = 0 THEN
        V_COMPRAS_VALOR_TASA := R_CIDIDI.CDI_COMPRAS_PESOS / 1;
      ELSE
        V_COMPRAS_VALOR_TASA := R_CIDIDI.CDI_COMPRAS_PESOS /
                                R_CIDIDI.CDI_COMPRAS_USD;
      END IF;

      IF NVL(R_CIDIDI.CDI_COMPRAS_USD, 0) = 0 THEN
        V_COMPRAS_VALOR_TASA := R_CIDIDI.CDI_COMPRAS_PESOS / 1;
      ELSE
        V_COMPRAS_VALOR_TASA := R_CIDIDI.CDI_COMPRAS_PESOS /
                                R_CIDIDI.CDI_COMPRAS_USD;
      END IF;

      IF NVL(R_CIDIDI.CDI_VENTAS_USD, 0) = 0 THEN
        V_VENTAS_VALOR_TASA := R_CIDIDI.CDI_VENTAS_PESOS / 1;
      ELSE
        V_VENTAS_VALOR_TASA := R_CIDIDI.CDI_VENTAS_PESOS /
                               R_CIDIDI.CDI_VENTAS_USD;
      END IF;

      IF R_CIDIDI.CDI_INVENTARIO_FINAL_USD = 0 THEN
        V_TASA_VALOR_TASA := R_CIDIDI.CDI_INVENTARIO_FINAL_PESOS / 1;
      ELSE
        V_TASA_VALOR_TASA := R_CIDIDI.CDI_INVENTARIO_FINAL_PESOS /
                             R_CIDIDI.CDI_INVENTARIO_FINAL_USD;
      END IF;

      OPEN SUMA_COMISION(SYSDATE - 1, V_FECHA_INICIO);
      FETCH SUMA_COMISION
        INTO C_SUMA_COMISION;
      CLOSE SUMA_COMISION;

      V_UTILIDAD_ACUMULADA     := C_SUMA_COMISION.CDI_UTILIDAD_OPERATIVA;
      UTILIDAD_DIA_MES         := R_CIDIDI.CDI_UTILIDAD_OPERATIVA +
                                  C_SUMA_COMISION.CDI_UTILIDAD_OPERATIVA;
      V_COMISION_ACUMULADA     := C_SUMA_COMISION.CDI_COMISION;
      V_COMISION_DIA_MES       := R_CIDIDI.CDI_COMISION +
                                  V_COMISION_ACUMULADA;
      V_COMERCIAL_ACUMULADA    := C_SUMA_COMISION.CDI_COMISION_COMERCIAL;
      V_COMISION_COMERCIAL_MES := C_SUMA_COMISION.CDI_COMISION_COMERCIAL +
                                  V_COMERCIAL_ACUMULADA;
      V_GASTOS_GIRO_ACUMULADA  := R_CIDIDI.CDI_COMISION_COMERCIAL +
                                  V_COMERCIAL_ACUMULADA; --C_SUMA_COMISION.CDI_GASTOS_GIRO;
      V_GIRO_ACUMULADA         := R_CIDIDI.CDI_GASTOS_GIRO +
                                  C_SUMA_COMISION.CDI_GASTOS_GIRO;
      V_OVER_NIGHT_ACUMULADA   := C_SUMA_COMISION.CDI_OVER_NIGHT;
      V_OVERNIGHT_MES          := V_OVER_NIGHT_ACUMULADA +
                                  C_SUMA_COMISION.CDI_OVER_NIGHT;
      V_OTRA_MONEDA_ACUMULADA  := C_SUMA_COMISION.CDI_COMPRA_OTRA_MONEDA;
      INGRESOS_MONEDAS_MES     := C_SUMA_COMISION.CDI_COMPRA_OTRA_MONEDA +
                                  V_OTRA_MONEDA_ACUMULADA;
      V_VENTA_OTRA_MONEDA_ACUM := C_SUMA_COMISION.CDI_VENTA_OTRA_MONEDA;
      V_EGRESOS_MONEDAS_ACUM   := C_SUMA_COMISION.CDI_VENTA_OTRA_MONEDA +
                                  V_VENTA_OTRA_MONEDA_ACUM;
      V_CORRESPONSAL_ACUM      := C_SUMA_COMISION.CDI_EGRESOS_CORRESPONSAL;
      GASTOS_CORRESPONSAL_MES  := R_CIDIDI.CDI_EGRESOS_CORRESPONSAL +
                                  V_CORRESPONSAL_ACUM;
      V_GASTO_SOBREGIRO_ACUM   := C_SUMA_COMISION.CDI_VENTA_GASTO_SOBREGIRO;
      V_GASTOS_SOBREGIRO_MES   := C_SUMA_COMISION.CDI_VENTA_GASTO_SOBREGIRO +
                                  V_GASTO_SOBREGIRO_ACUM;

      OPEN INT_TOTAL_ACUM(R_CIDIDI.FECHA_PROCESO);
      FETCH INT_TOTAL_ACUM
        INTO C_INT_ACUMULADO;
      CLOSE INT_TOTAL_ACUM;
      V_IDE_INTERES := NVL(C_INT_ACUMULADO.IDE_PORC_ACUM, 0);

      V_ND_TOTAL := R_CIDIDI.CDI_NEXT_INT_COMPRAS -
                    R_CIDIDI.CDI_NEXT_INT_VENTAS;

      OPEN FIX_CLIENTES;
      FETCH FIX_CLIENTES
        INTO C_FIX_CLIENTES;
      CLOSE FIX_CLIENTES;

      V_FIX_TOTAL         := R_CIDIDI.CDI_FIX_INT_COMPRAS -
                             R_CIDIDI.CDI_FIX_INT_VENTAS + C_FIX_CLIENTES; --  NVL(C_FIX_CLIENTES,0) ;
      V_BVC_TOTAL_COMPRAS := R_CIDIDI.CDI_DER_BVC_CL_COM +
                             R_CIDIDI.CDI_DER_BVC_PP_COM;
      V_BVC_TOTAL_VENTAS  := R_CIDIDI.CDI_DER_BVC_CL_VEN +
                             R_CIDIDI.CDI_DER_BVC_PP_VEN;

      INSERT INTO TMP_CIDIDI
        (FECHA_PROCESO,
         VALOR_TRM,
         TPC_TRANF_INICIO_DIA,
         TPC_TRANF_DIA,
         TPC_CHEQUE_INICIO_DIA,
         TPC_CHEQUE_DIA,
         TPC_EFECTIVO_INICIO_DIA,
         TPC_EFECTIVO_DIA,
         INVENTARIO_INICIAL_USD,
         INVENTARIO_INICIAL_PESOS,
         INVENTARIO_INICIAL_TASA,
         COMPRAS_VALOR_USD,
         COMPRAS_VALOR_PESOS,
         COMPRAS_VALOR_TASA,
         VENTAS_VALOR_USD,
         VENTAS_VALOR_PESOS,
         VENTAS_VALOR_TASA,
         INVENTARIO_FINAL_USD,
         INVENTARIO_FINAL_PESOS,
         INVENTARIO_FINAL_TASA,
         SWAP_VALOR_USD,
         INVENTARIO_FINAL_USD_POS,
         UTILIDAD_DIA_DIA,
         UTILIDAD_DIA_ACUMULADA,
         UTILIDAD_DIA_MES,
         COMISION_DIA_DIA,
         COMISION_DIA_ACUMULADA,
         COMISION_DIA_MES,
         COMISION_COMERCIAL_DIA,
         COMISION_COMERCIAL_ACUMULADA,
         COMISION_COMERCIAL_MES,
         VALOR_GIRO_DIA,
         VALOR_GIRO_ACUMULADA,
         VALOR_GIRO_MES,
         INGRESOS_OVERNIGHT_DIA,
         INGRESOS_OVERNIGHT_ACUMULADA,
         INGRESOS_OVERNIGHT_MES,
         INGRESOS_OTRAS_MONEDAS_DIA,
         INGRESOS_OTRAS_MONEDAS_ACUM,
         INGRESOS_OTRAS_MONEDAS_MES,
         EGRESOS_OTRAS_MONEDAS_DIA,
         EGRESOS_OTRAS_MONEDAS_ACUM,
         EGRESOS_OTRAS_MONEDAS_MES,
         GASTOS_CORRESPONSAL_DIA,
         GASTOS_CORRESPONSAL_ACUM,
         GASTOS_CORRESPONSAL_MES,
         VENTA_GASTOS_DIA,
         VENTA_GASTOS_ACUMULADA,
         VENTA_GASTOS_MES,
         VLR_PESOS_ORD_SIN_COMPLEMENTAR,
         INTERES_DEPOSITO_EXTERIOR,
         CUENTAS_DEPOSITO_EXTERIOR,
         OPERACIONES_ND_INTERBANCA,
         OPERACIONES_ND_CLIENTES,
         OPERACIONES_ND_NEXT_COMPRAS,
         OPERACIONES_ND_NEXT_VENTAS,
         OPERACIONES_ND_TOTAL,
         OPERACIONES_FIX_INTERBANCA,
         OPERACIONES_FIX_CLIENTES,
         OPERACIONES_FIX_COMPRAS,
         OPERACIONES_FIX_VENTAS,
         OPERACIONES_FIX_TOTAL,
         OPCIONES_OTROS_DER_COMPRAS,
         OPCIONES_OTROS_DER_VENTAS,
         FORWARDS_COMPRAS,
         FORWARDS_VENTAS,
         DERIVADOS_BVC_COMPRAS_PP,
         DERIVADOS_BVC_VENTAS_PP,
         DERIVADOS_BVC_COMPRAS_CLIENTES,
         DERIVADOS_BVC_VENTAS_CLIENTES,
         DERIVADOS_BVC_TOTAL_COMPRAS,
         DERIVADOS_BVC_TOTAL_VENTAS)
      VALUES
        (R_CIDIDI.FECHA_PROCESO, --FECHA_PROCESO
         V_VALOR_TRM, --VALOR_TRM
         V_TPC_TRANF_DIA, --TPC_TRANF_DIA
         R_CIDIDI.CDI_VALOR_TPC_DIA,
         V_CHEQUE_INICIO_DIA, --TPC_CHEQUE_INICIO_DIA
         R_CIDIDI.CDI_VALOR_TPC_DIA_CHEQUES,
         V_TPC_EFECTIVO_INICIO_DIA, --TPC_EFECTIVO_INICIO_DIA
         R_CIDIDI.CDI_VALOR_TPC_DIA_EFECTIVO,
         R_CIDIDI.CDI_INVENTARIO_INICIAL_USD,
         R_CIDIDI.CDI_INVENTARIO_INICIAL_PESOS,
         V_INVENTARIO_INICIAL_TASA, --  INVENTARIO_INICIAL_TASA
         R_CIDIDI.CDI_COMPRAS_USD,
         R_CIDIDI.CDI_COMPRAS_PESOS,
         V_COMPRAS_VALOR_TASA, -- COMPRAS_VALOR_TASA
         R_CIDIDI.CDI_VENTAS_USD,
         R_CIDIDI.CDI_VENTAS_PESOS,
         V_VENTAS_VALOR_TASA, -- VENTAS_VALOR_TASA
         R_CIDIDI.CDI_INVENTARIO_FINAL_USD,
         R_CIDIDI.CDI_INVENTARIO_FINAL_PESOS,
         V_TASA_VALOR_TASA, -- INVENTARIO_FINAL_TASA
         R_CIDIDI.CDI_SWAP,
         R_CIDIDI.CDI_INVENTARIO_FINAL_USD + R_CIDIDI.CDI_SWAP,
         R_CIDIDI.CDI_UTILIDAD_OPERATIVA,
         V_UTILIDAD_ACUMULADA, -- UTILIDAD_DIA_ACUMULADA
         UTILIDAD_DIA_MES, --UTILIDAD_DIA_MES
         R_CIDIDI.CDI_COMISION,
         V_COMISION_ACUMULADA, --COMISION_DIA_ACUMULADA
         V_COMISION_DIA_MES, --COMISION_DIA_MES
         R_CIDIDI.CDI_COMISION_COMERCIAL,
         V_COMERCIAL_ACUMULADA, -- COMISION_COMERCIAL_ACUMULADA
         V_GASTOS_GIRO_ACUMULADA, --COMISION_COMERCIAL_MES
         R_CIDIDI.CDI_GASTOS_GIRO,
         C_SUMA_COMISION.CDI_GASTOS_GIRO, --VALOR_GIRO_ACUMULADA
         V_GIRO_ACUMULADA, --VALOR_GIRO_MES
         R_CIDIDI.CDI_OVER_NIGHT,
         V_OVER_NIGHT_ACUMULADA, -- INGRESOS_OVERNIGHT_ACUMULADA
         V_OVERNIGHT_MES, --INGRESOS_OVERNIGHT_MES
         R_CIDIDI.CDI_COMPRA_OTRA_MONEDA,
         V_OTRA_MONEDA_ACUMULADA, --INGRESOS_OTRAS_MONEDAS_ACUM
         INGRESOS_MONEDAS_MES, -- INGRESOS_OTRAS_MONEDAS_MES
         R_CIDIDI.CDI_VENTA_OTRA_MONEDA,
         V_VENTA_OTRA_MONEDA_ACUM, --EGRESOS_OTRAS_MONEDAS_ACUM
         V_EGRESOS_MONEDAS_ACUM, --EGRESOS_OTRAS_MONEDAS_MES
         R_CIDIDI.CDI_EGRESOS_CORRESPONSAL,
         V_CORRESPONSAL_ACUM, --GASTOS_CORRESPONSAL_ACUM
         GASTOS_CORRESPONSAL_MES, --GASTOS_CORRESPONSAL_MES
         R_CIDIDI.CDI_VENTA_GASTO_SOBREGIRO,
         V_GASTO_SOBREGIRO_ACUM, --VENTA_GASTOS_ACUMULADA
         V_GASTOS_SOBREGIRO_MES, --VENTA_GASTOS_MES
         R_CIDIDI.CDI_SALDO_ORDENES_SIN_PAGOS,
         V_IDE_INTERES, --INTERES_DEPOSITO_EXTERIOR
         R_CIDIDI.CDI_SALDO_DEPOSITOS,
         R_CIDIDI.CDI_VALOR_NEXT_DAY,
         R_CIDIDI.CDI_VALOR_NEXT_DAY_CLIENTE,
         R_CIDIDI.CDI_NEXT_INT_COMPRAS,
         R_CIDIDI.CDI_NEXT_INT_VENTAS,
         V_ND_TOTAL, --OPERACIONES_ND_TOTAL
         R_CIDIDI.CDI_VALOR_FIX,
         NVL(C_FIX_CLIENTES, 0), --OPERACIONES_FIX_CLIENTES
         R_CIDIDI.CDI_FIX_INT_COMPRAS,
         R_CIDIDI.CDI_FIX_INT_VENTAS,
         V_FIX_TOTAL, --OPERACIONES_FIX_TOTAL
         R_CIDIDI.CDI_DERIVADOS_COMPRAS,
         R_CIDIDI.CDI_DERIVADOS_VENTAS,
         R_CIDIDI.CDI_FORWARD_COMPRAS,
         R_CIDIDI.CDI_FORWARD_VENTAS,
         R_CIDIDI.CDI_DER_BVC_PP_COM,
         R_CIDIDI.CDI_DER_BVC_PP_VEN,
         R_CIDIDI.CDI_DER_BVC_CL_COM,
         R_CIDIDI.CDI_DER_BVC_CL_VEN,
         V_BVC_TOTAL_COMPRAS, --DERIVADOS_BVC_TOTAL_COMPRAS
         V_BVC_TOTAL_VENTAS --DERIVADOS_BVC_TOTAL_VENTAS
         );
      COMMIT;
    END LOOP;
  END GENERA_CIDIDI;

  PROCEDURE P_EJECUTA_CIDIDI IS

    P_CODIGO       VARCHAR2(200);
    P_RESPUESTA    VARCHAR2(200);
    V_RUTA         VARCHAR2(100);
    NOMBRE_ARCHIVO VARCHAR2(100);
    P_NUM_INI      NUMBER;
    P_NUM_FIN      NUMBER;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_GENERA_REPORTES_RIESGOS - P_EJECUTA_CIDIDI',
                                                      'INI');

    GENERA_CIDIDI;
    V_RUTA         := '\\nas.corredor.local\Riesgo\CONFIDENCIAL\Reportes Excel Coeasy\';
    NOMBRE_ARCHIVO := 'CIERRE_DIVISAS_' ||
                      TO_CHAR(SYSDATE - 1, 'DDMMYYYY_hh24mmss');

    --LLAMADO AL PROGRAMA QUE CREA EL XSLX
    P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => V_RUTA,
                                   P_NOMBRE_ARCHIVO => NOMBRE_ARCHIVO,
                                   P_QUERY          => 'SELECT FECHA_PROCESO ' ||
                                                       '     , VALOR_TRM ' ||
                                                       '     , TPC_TRANF_INICIO_DIA ' ||
                                                       '     , TPC_TRANF_DIA ' ||
                                                       '     , TPC_CHEQUE_INICIO_DIA ' ||
                                                       '     , TPC_CHEQUE_DIA ' ||
                                                       '     , TPC_EFECTIVO_INICIO_DIA ' ||
                                                       '     , TPC_EFECTIVO_DIA ' ||
                                                       '     , INVENTARIO_INICIAL_USD ' ||
                                                       '     , INVENTARIO_INICIAL_PESOS ' ||
                                                       '     , INVENTARIO_INICIAL_TASA ' ||
                                                       '     , COMPRAS_VALOR_USD ' ||
                                                       '     , COMPRAS_VALOR_PESOS ' ||
                                                       '     , COMPRAS_VALOR_TASA ' ||
                                                       '     , VENTAS_VALOR_USD ' ||
                                                       '     , VENTAS_VALOR_PESOS ' ||
                                                       '     , VENTAS_VALOR_TASA ' ||
                                                       '     , INVENTARIO_FINAL_USD ' ||
                                                       '     , INVENTARIO_FINAL_PESOS ' ||
                                                       '     , INVENTARIO_FINAL_TASA ' ||
                                                       '     , SWAP_VALOR_USD ' ||
                                                       '     , INVENTARIO_FINAL_USD_POS ' ||
                                                       '     , UTILIDAD_DIA_DIA ' ||
                                                       '     , UTILIDAD_DIA_ACUMULADA ' ||
                                                       '     , UTILIDAD_DIA_MES ' ||
                                                       '     , COMISION_DIA_DIA ' ||
                                                       '     , COMISION_DIA_ACUMULADA ' ||
                                                       '     , COMISION_DIA_MES ' ||
                                                       '     , COMISION_COMERCIAL_DIA ' ||
                                                       '     , COMISION_COMERCIAL_ACUMULADA ' ||
                                                       '     , COMISION_COMERCIAL_MES ' ||
                                                       '     , VALOR_GIRO_DIA ' ||
                                                       '     , VALOR_GIRO_ACUMULADA ' ||
                                                       '     , VALOR_GIRO_MES ' ||
                                                       '     , INGRESOS_OVERNIGHT_DIA ' ||
                                                       '     , INGRESOS_OVERNIGHT_ACUMULADA ' ||
                                                       '     , INGRESOS_OVERNIGHT_MES ' ||
                                                       '     , INGRESOS_OTRAS_MONEDAS_DIA ' ||
                                                       '     , INGRESOS_OTRAS_MONEDAS_ACUM ' ||
                                                       '     , INGRESOS_OTRAS_MONEDAS_MES ' ||
                                                       '     , EGRESOS_OTRAS_MONEDAS_DIA ' ||
                                                       '     , EGRESOS_OTRAS_MONEDAS_ACUM ' ||
                                                       '     , EGRESOS_OTRAS_MONEDAS_MES ' ||
                                                       '     , GASTOS_CORRESPONSAL_DIA ' ||
                                                       '     , GASTOS_CORRESPONSAL_ACUM ' ||
                                                       '     , GASTOS_CORRESPONSAL_MES ' ||
                                                       '     , VENTA_GASTOS_DIA ' ||
                                                       '     , VENTA_GASTOS_ACUMULADA ' ||
                                                       '     , VENTA_GASTOS_MES ' ||
                                                       '     , VLR_PESOS_ORD_SIN_COMPLEMENTAR ' ||
                                                       '     , INTERES_DEPOSITO_EXTERIOR ' ||
                                                       '     , CUENTAS_DEPOSITO_EXTERIOR ' ||
                                                       '     , OPERACIONES_ND_INTERBANCA ' ||
                                                       '     , OPERACIONES_ND_CLIENTES ' ||
                                                       '     , OPERACIONES_ND_NEXT_COMPRAS ' ||
                                                       '     , OPERACIONES_ND_NEXT_VENTAS ' ||
                                                       '     , OPERACIONES_ND_TOTAL ' ||
                                                       '     , OPERACIONES_FIX_INTERBANCA ' ||
                                                       '     , OPERACIONES_FIX_CLIENTES ' ||
                                                       '     , OPERACIONES_FIX_COMPRAS ' ||
                                                       '     , OPERACIONES_FIX_VENTAS ' ||
                                                       '     , OPERACIONES_FIX_TOTAL ' ||
                                                       '     , OPCIONES_OTROS_DER_COMPRAS ' ||
                                                       '     , OPCIONES_OTROS_DER_VENTAS ' ||
                                                       '     , FORWARDS_COMPRAS ' ||
                                                       '     , FORWARDS_VENTAS ' ||
                                                       '     , DERIVADOS_BVC_COMPRAS_PP ' ||
                                                       '     , DERIVADOS_BVC_VENTAS_PP ' ||
                                                       '     , DERIVADOS_BVC_COMPRAS_CLIENTES ' ||
                                                       '     , DERIVADOS_BVC_VENTAS_CLIENTES ' ||
                                                       '     , DERIVADOS_BVC_TOTAL_COMPRAS ' ||
                                                       '     , DERIVADOS_BVC_TOTAL_VENTAS ' ||
                                                       '  FROM TMP_CIDIDI',
                                   P_CODIGO         => P_CODIGO,
                                   P_RESPUESTA      => P_RESPUESTA);
    IF P_CODIGO = '0000' THEN
      DBMS_OUTPUT.PUT_LINE('Se ha generado el archivo, en la ruta ' ||
                           V_RUTA);
    END IF;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_GENERA_REPORTES_RIESGOS - P_EJECUTA_CIDIDI',
                                                      'FIN');
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20059,
                              'No se genero reporte, comuniquese con soporte, error: ' ||
                              SQLERRM);
  END P_EJECUTA_CIDIDI;

  FUNCTION CLIENTE(P_ORD_CLI_PER_NUM_IDEN   VARCHAR2,
                   P_ORD_CLI_PER_TID_CODIGO VARCHAR2) RETURN VARCHAR2 IS
    CURSOR C IS
      SELECT L_FILTRO_PERSONAS.PER_NOMBRE
        FROM FILTRO_PERSONAS L_FILTRO_PERSONAS
       WHERE (L_FILTRO_PERSONAS.PER_NUM_IDEN = P_ORD_CLI_PER_NUM_IDEN OR
             (L_FILTRO_PERSONAS.PER_NUM_IDEN IS NULL AND
             P_ORD_CLI_PER_NUM_IDEN IS NULL))
         AND (L_FILTRO_PERSONAS.PER_TID_CODIGO = P_ORD_CLI_PER_TID_CODIGO OR
             (L_FILTRO_PERSONAS.PER_TID_CODIGO IS NULL AND
             P_ORD_CLI_PER_TID_CODIGO IS NULL));

    V_CLIENTE VARCHAR2(200);
  BEGIN
    OPEN C;
    FETCH C
      INTO V_CLIENTE;
    IF C%NOTFOUND THEN
      CLOSE C;
      V_CLIENTE := NULL;
    END IF;
    CLOSE C;
    RETURN V_CLIENTE;
  END;

  PROCEDURE GENERA_FORMATO_531_GENERAL(P_FECHA DATE) IS

    CURSOR C_F531G(FECHA_CORTE DATE) IS
      SELECT CCC_CLI_PER_NUM_IDEN,
             CCC_CLI_PER_TID_CODIGO,
             ENA_BMO_MNEMONICO,
             ENA_MNEMONICO,
             LIC_TIPO_OPERACION,
             TO_CHAR(LIC_NUMERO_OPERACION) NUMERO_OPERACION,
             LIC_FECHA_CUMPLIMIENTO,
             DECODE(LIC_COD_CMSNSTA_CMPRDOR || LIC_COD_CMSNSTA_VNDDOR,
                    '002002',
                    'CRUZADA',
                    'CONVENIDA') CRUZCON,
             LIC_TIPO_OFERTA,
             LIC_SUCURSAL_CUMPLIMIENTO,
             LIC_VOLUMEN_FRACCION,
             LIC_CANTIDAD_FRACCION,
             LIC_VALORACION_TM,
             LIC_FECHA_EMISION,
             LIC_FECHA_VENCIMIENTO
        FROM EMISORES,
             CUENTAS_CLIENTE_CORREDORES,
             ESPECIES_NACIONALES,
             PERSONAS                    PER,
             ORDENES_VENTA,
             LIQUIDACIONES_COMERCIAL     LIC,
             PERSONAS                    PER1,
             PERSONAS_CENTROS_PRODUCCION,
             CENTROS_PRODUCCION
       WHERE ENA_EMI_MNEMONICO = EMI_MNEMONICO
         AND LIC_MNEMOTECNICO_TITULO = ENA_MNEMONICO
         AND CCC_PER_NUM_IDEN = PER.PER_NUM_IDEN
         AND CCC_PER_TID_CODIGO = PER.PER_TID_CODIGO
         AND OVE_CCC_CLI_PER_NUM_IDEN = CCC_CLI_PER_NUM_IDEN
         AND OVE_CCC_CLI_PER_TID_CODIGO = CCC_CLI_PER_TID_CODIGO
         AND OVE_CCC_NUMERO_CUENTA = CCC_NUMERO_CUENTA
         AND OVE_PER_NUM_IDEN = PER1.PER_NUM_IDEN
         AND OVE_PER_TID_CODIGO = PER1.PER_TID_CODIGO
         AND LIC_BOL_MNEMONICO = OVE_BOL_MNEMONICO
         AND LIC_OVE_COC_CTO_MNEMONICO = OVE_COC_CTO_MNEMONICO
         AND LIC_OVE_CONSECUTIVO = OVE_CONSECUTIVO
         AND LIC_FECHA_PACTO_CUMPLIMIENTO IS NULL
         AND LIC_FECHA_CUMPLIMIENTO >= FECHA_CORTE + 1
         AND LIC_FECHA_CUMPLIMIENTO < FECHA_CORTE + 31
         AND LIC_FECHA_OPERACION < FECHA_CORTE + 1
         AND LIC_TIPO_OPERACION = 'V'
         AND CCC_PER_NUM_IDEN = PCP_PER_NUM_IDEN
         AND CCC_PER_TID_CODIGO = PCP_PER_TID_CODIGO
         AND PCP_PRINCIPAL = 'S'
         AND PCP_CPR_MNEMONICO = CPR_MNEMONICO
         AND LIC_ELI_MNEMONICO <> 'ANU';
    P_F531G C_F531G%ROWTYPE;

    FECHA_CORTE  DATE;
    VALORA_FINAL NUMBER(22, 2);
    VAL_MAX      NUMBER(22, 2);
  BEGIN
    DELETE TMP_F531GENERAL;
    COMMIT;

    FECHA_CORTE := P_FECHA;
    FOR P_F531G IN C_F531G(FECHA_CORTE) LOOP

      VALORA_FINAL := P_FORMATO_531.FN_VALORACION(FECHA_CORTE,
                                                  P_F531G.ENA_BMO_MNEMONICO,
                                                  P_F531G.LIC_VALORACION_TM,
                                                  P_F531G.ENA_MNEMONICO,
                                                  P_F531G.CCC_CLI_PER_NUM_IDEN,
                                                  P_F531G.CCC_CLI_PER_TID_CODIGO,
                                                  P_F531G.LIC_CANTIDAD_FRACCION,
                                                  P_F531G.LIC_FECHA_EMISION,
                                                  P_F531G.LIC_FECHA_VENCIMIENTO);
      IF VALORA_FINAL > P_F531G.LIC_VOLUMEN_FRACCION THEN
        VAL_MAX := VALORA_FINAL;
      ELSE
        VAL_MAX := P_F531G.LIC_VOLUMEN_FRACCION;
      END IF;

      INSERT INTO TMP_F531GENERAL
        (NUM_IDENTIFICACION,
         TIPO_IDENTIFICACION,
         BASE_MONETARIA,
         ESPECIE,
         TIPO_OPERACION,
         NUMERO_OPERACION,
         FECHA_CUMPLIMIENTO,
         CRUZCON,
         TIPO_OFERTA,
         SUCURSAL,
         VOLUMEN_FRACCION,
         CANTIDAD_FRACCION,
         VALORACION_TM,
         VALORACION_FINAL,
         VAL_MAX)
      VALUES
        (P_F531G.CCC_CLI_PER_NUM_IDEN,
         P_F531G.CCC_CLI_PER_TID_CODIGO,
         P_F531G.ENA_BMO_MNEMONICO,
         P_F531G.ENA_MNEMONICO,
         P_F531G.LIC_TIPO_OPERACION,
         P_F531G.NUMERO_OPERACION,
         P_F531G.LIC_FECHA_CUMPLIMIENTO,
         P_F531G.CRUZCON,
         P_F531G.LIC_TIPO_OFERTA,
         P_F531G.LIC_SUCURSAL_CUMPLIMIENTO,
         P_F531G.LIC_VOLUMEN_FRACCION,
         P_F531G.LIC_CANTIDAD_FRACCION,
         P_F531G.LIC_VALORACION_TM,
         VALORA_FINAL,
         VAL_MAX);
      COMMIT;
    END LOOP;
  END GENERA_FORMATO_531_GENERAL;

  PROCEDURE PR_EJECUTA_FORMATO_531_GENERAL(P_FECHA DATE) IS

    P_CODIGO       VARCHAR2(200);
    P_RESPUESTA    VARCHAR2(200);
    V_RUTA         VARCHAR2(100);
    NOMBRE_ARCHIVO VARCHAR2(100);
    FECHA          DATE;
    HABIL          VARCHAR2(1);
    P_NUM_INI      NUMBER;
    P_NUM_FIN      NUMBER;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_GENERA_REPORTES_RIESGOS - PR_EJECUTA_FORMATO_531_GENERAL',
                                                      'INI');

    FECHA := P_FECHA;

    IF TO_CHAR(FECHA, 'D') = '2' THEN

      FECHA := FECHA - 3;

      HABIL := P_TOOLS.FN_ES_DIA_HABIL(FECHA);

      IF HABIL = 'N' THEN
        FECHA := FECHA - 1;

        HABIL := NULL;
        HABIL := P_TOOLS.FN_ES_DIA_HABIL(FECHA);

        IF HABIL = 'N' THEN

          FECHA := FECHA - 1;

          HABIL := NULL;
          HABIL := P_TOOLS.FN_ES_DIA_HABIL(FECHA);

        END IF;
      END IF;
      GENERA_FORMATO_531_GENERAL(FECHA);
      V_RUTA := '\\nas.corredor.local\Riesgo\CONFIDENCIAL\Reportes Excel Coeasy\';

      NOMBRE_ARCHIVO := 'F_531_General_' || TO_CHAR(FECHA, 'YYYYMMDD');

      --LLAMADO AL PROGRAMA QUE CREA EL XSLX
      P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => V_RUTA,
                                     P_NOMBRE_ARCHIVO => NOMBRE_ARCHIVO,
                                     P_QUERY          => 'SELECT NUM_IDENTIFICACION ' ||
                                                         '     , TIPO_IDENTIFICACION ' ||
                                                         '     , BASE_MONETARIA ' ||
                                                         '     , ESPECIE ' ||
                                                         '     , TIPO_OPERACION ' ||
                                                         '     , NUMERO_OPERACION ' ||
                                                         '     , FECHA_CUMPLIMIENTO ' ||
                                                         '     , CRUZCON ' ||
                                                         '     , TIPO_OFERTA ' ||
                                                         '     , SUCURSAL ' ||
                                                         '     , VOLUMEN_FRACCION ' ||
                                                         '     , CANTIDAD_FRACCION ' ||
                                                         '     , VALORACION_TM ' ||
                                                         '     , VALORACION_FINAL ' ||
                                                         '     , VAL_MAX ' ||
                                                         '  FROM TMP_F531GENERAL',
                                     P_CODIGO         => P_CODIGO,
                                     P_RESPUESTA      => P_RESPUESTA);
      IF P_CODIGO = '0000' THEN
        DBMS_OUTPUT.PUT_LINE('Se ha generado el archivo, en la ruta ' ||
                             V_RUTA);
      END IF;
    ELSE
      DBMS_OUTPUT.PUT_LINE('La fecha no es un lunes ' || FECHA);
    END IF;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_GENERA_REPORTES_RIESGOS - PR_EJECUTA_FORMATO_531_GENERAL',
                                                      'FIN');
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20059,
                              'No se genero reporte, comuniquese con soporte, error: ' ||
                              SQLERRM);
      --END;
  END PR_EJECUTA_FORMATO_531_GENERAL;

  PROCEDURE GENERA_ORDENES IS
    CURSOR C_COMPRAS IS
      SELECT ORD_SUC_CODIGO,
             ORD_CONSECUTIVO ORDEN,
             '' CLIENTE,
             ORD_TMD_MNEMONICO TIPO_MOV,
             ORD_VALOR_DOLARES VALOR_DOLARES,
             ORD_TASA_CAMBIO TASA_CAMBIO,
             ORD_VALOR_PESOS VALOR_PESOS,
             ORD_VALOR_COMISION VALOR_COMISION,
             ORD_COMISION_COMERCIAL COMISION_COMERCIAL,
             ORD_GASTOS_GIRO GASTOS_GIRO,
             '' VALOR_OVER_NIGHT,
             '' VALOR_OTRAS_MONEDAS,
             ORD_CLI_PER_NUM_IDEN IDENTIFICACION,
             ORD_CLI_PER_TID_CODIGO TIPO,
             '' SUCURSAL,
             ORD_COLOCADO_POR COLOCADO_POR,
             ORD_FECHA_COLOCACION FECHA_COLOCACION,
             ORD_DIAS_NEXT_DAY DIAS_NEXT_DAY,
             ORD_FECHA_CUMPLIMIENTO FECHA_CUMPLIMIENTO
        FROM ORDENES_DIVISAS
       WHERE (ORDENES_DIVISAS.ORD_EOF_CODIGO = 'APR' AND
             ORDENES_DIVISAS.ORD_TIPO_ORDEN = 'C' AND
             ((TRUNC(ORD_FECHA_COLOCACION) = TRUNC(SYSDATE) - 1
             --AND TRUNC(ORD_FECHA_COLOCACION) < TRUNC(SYSDATE)
             AND NVL(ORD_DIAS_NEXT_DAY, 0) = 0) OR
             (TRUNC(ORD_FECHA_CUMPLIMIENTO) = TRUNC(SYSDATE) - 1
             --AND TRUNC(ORD_FECHA_CUMPLIMIENTO) <TRUNC(SYSDATE)
             AND NVL(ORD_DIAS_NEXT_DAY, 0) IN (1, 2, 3))))
       ORDER BY ORD_CONSECUTIVO, ORD_SUC_CODIGO;

    CURSOR C(P_ORD_SUC_CODIGO NUMBER) IS
      SELECT SUC.SUC_NOMBRE
        FROM SUCURSALES SUC
       WHERE SUC.SUC_CODIGO = P_ORD_SUC_CODIGO;

    CURSOR C_VENTAS IS
      SELECT ORD_CONSECUTIVO ORDEN,
             '' CLIENTE,
             ORD_TMD_MNEMONICO TIPO_MOV,
             ORD_VALOR_DOLARES VALOR_DOLARES,
             ORD_TASA_CAMBIO TASA_CAMBIO,
             ORD_VALOR_PESOS VALOR_PESOS,
             ORD_VALOR_COMISION VALOR_COMISION,
             ORD_COMISION_COMERCIAL COMISION_COMERCIAL,
             ORD_GASTOS_GIRO GASTOS_GIRO,
             '' VALOR_OVER_NIGHT,
             '' VALOR_OTRAS_MONEDAS,
             ORD_CLI_PER_NUM_IDEN IDENTIFICACION,
             ORD_CLI_PER_TID_CODIGO TIPO,
             '' SUCURSAL,
             ORD_COLOCADO_POR COLOCADO_POR,
             ORD_FECHA_COLOCACION FECHA_COLOCACION,
             ORD_DIAS_NEXT_DAY DIAS_NEXT_DAY,
             ORD_FECHA_CUMPLIMIENTO FECHA_CUMPLIMIENTO,
             ORD_SUC_CODIGO
        FROM ORDENES_DIVISAS
       WHERE (ORDENES_DIVISAS.ORD_EOF_CODIGO = 'APR' AND
             ORDENES_DIVISAS.ORD_TIPO_ORDEN = 'V' AND
             ((TRUNC(ORD_FECHA_COLOCACION) = TRUNC(SYSDATE) - 1
             -- AND TRUNC(ORD_FECHA_COLOCACION) <TRUNC(SYSDATE)
             AND NVL(ORD_DIAS_NEXT_DAY, 0) = 0) OR
             (TRUNC(ORD_FECHA_CUMPLIMIENTO) = TRUNC(SYSDATE) - 1
             --AND TRUNC(ORD_FECHA_CUMPLIMIENTO) <TRUNC(SYSDATE)
             AND NVL(ORD_DIAS_NEXT_DAY, 0) IN (1, 2, 3))))
       ORDER BY ORD_CONSECUTIVO, ORD_SUC_CODIGO;

    V_CLIENTE       VARCHAR2(100);
    V_OVER_NIGHT    NUMBER;
    V_OTRAS_MONEDAS NUMBER;
    V_SUCURSAL      VARCHAR2(100);
  BEGIN
    DELETE TMP_ORDEN_COMPRA;
    DELETE TMP_ORDEN_VENTA;
    DELETE TMP_ORDEN;
    COMMIT;

    --COMPRAS
    FOR R_COMPRAS IN C_COMPRAS LOOP
      V_CLIENTE := CLIENTE(R_COMPRAS.IDENTIFICACION, R_COMPRAS.TIPO);
      --OVERNIGHT
      IF R_COMPRAS.TIPO_MOV IS NOT NULL THEN
        IF R_COMPRAS.TIPO_MOV = 'COPYG' THEN
          V_OVER_NIGHT    := R_COMPRAS.VALOR_PESOS;
          V_OTRAS_MONEDAS := 0;
        ELSIF R_COMPRAS.TIPO_MOV = 'COOTM' THEN
          V_OTRAS_MONEDAS := R_COMPRAS.VALOR_PESOS;
          V_OVER_NIGHT    := 0;
        ELSE
          V_OVER_NIGHT    := 0;
          V_OTRAS_MONEDAS := 0;
        END IF;
      END IF;

      --SUCURSAL
      OPEN C(R_COMPRAS.ORD_SUC_CODIGO);
      FETCH C
        INTO V_SUCURSAL;
      IF C%NOTFOUND THEN
        CLOSE C;
        V_SUCURSAL := NULL;
      END IF;
      CLOSE C;

      INSERT INTO TMP_ORDEN_COMPRA
        (ORDEN,
         CLIENTE,
         TIPO_MOVIMIENTO,
         VALOR_DOLARES,
         TASA_CAMBIO,
         VALOR_PESOS,
         VALOR_COMISION,
         COMISION_COMERCIAL,
         GASTOS_GIRO,
         VALOR_OVER_NIGHT,
         VALOR_OTRAS_MONEDAS,
         IDENTIFICACION,
         TIPO,
         SUCURSAL,
         COLOCADO_POR,
         FECHA_COLOCACION,
         DIAS_NEXT_DAY,
         FECHA_CUMPLIMIENTO)
      VALUES
        (R_COMPRAS.ORDEN, --ORDEN
         V_CLIENTE, -- CLIENTE,
         R_COMPRAS.TIPO_MOV, --VALOR_DOLARES
         R_COMPRAS.VALOR_DOLARES, --TASA_CAMBIO
         R_COMPRAS.TASA_CAMBIO, --TASA_CAMBIO
         R_COMPRAS.VALOR_PESOS, --VALOR_PESOS
         R_COMPRAS.VALOR_COMISION, --VALOR_COMISION
         R_COMPRAS.COMISION_COMERCIAL, --COMISION_COMERCIAL
         R_COMPRAS.GASTOS_GIRO, --GASTOS_GIRO
         V_OVER_NIGHT, -- VALOR_OVER_NIGHT,
         V_OTRAS_MONEDAS, -- VALOR_OTRAS_MONEDAS,
         R_COMPRAS.IDENTIFICACION, --IDENTIFICACION
         R_COMPRAS.TIPO, --TIPO
         V_SUCURSAL, -- SUCURSAL,
         R_COMPRAS.COLOCADO_POR, --COLOCADO_POR
         R_COMPRAS.FECHA_COLOCACION, --FECHA_COLOCACION
         R_COMPRAS.DIAS_NEXT_DAY, --DIAS_NEXT_DAY
         R_COMPRAS.FECHA_CUMPLIMIENTO --FECHA_CUMPLIMIENTO
         );

    END LOOP;
    COMMIT;

    --VENTAS
    FOR R_VENTAS IN C_VENTAS LOOP
      V_CLIENTE := CLIENTE(R_VENTAS.IDENTIFICACION, R_VENTAS.TIPO);
      --OVERNIGHT
      IF R_VENTAS.TIPO_MOV IS NOT NULL THEN
        IF R_VENTAS.TIPO_MOV = 'COPYG' THEN
          V_OVER_NIGHT    := R_VENTAS.VALOR_PESOS;
          V_OTRAS_MONEDAS := 0;
        ELSIF R_VENTAS.TIPO_MOV = 'COOTM' THEN
          V_OTRAS_MONEDAS := R_VENTAS.VALOR_PESOS;
          V_OVER_NIGHT    := 0;
        ELSE
          V_OVER_NIGHT    := 0;
          V_OTRAS_MONEDAS := 0;
        END IF;
      END IF;

      --SUCURSAL
      OPEN C(R_VENTAS.ORD_SUC_CODIGO);
      FETCH C
        INTO V_SUCURSAL;
      IF C%NOTFOUND THEN
        CLOSE C;
        V_SUCURSAL := NULL;
      END IF;
      CLOSE C;

      INSERT INTO TMP_ORDEN_VENTA
        (ORDEN,
         CLIENTE,
         TIPO_MOVIMIENTO,
         VALOR_DOLARES,
         TASA_CAMBIO,
         VALOR_PESOS,
         VALOR_COMISION,
         COMISION_COMERCIAL,
         GASTOS_GIRO,
         VALOR_OVER_NIGHT,
         VALOR_OTRAS_MONEDAS,
         IDENTIFICACION,
         TIPO,
         SUCURSAL,
         COLOCADO_POR,
         FECHA_COLOCACION,
         DIAS_NEXT_DAY,
         FECHA_CUMPLIMIENTO,
         FECHA_REPORTE)
      VALUES
        (R_VENTAS.ORDEN, --ORDEN
         V_CLIENTE, -- CLIENTE,
         R_VENTAS.TIPO_MOV, --VALOR_DOLARES
         R_VENTAS.VALOR_DOLARES, --TASA_CAMBIO
         R_VENTAS.TASA_CAMBIO, --TASA_CAMBIO
         R_VENTAS.VALOR_PESOS, --VALOR_PESOS
         R_VENTAS.VALOR_COMISION, --VALOR_COMISION
         R_VENTAS.COMISION_COMERCIAL, --COMISION_COMERCIAL
         R_VENTAS.GASTOS_GIRO, --GASTOS_GIRO
         V_OVER_NIGHT, -- VALOR_OVER_NIGHT,
         V_OTRAS_MONEDAS, -- VALOR_OTRAS_MONEDAS,
         R_VENTAS.IDENTIFICACION, --IDENTIFICACION
         R_VENTAS.TIPO, --TIPO
         V_SUCURSAL, -- SUCURSAL,
         R_VENTAS.COLOCADO_POR, --COLOCADO_POR
         R_VENTAS.FECHA_COLOCACION, --FECHA_COLOCACION
         R_VENTAS.DIAS_NEXT_DAY, --DIAS_NEXT_DAY
         R_VENTAS.FECHA_CUMPLIMIENTO, --FECHA_CUMPLIMIENTO
         SYSDATE);
      -- COMMIT;
    END LOOP;
    COMMIT;

    --żRDENES
    INSERT INTO TMP_ORDEN
      (FECHA,
       PUNTA,
       ORDEN,
       CLIENTE,
       TIPO_MOVIMIENTO,
       VALOR_DOLARES,
       TASA_CAMBIO,
       VALOR_PESOS,
       VALOR_COMISION,
       COMISION_COMERCIAL,
       GASTOS_GIRO,
       VALOR_OVER_NIGHT,
       VALOR_OTRAS_MONEDAS,
       IDENTIFICACION,
       TIPO,
       SUCURSAL,
       COLOCADO_POR,
       FECHA_COLOCACION,
       DIAS_NEXT_DAY,
       FECHA_CUMPLIMIENTO)
      SELECT FECHA_REPORTE,
             'C' PUNTA,
             ORDEN,
             CLIENTE,
             TIPO_MOVIMIENTO,
             VALOR_DOLARES,
             TASA_CAMBIO,
             VALOR_PESOS,
             VALOR_COMISION,
             COMISION_COMERCIAL,
             GASTOS_GIRO,
             VALOR_OVER_NIGHT,
             VALOR_OTRAS_MONEDAS,
             IDENTIFICACION,
             TIPO,
             SUCURSAL,
             COLOCADO_POR,
             FECHA_COLOCACION,
             DIAS_NEXT_DAY,
             FECHA_CUMPLIMIENTO
        FROM TMP_ORDEN_COMPRA;
    COMMIT;

    INSERT INTO TMP_ORDEN
      (FECHA,
       PUNTA,
       ORDEN,
       CLIENTE,
       TIPO_MOVIMIENTO,
       VALOR_DOLARES,
       TASA_CAMBIO,
       VALOR_PESOS,
       VALOR_COMISION,
       COMISION_COMERCIAL,
       GASTOS_GIRO,
       VALOR_OVER_NIGHT,
       VALOR_OTRAS_MONEDAS,
       IDENTIFICACION,
       TIPO,
       SUCURSAL,
       COLOCADO_POR,
       FECHA_COLOCACION,
       DIAS_NEXT_DAY,
       FECHA_CUMPLIMIENTO)
      SELECT FECHA_REPORTE,
             'V' PUNTA,
             ORDEN,
             CLIENTE,
             TIPO_MOVIMIENTO,
             VALOR_DOLARES,
             TASA_CAMBIO,
             VALOR_PESOS,
             VALOR_COMISION,
             COMISION_COMERCIAL,
             GASTOS_GIRO,
             VALOR_OVER_NIGHT,
             VALOR_OTRAS_MONEDAS,
             IDENTIFICACION,
             TIPO,
             SUCURSAL,
             COLOCADO_POR,
             FECHA_COLOCACION,
             DIAS_NEXT_DAY,
             FECHA_CUMPLIMIENTO
        FROM TMP_ORDEN_VENTA;
    COMMIT;

  END GENERA_ORDENES;

  PROCEDURE P_EJECUTA_ORDENES IS

    P_CODIGO       VARCHAR2(200);
    P_RESPUESTA    VARCHAR2(200);
    V_RUTA         VARCHAR2(100);
    NOMBRE_ARCHIVO VARCHAR2(100);
    P_NUM_INI      NUMBER;
    P_NUM_FIN      NUMBER;
  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_GENERA_REPORTES_RIESGOS - P_EJECUTA_ORDENES',
                                                      'INI');

    GENERA_ORDENES;

    V_RUTA         := '\\nas.corredor.local\Riesgo\CONFIDENCIAL\Reportes Excel Coeasy\';
    NOMBRE_ARCHIVO := 'ORDENES_DIVISAS_' ||
                      TO_CHAR(SYSDATE - 1, 'DDMMYYYY_hh24mmss');

    --LLAMADO AL PROGRAMA QUE CREA EL XSLX
    P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => V_RUTA,
                                   P_NOMBRE_ARCHIVO => NOMBRE_ARCHIVO,
                                   P_QUERY          => 'SELECT FECHA ' ||
                                                       '     , PUNTA ' ||
                                                       '     , ORDEN ' ||
                                                       '     , CLIENTE ' ||
                                                       '     , TIPO_MOVIMIENTO ' ||
                                                       '     , VALOR_DOLARES ' ||
                                                       '     , TASA_CAMBIO ' ||
                                                       '     , VALOR_PESOS ' ||
                                                       '     , VALOR_COMISION ' ||
                                                       '     , COMISION_COMERCIAL ' ||
                                                       '     , GASTOS_GIRO ' ||
                                                       '     , VALOR_OVER_NIGHT ' ||
                                                       '     , VALOR_OTRAS_MONEDAS ' ||
                                                       '     , IDENTIFICACION ' ||
                                                       '     , TIPO ' ||
                                                       '     , SUCURSAL ' ||
                                                       '     , COLOCADO_POR ' ||
                                                       '     , FECHA_COLOCACION ' ||
                                                       '     , DIAS_NEXT_DAY ' ||
                                                       '     , FECHA_CUMPLIMIENTO ' ||
                                                       '  FROM TMP_ORDEN',
                                   P_CODIGO         => P_CODIGO,
                                   P_RESPUESTA      => P_RESPUESTA);
    IF P_CODIGO = '0000' THEN
      DBMS_OUTPUT.PUT_LINE('Se ha generado el archivo, en la ruta ' ||
                           V_RUTA);
    END IF;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_GENERA_REPORTES_RIESGOS - P_EJECUTA_ORDENES',
                                                      'FIN');
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20059,
                              'No se genero reporte, comuniquese con soporte, error: ' ||
                              SQLERRM);
  END P_EJECUTA_ORDENES;

  PROCEDURE PR_REPORTE_PYGFON(P_USERID IN VARCHAR2) IS

    VAR       VARCHAR2(2000);
    P_FONDO   VARCHAR2(1);
    V_FECHA   VARCHAR2(20);
    V_FECHAN  VARCHAR2(20);
    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_RPYGFO',
                                                      'INI');

    SELECT TO_CHAR(TRUNC(SYSDATE - 1),
                   'DD-MON-YYYY',
                   'nls_date_language = ''LATIN AMERICAN SPANISH''')
      INTO V_FECHA
      FROM DUAL;

    SELECT TO_CHAR(TRUNC(SYSDATE - 1), 'DDMMYYYY') INTO V_FECHAN FROM DUAL;
    /*P_MAIL.ENVIO_MAIL_ERROR('Inicio genera reporte RPYGFO ',
    '<br>'||'Fecha consultada del reporte: '||V_FECHA||,
    DESTINATARIOS); */

    P_TOOLS.PR_CREAR_REPORTE(P_REPORT     => 'RPYGFO',
                             P_USERID     => P_USERID,
                             P_FORMATO    => 'XLS',
                             P_PARAMETROS => '+FECHA_DESDE=' || V_FECHA ||
                                             '+FONDO=%25+FECHA_HASTA=' ||
                                             V_FECHA,
                             P_ARCHIVO    => '/apps/rep_nocturnos/diarios/PYGFON_' ||
                                             V_FECHAN);

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_RPYGFO',
                                                      'FIN');

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PR_REPORTE_RPYGFO',
                              SUBSTR(SQLERRM, 1, 80),
                              'procesosnocturnos@corredores.com');
  END PR_REPORTE_PYGFON;

  PROCEDURE P_GENERA_INPOAD IS

    CURSOR C_PFRF IS
      SELECT PFRF_FON_CODIGO,
             PFRF_TFO_CODIGO,
             PFRF_TFO_ENA_MNEMONICO,
             PFRF_TFO_PERIODICIDAD_TASA,
             PFRF_TFO_MODALIDAD_TASA,
             PFRF_TFO_VALOR_OPERACION,
             PFRF_TFO_LTI_MNEMONICO,
             PFRF_TFO_PRC_PRF_CONSECUTIVO,
             PFRF_MRF_TIR365_C,
             PFRF_MRF_VALOR_TITULO_TM,
             PFRF_MRF_VALORIZACION_TM,
             PFRF_MRF_VALOR_DIS_DIA,
             PFRF_MRF_PRECIO,
             PFRF_MRF_INDICADOR,
             PFRF_EMI_MNEMONICO,
             PFRF_NUMERO_OPERACION,
             PFRF_DIAS_VENCIMIENTO,
             PFRF_TASA_DESC_PIP,
             PFRF_ENA_MNEMONICO_SUPER,
             PFRF_VALORIZACION_LR,
             PFRF_TASA,
             PFRF_MRF_VALOR_TITULO_TM_AY,
             PFRF_GNA_MNEMONICO,
             PFRF_GNA_DESCRIPCION,
             PFRF_EMI_DESCRIPCION
        FROM HIS_PORTAFOLIO_FONDOS_RF
       WHERE PFRF_FON_RAZON_SOCIAL IS NULL
         AND PFRF_FON_CODIGO IS NOT NULL
         AND PFRF_FECHA >= TRUNC(SYSDATE - 1)
         AND PFRF_FECHA < TRUNC(SYSDATE);
    V_PFRF C_PFRF%ROWTYPE;

    CURSOR C_FONDOS(CODIGO VARCHAR2) IS
      SELECT FON_RAZON_SOCIAL FROM FONDOS WHERE FON_CODIGO = CODIGO;

    V_FONDOS VARCHAR2(200);

    P_CODIGO       VARCHAR2(200);
    P_RESPUESTA    VARCHAR2(200);
    RUTA           VARCHAR2(100);
    NOMBRE_ARCHIVO VARCHAR2(100);
    V_QUERY        VARCHAR2(5000);

  BEGIN

    DELETE FROM GL_COPORF;
    COMMIT;

    RUTA           := '\\nas.corredor.local\Riesgo\CONFIDENCIAL\Reportes Excel Coeasy\'; --\\Nas\Riesgo\Confidencial\Portafolios Renta Fija\';
    NOMBRE_ARCHIVO := 'INPOAD_DET_' ||
                      TO_CHAR(SYSDATE, 'DDMMYYYY_hh24mmss');

    OPEN C_PFRF;
    FETCH C_PFRF
      INTO V_PFRF;
    WHILE C_PFRF%FOUND LOOP
      OPEN C_FONDOS(V_PFRF.PFRF_FON_CODIGO);
      FETCH C_FONDOS
        INTO V_FONDOS;
      IF C_FONDOS%FOUND THEN
        UPDATE HIS_PORTAFOLIO_FONDOS_RF
           SET PFRF_FON_RAZON_SOCIAL = V_FONDOS
         WHERE PFRF_FON_CODIGO = V_PFRF.PFRF_FON_CODIGO
           AND PFRF_FON_RAZON_SOCIAL IS NULL;
        COMMIT;
      END IF;
      CLOSE C_FONDOS;
      FETCH C_PFRF
        INTO V_PFRF;
    END LOOP;
    CLOSE C_PFRF;

    INSERT INTO GL_COPORF
      (FECHA_REPORTE,
       FONDO,
       CODIGO,
       ESPECIE,
       CUENTA,
       VALOR_NOMINAL,
       TASA,
       MODAL,
       EMISION,
       VENCIM,
       COMPRA,
       CAL_INT,
       CAPT,
       PRECIO_PIP,
       PRECIO_INFOVAL,
       MARGEN_C,
       MARGEN,
       INDICE,
       GRUP_VAL,
       VALOR_COMPRA,
       DIAS_VENC,
       VR_DIST_DIA,
       VR_TASA_MDO,
       VALOR_TITULO_TM_PIP,
       TIPO_INVERSION,
       NEGOCIO,
       IND_VAL,
       IND_SUP,
       TASA_DESC_PIP,
       TASA_DESC_INFOVAL,
       ISIN_NUMEMISION,
       DEPOSITO,
       NUMERO_OPERACION,
       VALORIZACION_LR,
       VALOR_TITULO_TM_AY,
       GNA_MNEMONICO,
       GNA_DESCRIPCION,
       EMI_DESCRIPCION,
       TIPO_GARANTIA,
       CUENTA_CRCC,
       SEGMENTO,
       ESTADO_TIT,
       TITULO_GAR_SIM,
       VALOR_TM_ANO_ANT,
       RAZON_SOCIAL,
       PYG_MERCADO,
       ORI_ACUMULADO,
       ORI_DIARIO,
       CLASIF_INVERSION) -- SORTIZ transmisiones simultaneas se adiciona desde el PYG_MERCADO
      SELECT PFRF_FECHA fecha_reporte,
             PFRF_FON_CODIGO fondo,
             PFRF_TFO_CODIGO Codigo,
             PFRF_TFO_ENA_MNEMONICO Especie,
             PFRF_CCC_NUMERO_CUENTA Cuenta,
             PFRF_TFO_VALOR_NOMINAL Valor_Nominal,
             PFRF_TASA TASA,
             PFRF_TFO_PERIODICIDAD_TASA || PFRF_TFO_MODALIDAD_TASA Modal,
             PFRF_TFO_FECHA_EMISION Emision,
             PFRF_TFO_FECHA_VENCIMIENTO Vencim,
             PFRF_TFO_FECHA_OPERACION Compra,
             PFRF_TIPO_PAGO_FLUJO CAL_INT,
             PFRF_TFO_CAPITALIZABLE CAPT,
             PFRF_MRF_PRECIO PRECIO_PIP,
             PFRF_MRF_PRECIO_ALT PRECIO_INFOVAL,
             PFRF_MRF_TIR365_C Margen_C,
             PFRF_MRF_MARGEN Margen,
             PFRF_MRF_INDICE INDICE,
             PFRF_GRUPO_VAL GRUP_VAL,
             PFRF_TFO_VALOR_OPERACION VALOR_COMPRA,
             PFRF_DIAS_VENCIMIENTO DIAS_VENC,
             PFRF_MRF_VALOR_DIS_DIA VR_DIST_DIA,
             PFRF_MRF_VALORIZACION_TM VR_TASA_MDO,
             PFRF_MRF_VALOR_TITULO_TM VALOR_TITULO_TM_PIP,
             PFRF_TIPO_INVERSION TIPO_INVERSION,
             (CASE
               WHEN PFRF_TFO_PRC_PRF_CONSECUTIVO IS NOT NULL AND
                    PFRF_TFO_PRV_PRF_CONSECUTIVO IS NULL THEN
                PFRF_TFO_PRC_PRF_CONSECUTIVO
               WHEN PFRF_TFO_PRV_PRF_CONSECUTIVO IS NOT NULL AND
                    PFRF_TFO_PRC_PRF_CONSECUTIVO IS NULL THEN
                PFRF_TFO_PRV_PRF_CONSECUTIVO
               ELSE
                NULL
             END) NEGOCIO,
             PFRF_MRF_INDICADOR IND_VAL,
             PFRF_ENA_MNEMONICO_SUPER IND_SUP,
             PFRF_TASA_DESC_PIP Tasa_Desc_PIP,
             PFRF_TASA_DESC_INF TASA_DESC_INFOVAL,
             PFRF_TFO_FUG_ISI_MNEMONICO ISIN_NUMEMISION,
             DECODE(PFRF_TFO_LTI_MNEMONICO,
                    'DA',
                    'Deceval',
                    'DV',
                    'DCV',
                    PFRF_TFO_LTI_MNEMONICO) Deposito,
             TO_CHAR(PFRF_NUMERO_OPERACION) Numero_Operacion,
             PFRF_VALORIZACION_LR Valorizacion_LR,
             PFRF_MRF_VALOR_TITULO_TM_AY,
             PFRF_GNA_MNEMONICO,
             PFRF_GNA_DESCRIPCION,
             PFRF_EMI_DESCRIPCION,
             PFRF_TFO_TIPO_GARANTIA,
             PFRF_TFO_CUENTA_CRCC,
             PFRF_TFO_SEGMENTO,
             PFRF_TFO_ETI_CODIGO,
             PFRF_TFOS_CODIGO,
             PFRF_VALOR_TM_ANO_ANT,
             PFRF_FON_RAZON_SOCIAL,
             PFRF_PYG_MERCADO -- SORTIZ TRANSMISIONES SIMULTANEAS 2
            ,
             PFRF_ORI_ACUMULADO -- SORTIZ TRANSMISIONES SIMULTANEAS 2
            ,
             PFRF_ORI_DIARIO -- SORTIZ TRANSMISIONES SIMULTANEAS 2
            ,
             PFRF_CLASIF_INVERSION -- SORTIZ TRANSMISIONES SIMULTANEAS 2
        FROM HIS_PORTAFOLIO_FONDOS_RF
       WHERE PFRF_MRF_VALOR_TITULO_TM != 0
         AND EXISTS (SELECT 'X'
                FROM TIPOS_OPERACIONES_PORTAFOLIO,
                     CLASIFICACIONES_OPERACIONES_DA
               WHERE TOPO_MNEMONICO = CLOD_TOPO_MNEMONICO
                 AND TOPO_DESCRIPCION = PFRF_TIPO_INVERSION)
         AND PFRF_FECHA >= TRUNC(SYSDATE - 1)
         AND PFRF_FECHA < TRUNC(SYSDATE);
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PRC_SALDOS_DISPONIBLES_LVA',
                              SUBSTR(SQLERRM, 1, 80),
                              'procesosnocturnos@corredores.com');
      --NULL;
  END P_GENERA_INPOAD;

  PROCEDURE P_EJECUTA_INPOAD IS

    NOMBRE_ARCHIVO     VARCHAR2(100);
    P_FECHA2           VARCHAR2(20);
    TIPO_CLIENTE       VARCHAR2(20);
    TIP_ARCHIVO        UTL_FILE.FILE_TYPE;
    ARCHIVO_PORTAFOLIO VARCHAR2(100);
    V_RUTA             VARCHAR2(100);
    P_CODIGO           VARCHAR2(200);
    P_RESPUESTA        VARCHAR2(200);
    P_NUM_INI          NUMBER;
    P_NUM_FIN          NUMBER;
  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_GENERA_REPORTES_RIESGOS - P_EJECUTA_INPOAD',
                                                      'INI');

    P_GENERA_INPOAD;
    V_RUTA         := '\\nas.corredor.local\Riesgo\CONFIDENCIAL\Reportes Excel Coeasy\';
    NOMBRE_ARCHIVO := 'INPOAD_' ||
                      TO_CHAR(SYSDATE - 1, 'DDMMYYYY_hh24mmss');

    --LLAMADO AL PROGRAMA QUE CREA EL XSLX
    P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => V_RUTA,
                                   P_NOMBRE_ARCHIVO => NOMBRE_ARCHIVO,
                                   P_QUERY          => 'SELECT CODIGO ' ||
                                                       '     , ESPECIE ' ||
                                                       '     , VALOR_NOMINAL ' ||
                                                       '     , TASA, MODAL ' ||
                                                       '     , EMISION ' ||
                                                       '     , VENCIM ' ||
                                                       '     , COMPRA ' ||
                                                       '     , CAL_INT ' ||
                                                       '     , CAPT ' ||
                                                       '     , PRECIO_PIP ' ||
                                                       '     , PRECIO_INFOVAL ' ||
                                                       '     , MARGEN_C ' ||
                                                       '     , MARGEN ' ||
                                                       '     , INDICE ' ||
                                                       '     , GRUP_VAL ' ||
                                                       '     , VALOR_COMPRA ' ||
                                                       '     , DIAS_VENC ' ||
                                                       '     , VR_DIST_DIA ' ||
                                                       '     , VR_TASA_MDO ' ||
                                                       '     , VALOR_TITULO_TM_PIP ' ||
                                                       '     , TIPO_INVERSION ' ||
                                                       '     , NEGOCIO ' ||
                                                       '     , IND_VAL ' ||
                                                       '     , IND_SUP ' ||
                                                       '     , TASA_DESC_PIP ' ||
                                                       '     , TASA_DESC_INFOVAL ' ||
                                                       '     , ISIN_NUMEMISION ' ||
                                                       '     , DEPOSITO ' ||
                                                       '     , NUMERO_OPERACION ' ||
                                                       '     , VALORIZACION_LR ' ||
                                                       '     , VALOR_TITULO_TM_AY ' ||
                                                       '     , GNA_MNEMONICO ' ||
                                                       '     , GNA_DESCRIPCION ' ||
                                                       '     , EMI_DESCRIPCION ' ||
                                                       '     , FECHA_REPORTE ' ||
                                                       '     , FONDO ' ||
                                                       '     , TIPO_GARANTIA ' ||
                                                       '     , CUENTA_CRCC ' ||
                                                       '     , SEGMENTO ' ||
                                                       '     , ESTADO_TIT ' ||
                                                       '     , CUENTA ' ||
                                                       '     , TITULO_GAR_SIM ' ||
                                                       '     , VALOR_TM_ANO_ANT ' ||
                                                       '     , RAZON_SOCIAL ' ||
                                                       '     , PYG_MERCADO ' ||
                                                       '     , ORI_ACUMULADO ' ||
                                                       '     , ORI_DIARIO ' ||
                                                       '     , CLASIF_INVERSION ' ||
                                                       '  FROM GL_COPORF',
                                   P_CODIGO         => P_CODIGO,
                                   P_RESPUESTA      => P_RESPUESTA);
    IF P_CODIGO = '0000' THEN
      DBMS_OUTPUT.PUT_LINE('Se ha generado el archivo, en la ruta ' ||
                           V_RUTA);
    END IF;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_GENERA_REPORTES_RIESGOS - P_EJECUTA_INPOAD',
                                                      'FIN');
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20059,
                              'No se genero reporte, comuniquese con soporte, error: ' ||
                              SQLERRM);

  END P_EJECUTA_INPOAD;

  PROCEDURE P_GENERA_SAMOBS IS
    P_RUTA    VARCHAR2(100);
    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;
  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_GENERA_REPORTES_RIESGOS - P_GENERA_SAMOBS',
                                                      'INI');

    P_REPORTES_OMNIBUS.REPORTE_SALDOS_OMNIBUS(TRUNC(SYSDATE - 1),

                                              SYSDATE,
                                              '%',
                                              '0',
                                              'N',
                                              P_RUTA);

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_GENERA_REPORTES_RIESGOS - P_GENERA_SAMOBS',
                                                      'FIN');
    COMMIT;

  END P_GENERA_SAMOBS;
  FUNCTION DIA_HABIL(FECOPE IN DATE, FECCUM IN DATE) RETURN NUMBER IS
    CURSOR DIAS(DINOHA DATE) IS
      SELECT 'X' FROM DIAS_NO_HABILES WHERE DNH_FECHA = DINOHA;
    DATO      VARCHAR2(1);
    CONTADOR  NUMBER;
    FECHA_OPE DATE;
  BEGIN
    CONTADOR  := 0;
    FECHA_OPE := FECOPE;
    WHILE FECHA_OPE <= FECCUM LOOP
      IF TO_CHAR(FECHA_OPE, 'D') IN ('1', '7') THEN
        CONTADOR := CONTADOR + 1;
      ELSE
        OPEN DIAS(FECHA_OPE);
        FETCH DIAS
          INTO DATO;
        IF DIAS%FOUND THEN
          CONTADOR := CONTADOR + 1;
        END IF;
        CLOSE DIAS;
      END IF;
      FECHA_OPE := FECHA_OPE + 1;
    END LOOP;
    CONTADOR := (FECCUM - FECOPE) - CONTADOR;
    RETURN(CONTADOR);
  END DIA_HABIL;

  FUNCTION VALOR_TIPO_OPERACION(INDICADOR_SWAP        VARCHAR2,
                                INDICADOR_CARRUSEL    VARCHAR2,
                                TIPO_OFERTA           VARCHAR2,
                                CONDICION_NEGOCIACION VARCHAR2,
                                FECHA_OPERACION       DATE,
                                FECHA_CUMPLIMIENTO    DATE,
                                CLASE_TRANSACCION     VARCHAR2) RETURN CHAR IS
    DIAS NUMBER;
  BEGIN
    IF INDICADOR_SWAP = 'S' THEN
      RETURN('SWAP');
    ELSIF INDICADOR_CARRUSEL = 'S' THEN
      RETURN('CARRUSEL');
    ELSIF TIPO_OFERTA IN ('A', 'R') THEN
      RETURN('REPO CRCC');
    ELSIF TIPO_OFERTA IN ('P') THEN
      RETURN('OPA');
    ELSIF TIPO_OFERTA IN ('1', '2') THEN
      RETURN('SIMULTANEA');
    ELSIF TIPO_OFERTA IN ('3', '4') THEN
      RETURN('TTV');
    ELSIF TIPO_OFERTA IN ('5', '6') THEN
      RETURN('SIMULTANEA CRCC');
    ELSIF CONDICION_NEGOCIACION = 'VCO' THEN
      RETURN('VENTA CORTO');
    ELSE
      --     IF TRUNC(:LIC_FECHA_OPERACION) <> TRUNC(:LIC_FECHA_CUMPLIMIENTO) THEN
      DIAS := DIA_HABIL(FECHA_OPERACION, FECHA_CUMPLIMIENTO);
      IF (DIAS >= 6 AND CLASE_TRANSACCION = 'RF') OR
         (DIAS >= 7 AND CLASE_TRANSACCION = 'ACC') THEN
        RETURN('PLAZO');
      ELSE
        RETURN('CONTADO');
      END IF;
    END IF;
  END VALOR_TIPO_OPERACION;

  FUNCTION VALORACION_PESOS(OVE_ENA_MNEMONICO VARCHAR2,
                            FECHA_VALORACION  DATE,
                            VALORACION_TM     NUMBER) RETURN NUMBER IS
    CURSOR C_BASE_MONETARIA IS
      SELECT ENA_BMO_MNEMONICO
        FROM ESPECIES_NACIONALES
       WHERE ENA_MNEMONICO = OVE_ENA_MNEMONICO;
    ENA1 C_BASE_MONETARIA%ROWTYPE;

    CURSOR C_COTIZACION(P_BASE VARCHAR2, P_FECHA DATE) IS
      SELECT CBM_VALOR
        FROM COTIZACIONES_BASE_MONETARIAS
       WHERE CBM_BMO_MNEMONICO = P_BASE
         AND CBM_FECHA >= TRUNC(P_FECHA)
         AND CBM_FECHA < TRUNC(P_FECHA + 1);
    CBM1 C_COTIZACION%ROWTYPE;

  BEGIN
    IF FECHA_VALORACION IS NOT NULL THEN
      OPEN C_BASE_MONETARIA;
      FETCH C_BASE_MONETARIA
        INTO ENA1;
      CLOSE C_BASE_MONETARIA;

      IF ENA1.ENA_BMO_MNEMONICO = 'PEI' THEN
        OPEN C_COTIZACION(ENA1.ENA_BMO_MNEMONICO, FECHA_VALORACION);
        FETCH C_COTIZACION
          INTO CBM1;
        CLOSE C_COTIZACION;

        RETURN NVL(VALORACION_TM * CBM1.CBM_VALOR, 0);
      ELSE
        RETURN VALORACION_TM;
      END IF;
    ELSE
      RETURN VALORACION_TM;
    END IF;
  END VALORACION_PESOS;

  FUNCTION IVA(TIPO_OPERACION   VARCHAR2,
               NUMERO_OPERACION NUMBER,
               NUMERO_FRACCION  NUMBER,
               BOL_MNEMONICO    VARCHAR2) RETURN NUMBER IS

    V_MONTO_MVTO NUMBER(22, 3) := 0;
  BEGIN
    IF TIPO_OPERACION = 'V' THEN

      SELECT NVL((MCC_MONTO + MCC_MONTO_A_CONTADO + MCC_MONTO_A_PLAZO +
                 MCC_MONTO_BURSATIL),
                 0) MONTO_MVTO
        INTO V_MONTO_MVTO
        FROM MOVIMIENTOS_CUENTA_CORREDORES
       WHERE MCC_LIC_NUMERO_OPERACION = NUMERO_OPERACION
         AND MCC_LIC_NUMERO_FRACCION = NUMERO_FRACCION
         AND MCC_LIC_TIPO_OPERACION = TIPO_OPERACION
         AND MCC_LIC_BOL_MNEMONICO = BOL_MNEMONICO
            --  AND    MCC_MCC_FECHA IS NULL       -- rhenao
         AND MCC_MCC_CONSECUTIVO IS NULL -- rhenao
         AND MCC_TMC_MNEMONICO = 'IVAV';

    ELSIF TIPO_OPERACION = 'C' THEN

      SELECT NVL((MCC_MONTO + MCC_MONTO_A_CONTADO + MCC_MONTO_A_PLAZO +
                 MCC_MONTO_BURSATIL),
                 0) MONTO_MVTO
        INTO V_MONTO_MVTO
        FROM MOVIMIENTOS_CUENTA_CORREDORES
       WHERE MCC_LIC_NUMERO_OPERACION = NUMERO_OPERACION
         AND MCC_LIC_NUMERO_FRACCION = NUMERO_FRACCION
         AND MCC_LIC_TIPO_OPERACION = TIPO_OPERACION
         AND MCC_LIC_BOL_MNEMONICO = BOL_MNEMONICO
            --  AND    MCC_MCC_FECHA IS NULL       -- rhenao
         AND MCC_MCC_CONSECUTIVO IS NULL -- rhenao
         AND MCC_TMC_MNEMONICO = 'IVAC';
    END IF;

    RETURN V_MONTO_MVTO;
  EXCEPTION
    WHEN NO_DATA_FOUND THEN
      RETURN V_MONTO_MVTO;
  END IVA;

  FUNCTION RETEFTE(TIPO_OPERACION   VARCHAR2,
                   NUMERO_OPERACION NUMBER,
                   NUMERO_FRACCION  NUMBER,
                   BOL_MNEMONICO    VARCHAR2) RETURN NUMBER IS
    V_MONTO_MVTO NUMBER(22, 3) := 0;
  BEGIN
    IF TIPO_OPERACION = 'V' THEN
      SELECT NVL((MCC_MONTO + MCC_MONTO_A_CONTADO + MCC_MONTO_A_PLAZO +
                 MCC_MONTO_BURSATIL),
                 0) MONTO_MVTO
        INTO V_MONTO_MVTO
        FROM MOVIMIENTOS_CUENTA_CORREDORES
       WHERE MCC_LIC_NUMERO_OPERACION = NUMERO_OPERACION
         AND MCC_LIC_NUMERO_FRACCION = NUMERO_FRACCION
         AND MCC_LIC_TIPO_OPERACION = TIPO_OPERACION
         AND MCC_LIC_BOL_MNEMONICO = BOL_MNEMONICO
         AND MCC_MCC_CONSECUTIVO IS NULL
         AND MCC_TMC_MNEMONICO = 'RFV';

    ELSIF TIPO_OPERACION = 'C' THEN

      SELECT ABS(NVL((MCC_MONTO + MCC_MONTO_A_CONTADO + MCC_MONTO_A_PLAZO +
                     MCC_MONTO_BURSATIL),
                     0)) MONTO_MVTO
        INTO V_MONTO_MVTO
        FROM MOVIMIENTOS_CUENTA_CORREDORES
       WHERE MCC_LIC_NUMERO_OPERACION = NUMERO_OPERACION
         AND MCC_LIC_NUMERO_FRACCION = NUMERO_FRACCION
         AND MCC_LIC_TIPO_OPERACION = TIPO_OPERACION
         AND MCC_LIC_BOL_MNEMONICO = BOL_MNEMONICO
         AND MCC_MCC_CONSECUTIVO IS NULL
         AND MCC_TMC_MNEMONICO = 'RFC';
    END IF;

    RETURN V_MONTO_MVTO;
  EXCEPTION
    WHEN NO_DATA_FOUND THEN
      RETURN V_MONTO_MVTO;
  END RETEFTE;

  FUNCTION PAQUETE(TIPO_OPERACION   VARCHAR2,
                   NUMERO_OPERACION NUMBER,
                   NUMERO_FRACCION  NUMBER,
                   BOL_MNEMONICO    VARCHAR2) RETURN VARCHAR2 IS

    V_PAQUETE_BVC VARCHAR2(20);

    CURSOR C_LEP IS
      SELECT TO_CHAR(LEP_PBO_FECHA_PAQUETE_BOLSA, 'YYYYMMDD') ||
             LEP_PBO_FOLIO_PAQUETE_BOLSA PAQ_BVC
        FROM LIQUIDACIONES_EMPAQUETADAS
       WHERE LEP_NUMERO_OPERACION = NUMERO_OPERACION
         AND LEP_NUMERO_FRACCION = NUMERO_FRACCION
         AND LEP_TIPO_OPERACION = TIPO_OPERACION
         AND LEP_BOL_MNEMONICO = BOL_MNEMONICO;

  BEGIN
    OPEN C_LEP;
    FETCH C_LEP
      INTO V_PAQUETE_BVC;
    IF C_LEP%FOUND THEN
      IF NVL(V_PAQUETE_BVC, ' ') = ' ' THEN
        V_PAQUETE_BVC := 'EN PROCESO';
      END IF;
    ELSE
      V_PAQUETE_BVC := '';
    END IF;
    RETURN(V_PAQUETE_BVC);
  END PAQUETE;

  FUNCTION ISIN(OVE_ENA_MNEMONICO VARCHAR2) RETURN VARCHAR2 IS

    V_FN_ISIN FUNGIBLES.FUG_ISI_MNEMONICO%TYPE;

    CURSOR C_ISIN IS
      SELECT FUG_ISI_MNEMONICO FUG_ISI_MNEMONICO
        FROM FUNGIBLES
       WHERE FUG_ENA_MNEMONICO = OVE_ENA_MNEMONICO
         AND FUG_ESTADO = 'A';

  BEGIN
    OPEN C_ISIN;
    FETCH C_ISIN
      INTO V_FN_ISIN;
    IF C_ISIN%FOUND THEN
      IF NVL(V_FN_ISIN, ' ') = ' ' THEN
        V_FN_ISIN := NULL;
      END IF;
    ELSE
      V_FN_ISIN := '';
    END IF;
    RETURN(V_FN_ISIN);
  END ISIN;

  PROCEDURE GENERA_OPEBOL_DIA IS

    P_HINT                   VARCHAR2(100);
    P_CONDICION              VARCHAR2(500);
    P_CLIENTE                VARCHAR2(1) := '%';
    P_CONDICION_ESPECULATIVA VARCHAR2(500);
    CONT                     NUMBER;
    V_TO                     VARCHAR2(100);
    V_VALOR_TM               NUMBER;
    V_IVA                    NUMBER;
    V_RETEFTE                NUMBER;
    V_PAQUETE                VARCHAR2(100);
    V_ISIN                   VARCHAR2(15);

    CURSOR C_DATOS_GL IS
      SELECT BOL_MNEMONICO,
             NUMERO_OPERACION,
             NUMERO_FRACCION,
             TIPO_OPERACION,
             ELI_MNEMONICO,
             MERCADO,
             FECHA_CUMPLIMIENTO,
             SERVICIO_BOLSA_OPERACION,
             SERVICIO_BOLSA_VOLUMEN,
             FECHA_VENCIMIENTO,
             PERIODO,
             TASA,
             CANTIDAD_TOTAL_OPERACION,
             CANTIDAD_FRACCION,
             VOLUMEN_NETO_FRACCION,
             PRECIO,
             FECHA_EMISION,
             FECHA_OPERACION,
             PORCENTAJE_COMISION,
             VALOR_COMISION,
             OVE_ENA_MNEMONICO,
             ENA_DESCRIPCION,
             EMI_DESCRIPCION,
             CRUZCON,
             COM_VENDEDOR,
             LOCALIZACION,
             VIGENCIA_OP,
             CCC_CLI_PER_TID_CODIGO,
             CCC_CLI_PER_NUM_IDEN,
             CCC_NUMERO_CUENTA,
             CCC_NOMBRE_CUENTA,
             PER_INICIALES_USUARIO,
             PER_SUC_CODIGO,
             ORDEN,
             COR_ORDEN,
             TIPO_OPERACION_TO,
             FECHA_VALORACION,
             VALORACION_TM_1,
             IVA,
             RETEFTE,
             OVE_MONEDA_COMPENSACION,
             OVE_TIPO_MEC,
             CPR_MNEMONICO,
             CPR_DESCRIPCION,
             CCC_CUENTA_APT,
             VOLUMEN_NETO_INCLUIDO_IVA,
             HORA_GRABACION_NEGOCIO,
             ORIGEN_OPERACION,
             CODIGO_OPERADOR_COMPRADOR,
             CODIGO_OPERADOR_VENDEDOR,
             PLAZO_VENCIMIENTO,
             PORCENTAJE_PRECIO,
             PRCNTJE_TSA_ADJDCCION,
             PLAZO_EMISION,
             TASA_REFERENCIA,
             BASE_CALCULO_INTERES,
             REINVERSION,
             IDENTIFICACION_REMATE,
             PLAZO_LIQ,
             MOD_LIQUIDACION,
             FIJA_PRECIO_ACCIONES,
             PERIODO_EXDIVIDENDO,
             IND_ORIGEN,
             REF_SWAP,
             PORCENTAJE_TASA_REPO,
             PLAZO_REPO,
             VALOR_CAPTACION_REPO,
             VOLUMEN_RECOMPRA_REPO,
             SUCURSAL_CUMPLIMIENTO,
             VOLUMEN_FRACCION,
             PRCNTJE_PRCIO_NTO_FRCCION,
             NMRO_IMPRSNES_LQUDCION,
             CODIGO_CONTACTO_COMERCIAL,
             NUMERO_FRACCIONES,
             REFERENCIA_COMISIONISTA,
             TIPO_IDENTIFICACION_1,
             NIT_1,
             IDNTFCCION_PTRMNIO_AUT_1,
             TIPO_IDENTIFICACION_2,
             NIT_2,
             IDNTFCCION_PTRMNIO_AUT_2,
             TIPO_IDENTIFICACION_3,
             NIT_3,
             IDNTFCCION_PTRMNIO_AUT_3,
             IND_OPERACION,
             BASE_RETENCION_COBRO,
             PORCENTAJE_RET_COBRO,
             BASE_RETENCION_TRASLADO,
             PORCENTAJE_RET_TRASLADO,
             PORCENTAJE_IVA_COMISION,
             VALOR_IVA_COMISION,
             TRASLADA_SERV_A_CLIENTE,
             OP_CON_RETEFTE_ENAJENA,
             FECHA_CONSTA_VENTA,
             VALOR_CONSTA_VENTA,
             GENERA_CONSTA_COMPRADOR,
             CONTRAPAGO_OPERACION,
             ENVIA_RTEFTE,
             PROMOTOR_LIQUIDEZ,
             TIPO_USO_TASA,
             NEMO_LARGO,
             VALOR_EXTEMPO,
             POSICION_EXTEMPO,
             PAQUETE_BVC,
             REIV_PRIM,
             CTA_MARGEN,
             CANAL_ORIGEN,
             MEDIO_RECEPCION,
             COMERCIAL_ORDENA,
             ISIN,
             FECHA_RECEPCION,
             HORA_RECEPCION,
             DETALLE_MEDIO_RECEPCION,
             OBSERVACIONES,
             SEGMENTO,
             FECHA_REGISTRO,
             PERFIL_RIESGO,
             TIPO_IDENTIFICACION_4,
             NIT_4,
             INSTRUCCION_IMPARTIDA_POR,
             CALIFICA_RIESGO
        FROM GL_DATOS_ROPEFE;
    C_ROPEFE C_DATOS_GL%ROWTYPE;

    CURSOR C_DATOS_ROPEFE IS
      SELECT LIC_INDICADOR_SWAP,
             LIC_INDICADOR_CARRUSEL,
             LIC_TIPO_OFERTA,
             OVE_CNE_MNEMONICO,
             LIC_CLASE_TRANSACCION,
             LIC_VALORACION_TM
        FROM LIQUIDACIONES_COMERCIAL, ORDENES_VENTA
       WHERE LIC_OVE_CONSECUTIVO = OVE_CONSECUTIVO
         AND LIC_BOL_MNEMONICO = C_ROPEFE.BOL_MNEMONICO
         AND LIC_NUMERO_OPERACION = C_ROPEFE.NUMERO_OPERACION
         AND LIC_NUMERO_FRACCION = C_ROPEFE.NUMERO_FRACCION
         AND LIC_TIPO_OPERACION = C_ROPEFE.TIPO_OPERACION
      UNION
      SELECT LIC_INDICADOR_SWAP,
             LIC_INDICADOR_CARRUSEL,
             LIC_TIPO_OFERTA,
             OCO_CNE_MNEMONICO,
             LIC_CLASE_TRANSACCION,
             LIC_VALORACION_TM
        FROM LIQUIDACIONES_COMERCIAL, ORDENES_COMPRA
       WHERE LIC_OCO_CONSECUTIVO = OCO_CONSECUTIVO
         AND LIC_BOL_MNEMONICO = C_ROPEFE.BOL_MNEMONICO
         AND LIC_NUMERO_OPERACION = C_ROPEFE.NUMERO_OPERACION
         AND LIC_NUMERO_FRACCION = C_ROPEFE.NUMERO_FRACCION
         AND LIC_TIPO_OPERACION = C_ROPEFE.TIPO_OPERACION;
    C_DAT_RO C_DATOS_ROPEFE%ROWTYPE;

  BEGIN
    DELETE FROM GL_DATOS_ROPEFE;
    COMMIT;

    P_HINT      := '/*+ INDEX (LIC LIC_FECHA_OPERACION_I) */';
    P_CONDICION := ' AND LIC_FECHA_OPERACION >= ''' ||
                   TO_CHAR(TRUNC(SYSDATE - 1), 'DD-MON-YYYY') || '''' ||
                   ' AND LIC_FECHA_OPERACION  < ''' ||
                   TO_CHAR(TRUNC(SYSDATE), 'DD-MON-YYYY') || ''' ';

    P_CONDICION_ESPECULATIVA := ' ';

    P_OPERACIONES.P_CALCULA_DATOS(P_HINT                   => P_HINT,
                                  P_EMISOR                 => '%',
                                  P_ESPECIE                => '%',
                                  P_CONDICION_ESPECULATIVA => P_CONDICION_ESPECULATIVA,
                                  P_CONDICION              => P_CONDICION,
                                  P_MERCADO                => '%',
                                  P_BOLSA                  => '%');

    SELECT COUNT(1) INTO CONT FROM GL_DATOS_ROPEFE;

    OPEN C_DATOS_GL;
    FETCH C_DATOS_GL
      INTO C_ROPEFE;
    WHILE C_DATOS_GL%FOUND LOOP
      OPEN C_DATOS_ROPEFE;
      FETCH C_DATOS_ROPEFE
        INTO C_DAT_RO;
      CLOSE C_DATOS_ROPEFE;

      V_TO := VALOR_TIPO_OPERACION(C_DAT_RO.LIC_INDICADOR_SWAP,
                                   C_DAT_RO.LIC_INDICADOR_CARRUSEL,
                                   C_DAT_RO.LIC_TIPO_OFERTA,
                                   C_DAT_RO.OVE_CNE_MNEMONICO,
                                   C_ROPEFE.FECHA_OPERACION,
                                   C_ROPEFE.FECHA_CUMPLIMIENTO,
                                   C_DAT_RO.LIC_CLASE_TRANSACCION);

      V_VALOR_TM := VALORACION_PESOS(C_ROPEFE.OVE_ENA_MNEMONICO,
                                     C_ROPEFE.FECHA_VALORACION,
                                     C_DAT_RO.LIC_VALORACION_TM);

      V_IVA := IVA(C_ROPEFE.TIPO_OPERACION,
                   C_ROPEFE.NUMERO_OPERACION,
                   C_ROPEFE.NUMERO_FRACCION,
                   C_ROPEFE.BOL_MNEMONICO);

      V_RETEFTE := RETEFTE(C_ROPEFE.TIPO_OPERACION,
                           C_ROPEFE.NUMERO_OPERACION,
                           C_ROPEFE.NUMERO_FRACCION,
                           C_ROPEFE.BOL_MNEMONICO);

      V_PAQUETE := PAQUETE(C_ROPEFE.TIPO_OPERACION,
                           C_ROPEFE.NUMERO_OPERACION,
                           C_ROPEFE.NUMERO_FRACCION,
                           C_ROPEFE.BOL_MNEMONICO);

      V_ISIN := ISIN(C_ROPEFE.OVE_ENA_MNEMONICO);

      UPDATE GL_DATOS_ROPEFE
         SET TIPO_OPERACION_TO = V_TO,
             VALORACION_TM_1   = V_VALOR_TM,
             IVA               = V_IVA,
             RETEFTE           = V_RETEFTE,
             PAQUETE_BVC       = V_PAQUETE,
             ISIN              = V_ISIN
       WHERE BOL_MNEMONICO = C_ROPEFE.BOL_MNEMONICO
         AND NUMERO_OPERACION = C_ROPEFE.NUMERO_OPERACION
         AND NUMERO_FRACCION = C_ROPEFE.NUMERO_FRACCION
         AND TIPO_OPERACION = C_ROPEFE.TIPO_OPERACION;

      COMMIT;

      FETCH C_DATOS_GL
        INTO C_ROPEFE;
    END LOOP;
    CLOSE C_DATOS_GL;

  END GENERA_OPEBOL_DIA;

  PROCEDURE GENERA_OPEBOL_CUMPLIR IS

    P_HINT                   VARCHAR2(100);
    P_CONDICION              VARCHAR2(500);
    P_CLIENTE                VARCHAR2(1) := '%';
    P_CONDICION_ESPECULATIVA VARCHAR2(500);
    CONT                     NUMBER;
    V_TO                     VARCHAR2(100);
    V_VALOR_TM               NUMBER;
    V_IVA                    NUMBER;
    V_RETEFTE                NUMBER;
    V_PAQUETE                VARCHAR2(100);
    V_ISIN                   VARCHAR2(15);

    CURSOR C_DATOS_GL IS
      SELECT BOL_MNEMONICO,
             NUMERO_OPERACION,
             NUMERO_FRACCION,
             TIPO_OPERACION,
             ELI_MNEMONICO,
             MERCADO,
             FECHA_CUMPLIMIENTO,
             SERVICIO_BOLSA_OPERACION,
             SERVICIO_BOLSA_VOLUMEN,
             FECHA_VENCIMIENTO,
             PERIODO,
             TASA,
             CANTIDAD_TOTAL_OPERACION,
             CANTIDAD_FRACCION,
             VOLUMEN_NETO_FRACCION,
             PRECIO,
             FECHA_EMISION,
             FECHA_OPERACION,
             PORCENTAJE_COMISION,
             VALOR_COMISION,
             OVE_ENA_MNEMONICO,
             ENA_DESCRIPCION,
             EMI_DESCRIPCION,
             CRUZCON,
             COM_VENDEDOR,
             LOCALIZACION,
             VIGENCIA_OP,
             CCC_CLI_PER_TID_CODIGO,
             CCC_CLI_PER_NUM_IDEN,
             CCC_NUMERO_CUENTA,
             CCC_NOMBRE_CUENTA,
             PER_INICIALES_USUARIO,
             PER_SUC_CODIGO,
             ORDEN,
             COR_ORDEN,
             TIPO_OPERACION_TO,
             FECHA_VALORACION,
             VALORACION_TM_1,
             IVA,
             RETEFTE,
             OVE_MONEDA_COMPENSACION,
             OVE_TIPO_MEC,
             CPR_MNEMONICO,
             CPR_DESCRIPCION,
             CCC_CUENTA_APT,
             VOLUMEN_NETO_INCLUIDO_IVA,
             HORA_GRABACION_NEGOCIO,
             ORIGEN_OPERACION,
             CODIGO_OPERADOR_COMPRADOR,
             CODIGO_OPERADOR_VENDEDOR,
             PLAZO_VENCIMIENTO,
             PORCENTAJE_PRECIO,
             PRCNTJE_TSA_ADJDCCION,
             PLAZO_EMISION,
             TASA_REFERENCIA,
             BASE_CALCULO_INTERES,
             REINVERSION,
             IDENTIFICACION_REMATE,
             PLAZO_LIQ,
             MOD_LIQUIDACION,
             FIJA_PRECIO_ACCIONES,
             PERIODO_EXDIVIDENDO,
             IND_ORIGEN,
             REF_SWAP,
             PORCENTAJE_TASA_REPO,
             PLAZO_REPO,
             VALOR_CAPTACION_REPO,
             VOLUMEN_RECOMPRA_REPO,
             SUCURSAL_CUMPLIMIENTO,
             VOLUMEN_FRACCION,
             PRCNTJE_PRCIO_NTO_FRCCION,
             NMRO_IMPRSNES_LQUDCION,
             CODIGO_CONTACTO_COMERCIAL,
             NUMERO_FRACCIONES,
             REFERENCIA_COMISIONISTA,
             TIPO_IDENTIFICACION_1,
             NIT_1,
             IDNTFCCION_PTRMNIO_AUT_1,
             TIPO_IDENTIFICACION_2,
             NIT_2,
             IDNTFCCION_PTRMNIO_AUT_2,
             TIPO_IDENTIFICACION_3,
             NIT_3,
             IDNTFCCION_PTRMNIO_AUT_3,
             IND_OPERACION,
             BASE_RETENCION_COBRO,
             PORCENTAJE_RET_COBRO,
             BASE_RETENCION_TRASLADO,
             PORCENTAJE_RET_TRASLADO,
             PORCENTAJE_IVA_COMISION,
             VALOR_IVA_COMISION,
             TRASLADA_SERV_A_CLIENTE,
             OP_CON_RETEFTE_ENAJENA,
             FECHA_CONSTA_VENTA,
             VALOR_CONSTA_VENTA,
             GENERA_CONSTA_COMPRADOR,
             CONTRAPAGO_OPERACION,
             ENVIA_RTEFTE,
             PROMOTOR_LIQUIDEZ,
             TIPO_USO_TASA,
             NEMO_LARGO,
             VALOR_EXTEMPO,
             POSICION_EXTEMPO,
             PAQUETE_BVC,
             REIV_PRIM,
             CTA_MARGEN,
             CANAL_ORIGEN,
             MEDIO_RECEPCION,
             COMERCIAL_ORDENA,
             ISIN,
             FECHA_RECEPCION,
             HORA_RECEPCION,
             DETALLE_MEDIO_RECEPCION,
             OBSERVACIONES,
             SEGMENTO,
             FECHA_REGISTRO,
             PERFIL_RIESGO,
             TIPO_IDENTIFICACION_4,
             NIT_4,
             INSTRUCCION_IMPARTIDA_POR,
             CALIFICA_RIESGO
        FROM GL_DATOS_ROPEFE;
    C_ROPEFE C_DATOS_GL%ROWTYPE;

    CURSOR C_DATOS_ROPEFE IS
      SELECT LIC_INDICADOR_SWAP,
             LIC_INDICADOR_CARRUSEL,
             LIC_TIPO_OFERTA,
             OVE_CNE_MNEMONICO,
             LIC_CLASE_TRANSACCION,
             LIC_VALORACION_TM
        FROM LIQUIDACIONES_COMERCIAL, ORDENES_VENTA
       WHERE LIC_OVE_CONSECUTIVO = OVE_CONSECUTIVO
         AND LIC_BOL_MNEMONICO = C_ROPEFE.BOL_MNEMONICO
         AND LIC_NUMERO_OPERACION = C_ROPEFE.NUMERO_OPERACION
         AND LIC_NUMERO_FRACCION = C_ROPEFE.NUMERO_FRACCION
         AND LIC_TIPO_OPERACION = C_ROPEFE.TIPO_OPERACION
      UNION
      SELECT LIC_INDICADOR_SWAP,
             LIC_INDICADOR_CARRUSEL,
             LIC_TIPO_OFERTA,
             OCO_CNE_MNEMONICO,
             LIC_CLASE_TRANSACCION,
             LIC_VALORACION_TM
        FROM LIQUIDACIONES_COMERCIAL, ORDENES_COMPRA
       WHERE LIC_OCO_CONSECUTIVO = OCO_CONSECUTIVO
         AND LIC_BOL_MNEMONICO = C_ROPEFE.BOL_MNEMONICO
         AND LIC_NUMERO_OPERACION = C_ROPEFE.NUMERO_OPERACION
         AND LIC_NUMERO_FRACCION = C_ROPEFE.NUMERO_FRACCION
         AND LIC_TIPO_OPERACION = C_ROPEFE.TIPO_OPERACION;
    C_DAT_RO C_DATOS_ROPEFE%ROWTYPE;

  BEGIN
    DELETE FROM GL_DATOS_ROPEFE;
    COMMIT;

    P_HINT      := '/*+ INDEX (LIC LIC_CUM_I) */';
    P_CONDICION := ' AND (LIC_FECHA_PACTO_CUMPLIMIENTO IS NULL AND ' ||
                   '       LIC_FECHA_CUMPLIMIENTO >= ''' ||
                   TO_CHAR(TRUNC(SYSDATE - 1), 'DD-MON-YYYY') || '''' || ')';

    P_CONDICION_ESPECULATIVA := ' ';

    P_OPERACIONES.P_CALCULA_DATOS(P_HINT                   => P_HINT,
                                  P_EMISOR                 => '%',
                                  P_ESPECIE                => '%',
                                  P_CONDICION_ESPECULATIVA => P_CONDICION_ESPECULATIVA,
                                  P_CONDICION              => P_CONDICION,
                                  P_MERCADO                => '%',
                                  P_BOLSA                  => '%');

    SELECT COUNT(1) INTO CONT FROM GL_DATOS_ROPEFE;

    OPEN C_DATOS_GL;
    FETCH C_DATOS_GL
      INTO C_ROPEFE;
    WHILE C_DATOS_GL%FOUND LOOP
      OPEN C_DATOS_ROPEFE;
      FETCH C_DATOS_ROPEFE
        INTO C_DAT_RO;
      CLOSE C_DATOS_ROPEFE;

      V_TO := VALOR_TIPO_OPERACION(C_DAT_RO.LIC_INDICADOR_SWAP,
                                   C_DAT_RO.LIC_INDICADOR_CARRUSEL,
                                   C_DAT_RO.LIC_TIPO_OFERTA,
                                   C_DAT_RO.OVE_CNE_MNEMONICO,
                                   C_ROPEFE.FECHA_OPERACION,
                                   C_ROPEFE.FECHA_CUMPLIMIENTO,
                                   C_DAT_RO.LIC_CLASE_TRANSACCION);

      V_VALOR_TM := VALORACION_PESOS(C_ROPEFE.OVE_ENA_MNEMONICO,
                                     C_ROPEFE.FECHA_VALORACION,
                                     C_DAT_RO.LIC_VALORACION_TM);

      V_IVA := IVA(C_ROPEFE.TIPO_OPERACION,
                   C_ROPEFE.NUMERO_OPERACION,
                   C_ROPEFE.NUMERO_FRACCION,
                   C_ROPEFE.BOL_MNEMONICO);

      V_RETEFTE := RETEFTE(C_ROPEFE.TIPO_OPERACION,
                           C_ROPEFE.NUMERO_OPERACION,
                           C_ROPEFE.NUMERO_FRACCION,
                           C_ROPEFE.BOL_MNEMONICO);

      V_PAQUETE := PAQUETE(C_ROPEFE.TIPO_OPERACION,
                           C_ROPEFE.NUMERO_OPERACION,
                           C_ROPEFE.NUMERO_FRACCION,
                           C_ROPEFE.BOL_MNEMONICO);

      V_ISIN := ISIN(C_ROPEFE.OVE_ENA_MNEMONICO);

      UPDATE GL_DATOS_ROPEFE
         SET TIPO_OPERACION_TO = V_TO,
             VALORACION_TM_1   = V_VALOR_TM,
             IVA               = V_IVA,
             RETEFTE           = V_RETEFTE,
             PAQUETE_BVC       = V_PAQUETE,
             ISIN              = V_ISIN
       WHERE BOL_MNEMONICO = C_ROPEFE.BOL_MNEMONICO
         AND NUMERO_OPERACION = C_ROPEFE.NUMERO_OPERACION
         AND NUMERO_FRACCION = C_ROPEFE.NUMERO_FRACCION
         AND TIPO_OPERACION = C_ROPEFE.TIPO_OPERACION;

      COMMIT;

      FETCH C_DATOS_GL
        INTO C_ROPEFE;
    END LOOP;
    CLOSE C_DATOS_GL;

  END GENERA_OPEBOL_CUMPLIR;

  PROCEDURE P_EJECUTA_OPEBOL IS

    NOMBRE_ARCHIVO     VARCHAR2(100);
    P_FECHA2           VARCHAR2(20);
    TIPO_CLIENTE       VARCHAR2(20);
    TIP_ARCHIVO        UTL_FILE.FILE_TYPE;
    ARCHIVO_PORTAFOLIO VARCHAR2(100);
    V_RUTA             VARCHAR2(100);
    P_CODIGO           VARCHAR2(200);
    P_RESPUESTA        VARCHAR2(200);
    P_NUM_INI          NUMBER;
    P_NUM_FIN          NUMBER;
  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_GENERA_REPORTES_RIESGOS - P_EJECUTA_OPEBOL',
                                                      'INI');

    GENERA_OPEBOL_DIA;
    V_RUTA         := '\\nas.corredor.local\Riesgo\CONFIDENCIAL\Reportes Excel Coeasy\';
    NOMBRE_ARCHIVO := 'OPERACIONES_DIA_' ||
                      TO_CHAR(SYSDATE - 1, 'DDMMYYYY_hh24mmss');

    --LLAMADO AL PROGRAMA QUE CREA EL XSLX
    P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => V_RUTA,
                                   P_NOMBRE_ARCHIVO => NOMBRE_ARCHIVO,
                                   P_QUERY          => 'SELECT BOL_MNEMONICO ' ||
                                                       '     , NUMERO_OPERACION ' ||
                                                       '     , NUMERO_FRACCION ' ||
                                                       '     , TIPO_OPERACION ' ||
                                                       '     , ELI_MNEMONICO ' ||
                                                       '     , MERCADO ' ||
                                                       '     , FECHA_CUMPLIMIENTO ' ||
                                                       '     , SERVICIO_BOLSA_OPERACION ' ||
                                                       '     , SERVICIO_BOLSA_VOLUMEN ' ||
                                                       '     , FECHA_VENCIMIENTO ' ||
