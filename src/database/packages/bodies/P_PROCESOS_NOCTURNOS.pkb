    V_FECHAN      VARCHAR2(20);

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN
    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_RMOVBA_CE_A2',
