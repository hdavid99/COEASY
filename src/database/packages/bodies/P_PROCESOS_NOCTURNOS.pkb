  PROCEDURE PR_REPORTE_REXCLS1_PP(P_USERID IN VARCHAR2) IS

    VAR            VARCHAR2(2000);
    V_FECHA_INICIO VARCHAR2(20);
    V_FECHA_CORTE  VARCHAR2(20);
    V_FECHAN       VARCHAR2(20);
    V_QUE_CLIENTE  VARCHAR2(2000);

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_REXCLS1_PP',
                                                      'INI');

    select to_char(trunc(sysdate, 'MM'),
                   'DD-MON-YYYY',
                   'nls_date_language = ''LATIN AMERICAN SPANISH''')
      INTO V_FECHA_INICIO
      from dual;
    select to_char(trunc(sysdate),
                   'DD-MON-YYYY',
                   'nls_date_language = ''LATIN AMERICAN SPANISH''')
      INTO V_FECHA_CORTE
      from dual;

    select to_char(trunc(sysdate - 1), 'DDMMYYYY') INTO V_FECHAN from dual;
    V_QUE_CLIENTE := ' AND CCC_CLI_PER_NUM_IDEN = ''860079174'' ';

    /*P_MAIL.ENVIO_MAIL_ERROR('Inicio genera reporte REXCLS1 ',
    '<br>'||'Fecha consultada del reporte: '||V_FECHA||,
    DESTINATARIOS); */

    P_TOOLS.PR_CREAR_REPORTE(P_REPORT     => 'REXCLS1',
                             P_USERID     => P_USERID,
                             P_FORMATO    => 'TXT',
                             P_PARAMETROS => '+FECHA_DESDE=' ||
                                             V_FECHA_INICIO ||
                                             '+FECHA_HASTA=' ||
                                             V_FECHA_CORTE ||
                                             '+QUE_CLIENTE=' ||
                                             V_QUE_CLIENTE,
                             P_ARCHIVO    => '/apps/rep_nocturnos/diarios/REXCLS1_PP_' ||
                                             V_FECHAN);

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_REXCLS1_PP',
                                                      'FIN');

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PR_REPORTE_REXCLS1_PP',
                              SUBSTR(SQLERRM, 1, 80),
                              'procesosnocturnos@corredores.com');
  END PR_REPORTE_REXCLS1_PP;

