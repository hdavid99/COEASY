               TRUNC(SYSDATE - 1),
               'USD',
               A.LIT_IDENTIFICACION_I,
               A.LIT_COMPANIA_I,
               LIT_P3_18
          FROM PROD.ARCHIVO_LIMITE_CONTRAPARTE A
         WHERE LIT_FECHA_CARGUE = VALF;
      COMMIT;

    ELSIF V_CAMPO1 = 'LIT_P3_19' THEN
      SELECT MAX(LIT_FECHA_CARGUE)
        INTO VALF
