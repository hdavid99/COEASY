                                                       '     , CCC_CLI_PER_NUM_IDEN ' ||
                                                       '     , CCC_NUMERO_CUENTA ' ||
                                                       '     , CCC_NOMBRE_CUENTA ' ||
                                                       '     , PER_INICIALES_USUARIO ' ||
                                                       '     , PER_SUC_CODIGO ' ||
                                                       '     , ORDEN ' ||
                                                       '     , COR_ORDEN ' ||
                                                       '     , TIPO_OPERACION_TO ' ||
                                                       '     , FECHA_VALORACION ' ||
                                                       '     , VALORACION_TM_1 ' ||
                                                       '     , IVA ' ||
                                                       '     , RETEFTE ' ||
                                                       '     , OVE_MONEDA_COMPENSACION ' ||
                                                       '     , OVE_TIPO_MEC ' ||
                                                       '     , CPR_MNEMONICO ' ||
                                                       '     , CPR_DESCRIPCION ' ||
                                                       '     , CCC_CUENTA_APT ' ||
                                                       '     , VOLUMEN_NETO_INCLUIDO_IVA ' ||
