  /************************************************************************************************
  ***  Procedimiento  PR_DISTRIBUYE_PP_CCIAL para:                                               **
  ***  1. Distribuir de forma correcta en operaciones diarias de Posicion Propia                 **
  ***  se debe correr despues de distribucion_clientes_pp y distribucion_clientes_rfija.sql      **
  ***  se llama desde el proceso nocturno operaciones_diarias.sql                                **
  ********************************************************************************************** */
  PROCEDURE PR_DISTRIBUYE_PP_CCIAL(P_FECHA IN DATE,P_TX IN NUMBER DEFAULT NULL) IS

    CURSOR C_OPC IS
      SELECT OPC_CONSECUTIVO, OPC_PRF_FON_CODIGO, OPC_PRF_CONSECUTIVO
        FROM OPERACIONES_DIARIAS
       WHERE OPC_FECHA >= TRUNC(P_FECHA)
         AND OPC_FECHA < TRUNC(P_FECHA + 1)
         AND OPC_PRO_MNEMONICO = 'PP'
         AND OPC_PRF_CONSECUTIVO IS NOT NULL;

    R_OPC C_OPC%ROWTYPE;

    CURSOR C_DIC(P_OPC NUMBER) IS
      SELECT DIC_PER_NUM_IDEN,
             DIC_PER_TID_CODIGO,
             DIC_CCC_NUMERO_CUENTA,
             DIC_PARTICIPACION_ESTIMADA
        FROM DISTRIBUCION_CLIENTES
       WHERE DIC_OPC_CONSECUTIVO = P_OPC
         AND DIC_PARTICIPACION_ESTIMADA != 0;
    R_DIC C_DIC%ROWTYPE;

    CURSOR C_REGLAS(PRODUCTO VARCHAR2) IS
      SELECT RAP_PER_NUM_IDEN_CONT, RAP_PER_TID_CODIGO_CONT, CPR_MNEMONICO
        FROM REGLAS_ASIGNACION_PRODUCTOS,
             PERSONAS                    PER,
             CENTROS_PRODUCCION          CC,
             PERSONAS_CENTROS_PRODUCCION PCP
       WHERE RAP_PRO_MNEMONICO = PRODUCTO
         AND PER.PER_NUM_IDEN = PCP.PCP_PER_NUM_IDEN
         AND PER.PER_TID_CODIGO = PCP.PCP_PER_TID_CODIGO
         AND PCP.PCP_CPR_MNEMONICO = CC.CPR_MNEMONICO
         AND PCP.PCP_PRINCIPAL = 'S'
         AND RAP_PER_NUM_IDEN_CONT = PER.PER_NUM_IDEN
         AND RAP_PER_TID_CODIGO_CONT = PER.PER_TID_CODIGO;

    R_REGLAS C_REGLAS%ROWTYPE;

    CURSOR C_COM(P_NID VARCHAR2, P_TID VARCHAR2, P_CTA NUMBER) IS
      SELECT CCC.CCC_PER_NUM_IDEN, CCC.CCC_PER_TID_CODIGO, CPR_MNEMONICO
        FROM CUENTAS_CLIENTE_CORREDORES  CCC,
             PERSONAS                    PER,
             CENTROS_PRODUCCION          CC,
             PERSONAS_CENTROS_PRODUCCION PCP
       WHERE CCC.CCC_PER_NUM_IDEN = PER.PER_NUM_IDEN
         AND CCC.CCC_PER_TID_CODIGO = PER.PER_TID_CODIGO
         AND PER.PER_NUM_IDEN = PCP.PCP_PER_NUM_IDEN
         AND PER.PER_TID_CODIGO = PCP.PCP_PER_TID_CODIGO
         AND PCP.PCP_CPR_MNEMONICO = CC.CPR_MNEMONICO
         AND PCP.PCP_PRINCIPAL = 'S'
         AND CCC_CLI_PER_NUM_IDEN = P_NID
         AND CCC_CLI_PER_TID_CODIGO = P_TID
         AND CCC_NUMERO_CUENTA = P_CTA;
    R_COM C_COM%ROWTYPE;

    CURSOR C_LIC(P_PRF_FON VARCHAR2, P_PRF_CONS NUMBER) IS
      SELECT LIC_BOL_MNEMONICO,
             LIC_NUMERO_OPERACION,
             LIC_NUMERO_FRACCION,
             LIC_TIPO_OPERACION,
             LIC_VOLUMEN_NETO_FRACCION,
             CCC_PER_NUM_IDEN,
             CCC_PER_TID_CODIGO,
             CPR_MNEMONICO
        FROM PREORDENES_COMPRA,
             LIQUIDACIONES_COMERCIAL,
             ORDENES_COMPRA,
             CUENTAS_CLIENTE_CORREDORES,
             PERSONAS                    PER,
             CENTROS_PRODUCCION          CC,
             PERSONAS_CENTROS_PRODUCCION PCP
       WHERE PRC_BOL_MNEMONICO = LIC_BOL_MNEMONICO
         AND PRC_NUMERO_OPERACION = LIC_NUMERO_OPERACION
         AND PRC_LIC_NUMERO_FRACCION = LIC_NUMERO_FRACCION
         AND PRC_LIC_TIPO_OPERACION = LIC_TIPO_OPERACION
         AND LIC_BOL_MNEMONICO = OCO_BOL_MNEMONICO
         AND LIC_OCO_COC_CTO_MNEMONICO = OCO_COC_CTO_MNEMONICO
         AND LIC_OCO_CONSECUTIVO = OCO_CONSECUTIVO
         AND OCO_CCC_CLI_PER_NUM_IDEN = CCC_CLI_PER_NUM_IDEN
         AND OCO_CCC_CLI_PER_TID_CODIGO = CCC_CLI_PER_TID_CODIGO
         AND OCO_CCC_NUMERO_CUENTA = CCC_NUMERO_CUENTA
         AND CCC_PER_NUM_IDEN = PER_NUM_IDEN
         AND CCC_PER_TID_CODIGO = PER_TID_CODIGO
         AND PER_NUM_IDEN = PCP_PER_NUM_IDEN
         AND PER_TID_CODIGO = PCP_PER_TID_CODIGO
         AND PCP_CPR_MNEMONICO = CPR_MNEMONICO
         AND PCP_PRINCIPAL = 'S'
         AND PRC_PRF_FON_CODIGO = P_PRF_FON
         AND PRC_PRF_CONSECUTIVO = P_PRF_CONS
      UNION
      SELECT LIC_BOL_MNEMONICO,
             LIC_NUMERO_OPERACION,
             LIC_NUMERO_FRACCION,
             LIC_TIPO_OPERACION,
             LIC_VOLUMEN_NETO_FRACCION,
             CCC_PER_NUM_IDEN,
             CCC_PER_TID_CODIGO,
             CPR_MNEMONICO
        FROM PREORDENES_VENTA,
             LIQUIDACIONES_COMERCIAL,
             ORDENES_VENTA,
             CUENTAS_CLIENTE_CORREDORES,
             PERSONAS                    PER,
             CENTROS_PRODUCCION          CC,
             PERSONAS_CENTROS_PRODUCCION PCP
       WHERE PRV_BOL_MNEMONICO = LIC_BOL_MNEMONICO
         AND PRV_NUMERO_OPERACION = LIC_NUMERO_OPERACION
         AND PRV_LIC_NUMERO_FRACCION = LIC_NUMERO_FRACCION
         AND PRV_LIC_TIPO_OPERACION = LIC_TIPO_OPERACION
         AND LIC_BOL_MNEMONICO = OVE_BOL_MNEMONICO
         AND LIC_OVE_COC_CTO_MNEMONICO = OVE_COC_CTO_MNEMONICO
         AND LIC_OVE_CONSECUTIVO = OVE_CONSECUTIVO
         AND OVE_CCC_CLI_PER_NUM_IDEN = CCC_CLI_PER_NUM_IDEN
         AND OVE_CCC_CLI_PER_TID_CODIGO = CCC_CLI_PER_TID_CODIGO
         AND OVE_CCC_NUMERO_CUENTA = CCC_NUMERO_CUENTA
         AND CCC_PER_NUM_IDEN = PER_NUM_IDEN
         AND CCC_PER_TID_CODIGO = PER_TID_CODIGO
         AND PER_NUM_IDEN = PCP_PER_NUM_IDEN
         AND PER_TID_CODIGO = PCP_PER_TID_CODIGO
         AND PCP_CPR_MNEMONICO = CPR_MNEMONICO
         AND PCP_PRINCIPAL = 'S'
         AND PRV_PRF_FON_CODIGO = P_PRF_FON
         AND PRV_PRF_CONSECUTIVO = P_PRF_CONS;
    R_LIC                   C_LIC%ROWTYPE;
    TOTAL_VOLUMEN           NUMBER;
    TOTAL_PARTICIPACION     NUMBER;
    TOTAL_PARTICIPACION_OTR NUMBER;
    CURSOR C_TOT_LIC IS
      SELECT PER_NUM_IDEN,
             PER_TID_CODIGO,
             CPR_MNEMONICO,
             SUM(PARTICIPACION_ESTIMADA) PARTICIPACION_ESTIMADA
        FROM GL_DISTRIBUCION_LIC
       GROUP BY PER_NUM_IDEN, PER_TID_CODIGO, CPR_MNEMONICO;
    R_TOT_LIC C_TOT_LIC%ROWTYPE;

    CURSOR C_DIST IS
      SELECT DOP_PER_NUM_IDEN,
             DOP_PER_TID_CODIGO,
             DOP_CPR_MNEMONICO,
             DOP_OPC_CONSECUTIVO,
             SUM(DOP_PARTICIPACION_ESTIMADA) DOP_PARTICIPACION_ESTIMADA
        FROM GL_DISTRIBUCION_OPC
       GROUP BY DOP_PER_NUM_IDEN,
                DOP_PER_TID_CODIGO,
                DOP_CPR_MNEMONICO,
                DOP_OPC_CONSECUTIVO
      HAVING SUM(DOP_PARTICIPACION_ESTIMADA) != 0;
    R_DIST C_DIST%ROWTYPE;

    CURSOR PARTICIPACION(FONDO VARCHAR2, CONS NUMBER) IS
      SELECT PAP_PER_NUM_IDEN,
             PAP_PER_TID_CODIGO,
             PAP_PORCENTAJE,
             PCP_CPR_MNEMONICO CPR_MNEMONICO
        FROM PARTICIPACIONES_PREORDENES,
             PERSONAS,
             PERSONAS_CENTROS_PRODUCCION A
       WHERE PAP_PER_NUM_IDEN = PER_NUM_IDEN(+)
         AND PAP_PER_TID_CODIGO = PER_TID_CODIGO(+)
         AND PER_NUM_IDEN = PCP_PER_NUM_IDEN(+)
         AND PER_TID_CODIGO = PCP_PER_TID_CODIGO(+)
         AND PAP_PRF_FON_CODIGO = FONDO
         AND PAP_PRF_CONSECUTIVO = CONS
         AND NVL(PAP_PORCENTAJE, 0) != 0
         AND PCP_PRINCIPAL = 'S';

    R_PART PARTICIPACION%ROWTYPE;

    NID_COR VARCHAR2(15);
    TID_COR VARCHAR2(3);
    CPR_COR NUMBER(5);

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;
    N_ID_PROCESO NUMBER;
    N_TX NUMBER;

  BEGIN

     --se asigna el consecutivo del proceso(tabla PARAMETRIZACION_PROCESOS)
      N_ID_PROCESO := P_TRAZA_CORE.FN_ID_PROCESO('P_PROCESOS_NOCTURNOS.PR_DISTRIBUYE_PP_CCIAL');

      --se Asigna consecutivo para la transaccion, si el proceso es el primero que se llama, reinicia el consecutivo
      N_TX := P_TRAZA_CORE.FN_TRAE_TX(P_TX);

      --Registra Traza
      P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                      'I',
                                      'Inicio proceso P_PROCESOS_NOCTURNOS.PR_DISTRIBUYE_PP_CCIAL. Fecha Proceso: ' ||
                                      TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss'),
                                      N_TX);

    OPEN C_OPC;
    FETCH C_OPC
      INTO R_OPC;
    WHILE C_OPC%FOUND LOOP
      TOTAL_PARTICIPACION     := 0;
      TOTAL_PARTICIPACION_OTR := 0;
      DELETE FROM DISTRIBUCION_OPERACIONES
       WHERE DOP_OPC_CONSECUTIVO = R_OPC.OPC_CONSECUTIVO;

      DELETE FROM GL_DISTRIBUCION_OPC;
      DELETE FROM GL_DISTRIBUCION_LIC;

      OPEN C_REGLAS('PP');
      FETCH C_REGLAS
        INTO R_REGLAS;
      IF C_REGLAS%FOUND THEN
        NID_COR := R_REGLAS.RAP_PER_NUM_IDEN_CONT;
        TID_COR := R_REGLAS.RAP_PER_TID_CODIGO_CONT;
        CPR_COR := R_REGLAS.CPR_MNEMONICO;
      END IF;
      CLOSE C_REGLAS;

      OPEN C_DIC(R_OPC.OPC_CONSECUTIVO);
      FETCH C_DIC
        INTO R_DIC;
      IF C_DIC%FOUND THEN
        WHILE C_DIC%FOUND LOOP
          IF R_DIC.DIC_PER_NUM_IDEN IN
             ('860079174', '860079074', '8600791743', '8600791749') AND
             R_DIC.DIC_CCC_NUMERO_CUENTA = 0 THEN
            INSERT INTO GL_DISTRIBUCION_OPC
              (DOP_PER_NUM_IDEN,
               DOP_PER_TID_CODIGO,
               DOP_CPR_MNEMONICO,
               DOP_OPC_CONSECUTIVO,
               DOP_PARTICIPACION_ESTIMADA)
            VALUES
              (NID_COR,
               TID_COR,
               CPR_COR,
               R_OPC.OPC_CONSECUTIVO,
               R_DIC.DIC_PARTICIPACION_ESTIMADA);
          ELSE
            OPEN C_COM(R_DIC.DIC_PER_NUM_IDEN,
                       R_DIC.DIC_PER_TID_CODIGO,
                       R_DIC.DIC_CCC_NUMERO_CUENTA);
            FETCH C_COM
              INTO R_COM;
            IF C_COM%FOUND THEN
              INSERT INTO GL_DISTRIBUCION_OPC
                (DOP_PER_NUM_IDEN,
                 DOP_PER_TID_CODIGO,
                 DOP_CPR_MNEMONICO,
                 DOP_OPC_CONSECUTIVO,
                 DOP_PARTICIPACION_ESTIMADA)
              VALUES
                (R_COM.CCC_PER_NUM_IDEN,
                 R_COM.CCC_PER_TID_CODIGO,
                 R_COM.CPR_MNEMONICO,
                 R_OPC.OPC_CONSECUTIVO,
                 R_DIC.DIC_PARTICIPACION_ESTIMADA);
            END IF;
            CLOSE C_COM;
          END IF;
          FETCH C_DIC
            INTO R_DIC;
        END LOOP;
        SELECT SUM(DOP_PARTICIPACION_ESTIMADA)
          INTO TOTAL_PARTICIPACION
          FROM GL_DISTRIBUCION_OPC
         WHERE DOP_PER_NUM_IDEN || DOP_PER_TID_CODIGO = NID_COR || TID_COR;
        TOTAL_PARTICIPACION := NVL(TOTAL_PARTICIPACION, 0);
        SELECT SUM(DOP_PARTICIPACION_ESTIMADA)
          INTO TOTAL_PARTICIPACION_OTR
          FROM GL_DISTRIBUCION_OPC
         WHERE DOP_PER_NUM_IDEN || DOP_PER_TID_CODIGO != NID_COR || TID_COR;
        TOTAL_PARTICIPACION_OTR := NVL(TOTAL_PARTICIPACION_OTR, 0);
        IF TOTAL_PARTICIPACION_OTR != 0 THEN
          UPDATE GL_DISTRIBUCION_OPC
             SET DOP_PARTICIPACION_ESTIMADA =
                 (DOP_PARTICIPACION_ESTIMADA / TOTAL_PARTICIPACION_OTR * 100) *
                 (100 - TOTAL_PARTICIPACION) / 100
           WHERE DOP_PER_NUM_IDEN || DOP_PER_TID_CODIGO !=
                 NID_COR || TID_COR;
        END IF;
      ELSE
        OPEN C_LIC(R_OPC.OPC_PRF_FON_CODIGO, R_OPC.OPC_PRF_CONSECUTIVO);
        FETCH C_LIC
          INTO R_LIC;
        IF C_LIC%FOUND THEN
          WHILE C_LIC%FOUND LOOP
            INSERT INTO GL_DISTRIBUCION_LIC
              (LIC_NUMERO_OPERACION,
               LIC_NUMERO_FRACCION,
               LIC_TIPO_OPERACION,
               LIC_BOL_MNEMONICO,
               LIC_VOLUMEN_NETO_FRACCION,
               PER_NUM_IDEN,
               PER_TID_CODIGO,
               CPR_MNEMONICO)
            VALUES
              (R_LIC.LIC_NUMERO_OPERACION,
               R_LIC.LIC_NUMERO_FRACCION,
               R_LIC.LIC_TIPO_OPERACION,
               R_LIC.LIC_BOL_MNEMONICO,
               R_LIC.LIC_VOLUMEN_NETO_FRACCION,
               R_LIC.CCC_PER_NUM_IDEN,
               R_LIC.CCC_PER_TID_CODIGO,
               R_LIC.CPR_MNEMONICO);
            FETCH C_LIC
              INTO R_LIC;
          END LOOP;
          CLOSE C_LIC;
          SELECT SUM(LIC_VOLUMEN_NETO_FRACCION)
            INTO TOTAL_VOLUMEN
            FROM GL_DISTRIBUCION_LIC;
          TOTAL_VOLUMEN := NVL(TOTAL_VOLUMEN, 0);
          IF TOTAL_VOLUMEN != 0 THEN
            UPDATE GL_DISTRIBUCION_LIC
               SET PARTICIPACION_ESTIMADA = LIC_VOLUMEN_NETO_FRACCION /
                                            TOTAL_VOLUMEN * 100;
          END IF;
          OPEN C_TOT_LIC;
          FETCH C_TOT_LIC
            INTO R_TOT_LIC;
          WHILE C_TOT_LIC%FOUND LOOP
            INSERT INTO GL_DISTRIBUCION_OPC
              (DOP_PER_NUM_IDEN,
               DOP_PER_TID_CODIGO,
               DOP_CPR_MNEMONICO,
               DOP_OPC_CONSECUTIVO,
               DOP_PARTICIPACION_ESTIMADA)
            VALUES
              (R_TOT_LIC.PER_NUM_IDEN,
               R_TOT_LIC.PER_TID_CODIGO,
               R_TOT_LIC.CPR_MNEMONICO,
               R_OPC.OPC_CONSECUTIVO,
               R_DIC.DIC_PARTICIPACION_ESTIMADA);
            FETCH C_TOT_LIC
              INTO R_TOT_LIC;
          END LOOP;
          CLOSE C_TOT_LIC;
        ELSE
          OPEN PARTICIPACION(R_OPC.OPC_PRF_FON_CODIGO,
                             R_OPC.OPC_PRF_CONSECUTIVO);
          FETCH PARTICIPACION
            INTO R_PART;
          WHILE PARTICIPACION%FOUND LOOP
            INSERT INTO GL_DISTRIBUCION_OPC
              (DOP_PER_NUM_IDEN,
               DOP_PER_TID_CODIGO,
               DOP_CPR_MNEMONICO,
               DOP_OPC_CONSECUTIVO,
               DOP_PARTICIPACION_ESTIMADA)
            VALUES
              (R_PART.PAP_PER_NUM_IDEN,
               R_PART.PAP_PER_TID_CODIGO,
               R_PART.CPR_MNEMONICO,
               R_OPC.OPC_CONSECUTIVO,
               R_PART.PAP_PORCENTAJE);
            FETCH PARTICIPACION
              INTO R_PART;
          END LOOP;
          CLOSE PARTICIPACION;
        END IF;
      END IF;
      CLOSE C_DIC;
      OPEN C_DIST;
      FETCH C_DIST
        INTO R_DIST;
      IF C_DIST%FOUND THEN
        WHILE C_DIST%FOUND LOOP
          INSERT INTO DISTRIBUCION_OPERACIONES
            (DOP_PER_NUM_IDEN,
             DOP_PER_TID_CODIGO,
             DOP_CPR_MNEMONICO,
             DOP_OPC_CONSECUTIVO,
             DOP_PARTICIPACION_ESTIMADA,
             DOP_CONFIRMADO)
          VALUES
            (R_DIST.DOP_PER_NUM_IDEN,
             R_DIST.DOP_PER_TID_CODIGO,
             R_DIST.DOP_CPR_MNEMONICO,
             R_OPC.OPC_CONSECUTIVO,
             R_DIST.DOP_PARTICIPACION_ESTIMADA,
             'N');

          FETCH C_DIST
            INTO R_DIST;
        END LOOP;
      ELSE
        OPEN PARTICIPACION(R_OPC.OPC_PRF_FON_CODIGO,
                           R_OPC.OPC_PRF_CONSECUTIVO);
        FETCH PARTICIPACION
          INTO R_PART;
        WHILE PARTICIPACION%FOUND LOOP
          INSERT INTO DISTRIBUCION_OPERACIONES
            (DOP_PER_NUM_IDEN,
             DOP_PER_TID_CODIGO,
             DOP_CPR_MNEMONICO,
             DOP_OPC_CONSECUTIVO,
             DOP_PARTICIPACION_ESTIMADA)
          VALUES
            (R_PART.PAP_PER_NUM_IDEN,
             R_PART.PAP_PER_TID_CODIGO,
             R_PART.CPR_MNEMONICO,
             R_OPC.OPC_CONSECUTIVO,
             R_PART.PAP_PORCENTAJE);
          FETCH PARTICIPACION
            INTO R_PART;
        END LOOP;
        CLOSE PARTICIPACION;
      END IF;
      CLOSE C_DIST;
      FETCH C_OPC
        INTO R_OPC;
    END LOOP;
    CLOSE C_OPC;

    COMMIT;

    -- Registrar traza FIN
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'F',
                                    'Fin P_PROCESOS_NOCTURNOS.PR_DISTRIBUYE_PP_CCIAL. Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss'),
                                    N_TX);                       
    COMMIT;                            
  END PR_DISTRIBUYE_PP_CCIAL;

  PROCEDURE PR_CRUCE_PAGOS_OPERACIONES IS
    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_CRUCE_PAGOS_OPERACIONES',
                                                      'INI');

    P_MAIL.ENVIO_MAIL_ERROR('Inicio proceso PR_CRUCE_PAGOS_OPERACIONES',
                            DESTINATARIOS);
    P_ADMON_SALDOS.PR_INVENTARIO_PAGOS;
    P_MAIL.ENVIO_MAIL_ERROR('Fin proceso PR_CRUCE_PAGOS_OPERACIONES',
                            DESTINATARIOS);
    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_CRUCE_PAGOS_OPERACIONES',
                                                      'FIN');
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PR_CRUCE_PAGOS_OPERACIONES' ||
                              SUBSTR(SQLERRM, 1, 80),
                              DESTINATARIOS);
  END PR_CRUCE_PAGOS_OPERACIONES;

  PROCEDURE PR_OPX_PORTAFOLIO IS
    CURSOR PERIODO IS
      SELECT CON_VALOR_CHAR FROM CONSTANTES WHERE CON_MNEMONICO = 'OP1';

    CURSOR C_NUM_CLI_OPX IS
      SELECT COUNT(*)
        FROM HISTORICO_PORTAFOLIO_OPX
       WHERE HPO_FECHA_OPX = SYSDATE;

    CURSOR C_CLI_OPX IS
      SELECT HPO_CLI_PER_NUM_IDEN   CLI_PER_NUM_IDEN,
             HPO_CLI_PER_TID_CODIGO CLI_PER_TID_CODIGO
        FROM HISTORICO_PORTAFOLIO_OPX
       WHERE HPO_FECHA_OPX = SYSDATE;
    R_CLI_OPX C_CLI_OPX%ROWTYPE;

    V_PERIODO         VARCHAR2(15);
    V_FECHA_OPX       DATE;
    V_FECHA_HOY       DATE;
    V_NUM_CLI_OPX     NUMBER;
    V_ARCHIVO_CLI_OPX VARCHAR2(2000);

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_OPX_PORTAFOLIO',
                                                      'INI');

    OPEN PERIODO;
    FETCH PERIODO
      INTO V_PERIODO;
    CLOSE PERIODO;
    V_NUM_CLI_OPX := 0;

    SELECT TRUNC(SYSDATE) INTO V_FECHA_HOY FROM DUAL;
    CASE V_PERIODO
      WHEN 'MENSUAL' THEN
        SELECT TRUNC(SYSDATE, 'MONTH') INTO V_FECHA_OPX FROM DUAL;
      WHEN 'SEMESTRAL' THEN
        SELECT TRUNC(ADD_MONTHS(SYSDATE,
                                (1 +
                                6 * ROUND(ROUND(EXTRACT(MONTH FROM(SYSDATE)) / 12,
                                                 1) - 0.1,
                                           0)) -
                                EXTRACT(MONTH FROM(SYSDATE))),
                     'Month')
          INTO V_FECHA_OPX
          FROM DUAL;
      WHEN 'TRIMESTRAL' THEN
        SELECT TRUNC(SYSDATE, 'Q') INTO V_FECHA_OPX FROM DUAL;
      WHEN 'ANUAL' THEN
        SELECT TRUNC(SYSDATE, 'Y') INTO V_FECHA_OPX FROM DUAL;
      ELSE
        SELECT TRUNC(SYSDATE) INTO V_FECHA_OPX FROM DUAL;
    END CASE;

    IF V_FECHA_OPX = V_FECHA_HOY THEN
      V_ARCHIVO_CLI_OPX := P_OPX.FN_ARCHIVO_CLI_OPX;
      P_OPX.PR_CLIENTES_OPX(V_ARCHIVO_CLI_OPX);

      OPEN C_NUM_CLI_OPX;
      FETCH C_NUM_CLI_OPX
        INTO V_NUM_CLI_OPX;
      V_NUM_CLI_OPX := NVL(V_NUM_CLI_OPX, 0);
      IF V_NUM_CLI_OPX > 0 THEN
        P_MAIL.ENVIO_MAIL_ERROR('OPX - Archivos Portafolio',
                                'Se han generado los archivos de portafolio para los nuevos clientes OPX. ' ||
                                'En la carpeta de NAS de archivos OPX de portafolio, encontrara el archivo ' ||
                                V_ARCHIVO_CLI_OPX ||
                                ' con la lista de los nuevos clientes OPX',
                                DESTINATARIOS_OPX);
      ELSE
        P_MAIL.ENVIO_MAIL_ERROR('OPX - Archivos Portafolio',
                                'Se ha ejecutado el proceso de generacion de archivos de portafolio OPX ' ||
                                'y no se han encontrado nuevos clientes OPX',
                                DESTINATARIOS_OPX);

      END IF;
      CLOSE C_NUM_CLI_OPX;
    END IF;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_OPX_PORTAFOLIO',
                                                      'FIN');
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('OPX - ERROR Archivos Portafolio',
                              'Se ha generado un Error en la ejecuciżn del proceso de generaciżn ' ||
                              'de archivos de portafolio OPX PR_OPX_PORTAFOLIO' ||
                              SUBSTR(SQLERRM, 1, 80),
                              DESTINATARIOS_OPX);

  END PR_OPX_PORTAFOLIO;

  PROCEDURE PR_OPX_MOVIMIENTOS IS

    V_DIA       VARCHAR2(10);
    P_CLI_NID   VARCHAR2(15);
    P_CLI_TID   VARCHAR2(3);
    P_FECHA_INI DATE;
    P_FECHA_FIN DATE;

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_OPX_MOVIMIENTOS',
                                                      'INI');

    SELECT RTRIM(TO_CHAR(SYSDATE, 'DAY', 'NLS_DATE_LANGUAGE=SPANISH'))
      INTO V_DIA
      FROM DUAL;

    IF V_DIA = 'DOMINGO' THEN
      P_CLI_NID := '%';
      P_CLI_TID := '%';
      --      SELECT TRUNC(SYSDATE - 6)  INTO P_FECHA_INI FROM DUAL;
      SELECT POF_FECHA_CORTE
        INTO P_FECHA_INI
        FROM PROCESOS_OPX_FECHAS
       WHERE POF_PROCESO = 'MOVIMIENTOS';

      SELECT TRUNC(SYSDATE) INTO P_FECHA_FIN FROM DUAL;
      P_OPX.PR_MOVIMIENTOS_OPX(P_CLI_NID   => P_CLI_NID,
                               P_CLI_TID   => P_CLI_TID,
                               P_FECHA_INI => P_FECHA_INI,
                               P_FECHA_FIN => P_FECHA_FIN);
      P_MAIL.ENVIO_MAIL_ERROR('OPX - Archivos Movimientos',
                              'Se han generado los archivos de movimientos de la semana anterior ' ||
                              'para los clientes OPX. ',
                              DESTINATARIOS_OPX);
    END IF;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_OPX_MOVIMIENTOS',
                                                      'FIN');
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('OPX - ERROR Archivos Movimientos',
                              'Se ha generado un Error en la ejecuciżn del proceso de generaciżn ' ||
                              'de archivos de movimientos de los clientes OPX: PR_OPX_MOVIMIENTOS ' ||
                              SUBSTR(SQLERRM, 1, 80),
                              DESTINATARIOS_OPX);

  END PR_OPX_MOVIMIENTOS;

  PROCEDURE PR_CLIENTES_EXENTOS(P_ES_NOCTURNO VARCHAR2) IS
    CURSOR C_CLIENTES_EXENTOS IS
      SELECT CEAV_CONSECUTIVO,
             CEAV_FECHA,
             CEAV_CLI_PER_NUM_IDEN,
             CEAV_CLI_PER_TID_CODIGO,
             CEAV_EXENCION_FIDUCIARIA,
             CEAV_EXENCION_CC_LIQUIDEZ,
             CEAV_EXENCION_OPE_BURSATIL,
             CEAV_EXENCION_PRIMARIO,
             CEAV_PORCENTAJE_EXENCION,
             CEAV_USUARIO,
             CEAV_TERMINAL,
             CEAV_PCE_CONSECUTIVO
        FROM CLIENTES_EXENTOS_ADMON_VALORES;
    CEAV1 C_CLIENTES_EXENTOS%ROWTYPE;

    CURSOR C_PERIODOS_EXENCIONES IS
      SELECT PCE_FECHA_INICIAL_VIGENCIA, PCE_FECHA_FINAL_VIGENCIA
        FROM PERIODOS_CARGUES_EXENCIONES
       WHERE PCE_CONSECUTIVO = CEAV1.CEAV_PCE_CONSECUTIVO;
    PCE1 C_PERIODOS_EXENCIONES%ROWTYPE;

    CURSOR C_CONSTANTE(P_MNEMONICO VARCHAR2) IS
      SELECT CON_VALOR FROM CONSTANTES WHERE CON_MNEMONICO = P_MNEMONICO;
    CON1 C_CONSTANTE%ROWTYPE;

    CURSOR C_TIPO_EXENCION(P_TIPO VARCHAR2) IS
      SELECT TCEX_INDICADOR_COBRO
        FROM TIPOS_CARGUES_EXENCIONES
       WHERE TCEX_MNEMONICO = P_TIPO;
    TCEX1 C_TIPO_EXENCION%ROWTYPE;

    EXENCION       NUMBER;
    VALOR_EXENCION NUMBER;
    FECHA          DATE;

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_CLIENTES_EXENTOS',
                                                      'INI');

    SELECT SYSDATE INTO FECHA FROM DUAL;
    OPEN C_CLIENTES_EXENTOS;
    FETCH C_CLIENTES_EXENTOS
      INTO CEAV1;
    WHILE C_CLIENTES_EXENTOS%FOUND LOOP
      EXENCION := 0;
      OPEN C_PERIODOS_EXENCIONES;
      FETCH C_PERIODOS_EXENCIONES
        INTO PCE1;
      CLOSE C_PERIODOS_EXENCIONES;
      IF TRUNC(PCE1.PCE_FECHA_INICIAL_VIGENCIA) <= TRUNC(FECHA) AND
         TRUNC(PCE1.PCE_FECHA_FINAL_VIGENCIA) >= TRUNC(FECHA) THEN
        IF CEAV1.CEAV_EXENCION_FIDUCIARIA = 'S' THEN
          VALOR_EXENCION := P_ADMON_SALDOS.FN_CALCULAR_EXENCION(P_TCEX_MNEMONICO => 'FID',
                                                                P_CON_MNEMONICO  => 'PEF');
          IF EXENCION < VALOR_EXENCION THEN
            EXENCION := VALOR_EXENCION;
          END IF;
        END IF;
        IF CEAV1.CEAV_EXENCION_CC_LIQUIDEZ = 'S' THEN
          VALOR_EXENCION := P_ADMON_SALDOS.FN_CALCULAR_EXENCION(P_TCEX_MNEMONICO => 'CC',
                                                                P_CON_MNEMONICO  => 'PEU');
          IF EXENCION < VALOR_EXENCION THEN
            EXENCION := VALOR_EXENCION;
          END IF;
        END IF;
        IF CEAV1.CEAV_EXENCION_OPE_BURSATIL = 'S' THEN
          VALOR_EXENCION := P_ADMON_SALDOS.FN_CALCULAR_EXENCION(P_TCEX_MNEMONICO => 'OB',
                                                                P_CON_MNEMONICO  => 'PEB');
          IF EXENCION < VALOR_EXENCION THEN
            EXENCION := VALOR_EXENCION;
          END IF;
        END IF;
        IF CEAV1.CEAV_EXENCION_PRIMARIO = 'S' THEN
          VALOR_EXENCION := P_ADMON_SALDOS.FN_CALCULAR_EXENCION(P_TCEX_MNEMONICO => 'DAV',
                                                                P_CON_MNEMONICO  => 'PED');
          IF EXENCION < VALOR_EXENCION THEN
            EXENCION := VALOR_EXENCION;
          END IF;
        END IF;
        IF CEAV1.CEAV_PORCENTAJE_EXENCION != EXENCION THEN
          UPDATE CLIENTES_EXENTOS_ADMON_VALORES
             SET CEAV_FECHA               = SYSDATE,
                 CEAV_PORCENTAJE_EXENCION = EXENCION,
                 CEAV_USUARIO             = USER,
                 CEAV_TERMINAL            = FN_TERMINAL()
           WHERE CEAV_CLI_PER_NUM_IDEN = CEAV1.CEAV_CLI_PER_NUM_IDEN
             AND CEAV_CLI_PER_TID_CODIGO = CEAV1.CEAV_CLI_PER_TID_CODIGO;
        END IF;
      ELSE
        IF CEAV1.CEAV_EXENCION_FIDUCIARIA = 'S' OR
           CEAV1.CEAV_EXENCION_CC_LIQUIDEZ = 'S' OR
           CEAV1.CEAV_EXENCION_OPE_BURSATIL = 'S' OR
           CEAV1.CEAV_EXENCION_PRIMARIO = 'S' OR
           CEAV1.CEAV_PORCENTAJE_EXENCION != 0 THEN
          UPDATE CLIENTES_EXENTOS_ADMON_VALORES
             SET CEAV_FECHA                 = SYSDATE,
                 CEAV_EXENCION_FIDUCIARIA   = 'N',
                 CEAV_EXENCION_CC_LIQUIDEZ  = 'N',
                 CEAV_EXENCION_OPE_BURSATIL = 'N',
                 CEAV_EXENCION_PRIMARIO     = 'N',
                 CEAV_PORCENTAJE_EXENCION   = 0,
                 CEAV_USUARIO               = USER,
                 CEAV_TERMINAL              = FN_TERMINAL()
           WHERE CEAV_CLI_PER_NUM_IDEN = CEAV1.CEAV_CLI_PER_NUM_IDEN
             AND CEAV_CLI_PER_TID_CODIGO = CEAV1.CEAV_CLI_PER_TID_CODIGO;
        END IF;
      END IF;
      FETCH C_CLIENTES_EXENTOS
        INTO CEAV1;
    END LOOP;
    CLOSE C_CLIENTES_EXENTOS;

    IF P_ES_NOCTURNO = 'S' THEN
      P_MAIL.ENVIO_MAIL_ERROR('Proceso calculo de exencion servicio admon. valores',
                              '<br>' ||
                              'El proceso termino de forma exitosa para la fecha: ' ||
                              TO_CHAR(FECHA, 'DD-MON-YYYY'),
                              DESTINATARIOS);
    END IF;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_CLIENTES_EXENTOS',
                                                      'FIN');
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
      IF P_ES_NOCTURNO = 'S' THEN
        P_MAIL.ENVIO_MAIL_ERROR('Proceso calculo de exencion servicio admon. valores. ',
                                'Se ha generado un Error en la ejecuciżn del proceso ' ||
                                SUBSTR(SQLERRM, 1, 80),
                                DESTINATARIOS);
      ELSE
        RAISE_APPLICATION_ERROR(-20001, SQLERRM);
      END IF;
  END PR_CLIENTES_EXENTOS;

  /**********************************************************************************/
  PROCEDURE PR_TRANSFERENCIAS_CORLINE IS
    CURSOR C_TRANSFERENCIA_WEB_POSFECHA IS
      SELECT TWB_CONSECUTIVO,
             TWB_CLI_PER_NUM_IDEN,
             TWB_CLI_PER_TID_CODIGO,
             TWB_TIPO_ORIGEN,
             TWB_TIPO_ORDEN_ORIGEN,
             TWB_NUMERO_CUENTA_ORIGEN,
             TWB_NEGOCIO_ORIGEN,
             TWB_PRODUCTO_ORIGEN,
             TWB_SUBCUENTA_ORIGEN,
             TWB_CODIGO_FONDO_ORIGEN,
             TWB_APORTE_ORIGEN,
             TWB_TIPO_DESTINO,
             TWB_TIPO_ORDEN_DESTINO,
             TWB_NUMERO_CUENTA_DESTINO,
             TWB_NEGOCIO_DESTINO,
             TWB_PRODUCTO_DESTINO,
             TWB_SUBCUENTA_DESTINO,
             TWB_CODIGO_FONDO_DESTINO,
             TWB_APORTE_DESTINO,
             TWB_TERCERO,
             TWB_NUMERO_CUENTA_BANCARIA,
             TWB_CODIGO_BANCO,
             TWB_TIPO_CUENTA_BANCARIA,
             TWB_TIPO_ID_BENEFICIARIO,
             TWB_NUMERO_ID_BENEFICIARIO,
             TWB_NOMBRE_BENEFICIARIO,
             TWB_MONTO,
             TWB_MEDIO_RECEPCION,
             TWB_IP,
             TWB_IMPUESTOS,
             TWB_PENALIZACIONES,
             TWB_CONSECUTIVO_DET_CAN,
             TWB_FECHA_EJECUCION,
             TWB_FECHA_EJECUCION_REAL,
             TWB_EJECUTADO,
             TWB_ERROR,
             TWB_DPCA_CONSECUTIVO,
             TWB_CNL_CONSECUTIVO,
             TWB_DETALLE_ABONO_CUENTA,
             TWB_ARCHIVO_ACH
        FROM TRANSFERENCIA_WEB_POSFECHA
       WHERE TWB_FECHA_EJECUCION = TRUNC(SYSDATE)
         AND NVL(TWB_EJECUTADO, 'N') = 'N'
         AND NVL(TWB_ANULADO, 'N') = 'N';

    CURSOR C_DETALLES_PAGOS_CANALES(V_DPCA_CONSECUTIVO VARCHAR2) IS
      SELECT DPCA_CONSECUTIVO,
             DPCA_CNL_CONSECUTIVO,
             DPCA_FECHA,
             DPCA_OFO_CONSECUTIVO,
             DPCA_OFO_SUC_CODIGO,
             DPCA_ODP_CONSECUTIVO,
             DPCA_ODP_SUC_CODIGO,
             DPCA_ODP_NEG_CONSECUTIVO,
             DPCA_DAA_CONSECUTIVO,
             DPCA_DAA_SUC_CODIGO,
             DPCA_DAA_NEG_CONSECUTIVO
        FROM DETALLES_PAGOS_CANALES
       WHERE DPCA_CONSECUTIVO = V_DPCA_CONSECUTIVO;

    V_TRANSFERENCIA_WEB_POS_ROW  C_TRANSFERENCIA_WEB_POSFECHA%ROWTYPE;
    V_DETALLES_PAGOS_CANALES_ROW DETALLES_PAGOS_CANALES%ROWTYPE;
    V_VALIDO                     VARCHAR2(200);
    V_IMPUESTOS                  NUMBER;
    V_PENALIZACIONES             NUMBER;
    V_FECHA_EJECUCION            VARCHAR2(200);
    V_FECHA_CUMPLIMIENTO         VARCHAR2(200);
    V_CONSECUTIVO                NUMBER;
    V_ERROR                      VARCHAR2(200);

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;
    -- VAGTUD991
    V_APLICA_SALTOS        VARCHAR2(1);
    V_CODIGO_FONDO_ORIGEN  TRANSFERENCIA_WEB_POSFECHA.TWB_CODIGO_FONDO_ORIGEN%TYPE;
    V_CODIGO_FONDO_DESTINO TRANSFERENCIA_WEB_POSFECHA.TWB_CODIGO_FONDO_DESTINO%TYPE;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_TRANSFERENCIAS_CORLINE',
                                                      'INI');

    OPEN C_TRANSFERENCIA_WEB_POSFECHA;
    LOOP
      FETCH C_TRANSFERENCIA_WEB_POSFECHA
        INTO V_TRANSFERENCIA_WEB_POS_ROW;
      EXIT WHEN C_TRANSFERENCIA_WEB_POSFECHA%NOTFOUND;
      BEGIN
        -- VAGTUD991
        -- SE VALIDA LA PARTICIPACION ACTIVA - FONDO CON SALGOS - FINT
        V_CODIGO_FONDO_ORIGEN  := V_TRANSFERENCIA_WEB_POS_ROW.TWB_CODIGO_FONDO_ORIGEN;
        V_CODIGO_FONDO_DESTINO := V_TRANSFERENCIA_WEB_POS_ROW.TWB_CODIGO_FONDO_DESTINO;

        BEGIN
          V_APLICA_SALTOS := NULL;
          IF V_TRANSFERENCIA_WEB_POS_ROW.TWB_CODIGO_FONDO_ORIGEN IS NOT NULL THEN
            V_APLICA_SALTOS := P_ORDENES_FONDOS.FN_APLICA_SALTOS(V_TRANSFERENCIA_WEB_POS_ROW.TWB_CODIGO_FONDO_ORIGEN);
            IF NVL(V_APLICA_SALTOS, 'N') = 'S' THEN
              V_CODIGO_FONDO_ORIGEN := P_RECAUDOS_DAVICASH.FN_PARTICIPACION_ACTIVA(P_CCC_CLI_PER_TID_CODIGO => V_TRANSFERENCIA_WEB_POS_ROW.TWB_CLI_PER_TID_CODIGO,
                                                                                   P_CCC_CLI_PER_NUM_IDEN   => V_TRANSFERENCIA_WEB_POS_ROW.TWB_CLI_PER_NUM_IDEN,
                                                                                   P_CCC_NUMERO_CUENTA      => V_TRANSFERENCIA_WEB_POS_ROW.TWB_NUMERO_CUENTA_ORIGEN,
                                                                                   P_CFO_FON_CODIGO         => V_TRANSFERENCIA_WEB_POS_ROW.TWB_CODIGO_FONDO_ORIGEN,
                                                                                   P_CFO_CODIGO             => V_TRANSFERENCIA_WEB_POS_ROW.TWB_APORTE_ORIGEN);

              IF V_CODIGO_FONDO_ORIGEN IS NULL THEN
                V_CODIGO_FONDO_ORIGEN := V_TRANSFERENCIA_WEB_POS_ROW.TWB_CODIGO_FONDO_ORIGEN;
              END IF;
            END IF;
          END IF;
        END;

        BEGIN
          V_APLICA_SALTOS := NULL;
          IF V_TRANSFERENCIA_WEB_POS_ROW.TWB_CODIGO_FONDO_DESTINO IS NOT NULL THEN
            V_APLICA_SALTOS := P_ORDENES_FONDOS.FN_APLICA_SALTOS(V_TRANSFERENCIA_WEB_POS_ROW.TWB_CODIGO_FONDO_DESTINO);
            IF NVL(V_APLICA_SALTOS, 'N') = 'S' THEN
              V_CODIGO_FONDO_DESTINO := P_RECAUDOS_DAVICASH.FN_PARTICIPACION_ACTIVA(P_CCC_CLI_PER_TID_CODIGO => V_TRANSFERENCIA_WEB_POS_ROW.TWB_CLI_PER_TID_CODIGO,
                                                                                    P_CCC_CLI_PER_NUM_IDEN   => V_TRANSFERENCIA_WEB_POS_ROW.TWB_CLI_PER_NUM_IDEN,
                                                                                    P_CCC_NUMERO_CUENTA      => V_TRANSFERENCIA_WEB_POS_ROW.TWB_NUMERO_CUENTA_DESTINO,
                                                                                    P_CFO_FON_CODIGO         => V_TRANSFERENCIA_WEB_POS_ROW.TWB_CODIGO_FONDO_DESTINO,
                                                                                    P_CFO_CODIGO             => V_TRANSFERENCIA_WEB_POS_ROW.TWB_APORTE_DESTINO);

              IF V_CODIGO_FONDO_DESTINO IS NULL THEN
                V_CODIGO_FONDO_DESTINO := V_TRANSFERENCIA_WEB_POS_ROW.TWB_CODIGO_FONDO_DESTINO;
              END IF;
            END IF;
          END IF;
        END;

        SAVEPOINT SV_TRANSACCION;
        P_WEB_TRANSACCIONES.PR_INSERTAR_TRANSFERENCIA(P_NUMERO_IDENTIFICACION  => V_TRANSFERENCIA_WEB_POS_ROW.TWB_CLI_PER_NUM_IDEN,
                                                      P_TIPO_IDENTIFICACION    => V_TRANSFERENCIA_WEB_POS_ROW.TWB_CLI_PER_TID_CODIGO,
                                                      P_TIPO_ORIGEN            => V_TRANSFERENCIA_WEB_POS_ROW.TWB_TIPO_ORIGEN,
                                                      P_TIPO_ORDEN_ORIGEN      => V_TRANSFERENCIA_WEB_POS_ROW.TWB_TIPO_ORDEN_ORIGEN,
                                                      P_NUMERO_CUENTA_ORIGEN   => V_TRANSFERENCIA_WEB_POS_ROW.TWB_NUMERO_CUENTA_ORIGEN,
                                                      P_NEGOCIO_ORIGEN         => V_TRANSFERENCIA_WEB_POS_ROW.TWB_NEGOCIO_ORIGEN,
                                                      P_PRODUCTO_ORIGEN        => V_TRANSFERENCIA_WEB_POS_ROW.TWB_PRODUCTO_ORIGEN,
                                                      P_SUBCUENTA_ORIGEN       => V_TRANSFERENCIA_WEB_POS_ROW.TWB_SUBCUENTA_ORIGEN,
                                                      P_CODIGO_FONDO_ORIGEN    => V_CODIGO_FONDO_ORIGEN, -- V_TRANSFERENCIA_WEB_POS_ROW.TWB_CODIGO_FONDO_ORIGEN --- VAGTUD991
                                                      P_APORTE_ORIGEN          => V_TRANSFERENCIA_WEB_POS_ROW.TWB_APORTE_ORIGEN,
                                                      P_TIPO_DESTINO           => V_TRANSFERENCIA_WEB_POS_ROW.TWB_TIPO_DESTINO,
                                                      P_TIPO_ORDEN_DESTINO     => V_TRANSFERENCIA_WEB_POS_ROW.TWB_TIPO_ORDEN_DESTINO,
                                                      P_NUMERO_CUENTA_DESTINO  => V_TRANSFERENCIA_WEB_POS_ROW.TWB_NUMERO_CUENTA_DESTINO,
                                                      P_NEGOCIO_DESTINO        => V_TRANSFERENCIA_WEB_POS_ROW.TWB_NEGOCIO_DESTINO,
                                                      P_PRODUCTO_DESTINO       => V_TRANSFERENCIA_WEB_POS_ROW.TWB_PRODUCTO_DESTINO,
                                                      P_SUBCUENTA_DESTINO      => V_TRANSFERENCIA_WEB_POS_ROW.TWB_SUBCUENTA_DESTINO,
                                                      P_CODIGO_FONDO_DESTINO   => V_CODIGO_FONDO_DESTINO, -- V_TRANSFERENCIA_WEB_POS_ROW.TWB_CODIGO_FONDO_DESTINO  -- VAGTUD991
                                                      P_APORTE_DESTINO         => V_TRANSFERENCIA_WEB_POS_ROW.TWB_APORTE_DESTINO,
                                                      P_TERCERO                => V_TRANSFERENCIA_WEB_POS_ROW.TWB_TERCERO,
                                                      P_NUMERO_CUENTA_BANCARIA => V_TRANSFERENCIA_WEB_POS_ROW.TWB_NUMERO_CUENTA_BANCARIA,
                                                      P_CODIGO_BANCO           => V_TRANSFERENCIA_WEB_POS_ROW.TWB_CODIGO_BANCO,
                                                      P_TIPO_CUENTA_BANCARIA   => V_TRANSFERENCIA_WEB_POS_ROW.TWB_TIPO_CUENTA_BANCARIA,
                                                      P_TIPO_ID_BENEFICIARIO   => V_TRANSFERENCIA_WEB_POS_ROW.TWB_TIPO_ID_BENEFICIARIO,
                                                      P_NUMERO_ID_BENEFICIARIO => V_TRANSFERENCIA_WEB_POS_ROW.TWB_NUMERO_ID_BENEFICIARIO,
                                                      P_NOMBRE_BENEFICIARIO    => V_TRANSFERENCIA_WEB_POS_ROW.TWB_NOMBRE_BENEFICIARIO,
                                                      P_MONTO                  => V_TRANSFERENCIA_WEB_POS_ROW.TWB_MONTO,
                                                      P_MEDIO_RECEPCION        => V_TRANSFERENCIA_WEB_POS_ROW.TWB_MEDIO_RECEPCION,
                                                      P_IP                     => V_TRANSFERENCIA_WEB_POS_ROW.TWB_IP,
                                                      P_VALIDO                 => V_VALIDO,
                                                      P_IMPUESTOS              => V_IMPUESTOS,
                                                      P_PENALIZACIONES         => V_PENALIZACIONES,
                                                      P_FECHA_EJECUCION        => V_FECHA_EJECUCION,
                                                      P_FECHA_CUMPLIMIENTO     => V_FECHA_CUMPLIMIENTO,
                                                      P_CONSECUTIVO            => V_CONSECUTIVO,
                                                      P_CANAL                  => V_TRANSFERENCIA_WEB_POS_ROW.TWB_CNL_CONSECUTIVO,
                                                      P_DETALLE_ABONO_CUENTA   => V_TRANSFERENCIA_WEB_POS_ROW.TWB_DETALLE_ABONO_CUENTA,
                                                      P_LLAMADO                => 'PNOCT',
                                                      P_NOMBRE_ARCHIVO_PEFI    => V_TRANSFERENCIA_WEB_POS_ROW.TWB_ARCHIVO_ACH);

        UPDATE TRANSFERENCIA_WEB_POSFECHA
           SET TWB_IMPUESTOS            = V_IMPUESTOS,
               TWB_PENALIZACIONES       = V_PENALIZACIONES,
               TWB_FECHA_EJECUCION_REAL = TO_DATE(V_FECHA_EJECUCION,
                                                  'DD-MM-YYYY'),
               TWB_EJECUTADO            = 'S'
         WHERE TWB_CONSECUTIVO =
               V_TRANSFERENCIA_WEB_POS_ROW.TWB_CONSECUTIVO;

        IF V_CONSECUTIVO != 0 THEN
          OPEN C_DETALLES_PAGOS_CANALES(V_CONSECUTIVO);
          FETCH C_DETALLES_PAGOS_CANALES
            INTO V_DETALLES_PAGOS_CANALES_ROW;
          IF C_DETALLES_PAGOS_CANALES%FOUND THEN
            UPDATE DETALLES_PAGOS_CANALES
               SET DPCA_OFO_CONSECUTIVO     = V_DETALLES_PAGOS_CANALES_ROW.DPCA_OFO_CONSECUTIVO,
                   DPCA_OFO_SUC_CODIGO      = V_DETALLES_PAGOS_CANALES_ROW.DPCA_OFO_SUC_CODIGO,
                   DPCA_ODP_CONSECUTIVO     = V_DETALLES_PAGOS_CANALES_ROW.DPCA_ODP_CONSECUTIVO,
                   DPCA_ODP_SUC_CODIGO      = V_DETALLES_PAGOS_CANALES_ROW.DPCA_ODP_SUC_CODIGO,
                   DPCA_ODP_NEG_CONSECUTIVO = V_DETALLES_PAGOS_CANALES_ROW.DPCA_ODP_NEG_CONSECUTIVO,
                   DPCA_DAA_CONSECUTIVO     = V_DETALLES_PAGOS_CANALES_ROW.DPCA_DAA_CONSECUTIVO,
                   DPCA_DAA_SUC_CODIGO      = V_DETALLES_PAGOS_CANALES_ROW.DPCA_DAA_SUC_CODIGO,
                   DPCA_DAA_NEG_CONSECUTIVO = V_DETALLES_PAGOS_CANALES_ROW.DPCA_DAA_NEG_CONSECUTIVO
             WHERE DPCA_CONSECUTIVO =
                   V_TRANSFERENCIA_WEB_POS_ROW.TWB_DPCA_CONSECUTIVO;
          END IF;
          CLOSE C_DETALLES_PAGOS_CANALES;
        END IF;
        COMMIT;
      EXCEPTION
        WHEN OTHERS THEN
          V_ERROR := SUBSTR(SQLERRM, 0, 200);
          ROLLBACK TO SV_TRANSACCION;

          UPDATE TRANSFERENCIA_WEB_POSFECHA
             SET TWB_FECHA_EJECUCION_REAL = SYSDATE,
                 TWB_ERROR                = V_ERROR,
                 TWB_EJECUTADO            = 'S'
           WHERE TWB_CONSECUTIVO =
                 V_TRANSFERENCIA_WEB_POS_ROW.TWB_CONSECUTIVO;
      END;
    END LOOP;
    CLOSE C_TRANSFERENCIA_WEB_POSFECHA;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_TRANSFERENCIAS_CORLINE',
                                                      'FIN');
    COMMIT;

  END PR_TRANSFERENCIAS_CORLINE;
  /**********************************************************************************/

  PROCEDURE PR_PROCESOS_OPX IS
    V_ERRORES VARCHAR2(4000);
    CONTADOR  NUMERIC;

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_PROCESOS_OPX',
                                                      'INI');

    V_ERRORES := 'ACTUALIZANDO PRECIO DE:<br/>';
    FOR CUR_ACTUALIZA IN (SELECT OE_ENA_MNEMONICO, OE_ID FROM OPX_ESPECIES) LOOP
      BEGIN
        P_OPTIMIZACION_PORTAFOLIO.PR_CALCULO_PRECIOS_OPX(CUR_ACTUALIZA.OE_ENA_MNEMONICO,
                                                         CUR_ACTUALIZA.OE_ID);
        COMMIT;
        CONTADOR := CONTADOR + 1;
      EXCEPTION
        WHEN OTHERS THEN
          V_ERRORES := V_ERRORES || CUR_ACTUALIZA.OE_ENA_MNEMONICO ||
                       '<br/>';
      END;
    END LOOP;

    DELETE FROM OPX_PRECIOS_ESPECIES
     WHERE TRUNC(OPES_FECHA) = TRUNC(SYSDATE);
    COMMIT;

    P_MAIL.ENVIO_MAIL_ERROR('OPX - Precios OPX',
                            'Se realizo la actualizaciżn de precios en la tabla OPX_PRECIOS_ESPECIE <br/>' ||
                            V_ERRORES,
                            DESTINATARIOS_OPX);

    V_ERRORES := 'ACTUALIZANDO PROTAFOLIO DE:<br/>';
    FOR CUR_VALORA IN (SELECT CLI.CLI_PER_NUM_IDEN, CLI.CLI_PER_TID_CODIGO
                         FROM CLIENTES CLI
                        WHERE CLI.CLI_OPX = 'S'
                          AND CLI.CLI_NO_OPX IS NULL) LOOP
      BEGIN
        P_OPTIMIZACION_PORTAFOLIO.PR_VALORA_RECOMENDACION(CUR_VALORA.CLI_PER_NUM_IDEN,
                                                          CUR_VALORA.CLI_PER_TID_CODIGO);
        COMMIT;
      EXCEPTION
        WHEN OTHERS THEN
          IF LENGTH(V_ERRORES) < 1000 THEN
            V_ERRORES := V_ERRORES || CUR_VALORA.CLI_PER_NUM_IDEN ||
                         CUR_VALORA.CLI_PER_TID_CODIGO || SQLERRM ||
                         '<br/>';
          END IF;
      END;
    END LOOP;

    P_MAIL.ENVIO_MAIL_ERROR('OPX - Valoracion Portafolio OPX',
                            'Finalizo la valoraciżn de los portafolios recomendados <br/>',
                            DESTINATARIOS_OPX);

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_PROCESOS_OPX',
                                                      'FIN');
    COMMIT;

  END;

  /**********************************************************************************/
  PROCEDURE PR_ACT_RENTAB_VOLATIL(P_TX IN NUMBER DEFAULT NULL) IS

    CONTEO    NUMBER(10);
    --P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;
    N_ID_PROCESO NUMBER;
    N_TX NUMBER;

  BEGIN

     --se asigna el consecutivo del proceso(tabla PARAMETRIZACION_PROCESOS)
    N_ID_PROCESO := P_TRAZA_CORE.FN_ID_PROCESO('P_PROCESOS_NOCTURNOS.PR_ACT_RENTAB_VOLATIL');

    --se Asigna consecutivo para la transaccion, si el proceso es el primero que se llama, reinicia el consecutivo
    N_TX := P_TRAZA_CORE.FN_TRAE_TX(P_TX);

    --Registra Traza
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'I',
                                    'Inicio proceso P_PROCESOS_NOCTURNOS.PR_ACT_RENTAB_VOLATIL. Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss'),
                                    N_TX);

    P_CALCULO_RENTABILIDAD.INSERTAR_RENTAB(SYSDATE - 1,N_TX);
    P_CALCULO_VOLATILIDAD.INSERTAR_VOLATIL(SYSDATE - 1,N_TX);

    SELECT COUNT(*)
      INTO CONTEO
      FROM (SELECT VFO_FON_CODIGO
              FROM VALORIZACIONES_FONDO
             WHERE VFO_FECHA_VALORIZACION >= TRUNC(SYSDATE) - 1
               AND VFO_FECHA_VALORIZACION < TRUNC(SYSDATE)
               AND NOT EXISTS
             (SELECT RYV_FON_CODIGO
                      FROM RENTABILIDADES_Y_VOLATILIDADES
                     WHERE RYV_FON_CODIGO = VFO_FON_CODIGO
                       AND TRUNC(RYV_FECHA) = TRUNC(VFO_FECHA_VALORIZACION)
                       AND RYV_FECHA >= TRUNC(SYSDATE) - 1
                       AND RYV_fecha < TRUNC(SYSDATE)));

    IF CONTEO > 0 THEN
      /*P_MAIL.ENVIO_MAIL_ERROR('Error en el proceso Actualizaciżn tabla RENTABILIDADES_Y_VOLATILIDADES para el dia: ' ||
                              TO_CHAR(sysdate - 1, 'DD-MON-YYYY'),
                              '<br>' ||
                              'Se copia correo al Ingeniero de desarrollo para revision al siguiente dia',
                              'stecnico@corredores.com, smorales@corredores.com,fmunozc@corredores.com');*/
        P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'T',
                                    'Traza proceso P_PROCESOS_NOCTURNOS.PR_ACT_RENTAB_VOLATIL. Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss')||' Error en el proceso Actualizaciżn tabla RENTABILIDADES_Y_VOLATILIDADES',
                                    N_TX);
    ELSE
      /*P_MAIL.ENVIO_MAIL_ERROR('Proceso de Actualizaciżn tabla RENTABILIDADES_Y_VOLATILIDADES terminado correctamente para el dia : ' ||
                              TO_CHAR(sysdate - 1, 'DD-MON-YYYY'),
                              'stecnico@corredores.com');*/
       P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'T',
                                    'Traza proceso P_PROCESOS_NOCTURNOS.PR_ACT_RENTAB_VOLATIL. Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss')||' Proceso de Actualizaciżn tabla RENTABILIDADES_Y_VOLATILIDADES terminado correctamente',
                                    N_TX);                              
    END IF;

    P_CALCULO_RENTABILIDAD_FICI.PR_CALCULO_DIARIO(N_TX); --VAGTUD937-13 - Controles generaciżn extractos - Rentabilidad


     --Registra Traza
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'F',
                                    'Fin proceso P_PROCESOS_NOCTURNOS.PR_ACT_RENTAB_VOLATIL. Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss'),
                                    N_TX);                                               
    COMMIT;

  END PR_ACT_RENTAB_VOLATIL;

  /***********************************************************************************************
  ***  PROCEDIMIENTO  P_PROCESOS_NOCTURNOS.P_NOC_GARANTIAS_EFECTIVO                              **
  ***     realiza llamado a proceso que guarda diariamente las garantias en efectivo de clientes **
  ***     se debe enviar todos los dias: borra la informacion de la fecha y la vuenve a insertar **
  ***     debe correr antes de:                                                                  **
  ***         proceso de segmentacion  P_PROCESOS_NOCTURNOS.P_NOC_SEGMENTA_CLI                   **
  ***         procesos de CORLINE                                                                **
  /********************************************************************************************* */

  PROCEDURE PR_NOC_GARANTIAS_EFECTIVO(P_TX IN NUMBER DEFAULT NULL) IS

    P_NUM_INI    NUMBER;
    P_NUM_FIN    NUMBER;
    N_TX         NUMBER;
    N_ID_PROCESO NUMBER;

  BEGIN

    --se asigna consecutivo del proceso(tabla PARAMETRIZACION_PROCESOS)
    N_ID_PROCESO := P_TRAZA_CORE.FN_ID_PROCESO('P_PROCESOS_NOCTURNOS.PR_NOC_GARANTIAS_EFECTIVO');

    --se Asigna consecutivo para la transaccion
    N_TX := P_TRAZA_CORE.FN_TRAE_TX(P_TX);

    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'I',
                                    'Inicio proceso P_PROCESOS_NOCTURNOS.PR_NOC_GARANTIAS_EFECTIVO. Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE,
                                            'DD-MM-YYYY HH24:mi:ss'),
                                    N_TX);

    P_CLIENTES.PR_GARANTIA_EFECTIVO_DIA(SYSDATE - 1, N_TX);

    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'F',
                                    'Fin proceso P_PROCESOS_NOCTURNOS.PR_NOC_GARANTIAS_EFECTIVO . Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE,
                                            'DD-MM-YYYY HH24:mi:ss'),
                                    N_TX);
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
      P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                      'E',
                                      'Error PR_NOC_GARANTIAS_EFECTIVO' ||
                                      SUBSTR(SQLERRM, 1, 80) || ':' ||
                                      TO_CHAR(SYSDATE,
                                              'DD-MM-YYYY HH24:mi:ss'),
                                      N_TX);
  END PR_NOC_GARANTIAS_EFECTIVO;

  /***********************************************************************************************
  ***  PROCEDIMIENTO  P_PROCESOS_NOCTURNOS.P_NOC_SEGMENTA_CLI                                   **
  ***     realiza llamado a proceso de segmentacion de clientes                                 **
  ***     se debe enviar sżlo el sabado anterior a 01 de Enero y 01 de Julio                    **
  /********************************************************************************************* */
  PROCEDURE PR_NOC_SEGMENTA_CLI(P_TX IN NUMBER DEFAULT NULL) IS
    P_FECHA         DATE;
    P_FECHA_PROXIMA DATE;
    P_FECHA_JUL     DATE;
    P_FECHA_ENE     DATE;

    P_NUM_INI    NUMBER;
    P_NUM_FIN    NUMBER;
    N_ID_PROCESO NUMBER;
    N_TX         NUMBER;

  BEGIN

     -- SE LEE FECHA DE PROXIMO REBALANCEO DE CONSTANTES
    SELECT CON_VALOR_DATE
      INTO P_FECHA
      FROM CONSTANTES
     WHERE CON_MNEMONICO = 'FRB';
    IF TRUNC(P_FECHA) = TRUNC(SYSDATE) THEN
      BEGIN
         --se asignar el consecutivo del proceso(tabla PARAMETRIZACION_PROCESOS)
        N_ID_PROCESO := P_TRAZA_CORE.FN_ID_PROCESO('P_PROCESOS_NOCTURNOS.PR_NOC_SEGMENTA_CLI');

        --se Asigna consecutivo para la transaccion, si el proceso es el primero que se llama, reinicia el consecutivo
        N_TX := P_TRAZA_CORE.FN_TRAE_TX(P_TX);

        --Registra Traza
        P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                        'I',
                                        'Inicio proceso P_PROCESOS_NOCTURNOS.PR_NOC_SEGMENTA_CLI . Fecha Proceso: ' ||
                                        TO_CHAR(SYSDATE,
                                                'DD-MM-YYYY HH24:mi:ss'),
                                        N_TX);

        P_CLIENTES.PR_SEGMENTA_CLIENTE(P_FECHA, N_TX);

        -- SE ACTUALIZA LA CONSTANTE DE ULTIMA FECHA DE REBALANCEO
        UPDATE CONSTANTES
           SET CON_VALOR_DATE = TRUNC(SYSDATE)
         WHERE CON_MNEMONICO = 'URB';

        P_FECHA_JUL := TO_DATE('01-JUL-' || TO_CHAR(P_FECHA, 'YYYY'));
        P_FECHA_ENE := TO_DATE('01-ENE-' || TO_CHAR(P_FECHA + 365, 'YYYY'));

        LOOP
          IF TO_CHAR(P_FECHA_JUL, 'D') = '7' THEN
            EXIT;
          ELSE
            P_FECHA_JUL := P_FECHA_JUL - 1;
          END IF;
        END LOOP;

        LOOP
          IF TO_CHAR(P_FECHA_ENE, 'D') = '7' THEN
            EXIT;
          ELSE
            P_FECHA_ENE := P_FECHA_ENE - 1;
          END IF;
        END LOOP;

        IF TRUNC(P_FECHA) < TRUNC(P_FECHA_JUL) THEN
          UPDATE CONSTANTES
             SET CON_VALOR_DATE = TRUNC(P_FECHA_JUL)
           WHERE CON_MNEMONICO = 'FRB';
        ELSIF TRUNC(P_FECHA) >= TRUNC(P_FECHA_JUL) AND
              TRUNC(P_FECHA) < TRUNC(P_FECHA_ENE) THEN
          UPDATE CONSTANTES
             SET CON_VALOR_DATE = TRUNC(P_FECHA_ENE)
           WHERE CON_MNEMONICO = 'FRB';
        ELSE
          P_FECHA_JUL := TO_DATE('01-JUL-' ||
                                 TO_CHAR(P_FECHA + 365, 'YYYY'));
          LOOP
            IF TO_CHAR(P_FECHA_JUL, 'D') = '7' THEN
              EXIT;
            ELSE
              P_FECHA_JUL := P_FECHA_JUL - 1;
            END IF;
          END LOOP;

          UPDATE CONSTANTES
             SET CON_VALOR_DATE = P_FECHA_JUL
           WHERE CON_MNEMONICO = 'FRB';
        END IF;

        -- PROCESO DE ASIGNACION SEGMENTO ALTERNO
        P_CLIENTES.PR_SEGMENTA_ALTERNO_CLIENTE(N_TX);

        P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                        'F',
                                        'Fin P_PROCESOS_NOCTURNOS.PR_NOC_SEGMENTA_CLI. Fecha Proceso: ' ||
                                        TO_CHAR(SYSDATE,
                                                'DD-MM-YYYY HH24:mi:ss'),
                                        N_TX);
        COMMIT;

      EXCEPTION
        WHEN OTHERS THEN
           P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                          'E',
                                          'P_PROCESOS_NOCTURNOS.PR_NOC_SEGMENTA_CLI. Fecha: ' ||
                                          TO_CHAR(SYSDATE,
                                                  'DD-MM-YYYY HH24:mi:ss') || ' ' ||
                                          SUBSTR(SQLERRM, 1, 80),
                                          N_TX);
      END;
        P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                      'F',
                                      'Proceso diario finalizado:P_PROCESOS_NOCTURNOS.PR_NOC_SEGMENTA_CLI. Fecha proceso: ' ||
                                      TO_CHAR(SYSDATE,
                                              'DD-MM-YYYY HH24:mi:ss'),
                                      N_TX);
    END IF;

  END PR_NOC_SEGMENTA_CLI;

  PROCEDURE PR_INACTIVA_COTRATO_DERIVADOS(P_TX IN NUMBER DEFAULT NULL) IS
    CURSOR C1 IS
      SELECT CNT_CONSECUTIVO
        FROM CONTRATOS
       WHERE CNT_FECHA_VENCIMIENTO < TRUNC(SYSDATE)
         AND CNT_ESTADO = 'A'
         AND NOT EXISTS
       (SELECT 'X'
                FROM GL_CLI_DERIVADOS
               WHERE CLI_PER_NUM_IDEN = CNT_CLI_PER_NUM_IDEN
                 AND CLI_PER_TID_CODIGO = CNT_CLI_PER_TID_CODIGO);

    C_C1 C1%ROWTYPE;

    P_DATOS_GARANTIA        P_GARANTIAS.V_DATOS_REFCUR2;
    P_DATOS_GARANTIA_SCB    P_GARANTIAS.V_DATOS_REFCUR3;
    V_UTILIDAD_EFECTIVO     UTILIDADES_GARANTIAS_EFECTIVO%ROWTYPE;
    V_UTILIDAD_EFECTIVO_SCB UTILIDADES_GARANTIAS_EFECTIVO%ROWTYPE;

    --P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;
    N_ID_PROCESO NUMBER;
    N_TX NUMBER;

  BEGIN

      --se asigna el consecutivo del proceso(tabla PARAMETRIZACION_PROCESOS)
    N_ID_PROCESO := P_TRAZA_CORE.FN_ID_PROCESO('P_PROCESOS_NOCTURNOS.PR_INACTIVA_COTRATO_DERIVADOS');

    --se Asigna consecutivo para la transaccion, si el proceso es el primero que se llama, reinicia el consecutivo
    N_TX := P_TRAZA_CORE.FN_TRAE_TX(P_TX);

    --Registra Traza
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'I',
                                    'Inicio proceso P_PROCESOS_NOCTURNOS.PR_INACTIVA_COTRATO_DERIVADOS . Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss'),
                                    N_TX);                   

    DELETE GL_CLI_DERIVADOS;
    COMMIT;
    P_DATOS_GARANTIA        := NULL;
    P_DATOS_GARANTIA_SCB    := NULL;
    V_UTILIDAD_EFECTIVO     := NULL;
    V_UTILIDAD_EFECTIVO_SCB := NULL;

    P_GARANTIAS.P_VALOR_GARANTIA_DER(P_FECHA_PROCESO  => SYSDATE,
                                     P_DATOS_GARANTIA => P_DATOS_GARANTIA,
                                     P_LLAMADO =>'',
                                     P_TX=>N_TX);

    LOOP
      FETCH P_DATOS_GARANTIA
        INTO V_UTILIDAD_EFECTIVO.UTGE_CCC_CLI_PER_NUM_IDEN,
             V_UTILIDAD_EFECTIVO.UTGE_CCC_CLI_PER_TID_CODIGO,
             V_UTILIDAD_EFECTIVO.UTGE_CCC_NUMERO_CUENTA,
             V_UTILIDAD_EFECTIVO.UTGE_NOMBRE_CUENTA,
             V_UTILIDAD_EFECTIVO.UTGE_VALOR_CHEQUES,
             V_UTILIDAD_EFECTIVO.UTGE_VALOR_CONSIG_CAJA,
             V_UTILIDAD_EFECTIVO.UTGE_VALOR_TRANSF_CAJA,
             V_UTILIDAD_EFECTIVO.UTGE_VALOR_RECIBOS_CAJA,
             V_UTILIDAD_EFECTIVO.UTGE_VALOR_ORDENES_PAGO;
      EXIT WHEN P_DATOS_GARANTIA%NOTFOUND;
      INSERT INTO GL_CLI_DERIVADOS
        (CLI_PER_NUM_IDEN, CLI_PER_TID_CODIGO)
      VALUES
        (V_UTILIDAD_EFECTIVO.UTGE_CCC_CLI_PER_NUM_IDEN --CLI_PER_NUM_IDEN
        ,
         V_UTILIDAD_EFECTIVO.UTGE_CCC_CLI_PER_TID_CODIGO --CLI_PER_TID_CODIGO
         );
    END LOOP;
    CLOSE P_DATOS_GARANTIA;

    P_GARANTIAS.PR_GARANTIAS_DER_SCB(P_FECHA_PROCESO  => SYSDATE,
                                     P_DATOS_GARANTIA => P_DATOS_GARANTIA_SCB,
                                     P_LLAMADO =>'',
                                     P_TX=>N_TX);

    LOOP
      FETCH P_DATOS_GARANTIA_SCB
        INTO V_UTILIDAD_EFECTIVO_SCB.UTGE_CCC_CLI_PER_NUM_IDEN,
             V_UTILIDAD_EFECTIVO_SCB.UTGE_CCC_CLI_PER_TID_CODIGO,
             V_UTILIDAD_EFECTIVO_SCB.UTGE_CCC_NUMERO_CUENTA,
             V_UTILIDAD_EFECTIVO_SCB.UTGE_NOMBRE_CUENTA,
             V_UTILIDAD_EFECTIVO_SCB.UTGE_VALOR_CHEQUES,
             V_UTILIDAD_EFECTIVO_SCB.UTGE_VALOR_CONSIG_CAJA,
             V_UTILIDAD_EFECTIVO_SCB.UTGE_VALOR_TRANSF_CAJA,
             V_UTILIDAD_EFECTIVO_SCB.UTGE_VALOR_RECIBOS_CAJA,
             V_UTILIDAD_EFECTIVO_SCB.UTGE_VALOR_ORDENES_PAGO_SCB,
             V_UTILIDAD_EFECTIVO_SCB.UTGE_VALOR_ORDENES_PAGO;

      EXIT WHEN P_DATOS_GARANTIA_SCB%NOTFOUND;
      INSERT INTO GL_CLI_DERIVADOS
        (CLI_PER_NUM_IDEN, CLI_PER_TID_CODIGO)
      VALUES
        (V_UTILIDAD_EFECTIVO_SCB.UTGE_CCC_CLI_PER_NUM_IDEN --CLI_PER_NUM_IDEN
        ,
         V_UTILIDAD_EFECTIVO_SCB.UTGE_CCC_CLI_PER_TID_CODIGO --CLI_PER_TID_CODIGO
         );
    END LOOP;
    CLOSE P_DATOS_GARANTIA_SCB;

    /**** GARANTIAS DISPONIBLES****/
    BEGIN
      INSERT INTO GL_CLI_DERIVADOS
        (CLI_PER_NUM_IDEN, CLI_PER_TID_CODIGO)
        SELECT DISTINCT CFC_CCC_CLI_PER_NUM_IDEN,
                        CFC_CCC_CLI_PER_TID_CODIGO
          FROM CUENTAS_FUNGIBLE_CLIENTE
         WHERE CFC_SALDO_DCVAL_GARANTIA > 0;
    END;

    OPEN C1;
    FETCH C1
      INTO C_C1;
    WHILE C1%FOUND LOOP
      UPDATE CONTRATOS
         SET CNT_ESTADO = 'I'
       WHERE CNT_CONSECUTIVO = C_C1.CNT_CONSECUTIVO;
      FETCH C1
        INTO C_C1;
    END LOOP;
    CLOSE C1;

    COMMIT;

     -- Registrar traza FIN
   P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                'F',
                                'Fin P_PROCESOS_NOCTURNOS.PR_INACTIVA_COTRATO_DERIVADOS. Fecha Proceso: ' ||
                                TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss'),
                                N_TX);                                                      
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
     --Registra Traza ERROR
      P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                      'E',
                                      'P_PROCESOS_NOCTURNOS.PR_INACTIVA_COTRATO_DERIVADOS. Fecha: ' ||
                                      TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss') || ' ' ||
                                      SUBSTR(SQLERRM, 1, 150),
                                      N_TX);                              

  END PR_INACTIVA_COTRATO_DERIVADOS;

  PROCEDURE CALCULO_DUR_MACAULAY IS

    CURSOR C_FONDOS IS
      SELECT FON_CODIGO
        FROM FONDOS
       WHERE FON_CODIGO IN ('800154697', '900041269', '900008438');
    FONDO C_FONDOS%ROWTYPE;

    ---DURACION FLUJOS----
    CURSOR C_TITULO_FONDO IS
      SELECT TFO_CODIGO,
             TFO_FECHA_EMISION,
             TFO_FECHA_VENCIMIENTO,
             TFO_VALOR_NOMINAL,
             TFO_TASA_FACIAL, --->TASA CUPON
             TFO_ENA_MNEMONICO,
             TFO_BMO_MNEMONICO

        FROM TITULOS_FONDOS
       WHERE TFO_FECHA_EMISION <= TRUNC(SYSDATE - 1) --TRUNC(SYSDATE-1)
         AND TFO_FECHA_VENCIMIENTO >= TRUNC(SYSDATE) --TRUNC(SYSDATE)
         AND TFO_FON_CODIGO = FONDO.FON_CODIGO
         AND TFO_MODALIDAD_TASA IN ('V', 'A')
         AND TFO_TYPE = 'TRF'
         AND TFO_ENA_MNEMONICO NOT IN ('ESTRATEINTP')
         AND EXISTS (SELECT 'X'
                FROM MVTOS_RENTA_FIJA
               WHERE MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                 AND MRF_TFO_CODIGO = TFO_CODIGO
                 AND MRF_TMT_MNEMONICO = 'VAF'
                 AND MRF_FECHA >= TRUNC(SYSDATE - 1) --TRUNC(SYSDATE-1)
                 AND MRF_FECHA < TRUNC(SYSDATE)); --TRUNC(SYSDATE));
    C_TFO C_TITULO_FONDO%ROWTYPE;

    CURSOR C_TASA_DES IS
      SELECT MRF_VALOR_TITULO_TM,
             MRF_PRECIO PRECIO,
             (MRF_TASA_DESCUENTO / 100) + 1 TAS_DES
        FROM MVTOS_RENTA_FIJA
       WHERE MRF_TFO_FON_CODIGO = FONDO.FON_CODIGO
         AND MRF_TFO_CODIGO = C_TFO.TFO_CODIGO
         AND MRF_FECHA >= TRUNC(SYSDATE - 1) --TRUNC(SYSDATE-1)
         AND MRF_FECHA < TRUNC(SYSDATE) --TRUNC(SYSDATE)
         AND MRF_PRECIO IS NOT NULL
       ORDER BY MRF_FECHA DESC;
    C_TAS C_TASA_DES%ROWTYPE;

    VALOR_NOMIN NUMBER;

    CURSOR C_FLUJOS_V IS
      SELECT MAX(ROWNUM),
             FRT_FECHA,
             ROUND(TRUNC((FRT_INTERES_MERCADO / VALOR_NOMIN) * 100, 6), 7) FLUJO,
             TRUNC(FRT_FECHA) - TRUNC(SYSDATE - 1) DIAS,
             FRT_INTERES_MERCADO INTERES_MERCADO
        FROM FLUJOS_RENDIMIENTOS_TITULOS
       WHERE FRT_TFO_FON_CODIGO = FONDO.FON_CODIGO
         AND FRT_TFO_CODIGO = C_TFO.TFO_CODIGO
         AND FRT_ESTADO IN ('V', 'A')
       GROUP BY FRT_FECHA,
                ROUND(TRUNC((FRT_INTERES_MERCADO / VALOR_NOMIN) * 100, 6),
                      7),
                TRUNC(FRT_FECHA) - TRUNC(SYSDATE - 1),
                FRT_INTERES_MERCADO
      HAVING COUNT(*) < MAX(ROWNUM)
       ORDER BY FRT_FECHA;
    C_FLU C_FLUJOS_V%ROWTYPE;

    CURSOR C_BASE_MONETARIA IS
      SELECT CBM_VALOR
        FROM COTIZACIONES_BASE_MONETARIAS
       WHERE CBM_BMO_MNEMONICO = C_TFO.TFO_BMO_MNEMONICO
         AND CBM_FECHA >= TRUNC(SYSDATE - 1) --TRUNC(SYSDATE-1)
         AND CBM_FECHA < TRUNC(SYSDATE); --TRUNC(SYSDATE);
    VALOR NUMBER;

    CURSOR C_FLUJOS_U IS
      SELECT FRT_FECHA,
             ROUND(TRUNC(((FRT_INTERES_MERCADO / VALOR_NOMIN) * 100) + 100,
                         6),
                   7) FLUJO,
             TRUNC(FRT_FECHA) - TRUNC(SYSDATE - 1) DIAS,
             FRT_INTERES_MERCADO INTERES_MERCADO
        FROM FLUJOS_RENDIMIENTOS_TITULOS
       WHERE FRT_TFO_FON_CODIGO = FONDO.FON_CODIGO
         AND FRT_TFO_CODIGO = C_TFO.TFO_CODIGO
         AND FRT_ESTADO IN ('V', 'A')
         AND ROWNUM = 1;
    C_FLU_U C_FLUJOS_U%ROWTYPE;

    CURSOR C_FLUJOS_A IS
      SELECT FAT_FECHA,
             TRUNC(FAT_FECHA) - TRUNC(SYSDATE - 1) DIAS,
             FAT_AMORTIZACION_CAPITAL
      --   ROUND(TRUNC(((TRUNC(TFO_FECHA_VENCIMIENTO)-TRUNC(FECHA))/365),6),7) DURACION
        FROM FLUJOS_AMORTIZACION_TITULOS
       WHERE FAT_TFO_FON_CODIGO = FONDO.FON_CODIGO
         AND FAT_TFO_CODIGO = C_TFO.TFO_CODIGO
         AND FAT_ESTADO IN ('V', 'A');
    C_FLU_A C_FLUJOS_A%ROWTYPE;

    ---DURACION SIMULTANEA
    CURSOR C_SIMULTANEA IS
      SELECT TRUNC(TFO_FECHA_VENCIMIENTO) - TRUNC(SYSDATE - 1),
             TFO_VALOR_NOMINAL,
             ROUND(TRUNC(((TRUNC(TFO_FECHA_VENCIMIENTO) -
                         TRUNC(SYSDATE - 1)) / 365),
                         6),
                   7) DURACION
        FROM TITULOS_FONDOS
       WHERE TFO_FECHA_EMISION <= TRUNC(SYSDATE - 1) --TRUNC(SYSDATE-1)
         AND TFO_FECHA_VENCIMIENTO > TRUNC(SYSDATE) --TRUNC(SYSDATE)
         AND TFO_FON_CODIGO = FONDO.FON_CODIGO
         AND TFO_MODALIDAD_TASA = 'D'
         AND TFO_TYPE = 'TRF'
         AND TFO_ENA_MNEMONICO NOT IN ('ESTRATEINTP')
         AND EXISTS (SELECT 'X'
                FROM MVTOS_RENTA_FIJA
               WHERE MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                 AND MRF_TFO_CODIGO = TFO_CODIGO
                 AND MRF_TMT_MNEMONICO = 'VAF'
                 AND MRF_FECHA >= TRUNC(SYSDATE - 1) --TRUNC(SYSDATE-1)
                 AND MRF_FECHA < TRUNC(SYSDATE)); --TRUNC(SYSDATE));
    C_SIM C_SIMULTANEA%ROWTYPE;

    ---DURACION CUENTAS AHORRO

    CURSOR C_CUENTAS_BANCARIAS IS
      SELECT CBF_NUMERO_CUENTA, CBF_BAN_CODIGO, CBF_FON_CODIGO
        FROM CUENTAS_BANCARIAS_FONDOS
       WHERE CBF_ESTADO = 'A'
         AND CBF_TIPO_CUENTA = 'A'
         AND CBF_FON_CODIGO = FONDO.FON_CODIGO;
    CBF C_CUENTAS_BANCARIAS%ROWTYPE;

    CURSOR C_SALDO_CUENTA IS
      SELECT MTF_SALDO, ROUND(TRUNC((1 / 365), 6), 7) DURACION
        FROM MOVIMIENTOS_TESORERIA_FONDOS
       WHERE MTF_CBF_BAN_CODIGO = CBF.CBF_BAN_CODIGO
         AND MTF_CBF_NUMERO_CUENTA = CBF.CBF_NUMERO_CUENTA -- IN  (04882034670,80100001434)
         AND MTF_CBF_FON_CODIGO = CBF.CBF_FON_CODIGO
         AND MTF_FECHA >= TRUNC(SYSDATE - 1) --TRUNC(SYSDATE-1)
         AND MTF_FECHA < TRUNC(SYSDATE) --TRUNC(SYSDATE)
       ORDER BY MTF_CONSECUTIVO DESC;

    SAL_C   C_SALDO_CUENTA%ROWTYPE;
    TOT_MTF NUMBER;

    T_DESC      NUMBER;
    VPN         NUMBER;
    DUR         NUMBER;
    SUM_DUR     NUMBER;
    DIA_H       VARCHAR2(1);
    FEC_CUENTA  DATE;
    SUM_DUR_FLU NUMBER;
    SUM_VMI_TIT NUMBER;
    VMI_DUR     NUMBER;
    SUM_DUR_SIM NUMBER;
    SUM_DUR_CUE NUMBER;
    DUR_FON     NUMBER;
    ANTERIOR    DATE;
    ACTUAL      DATE;
    CANTIDAD    NUMBER;
    FLUJO       NUMBER;
    FJ          NUMBER;
    DIAS        NUMBER;
    RESP        VARCHAR2(10);
    PRIMER_DIA  DATE;
    SUMA_PRU    NUMBER;

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.CALCULO_DUR_MACAULAY',
                                                      'INI');

    SELECT TRUNC(SYSDATE, 'MONTH') INTO PRIMER_DIA FROM DUAL;

    IF PRIMER_DIA = TRUNC(SYSDATE) THEN

      OPEN C_FONDOS;
      FETCH C_FONDOS
        INTO FONDO;
      WHILE C_FONDOS%FOUND LOOP

        SUM_DUR     := 0;
        SUM_DUR_FLU := 0;
        SUM_VMI_TIT := 0;
        VMI_DUR     := 0;
        SUM_DUR_SIM := 0;
        SUM_DUR_CUE := 0;
        DUR_FON     := 0;
        SUMA_PRU    := 0;

        ------------------DURACION FLUJOS-----------------------
        OPEN C_TITULO_FONDO;
        FETCH C_TITULO_FONDO
          INTO C_TFO;
        LOOP
          EXIT WHEN C_TITULO_FONDO%NOTFOUND;
          OPEN C_TASA_DES;
          FETCH C_TASA_DES
            INTO C_TAS;
          IF C_TASA_DES%NOTFOUND THEN
            C_TAS.PRECIO := NULL;
          END IF;
          CLOSE C_TASA_DES;

          IF C_TFO.TFO_BMO_MNEMONICO = 'UVR' THEN
            OPEN C_BASE_MONETARIA;
            FETCH C_BASE_MONETARIA
              INTO VALOR;
            CLOSE C_BASE_MONETARIA;

            VALOR_NOMIN := VALOR * C_TFO.TFO_VALOR_NOMINAL;
          ELSE
            VALOR_NOMIN := C_TFO.TFO_VALOR_NOMINAL;
          END IF;

          IF SUBSTR(C_TFO.TFO_ENA_MNEMONICO, 1, 3) = 'TRD' THEN

            DUR         := NVL(ROUND(TRUNC(((TRUNC(C_TFO.TFO_FECHA_VENCIMIENTO) -
                                           TRUNC(SYSDATE - 1)) / 365),
                                           6),
                                     7),
                               0);
            SUM_DUR_FLU := SUM_DUR_FLU + DUR;

          ELSE

            OPEN C_FLUJOS_V;
            FETCH C_FLUJOS_V
              INTO C_FLU;
            WHILE C_FLUJOS_V%FOUND LOOP

              T_DESC := ROUND(TRUNC(POWER(C_TAS.TAS_DES, (C_FLU.DIAS / 365)),
                                    9),
                              10);
              VPN    := ROUND(TRUNC(C_FLU.FLUJO / T_DESC, 9), 10);

              IF C_TAS.PRECIO IS NULL THEN
                IF C_TFO.TFO_BMO_MNEMONICO != 'PESOS' THEN
                  OPEN C_BASE_MONETARIA;
                  FETCH C_BASE_MONETARIA
                    INTO VALOR;
                  CLOSE C_BASE_MONETARIA;

                  DUR := ROUND(TRUNC((VPN * (C_FLU.DIAS / 365)) /
                                     (((VALOR * VALOR_NOMIN) / VALOR_NOMIN) * 100),
                                     8),
                               9);

                ELSE
                  DUR := ROUND(TRUNC((VPN * (C_FLU.DIAS / 365)) /
                                     (((C_TAS.MRF_VALOR_TITULO_TM) /
                                     VALOR_NOMIN) * 100),
                                     8),
                               9);
                END IF;
              ELSE
                DUR := ROUND(TRUNC((VPN * (C_FLU.DIAS / 365)) /
                                   C_TAS.PRECIO,
                                   8),
                             9);
              END IF;

              DUR         := NVL(DUR, 0);
              SUM_DUR_FLU := SUM_DUR_FLU + DUR;

              FETCH C_FLUJOS_V
                INTO C_FLU;
            END LOOP;
            CLOSE C_FLUJOS_V;

            OPEN C_FLUJOS_U;
            FETCH C_FLUJOS_U
              INTO C_FLU_U;
            WHILE C_FLUJOS_U%FOUND LOOP

              T_DESC := ROUND(TRUNC(POWER(C_TAS.TAS_DES,
                                          (C_FLU_U.DIAS / 365)),
                                    9),
                              10);
              VPN    := ROUND(TRUNC(C_FLU_U.FLUJO / T_DESC, 9), 10);
              IF C_TAS.PRECIO IS NULL THEN
                IF C_TFO.TFO_BMO_MNEMONICO != 'PESOS' THEN
                  OPEN C_BASE_MONETARIA;
                  FETCH C_BASE_MONETARIA
                    INTO VALOR;
                  CLOSE C_BASE_MONETARIA;
                  DBMS_OUTPUT.PUT_LINE('1111');
                  DUR := ROUND(TRUNC((VPN * (C_FLU.DIAS / 365)) /
                                     (((VALOR * VALOR_NOMIN) / VALOR_NOMIN) * 100),
                                     8),
                               9);
                ELSE

                  DUR := ROUND(TRUNC((VPN * (C_FLU_U.DIAS / 365)) /
                                     (((C_TAS.MRF_VALOR_TITULO_TM) /
                                     VALOR_NOMIN) * 100),
                                     8),
                               9);
                END IF;
              ELSE
                DUR := ROUND(TRUNC((VPN * (C_FLU_U.DIAS / 365)) /
                                   C_TAS.PRECIO,
                                   8),
                             9);
              END IF;

              SUM_DUR_FLU := SUM_DUR_FLU + NVL(DUR, 0);

              FETCH C_FLUJOS_U
                INTO C_FLU_U;
            END LOOP;
            CLOSE C_FLUJOS_U;
          END IF;

          ---------------

          IF SUBSTR(C_TFO.TFO_ENA_MNEMONICO, 1, 3) = 'TRD' THEN
            IF C_TFO.TFO_BMO_MNEMONICO != 'PESOS' THEN
              OPEN C_BASE_MONETARIA;
              FETCH C_BASE_MONETARIA
                INTO VALOR;
              CLOSE C_BASE_MONETARIA;

              SUM_VMI_TIT := SUM_VMI_TIT + (VALOR_NOMIN * VALOR);
              VMI_DUR     := VMI_DUR +
                             ((VALOR_NOMIN * VALOR) * SUM_DUR_FLU);
            ELSE
              SUM_VMI_TIT := SUM_VMI_TIT + C_TAS.MRF_VALOR_TITULO_TM;
              VMI_DUR     := VMI_DUR +
                             (C_TAS.MRF_VALOR_TITULO_TM * SUM_DUR_FLU);
            END IF;

          ELSE
            IF C_TAS.PRECIO IS NULL THEN
              IF C_TFO.TFO_BMO_MNEMONICO != 'PESOS' THEN
                OPEN C_BASE_MONETARIA;
                FETCH C_BASE_MONETARIA
                  INTO VALOR;
                CLOSE C_BASE_MONETARIA;

                SUM_VMI_TIT := SUM_VMI_TIT + (VALOR_NOMIN * VALOR);
                VMI_DUR     := VMI_DUR +
                               ((VALOR_NOMIN * VALOR) * SUM_DUR_FLU);
              ELSE
                SUM_VMI_TIT := SUM_VMI_TIT + C_TAS.MRF_VALOR_TITULO_TM;
                VMI_DUR     := VMI_DUR +
                               (C_TAS.MRF_VALOR_TITULO_TM * SUM_DUR_FLU);
              END IF;
            ELSE
              SUM_VMI_TIT := SUM_VMI_TIT +
                             ((C_TAS.PRECIO / 100) * VALOR_NOMIN);
              VMI_DUR     := VMI_DUR + (((C_TAS.PRECIO / 100) * VALOR_NOMIN) *
                             SUM_DUR_FLU);

            END IF;
          END IF;

          SUM_DUR_FLU := 0;

          FETCH C_TITULO_FONDO
            INTO C_TFO;
        END LOOP;
        CLOSE C_TITULO_FONDO;

        ------------DURACION SIMULTANEAS   ----------
        OPEN C_SIMULTANEA;
        FETCH C_SIMULTANEA
          INTO C_SIM;
        LOOP
          EXIT WHEN C_SIMULTANEA%NOTFOUND;

          SUM_DUR_SIM := SUM_DUR_SIM + C_SIM.DURACION;

          SUM_VMI_TIT := SUM_VMI_TIT + C_SIM.TFO_VALOR_NOMINAL;
          VMI_DUR     := VMI_DUR +
                         ((C_SIM.TFO_VALOR_NOMINAL) * SUM_DUR_SIM);

          FETCH C_SIMULTANEA
            INTO C_SIM;
        END LOOP;
        CLOSE C_SIMULTANEA;

        ------------DURACION CUENTAS AHORRO---------

        OPEN C_CUENTAS_BANCARIAS;
        FETCH C_CUENTAS_BANCARIAS
          INTO CBF;
        LOOP
          EXIT WHEN C_CUENTAS_BANCARIAS%NOTFOUND;

          OPEN C_SALDO_CUENTA;
          FETCH C_SALDO_CUENTA
            INTO SAL_C;
          CLOSE C_SALDO_CUENTA;

          SUM_DUR_CUE := SUM_DUR_CUE + SAL_C.DURACION;

          SUM_VMI_TIT := SUM_VMI_TIT + SAL_C.MTF_SALDO;
          VMI_DUR     := VMI_DUR + (SAL_C.MTF_SALDO * SUM_DUR_CUE);

          FETCH C_CUENTAS_BANCARIAS
            INTO CBF;
        END LOOP;
        CLOSE C_CUENTAS_BANCARIAS;

        DUR_FON := ROUND(TRUNC(VMI_DUR / SUM_VMI_TIT, 4), 3);

        RESP := TO_CHAR(TRUNC(DUR_FON, 3), '90.999');

        INSERT INTO DURACIONES_MACAULAY_FONDOS
          (DUMF_FON_CODIGO, DUMF_FECHA, DUMF_DURACION)
        VALUES
          (FONDO.FON_CODIGO, TRUNC(SYSDATE - 1), DUR_FON);
        COMMIT;

        FETCH C_FONDOS
          INTO FONDO;
      END LOOP;
      CLOSE C_FONDOS;
    END IF;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.CALCULO_DUR_MACAULAY',
                                                      'FIN');
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento CALCULO_DUR_MACAULAY',
                              '<br>' ||
                              'Error en el procedimiento P_PROCESOS_NOCTURNOS.CALCULO_DUR_MACAULAY, el ingeniero revisara el dia habil siguiente.' ||
                              SUBSTR(SQLERRM, 1, 80),
                              DESTINA_MACAULAY);
  END CALCULO_DUR_MACAULAY;

  /***********************************************************************************************************************
  ***  PROCEDIMIENTO  P_PROCESOS_NOCTURNOS.PR_NOC_CONV_REC_PAGOS                                                        **
  ***     - realiza llamado a proceso  P_TESORERIA.PR_PAG_REC_DIA  : PROCEDIMIENTO NOCTURNO PARA CONTAR                 **
  ***       EL TOTAL DE RECAUDOS Y PAGOS DIARIOS POR BANCO POR CLIENTE DEL CONVENIO PARA CONVENIOS CON RECIPROCIDAD     **
  ***     -se corre todos los dias                                                                                      **
  /******************************************************************************************************************** */
  PROCEDURE PR_NOC_CONV_REC_PAGOS IS

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_NOC_CONV_REC_PAGOS',
                                                      'INI');

    BEGIN
      P_MAIL.ENVIO_MAIL_ERROR('Inicio proceso nocturno P_TESORERIA.PR_PAG_REC_DIA . ',
                              '<br>' || 'Fecha Proceso: ' || SYSDATE,
                              DESTINATARIOS);
    EXCEPTION
      WHEN OTHERS THEN
        DBMS_OUTPUT.PUT_LINE('-20001 Fallo el llamado al paquete de Mail. ' ||
                             SQLERRM);
    END;
    P_TESORERIA.PR_PAG_REC_DIA(SYSDATE);
    P_MAIL.ENVIO_MAIL_ERROR('Proceso finalizado con EXITO : P_TESORERIA.PR_PAG_REC_DIA. ',
                            '<br>' || 'Fecha Proceso: ' || SYSDATE,
                            DESTINATARIOS);

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_NOC_CONV_REC_PAGOS',
                                                      'FIN');
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('P_TESORERIA.PR_PAG_REC_DIA. Fecha de Proceso' ||
                              SYSDATE || ' ' || SUBSTR(SQLERRM, 1, 80),
                              DESTINATARIOS);
  END PR_NOC_CONV_REC_PAGOS;

