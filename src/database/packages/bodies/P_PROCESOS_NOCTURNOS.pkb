  PROCEDURE P_EJECUTA_REPGAR_DSCB IS
    P_CODIGO       VARCHAR2(200);
    P_RESPUESTA    VARCHAR2(200);
    V_RUTA         VARCHAR2(100);
    NOMBRE_ARCHIVO VARCHAR2(100);

    V_DATOS_1 P_GARANTIAS.V_DATOS_REFCUR;
    V_DATOS_3 P_GARANTIAS.V_DATOS_REFCUR3;
    V_DATOS_5 P_GARANTIAS.V_DATOS_REFCUR5;
    V_DATOS_4 P_GARANTIAS.V_DATOS_REFCUR2;
    V_PRIMERO VARCHAR(1);

    TYPE TIPO_REG IS RECORD(
      V_CCC_CLI_PER_NUM_IDEN   VARCHAR2(15),
      V_CCC_CLI_PER_TID_CODIGO VARCHAR(3),
      V_CCC_NUMERO_CUENTA      NUMBER,
      V_CCC_NOMBRE_CUENTA      VARCHAR(62),
      V_RC_CHEQUES             NUMBER,
      V_RC_CONSIG_CAJA         NUMBER,
      V_RC_TRANSF_CAJA         NUMBER,
      V_RC_CAJA                NUMBER,
      V_ODP                    NUMBER,
      V_ODP_SCB                NUMBER);

    V_REC TIPO_REG;

    TYPE TIPO_REG1 IS RECORD(
      V_CCC_CLI_PER_NUM_IDEN   VARCHAR2(15),
      V_CCC_CLI_PER_TID_CODIGO VARCHAR(3),
      V_CCC_NUMERO_CUENTA      NUMBER,
      V_CCC_NOMBRE_CUENTA      VARCHAR(62),
      V_RC_CHEQUES             NUMBER,
      V_RC_CONSIG_CAJA         NUMBER,
      V_RC_TRANSF_CAJA         NUMBER,
      V_RC_CAJA                NUMBER,
      V_ODP                    NUMBER);

    V_REC1 TIPO_REG1;

    CURSOR C_GAR IS
      SELECT TRG_CCC_CLI_PER_NUM_IDEN,
             TRG_CCC_CLI_PER_TID_CODIGO,
             TRG_CCC_NUMERO_CUENTA,
             TRG_CCC_NOMBRE_CUENTA,
             TRG_RC_CHEQUES,
             TRG_RC_CONSIG_CAJA,
             TRG_RC_TRANSF_CAJA,
             TRG_RC_CAJA,
             TRG_ODP,
             TRG_ODP_SCB,
             CCC_CUENTA_CRCC,
             TRG_FECHA,
             TRG_REPORTE
        FROM TMP_REPORTES_GARANTIAS, CUENTAS_CLIENTE_CORREDORES
       WHERE TRG_CCC_CLI_PER_NUM_IDEN = CCC_CLI_PER_NUM_IDEN
         AND TRG_CCC_CLI_PER_TID_CODIGO = CCC_CLI_PER_TID_CODIGO
         AND TRG_CCC_NUMERO_CUENTA = CCC_NUMERO_CUENTA
         AND TRG_CCC_CLI_PER_NUM_IDEN = CCC_CLI_PER_NUM_IDEN
         AND TRG_CCC_CLI_PER_TID_CODIGO = CCC_CLI_PER_TID_CODIGO;
    R_GAR C_GAR%ROWTYPE;

    V_FECHA DATE;
  BEGIN

    DELETE FROM TMP_REPORTES_GARANTIAS;
    COMMIT;

    V_FECHA := TRUNC(SYSDATE - 1);
    -- SCB
    P_GARANTIAS.PR_GARANTIAS_DER_SCB(V_FECHA, V_DATOS_3);
    LOOP
      FETCH V_DATOS_3
        INTO V_REC;
      EXIT WHEN V_DATOS_3%NOTFOUND;
      INSERT INTO TMP_REPORTES_GARANTIAS
      VALUES
        (V_FECHA,
         V_REC.V_CCC_CLI_PER_NUM_IDEN,
         V_REC.V_CCC_CLI_PER_TID_CODIGO,
         V_REC.V_CCC_NUMERO_CUENTA,
         V_REC.V_CCC_NOMBRE_CUENTA,
         V_REC.V_RC_CHEQUES,
         V_REC.V_RC_CONSIG_CAJA,
         V_REC.V_RC_TRANSF_CAJA,
         V_REC.V_RC_CAJA,
         V_REC.V_ODP,
         V_REC.V_ODP_SCB,
         'DERIVADOS CRCC');
      COMMIT;
    END LOOP;

    -- BVC
    P_GARANTIAS.P_VALOR_GARANTIA_OPCE(V_FECHA, V_DATOS_1);
    LOOP
      FETCH V_DATOS_1
        INTO V_REC1;
      EXIT WHEN V_DATOS_1%NOTFOUND;
      INSERT INTO TMP_REPORTES_GARANTIAS
      VALUES
        (V_FECHA,
         V_REC1.V_CCC_CLI_PER_NUM_IDEN,
         V_REC1.V_CCC_CLI_PER_TID_CODIGO,
         V_REC1.V_CCC_NUMERO_CUENTA,
         V_REC1.V_CCC_NOMBRE_CUENTA,
         V_REC1.V_RC_CHEQUES,
         V_REC1.V_RC_CONSIG_CAJA,
         V_REC1.V_RC_TRANSF_CAJA,
         V_REC1.V_RC_CAJA,
         V_REC1.V_ODP,
         0,
         'GARANTIAS BVC');
      COMMIT;
    END LOOP;

    --CRCC
    P_GARANTIAS.P_VALOR_GARANTIA_CRCC(V_FECHA, V_DATOS_5);
    LOOP
      FETCH V_DATOS_5
        INTO V_REC1;
      EXIT WHEN V_DATOS_5%NOTFOUND;
      INSERT INTO TMP_REPORTES_GARANTIAS
      VALUES
        (V_FECHA,
         V_REC1.V_CCC_CLI_PER_NUM_IDEN,
         V_REC1.V_CCC_CLI_PER_TID_CODIGO,
         V_REC1.V_CCC_NUMERO_CUENTA,
         V_REC1.V_CCC_NOMBRE_CUENTA,
         V_REC1.V_RC_CHEQUES,
         V_REC1.V_RC_CONSIG_CAJA,
         V_REC1.V_RC_TRANSF_CAJA,
         V_REC1.V_RC_CAJA,
         V_REC1.V_ODP,
         0,
         'GARANTIAS CRCC');
      COMMIT;
    END LOOP;

    --GAR REPOS
    P_GARANTIAS.P_VALOR_GARANTIA_DER(V_FECHA, V_DATOS_4);
    LOOP
      FETCH V_DATOS_4
        INTO V_REC1;
      EXIT WHEN V_DATOS_4%NOTFOUND;
      INSERT INTO TMP_REPORTES_GARANTIAS
      VALUES
        (V_FECHA,
         V_REC1.V_CCC_CLI_PER_NUM_IDEN,
         V_REC1.V_CCC_CLI_PER_TID_CODIGO,
         V_REC1.V_CCC_NUMERO_CUENTA,
         V_REC1.V_CCC_NOMBRE_CUENTA,
         V_REC1.V_RC_CHEQUES,
         V_REC1.V_RC_CONSIG_CAJA,
         V_REC1.V_RC_TRANSF_CAJA,
         V_REC1.V_RC_CAJA,
         V_REC1.V_ODP,
         0,
         'DERIVADOS CRCC');
      COMMIT;
    END LOOP;

    V_FECHA := TRUNC(V_FECHA + 1);

    V_RUTA         := '\\nas.corredor.local\Riesgo\CONFIDENCIAL\Reportes Excel Coeasy\';
    NOMBRE_ARCHIVO := 'REPORTE_GARANTIAS_' ||
                      TO_CHAR(SYSDATE - 1, 'DDMMYYYY_hh24mmss');

    P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => V_RUTA,
                                   P_NOMBRE_ARCHIVO => NOMBRE_ARCHIVO,
                                   P_QUERY          => 'SELECT TO_CHAR(TRG_FECHA,''DD/MM/YYYY'') Fecha, ' ||
                                                       '       TRG_CCC_CLI_PER_NUM_IDEN Identificacion, ' ||
                                                       '       TRG_CCC_CLI_PER_TID_CODIGO Tipo_Id, ' ||
                                                       '       TRG_CCC_NUMERO_CUENTA Numero_Cuenta, ' ||
                                                       '       TRG_CCC_NOMBRE_CUENTA Nombre_Portafolio, ' ||
                                                       '       SUBSTR(CCC_CUENTA_CRCC,0,3) Cuenta_CRCC, ' ||
                                                       '       TRG_RC_CHEQUES Cheques, ' ||
                                                       '       TRG_RC_CONSIG_CAJA Consignaciones, ' ||
                                                       '       TRG_RC_TRANSF_CAJA Transferencias, ' ||
                                                       '       TRG_RC_CAJA Consig_Efectivo, ' ||
                                                       '       TRG_ODP Odp, ' ||
                                                       '       (TRG_ODP+(TRG_RC_CHEQUES+TRG_RC_CONSIG_CAJA+TRG_RC_TRANSF_CAJA+TRG_RC_CAJA)) Saldo_Garantias, ' ||
                                                       '       TRG_REPORTE Tipo_Garantias ' ||
                                                       '  FROM TMP_REPORTES_GARANTIAS,CUENTAS_CLIENTE_CORREDORES ' ||
                                                       ' WHERE TRG_CCC_CLI_PER_NUM_IDEN = CCC_CLI_PER_NUM_IDEN ' ||
                                                       '   AND TRG_CCC_CLI_PER_TID_CODIGO = CCC_CLI_PER_TID_CODIGO ' ||
                                                       '   AND TRG_CCC_NUMERO_CUENTA = CCC_NUMERO_CUENTA ' ||
                                                       ' ORDER BY TRG_FECHA',
                                   P_CODIGO         => P_CODIGO,
                                   P_RESPUESTA      => P_RESPUESTA);
    IF P_CODIGO = '0000' THEN
      DBMS_OUTPUT.PUT_LINE('Se ha generado el archivo, en la ruta ' ||
                           V_RUTA);
    END IF;
  EXCEPTION
    WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20059,
                              'No se genero reporte, comuniquese con soporte, error: ' ||
                              SQLERRM);
  END P_EJECUTA_REPGAR_DSCB;

  PROCEDURE P_EJECUTA_REPGAR_PRORRATEO IS
    P_CODIGO       VARCHAR2(200);
    P_RESPUESTA    VARCHAR2(200);
    V_RUTA         VARCHAR2(100);
    NOMBRE_ARCHIVO VARCHAR2(100);
    V_UTGE_ESTADO  UTILIDADES_GARANTIAS_EFECTIVO.UTGE_ESTADO%TYPE;

    CURSOR C_PRORRATEO IS
      SELECT UTGE_FECHA FECHA,
             UTGE_CCC_CLI_PER_NUM_IDEN NUM_IDEN,
             UTGE_CCC_CLI_PER_TID_CODIGO TID,
             UTGE_CCC_NUMERO_CUENTA NUMERO_CUENTA,
             UTGE_NOMBRE_CUENTA NOMBRE_CUENTA,
             NVL(UTGE_VALOR_ORDENES_PAGO, 0) +
             (NVL(UTGE_VALOR_CHEQUES, 0) + NVL(UTGE_VALOR_CONSIG_CAJA, 0) +
              NVL(UTGE_VALOR_RECIBOS_CAJA, 0) +
              NVL(UTGE_VALOR_TRANSF_CAJA, 0) +
              NVL(UTGE_VALOR_ORDENES_PAGO_SCB, 0)) SALDO_GARANTIAS,
             UTGE_VALOR_UTILIDAD VALOR_UTILIDAD,
             UTGE_GARANTIA_SCB GARANTIA_SCB
        FROM UTILIDADES_GARANTIAS_EFECTIVO
       WHERE UTGE_FECHA >= TRUNC(SYSDATE - 1)
         AND UTGE_FECHA <= TRUNC(SYSDATE)
            --AND UTGE_CCC_CLI_PER_TID_CODIGO =  UTGE_CCC_CLI_PER_TID_CODIGO
            --AND UTGE_CCC_CLI_PER_NUM_IDEN   =  UTGE_CCC_CLI_PER_NUM_IDEN
         AND UTGE_ESTADO = 'APR'
      --AND UTGE_CCC_CLI_PER_NUM_IDEN   =  UTGE_CCC_CLI_PER_NUM_IDEN
      ;
    R_PRORRATEO C_PRORRATEO%ROWTYPE;

    CURSOR C_CUENTA_CRCC(NUM_IDEN      VARCHAR2,
                         TID           VARCHAR2,
                         NUMERO_CUENTA NUMBER) IS
      SELECT NVL(SUBSTR(CCC_CUENTA_CRCC, 0, 3), 0) CUENTA_CRCC
        FROM CUENTAS_CLIENTE_CORREDORES
       WHERE CCC_CLI_PER_NUM_IDEN = NUM_IDEN
         AND CCC_CLI_PER_TID_CODIGO = TID
         AND CCC_NUMERO_CUENTA = NUMERO_CUENTA;
    R_CUENTA_CRCC C_CUENTA_CRCC%ROWTYPE;

    CURSOR C_TOTAL_PRORRATEO(FECHA DATE, NUM_IDEN VARCHAR2) IS
      SELECT NVL(SUM(UTGE_VALOR_UTILIDAD), 0) TOTAL_PRORRATEO
        FROM UTILIDADES_GARANTIAS_EFECTIVO
       WHERE UTGE_FECHA >= TRUNC(FECHA)
         AND UTGE_FECHA <= TRUNC(FECHA + 1)
         AND UTGE_CCC_CLI_PER_NUM_IDEN = NUM_IDEN
       GROUP BY TRUNC(FECHA);
    R_TOTAL_PRORRATEO C_TOTAL_PRORRATEO%ROWTYPE;
  BEGIN

    DELETE FROM TMP_REPORTES_PRORRATEO;
    COMMIT;

    OPEN C_PRORRATEO;
    FETCH C_PRORRATEO
      INTO R_PRORRATEO;
    WHILE C_PRORRATEO%FOUND LOOP
      OPEN C_CUENTA_CRCC(R_PRORRATEO.NUM_IDEN,
                         R_PRORRATEO.TID,
                         R_PRORRATEO.NUMERO_CUENTA);
      FETCH C_CUENTA_CRCC
        INTO R_CUENTA_CRCC;
      CLOSE C_CUENTA_CRCC;
      OPEN C_TOTAL_PRORRATEO(R_PRORRATEO.FECHA, R_PRORRATEO.NUM_IDEN);
      FETCH C_TOTAL_PRORRATEO
        INTO R_TOTAL_PRORRATEO;
      CLOSE C_TOTAL_PRORRATEO;
      INSERT INTO TMP_REPORTES_PRORRATEO
      VALUES
        (R_PRORRATEO.FECHA,
         R_PRORRATEO.NUM_IDEN,
         R_PRORRATEO.TID,
         R_PRORRATEO.NUMERO_CUENTA,
         R_PRORRATEO.NOMBRE_CUENTA,
         R_CUENTA_CRCC.CUENTA_CRCC,
         R_PRORRATEO.SALDO_GARANTIAS,
         R_PRORRATEO.VALOR_UTILIDAD,
         R_TOTAL_PRORRATEO.TOTAL_PRORRATEO,
         R_PRORRATEO.GARANTIA_SCB);
      COMMIT;

      FETCH C_PRORRATEO
        INTO R_PRORRATEO;
    END LOOP;
    CLOSE C_PRORRATEO;

    V_RUTA         := '\\nas.corredor.local\Riesgo\CONFIDENCIAL\Reportes Excel Coeasy\';
    NOMBRE_ARCHIVO := 'PRORRATEO' ||
                      TO_CHAR(SYSDATE - 1, 'DDMMYYYY_hh24mmss');

    P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => V_RUTA,
                                   P_NOMBRE_ARCHIVO => NOMBRE_ARCHIVO,
                                   P_QUERY          => 'SELECT TO_CHAR(TRP_FECHA,''DD/MM/YYYY'') Fecha, ' ||
                                                       '       TRP_CCC_CLI_PER_TID_CODIGO Tipo_Identificacion, ' ||
                                                       '       TRP_CCC_CLI_PER_NUM_IDEN Num_Identificacion, ' ||
                                                       '       TRP_CCC_NUMERO_CUENTA Numero_Cuenta, ' ||
                                                       '       TRP_CCC_NOMBRE_CUENTA Nombre_Cuenta, ' ||
                                                       '       TRP_CUENTA_CRCC Cuenta_CRCC, ' ||
                                                       '       TRP_SALDO_GARANTIAS Saldo_Garantias, ' ||
                                                       '       TRP_RENDIMIENTOS Valor_Rendimientos, ' ||
                                                       '       TRP_TOTAL_PRORRATEO Valor_Prorrateo, ' ||
                                                       '       TRP_GAR_CORREDORES  Gar_Corredores ' ||
                                                       '  FROM TMP_REPORTES_PRORRATEO',
                                   P_CODIGO         => P_CODIGO,
                                   P_RESPUESTA      => P_RESPUESTA);
    IF P_CODIGO = '0000' THEN
      DBMS_OUTPUT.PUT_LINE('Se ha generado el archivo, en la ruta ' ||
                           V_RUTA);
    END IF;
  EXCEPTION
    WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20059,
                              'No se genero reporte, comuniquese con soporte, error: ' ||
                              SQLERRM);
  END P_EJECUTA_REPGAR_PRORRATEO;

  PROCEDURE P_EJECUTA_CODEOR2 IS
    P_CODIGO       VARCHAR2(200);
    P_RESPUESTA    VARCHAR2(200);
    V_RUTA         VARCHAR2(100);
    NOMBRE_ARCHIVO VARCHAR2(100);

    V_COMERCIAL  VARCHAR2(100);
    V_FECHA_PAGO DATE;
    V_IBA        NUMBER;
    V_IBC        NUMBER;
    NOMBRE       VARCHAR2(62);
    V_DIAS_PAGO  NUMBER(20);
    P_NUM_INI    NUMBER;
    P_NUM_FIN    NUMBER;

    CURSOR C2 IS
      SELECT OFO_SUC_CODIGO --- RECAUDOS CON ORR
            ,
             OFO_CONSECUTIVO OFO_CONSECUTIVO,
             OFO_CFO_CCC_CLI_PER_TID_CODIGO,
             OFO_CFO_CCC_CLI_PER_NUM_IDEN,
             OFO_CFO_CCC_NUMERO_CUENTA,
             CCC_NOMBRE_CUENTA,
             FON_CODIGO,
             FON_RAZON_SOCIAL,
             OFO_EOF_CODIGO,
             OFO_TTO_TOF_CODIGO,
             OFO_MONTO,
             0 AS IBA,
             0 AS IBC,
             OFO_TTO_TIT_CODIGO,
             OFO_CARGO_ABONO_CUENTA,
             OFO_FECHA_AUTORIZACION,
             OFO_FECHA_EJECUCION,
             TPA_MNEMONICO AS MNEMONICO,
             TPA_DESCRIPCION,
             ORR_MONTO AS MONTO,
             ORR_CBA_BAN_CODIGO AS BANCO,
             ORR_CBA_NUMERO_CUENTA AS NUMERO_CUENTA,
             FON_BMO_MNEMONICO,
             FON_TIPO,
             NULL AS ODP_SUC_CODIGO,
             NULL AS ODP_CONSECUTIVO,
             NULL AS ODP_TBC_CONSECUTIVO,
             NULL AS ODP_TCC_CONSECUTIVO,
             NULL AS ODP_CEG_CONSECUTIVO,
             NULL AS ODP_CGE_CONSECUTIVO,
             NULL AS ODP_FECHA_EJECUCION,
             OFO_DESCRIPCION,
             CCC_PER_NUM_IDEN,
             CCC_PER_TID_CODIGO,
             OFO_FECHA_RECEPCION,
             OFO_HORA_RECEPCION,
             DECODE(OFO_MEDIO_RECEPCION,
                    'TEL',
                    'EXTENSION',
                    'FAX',
                    'FAX',
                    'MSN',
                    'MESSENGER',
                    'COE',
                    'CORREO ELECTRONICO',
                    'PSE',
                    'PRESENCIAL CON SOPORTE ESCRITO',
                    'NO DEFINIDO') OFO_MEDIO_RECEPCION,
             OFO_DETALLE_MEDIO_RECEPCION
        FROM ORDENES_FONDOS,
             FONDOS,
             CUENTAS_CLIENTE_CORREDORES,
             ORDENES_RECAUDO,
             TIPOS_PAGO
       WHERE OFO_CFO_FON_CODIGO = FON_CODIGO
         AND OFO_CFO_CCC_CLI_PER_NUM_IDEN = CCC_CLI_PER_NUM_IDEN
         AND OFO_CFO_CCC_CLI_PER_TID_CODIGO = CCC_CLI_PER_TID_CODIGO
         AND OFO_CFO_CCC_NUMERO_CUENTA = CCC_NUMERO_CUENTA
         AND OFO_CFO_FON_CODIGO = FON_CODIGO
         AND OFO_SUC_CODIGO = ORR_OFO_SUC_CODIGO
         AND OFO_CONSECUTIVO = ORR_OFO_CONSECUTIVO
         AND ORR_TPA_MNEMONICO = TPA_MNEMONICO
         AND OFO_FECHA_EJECUCION >= TRUNC(SYSDATE - 1)
         AND OFO_FECHA_EJECUCION < TRUNC(SYSDATE - 1) + 1
         AND OFO_TTO_TIT_CODIGO = 'CAR'
      UNION ALL -- RECAUDOS CON DAU
      SELECT OFO_SUC_CODIGO,
             OFO_CONSECUTIVO,
             OFO_CFO_CCC_CLI_PER_TID_CODIGO,
             OFO_CFO_CCC_CLI_PER_NUM_IDEN,
             OFO_CFO_CCC_NUMERO_CUENTA,
             CCC_NOMBRE_CUENTA,
             FON_CODIGO,
             FON_RAZON_SOCIAL,
             OFO_EOF_CODIGO,
             OFO_TTO_TOF_CODIGO,
             OFO_MONTO,
             0                              AS IBA,
             0                              AS IBC,
             OFO_TTO_TIT_CODIGO,
             OFO_CARGO_ABONO_CUENTA,
             OFO_FECHA_AUTORIZACION,
             OFO_FECHA_EJECUCION,
             TIU_MNEMONICO                  AS MNEMONICO,
             TIU_DESCRIPCION,
             DAU_VALOR,
             NULL                           AS BANCO,
             NULL                           AS NUMERO_CUENTA,
             FON_BMO_MNEMONICO,
             FON_TIPO,
             NULL                           AS ODP_SUC_CODIGO,
             NULL                           AS ODP_CONSECUTIVO,
             NULL                           AS ODP_TBC_CONSECUTIVO,
             NULL                           AS ODP_TCC_CONSECUTIVO,
             NULL                           AS ODP_CEG_CONSECUTIVO,
             NULL                           AS ODP_CGE_CONSECUTIVO,
             NULL                           AS ODP_FECHA_EJECUCION,
             OFO_DESCRIPCION,
             CCC_PER_NUM_IDEN,
             CCC_PER_TID_CODIGO,
             OFO_FECHA_RECEPCION,
             OFO_HORA_RECEPCION,
             OFO_MEDIO_RECEPCION,
             OFO_DETALLE_MEDIO_RECEPCION
        FROM ORDENES_FONDOS,
             FONDOS,
             CUENTAS_CLIENTE_CORREDORES,
             DETALLES_CARGOS_CUENTAS,
             TIPOS_CARGOS_CUENTAS
       WHERE OFO_CFO_FON_CODIGO = FON_CODIGO
         AND OFO_CFO_CCC_CLI_PER_NUM_IDEN = CCC_CLI_PER_NUM_IDEN
         AND OFO_CFO_CCC_CLI_PER_TID_CODIGO = CCC_CLI_PER_TID_CODIGO
         AND OFO_CFO_CCC_NUMERO_CUENTA = CCC_NUMERO_CUENTA
         AND OFO_CFO_FON_CODIGO = FON_CODIGO
         AND OFO_SUC_CODIGO = DAU_OFO_SUC_CODIGO
         AND OFO_CONSECUTIVO = DAU_OFO_CONSECUTIVO
         AND DAU_TIU_MNEMONICO = TIU_MNEMONICO
         AND OFO_FECHA_EJECUCION >= TRUNC(SYSDATE - 1)
         AND OFO_FECHA_EJECUCION < TRUNC(SYSDATE - 1) + 1
         AND OFO_TTO_TIT_CODIGO = 'CAR'
      UNION ALL -- EGRESOS CON ODP
      SELECT OFO_SUC_CODIGO,
             OFO_CONSECUTIVO,
             OFO_CFO_CCC_CLI_PER_TID_CODIGO,
             OFO_CFO_CCC_CLI_PER_NUM_IDEN,
             OFO_CFO_CCC_NUMERO_CUENTA,
             CCC_NOMBRE_CUENTA,
             FON_CODIGO,
             FON_RAZON_SOCIAL,
             OFO_EOF_CODIGO,
             OFO_TTO_TOF_CODIGO,
             OFO_MONTO,
             NULL                           AS IBA,
             NULL                           AS IBC,
             OFO_TTO_TIT_CODIGO,
             OFO_CARGO_ABONO_CUENTA,
             OFO_FECHA_AUTORIZACION,
             OFO_FECHA_EJECUCION,
             TPA_MNEMONICO                  AS MNEMONICO,
             TPA_DESCRIPCION,
             ODP_MONTO_ORDEN                AS MONTO,
             ODP_BAN_CODIGO                 AS BANCO,
             NULL                           AS NUMERO_CUENTA,
             FON_BMO_MNEMONICO,
             FON_TIPO,
             ODP_SUC_CODIGO                 AS ODP_SUC_CODIGO,
             ODP_CONSECUTIVO                AS ODP_CONSECUTIVO,
             ODP_TBC_CONSECUTIVO            AS ODP_TBC_CONSECUTIVO,
             ODP_TCC_CONSECUTIVO            AS ODP_TCC_CONSECUTIVO,
             ODP_CEG_CONSECUTIVO            AS ODP_CEG_CONSECUTIVO,
             ODP_CGE_CONSECUTIVO            AS ODP_CGE_CONSECUTIVO,
             ODP_FECHA_EJECUCION            AS ODP_FECHA_EJECUCION,
             OFO_DESCRIPCION,
             CCC_PER_NUM_IDEN,
             CCC_PER_TID_CODIGO,
             OFO_FECHA_RECEPCION,
             OFO_HORA_RECEPCION,
             OFO_MEDIO_RECEPCION,
             OFO_DETALLE_MEDIO_RECEPCION
        FROM ORDENES_FONDOS,
             FONDOS,
             CUENTAS_CLIENTE_CORREDORES,
             ORDENES_DE_PAGO,
             TIPOS_PAGO
       WHERE OFO_CFO_FON_CODIGO = FON_CODIGO
         AND OFO_CFO_CCC_CLI_PER_NUM_IDEN = CCC_CLI_PER_NUM_IDEN
         AND OFO_CFO_CCC_CLI_PER_TID_CODIGO = CCC_CLI_PER_TID_CODIGO
         AND OFO_CFO_CCC_NUMERO_CUENTA = CCC_NUMERO_CUENTA
         AND OFO_CFO_FON_CODIGO = FON_CODIGO
         AND OFO_SUC_CODIGO = ODP_OFO_SUC_CODIGO
         AND OFO_CONSECUTIVO = ODP_OFO_CONSECUTIVO
         AND ODP_TPA_MNEMONICO = TPA_MNEMONICO
         AND OFO_FECHA_EJECUCION >= TRUNC(SYSDATE - 1)
         AND OFO_FECHA_EJECUCION < TRUNC(SYSDATE - 1) + 1
         AND OFO_TTO_TIT_CODIGO = 'ABO'
      UNION ALL -- EGRESOS CON DAA
      SELECT OFO_SUC_CODIGO,
             OFO_CONSECUTIVO,
             OFO_CFO_CCC_CLI_PER_TID_CODIGO,
             OFO_CFO_CCC_CLI_PER_NUM_IDEN,
             OFO_CFO_CCC_NUMERO_CUENTA,
             CCC_NOMBRE_CUENTA,
             FON_CODIGO,
             FON_RAZON_SOCIAL,
             OFO_EOF_CODIGO,
             OFO_TTO_TOF_CODIGO,
             OFO_MONTO,
             NULL                           AS IBA,
             NULL                           AS IBC,
             OFO_TTO_TIT_CODIGO,
             OFO_CARGO_ABONO_CUENTA,
             OFO_FECHA_AUTORIZACION,
             OFO_FECHA_EJECUCION,
             TAC_MNEMONICO                  AS MNEMONICO,
             TAC_DESCRIPCION,
             DAA_VALOR,
             NULL                           AS BANCO,
             NULL                           AS NUMERO_CUENTA,
             FON_BMO_MNEMONICO,
             FON_TIPO,
             NULL                           AS ODP_SUC_CODIGO,
             NULL                           AS ODP_CONSECUTIVO,
             NULL                           AS ODP_TBC_CONSECUTIVO,
             NULL                           AS ODP_TCC_CONSECUTIVO,
             NULL                           AS ODP_CEG_CONSECUTIVO,
             NULL                           AS ODP_CGE_CONSECUTIVO,
             NULL                           AS ODP_FECHA_EJECUCION,
             OFO_DESCRIPCION,
             CCC_PER_NUM_IDEN,
             CCC_PER_TID_CODIGO,
             OFO_FECHA_RECEPCION,
             OFO_HORA_RECEPCION,
             OFO_MEDIO_RECEPCION,
             OFO_DETALLE_MEDIO_RECEPCION
        FROM ORDENES_FONDOS,
             FONDOS,
             CUENTAS_CLIENTE_CORREDORES,
             DETALLES_ABONOS_CUENTAS,
             TIPOS_ABONOS_CUENTAS
       WHERE OFO_CFO_FON_CODIGO = FON_CODIGO
         AND OFO_CFO_CCC_CLI_PER_NUM_IDEN = CCC_CLI_PER_NUM_IDEN
         AND OFO_CFO_CCC_CLI_PER_TID_CODIGO = CCC_CLI_PER_TID_CODIGO
         AND OFO_CFO_CCC_NUMERO_CUENTA = CCC_NUMERO_CUENTA
         AND OFO_CFO_FON_CODIGO = FON_CODIGO
         AND OFO_SUC_CODIGO = DAA_OFO_SUC_CODIGO
         AND OFO_CONSECUTIVO = DAA_OFO_CONSECUTIVO
         AND DAA_TAC_MNEMONICO = TAC_MNEMONICO
         AND OFO_FECHA_EJECUCION >= TRUNC(SYSDATE - 1)
         AND OFO_FECHA_EJECUCION < TRUNC(SYSDATE - 1) + 1
         AND OFO_TTO_TIT_CODIGO = 'ABO';

    C_ORD1 C2%ROWTYPE;

    CURSOR C_COMERCIAL(P_NUM_IDEN VARCHAR2, P_TIP_CODIGO VARCHAR2) IS
      SELECT PER_NOMBRE
        FROM FILTRO_PERSONAS
       WHERE PER_NUM_IDEN = P_NUM_IDEN
         AND PER_TID_CODIGO = P_TIP_CODIGO
         AND PER_ES_CORREDOR = 'S';

    CURSOR C_VALOR_PAR(TIPO NUMBER, P_FONDO VARCHAR2) IS
      SELECT PFO_RANGO_MIN_NUMBER, PFO_RANGO_MAX_NUMBER
        FROM PARAMETROS_FONDOS A
       WHERE PFO_FON_CODIGO = P_FONDO
         AND A.PFO_PAR_CODIGO = TIPO;
    PFO1 C_VALOR_PAR%ROWTYPE;

    CURSOR C_FECHA_CUMP(P_OFO_CONSEC NUMBER) IS
      SELECT OFO_FECHA_CUMPLIMIENTO
        FROM ORDENES_FONDOS
       WHERE OFO_CONSECUTIVO = P_OFO_CONSEC;

    CURSOR C_IBA(P_SUC VARCHAR2, P_CONSEC NUMBER) IS
      SELECT NVL(SUM(MTF_DEBITO - MTF_CREDITO), 0)
        FROM MOVIMIENTOS_TESORERIA_FONDOS
       WHERE MTF_OFO_SUC_CODIGO = P_SUC
         AND MTF_OFO_CONSECUTIVO = P_CONSEC
         AND MTF_TTE_MNEMONICO = 'IBA';

    CURSOR C_IBC(P_SUC_CODIGO VARCHAR2, P_CONSEC NUMBER) IS
      SELECT NVL(SUM(MCA_VALOR), 0)
        FROM MOVIMIENTOS_CARGOS_ABONOS
       WHERE MCA_OFO_SUC_CODIGO = P_SUC_CODIGO
         AND MCA_OFO_CONSECUTIVO = P_CONSEC
         AND MCA_TIPO_MOVIMIENTO = 'IBC';
  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_GENERA_REPORTES_RIESGOS - P_EJECUTA_CODEOR2',
                                                      'INI');

    DELETE FROM GL_CODEOR2;
    COMMIT;

    OPEN C2;
    FETCH C2
      INTO C_ORD1;
    WHILE C2%FOUND LOOP

      OPEN C_COMERCIAL(C_ORD1.OFO_CFO_CCC_CLI_PER_NUM_IDEN,
                       C_ORD1.OFO_CFO_CCC_CLI_PER_TID_CODIGO);
      FETCH C_COMERCIAL
        INTO NOMBRE;
      CLOSE C_COMERCIAL;
      V_COMERCIAL := NOMBRE;

      OPEN C_VALOR_PAR(96, C_ORD1.FON_CODIGO);
      FETCH C_VALOR_PAR
        INTO PFO1;
      IF C_VALOR_PAR%NOTFOUND THEN
        PFO1.PFO_RANGO_MIN_NUMBER := 0;
      END IF;
      V_DIAS_PAGO := NVL(PFO1.PFO_RANGO_MIN_NUMBER, 0);
      CLOSE C_VALOR_PAR;
      IF V_DIAS_PAGO > 0 THEN
        OPEN C_FECHA_CUMP(C_ORD1.OFO_CONSECUTIVO);
        FETCH C_FECHA_CUMP
          INTO V_FECHA_PAGO;
        IF C_FECHA_CUMP%NOTFOUND THEN
          V_FECHA_PAGO := NULL;
        END IF;
        CLOSE C_FECHA_CUMP;
      ELSE
        V_DIAS_PAGO  := NULL;
        V_FECHA_PAGO := NULL;
      END IF;

      OPEN C_IBA(C_ORD1.OFO_SUC_CODIGO, C_ORD1.OFO_CONSECUTIVO);
      FETCH C_IBA
        INTO V_IBA;
      IF C_IBA%NOTFOUND THEN
        V_IBA := 0;
      END IF;
      CLOSE C_IBA;

      OPEN C_IBC(C_ORD1.OFO_SUC_CODIGO, C_ORD1.OFO_CONSECUTIVO);
      FETCH C_IBC
        INTO V_IBC;
      IF C_IBC%NOTFOUND THEN
        V_IBC := 0;
      END IF;
      CLOSE C_IBC;

      BEGIN
        INSERT INTO GL_CODEOR2
        VALUES
          (C_ORD1.FON_CODIGO,
           C_ORD1.FON_RAZON_SOCIAL,
           C_ORD1.OFO_SUC_CODIGO,
           C_ORD1.OFO_CONSECUTIVO,
           C_ORD1.OFO_CFO_CCC_CLI_PER_TID_CODIGO,
           C_ORD1.OFO_CFO_CCC_CLI_PER_NUM_IDEN,
           C_ORD1.OFO_CFO_CCC_NUMERO_CUENTA,
           C_ORD1.CCC_NOMBRE_CUENTA,
           C_ORD1.OFO_EOF_CODIGO,
           C_ORD1.OFO_TTO_TOF_CODIGO,
           C_ORD1.OFO_MONTO,
           V_IBA,
           V_IBC,
           C_ORD1.OFO_TTO_TIT_CODIGO,
           C_ORD1.OFO_CARGO_ABONO_CUENTA,
           C_ORD1.OFO_FECHA_AUTORIZACION,
           C_ORD1.OFO_FECHA_EJECUCION,
           C_ORD1.MNEMONICO,
           C_ORD1.TPA_DESCRIPCION,
           C_ORD1.MONTO,
           C_ORD1.BANCO,
           C_ORD1.NUMERO_CUENTA,
           C_ORD1.ODP_SUC_CODIGO,
           C_ORD1.ODP_CONSECUTIVO,
           C_ORD1.ODP_FECHA_EJECUCION,
           C_ORD1.ODP_TBC_CONSECUTIVO,
           C_ORD1.ODP_TCC_CONSECUTIVO,
           C_ORD1.ODP_CEG_CONSECUTIVO,
           C_ORD1.ODP_CGE_CONSECUTIVO,
           C_ORD1.OFO_DESCRIPCION,
           V_COMERCIAL,
           V_FECHA_PAGO,
           C_ORD1.OFO_FECHA_RECEPCION,
           C_ORD1.OFO_HORA_RECEPCION,
           C_ORD1.OFO_MEDIO_RECEPCION,
           C_ORD1.OFO_DETALLE_MEDIO_RECEPCION);
        COMMIT;

      EXCEPTION
        WHEN OTHERS THEN
          RAISE_APPLICATION_ERROR(-20059,
                                  'No se genero reporte, comuniquese con soporte, error: ' ||
                                  SQLERRM);
      END;

      FETCH C2
        INTO C_ORD1;
    END LOOP;
    CLOSE C2;

    V_RUTA         := '\\nas.corredor.local\Riesgo\CONFIDENCIAL\Reportes Excel Coeasy\';
    NOMBRE_ARCHIVO := 'CODEOR_' ||
                      TO_CHAR(SYSDATE - 1, 'DDMMYYYY_hh24mmss');

    P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => V_RUTA,
                                   P_NOMBRE_ARCHIVO => NOMBRE_ARCHIVO,
                                   P_QUERY          => 'SELECT FON_CODIGO ' ||
                                                       '     , FON_RAZON_SOCIAL ' ||
                                                       '     , SUC ' ||
                                                       '     , NRO_ORDEN ' ||
                                                       '     , T_ID ' ||
                                                       '     , NUM_ID ' ||
                                                       '     , C ' ||
                                                       '     , CLIENTE ' ||
                                                       '     , ESTADO ' ||
                                                       '     , TIPO ' ||
                                                       '     , MONTO_ORDEN ' ||
                                                       '     , IBA ' ||
                                                       '     , IBC ' ||
                                                       '     , TIPO_FP ' ||
                                                       '     , CARGO_ABONO ' ||
                                                       '     , FECHA_AUTORIZACION ' ||
                                                       '     , FECHA_EJECUCION ' ||
                                                       '     , TIPO_PAGO ' ||
                                                       '     , TPA_DESCRIPCION ' ||
                                                       '     , MONTO ' ||
                                                       '     , BANCO ' ||
                                                       '     , NUMERO_CUENTA ' ||
                                                       '     , OP_SUC ' ||
                                                       '     , OP_CONS ' ||
                                                       '     , OP_FECHA ' ||
                                                       '     , OP_TBC ' ||
                                                       '     , OP_TCC ' ||
                                                       '     , OP_CEG ' ||
                                                       '     , OP_CGE ' ||
                                                       '     , OBSERVACIONES ' ||
                                                       '     , COMERCIAL ' ||
                                                       '     , FECHA_PAGO ' ||
                                                       '     , FECHA_RECEPCION ' ||
                                                       '     , HORA_RECEPCION ' ||
                                                       '     , MEDIO_RECEPCION ' ||
                                                       '     , DETALLE_MEDIO_RECEPCION ' ||
                                                       '  FROM GL_CODEOR2',
                                   P_CODIGO         => P_CODIGO,
                                   P_RESPUESTA      => P_RESPUESTA);
    IF P_CODIGO = '0000' THEN
      DBMS_OUTPUT.PUT_LINE('Se ha generado el archivo, en la ruta ' ||
                           V_RUTA);
    END IF;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_GENERA_REPORTES_RIESGOS - P_EJECUTA_CODEOR2',
                                                      'FIN');
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20059,
                              'No se genero reporte, comuniquese con soporte, error: ' ||
                              SQLERRM);
  END P_EJECUTA_CODEOR2;

  PROCEDURE P_EJECUTA_COORRE IS
    P_CODIGO       VARCHAR2(200);
    P_RESPUESTA    VARCHAR2(200);
    V_RUTA         VARCHAR2(100);
    NOMBRE_ARCHIVO VARCHAR2(100);
    P_NUM_INI      NUMBER;
    P_NUM_FIN      NUMBER;

    CURSOR C_FONDO(CODIGO VARCHAR2) IS
      SELECT FON_RAZON_SOCIAL FROM FONDOS WHERE FON_CODIGO = CODIGO;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_GENERA_REPORTES_RIESGOS - P_EJECUTA_COORRE',
                                                      'INI');

    DELETE FROM TMP_REORRE;
    COMMIT;

    INSERT INTO TMP_REORRE
      (TREO_FECHA_CONSULTA,
       TREO_FONDO,
       TREO_UPF_OFO_CONSECUTIVO,
       TREO_UPF_OFO_CONSECUTIVO_R,
       TREO_PER_NOMBRE,
       TREO_UPF_FECHA_DISPONIBLE,
       TREO_UPF_FECHA_PAGO,
       TREO_DSP_VALOR_AL_DIA,
       TREO_DSP_PORCENTAJE_PENALIZACI,
       TREO_DSP_PENALIZACION,
       TREO_DSP_VALOR_NETO,
       TREO_UPF_INSTRUCCION,
       TREO_UPF_MONTO_RETIRO,
       TREO_UPF_DSP_SALDO_INVER,
       TREO_UPF_FECHA,
       TREO_UPF_CFO_CCC_CLI_PER_NUM_I,
       TREO_UPF_CFO_CCC_CLI_PER_TID_C,
       TREO_UPF_CFO_CCC_NUMERO_CUENTA,
       TREO_UPF_CFO_FON_CODIGO,
       TREO_UPF_CFO_CODIGO)
      SELECT A.FECHA_CONSULTA,
             F.FON_RAZON_SOCIAL,
             A.HIS_UPF_CONSECUTIVO,
             A.HIS_UPF_OFO_SUC_CODIGO_R,
             A.HIS_CLIENTE,
             A.HIS_UPF_FECHA_DISPONIBLE,
             A.HIS_UPF_FECHA_PAGO,
             A.HIS_DSP_VALOR_AL_DIA,
             A.HIS_DSP_PORCENTAJE_PENALIZACI,
             A.HIS_DSP_PENALIZACION,
             A.HIS_DSP_VALOR_NETO,
             A.HIS_UPF_INSTRUCCION,
             A.HIS_UPF_MONTO_RETIRO,
             A.HIS_DSP_SALDO_INVER,
             A.HIS_UPF_FECHA,
             A.HIS_UPF_CFO_CCC_CLI_PER_NUM_I,
             A.HIS_UPF_CFO_CCC_CLI_PER_TID_C,
             A.HIS_UPF_CFO_CCC_NUMERO_CUENTA,
             A.HIS_UPF_CFO_FON_CODIGO,
             A.HIS_UPF_CFO_CODIGO
        FROM (SELECT FECHA_CONSULTA,
                     HIS_UPF_CONSECUTIVO,
                     HIS_UPF_OFO_SUC_CODIGO_R,
                     HIS_CLIENTE,
                     HIS_UPF_FECHA_DISPONIBLE,
                     HIS_UPF_FECHA_PAGO,
                     HIS_DSP_VALOR_AL_DIA,
                     HIS_DSP_PORCENTAJE_PENALIZACI,
                     HIS_DSP_PENALIZACION,
                     HIS_DSP_VALOR_NETO,
                     HIS_UPF_INSTRUCCION,
                     HIS_UPF_MONTO_RETIRO,
                     HIS_DSP_SALDO_INVER,
                     HIS_UPF_FECHA,
                     HIS_UPF_CFO_CCC_CLI_PER_NUM_I,
                     HIS_UPF_CFO_CCC_CLI_PER_TID_C,
                     HIS_UPF_CFO_CCC_NUMERO_CUENTA,
                     HIS_UPF_CFO_FON_CODIGO,
                     HIS_UPF_CFO_CODIGO
                FROM HIS_UNIDADES_PENALIZACIONES_F
               WHERE EXISTS (SELECT 'X'
                        FROM CUENTAS_CLIENTE_CORREDORES
                       WHERE CCC_CLI_PER_NUM_IDEN =
                             HIS_UPF_CFO_CCC_CLI_PER_NUM_I
                         AND CCC_CLI_PER_TID_CODIGO =
                             HIS_UPF_CFO_CCC_CLI_PER_TID_C
                         AND CCC_NUMERO_CUENTA =
                             HIS_UPF_CFO_CCC_NUMERO_CUENTA)
                 AND HIS_UPF_INSTRUCCION IS NOT NULL
                 AND TRUNC(FECHA_CONSULTA) BETWEEN TRUNC(SYSDATE - 1) AND
                     TRUNC(SYSDATE)) A,
             FONDOS F
       WHERE F.FON_CODIGO = A.HIS_UPF_CFO_FON_CODIGO
      UNION
      SELECT A.FECHA_CONSULTA,
             F.FON_RAZON_SOCIAL,
             A.HIS_UPF_CONSECUTIVO,
             A.HIS_UPF_OFO_SUC_CODIGO_R,
             A.HIS_CLIENTE,
             A.HIS_UPF_FECHA_DISPONIBLE,
             A.HIS_UPF_FECHA_PAGO,
             A.HIS_DSP_VALOR_AL_DIA,
             A.HIS_DSP_PORCENTAJE_PENALIZACI,
             A.HIS_DSP_PENALIZACION,
             A.HIS_DSP_VALOR_NETO,
             A.HIS_UPF_INSTRUCCION,
             A.HIS_UPF_MONTO_RETIRO,
             A.HIS_DSP_SALDO_INVER,
             A.HIS_UPF_FECHA,
             A.HIS_UPF_CFO_CCC_CLI_PER_NUM_I,
             A.HIS_UPF_CFO_CCC_CLI_PER_TID_C,
             A.HIS_UPF_CFO_CCC_NUMERO_CUENTA,
             A.HIS_UPF_CFO_FON_CODIGO,
             A.HIS_UPF_CFO_CODIGO
        FROM (SELECT FECHA_CONSULTA,
                     HIS_UPF_CONSECUTIVO,
                     HIS_UPF_OFO_SUC_CODIGO_R,
                     HIS_CLIENTE,
                     HIS_UPF_FECHA_DISPONIBLE,
                     HIS_UPF_FECHA_PAGO,
                     HIS_DSP_VALOR_AL_DIA,
                     HIS_DSP_PORCENTAJE_PENALIZACI,
                     HIS_DSP_PENALIZACION,
                     HIS_DSP_VALOR_NETO,
                     HIS_UPF_INSTRUCCION,
                     HIS_UPF_MONTO_RETIRO,
                     HIS_DSP_SALDO_INVER,
                     HIS_UPF_FECHA,
                     HIS_UPF_CFO_CCC_CLI_PER_NUM_I,
                     HIS_UPF_CFO_CCC_CLI_PER_TID_C,
                     HIS_UPF_CFO_CCC_NUMERO_CUENTA,
                     HIS_UPF_CFO_FON_CODIGO,
                     HIS_UPF_CFO_CODIGO
                FROM HIS_UNIDADES_PENALIZACIONES_F
               WHERE EXISTS (SELECT 'X'
                        FROM CUENTAS_CLIENTE_CORREDORES
                       WHERE CCC_CLI_PER_NUM_IDEN =
                             HIS_UPF_CFO_CCC_CLI_PER_NUM_I
                         AND CCC_CLI_PER_TID_CODIGO =
                             HIS_UPF_CFO_CCC_CLI_PER_TID_C
                         AND CCC_NUMERO_CUENTA =
                             HIS_UPF_CFO_CCC_NUMERO_CUENTA)
                 AND (HIS_DSP_SALDO_INVER != 0 AND
                     HIS_UPF_INSTRUCCION IS NULL)
                 AND TRUNC(FECHA_CONSULTA) BETWEEN TRUNC(SYSDATE - 1) AND
                     TRUNC(SYSDATE)) A,
             FONDOS F
       WHERE F.FON_CODIGO = A.HIS_UPF_CFO_FON_CODIGO;
    COMMIT;

    V_RUTA := '\\nas.corredor.local\Riesgo\CONFIDENCIAL\Reportes Excel Coeasy\';
    --V_RUTA := '\\nas.corredor.local\Presentaciones\';
    NOMBRE_ARCHIVO := 'COORRE_' ||
                      TO_CHAR(SYSDATE - 1, 'DDMMYYYY_hh24mmss');

    P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => V_RUTA,
                                   P_NOMBRE_ARCHIVO => NOMBRE_ARCHIVO,
                                   P_QUERY          => 'SELECT TO_CHAR(TREO_FECHA_CONSULTA,' ||
                                                       '''dd/mm/yyyy''' ||
                                                       ') FECHA_CONSULTA, ' ||
                                                       '       TREO_FONDO FONDO, ' ||
                                                       '       TREO_UPF_OFO_CONSECUTIVO ORDEN_ING_INC, ' ||
                                                       '       TREO_UPF_OFO_CONSECUTIVO_R ORDEN_RETIRO, ' ||
                                                       '       TREO_PER_NOMBRE CLIENTE, ' ||
                                                       '       TREO_UPF_FECHA_DISPONIBLE FECHA_VTO_APORTE, ' ||
                                                       '       TREO_UPF_FECHA_PAGO FECHA_PAGO_VTO, ' ||
                                                       '       TREO_DSP_VALOR_AL_DIA VALOR_AL_DIA, ' ||
                                                       '       TREO_DSP_PORCENTAJE_PENALIZACI PORCENTAJE_PENAL, ' ||
                                                       '       TREO_DSP_PENALIZACION PENALIZACION, ' ||
                                                       '       TREO_DSP_VALOR_NETO VALOR_NETO, ' ||
                                                       '       TREO_UPF_INSTRUCCION INSTRUCCION, ' ||
                                                       '       TREO_UPF_MONTO_RETIRO MONTO_RETIRO, ' ||
                                                       '       TREO_UPF_DSP_SALDO_INVER SALDO_INVERSION, ' ||
                                                       '       TO_CHAR(TREO_UPF_FECHA,' ||
                                                       '''dd/mm/yyyy''' ||
                                                       ') FECHA_INGRESO, ' ||
                                                       '       TREO_UPF_CFO_CCC_CLI_PER_NUM_I NO_IDEN, ' ||
                                                       '       TREO_UPF_CFO_CCC_CLI_PER_TID_C TI, ' ||
                                                       '       TREO_UPF_CFO_CCC_NUMERO_CUENTA CTA, ' ||
                                                       '       TREO_UPF_CFO_FON_CODIGO FONDO, ' ||
                                                       '       TREO_UPF_CFO_CODIGO APORTE ' ||
                                                       '  FROM TMP_REORRE',
                                   P_CODIGO         => P_CODIGO,
                                   P_RESPUESTA      => P_RESPUESTA);
    IF P_CODIGO = '0000' THEN
      DBMS_OUTPUT.PUT_LINE('Se ha generado el archivo, en la ruta ' ||
                           V_RUTA);
    END IF;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_GENERA_REPORTES_RIESGOS - P_EJECUTA_COORRE',
                                                      'FIN');
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20059,
                              'No se genero reporte, comuniquese con soporte, error: ' ||
                              SQLERRM);
  END P_EJECUTA_COORRE;

  ---------------------------FIN REPORTES PLANO INTEGRADO 5 PARTE B - JCALDERON -------------------------

  ----------------------INICIO CORREO LIMCOS PLANO INTEGRADO 5 PARTE B - JCALDERON ----------------------

  PROCEDURE P_CORREO_EXCESO_CONSUMO_LIMCOS IS

    CURSOR C_MAIL IS
      SELECT LCCT_NIT_CONTRAPARTE ID,
             LCCT_CONTRAPARTE CONTRAPARTE,
             LCCT_LIMITE_CONTRA_95_COP LIMITE_95,
             LCCT_CONSUMO_CIERRE CONSUMO_CIERRE,
             ABS(LCCT_LIMITE_CONTRA_95_COP - LCCT_CONSUMO_CIERRE) DIFERENCIA
        FROM LIMITES_CONSUMO_CONTRAPARTES
       WHERE LCCT_EXCESO = 'S'

         AND LCCT_FECHA = TRUNC(SYSDATE - 1);
    V_MAIL C_MAIL%ROWTYPE;

    P_CLI_PER_TID_CODIGO NOTIFICACIONES_MAIL_CORREDORES.NMC_CLI_PER_TID_CODIGO%TYPE;
    P_CLI_PER_NUM_IDEN   NOTIFICACIONES_MAIL_CORREDORES.NMC_CLI_PER_NUM_IDEN%TYPE;
    P_SERVICIO           NOTIFICACIONES_MAIL_CORREDORES.NMC_SERVICIO%TYPE;
    P_DE                 NOTIFICACIONES_MAIL_CORREDORES.NMC_DE%TYPE;
    P_PARA               NOTIFICACIONES_MAIL_CORREDORES.NMC_PARA%TYPE;
    P_ASUNTO             NOTIFICACIONES_MAIL_CORREDORES.NMC_ASUNTO%TYPE;
    P_MENSAJE            NOTIFICACIONES_MAIL_CORREDORES.NMC_CUERPO%TYPE;
    P_CLOB               CLOB;
    P_MENSAJE_CLOB       CLOB;
    V_ARCHIVO            VARCHAR2(150);
    V_LINEA              VARCHAR2(4000);
    OUT_FILE             UTL_FILE.FILE_TYPE;
    V_FECHA              DATE;

  BEGIN
    V_FECHA := TRUNC(SYSDATE - 1);

    P_LIMITES_CONSUMO.PR_CONSUMO_DIA_TOTAL_DIA_COP(V_FECHA); --CONSUMO_DIARIO_TOTAL_C_DIA_COP
    P_LIMITES_CONSUMO.PR_CONSUMO_DIARIO_COP_CD(V_FECHA); --CONSUMO_DIARIO_COP_CD1
    P_LIMITES_CONSUMO.PR_CONSUMO_PLAZO_TOTAL_DIA_COP(V_FECHA); --CONSUMO_PLAZO_TOTAL_CDIA_COP
    P_LIMITES_CONSUMO.PR_CONSUMO_PLAZO_COP_CD(V_FECHA); --CONSUMO_PLAZO_COP_CD1;
    P_LIMITES_CONSUMO.PR_CONSUMO_CIERRE_COP(V_FECHA); --CONSUMO_CIERRE_COP;
    P_LIMITES_CONSUMO.PR_GRUPOS(V_FECHA); --GRUPOS;
    P_LIMITES_CONSUMO.PR_ELIMINAR_EXCLUIDOS; --ELIMINAR_EXCLUIDOS;

    --V_ARCHIVO               := 'Contraparte_con_exceso_de_consumo_'||TO_CHAR(SYSDATE-1,'DDMONYYYY')||'.csv';
    V_ARCHIVO := 'Contraparte_con_exceso_de_consumo_' ||
                 TO_CHAR(SYSDATE - 1, 'DDMONYYYY') || '.txt';
    OUT_FILE  := UTL_FILE.FOPEN('NTFMAILATT', V_ARCHIVO, 'W');
    V_LINEA   := 'NIT' || ';' || 'RAZON_SOCIAL' || ';' ||
                 'LIMITE_CONTRAPARTE_COP_95' || ';' || 'CONSUMO_CIERRE' || ';' ||
                 'DIFERENCIA';
    UTL_FILE.PUTF(OUT_FILE, '%s\n', V_LINEA);
    OPEN C_MAIL;
    FETCH C_MAIL
      INTO V_MAIL;

    IF C_MAIL%FOUND THEN
      WHILE C_MAIL%FOUND LOOP
        V_LINEA := V_MAIL.ID || ';' || V_MAIL.CONTRAPARTE || ';' ||
                   V_MAIL.LIMITE_95 || ';' || V_MAIL.CONSUMO_CIERRE || ';' ||
                   V_MAIL.DIFERENCIA;
        UTL_FILE.PUTF(OUT_FILE, '%s\n', V_LINEA);

        FETCH C_MAIL
          INTO V_MAIL;
      END LOOP;
      CLOSE C_MAIL;
      UTL_FILE.FCLOSE(OUT_FILE);
      P_CLI_PER_TID_CODIGO := '0';
      P_CLI_PER_NUM_IDEN   := '0';
      P_SERVICIO           := 'EXCESO_CONSUMO_CONTRAPARTES';
      P_DE                 := 'notificaciones@corredores.com';
      P_PARA               := 'riesgos@corredores.com';
      P_ASUNTO             := 'Se presenta un exceso sobre los lżmites de contrapartes';
      P_MENSAJE            := 'Se presenta un exceso sobre el lżmite de contraparte indicada.<br/><br/>';
      P_MENSAJE            := P_MENSAJE ||
                              'Favor verificar la veracidad de este evento y remitir al comercial la alerta correspondiente. <br/>';
      P_NOTIFICACIONES_MAIL.PR_ENVIO_MAIL(P_CLI_PER_TID_CODIGO,
                                          P_CLI_PER_NUM_IDEN,
                                          P_SERVICIO,
                                          P_DE,
                                          P_PARA,
                                          P_ASUNTO,
                                          P_MENSAJE,
                                          P_CLOB,
                                          P_MENSAJE_CLOB,
                                          V_ARCHIVO);

    ELSE
      NULL;
    END IF;

  END P_CORREO_EXCESO_CONSUMO_LIMCOS;

  ------------------------FIN CORREO LIMCOS PLANO INTEGRADO 5 PARTE B - JCALDERON -----------------------

  -------------------------------------FIN REPORTES PLANO INTEGRADO V------------------------------------

  -----------------REVERSION DE ORDENES PLATAFORMAS DAVIVIENDA----------------
  PROCEDURE P_REVERSIONES_DAVIVIENDA IS
    --LISTA DE NOTIFICACIONES DE REVERSIżN PENDIENTES POR PROCESAR
    CURSOR C_LISTA_ANULACIONES IS
      SELECT TRAN_CONSECUTIVO,
             TRAN_ESTADO,
             TRAN_FECHA_INGRESO,
             TRAN_FECHA_PROCESADO,
             TRAN_ERROR,
             TRAN_TIPO_SERVICIO,
             TRAN_CODIGO_TRANSACCION,
             TRAN_USUARIO,
             TRAN_CODIGO_OFICINA,
             TRAN_TALON,
             TRAN_CANAL_DAVIVIENDA,
             TRAN_CONSECUTIVO_DAVIVIENDA,
             TRAN_TERMINAL,
             TRAN_TAREA,
             TRAN_JORNADA,
             TRAN_MODO_TERMINAL,
             TRAN_PERFIL
        FROM TRANSACCIONES_ANULACION_DAV
       WHERE TRAN_ESTADO = 'POR_PROCESAR'
         AND TRAN_FECHA_INGRESO >= TRUNC(SYSDATE);

    R_LISTA_ANULACIONES C_LISTA_ANULACIONES%ROWTYPE;

    --CONSULTA ORDEN DE FONDOS
    CURSOR C_ORDEN_FONDOS(P_CANAL_CORREDORES NUMBER, P_TALON NUMBER) IS
      SELECT OFO_CONSECUTIVO, OFO_SUC_CODIGO
        FROM ORDENES_FONDOS
       WHERE OFO_FECHA_CAPTURA >= TRUNC(SYSDATE)
         AND OFO_CNL_CONSECUTIVO = P_CANAL_CORREDORES
         AND OFO_TALON = P_TALON
         AND OFO_EOF_CODIGO = 'CON';

    R_ORDEN_FONDOS C_ORDEN_FONDOS%ROWTYPE;
    --
    CURSOR C_CANAL(P_NUMERO_CANAL NUMBER) IS
      SELECT CNL_CONSECUTIVO
        FROM CANALES
       WHERE CNL_CODIGO_BANCO = P_NUMERO_CANAL;

    V_MENSAJE          VARCHAR2(2000);
    V_SUCURSAL         NUMBER(5);
    V_OFO_CONSECUTIVO  NUMBER(10);
    V_CANAL_CORREDORES CANALES.CNL_CONSECUTIVO%TYPE;
  BEGIN
    OPEN C_LISTA_ANULACIONES;
    FETCH C_LISTA_ANULACIONES
      INTO R_LISTA_ANULACIONES;
    IF C_LISTA_ANULACIONES%FOUND THEN
      WHILE C_LISTA_ANULACIONES%FOUND LOOP
        --Consulta el codigo de Canal
        OPEN C_CANAL(R_LISTA_ANULACIONES.TRAN_CANAL_DAVIVIENDA);
        FETCH C_CANAL
          INTO V_CANAL_CORREDORES;
        CLOSE C_CANAL;

        OPEN C_ORDEN_FONDOS(P_CANAL_CORREDORES => V_CANAL_CORREDORES,
                            P_TALON            => R_LISTA_ANULACIONES.TRAN_TALON);
        FETCH C_ORDEN_FONDOS
          INTO R_ORDEN_FONDOS;
        IF C_ORDEN_FONDOS%FOUND THEN
          BEGIN
            P_ORDENES_FONDOS.PR_ANULAR_ORDEN_DAV(P_OFO_SUC_CODIGO  => R_ORDEN_FONDOS.OFO_SUC_CODIGO,
                                                 P_OFO_CONSECUTIVO => R_ORDEN_FONDOS.OFO_CONSECUTIVO,
                                                 P_MENSAJE         => V_MENSAJE);

            DBMS_OUTPUT.PUT_LINE(V_MENSAJE);
            IF V_MENSAJE IS NULL OR LENGTH(V_MENSAJE) = 0 THEN
              UPDATE TRANSACCIONES_ANULACION_DAV
                 SET TRAN_ESTADO          = 'PROCESADO',
                     TRAN_FECHA_PROCESADO = SYSDATE
               WHERE TRAN_CONSECUTIVO =
                     R_LISTA_ANULACIONES.TRAN_CONSECUTIVO;
            ELSE
              ROLLBACK;
              UPDATE TRANSACCIONES_ANULACION_DAV
                 SET TRAN_ESTADO          = 'PROCESADO',
                     TRAN_FECHA_PROCESADO = SYSDATE,
                     TRAN_ERROR           = SUBSTR(V_MENSAJE, 0, 200)
               WHERE TRAN_CONSECUTIVO =
                     R_LISTA_ANULACIONES.TRAN_CONSECUTIVO;
            END IF;
          EXCEPTION
            WHEN OTHERS THEN
              V_MENSAJE := SUBSTR(SQLERRM, 0, 200);
              ROLLBACK;
              UPDATE TRANSACCIONES_ANULACION_DAV
                 SET TRAN_ESTADO          = 'PROCESADO',
                     TRAN_FECHA_PROCESADO = SYSDATE,
                     TRAN_ERROR           = V_MENSAJE
               WHERE TRAN_CONSECUTIVO =
                     R_LISTA_ANULACIONES.TRAN_CONSECUTIVO;
          END;
        ELSE
          UPDATE TRANSACCIONES_ANULACION_DAV
             SET TRAN_FECHA_PROCESADO = SYSDATE,
                 TRAN_ERROR           = 'No se encontrż una orden para reversar'
           WHERE TRAN_CONSECUTIVO = R_LISTA_ANULACIONES.TRAN_CONSECUTIVO;
        END IF;
        COMMIT;
        CLOSE C_ORDEN_FONDOS;
        FETCH C_LISTA_ANULACIONES
          INTO R_LISTA_ANULACIONES;
      END LOOP;
    END IF;
  END P_REVERSIONES_DAVIVIENDA;

  -------------------------------------INICIO P_CREA_PARTICION V------------------------------------

  -----------------PARTICIONAMIENTO AUTOMATICO----------------
  PROCEDURE P_CREA_PARTICION as

    V_periodo        varchar2(30);
    V_TABLA          varchar2(60);
    V_PARTITION_NAME varchar2(60);
    gValues          varchar2(400);
    v_retorna        varchar2(100);
    v_anno           varchar2(100);
    v_anno_particion varchar2(100);
    v_MES            varchar2(100);
    v_MES_CADENA     varchar2(100);
    v_MES_PARTICION  varchar2(100);
    gPar_Name        VARCHAR2(500);

    gTes_Name VARCHAR2(50);

    gValues VARCHAR2(100);

    gVar_Sql   VARCHAR2(2000);
    v_longitud VARCHAR2(2000);

    cursor lista_tablas IS
      SELECT A.TABLE_NAME, A.PARTITION_NAME
        FROM dba_tab_partitions A
        JOIN (SELECT MAX(PARTITION_POSITION) MAX_PARTITION_POSITION,
                     TABLE_NAME
                FROM dba_tab_partitions
               where TABLE_OWNER = 'PROD'
               GROUP BY TABLE_NAME) B
          ON A.TABLE_NAME = B.TABLE_NAME
         AND A.PARTITION_POSITION = B.MAX_PARTITION_POSITION;

  BEGIN

    gTes_Name := 'data_coeasy';

    FOR X IN lista_tablas LOOP

      V_TABLA          := X.TABLE_NAME;
      V_PARTITION_NAME := X.PARTITION_NAME;
      V_PERIODO        := substr(V_PARTITION_NAME,
                                 INSTR(V_PARTITION_NAME, '2'),
                                 6);
      v_anno           := substr(V_PERIODO, 1, 4);
      v_MES            := substr(V_PERIODO, 5, 2);

      IF v_MES = '12' THEN

        v_anno := TO_NUMBER(v_anno) + 1;
        v_MES  := '02';

        v_retorna := '(TO_DATE('' ' || v_anno || '-' || v_MES ||
                     '-01 00:00:00'', ''SYYYY-MM-DD HH24:MI:SS'', ''NLS_CALENDAR=GREGORIAN''))';
        gPar_Name := substr(V_PARTITION_NAME,
                            1,
                            length(V_PARTITION_NAME) - 6) || v_anno || '01';

      ELSIF v_MES = '11' THEN

        v_anno_particion := v_anno;
        v_anno           := TO_NUMBER(v_anno) + 1;

        v_MES := '01';

        v_retorna := '(TO_DATE('' ' || v_anno || '-' || v_MES ||
                     '-01 00:00:00'', ''SYYYY-MM-DD HH24:MI:SS'', ''NLS_CALENDAR=GREGORIAN''))';
        gPar_Name := substr(V_PARTITION_NAME,
                            1,
                            length(V_PARTITION_NAME) - 6) ||
                     v_anno_particion || '12';

      ELSE

        v_MES_CADENA    := to_number(v_MES) + 1;
        v_MES_PARTICION := to_number(v_MES) + 2;
        v_longitud      := length(v_MES_CADENA);

        if v_longitud = 1 then
          v_MES_CADENA := '0' || v_MES_CADENA;
        else
          v_MES_CADENA := v_MES_CADENA;
        end if;

        v_retorna := '(TO_DATE('' ' || v_anno || '-' || v_MES_PARTICION ||
                     '-01 00:00:00'', ''SYYYY-MM-DD HH24:MI:SS'', ''NLS_CALENDAR=GREGORIAN''))';
        gPar_Name := substr(V_PARTITION_NAME,
                            1,
                            length(V_PARTITION_NAME) - 6) || v_anno ||
                     v_MES_CADENA;

      END IF;

      gVar_Sql := 'ALTER TABLE ' || V_TABLA || ' ADD PARTITION ' ||
                  gPar_Name || ' values less than  (' || v_retorna ||
                  ') TABLESPACE ' || gTes_Name;

      EXECUTE IMMEDIATE GVAR_SQL;

    END LOOP;

  END P_CREA_PARTICION;

  -------------------------------------FIN P_CREA_PARTICION V------------------------------------

  PROCEDURE CALCULAR_SALDO(P_SALDO_INVER    IN OUT NUMBER,
                           P_SALDO_UNIDADES IN OUT NUMBER,
                           NUM_IDEN         VARCHAR2,
                           TID              VARCHAR2,
                           NUMERO_CUENTA    NUMBER,
                           FONDO            VARCHAR2,
                           APORTE           NUMBER) IS

    CURSOR C_SALDO_INVER IS
      SELECT CFO_SALDO_INVER, CFO_SALDO_UNIDADES
        FROM CUENTAS_FONDOS
       WHERE CFO_CCC_CLI_PER_NUM_IDEN = NUM_IDEN
         AND CFO_CCC_CLI_PER_TID_CODIGO = TID
         AND CFO_CCC_NUMERO_CUENTA = NUMERO_CUENTA
         AND CFO_FON_CODIGO = FONDO
         AND CFO_CODIGO = APORTE;
    CFO1 C_SALDO_INVER%ROWTYPE;

    CURSOR C_ORDENES IS
      SELECT OFO_CONSECUTIVO, OFO_SUC_CODIGO, OFO_TTO_TOF_CODIGO, OFO_MONTO
        FROM ORDENES_FONDOS
       WHERE OFO_CFO_CCC_CLI_PER_NUM_IDEN = NUM_IDEN
         AND OFO_CFO_CCC_CLI_PER_TID_CODIGO = TID
         AND OFO_CFO_CCC_NUMERO_CUENTA = NUMERO_CUENTA
         AND OFO_CFO_FON_CODIGO = FONDO
         AND OFO_CFO_CODIGO = APORTE
         AND OFO_EOF_CODIGO IN ('COL', 'CON');
    OFO1 C_ORDENES%ROWTYPE;

    CURSOR C_RETIRO IS
      SELECT UPF_FECHA_DISPONIBLE, UPF_PEN_FON_CODIGO, UPF_PEN_CONSECUTIVO
        FROM UNIDADES_PENALIZACIONES_FONDOS
       WHERE UPF_OFO_CONSECUTIVO_R = OFO1.OFO_CONSECUTIVO
         AND UPF_OFO_SUC_CODIGO_R = OFO1.OFO_SUC_CODIGO;
    UPF1 C_RETIRO%ROWTYPE;

    CURSOR C_PENALIZACION IS
      SELECT PEN_PORCENTAJE
        FROM PENALIZACIONES
       WHERE PEN_FON_CODIGO = UPF1.UPF_PEN_FON_CODIGO
         AND PEN_CONSECUTIVO = UPF1.UPF_PEN_CONSECUTIVO;
    PEN1 C_PENALIZACION%ROWTYPE;

    CURSOR C_IMGF_PAGOS IS
      SELECT SUM(ODP_MONTO_IMGF)
        FROM ORDENES_DE_PAGO
       WHERE ODP_OFO_CONSECUTIVO = OFO1.OFO_CONSECUTIVO
         AND ODP_OFO_SUC_CODIGO = OFO1.OFO_SUC_CODIGO;
    TOTAL_IMGF_PAGOS NUMBER;

    CURSOR C_IMGF_ABONOS IS
      SELECT SUM(DAA_VALOR_IMGF)
        FROM DETALLES_ABONOS_CUENTAS
       WHERE DAA_OFO_CONSECUTIVO = OFO1.OFO_CONSECUTIVO
         AND DAA_OFO_SUC_CODIGO = OFO1.OFO_SUC_CODIGO;
    TOTAL_IMGF_ABONOS NUMBER;

    CURSOR C_IMGF_TRASLADOS IS
      SELECT SUM(TFE_VALOR_IMGF)
        FROM TRASLADOS_FONDO_ESCALA
       WHERE TFE_OFO_CONSECUTIVO = OFO1.OFO_CONSECUTIVO
         AND TFE_OFO_SUC_CODIGO = OFO1.OFO_SUC_CODIGO;
    TOTAL_IMGF_TRASLADOS NUMBER;

    FECHA        DATE;
    PENALIZACION NUMBER;

  BEGIN
    SELECT SYSDATE INTO FECHA FROM DUAL;
    OPEN C_SALDO_INVER;
    FETCH C_SALDO_INVER
      INTO CFO1;
    CLOSE C_SALDO_INVER;

    CFO1.CFO_SALDO_INVER := NVL(CFO1.CFO_SALDO_INVER, 0);

    OPEN C_ORDENES;
    FETCH C_ORDENES
      INTO OFO1;
    WHILE C_ORDENES%FOUND LOOP
      IF OFO1.OFO_TTO_TOF_CODIGO IN ('ING', 'INC') THEN
        CFO1.CFO_SALDO_INVER := CFO1.CFO_SALDO_INVER + OFO1.OFO_MONTO;
      ELSIF OFO1.OFO_TTO_TOF_CODIGO IN ('RP', 'RT') THEN
        TOTAL_IMGF_PAGOS     := 0;
        TOTAL_IMGF_ABONOS    := 0;
        TOTAL_IMGF_TRASLADOS := 0;

        CFO1.CFO_SALDO_INVER := CFO1.CFO_SALDO_INVER - OFO1.OFO_MONTO;
        OPEN C_RETIRO;
        FETCH C_RETIRO
          INTO UPF1;
        CLOSE C_RETIRO;

        OPEN C_PENALIZACION;
        FETCH C_PENALIZACION
          INTO PEN1.PEN_PORCENTAJE;
        CLOSE C_PENALIZACION;

        PENALIZACION := ROUND(OFO1.OFO_MONTO * PEN1.PEN_PORCENTAJE, 2);

        OPEN C_IMGF_PAGOS;
        FETCH C_IMGF_PAGOS
          INTO TOTAL_IMGF_PAGOS;
        CLOSE C_IMGF_PAGOS;
        TOTAL_IMGF_PAGOS := NVL(TOTAL_IMGF_PAGOS, 0);

        OPEN C_IMGF_ABONOS;
        FETCH C_IMGF_ABONOS
          INTO TOTAL_IMGF_ABONOS;
        CLOSE C_IMGF_ABONOS;
        TOTAL_IMGF_ABONOS := NVL(TOTAL_IMGF_ABONOS, 0);

        OPEN C_IMGF_TRASLADOS;
        FETCH C_IMGF_TRASLADOS
          INTO TOTAL_IMGF_TRASLADOS;
        CLOSE C_IMGF_TRASLADOS;
        TOTAL_IMGF_TRASLADOS := NVL(TOTAL_IMGF_TRASLADOS, 0);

        CFO1.CFO_SALDO_INVER := CFO1.CFO_SALDO_INVER - PENALIZACION -
                                TOTAL_IMGF_PAGOS - TOTAL_IMGF_ABONOS -
                                TOTAL_IMGF_TRASLADOS;
      END IF;
      FETCH C_ORDENES
        INTO OFO1;
    END LOOP;
    CLOSE C_ORDENES;

    P_SALDO_INVER    := CFO1.CFO_SALDO_INVER;
    P_SALDO_UNIDADES := CFO1.CFO_SALDO_UNIDADES;
  END CALCULAR_SALDO;

  PROCEDURE P_COORRE_HISTORICO IS
    CURSOR UNI_PEN IS
      SELECT UPF_OFO_CONSECUTIVO            ORDEN_ING_INC,
             UPF_OFO_CONSECUTIVO_R          ORDEN_RETIRO,
             UPF_FECHA_DISPONIBLE           FECHA_DISPONIBLE,
             UPF_FECHA_PAGO                 FECHA_PAGO,
             UPF_INSTRUCCION                INSTRUCCION,
             UPF_MONTO_RETIRO               MONTO_RETIRO,
             UPF_FECHA                      FECHA_INGRESO,
             UPF_CFO_CCC_CLI_PER_NUM_IDEN   NUM_IDEN,
             UPF_CFO_CCC_CLI_PER_TID_CODIGO TID,
             UPF_CFO_CCC_NUMERO_CUENTA      NUMERO_CUENTA,
             UPF_CFO_FON_CODIGO             FONDO,
             UPF_CFO_CODIGO                 APORTE,
             UPF_EOF_CODIGO,
             UPF_UNIDADES_POR_PENALIZAR,
             UPF_PEN_FON_CODIGO, -- NO INGRESA AL INSERT
             UPF_PEN_CONSECUTIVO -- NO INGRESA AL INSERT

        FROM UNIDADES_PENALIZACIONES_FONDOS
       WHERE UPF_EOF_CODIGO = 'APR'
            -- AND   UPF_CFO_FON_CODIGO = 'FON.FON_CODIGO'
         AND UPF_UNIDADES_POR_PENALIZAR > 0
         AND EXISTS
       (SELECT 'X'
                FROM CUENTAS_CLIENTE_CORREDORES, FILTRO_COMERCIALES
               WHERE CCC_CLI_PER_NUM_IDEN = UPF_CFO_CCC_CLI_PER_NUM_IDEN
                 AND CCC_CLI_PER_TID_CODIGO = UPF_CFO_CCC_CLI_PER_TID_CODIGO
                 AND CCC_NUMERO_CUENTA = UPF_CFO_CCC_NUMERO_CUENTA
                 AND CCC_PER_NUM_IDEN = PER_NUM_IDEN
                 AND CCC_PER_TID_CODIGO = PER_TID_CODIGO)
      --AND UPF_OFO_CONSECUTIVO = '1566253'
       ORDER BY UPF_FECHA_PAGO, UPF_OFO_CONSECUTIVO;

    UPF UNI_PEN%ROWTYPE;

    CURSOR C_CLIENTE IS
      SELECT PER_NOMBRE
        FROM FILTRO_PERSONAS
       WHERE PER_NUM_IDEN = UPF.NUM_IDEN
         AND PER_TID_CODIGO = UPF.TID;
    CLI C_CLIENTE%ROWTYPE;

    CURSOR C_VALOR_UNIDAD IS
      SELECT VFO_VALOR
        FROM VALORIZACIONES_FONDO
       WHERE VFO_FON_CODIGO = UPF.FONDO
       ORDER BY VFO_FECHA_VALORIZACION DESC;
    VFO1 C_VALOR_UNIDAD%ROWTYPE;

    CURSOR C_PENALIZACION IS
      SELECT PEN_PORCENTAJE
        FROM PENALIZACIONES
       WHERE PEN_FON_CODIGO = UPF.UPF_PEN_FON_CODIGO
         AND PEN_CONSECUTIVO = UPF.UPF_PEN_CONSECUTIVO;
    PEN1 C_PENALIZACION%ROWTYPE;

    SALDO          NUMBER;
    SALDO_UNIDADES NUMBER;
    VALOR_DIA      NUMBER;
    PORCENTAJE_PEN NUMBER;
    PENALIZACION   NUMBER;
    VAL_NETO       NUMBER;
    SAL_INVER      NUMBER;

  BEGIN

    OPEN UNI_PEN;
    FETCH UNI_PEN
      INTO UPF;
    <<UNIDAD>>
    WHILE UNI_PEN%FOUND LOOP

      OPEN C_VALOR_UNIDAD;
      FETCH C_VALOR_UNIDAD
        INTO VFO1;
      CLOSE C_VALOR_UNIDAD;

      OPEN C_PENALIZACION;
      FETCH C_PENALIZACION
        INTO PEN1.PEN_PORCENTAJE;
      CLOSE C_PENALIZACION;

      OPEN C_CLIENTE;
      FETCH C_CLIENTE
        INTO CLI;
      CLOSE C_CLIENTE;

      DBMS_OUTPUT.PUT_LINE('VFO1.VFO_VALOR: ' || VFO1.VFO_VALOR);
      DBMS_OUTPUT.PUT_LINE('UPF.UPF_UNIDADES_POR_PENALIZAR: ' ||
                           UPF.UPF_UNIDADES_POR_PENALIZAR);
      VALOR_DIA := ROUND(UPF.UPF_UNIDADES_POR_PENALIZAR * VFO1.VFO_VALOR, 2);

      DBMS_OUTPUT.PUT_LINE('VALOR_DIA: ' || VALOR_DIA);
      PORCENTAJE_PEN := PEN1.PEN_PORCENTAJE * 100;
      DBMS_OUTPUT.PUT_LINE('PEN1.PEN_PORCENTAJE: ' || PEN1.PEN_PORCENTAJE);
      DBMS_OUTPUT.PUT_LINE('PORCENTAJE_PEN: ' || PORCENTAJE_PEN);
      PENALIZACION := ROUND(VALOR_DIA * PEN1.PEN_PORCENTAJE, 2);
      DBMS_OUTPUT.PUT_LINE('PENALIZACION: ' || PENALIZACION);
      VAL_NETO := VALOR_DIA - PENALIZACION;
      DBMS_OUTPUT.PUT_LINE('VAL_NETO: ' || VAL_NETO);

      CALCULAR_SALDO(P_SALDO_INVER    => SAL_INVER,
                     P_SALDO_UNIDADES => SALDO_UNIDADES,
                     NUM_IDEN         => UPF.NUM_IDEN,
                     TID              => UPF.TID,
                     NUMERO_CUENTA    => UPF.NUMERO_CUENTA,
                     FONDO            => UPF.FONDO,
                     APORTE           => UPF.APORTE);

      SALDO := SAL_INVER;

      DBMS_OUTPUT.PUT_LINE('SALDO: ' || SALDO);

      INSERT INTO HIS_UNIDADES_PENALIZACIONES_F
        (FECHA_CONSULTA,
         HIS_UPF_CONSECUTIVO,
         HIS_UPF_OFO_SUC_CODIGO_R,
         HIS_CLIENTE,
         HIS_UPF_FECHA_DISPONIBLE,
         HIS_UPF_FECHA_PAGO,
         HIS_DSP_VALOR_AL_DIA,
         HIS_DSP_PORCENTAJE_PENALIZACI,
         HIS_DSP_PENALIZACION,
         HIS_DSP_VALOR_NETO,
         HIS_UPF_INSTRUCCION,
         HIS_UPF_MONTO_RETIRO,
         HIS_DSP_SALDO_INVER,
         HIS_UPF_FECHA,
         HIS_UPF_CFO_CCC_CLI_PER_NUM_I,
         HIS_UPF_CFO_CCC_CLI_PER_TID_C,
         HIS_UPF_CFO_CCC_NUMERO_CUENTA,
         HIS_UPF_CFO_FON_CODIGO,
         HIS_UPF_CFO_CODIGO,
         HIS_UPF_EOF_CODIGO,
         HIS_UPF_UNIDADES_POR_PENALIZAR)
      VALUES
        (sysdate,
         UPF.ORDEN_ING_INC,
         UPF.ORDEN_RETIRO,
         CLI.PER_NOMBRE,
         UPF.FECHA_DISPONIBLE,
         UPF.FECHA_PAGO,
         VALOR_DIA,
         PORCENTAJE_PEN,
         PENALIZACION,
         VAL_NETO,
         UPF.INSTRUCCION,
         UPF.MONTO_RETIRO,
         SALDO,
         UPF.FECHA_INGRESO,
         UPF.NUM_IDEN,
         UPF.TID,
         UPF.NUMERO_CUENTA,
         UPF.FONDO,
         UPF.APORTE,
         UPF.UPF_EOF_CODIGO,
         UPF.UPF_UNIDADES_POR_PENALIZAR);

      FETCH UNI_PEN
        INTO UPF;
    END LOOP UNIDAD;
    CLOSE UNI_PEN;
    COMMIT;
  END P_COORRE_HISTORICO;

  -------------------------------------INICIO CREACION DE SALDOS DEL PORTAL------------------------------------

  PROCEDURE P_CREA_SALDOS_FONDOS_PORTAL(P_FECHA_PROCESO DATE DEFAULT NULL) IS
    P_NUM_INI   NUMBER;
    P_NUM_FIN   NUMBER;
    P_RESULTADO VARCHAR2(100);
    V_FECHA     DATE;
  BEGIN
    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_CREA_SALDOS_FONDOS_PORTAL',
                                                      'INI');

    IF P_FECHA_PROCESO IS NULL THEN
      SELECT TRUNC(SYSDATE - 1) INTO V_FECHA FROM DUAL;
    ELSE
      V_FECHA := P_FECHA_PROCESO;
    END IF;

    BEGIN
      P_WEB_PORTAFOLIO.PR_PRE_CARGUE_CARTERAS(P_FECHA     => TO_CHAR(V_FECHA,
                                                                     'DD-MM-YYYY'),
                                              P_REPROCESO => 'S');

      P_CLIENTES.PR_INSERTA_SAL_CLIENTES_FONDOS(P_FECHA     => V_FECHA,
                                                P_RESULTADO => P_RESULTADO);
    EXCEPTION
      WHEN OTHERS THEN
        P_MAIL.ENVIO_MAIL_ERROR('Proceso generaciżn Saldos Fondos Portal PJ Resultado: ' ||
                                P_RESULTADO || SUBSTR(SQLERRM, 1, 80),
                                DESTINATARIOS);
    END;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_CREA_SALDOS_FONDOS_PORTAL',
                                                      'FIN');
  END P_CREA_SALDOS_FONDOS_PORTAL;

  PROCEDURE P_CREA_SALDOS_CUENTAS_PORTAL(P_FECHA_PROCESO DATE DEFAULT NULL) IS
    P_NUM_INI   NUMBER;
