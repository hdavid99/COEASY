                                                       '     , PORCENTAJE_COMISION ' ||
                                                       '     , VALOR_COMISION ' ||
                                                       '     , OVE_ENA_MNEMONICO ' ||
                                                       '     , ENA_DESCRIPCION ' ||
                                                       '     , EMI_DESCRIPCION ' ||
                                                       '     , CRUZCON ' ||
                                                       '     , COM_VENDEDOR ' ||
                                                       '     , LOCALIZACION ' ||
                                                       '     , VIGENCIA_OP ' ||
