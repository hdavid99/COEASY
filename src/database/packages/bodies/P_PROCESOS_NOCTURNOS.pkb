    V_FECHAN VARCHAR2(20);
    V_FONDO  VARCHAR2(20);

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN
    V_FONDO   := '860079174';
    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_CSVFO',
                                                      'INI');

    SELECT TO_CHAR(TRUNC(SYSDATE - 1),
                   'DD-MON-YYYY',
                   'nls_date_language = ''LATIN AMERICAN SPANISH''')
      INTO V_FECHA
      FROM DUAL;

    SELECT TO_CHAR(TRUNC(SYSDATE - 1), 'DDMMYYYY') INTO V_FECHAN FROM DUAL;
    /*P_MAIL.ENVIO_MAIL_ERROR('Inicio genera reporte CESVFO ',
    '<br>'||'Fecha consultada del reporte: '||V_FECHA||,
    DESTINATARIOS); */

    P_TOOLS.PR_CREAR_REPORTE(P_REPORT     => 'CESVFO',
                             P_USERID     => P_USERID,
                             P_FORMATO    => 'PDF',
                             P_PARAMETROS => '+P_FECHA=' || V_FECHA ||
                                             '+P_T0=S+P_BASE_MONETARIA=1',
                             P_ARCHIVO    => '/apps/rep_nocturnos/diarios/CESVFO_' ||
                                             V_FECHAN);

    P_TOOLS.PR_CREAR_REPORTE(P_REPORT     => 'CESVFO',
                             P_USERID     => P_USERID,
                             P_FORMATO    => 'TXT',
                             P_PARAMETROS => '+P_FECHA=' || V_FECHA ||
                                             '+P_T0=S+P_BASE_MONETARIA=1',
                             P_ARCHIVO    => '/apps/rep_nocturnos/diarios/CESVFO_' ||
                                             V_FECHAN);

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_CSVFO',
                                                      'FIN');

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PR_REPORTE_CSVFO',
                              SUBSTR(SQLERRM, 1, 80),
                              'procesosnocturnos@corredores.com');
  END PR_REPORTE_CSVFO;

  PROCEDURE PR_REPORTE_COMFCP AS
    CURSOR C1 IS
      SELECT CFO_FON_CODIGO FONDO,
             CFO_CCC_NUMERO_CUENTA CTA,
             CFO_CCC_CLI_PER_NUM_IDEN Indent,
             CFO_CCC_CLI_PER_TID_CODIGO TIPO,
             DECODE(PER_PRIMER_APELLIDO,
                    NULL,
                    PER_RAZON_SOCIAL,
                    PER_PRIMER_APELLIDO || ' ' || PER_SEGUNDO_APELLIDO || ' ' ||
                    PER_NOMBRE) CLIENTE,
             CFO_COMPROMISO_FCP MONTO,
             CFO_FECHA_COMPROMISO_FCP FECHA,
             CFO_BASE_COMPROMISO_FCP BASE
        FROM CUENTAS_FONDOS, PERSONAS
       WHERE CFO_FON_CODIGO IN
             (SELECT FON_CODIGO FROM FONDOS WHERE FON_CAPITAL_PRIVADO != 'N')
         AND NOT EXISTS (SELECT 'X'
                FROM PARAMETROS_FONDOS
               WHERE PFO_FON_CODIGO = CFO_FON_CODIGO
                 AND PFO_PAR_CODIGO = '84')
         AND CFO_SALDO_CAPITAL != 0
         AND CFO_ESTADO = 'A'
         AND PER_NUM_IDEN = CFO_CCC_CLI_PER_NUM_IDEN
       ORDER BY CFO_FON_CODIGO, CFO_CCC_CLI_PER_NUM_IDEN;

    v_file  UTL_FILE.FILE_TYPE;
    P_FECHA VARCHAR2(20);
  BEGIN
    SELECT TO_CHAR(SYSDATE - 1, 'DDMMYYYY') INTO P_FECHA FROM DUAL;

    v_file := UTL_FILE.FOPEN(location     => 'REP_NOCTURNOS',
                             filename     => 'COMFCP_' || P_FECHA || '.csv',
                             open_mode    => 'W',
                             max_linesize => 32767);

    FOR R1 IN C1 LOOP
      UTL_FILE.PUT_LINE(v_file,
                        R1.FONDO || ';' || R1.CTA || ';' || R1.Indent || ';' ||
                        R1.TIPO || ';' || R1.CLIENTE || ';' || R1.MONTO || ';' ||
                        R1.FECHA || ';' || R1.BASE);
    END LOOP;
    UTL_FILE.FCLOSE(v_file);
  EXCEPTION
    WHEN OTHERS THEN
      UTL_FILE.FCLOSE(v_file);
      RAISE;
  END PR_REPORTE_COMFCP;

  PROCEDURE PR_REPORTE_CBNOCO AS
    CURSOR C1 IS
      SELECT QUE_DINAMICA,
             PROCESO,
             CONSECUTIVO,
             CODIGO_TIPO_DOCUMENTO,
             CODIGO_TIPO_FIDEICOMISO,
             CODIGO_SUBTIPO_FIDEICOMISO,
             CODIGO_FIDEICOMISO,
             CODIGO_OFICINA,
             ANO_PREDOCUMENTO,
             SECUENCIAL_PREDOCUMENTO,
             FECHA_PREDOCUMENTO,
             ESTADO_PREDOCUMENTO,
             USUARIO_PREDOCUMENTO,
             SECUENCIAL_DOCUMENTO,
             LLAVE,
             SECUENCIAL_DETALLE,
             TIPO_DE_PUC,
             CLASE_CUENTA,
             GRUPO_CUENTA,
             CUENTA_MAYOR,
             SUBCUENTA,
             AUXILIAR_UNO,
             AUXILIAR_DOS,
             AUXILIAR_TRES,
             DEBITO_CREDITO,
             VALOR_MOVIMIENTO,
             ESTADO_MOVIMIENTO,
             DESCRIPCION,
             IDENTIFICACION_TERCERO,
             CLASE_DOCUMENTO_TERCERO,
             VALOR_BASE_RETENCION,
             IDENTIFICACION_RETENCION,
             CLASE_DOCUMENTO_RETENCION,
             CODIGO_OFIC_COSTO,
             CODIGO_CENTRO,
             NUMERO_CHEQUE,
             IDENTIFICACION,
             CLASE,
             DESCRIP_AFECTACION,
             TASA,
             NUMERO_DOLARES,
             FLUJO_EFECTIVO,
             RAZON_SOCIAL_TER,
             PRIMER_APELLIDO_TER,
             SEGUNDO_APELLIDO_TER,
             NOMBRE_TER,
             TIPO_PERSONA_TER,
             NOMBRE_CONTACTO_TER,
             CODIGO_CIU_TER,
             DIRECCION_RESIDENCIA_TER,
             DIRECCION_OFICINA_TER,
             CIUDAD_TER,
             TELEFONO_TER,
             FAX_TER,
             DIRECCION_EMAIL_TER
        FROM INTERFAZ_CONTABLE
       ORDER BY QUE_DINAMICA, PROCESO, CONSECUTIVO;

    v_file  UTL_FILE.FILE_TYPE;
    P_FECHA VARCHAR2(20);
  BEGIN

    SELECT TO_CHAR(SYSDATE - 1, 'DDMMYYYY') INTO P_FECHA FROM DUAL;

    v_file := UTL_FILE.FOPEN(location     => 'REP_NOCTURNOS',
                             filename     => 'CBNOCO_' || P_FECHA || '.csv',
                             open_mode    => 'W',
                             max_linesize => 32767);

    FOR R1 IN C1 LOOP
      UTL_FILE.PUT_LINE(v_file,
                        R1.QUE_DINAMICA || ';' || R1.PROCESO || ';' ||
                        R1.CONSECUTIVO || ';' || R1.CODIGO_TIPO_DOCUMENTO || ';' ||
                        R1.CODIGO_TIPO_FIDEICOMISO || ';' ||
                        R1.CODIGO_SUBTIPO_FIDEICOMISO || ';' ||
                        R1.CODIGO_FIDEICOMISO || ';' || R1.CODIGO_OFICINA || ';' ||
                        R1.ANO_PREDOCUMENTO || ';' ||
                        R1.SECUENCIAL_PREDOCUMENTO || ';' ||
                        R1.FECHA_PREDOCUMENTO || ';' ||
                        R1.ESTADO_PREDOCUMENTO || ';' ||
                        R1.USUARIO_PREDOCUMENTO || ';' ||
                        R1.SECUENCIAL_DOCUMENTO || ';' || R1.LLAVE || ';' ||
                        R1.TIPO_DE_PUC || ';' || R1.CLASE_CUENTA || ';' ||
                        R1.GRUPO_CUENTA || ';' || R1.CUENTA_MAYOR || ';' ||
                        R1.SUBCUENTA || ';' || R1.AUXILIAR_UNO || ';' ||
                        R1.AUXILIAR_DOS || ';' || R1.AUXILIAR_TRES || ';' ||
                        R1.DEBITO_CREDITO || ';' || R1.VALOR_MOVIMIENTO || ';' ||
                        R1.ESTADO_MOVIMIENTO || ';' || R1.DESCRIPCION || ';' ||
                        R1.IDENTIFICACION_TERCERO || ';' ||
                        R1.CLASE_DOCUMENTO_TERCERO || ';' ||
                        R1.VALOR_BASE_RETENCION || ';' ||
                        R1.IDENTIFICACION_RETENCION || ';' ||
                        R1.CLASE_DOCUMENTO_RETENCION || ';' ||
                        R1.CODIGO_OFIC_COSTO || ';' || R1.CODIGO_CENTRO || ';' ||
                        R1.NUMERO_CHEQUE || ';' || R1.IDENTIFICACION || ';' ||
                        R1.CLASE || ';' || R1.DESCRIP_AFECTACION || ';' ||
                        R1.TASA || ';' || R1.NUMERO_DOLARES || ';' ||
                        R1.FLUJO_EFECTIVO || ';' || R1.RAZON_SOCIAL_TER || ';' ||
                        R1.PRIMER_APELLIDO_TER || ';' ||
                        R1.SEGUNDO_APELLIDO_TER || ';' || R1.NOMBRE_TER || ';' ||
                        R1.TIPO_PERSONA_TER || ';' ||
                        R1.NOMBRE_CONTACTO_TER || ';' || R1.CODIGO_CIU_TER || ';' ||
                        R1.DIRECCION_RESIDENCIA_TER || ';' ||
                        R1.DIRECCION_OFICINA_TER || ';' || R1.CIUDAD_TER || ';' ||
                        R1.TELEFONO_TER || ';' || R1.FAX_TER || ';' ||
                        R1.DIRECCION_EMAIL_TER);
    END LOOP;
    UTL_FILE.FCLOSE(v_file);
  EXCEPTION
    WHEN OTHERS THEN
      UTL_FILE.FCLOSE(v_file);
      RAISE;
  END PR_REPORTE_CBNOCO;
  PROCEDURE PR_REPORTE_COMODE AS
    CURSOR C1 IS
      SELECT MDD_FECHA,
             DECODE(PER_PRIMER_APELLIDO,
                    NULL,
                    PER_RAZON_SOCIAL,
                    PER_PRIMER_APELLIDO || ' ' || PER_SEGUNDO_APELLIDO || ' ' ||
                    PER_NOMBRE) CLIENTE,
             MDD_CDD_CCC_CLI_PER_NUM_IDEN IDENTIFICACION,
             MDD_CDD_CCC_CLI_PER_TID_CODIGO TIPO,
             MDD_CDD_CCC_NUMERO_CUENTA CUENTA,
             MDD_TDD_MNEMONICO MOVIMIENTO,
             TDD_DESCRIPCION DESCRIPCION,
             MDD_MONTO,
             MDD_SALDO
        FROM MOVIMIENTOS_CUENTAS_DERIVADOS,
             PERSONAS,
             TIPOS_MOV_CUENTAS_DERIVADOS
       WHERE PER_NUM_IDEN = MDD_CDD_CCC_CLI_PER_NUM_IDEN
         AND TDD_MNEMONICO = MDD_TDD_MNEMONICO
         AND MDD_FECHA >= TRUNC(SYSDATE, 'mm')
         AND MDD_FECHA < TRUNC(SYSDATE) + 1
       ORDER BY MDD_CONSECUTIVO;

    v_file  UTL_FILE.FILE_TYPE;
    P_FECHA VARCHAR2(20);
  BEGIN
    SELECT TO_CHAR(SYSDATE - 1, 'DDMMYYYY') INTO P_FECHA FROM DUAL;
    --P_FECHA := '12112017';
    v_file := UTL_FILE.FOPEN(location     => 'REP_NOCTURNOS',
                             filename     => 'COMODE_' || P_FECHA || '.csv',
                             open_mode    => 'W',
                             max_linesize => 32767);

    FOR R1 IN C1 LOOP
      UTL_FILE.PUT_LINE(v_file,
                        R1.MDD_FECHA || ';' || R1.CLIENTE || ';' ||
                        R1.IDENTIFICACION || ';' || R1.TIPO || ';' ||
                        R1.CUENTA || ';' || R1.MOVIMIENTO || ';' ||
                        R1.DESCRIPCION || ';' || R1.MDD_MONTO || ';' ||
                        R1.MDD_SALDO);
    END LOOP;
    UTL_FILE.FCLOSE(v_file);
  EXCEPTION
    WHEN OTHERS THEN
      UTL_FILE.FCLOSE(v_file);
      RAISE;
  END PR_REPORTE_COMODE;

  PROCEDURE PR_REPORTE_ROPDER(P_USERID IN VARCHAR2) IS

    VAR      VARCHAR2(2000);
    V_FECHA  VARCHAR2(20);
    V_FECHAN VARCHAR2(20);
    V_FONDO  VARCHAR2(20);

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN
    V_FONDO   := '860079174';
    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_ROPDER',
                                                      'INI');

    SELECT TO_CHAR(TRUNC(P_TOOLS.CF_DIA_HABIL_ANTERIOR(SYSDATE)),
                   'DD-MON-YYYY',
                   'nls_date_language = ''LATIN AMERICAN SPANISH''')
      INTO V_FECHA
      FROM DUAL;

    SELECT TO_CHAR(TRUNC(P_TOOLS.CF_DIA_HABIL_ANTERIOR(SYSDATE - 1)),
                   'DDMMYYYY')
      INTO V_FECHAN
      FROM DUAL;
    /*P_MAIL.ENVIO_MAIL_ERROR('Inicio genera reporte ROPDER ',
    '<br>'||'Fecha consultada del reporte: '||V_FECHA||,
    DESTINATARIOS); */
    P_TOOLS.PR_CREAR_REPORTE(P_REPORT     => 'ROPDER',
                             P_USERID     => P_USERID,
                             P_FORMATO    => 'XLS',
                             P_PARAMETROS => '+P_FECHA=' || V_FECHA,
                             P_ARCHIVO    => '/apps/rep_nocturnos/diarios/ROPDER_' ||
                                             V_FECHAN);

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_ROPDER',
                                                      'FIN');

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PR_REPORTE_ROPDER',
                              SUBSTR(SQLERRM, 1, 80),
                              'procesosnocturnos@corredores.com');
  END PR_REPORTE_ROPDER;

  PROCEDURE PR_REPORTE_REXCLF_MES(P_USERID IN VARCHAR2) IS

    VAR            VARCHAR2(5000);
    V_FECHA_HASTA  VARCHAR2(20);
    V_FECHA_DESDE  VARCHAR2(20);
    V_FECHAN       VARCHAR2(20);
    V_FONDO        VARCHAR2(20);
    P_FONDO        VARCHAR2(20);
    P_TIPO         VARCHAR2(1);
    V_COND_CORR    VARCHAR2(1) := ' ';
    V_COND_SUC     VARCHAR2(1) := ' ';
    V_ENV_CORR     VARCHAR2(1) := ' ';
    V_TIPO_EXT     VARCHAR2(100);
    V_TIPO_FONDO   VARCHAR2(1) := '%';
    V_COND_FONDO   VARCHAR2(1) := ' ';
    V_COND_T_ENVIO VARCHAR2(1) := ' ';
    V_COND_CLI     VARCHAR2(1000);

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

    CURSOR C1 IS
      SELECT FON_CODIGO, FON_TIPO
        FROM VW_FONDOS
       WHERE FON_TIPO_PRODUCTO = 'APT';

  BEGIN
    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_REXCLF_MES',
                                                      'INI');

    SELECT to_char(trunc((add_months(SYSDATE, -1)), 'MM'),
                   'DD-MON-RRRR',
                   'nls_date_language = ''LATIN AMERICAN SPANISH''')
      INTO V_FECHA_DESDE
      from dual;

    SELECT TO_CHAR(LAST_DAY(TO_DATE((add_months(SYSDATE, -1)), 'DD/MM/RRRR')),
                   'DD-MON-RRRR',
                   'nls_date_language = ''LATIN AMERICAN SPANISH''')
      INTO V_FECHA_HASTA
      FROM DUAL;

    SELECT TO_CHAR(LAST_DAY(TO_DATE((add_months(SYSDATE, -1)), 'DD/MM/RRRR')),
                   'DDMMYYYY')
      INTO V_FECHAN
      FROM DUAL;

    V_COND_CLI   := '%20AND%20CCC_CLI_PER_NUM_IDEN=%27%27890902401%27%27';
    V_TIPO_EXT   := 'R';
    V_TIPO_FONDO := 'A';

    /*P_MAIL.ENVIO_MAIL_ERROR('Inicio genera reporte REXCLF ',
    '<br>'||'Fecha consultada del reporte: '||V_FECHA||,
    DESTINATARIOS); */
    FOR R1 IN C1 LOOP
      P_TOOLS.PR_CREAR_REPORTE(P_REPORT  => 'REXCLF',
                               P_USERID  => P_USERID,
                               P_FORMATO => 'PDF',
                               --P_PARAMETROS => '+P_COND_CLI=%20AND%20CCC_CLI_PER_NUM_IDEN=%27%27'||R1.FON_CODIGO||'%27%27+P_TIPO_EXT=R+P_FECHA_HASTA='||V_FECHA_HASTA||'+P_FECHA_DESDE='||V_FECHA_DESDE||'+P_TIPO_FONDO=A',
                               P_PARAMETROS => '+P_COND_FONDO=%22%20AND%20FON_CODIGO%20=%20%27' ||
                                               R1.FON_CODIGO ||
                                               '%27%20AND%20FON_TIPO%20=%20%27A%27%20%22+P_COND_T_ENVIO=%22%20%22+P_COND_CLI=%22%20AND%20EXISTS%20(SELECT%20%27X%27%20FROM%20FILTRO_COMERCIALES%20PER%20WHERE%20PER.PER_NUM_IDEN%20=%20CCC_PER_NUM_IDEN%20AND%20PER.PER_TID_CODIGO%20=%20CCC_PER_TID_CODIGO)%20%22+P_COND_CORR=%22%20%22+P_COND_SUC=%22%20PER_SUC_CODIGO%20=%201%20AND%20%22+P_ENV_CORR=%22%20%22+P_TIPO_EXT=R+P_FECHA_HASTA=' ||
                                               V_FECHA_HASTA ||
                                               '+P_FECHA_DESDE=' ||
                                               V_FECHA_DESDE ||
                                               '+P_TIPO_FONDO=A',
                               --P_ARCHIVO => '/apps/rep_nocturnos/mensuales/REXCLF_M_'||R1.FON_CODIGO||'_'||V_FECHAN
                               P_ARCHIVO => '/apps/rep_nocturnos/mensuales/' ||
                                            R1.FON_CODIGO || '/REXCLF_M_' ||
                                            R1.FON_CODIGO || '_' || V_FECHAN);
    END LOOP;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_REXCLF_MES',
                                                      'FIN');

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PR_REPORTE_REXCLF_MES',
                              SUBSTR(SQLERRM, 1, 80),
                              'procesosnocturnos@corredores.com');
  END PR_REPORTE_REXCLF_MES;

  PROCEDURE PR_REPORTE_REXCLF_ACUM(P_USERID IN VARCHAR2) IS

    VAR            VARCHAR2(5000);
    V_FECHA_HASTA  VARCHAR2(20);
    V_FECHA_DESDE  VARCHAR2(20);
    V_FECHAN       VARCHAR2(20);
    V_FONDO        VARCHAR2(20);
    P_FONDO        VARCHAR2(20);
    P_TIPO         VARCHAR2(1);
    V_COND_CORR    VARCHAR2(1) := ' ';
    V_COND_SUC     VARCHAR2(1) := ' ';
    V_ENV_CORR     VARCHAR2(1) := ' ';
    V_TIPO_EXT     VARCHAR2(100);
    V_TIPO_FONDO   VARCHAR2(1) := '%';
    V_COND_FONDO   VARCHAR2(1) := ' ';
    V_COND_T_ENVIO VARCHAR2(1) := ' ';
    V_COND_CLI     VARCHAR2(1000);

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

    CURSOR C1 IS
      SELECT FON_CODIGO, FON_TIPO
        FROM VW_FONDOS
       WHERE FON_TIPO_PRODUCTO = 'APT';

  BEGIN
    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_REXCLF_ACUM',
                                                      'INI');

    SELECT '01-ENE-' || TO_CHAR(SYSDATE, 'YYYY')
      INTO V_FECHA_DESDE
      from dual;

    SELECT TO_CHAR(LAST_DAY(TO_DATE((add_months(SYSDATE, -1)), 'DD/MM/RRRR')),
                   'DD-MON-RRRR',
                   'nls_date_language = ''LATIN AMERICAN SPANISH''')
      INTO V_FECHA_HASTA
      FROM DUAL;

    SELECT TO_CHAR(LAST_DAY(TO_DATE((add_months(SYSDATE, -1)), 'DD/MM/RRRR')),
                   'DD-MON-RRRR',
                   'nls_date_language = ''LATIN AMERICAN SPANISH''')
      INTO V_FECHAN
      FROM DUAL;

    V_COND_CLI   := '%20AND%20CCC_CLI_PER_NUM_IDEN=%27%27890902401%27%27';
    V_TIPO_EXT   := 'R';
    V_TIPO_FONDO := 'A';

    /*P_MAIL.ENVIO_MAIL_ERROR('Inicio genera reporte REXCLF ',
    '<br>'||'Fecha consultada del reporte: '||V_FECHA||,
    DESTINATARIOS); */
    FOR R1 IN C1 LOOP
      P_TOOLS.PR_CREAR_REPORTE(P_REPORT     => 'REXCLF',
                               P_USERID     => P_USERID,
                               P_FORMATO    => 'PDF',
                               P_PARAMETROS => '+P_COND_CLI=%20AND%20CCC_CLI_PER_NUM_IDEN=%27%27' ||
                                               R1.FON_CODIGO ||
                                               '%27%27+P_TIPO_EXT=R+P_FECHA_HASTA=' ||
                                               V_FECHA_HASTA ||
                                               '+P_FECHA_DESDE=' ||
                                               V_FECHA_DESDE ||
                                               '+P_TIPO_FONDO=A',
                               --P_ARCHIVO => '/apps/rep_nocturnos/mensuales/REXCLF_A_'||R1.FON_CODIGO||'_'||V_FECHAN
                               P_ARCHIVO => '/apps/rep_nocturnos/mensuales/' ||
                                            R1.FON_CODIGO || '/REXCLF_A_' ||
                                            R1.FON_CODIGO || '_' || V_FECHAN);
    END LOOP;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_REXCLF_ACUM',
                                                      'FIN');

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PR_REPORTE_REXCLF_ACUM',
                              SUBSTR(SQLERRM, 1, 80),
                              'procesosnocturnos@corredores.com');
  END PR_REPORTE_REXCLF_ACUM;

  PROCEDURE PR_REPORTE_REXCLS(P_USERID IN VARCHAR2) IS

    VAR            VARCHAR2(5000);
    V_FECHA_INICIO VARCHAR2(20);
    V_FECHA_CORTE  VARCHAR2(20);
    V_FECHAN       VARCHAR2(20);
    V_QUE_CLIENTE  VARCHAR2(2000);

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

    CURSOR C1 IS
      SELECT '''' || FON_CODIGO || '''' FON_CODIGO, FON_CODIGO FON
        FROM VW_FONDOS
       WHERE FON_TIPO_PRODUCTO = 'APT';

  BEGIN
    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_REXCLS',
                                                      'INI');

    SELECT to_char(trunc((add_months(SYSDATE, -1)), 'MM'),
                   'DD-MON-YYYY',
                   'nls_date_language = ''LATIN AMERICAN SPANISH''')
      INTO V_FECHA_INICIO
      FROM dual;
    SELECT TO_CHAR(LAST_DAY(TO_DATE((add_months(SYSDATE, -1)), 'DD/MM/RRRR')),
                   'DD-MON-RRRR',
                   'nls_date_language = ''LATIN AMERICAN SPANISH''')
      INTO V_FECHA_CORTE
      FROM dual;

    SELECT TO_CHAR(LAST_DAY(TO_DATE((add_months(SYSDATE, -1)), 'DD/MM/RRRR')),
                   'DDMMRRRR')
      INTO V_FECHAN
      FROM dual;
    /*P_MAIL.ENVIO_MAIL_ERROR('Inicio genera reporte REXCLS ',
    '<br>'||'Fecha consultada del reporte: '||V_FECHA||,
    DESTINATARIOS); */
    /*FOR R1 IN C1 LOOP
        P_TOOLS.PR_CREAR_REPORTE(
        P_REPORT => 'REXCLS',
        P_USERID => P_USERID,
        P_FORMATO => 'PDF',
        P_PARAMETROS => '+FECHA_DESDE='||V_FECHA_INICIO||'+FECHA_HASTA='||V_FECHA_CORTE||'+QUE_CLIENTE=AND CCC_CLI_PER_NUM_IDEN ='||R1.FON_CODIGO,
        P_ARCHIVO => '/apps/rep_nocturnos/mensuales/REXCLS_'||R1.FON||'_'||V_FECHAN
        );
    END LOOP;*/

    FOR R1 IN C1 LOOP
      P_TOOLS.PR_CREAR_REPORTE(P_REPORT     => 'REXCLS2',
                               P_USERID     => P_USERID,
                               P_FORMATO    => 'PDF',
                               P_PARAMETROS => '+FECHA_DESDE=' ||
                                               V_FECHA_INICIO ||
                                               '+FECHA_HASTA=' ||
                                               V_FECHA_CORTE ||
                                               '+QUE_CLIENTE=AND CCC_CLI_PER_NUM_IDEN =' ||
                                               R1.FON_CODIGO,
                               P_ARCHIVO    => '/apps/rep_nocturnos/mensuales/' ||
                                               R1.FON || '/REXCLS_' ||
                                               R1.FON || '_' || V_FECHAN);
    END LOOP;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_REXCLS',
                                                      'FIN');

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PR_REPORTE_REXCLS',
                              SUBSTR(SQLERRM, 1, 80),
                              'procesosnocturnos@corredores.com');
  END PR_REPORTE_REXCLS;

  PROCEDURE PR_REPORTE_REXCLS3(P_USERID IN VARCHAR2) IS

    VAR            VARCHAR2(5000);
    V_FECHA_INICIO VARCHAR2(20);
    V_FECHA_CORTE  VARCHAR2(20);
    V_FECHAN       VARCHAR2(20);
    V_QUE_CLIENTE  VARCHAR2(2000);

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

    CURSOR C1 IS
      SELECT '''' || FON_CODIGO || '''' FON_CODIGO, FON_CODIGO FON
        FROM VW_FONDOS
       WHERE FON_TIPO_PRODUCTO = 'APT';

  BEGIN
    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_REXCLS3',
                                                      'INI');

    --SELECT to_char (trunc((add_months(SYSDATE,-1)),'MM') ,'DD-MON-YYYY','nls_date_language = ''LATIN AMERICAN SPANISH''')
    --reporte acumulado
    SELECT '01-ENE-' || TO_CHAR(SYSDATE, 'YYYY')
      INTO V_FECHA_INICIO
      FROM dual;
    SELECT TO_CHAR(LAST_DAY(TO_DATE((add_months(SYSDATE, -1)), 'DD/MM/RRRR')),
                   'DD-MON-RRRR',
                   'nls_date_language = ''LATIN AMERICAN SPANISH''')
      INTO V_FECHA_CORTE
      FROM dual;

    SELECT TO_CHAR(LAST_DAY(TO_DATE((add_months(SYSDATE, -1)), 'DD/MM/RRRR')),
                   'DDMMRRRR')
      INTO V_FECHAN
      FROM dual;
    /*P_MAIL.ENVIO_MAIL_ERROR('Inicio genera reporte REXCLS ',
    '<br>'||'Fecha consultada del reporte: '||V_FECHA||,
    DESTINATARIOS); */
    FOR R1 IN C1 LOOP
      P_TOOLS.PR_CREAR_REPORTE(P_REPORT     => 'REXCLS3',
                               P_USERID     => P_USERID,
                               P_FORMATO    => 'TXT',
                               P_PARAMETROS => '+FECHA_DESDE=' ||
                                               V_FECHA_INICIO ||
                                               '+FECHA_HASTA=' ||
                                               V_FECHA_CORTE ||
                                               '+QUE_CLIENTE=AND CCC_CLI_PER_NUM_IDEN =' ||
                                               R1.FON_CODIGO,
                               P_ARCHIVO    => '/apps/rep_nocturnos/mensuales/' ||
                                               R1.FON || '/REXCLS_' ||
                                               R1.FON || '_' || V_FECHAN);
    END LOOP;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_REXCLS3',
                                                      'FIN');

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PR_REPORTE_REXCLS3',
                              SUBSTR(SQLERRM, 1, 80),
                              'procesosnocturnos@corredores.com');
  END PR_REPORTE_REXCLS3;

  PROCEDURE PR_REPORTE_RMOVBA(P_USERID IN VARCHAR2) IS

    VAR           VARCHAR2(2000);
    V_FECHA       VARCHAR2(20);
    V_FECHA2      VARCHAR2(20);
    V_FECHAN      VARCHAR2(20);
    V_CONDICION   VARCHAR2(5000);
    V_FECHAS      VARCHAR2(1000);
    V_FECHAS1     VARCHAR2(1000);
    V_FECHA_INI   VARCHAR2(1000);
    V_MOVIMIENTO  VARCHAR2(5000) := ' ';
    V_MOVIMIENTO1 VARCHAR2(5000) := ' ';

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN
    P_NUM_INI   := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_RMOVBA',
                                                        'INI');
    V_CONDICION := 'CBA.CBA_NEG_CONSECUTIVO%20LIKE%20%27%25%27%20AND%20CBA.CBA_ESTADO%20 =%20%27A%27%20AND';

    SELECT TO_CHAR(TRUNC((SYSDATE - 1)),
                   'DD-MON-YYYY',
                   'nls_date_language = ''LATIN AMERICAN SPANISH'''),
           TO_CHAR(TRUNC((SYSDATE)),
                   'DD-MON-YYYY',
                   'nls_date_language = ''LATIN AMERICAN SPANISH''')
      INTO V_FECHA, V_FECHA2
      FROM DUAL;

    SELECT TO_CHAR(TRUNC((SYSDATE - 1)), 'DDMMYYYY')
      INTO V_FECHAN
      FROM DUAL;

    /*P_MAIL.ENVIO_MAIL_ERROR('Inicio genera reporte RMOVBA ',
    '<br>'||'Fecha consultada del reporte: '||V_FECHA||,
    DESTINATARIOS); */

    P_TOOLS.PR_CREAR_REPORTE(P_REPORT     => 'RMOVBA',
                             P_USERID     => P_USERID,
                             P_FORMATO    => 'PDF',
                             P_PARAMETROS => '+P_FECHAS=MCB.MCB_FECHA%20%3E=%20%27%27' ||
                                             V_FECHA ||
                                             '%27%27%20AND%20MCB.MCB_FECHA%20%3C%20%27%27' ||
                                             V_FECHA2 ||
                                             '%27%27+P_FECHAS1=%20PCB.PCB_FECHA%20%3E=%20%27%27' ||
                                             V_FECHA ||
                                             '%27%27%20AND%20PCB.PCB_FECHA%20%3C%20%27%27' ||
                                             V_FECHA2 ||
                                             '%27%27+P_FECHA_INI=' ||
                                             V_FECHA || '+P_CONDICION=' ||
                                             V_CONDICION,
                             P_ARCHIVO    => '/apps/rep_nocturnos/diarios/RMOVBA_' ||
                                             V_FECHAN);

    P_TOOLS.PR_CREAR_REPORTE(P_REPORT     => 'RMOVBA',
                             P_USERID     => P_USERID,
                             P_FORMATO    => 'TXT',
                             P_PARAMETROS => '+P_FECHAS=MCB.MCB_FECHA%20%3E=%20%27%27' ||
                                             V_FECHA ||
                                             '%27%27%20AND%20MCB.MCB_FECHA%20%3C%20%27%27' ||
                                             V_FECHA2 ||
                                             '%27%27+P_FECHAS1=%20PCB.PCB_FECHA%20%3E=%20%27%27' ||
                                             V_FECHA ||
                                             '%27%27%20AND%20PCB.PCB_FECHA%20%3C%20%27%27' ||
                                             V_FECHA2 ||
                                             '%27%27+P_FECHA_INI=' ||
                                             V_FECHA || '+P_CONDICION=' ||
                                             V_CONDICION,
                             P_ARCHIVO    => '/apps/rep_nocturnos/diarios/RMOVBA_' ||
                                             V_FECHAN);

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_RMOVBA',
                                                      'FIN');

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PR_REPORTE_RMOVBA',
                              SUBSTR(SQLERRM, 1, 80),
                              'procesosnocturnos@corredores.com');
  END PR_REPORTE_RMOVBA;

  PROCEDURE PR_REPORTE_RCMVTF(P_USERID IN VARCHAR2) IS

    VAR       VARCHAR2(2000);
    V_FECHA_I VARCHAR2(20);
    V_FECHA_F VARCHAR2(20);
    V_FECHAN  VARCHAR2(20);

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN
    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_RCMVTF',
                                                      'INI');

    SELECT TO_CHAR(TRUNC(P_TOOLS.CF_DIA_HABIL_ANTERIOR(SYSDATE)),
                   'DD-MON-YYYY',
                   'nls_date_language = ''LATIN AMERICAN SPANISH''')
      INTO V_FECHA_F
      FROM DUAL;

    SELECT TO_CHAR(TRUNC(P_TOOLS.RESTAR_HABILES_A_FECHA(SYSDATE, 3)),
                   'DD-MON-YYYY',
                   'nls_date_language = ''LATIN AMERICAN SPANISH''')
      INTO V_FECHA_I
      FROM DUAL;

    SELECT TO_CHAR(TRUNC(SYSDATE - 1), 'DDMMYYYY') INTO V_FECHAN FROM DUAL;
    /*P_MAIL.ENVIO_MAIL_ERROR('Inicio genera reporte RCMVTF ',
    '<br>'||'Fecha consultada del reporte: '||V_FECHA||,
    DESTINATARIOS); */

    P_TOOLS.PR_CREAR_REPORTE(P_REPORT     => 'RCMVTF',
                             P_USERID     => P_USERID,
                             P_FORMATO    => 'PDF',
                             P_PARAMETROS => '+FECHA_DESDE=' || V_FECHA_I ||
                                             '+FECHA_HASTA=' || V_FECHA_F ||
                                             '+MVTOS=AND%20FON.FON_ESTADO%20=%20%27%27A%27%27',
                             P_ARCHIVO    => '/apps/rep_nocturnos/diarios/RCMVTF_' ||
                                             V_FECHAN);

    P_TOOLS.PR_CREAR_REPORTE(P_REPORT     => 'RCMVTF',
                             P_USERID     => P_USERID,
                             P_FORMATO    => 'TXT',
                             P_PARAMETROS => '+FECHA_DESDE=' || V_FECHA_I ||
                                             '+FECHA_HASTA=' || V_FECHA_F ||
                                             '+MVTOS=AND%20FON.FON_ESTADO%20=%20%27%27A%27%27',
                             P_ARCHIVO    => '/apps/rep_nocturnos/diarios/RCMVTF_' ||
                                             V_FECHAN);

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_RCMVTF',
                                                      'FIN');

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PR_REPORTE_RCMVTF',
                              SUBSTR(SQLERRM, 1, 80),
                              'procesosnocturnos@corredores.com');
  END PR_REPORTE_RCMVTF;

