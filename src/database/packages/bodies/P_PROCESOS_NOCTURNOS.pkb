  PROCEDURE PR_REPORTE_RCONRV(P_USERID IN VARCHAR2) IS

    VAR       VARCHAR2(2000);
    P_FONDO   VARCHAR2(1);
    V_FECHA   VARCHAR2(20);
    V_FECHAN  VARCHAR2(20);
    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;
    V_USERID  VARCHAR2(50);

  BEGIN
    V_USERID  := 'NOCTURNO';
    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_RCONRV',
                                                      'INI');

    SELECT TO_CHAR(TRUNC(SYSDATE - 1),
                   'DD-MON-YYYY',
                   'nls_date_language = ''LATIN AMERICAN SPANISH''')
      INTO V_FECHA
      FROM DUAL;

    SELECT TO_CHAR(TRUNC(SYSDATE - 1), 'DDMMYYYY') INTO V_FECHAN FROM DUAL;
    /*P_MAIL.ENVIO_MAIL_ERROR('Inicio genera reporte RPYGFO ',
    '<br>'||'Fecha consultada del reporte: '||V_FECHA||,
    DESTINATARIOS); */

    P_TOOLS.PR_CREAR_REPORTE(P_REPORT     => 'RCONRV',
                             P_USERID     => P_USERID,
                             P_FORMATO    => 'TXT',
                             P_PARAMETROS => '+P_USUARIO=%27' || V_USERID ||
                                             '%27+P_REPORTE=%27CONT%27+P_FECHA=' ||
                                             V_FECHA || '+P_FONDO=%25',
                             P_ARCHIVO    => '/apps/rep_nocturnos/diarios/RCONRV_' ||
                                             V_FECHAN);
    P_TOOLS.PR_CREAR_REPORTE(P_REPORT     => 'RCONRV',
                             P_USERID     => P_USERID,
                             P_FORMATO    => 'XLS',
                             P_PARAMETROS => '+P_USUARIO=%27' || V_USERID ||
                                             '%27+P_REPORTE=%27CONT%27+P_FECHA=' ||
                                             V_FECHA || '+P_FONDO=%25',
                             P_ARCHIVO    => '/apps/rep_nocturnos/diarios/RCONRV_' ||
                                             V_FECHAN);

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_REPORTE_RCONRV',
                                                      'FIN');

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PR_REPORTE_RCONRV',
                              SUBSTR(SQLERRM, 1, 80),
                              'procesosnocturnos@corredores.com');
  END PR_REPORTE_RCONRV;

  PROCEDURE P_GENERA_REPORTES_RIESGOS(P_USERID IN VARCHAR2) IS
  BEGIN
    -- VAGTUD975-2 FCP DEUDA - INVERSIONES EN CREDITOS
    P_INV_CREDITOS.PR_PORTAFOLIO_CREDITOS;

    P_EJECUTA_ROPDER;
    P_EJECUTA_CIDIDI;
    P_EJECUTA_ORDENES;
    PR_REPORTE_PYGFON(P_USERID);
    P_EJECUTA_INPOAD;
    PROD.P_GENERA_ARCHIVOS_GEARCI.EJECUTA_GEARCI;
    -- VAGTUD871 - OPCIONES FICS
    P_DERIVADOS.PR_REPORTE_PORTAFOLIO;
    P_DERIVADOS.PR_REPORTE_OPERACIONES;
    PR_EJECUTA_FORMATO_531_GENERAL(SYSDATE);
    P_GENERA_SAMOBS;
    P_EJECUTA_RFLVNF; --PLANO INTEGRADO 8
    P_EJECUTA_REINEG; --PLANO INTEGRADO 8
    P_EJECUTA_MANSIM; --PLANO INTEGRADO 8
    P_EJECUTA_MANSIM_NEG; --PLANO INTEGRADO 8
    P_EJECUTA_FIRECA; --PLANO INTEGRADO 8
    P_EJECUTA_DATCLI; --PLANO INTEGRADO 8
    P_EJECUTA_RECOFU; --Se debe de ejecutar en esta posicion del flujo
    P_EJECUTA_RCOND; --Se debe de ejecutar en esta posicion del flujo
    P_EJECUTA_OPEBOL;
    P_EJECUTA_REPGAR_BVC; --REPORTES PLANO INTEGRADO 5 PARTE B - JCALDERON
    P_EJECUTA_REPGAR_DCRCC; --REPORTES PLANO INTEGRADO 5 PARTE B - JCALDERON
    P_EJECUTA_REPGAR_REPOS; --REPORTES PLANO INTEGRADO 5 PARTE B - JCALDERON
    P_EJECUTA_REPGAR_DSCB; --REPORTES PLANO INTEGRADO 5 PARTE B - JCALDERON
    P_EJECUTA_REPGAR_PRORRATEO; --REPORTES PLANO INTEGRADO 5 PARTE B - JCALDERON
    P_EJECUTA_COORRE; --REPORTES PLANO INTEGRADO 5 PARTE B - JCALDERON
    P_EJECUTA_CODEOR2; --REPORTES PLANO INTEGRADO 5 PARTE B - JCALDERON
    P_REOPRV; --REPORTES PLANO INTEGRADO 5 PARTE B - JCALDERON
    PORTAFOLIO_VALORACION; --OJO
    P_FORMATOS_VAR.PR_LIQUIDEZ_385(SYSDATE - 1);
    P_FORMATOS_VAR.PR_PORTAFOLIO_385(SYSDATE - 1);
    P_FORMATOS_VAR.PR_SPOT_DIVISAS_385(SYSDATE - 1);
    P_FORMATOS_VAR.PR_FUTUROS_385(SYSDATE - 1);
    P_PROCESOS_NOCTURNOS.P_LIMITES_CLIENTES;
    P_LIMCOS;
    -- VAGTUD881 - CONSUMOS CONTRAPARTES
    P_LIMITES_CONSUMO.PR_GENERA_CONSUMO_CIERRE_COP(TRUNC(SYSDATE - 1));
    --P_ARCHIVO_PORTAFOLIO_FACT;  --Proyecto Factoring VAGTUD876
    P_EJECUTA_VAPAEMI;

  END P_GENERA_REPORTES_RIESGOS;

  --------------------------INICIO REPORTES PLANO INTEGRADO 5 PARTE B - JCALDERON -----------------------

  PROCEDURE P_REOPRV IS
    CURSOR C_FONDOS_REOPRV IS
      SELECT DISTINCT FON_CODIGO
        FROM FONDOS
       WHERE FON_ESTADO = 'A'
         AND FON_TIPO != 'O'
         AND NOT EXISTS
       (SELECT 1
                FROM PARAMETROS_FONDOS
               WHERE PFO_FON_CODIGO = FON_CODIGO
                 AND PFO_PAR_CODIGO IN (70)
                 AND NVL(PFO_RANGO_MIN_CHAR, 'N') = 'S')
         AND ((FON_CAPITAL_PRIVADO = 'N' AND
             FONDOS.FON_TIPO_ADMINISTRACION = 'A' AND
             FONDOS.FON_ESTADO = 'A') OR
             (FONDOS.FON_CAPITAL_PRIVADO = 'N' AND
             FONDOS.FON_TIPO_ADMINISTRACION = 'F' AND
             FONDOS.FON_ESTADO = 'A' AND FONDOS.FON_TIPO = 'A' AND
             FONDOS.FON_NOMBRE_CORTO IS NOT NULL) OR EXISTS
              (SELECT 1
                 FROM PARAMETROS_FONDOS
                WHERE PFO_FON_CODIGO = FON_CODIGO
                  AND PFO_PAR_CODIGO IN (19)
                  AND NVL(PFO_RANGO_MIN_CHAR, 'N') = 'S'))
       ORDER BY FON_CODIGO;
    V_FONDOS_REOPRV VARCHAR2(15);

    IND_ERROR      BOOLEAN;
    MENSAJE        VARCHAR2(200);
    V_RUTA         VARCHAR2(100);
    NOMBRE_ARCHIVO VARCHAR2(100);
    P_CODIGO       VARCHAR2(200);
    P_RESPUESTA    VARCHAR2(200);
    P_NUM_INI      NUMBER;
    P_NUM_FIN      NUMBER;
  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_GENERA_REPORTES_RIESGOS - P_REOPRV',
                                                      'INI');

    DELETE FROM TMP_CONTADO_RV;
    COMMIT;
    OPEN C_FONDOS_REOPRV;
    FETCH C_FONDOS_REOPRV
      INTO V_FONDOS_REOPRV;
    WHILE C_FONDOS_REOPRV%FOUND LOOP
      P_GESTION_RV.PR_GESTION_POSICION_PROPIA_RV(SYSDATE - 1,
                                                 V_FONDOS_REOPRV,
                                                 'CONT',
                                                 IND_ERROR,
                                                 MENSAJE);
      INSERT INTO TMP_CONTADO_RV
        (TCS_FECHA_CONSULTA,
         TCS_IDENT_CLIENTE,
         TCS_PORTAFOLIO,
         TCS_CODIGO,
         TCS_TRADER,
         TCS_MNEMO_ESPECIE,
         TCS_ISIN,
         TCS_CLASE_INVERSION_SFC,
         TCS_CLASE_ACCIONES,
         TCS_CLASE_OPERACIONES,
         TCS_PUNTA,
         TCS_NUMERO_ACCIONES,
         TCS_PRECIO_PACTADO,
         TCS_VAL_OPERACION_INICIAL,
         TCS_VALOR_CUMPLIMIENTO,
         TCS_FECHA_OPERACION,
         TCS_VALOR_NOMINAL,
         TCS_FECHA_CUMPLIMIENTO,
         TCS_DIAS_AL_CUMPLIMIENTO,
         TCS_VALORACION_DEL_DINERO,
         TCS_PRECIO_MERCADO,
         TCS_METODO_VALORACION,
         TCS_BURSATILIDAD,
         TCS_VALOR_MERCADO_COP,
         TCS_DERECHO,
         TCS_OBLIGACION,
         TCS_DER_MENOS_OBLIG,
         TCS_CALIFICACION_EMISOR,
         TCS_GOBIERNO_CORPORATIVO,
         TCS_VALOR_MERCADO_COP_TM1,
         TCS_FON_CODIGO,
         TCS_CONTRAPARTIDA)
        SELECT TCS_FECHA_CONSULTA,
               TCS_IDENT_CLIENTE,
               TCS_PORTAFOLIO,
               TCS_CODIGO,
               TCS_TRADER,
               TCS_MNEMO_ESPECIE,
               TCS_ISIN,
               TCS_CLASE_INVERSION_SFC,
               TCS_CLASE_ACCIONES,
               TCS_CLASE_OPERACIONES,
               TCS_PUNTA,
               TCS_NUMERO_ACCIONES,
               TCS_PRECIO_PACTADO,
               TCS_VAL_OPERACION_INICIAL,
               TCS_VALOR_CUMPLIMIENTO,
               TCS_FECHA_OPERACION,
               TCS_VALOR_NOMINAL,
               TCS_FECHA_CUMPLIMIENTO,
               TCS_DIAS_AL_CUMPLIMIENTO,
               TCS_VALORACION_DEL_DINERO,
               TCS_PRECIO_MERCADO,
               TCS_METODO_VALORACION,
               TCS_BURSATILIDAD,
               TCS_VALOR_MERCADO_COP,
               TCS_DERECHO,
               TCS_OBLIGACION,
               TCS_DER_MENOS_OBLIG,
               TCS_CALIFICACION_EMISOR,
               TCS_GOBIERNO_CORPORATIVO,
               TCS_VALOR_MERCADO_COP_TM1,
               TCS_FON_CODIGO,
               TCS_CONTRAPARTIDA
          FROM GL_CONTADO_RV;
      COMMIT;
      FETCH C_FONDOS_REOPRV
        INTO V_FONDOS_REOPRV;
    END LOOP;
    CLOSE C_FONDOS_REOPRV;
    V_RUTA         := '\\nas.corredor.local\Riesgo\CONFIDENCIAL\Reportes Excel Coeasy\';
    NOMBRE_ARCHIVO := 'CONTADO_' ||
                      TO_CHAR(SYSDATE - 1, 'DDMMYYYY_hh24mmss');

    P_REPORTES.PR_GENERAR_XLSX_API(P_RUTA           => V_RUTA,
                                   P_NOMBRE_ARCHIVO => NOMBRE_ARCHIVO,
                                   P_QUERY          => '      SELECT TCS_PORTAFOLIO Portafolio ' ||
                                                       '            ,TCS_CODIGO Codigo ' ||
                                                       '            ,TCS_TRADER Trader ' ||
                                                       '            ,TCS_MNEMO_ESPECIE Especie ' ||
                                                       '            ,TCS_ISIN Isin ' ||
                                                       '            ,TCS_CLASE_INVERSION_SFC Clase_Inv ' ||
                                                       '            ,TCS_CLASE_ACCIONES Clase_Acc ' ||
                                                       '            ,TCS_CLASE_OPERACIONES Clase_Operacion ' ||
                                                       '            ,TCS_PUNTA Punta ' ||
                                                       '            ,TCS_NUMERO_ACCIONES Numero_Acciones ' ||
                                                       '            ,TCS_PRECIO_PACTADO Precio_Pactado ' ||
                                                       '            ,TCS_VAL_OPERACION_INICIAL Val_Operacion_Inicial ' ||
                                                       '            ,TCS_VALOR_CUMPLIMIENTO Valor_Cumplimiento ' ||
                                                       '            ,to_char(TCS_FECHA_OPERACION,''DD-MM-YYYY'') Fecha_Operacion ' ||
                                                       '            ,TCS_VALOR_NOMINAL Valor_Nominal ' ||
                                                       '            ,TCS_FECHA_CUMPLIMIENTO Fecha_Cumplimiento ' ||
                                                       '            ,TCS_DIAS_AL_CUMPLIMIENTO Dias_al_Cumplimiento ' ||
                                                       '            ,TCS_VALORACION_DEL_DINERO Valoracion_del_Dinero ' ||
                                                       '            ,TCS_PRECIO_MERCADO Precio_Mercado ' ||
                                                       '            ,TCS_METODO_VALORACION Metodo_Valora ' ||
                                                       '            ,TCS_BURSATILIDAD Bursatilidad ' ||
                                                       '            ,TCS_VALOR_MERCADO_COP Valor_Mercado_Cop ' ||
                                                       '            ,TCS_DERECHO Derecho ' ||
                                                       '            ,TCS_OBLIGACION Obligacion ' ||
                                                       '            ,TCS_DER_MENOS_OBLIG Derecho_Menos_Obligacion ' ||
                                                       '            ,TCS_CALIFICACION_EMISOR Calif_Emisor ' ||
                                                       '            ,TCS_GOBIERNO_CORPORATIVO Gobierno_Corporativo ' ||
                                                       '            ,TRUNC(SYSDATE - 1) FECHA_REPORTE  ' ||
                                                      --'            ,TCS_IDENT_CLIENTE '||
                                                       '            ,NVL(TCS_VALOR_MERCADO_COP_TM1, 0) Valor_Mercado_Cop_T_1 ' ||
                                                       '            ,TCS_FON_CODIGO Identificacion_Cliente ' ||
                                                       '            ,TCS_CONTRAPARTIDA Contrapartida ' ||
                                                       '        FROM TMP_CONTADO_RV ' ||
                                                      --'       WHERE TCS_FECHA_CONSULTA = :P_FECHA '||
                                                       '       ORDER BY TCS_FON_CODIGO ' ||
                                                       '            ,TCS_MNEMO_ESPECIE',
                                   P_CODIGO         => P_CODIGO,
                                   P_RESPUESTA      => P_RESPUESTA);
    IF P_CODIGO = '0000' THEN
      DBMS_OUTPUT.PUT_LINE('Se ha generado el archivo, en la ruta ' ||
                           V_RUTA);
    END IF;
    DELETE FROM TMP_REPOS_RV;
    COMMIT;
    OPEN C_FONDOS_REOPRV;
    FETCH C_FONDOS_REOPRV
      INTO V_FONDOS_REOPRV;
    WHILE C_FONDOS_REOPRV%FOUND LOOP
