  CREATE OR REPLACE EDITIONABLE PACKAGE BODY "PROD"."P_PROCESOS_NOCTURNOS" AS

  PROCEDURE PR_VINCULACION_BUKCOE IS

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_VINCULACION_BUKCOE',
                                                      'INI');

    P_VINCULACION_PJ.PR_INSERTAR('DGC', SYSDATE - 1);
    P_VINCULACION_PJ.PR_VALIDAR('DGC');

    P_VINCULACION_PJ.PR_INSERTAR('DTC', SYSDATE - 1);
    P_VINCULACION_PJ.PR_VALIDAR('DTC');

    P_VINCULACION_PJ.PR_INSERTAR('FAT', SYSDATE - 1);
    P_VINCULACION_PJ.PR_VALIDAR('FAT');

    P_VINCULACION_PJ.PR_INSERTAR('PRC', SYSDATE - 1);
    P_VINCULACION_PJ.PR_VALIDAR('PRC');

    P_VINCULACION_PJ.PR_INSERTAR('REL', SYSDATE - 1);
    P_VINCULACION_PJ.PR_VALIDAR('REL');

    P_VINCULACION_PJ.PR_INSERTAR('RPS', SYSDATE - 1);
    P_VINCULACION_PJ.PR_VALIDAR('RPS');

    P_VINCULACION_PJ.PR_INSERTAR('REP', SYSDATE - 1);
    P_VINCULACION_PJ.PR_VALIDAR('REP');

    P_VINCULACION_PJ.PR_INSERTAR('LFS', SYSDATE - 1);
    P_VINCULACION_PJ.PR_VALIDAR('LFS');

    P_VINCULACION_PN.PR_INSERTAR('DGC', SYSDATE - 1);
    P_VINCULACION_PN.PR_VALIDAR('DGC');

    P_VINCULACION_PN.PR_INSERTAR('DTC', SYSDATE - 1);
    P_VINCULACION_PN.PR_VALIDAR('DTC');

    P_VINCULACION_PN.PR_INSERTAR('FAT', SYSDATE - 1);
    P_VINCULACION_PN.PR_VALIDAR('FAT');

    P_VINCULACION_PN.PR_INSERTAR('PRC', SYSDATE - 1);
    P_VINCULACION_PN.PR_VALIDAR('PRC');

    P_VINCULACION_PN.PR_INSERTAR('RJC', SYSDATE - 1);
    P_VINCULACION_PN.PR_VALIDAR('RJC');

    P_VINCULACION_PN.PR_INSERTAR('REP', SYSDATE - 1);
    P_VINCULACION_PN.PR_VALIDAR('REP');

    P_VINCULACION_ME.PR_INSERTAR('DGC', SYSDATE - 1);
    P_VINCULACION_ME.PR_VALIDAR('DGC');

    P_VINCULACION_ME.PR_INSERTAR('DTC', SYSDATE - 1);
    P_VINCULACION_ME.PR_VALIDAR('DTC');

    P_VINCULACION_ME.PR_INSERTAR('PRC', SYSDATE - 1);
    P_VINCULACION_ME.PR_VALIDAR('PRC');

    P_VINCULACION_PN.PR_GENERACION;
    P_VINCULACION_PJ.PR_GENERACION;
    P_VINCULACION_ME.PR_GENERACION;
    P_VINCULACION_PN.PR_MARCACION('MAR', SYSDATE - 1);

    P_VINCULACION_PN.PR_ENVIO_MAIL;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_VINCULACION_BUKCOE',
                                                      'FIN');
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Fallo en creaciżn de estructuras Coeasy BUK del dia :' ||
                              TO_CHAR(SYSDATE - 1, 'DD-MON-YYYY'),
                              '<br>' ||
                              'Fallo el proceso de generaciżn de estructuras de Coeasy BUK del dia : ' ||
                              TO_CHAR(SYSDATE - 1, 'DD-MON-YYYY'),
                              'stecnico@corredores.com,lcala@corredores.com,smotta@corredores.com');
  END PR_VINCULACION_BUKCOE;

  /***********************************************************************************/
  PROCEDURE P_SALDOS_DIARIOS_CLIENTES(FDESDE          IN DATE,
                                      FHASTA          IN DATE,
                                      P_NUM_IDEN      IN VARCHAR2,
                                      P_TID_CODIGO    IN VARCHAR2,
                                      P_NUMERO_CUENTA NUMBER,
                                      P_TX            IN NUMBER DEFAULT NULL) IS

    FECHA        DATE;
    N_ID_PROCESO NUMBER;
    N_TX         NUMBER;

  BEGIN

    --se asignar el consecutivo del proceso(tabla PARAMETRIZACION_PROCESOS)
    N_ID_PROCESO := P_TRAZA_CORE.FN_ID_PROCESO('P_PROCESOS_NOCTURNOS.P_SALDOS_DIARIOS_CLIENTES');

    --se Asigna consecutivo para la transaccion, si el proceso es el primero que se llama, reinicia el consecutivo
    N_TX := P_TRAZA_CORE.FN_TRAE_TX(P_TX);

    --Registra Traza
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'I',
                                    'Inicio proceso P_PROCESOS_NOCTURNOS.P_SALDOS_DIARIOS_CLIENTES . Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE,
                                            'DD-MM-YYYY HH24:mi:ss') ||
                                    ' Rango de fechas procesado: ' ||
                                    TO_CHAR(FDESDE, 'DD-MON-YYYY') || ' a ' ||
                                    TO_CHAR(FHASTA, 'DD-MON-YYYY'),
                                    N_TX);

    DELETE FROM SALDOS_DIARIOS_CLIENTE
     WHERE SDI_FECHA_SALDO >= FDESDE
       AND SDI_FECHA_SALDO < FHASTA + 1
       AND SDI_CCC_CLI_PER_NUM_IDEN = P_NUM_IDEN
       AND SDI_CCC_CLI_PER_TID_CODIGO = P_TID_CODIGO
       AND SDI_CCC_NUMERO_CUENTA = P_NUMERO_CUENTA;

    FECHA := TRUNC(FDESDE);
    WHILE FECHA <= FHASTA LOOP
      DELETE FROM GL_ULTIMO_MOV_SALDO;
      DELETE FROM GL_ULTIMO_MOV_SALDO_CC;
      DELETE FROM GL_ULTIMO_MOV_SALDO_BURSATIL;
      DELETE FROM GL_ULTIMO_MOV_SALDO_ADVAL;
      DELETE FROM GL_ULTIMO_MOV_SALDO_CANJE;
      DELETE FROM GL_ULTIMO_MOV_SALDO_CANJE_CC;
      DELETE FROM GL_ULTIMO_MOV_SALDO_CONTADO;
      DELETE FROM GL_ULTIMO_MOV_SALDO_PLAZO;

      INSERT INTO GL_ULTIMO_MOV_SALDO
        (MCC_CCC_CLI_PER_NUM_IDEN,
         MCC_CCC_CLI_PER_TID_CODIGO,
         MCC_CCC_NUMERO_CUENTA,
         MCC_FECHA_SALDO,
         MCC_CONSECUTIVO_SALDO)
        SELECT MCC_CCC_CLI_PER_NUM_IDEN,
               MCC_CCC_CLI_PER_TID_CODIGO,
               MCC_CCC_NUMERO_CUENTA,
               MAX(MCC_FECHA) FECHA_SALDO,
               MAX(MCC_CONSECUTIVO) CONSECUTIVO
          FROM MOVIMIENTOS_CUENTA_CORREDORES
         WHERE MCC_CCC_CLI_PER_NUM_IDEN = P_NUM_IDEN
           AND MCC_CCC_CLI_PER_TID_CODIGO = P_TID_CODIGO
           AND MCC_CCC_NUMERO_CUENTA = P_NUMERO_CUENTA
           AND MCC_FECHA < TRUNC(FECHA + 1)
           AND MCC_MONTO <> 0
         GROUP BY MCC_CCC_CLI_PER_NUM_IDEN,
                  MCC_CCC_CLI_PER_TID_CODIGO,
                  MCC_CCC_NUMERO_CUENTA;

      INSERT INTO GL_ULTIMO_MOV_SALDO_CC
        (MCC_CCC_CLI_PER_NUM_IDEN,
         MCC_CCC_CLI_PER_TID_CODIGO,
         MCC_CCC_NUMERO_CUENTA,
         MCC_FECHA_SALDO_CC,
         MCC_CONSECUTIVO_SALDO_CC)
        SELECT MCC_CCC_CLI_PER_NUM_IDEN,
               MCC_CCC_CLI_PER_TID_CODIGO,
               MCC_CCC_NUMERO_CUENTA,
               MAX(MCC_FECHA) FECHA_SALDO,
               MAX(MCC_CONSECUTIVO) CONSECUTIVO
          FROM MOVIMIENTOS_CUENTA_CORREDORES
         WHERE MCC_CCC_CLI_PER_NUM_IDEN = P_NUM_IDEN
           AND MCC_CCC_CLI_PER_TID_CODIGO = P_TID_CODIGO
           AND MCC_CCC_NUMERO_CUENTA = P_NUMERO_CUENTA
           AND MCC_FECHA < TRUNC(FECHA + 1)
           AND MCC_MONTO_CARTERA <> 0
         GROUP BY MCC_CCC_CLI_PER_NUM_IDEN,
                  MCC_CCC_CLI_PER_TID_CODIGO,
                  MCC_CCC_NUMERO_CUENTA;

      INSERT INTO GL_ULTIMO_MOV_SALDO_BURSATIL
        (MCC_CCC_CLI_PER_NUM_IDEN,
         MCC_CCC_CLI_PER_TID_CODIGO,
         MCC_CCC_NUMERO_CUENTA,
         MCC_FECHA_SALDO_BURSATIL,
         MCC_CONSECUTIVO_SALDO_BURSATIL)
        SELECT MCC_CCC_CLI_PER_NUM_IDEN,
               MCC_CCC_CLI_PER_TID_CODIGO,
               MCC_CCC_NUMERO_CUENTA,
               MAX(MCC_FECHA) FECHA_SALDO,
               MAX(MCC_CONSECUTIVO) CONSECUTIVO
          FROM MOVIMIENTOS_CUENTA_CORREDORES
         WHERE MCC_CCC_CLI_PER_NUM_IDEN = P_NUM_IDEN
           AND MCC_CCC_CLI_PER_TID_CODIGO = P_TID_CODIGO
           AND MCC_CCC_NUMERO_CUENTA = P_NUMERO_CUENTA
           AND MCC_FECHA < TRUNC(FECHA + 1)
           AND MCC_MONTO_BURSATIL <> 0
         GROUP BY MCC_CCC_CLI_PER_NUM_IDEN,
                  MCC_CCC_CLI_PER_TID_CODIGO,
                  MCC_CCC_NUMERO_CUENTA;

      INSERT INTO GL_ULTIMO_MOV_SALDO_ADVAL
        (MCC_CCC_CLI_PER_NUM_IDEN,
         MCC_CCC_CLI_PER_TID_CODIGO,
         MCC_CCC_NUMERO_CUENTA,
         MCC_FECHA_SALDO_ADVAL,
         MCC_CONSECUTIVO_SALDO_ADVAL)
        SELECT MCC_CCC_CLI_PER_NUM_IDEN,
               MCC_CCC_CLI_PER_TID_CODIGO,
               MCC_CCC_NUMERO_CUENTA,
               MAX(MCC_FECHA) FECHA_SALDO,
               MAX(MCC_CONSECUTIVO) CONSECUTIVO
          FROM MOVIMIENTOS_CUENTA_CORREDORES
         WHERE MCC_CCC_CLI_PER_NUM_IDEN = P_NUM_IDEN
           AND MCC_CCC_CLI_PER_TID_CODIGO = P_TID_CODIGO
           AND MCC_CCC_NUMERO_CUENTA = P_NUMERO_CUENTA
           AND MCC_FECHA < TRUNC(FECHA + 1)
           AND MCC_MONTO_ADMON_VALORES <> 0
         GROUP BY MCC_CCC_CLI_PER_NUM_IDEN,
                  MCC_CCC_CLI_PER_TID_CODIGO,
                  MCC_CCC_NUMERO_CUENTA;

      INSERT INTO GL_ULTIMO_MOV_SALDO_CANJE
        (MCC_CCC_CLI_PER_NUM_IDEN,
         MCC_CCC_CLI_PER_TID_CODIGO,
         MCC_CCC_NUMERO_CUENTA,
         MCC_FECHA_SALDO_CANJE,
         MCC_CONSECUTIVO_SALDO_CANJE)
        SELECT MCC_CCC_CLI_PER_NUM_IDEN,
               MCC_CCC_CLI_PER_TID_CODIGO,
               MCC_CCC_NUMERO_CUENTA,
               MAX(MCC_FECHA) FECHA_SALDO,
               MAX(MCC_CONSECUTIVO) CONSECUTIVO
          FROM MOVIMIENTOS_CUENTA_CORREDORES
         WHERE MCC_CCC_CLI_PER_NUM_IDEN = P_NUM_IDEN
           AND MCC_CCC_CLI_PER_TID_CODIGO = P_TID_CODIGO
           AND MCC_CCC_NUMERO_CUENTA = P_NUMERO_CUENTA
           AND MCC_FECHA < TRUNC(FECHA + 1)
           AND MCC_MONTO_CANJE <> 0
         GROUP BY MCC_CCC_CLI_PER_NUM_IDEN,
                  MCC_CCC_CLI_PER_TID_CODIGO,
                  MCC_CCC_NUMERO_CUENTA;

      INSERT INTO GL_ULTIMO_MOV_SALDO_CANJE_CC
        (MCC_CCC_CLI_PER_NUM_IDEN,
         MCC_CCC_CLI_PER_TID_CODIGO,
         MCC_CCC_NUMERO_CUENTA,
         MCC_FECHA_SALDO_CANJE_CC,
         MCC_CONSECUTIVO_SALDO_CANJE_CC)
        SELECT MCC_CCC_CLI_PER_NUM_IDEN,
               MCC_CCC_CLI_PER_TID_CODIGO,
               MCC_CCC_NUMERO_CUENTA,
               MAX(MCC_FECHA) FECHA_SALDO,
               MAX(MCC_CONSECUTIVO) CONSECUTIVO
          FROM MOVIMIENTOS_CUENTA_CORREDORES
         WHERE MCC_CCC_CLI_PER_NUM_IDEN = P_NUM_IDEN
           AND MCC_CCC_CLI_PER_TID_CODIGO = P_TID_CODIGO
           AND MCC_CCC_NUMERO_CUENTA = P_NUMERO_CUENTA
           AND MCC_FECHA < TRUNC(FECHA + 1)
           AND MCC_MONTO_CANJE_CC <> 0
         GROUP BY MCC_CCC_CLI_PER_NUM_IDEN,
                  MCC_CCC_CLI_PER_TID_CODIGO,
                  MCC_CCC_NUMERO_CUENTA;

      INSERT INTO GL_ULTIMO_MOV_SALDO_CONTADO
        (MCC_CCC_CLI_PER_NUM_IDEN,
         MCC_CCC_CLI_PER_TID_CODIGO,
         MCC_CCC_NUMERO_CUENTA,
         MCC_FECHA_SALDO_CONTADO,
         MCC_CONSECUTIVO_SALDO_CONTADO)
        SELECT MCC_CCC_CLI_PER_NUM_IDEN,
               MCC_CCC_CLI_PER_TID_CODIGO,
               MCC_CCC_NUMERO_CUENTA,
               MAX(MCC_FECHA) FECHA_SALDO,
               MAX(MCC_CONSECUTIVO) CONSECUTIVO
          FROM MOVIMIENTOS_CUENTA_CORREDORES
         WHERE MCC_CCC_CLI_PER_NUM_IDEN = P_NUM_IDEN
           AND MCC_CCC_CLI_PER_TID_CODIGO = P_TID_CODIGO
           AND MCC_CCC_NUMERO_CUENTA = P_NUMERO_CUENTA
           AND MCC_FECHA < TRUNC(FECHA + 1)
           AND MCC_MONTO_A_CONTADO <> 0
         GROUP BY MCC_CCC_CLI_PER_NUM_IDEN,
                  MCC_CCC_CLI_PER_TID_CODIGO,
                  MCC_CCC_NUMERO_CUENTA;

      INSERT INTO GL_ULTIMO_MOV_SALDO_PLAZO
        (MCC_CCC_CLI_PER_NUM_IDEN,
         MCC_CCC_CLI_PER_TID_CODIGO,
         MCC_CCC_NUMERO_CUENTA,
         MCC_FECHA_SALDO_PLAZO,
         MCC_CONSECUTIVO_SALDO_PLAZO)
        SELECT MCC_CCC_CLI_PER_NUM_IDEN,
               MCC_CCC_CLI_PER_TID_CODIGO,
               MCC_CCC_NUMERO_CUENTA,
               MAX(MCC_FECHA) FECHA_SALDO,
               MAX(MCC_CONSECUTIVO) CONSECUTIVO
          FROM MOVIMIENTOS_CUENTA_CORREDORES
         WHERE MCC_CCC_CLI_PER_NUM_IDEN = P_NUM_IDEN
           AND MCC_CCC_CLI_PER_TID_CODIGO = P_TID_CODIGO
           AND MCC_CCC_NUMERO_CUENTA = P_NUMERO_CUENTA
           AND MCC_FECHA < TRUNC(FECHA + 1)
           AND MCC_MONTO_A_PLAZO <> 0
         GROUP BY MCC_CCC_CLI_PER_NUM_IDEN,
                  MCC_CCC_CLI_PER_TID_CODIGO,
                  MCC_CCC_NUMERO_CUENTA;

      INSERT INTO SALDOS_DIARIOS_CLIENTE
        (SDI_CONSECUTIVO,
         SDI_FECHA_SALDO,
         SDI_FECHA_ULT_MOVIMIENTO,
         SDI_CONSECUTIVO_ULT_MOVIMIENTO,
         SDI_CCC_CLI_PER_NUM_IDEN,
         SDI_CCC_CLI_PER_TID_CODIGO,
         SDI_CCC_NUMERO_CUENTA,
         SDI_SALDO_CAPITAL,
         SDI_CONSEC_ULT_MOV_CAPITAL,
         SDI_FECHA_ULT_MOV_CAPITAL,
         SDI_SALDO_CC,
         SDI_CONSECUTIVO_ULT_MOV_CC,
         SDI_FECHA_ULT_MOV_CC,
         SDI_SALDO_BURSATIL,
         SDI_CONSEC_ULT_MOV_BURSATIL,
         SDI_FECHA_ULT_MOV_BURSATIL,
         SDI_SALDO_ADMON_VALORES,
         SDI_CONSEC_ULT_MOV_ADVAL,
         SDI_FECHA_ULT_MOV_ADVAL,
         SDI_SALDO_CANJE,
         SDI_CONSEC_ULT_MOV_CANJE,
         SDI_FECHA_ULT_MOV_CANJE,
         SDI_SALDO_CANJE_CC,
         SDI_CONSEC_ULT_MOV_CANJE_CC,
         SDI_FECHA_ULT_MOV_CANJE_CC,
         SDI_SALDO_A_CONTADO,
         SDI_CONSEC_ULT_MOV_CONTADO,
         SDI_FECHA_ULT_MOV_CONTADO,
         SDI_SALDO_A_PLAZO,
         SDI_CONSEC_ULT_MOV_PLAZO,
         SDI_FECHA_ULT_MOV_PLAZO)
        SELECT SDI_SEQ.NEXTVAL,
               TRUNC(FECHA),
               MCC.MCC_FECHA,
               MCC.MCC_CONSECUTIVO,
               CCC.CCC_CLI_PER_NUM_IDEN,
               CCC.CCC_CLI_PER_TID_CODIGO,
               CCC.CCC_NUMERO_CUENTA,
               MCC.MCC_SALDO,
               (SELECT MCC_CONSECUTIVO_SALDO
                  FROM GL_ULTIMO_MOV_SALDO MCC1
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA) CONSECUTIVO_SALDO,
               (SELECT MCC_FECHA_SALDO
                  FROM GL_ULTIMO_MOV_SALDO
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA) FECHA_SALDO,
               MCC.MCC_SALDO_CC,
               (SELECT MCC_CONSECUTIVO_SALDO_CC
                  FROM GL_ULTIMO_MOV_SALDO_CC
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA) CONSECUTIVO_SALDO_CC,
               (SELECT MCC_FECHA_SALDO_CC
                  FROM GL_ULTIMO_MOV_SALDO_CC
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA) FECHA_SALDO_CC,
               MCC.MCC_SALDO_BURSATIL,
               (SELECT MCC_CONSECUTIVO_SALDO_BURSATIL
                  FROM GL_ULTIMO_MOV_SALDO_BURSATIL
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA) CONSECUTIVO_SALDO_BURSATIL,
               (SELECT MCC_FECHA_SALDO_BURSATIL
                  FROM GL_ULTIMO_MOV_SALDO_BURSATIL
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA) FECHA_SALDO_BURSATIL,
               MCC.MCC_SALDO_ADMON_VALORES,
               (SELECT MCC_CONSECUTIVO_SALDO_ADVAL
                  FROM GL_ULTIMO_MOV_SALDO_ADVAL
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA) CONSECUTIVO_SALDO_ADVAL,
               (SELECT MCC_FECHA_SALDO_ADVAL
                  FROM GL_ULTIMO_MOV_SALDO_ADVAL
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA) FECHA_SALDO_ADVAL,
               MCC.MCC_SALDO_CANJE,
               (SELECT MCC_CONSECUTIVO_SALDO_CANJE
                  FROM GL_ULTIMO_MOV_SALDO_CANJE
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA) CONSECUTIVO_SALDO_CANJE,
               (SELECT MCC_FECHA_SALDO_CANJE
                  FROM GL_ULTIMO_MOV_SALDO_CANJE
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA) FECHA_SALDO_CANJE,
               MCC.MCC_SALDO_CANJE_CC,
               (SELECT MCC_CONSECUTIVO_SALDO_CANJE_CC
                  FROM GL_ULTIMO_MOV_SALDO_CANJE_CC
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA) CONSECUTIVO_SALDO_CANJE_CC,
               (SELECT MCC_FECHA_SALDO_CANJE_CC
                  FROM GL_ULTIMO_MOV_SALDO_CANJE_CC
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA) FECHA_SALDO_CANJE_CC,
               MCC.MCC_SALDO_A_CONTADO,
               (SELECT MCC_CONSECUTIVO_SALDO_CONTADO
                  FROM GL_ULTIMO_MOV_SALDO_CONTADO
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA) CONSECUTIVO_SALDO_CONTADO,
               (SELECT MCC_FECHA_SALDO_CONTADO
                  FROM GL_ULTIMO_MOV_SALDO_CONTADO
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA) FECHA_SALDO_CONTADO,
               MCC.MCC_SALDO_A_PLAZO,
               (SELECT MCC_CONSECUTIVO_SALDO_PLAZO
                  FROM GL_ULTIMO_MOV_SALDO_PLAZO
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA) CONSECUTIVO_SALDO_PLAZO,
               (SELECT MCC_FECHA_SALDO_PLAZO
                  FROM GL_ULTIMO_MOV_SALDO_PLAZO
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA) FECHA_SALDO_PLAZO
          FROM CUENTAS_CLIENTE_CORREDORES    CCC,
               MOVIMIENTOS_CUENTA_CORREDORES MCC
         WHERE CCC.CCC_CLI_PER_NUM_IDEN = MCC.MCC_CCC_CLI_PER_NUM_IDEN
           AND CCC.CCC_CLI_PER_TID_CODIGO = MCC.MCC_CCC_CLI_PER_TID_CODIGO
           AND CCC.CCC_NUMERO_CUENTA = MCC.MCC_CCC_NUMERO_CUENTA
           AND MCC.MCC_FECHA < TRUNC(FECHA + 1)
           AND MCC.MCC_CONSECUTIVO =
               (SELECT MAX(MCC1.MCC_CONSECUTIVO)
                  FROM MOVIMIENTOS_CUENTA_CORREDORES MCC1
                 WHERE CCC.CCC_CLI_PER_NUM_IDEN = P_NUM_IDEN
                   AND CCC.CCC_CLI_PER_TID_CODIGO = P_TID_CODIGO
                   AND CCC.CCC_NUMERO_CUENTA = P_NUMERO_CUENTA
                   AND MCC1.MCC_CCC_CLI_PER_NUM_IDEN =
                       CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC1.MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC1.MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA
                   AND MCC1.MCC_FECHA < TRUNC(FECHA + 1))
           AND (MCC_SALDO <> 0 OR MCC_SALDO_ADMON_VALORES <> 0 OR
               MCC_SALDO_A_PLAZO <> 0 OR MCC_SALDO_A_CONTADO <> 0 OR
               MCC_SALDO_CC <> 0 OR MCC_SALDO_BURSATIL <> 0 OR
               MCC_SALDO_CANJE <> 0 OR MCC_SALDO_CANJE_CC <> 0)
           AND CCC.CCC_FECHA_APERTURA < TRUNC(FECHA + 1);
      COMMIT;
      FECHA := FECHA + 1;
    END LOOP;
    COMMIT;

    -- Registrar traza FIN
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'F',
                                    'Fin P_PROCESOS_NOCTURNOS.P_SALDOS_DIARIOS_CLIENTES . Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE,
                                            'DD-MM-YYYY HH24:mi:ss') ||
                                    ' Rango de fechas procesado: ' ||
                                    TO_CHAR(FDESDE, 'DD-MON-YYYY') || ' a ' ||
                                    TO_CHAR(FHASTA, 'DD-MON-YYYY') ||
                                    'Proceso terminado con exito',
                                    N_TX);
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
      P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                      'E',
                                      'Error P_PROCESOS_NOCTURNOS.P_SALDOS_DIARIOS_CLIENTES. ' ||
                                      SUBSTR(SQLERRM, 1, 80) ||
                                      ' Fecha Proceso: ' ||
                                      TO_CHAR(SYSDATE,
                                              'DD-MM-YYYY HH24:mi:ss'),
                                      N_TX);
  END P_SALDOS_DIARIOS_CLIENTES;
  /**************************************** INICIO DEL NUEVO P_SALDOS_DIARIOS_CLIENTES ****************************/
  PROCEDURE P_SALDOS_DIARIOS_CLIENTES(FDESDE IN DATE,
                                      FHASTA IN DATE,
                                      P_TX   IN NUMBER DEFAULT NULL) IS

    FECHA DATE;
    PASO  VARCHAR2(50);

    CURSOR C_TMP IS
      SELECT COUNT(SDI_CCC_CLI_PER_NUM_IDEN)
        FROM GL_ULTIMOS_MOVIMIENTOS
       WHERE SDI_DIA_ANTERIOR = 'N';
    V_SIN NUMBER;

    N_ID_PROCESO NUMBER;
    N_TX         NUMBER;

  BEGIN

    --se asignar el consecutivo del proceso(tabla PARAMETRIZACION_PROCESOS)
    N_ID_PROCESO := P_TRAZA_CORE.FN_ID_PROCESO('P_PROCESOS_NOCTURNOS.P_SALDOS_DIARIOS_CLIENTES[2]');

    --se Asigna consecutivo para la transaccion, si el proceso es el primero que se llama, reinicia el consecutivo
    N_TX := P_TRAZA_CORE.FN_TRAE_TX(P_TX);

    --Registra Traza
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'I',
                                    'Inicio proceso P_PROCESOS_NOCTURNOS.P_SALDOS_DIARIOS_CLIENTES[2]. Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE,
                                            'DD-MM-YYYY HH24:mi:ss') ||
                                    ' Rango de fechas procesado: ' ||
                                    TO_CHAR(FDESDE, 'DD-MON-YYYY') || ' a ' ||
                                    TO_CHAR(FHASTA, 'DD-MON-YYYY'),
                                    N_TX);

    DELETE SALDOS_DIARIOS_CLIENTE
     WHERE SDI_FECHA_SALDO >= FDESDE
       AND SDI_FECHA_SALDO < FHASTA + 1;

    UPDATE CONSTANTES
       SET CON_VALOR_CHAR = TO_CHAR(SYSDATE, 'DD-MON-YYYY HH24:MI:SS')
     WHERE CON_MNEMONICO = 'HNO';

    FECHA := TRUNC(FDESDE);

    WHILE FECHA <= FHASTA LOOP
      DELETE FROM GL_ULTIMO_MOV_SALDO;
      DELETE FROM GL_ULTIMO_MOV_SALDO_CC;
      DELETE FROM GL_ULTIMO_MOV_SALDO_BURSATIL;
      DELETE FROM GL_ULTIMO_MOV_SALDO_ADVAL;
      DELETE FROM GL_ULTIMO_MOV_SALDO_CANJE;
      DELETE FROM GL_ULTIMO_MOV_SALDO_CANJE_CC;
      DELETE FROM GL_ULTIMO_MOV_SALDO_CONTADO;
      DELETE FROM GL_ULTIMO_MOV_SALDO_PLAZO;
      DELETE FROM GL_ULTIMOS_MOVIMIENTOS;
      DELETE FROM GL_ULTIMOS_MCC;
      PASO := 'GL_ULTIMO_MOV_SALDO';
      INSERT INTO GL_ULTIMO_MOV_SALDO
        (MCC_CCC_CLI_PER_NUM_IDEN,
         MCC_CCC_CLI_PER_TID_CODIGO,
         MCC_CCC_NUMERO_CUENTA,
         MCC_FECHA_SALDO,
         MCC_CONSECUTIVO_SALDO)
        SELECT MCC_CCC_CLI_PER_NUM_IDEN,
               MCC_CCC_CLI_PER_TID_CODIGO,
               MCC_CCC_NUMERO_CUENTA,
               MAX(MCC_FECHA) FECHA_SALDO,
               MAX(MCC_CONSECUTIVO) CONSECUTIVO
          FROM MOVIMIENTOS_CUENTA_CORREDORES
         WHERE MCC_FECHA >= TRUNC(FECHA)
           AND MCC_FECHA < TRUNC(FECHA + 1)
           AND MCC_MONTO <> 0
         GROUP BY MCC_CCC_CLI_PER_NUM_IDEN,
                  MCC_CCC_CLI_PER_TID_CODIGO,
                  MCC_CCC_NUMERO_CUENTA;
      PASO := 'GL_ULTIMO_MOV_SALDO_CC';
      INSERT INTO GL_ULTIMO_MOV_SALDO_CC
        (MCC_CCC_CLI_PER_NUM_IDEN,
         MCC_CCC_CLI_PER_TID_CODIGO,
         MCC_CCC_NUMERO_CUENTA,
         MCC_FECHA_SALDO_CC,
         MCC_CONSECUTIVO_SALDO_CC)
        SELECT MCC_CCC_CLI_PER_NUM_IDEN,
               MCC_CCC_CLI_PER_TID_CODIGO,
               MCC_CCC_NUMERO_CUENTA,
               MAX(MCC_FECHA) FECHA_SALDO,
               MAX(MCC_CONSECUTIVO) CONSECUTIVO
          FROM MOVIMIENTOS_CUENTA_CORREDORES
         WHERE MCC_FECHA >= TRUNC(FECHA)
           AND MCC_FECHA < TRUNC(FECHA + 1)
           AND MCC_MONTO_CARTERA <> 0
         GROUP BY MCC_CCC_CLI_PER_NUM_IDEN,
                  MCC_CCC_CLI_PER_TID_CODIGO,
                  MCC_CCC_NUMERO_CUENTA;
      PASO := 'GL_ULTIMO_MOV_SALDO_BURSATIL';
      INSERT INTO GL_ULTIMO_MOV_SALDO_BURSATIL
        (MCC_CCC_CLI_PER_NUM_IDEN,
         MCC_CCC_CLI_PER_TID_CODIGO,
         MCC_CCC_NUMERO_CUENTA,
         MCC_FECHA_SALDO_BURSATIL,
         MCC_CONSECUTIVO_SALDO_BURSATIL)
        SELECT MCC_CCC_CLI_PER_NUM_IDEN,
               MCC_CCC_CLI_PER_TID_CODIGO,
               MCC_CCC_NUMERO_CUENTA,
               MAX(MCC_FECHA) FECHA_SALDO,
               MAX(MCC_CONSECUTIVO) CONSECUTIVO
          FROM MOVIMIENTOS_CUENTA_CORREDORES
         WHERE MCC_FECHA >= TRUNC(FECHA)
           AND MCC_FECHA < TRUNC(FECHA + 1)
           AND MCC_MONTO_BURSATIL <> 0
         GROUP BY MCC_CCC_CLI_PER_NUM_IDEN,
                  MCC_CCC_CLI_PER_TID_CODIGO,
                  MCC_CCC_NUMERO_CUENTA;
      PASO := 'GL_ULTIMO_MOV_SALDO_ADVAL';
      INSERT INTO GL_ULTIMO_MOV_SALDO_ADVAL
        (MCC_CCC_CLI_PER_NUM_IDEN,
         MCC_CCC_CLI_PER_TID_CODIGO,
         MCC_CCC_NUMERO_CUENTA,
         MCC_FECHA_SALDO_ADVAL,
         MCC_CONSECUTIVO_SALDO_ADVAL)
        SELECT MCC_CCC_CLI_PER_NUM_IDEN,
               MCC_CCC_CLI_PER_TID_CODIGO,
               MCC_CCC_NUMERO_CUENTA,
               MAX(MCC_FECHA) FECHA_SALDO,
               MAX(MCC_CONSECUTIVO) CONSECUTIVO
          FROM MOVIMIENTOS_CUENTA_CORREDORES
         WHERE MCC_FECHA >= TRUNC(FECHA)
           AND MCC_FECHA < TRUNC(FECHA + 1)
           AND MCC_MONTO_ADMON_VALORES <> 0
         GROUP BY MCC_CCC_CLI_PER_NUM_IDEN,
                  MCC_CCC_CLI_PER_TID_CODIGO,
                  MCC_CCC_NUMERO_CUENTA;
      PASO := 'GL_ULTIMO_MOV_SALDO_CANJE';
      INSERT INTO GL_ULTIMO_MOV_SALDO_CANJE
        (MCC_CCC_CLI_PER_NUM_IDEN,
         MCC_CCC_CLI_PER_TID_CODIGO,
         MCC_CCC_NUMERO_CUENTA,
         MCC_FECHA_SALDO_CANJE,
         MCC_CONSECUTIVO_SALDO_CANJE)
        SELECT MCC_CCC_CLI_PER_NUM_IDEN,
               MCC_CCC_CLI_PER_TID_CODIGO,
               MCC_CCC_NUMERO_CUENTA,
               MAX(MCC_FECHA) FECHA_SALDO,
               MAX(MCC_CONSECUTIVO) CONSECUTIVO
          FROM MOVIMIENTOS_CUENTA_CORREDORES
         WHERE MCC_FECHA >= TRUNC(FECHA)
           AND MCC_FECHA < TRUNC(FECHA + 1)
           AND MCC_MONTO_CANJE <> 0
         GROUP BY MCC_CCC_CLI_PER_NUM_IDEN,
                  MCC_CCC_CLI_PER_TID_CODIGO,
                  MCC_CCC_NUMERO_CUENTA;
      PASO := 'GL_ULTIMO_MOV_SALDO_CANJE_CC';
      INSERT INTO GL_ULTIMO_MOV_SALDO_CANJE_CC
        (MCC_CCC_CLI_PER_NUM_IDEN,
         MCC_CCC_CLI_PER_TID_CODIGO,
         MCC_CCC_NUMERO_CUENTA,
         MCC_FECHA_SALDO_CANJE_CC,
         MCC_CONSECUTIVO_SALDO_CANJE_CC)
        SELECT MCC_CCC_CLI_PER_NUM_IDEN,
               MCC_CCC_CLI_PER_TID_CODIGO,
               MCC_CCC_NUMERO_CUENTA,
               MAX(MCC_FECHA) FECHA_SALDO,
               MAX(MCC_CONSECUTIVO) CONSECUTIVO
          FROM MOVIMIENTOS_CUENTA_CORREDORES
         WHERE MCC_FECHA >= TRUNC(FECHA)
           AND MCC_FECHA < TRUNC(FECHA + 1)
           AND MCC_MONTO_CANJE_CC <> 0
         GROUP BY MCC_CCC_CLI_PER_NUM_IDEN,
                  MCC_CCC_CLI_PER_TID_CODIGO,
                  MCC_CCC_NUMERO_CUENTA;
      PASO := 'GL_ULTIMO_MOV_SALDO_CONTADO';
      INSERT INTO GL_ULTIMO_MOV_SALDO_CONTADO
        (MCC_CCC_CLI_PER_NUM_IDEN,
         MCC_CCC_CLI_PER_TID_CODIGO,
         MCC_CCC_NUMERO_CUENTA,
         MCC_FECHA_SALDO_CONTADO,
         MCC_CONSECUTIVO_SALDO_CONTADO)
        SELECT MCC_CCC_CLI_PER_NUM_IDEN,
               MCC_CCC_CLI_PER_TID_CODIGO,
               MCC_CCC_NUMERO_CUENTA,
               MAX(MCC_FECHA) FECHA_SALDO,
               MAX(MCC_CONSECUTIVO) CONSECUTIVO
          FROM MOVIMIENTOS_CUENTA_CORREDORES
         WHERE MCC_FECHA >= TRUNC(FECHA)
           AND MCC_FECHA < TRUNC(FECHA + 1)
           AND MCC_MONTO_A_CONTADO <> 0
         GROUP BY MCC_CCC_CLI_PER_NUM_IDEN,
                  MCC_CCC_CLI_PER_TID_CODIGO,
                  MCC_CCC_NUMERO_CUENTA;
      PASO := 'GL_ULTIMO_MOV_SALDO_PLAZO';
      INSERT INTO GL_ULTIMO_MOV_SALDO_PLAZO
        (MCC_CCC_CLI_PER_NUM_IDEN,
         MCC_CCC_CLI_PER_TID_CODIGO,
         MCC_CCC_NUMERO_CUENTA,
         MCC_FECHA_SALDO_PLAZO,
         MCC_CONSECUTIVO_SALDO_PLAZO)
        SELECT MCC_CCC_CLI_PER_NUM_IDEN,
               MCC_CCC_CLI_PER_TID_CODIGO,
               MCC_CCC_NUMERO_CUENTA,
               MAX(MCC_FECHA) FECHA_SALDO,
               MAX(MCC_CONSECUTIVO) CONSECUTIVO
          FROM MOVIMIENTOS_CUENTA_CORREDORES
         WHERE MCC_FECHA >= TRUNC(FECHA)
           AND MCC_FECHA < TRUNC(FECHA + 1)
           AND MCC_MONTO_A_PLAZO <> 0
         GROUP BY MCC_CCC_CLI_PER_NUM_IDEN,
                  MCC_CCC_CLI_PER_TID_CODIGO,
                  MCC_CCC_NUMERO_CUENTA;
      PASO := 'GL_ULTIMOS_MOVIMIENTOS';
      -- GENERANDO REGISTRO DE MOVIMIENTOS EN LA FECHA PARA ACTUALIZAR LOS ULTIMOS MOVIMIENTOS
      -- DE TODOS LOS SALDOS ANTES DE INSERTAR EN SDI
      INSERT INTO GL_ULTIMOS_MOVIMIENTOS
        (SDI_CCC_CLI_PER_NUM_IDEN,
         SDI_CCC_CLI_PER_TID_CODIGO,
         SDI_CCC_NUMERO_CUENTA,
         SDI_FECHA_ULT_MOVIMIENTO,
         SDI_CONSECUTIVO_ULT_MOVIMIENTO,
         SDI_SALDO_CAPITAL,
         SDI_CONSEC_ULT_MOV_CAPITAL,
         SDI_FECHA_ULT_MOV_CAPITAL,
         SDI_SALDO_CC,
         SDI_CONSECUTIVO_ULT_MOV_CC,
         SDI_FECHA_ULT_MOV_CC,
         SDI_SALDO_BURSATIL,
         SDI_CONSEC_ULT_MOV_BURSATIL,
         SDI_FECHA_ULT_MOV_BURSATIL,
         SDI_SALDO_ADMON_VALORES,
         SDI_CONSEC_ULT_MOV_ADVAL,
         SDI_FECHA_ULT_MOV_ADVAL,
         SDI_SALDO_CANJE,
         SDI_CONSEC_ULT_MOV_CANJE,
         SDI_FECHA_ULT_MOV_CANJE,
         SDI_SALDO_CANJE_CC,
         SDI_CONSEC_ULT_MOV_CANJE_CC,
         SDI_FECHA_ULT_MOV_CANJE_CC,
         SDI_SALDO_A_CONTADO,
         SDI_CONSEC_ULT_MOV_CONTADO,
         SDI_FECHA_ULT_MOV_CONTADO,
         SDI_SALDO_A_PLAZO,
         SDI_CONSEC_ULT_MOV_PLAZO,
         SDI_FECHA_ULT_MOV_PLAZO,
         SDI_DIA_ANTERIOR)
        SELECT CCC.CCC_CLI_PER_NUM_IDEN,
               CCC.CCC_CLI_PER_TID_CODIGO,
               CCC.CCC_NUMERO_CUENTA,
               MCC.MCC_FECHA,
               MCC.MCC_CONSECUTIVO,
               MCC.MCC_SALDO,
               (SELECT MCC_CONSECUTIVO_SALDO
                  FROM GL_ULTIMO_MOV_SALDO MCC1
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA) CONSECUTIVO_SALDO,
               (SELECT MCC_FECHA_SALDO
                  FROM GL_ULTIMO_MOV_SALDO
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA) FECHA_SALDO,
               MCC.MCC_SALDO_CC,
               (SELECT MCC_CONSECUTIVO_SALDO_CC
                  FROM GL_ULTIMO_MOV_SALDO_CC
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA) CONSECUTIVO_SALDO_CC,
               (SELECT MCC_FECHA_SALDO_CC
                  FROM GL_ULTIMO_MOV_SALDO_CC
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA) FECHA_SALDO_CC,
               MCC.MCC_SALDO_BURSATIL,
               (SELECT MCC_CONSECUTIVO_SALDO_BURSATIL
                  FROM GL_ULTIMO_MOV_SALDO_BURSATIL
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA) CONSECUTIVO_SALDO_BURSATIL,
               (SELECT MCC_FECHA_SALDO_BURSATIL
                  FROM GL_ULTIMO_MOV_SALDO_BURSATIL
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA) FECHA_SALDO_BURSATIL,
               MCC.MCC_SALDO_ADMON_VALORES,
               (SELECT MCC_CONSECUTIVO_SALDO_ADVAL
                  FROM GL_ULTIMO_MOV_SALDO_ADVAL
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA) CONSECUTIVO_SALDO_ADVAL,
               (SELECT MCC_FECHA_SALDO_ADVAL
                  FROM GL_ULTIMO_MOV_SALDO_ADVAL
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA) FECHA_SALDO_ADVAL,
               MCC.MCC_SALDO_CANJE,
               (SELECT MCC_CONSECUTIVO_SALDO_CANJE
                  FROM GL_ULTIMO_MOV_SALDO_CANJE
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA) CONSECUTIVO_SALDO_CANJE,
               (SELECT MCC_FECHA_SALDO_CANJE
                  FROM GL_ULTIMO_MOV_SALDO_CANJE
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA) FECHA_SALDO_CANJE,
               MCC.MCC_SALDO_CANJE_CC,
               (SELECT MCC_CONSECUTIVO_SALDO_CANJE_CC
                  FROM GL_ULTIMO_MOV_SALDO_CANJE_CC
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA) CONSECUTIVO_SALDO_CANJE_CC,
               (SELECT MCC_FECHA_SALDO_CANJE_CC
                  FROM GL_ULTIMO_MOV_SALDO_CANJE_CC
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA) FECHA_SALDO_CANJE_CC,
               MCC.MCC_SALDO_A_CONTADO,
               (SELECT MCC_CONSECUTIVO_SALDO_CONTADO
                  FROM GL_ULTIMO_MOV_SALDO_CONTADO
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA) CONSECUTIVO_SALDO_CONTADO,
               (SELECT MCC_FECHA_SALDO_CONTADO
                  FROM GL_ULTIMO_MOV_SALDO_CONTADO
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA) FECHA_SALDO_CONTADO,
               MCC.MCC_SALDO_A_PLAZO,
               (SELECT MCC_CONSECUTIVO_SALDO_PLAZO
                  FROM GL_ULTIMO_MOV_SALDO_PLAZO
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA) CONSECUTIVO_SALDO_PLAZO,
               (SELECT MCC_FECHA_SALDO_PLAZO
                  FROM GL_ULTIMO_MOV_SALDO_PLAZO
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA) FECHA_SALDO_PLAZO,
               'N' SDI_DIA_ANTERIOR
          FROM CUENTAS_CLIENTE_CORREDORES    CCC,
               MOVIMIENTOS_CUENTA_CORREDORES MCC
         WHERE CCC.CCC_CLI_PER_NUM_IDEN = MCC.MCC_CCC_CLI_PER_NUM_IDEN
           AND CCC.CCC_CLI_PER_TID_CODIGO = MCC.MCC_CCC_CLI_PER_TID_CODIGO
           AND CCC.CCC_NUMERO_CUENTA = MCC.MCC_CCC_NUMERO_CUENTA
           AND MCC.MCC_FECHA >= TRUNC(FECHA)
           AND MCC.MCC_FECHA < TRUNC(FECHA + 1)
           AND MCC.MCC_CONSECUTIVO =
               (SELECT MAX(MCC1.MCC_CONSECUTIVO)
                  FROM MOVIMIENTOS_CUENTA_CORREDORES MCC1
                 WHERE MCC1.MCC_CCC_CLI_PER_NUM_IDEN =
                       CCC.CCC_CLI_PER_NUM_IDEN
                   AND MCC1.MCC_CCC_CLI_PER_TID_CODIGO =
                       CCC.CCC_CLI_PER_TID_CODIGO
                   AND MCC1.MCC_CCC_NUMERO_CUENTA = CCC.CCC_NUMERO_CUENTA
                   AND MCC1.MCC_FECHA >= TRUNC(FECHA)
                   AND MCC1.MCC_FECHA < TRUNC(FECHA + 1))
           AND (MCC_SALDO <> 0 OR MCC_SALDO_ADMON_VALORES <> 0 OR
               MCC_SALDO_A_PLAZO <> 0 OR MCC_SALDO_A_CONTADO <> 0 OR
               MCC_SALDO_CC <> 0 OR MCC_SALDO_BURSATIL <> 0 OR
               MCC_SALDO_CANJE <> 0 OR MCC_SALDO_CANJE_CC <> 0)
           AND CCC.CCC_FECHA_APERTURA < TRUNC(FECHA + 1);
      PASO := 'FIN GL_ULTIMOS_MOVIMIENTOS';
      -- ACTUALIZA LOS QUE TIENEN SALDO EL DIA ANTERIOR
      UPDATE GL_ULTIMOS_MOVIMIENTOS S1
         SET SDI_DIA_ANTERIOR = 'S'
       WHERE EXISTS
       (SELECT 'S'
                FROM SALDOS_DIARIOS_CLIENTE S2
               WHERE S1.SDI_CCC_CLI_PER_NUM_IDEN =
                     S2.SDI_CCC_CLI_PER_NUM_IDEN
                 AND S1.SDI_CCC_CLI_PER_TID_CODIGO =
                     S2.SDI_CCC_CLI_PER_TID_CODIGO
                 AND S1.SDI_CCC_NUMERO_CUENTA = S2.SDI_CCC_NUMERO_CUENTA
                 AND TRUNC(S2.SDI_FECHA_SALDO) = TRUNC(FECHA - 1));

      -- ACTUALIZANDO LAS FECHAS Y CONSECUTIVOS DE LOS ULTIMOS MOVIMIENTOS
      -- PARA LOS SALDOS NO AFECTADOS
      UPDATE GL_ULTIMOS_MOVIMIENTOS S1
         SET SDI_CONSEC_ULT_MOV_CAPITAL =
             (SELECT S2.SDI_CONSEC_ULT_MOV_CAPITAL
                FROM SALDOS_DIARIOS_CLIENTE S2
               WHERE S1.SDI_CCC_CLI_PER_NUM_IDEN =
                     S2.SDI_CCC_CLI_PER_NUM_IDEN
                 AND S1.SDI_CCC_CLI_PER_TID_CODIGO =
                     S2.SDI_CCC_CLI_PER_TID_CODIGO
                 AND S1.SDI_CCC_NUMERO_CUENTA = S2.SDI_CCC_NUMERO_CUENTA
                 AND S2.SDI_FECHA_SALDO >= TRUNC(FECHA - 1)
                 AND S2.SDI_FECHA_SALDO < TRUNC(FECHA)),
             SDI_FECHA_ULT_MOV_CAPITAL =
             (SELECT S3.SDI_FECHA_ULT_MOV_CAPITAL
                FROM SALDOS_DIARIOS_CLIENTE S3
               WHERE S1.SDI_CCC_CLI_PER_NUM_IDEN =
                     S3.SDI_CCC_CLI_PER_NUM_IDEN
                 AND S1.SDI_CCC_CLI_PER_TID_CODIGO =
                     S3.SDI_CCC_CLI_PER_TID_CODIGO
                 AND S1.SDI_CCC_NUMERO_CUENTA = S3.SDI_CCC_NUMERO_CUENTA
                 AND S3.SDI_FECHA_SALDO >= TRUNC(FECHA - 1)
                 AND S3.SDI_FECHA_SALDO < TRUNC(FECHA))
       WHERE SDI_FECHA_ULT_MOV_CAPITAL IS NULL
         AND SDI_DIA_ANTERIOR = 'S';

      UPDATE GL_ULTIMOS_MOVIMIENTOS S1
         SET SDI_CONSECUTIVO_ULT_MOV_CC =
             (SELECT S2.SDI_CONSECUTIVO_ULT_MOV_CC
                FROM SALDOS_DIARIOS_CLIENTE S2
               WHERE S1.SDI_CCC_CLI_PER_NUM_IDEN =
                     S2.SDI_CCC_CLI_PER_NUM_IDEN
                 AND S1.SDI_CCC_CLI_PER_TID_CODIGO =
                     S2.SDI_CCC_CLI_PER_TID_CODIGO
                 AND S1.SDI_CCC_NUMERO_CUENTA = S2.SDI_CCC_NUMERO_CUENTA
                 AND S2.SDI_FECHA_SALDO >= TRUNC(FECHA - 1)
                 AND S2.SDI_FECHA_SALDO < TRUNC(FECHA)),
             SDI_FECHA_ULT_MOV_CC      =
             (SELECT S3.SDI_FECHA_ULT_MOV_CC
                FROM SALDOS_DIARIOS_CLIENTE S3
               WHERE S1.SDI_CCC_CLI_PER_NUM_IDEN =
                     S3.SDI_CCC_CLI_PER_NUM_IDEN
                 AND S1.SDI_CCC_CLI_PER_TID_CODIGO =
                     S3.SDI_CCC_CLI_PER_TID_CODIGO
                 AND S1.SDI_CCC_NUMERO_CUENTA = S3.SDI_CCC_NUMERO_CUENTA
                 AND S3.SDI_FECHA_SALDO >= TRUNC(FECHA - 1)
                 AND S3.SDI_FECHA_SALDO < TRUNC(FECHA))
       WHERE SDI_FECHA_ULT_MOV_CC IS NULL
         AND SDI_DIA_ANTERIOR = 'S';

      UPDATE GL_ULTIMOS_MOVIMIENTOS S1
         SET SDI_CONSEC_ULT_MOV_BURSATIL =
             (SELECT S2.SDI_CONSEC_ULT_MOV_BURSATIL
                FROM SALDOS_DIARIOS_CLIENTE S2
               WHERE S1.SDI_CCC_CLI_PER_NUM_IDEN =
                     S2.SDI_CCC_CLI_PER_NUM_IDEN
                 AND S1.SDI_CCC_CLI_PER_TID_CODIGO =
                     S2.SDI_CCC_CLI_PER_TID_CODIGO
                 AND S1.SDI_CCC_NUMERO_CUENTA = S2.SDI_CCC_NUMERO_CUENTA
                 AND S2.SDI_FECHA_SALDO >= TRUNC(FECHA - 1)
                 AND S2.SDI_FECHA_SALDO < TRUNC(FECHA)),
             SDI_FECHA_ULT_MOV_BURSATIL =
             (SELECT S3.SDI_FECHA_ULT_MOV_BURSATIL
                FROM SALDOS_DIARIOS_CLIENTE S3
               WHERE S1.SDI_CCC_CLI_PER_NUM_IDEN =
                     S3.SDI_CCC_CLI_PER_NUM_IDEN
                 AND S1.SDI_CCC_CLI_PER_TID_CODIGO =
                     S3.SDI_CCC_CLI_PER_TID_CODIGO
                 AND S1.SDI_CCC_NUMERO_CUENTA = S3.SDI_CCC_NUMERO_CUENTA
                 AND S3.SDI_FECHA_SALDO >= TRUNC(FECHA - 1)
                 AND S3.SDI_FECHA_SALDO < TRUNC(FECHA))
       WHERE SDI_FECHA_ULT_MOV_BURSATIL IS NULL
         AND SDI_DIA_ANTERIOR = 'S';

      UPDATE GL_ULTIMOS_MOVIMIENTOS S1
         SET SDI_CONSEC_ULT_MOV_ADVAL =
             (SELECT S2.SDI_CONSEC_ULT_MOV_ADVAL
                FROM SALDOS_DIARIOS_CLIENTE S2
               WHERE S1.SDI_CCC_CLI_PER_NUM_IDEN =
                     S2.SDI_CCC_CLI_PER_NUM_IDEN
                 AND S1.SDI_CCC_CLI_PER_TID_CODIGO =
                     S2.SDI_CCC_CLI_PER_TID_CODIGO
                 AND S1.SDI_CCC_NUMERO_CUENTA = S2.SDI_CCC_NUMERO_CUENTA
                 AND S2.SDI_FECHA_SALDO >= TRUNC(FECHA - 1)
                 AND S2.SDI_FECHA_SALDO < TRUNC(FECHA)),
             SDI_FECHA_ULT_MOV_ADVAL =
             (SELECT S3.SDI_FECHA_ULT_MOV_ADVAL
                FROM SALDOS_DIARIOS_CLIENTE S3
               WHERE S1.SDI_CCC_CLI_PER_NUM_IDEN =
                     S3.SDI_CCC_CLI_PER_NUM_IDEN
                 AND S1.SDI_CCC_CLI_PER_TID_CODIGO =
                     S3.SDI_CCC_CLI_PER_TID_CODIGO
                 AND S1.SDI_CCC_NUMERO_CUENTA = S3.SDI_CCC_NUMERO_CUENTA
                 AND S3.SDI_FECHA_SALDO >= TRUNC(FECHA - 1)
                 AND S3.SDI_FECHA_SALDO < TRUNC(FECHA))
       WHERE SDI_FECHA_ULT_MOV_ADVAL IS NULL
         AND SDI_DIA_ANTERIOR = 'S';

      UPDATE GL_ULTIMOS_MOVIMIENTOS S1
         SET SDI_CONSEC_ULT_MOV_CANJE =
             (SELECT S2.SDI_CONSEC_ULT_MOV_CANJE
                FROM SALDOS_DIARIOS_CLIENTE S2
               WHERE S1.SDI_CCC_CLI_PER_NUM_IDEN =
                     S2.SDI_CCC_CLI_PER_NUM_IDEN
                 AND S1.SDI_CCC_CLI_PER_TID_CODIGO =
                     S2.SDI_CCC_CLI_PER_TID_CODIGO
                 AND S1.SDI_CCC_NUMERO_CUENTA = S2.SDI_CCC_NUMERO_CUENTA
                 AND S2.SDI_FECHA_SALDO >= TRUNC(FECHA - 1)
                 AND S2.SDI_FECHA_SALDO < TRUNC(FECHA)),
             SDI_FECHA_ULT_MOV_CANJE =
             (SELECT S3.SDI_FECHA_ULT_MOV_CANJE
                FROM SALDOS_DIARIOS_CLIENTE S3
               WHERE S1.SDI_CCC_CLI_PER_NUM_IDEN =
                     S3.SDI_CCC_CLI_PER_NUM_IDEN
                 AND S1.SDI_CCC_CLI_PER_TID_CODIGO =
                     S3.SDI_CCC_CLI_PER_TID_CODIGO
                 AND S1.SDI_CCC_NUMERO_CUENTA = S3.SDI_CCC_NUMERO_CUENTA
                 AND S3.SDI_FECHA_SALDO >= TRUNC(FECHA - 1)
                 AND S3.SDI_FECHA_SALDO < TRUNC(FECHA))
       WHERE SDI_FECHA_ULT_MOV_CANJE IS NULL
         AND SDI_DIA_ANTERIOR = 'S';

      UPDATE GL_ULTIMOS_MOVIMIENTOS S1
         SET SDI_CONSEC_ULT_MOV_CANJE_CC =
             (SELECT S2.SDI_CONSEC_ULT_MOV_CANJE_CC
                FROM SALDOS_DIARIOS_CLIENTE S2
               WHERE S1.SDI_CCC_CLI_PER_NUM_IDEN =
                     S2.SDI_CCC_CLI_PER_NUM_IDEN
                 AND S1.SDI_CCC_CLI_PER_TID_CODIGO =
                     S2.SDI_CCC_CLI_PER_TID_CODIGO
                 AND S1.SDI_CCC_NUMERO_CUENTA = S2.SDI_CCC_NUMERO_CUENTA
                 AND S2.SDI_FECHA_SALDO >= TRUNC(FECHA - 1)
                 AND S2.SDI_FECHA_SALDO < TRUNC(FECHA)),
             SDI_FECHA_ULT_MOV_CANJE_CC =
             (SELECT S3.SDI_FECHA_ULT_MOV_CANJE_CC
                FROM SALDOS_DIARIOS_CLIENTE S3
               WHERE S1.SDI_CCC_CLI_PER_NUM_IDEN =
                     S3.SDI_CCC_CLI_PER_NUM_IDEN
                 AND S1.SDI_CCC_CLI_PER_TID_CODIGO =
                     S3.SDI_CCC_CLI_PER_TID_CODIGO
                 AND S1.SDI_CCC_NUMERO_CUENTA = S3.SDI_CCC_NUMERO_CUENTA
                 AND S3.SDI_FECHA_SALDO >= TRUNC(FECHA - 1)
                 AND S3.SDI_FECHA_SALDO < TRUNC(FECHA))
       WHERE SDI_FECHA_ULT_MOV_CANJE_CC IS NULL
         AND SDI_DIA_ANTERIOR = 'S';

      UPDATE GL_ULTIMOS_MOVIMIENTOS S1
         SET SDI_CONSEC_ULT_MOV_CONTADO =
             (SELECT S2.SDI_CONSEC_ULT_MOV_CONTADO
                FROM SALDOS_DIARIOS_CLIENTE S2
               WHERE S1.SDI_CCC_CLI_PER_NUM_IDEN =
                     S2.SDI_CCC_CLI_PER_NUM_IDEN
                 AND S1.SDI_CCC_CLI_PER_TID_CODIGO =
                     S2.SDI_CCC_CLI_PER_TID_CODIGO
                 AND S1.SDI_CCC_NUMERO_CUENTA = S2.SDI_CCC_NUMERO_CUENTA
                 AND S2.SDI_FECHA_SALDO >= TRUNC(FECHA - 1)
                 AND S2.SDI_FECHA_SALDO < TRUNC(FECHA)),
             SDI_FECHA_ULT_MOV_CONTADO =
             (SELECT S3.SDI_FECHA_ULT_MOV_CONTADO
                FROM SALDOS_DIARIOS_CLIENTE S3
               WHERE S1.SDI_CCC_CLI_PER_NUM_IDEN =
                     S3.SDI_CCC_CLI_PER_NUM_IDEN
                 AND S1.SDI_CCC_CLI_PER_TID_CODIGO =
                     S3.SDI_CCC_CLI_PER_TID_CODIGO
                 AND S1.SDI_CCC_NUMERO_CUENTA = S3.SDI_CCC_NUMERO_CUENTA
                 AND S3.SDI_FECHA_SALDO >= TRUNC(FECHA - 1)
                 AND S3.SDI_FECHA_SALDO < TRUNC(FECHA))
       WHERE SDI_FECHA_ULT_MOV_CONTADO IS NULL
         AND SDI_DIA_ANTERIOR = 'S';

      UPDATE GL_ULTIMOS_MOVIMIENTOS S1
         SET SDI_CONSEC_ULT_MOV_PLAZO =
             (SELECT S2.SDI_CONSEC_ULT_MOV_PLAZO
                FROM SALDOS_DIARIOS_CLIENTE S2
               WHERE S1.SDI_CCC_CLI_PER_NUM_IDEN =
                     S2.SDI_CCC_CLI_PER_NUM_IDEN
                 AND S1.SDI_CCC_CLI_PER_TID_CODIGO =
                     S2.SDI_CCC_CLI_PER_TID_CODIGO
                 AND S1.SDI_CCC_NUMERO_CUENTA = S2.SDI_CCC_NUMERO_CUENTA
                 AND S2.SDI_FECHA_SALDO >= TRUNC(FECHA - 1)
                 AND S2.SDI_FECHA_SALDO < TRUNC(FECHA)),
             SDI_FECHA_ULT_MOV_PLAZO =
             (SELECT S3.SDI_FECHA_ULT_MOV_PLAZO
                FROM SALDOS_DIARIOS_CLIENTE S3
               WHERE S1.SDI_CCC_CLI_PER_NUM_IDEN =
                     S3.SDI_CCC_CLI_PER_NUM_IDEN
                 AND S1.SDI_CCC_CLI_PER_TID_CODIGO =
                     S3.SDI_CCC_CLI_PER_TID_CODIGO
                 AND S1.SDI_CCC_NUMERO_CUENTA = S3.SDI_CCC_NUMERO_CUENTA
                 AND S3.SDI_FECHA_SALDO >= TRUNC(FECHA - 1)
                 AND S3.SDI_FECHA_SALDO < TRUNC(FECHA))
       WHERE SDI_FECHA_ULT_MOV_PLAZO IS NULL
         AND SDI_DIA_ANTERIOR = 'S';

      OPEN C_TMP;
      FETCH C_TMP
        INTO V_SIN;
      CLOSE C_TMP;
      PASO := 'GL_ULTIMOS_MCC';
      -- VALIDA SI HAY REGISTROS SIN SALDO EL DIA ANTERIOR
      IF NVL(V_SIN, 0) > 0 THEN
        -- ACTUALIZANDO LOS QUE NO TIENEN SALDO REGISTRADO EL DIA ANTERIOR
        -- ULTIMO MOVIMIENTO CAPITAL
        INSERT INTO GL_ULTIMOS_MCC
          (MCC_CCC_CLI_PER_NUM_IDEN,
           MCC_CCC_CLI_PER_TID_CODIGO,
           MCC_CCC_NUMERO_CUENTA,
           MCC_FECHA,
           MCC_CONSECUTIVO)
          SELECT MCC_CCC_CLI_PER_NUM_IDEN,
                 MCC_CCC_CLI_PER_TID_CODIGO,
                 MCC_CCC_NUMERO_CUENTA,
                 MAX(MCC_FECHA) FECHA,
                 MAX(MCC_CONSECUTIVO) CONSECUTIVO
            FROM GL_ULTIMOS_MOVIMIENTOS, MOVIMIENTOS_CUENTA_CORREDORES
           WHERE MCC_CCC_CLI_PER_NUM_IDEN = SDI_CCC_CLI_PER_NUM_IDEN
             AND MCC_CCC_CLI_PER_TID_CODIGO = SDI_CCC_CLI_PER_TID_CODIGO
             AND MCC_CCC_NUMERO_CUENTA = SDI_CCC_NUMERO_CUENTA
             AND TRUNC(MCC_FECHA) <= TRUNC(FECHA)
             AND SDI_DIA_ANTERIOR = 'N'
             AND SDI_FECHA_ULT_MOV_CAPITAL IS NULL
             AND MCC_MONTO <> 0
           GROUP BY MCC_CCC_CLI_PER_NUM_IDEN,
                    MCC_CCC_CLI_PER_TID_CODIGO,
                    MCC_CCC_NUMERO_CUENTA;

        UPDATE GL_ULTIMOS_MOVIMIENTOS
           SET SDI_FECHA_ULT_MOV_CAPITAL =
               (SELECT MCC_FECHA
                  FROM GL_ULTIMOS_MCC
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = SDI_CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       SDI_CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = SDI_CCC_NUMERO_CUENTA),
               SDI_CONSEC_ULT_MOV_CAPITAL =
               (SELECT MCC_CONSECUTIVO
                  FROM GL_ULTIMOS_MCC
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = SDI_CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       SDI_CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = SDI_CCC_NUMERO_CUENTA)
         WHERE SDI_DIA_ANTERIOR = 'N'
           AND SDI_FECHA_ULT_MOV_CAPITAL IS NULL;

        -- ULTIMO MOVIMIENTO SALDO_CC
        DELETE FROM GL_ULTIMOS_MCC;
        PASO := 'GL_ULTIMOS_MCC 2';
        INSERT INTO GL_ULTIMOS_MCC
          (MCC_CCC_CLI_PER_NUM_IDEN,
           MCC_CCC_CLI_PER_TID_CODIGO,
           MCC_CCC_NUMERO_CUENTA,
           MCC_FECHA,
           MCC_CONSECUTIVO)
          SELECT MCC_CCC_CLI_PER_NUM_IDEN,
                 MCC_CCC_CLI_PER_TID_CODIGO,
                 MCC_CCC_NUMERO_CUENTA,
                 MAX(MCC_FECHA) FECHA,
                 MAX(MCC_CONSECUTIVO) CONSECUTIVO
            FROM GL_ULTIMOS_MOVIMIENTOS, MOVIMIENTOS_CUENTA_CORREDORES
           WHERE MCC_CCC_CLI_PER_NUM_IDEN = SDI_CCC_CLI_PER_NUM_IDEN
             AND MCC_CCC_CLI_PER_TID_CODIGO = SDI_CCC_CLI_PER_TID_CODIGO
             AND MCC_CCC_NUMERO_CUENTA = SDI_CCC_NUMERO_CUENTA
             AND TRUNC(MCC_FECHA) <= TRUNC(FECHA)
             AND SDI_DIA_ANTERIOR = 'N'
             AND SDI_FECHA_ULT_MOV_CC IS NULL
             AND MCC_MONTO_CARTERA <> 0
           GROUP BY MCC_CCC_CLI_PER_NUM_IDEN,
                    MCC_CCC_CLI_PER_TID_CODIGO,
                    MCC_CCC_NUMERO_CUENTA;

        UPDATE GL_ULTIMOS_MOVIMIENTOS
           SET SDI_FECHA_ULT_MOV_CC      =
               (SELECT MCC_FECHA
                  FROM GL_ULTIMOS_MCC
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = SDI_CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       SDI_CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = SDI_CCC_NUMERO_CUENTA),
               SDI_CONSECUTIVO_ULT_MOV_CC =
               (SELECT MCC_CONSECUTIVO
                  FROM GL_ULTIMOS_MCC
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = SDI_CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       SDI_CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = SDI_CCC_NUMERO_CUENTA)
         WHERE SDI_DIA_ANTERIOR = 'N'
           AND SDI_FECHA_ULT_MOV_CC IS NULL;

        -- ULTIMO MOVIMIENTO SALDO_BURSATIL
        DELETE FROM GL_ULTIMOS_MCC;
        PASO := 'GL_ULTIMOS_MCC 3';
        INSERT INTO GL_ULTIMOS_MCC
          (MCC_CCC_CLI_PER_NUM_IDEN,
           MCC_CCC_CLI_PER_TID_CODIGO,
           MCC_CCC_NUMERO_CUENTA,
           MCC_FECHA,
           MCC_CONSECUTIVO)
          SELECT MCC_CCC_CLI_PER_NUM_IDEN,
                 MCC_CCC_CLI_PER_TID_CODIGO,
                 MCC_CCC_NUMERO_CUENTA,
                 MAX(MCC_FECHA) FECHA,
                 MAX(MCC_CONSECUTIVO) CONSECUTIVO
            FROM GL_ULTIMOS_MOVIMIENTOS, MOVIMIENTOS_CUENTA_CORREDORES
           WHERE MCC_CCC_CLI_PER_NUM_IDEN = SDI_CCC_CLI_PER_NUM_IDEN
             AND MCC_CCC_CLI_PER_TID_CODIGO = SDI_CCC_CLI_PER_TID_CODIGO
             AND MCC_CCC_NUMERO_CUENTA = SDI_CCC_NUMERO_CUENTA
             AND TRUNC(MCC_FECHA) <= TRUNC(FECHA)
             AND SDI_DIA_ANTERIOR = 'N'
             AND SDI_FECHA_ULT_MOV_BURSATIL IS NULL
             AND MCC_MONTO_BURSATIL <> 0
           GROUP BY MCC_CCC_CLI_PER_NUM_IDEN,
                    MCC_CCC_CLI_PER_TID_CODIGO,
                    MCC_CCC_NUMERO_CUENTA;

        UPDATE GL_ULTIMOS_MOVIMIENTOS
           SET SDI_FECHA_ULT_MOV_BURSATIL =
               (SELECT MCC_FECHA
                  FROM GL_ULTIMOS_MCC
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = SDI_CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       SDI_CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = SDI_CCC_NUMERO_CUENTA),
               SDI_CONSEC_ULT_MOV_BURSATIL =
               (SELECT MCC_CONSECUTIVO
                  FROM GL_ULTIMOS_MCC
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = SDI_CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       SDI_CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = SDI_CCC_NUMERO_CUENTA)
         WHERE SDI_DIA_ANTERIOR = 'N'
           AND SDI_FECHA_ULT_MOV_BURSATIL IS NULL;

        -- ULTIMO MOVIMIENTO SALDO ADVAL
        DELETE FROM GL_ULTIMOS_MCC;
        PASO := 'GL_ULTIMOS_MCC 4';
        INSERT INTO GL_ULTIMOS_MCC
          (MCC_CCC_CLI_PER_NUM_IDEN,
           MCC_CCC_CLI_PER_TID_CODIGO,
           MCC_CCC_NUMERO_CUENTA,
           MCC_FECHA,
           MCC_CONSECUTIVO)
          SELECT MCC_CCC_CLI_PER_NUM_IDEN,
                 MCC_CCC_CLI_PER_TID_CODIGO,
                 MCC_CCC_NUMERO_CUENTA,
                 MAX(MCC_FECHA) FECHA,
                 MAX(MCC_CONSECUTIVO) CONSECUTIVO
            FROM GL_ULTIMOS_MOVIMIENTOS, MOVIMIENTOS_CUENTA_CORREDORES
           WHERE MCC_CCC_CLI_PER_NUM_IDEN = SDI_CCC_CLI_PER_NUM_IDEN
             AND MCC_CCC_CLI_PER_TID_CODIGO = SDI_CCC_CLI_PER_TID_CODIGO
             AND MCC_CCC_NUMERO_CUENTA = SDI_CCC_NUMERO_CUENTA
             AND TRUNC(MCC_FECHA) <= TRUNC(FECHA)
             AND SDI_DIA_ANTERIOR = 'N'
             AND SDI_FECHA_ULT_MOV_ADVAL IS NULL
             AND MCC_MONTO_ADMON_VALORES <> 0
           GROUP BY MCC_CCC_CLI_PER_NUM_IDEN,
                    MCC_CCC_CLI_PER_TID_CODIGO,
                    MCC_CCC_NUMERO_CUENTA;

        UPDATE GL_ULTIMOS_MOVIMIENTOS
           SET SDI_FECHA_ULT_MOV_ADVAL =
               (SELECT MCC_FECHA
                  FROM GL_ULTIMOS_MCC
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = SDI_CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       SDI_CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = SDI_CCC_NUMERO_CUENTA),
               SDI_CONSEC_ULT_MOV_ADVAL =
               (SELECT MCC_CONSECUTIVO
                  FROM GL_ULTIMOS_MCC
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = SDI_CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       SDI_CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = SDI_CCC_NUMERO_CUENTA)
         WHERE SDI_DIA_ANTERIOR = 'N'
           AND SDI_FECHA_ULT_MOV_ADVAL IS NULL;

        -- ULTIMO MOVIMIENTO SALDO CANJE
        DELETE FROM GL_ULTIMOS_MCC;
        PASO := 'GL_ULTIMOS_MCC 5';
        INSERT INTO GL_ULTIMOS_MCC
          (MCC_CCC_CLI_PER_NUM_IDEN,
           MCC_CCC_CLI_PER_TID_CODIGO,
           MCC_CCC_NUMERO_CUENTA,
           MCC_FECHA,
           MCC_CONSECUTIVO)
          SELECT MCC_CCC_CLI_PER_NUM_IDEN,
                 MCC_CCC_CLI_PER_TID_CODIGO,
                 MCC_CCC_NUMERO_CUENTA,
                 MAX(MCC_FECHA) FECHA,
                 MAX(MCC_CONSECUTIVO) CONSECUTIVO
            FROM GL_ULTIMOS_MOVIMIENTOS, MOVIMIENTOS_CUENTA_CORREDORES
           WHERE MCC_CCC_CLI_PER_NUM_IDEN = SDI_CCC_CLI_PER_NUM_IDEN
             AND MCC_CCC_CLI_PER_TID_CODIGO = SDI_CCC_CLI_PER_TID_CODIGO
             AND MCC_CCC_NUMERO_CUENTA = SDI_CCC_NUMERO_CUENTA
             AND TRUNC(MCC_FECHA) <= TRUNC(FECHA)
             AND SDI_DIA_ANTERIOR = 'N'
             AND SDI_FECHA_ULT_MOV_CANJE IS NULL
             AND MCC_MONTO_CANJE <> 0
           GROUP BY MCC_CCC_CLI_PER_NUM_IDEN,
                    MCC_CCC_CLI_PER_TID_CODIGO,
                    MCC_CCC_NUMERO_CUENTA;

        UPDATE GL_ULTIMOS_MOVIMIENTOS
           SET SDI_FECHA_ULT_MOV_CANJE =
               (SELECT MCC_FECHA
                  FROM GL_ULTIMOS_MCC
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = SDI_CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       SDI_CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = SDI_CCC_NUMERO_CUENTA),
               SDI_CONSEC_ULT_MOV_CANJE =
               (SELECT MCC_CONSECUTIVO
                  FROM GL_ULTIMOS_MCC
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = SDI_CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       SDI_CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = SDI_CCC_NUMERO_CUENTA)
         WHERE SDI_DIA_ANTERIOR = 'N'
           AND SDI_FECHA_ULT_MOV_CANJE IS NULL;

        -- ULTIMO MOVIMIENTO SALDO CANJE_CC
        DELETE FROM GL_ULTIMOS_MCC;
        PASO := 'GL_ULTIMOS_MCC 6';
        INSERT INTO GL_ULTIMOS_MCC
          (MCC_CCC_CLI_PER_NUM_IDEN,
           MCC_CCC_CLI_PER_TID_CODIGO,
           MCC_CCC_NUMERO_CUENTA,
           MCC_FECHA,
           MCC_CONSECUTIVO)
          SELECT MCC_CCC_CLI_PER_NUM_IDEN,
                 MCC_CCC_CLI_PER_TID_CODIGO,
                 MCC_CCC_NUMERO_CUENTA,
                 MAX(MCC_FECHA) FECHA,
                 MAX(MCC_CONSECUTIVO) CONSECUTIVO
            FROM GL_ULTIMOS_MOVIMIENTOS, MOVIMIENTOS_CUENTA_CORREDORES
           WHERE MCC_CCC_CLI_PER_NUM_IDEN = SDI_CCC_CLI_PER_NUM_IDEN
             AND MCC_CCC_CLI_PER_TID_CODIGO = SDI_CCC_CLI_PER_TID_CODIGO
             AND MCC_CCC_NUMERO_CUENTA = SDI_CCC_NUMERO_CUENTA
             AND TRUNC(MCC_FECHA) <= TRUNC(FECHA)
             AND SDI_DIA_ANTERIOR = 'N'
             AND SDI_FECHA_ULT_MOV_CANJE_CC IS NULL
             AND MCC_MONTO_CANJE_CC <> 0
           GROUP BY MCC_CCC_CLI_PER_NUM_IDEN,
                    MCC_CCC_CLI_PER_TID_CODIGO,
                    MCC_CCC_NUMERO_CUENTA;

        UPDATE GL_ULTIMOS_MOVIMIENTOS
           SET SDI_FECHA_ULT_MOV_CANJE_CC =
               (SELECT MCC_FECHA
                  FROM GL_ULTIMOS_MCC
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = SDI_CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       SDI_CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = SDI_CCC_NUMERO_CUENTA),
               SDI_CONSEC_ULT_MOV_CANJE_CC =
               (SELECT MCC_CONSECUTIVO
                  FROM GL_ULTIMOS_MCC
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = SDI_CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       SDI_CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = SDI_CCC_NUMERO_CUENTA)
         WHERE SDI_DIA_ANTERIOR = 'N'
           AND SDI_FECHA_ULT_MOV_CANJE_CC IS NULL;

        -- ULTIMO MOVIMIENTO SALDO CONTADO
        DELETE FROM GL_ULTIMOS_MCC;
        PASO := 'GL_ULTIMOS_MCC 7';
        INSERT INTO GL_ULTIMOS_MCC
          (MCC_CCC_CLI_PER_NUM_IDEN,
           MCC_CCC_CLI_PER_TID_CODIGO,
           MCC_CCC_NUMERO_CUENTA,
           MCC_FECHA,
           MCC_CONSECUTIVO)
          SELECT MCC_CCC_CLI_PER_NUM_IDEN,
                 MCC_CCC_CLI_PER_TID_CODIGO,
                 MCC_CCC_NUMERO_CUENTA,
                 MAX(MCC_FECHA) FECHA,
                 MAX(MCC_CONSECUTIVO) CONSECUTIVO
            FROM GL_ULTIMOS_MOVIMIENTOS, MOVIMIENTOS_CUENTA_CORREDORES
           WHERE MCC_CCC_CLI_PER_NUM_IDEN = SDI_CCC_CLI_PER_NUM_IDEN
             AND MCC_CCC_CLI_PER_TID_CODIGO = SDI_CCC_CLI_PER_TID_CODIGO
             AND MCC_CCC_NUMERO_CUENTA = SDI_CCC_NUMERO_CUENTA
             AND TRUNC(MCC_FECHA) <= TRUNC(FECHA)
             AND SDI_DIA_ANTERIOR = 'N'
             AND SDI_FECHA_ULT_MOV_CONTADO IS NULL
             AND MCC_MONTO_A_CONTADO <> 0
           GROUP BY MCC_CCC_CLI_PER_NUM_IDEN,
                    MCC_CCC_CLI_PER_TID_CODIGO,
                    MCC_CCC_NUMERO_CUENTA;

        UPDATE GL_ULTIMOS_MOVIMIENTOS
           SET SDI_FECHA_ULT_MOV_CONTADO =
               (SELECT MCC_FECHA
                  FROM GL_ULTIMOS_MCC
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = SDI_CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       SDI_CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = SDI_CCC_NUMERO_CUENTA),
               SDI_CONSEC_ULT_MOV_CONTADO =
               (SELECT MCC_CONSECUTIVO
                  FROM GL_ULTIMOS_MCC
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = SDI_CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       SDI_CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = SDI_CCC_NUMERO_CUENTA)
         WHERE SDI_DIA_ANTERIOR = 'N'
           AND SDI_FECHA_ULT_MOV_CONTADO IS NULL;

        -- ULTIMO MOVIMIENTO SALDO PLAZO
        DELETE FROM GL_ULTIMOS_MCC;
        PASO := 'GL_ULTIMOS_MCC 8';
        INSERT INTO GL_ULTIMOS_MCC
          (MCC_CCC_CLI_PER_NUM_IDEN,
           MCC_CCC_CLI_PER_TID_CODIGO,
           MCC_CCC_NUMERO_CUENTA,
           MCC_FECHA,
           MCC_CONSECUTIVO)
          SELECT MCC_CCC_CLI_PER_NUM_IDEN,
                 MCC_CCC_CLI_PER_TID_CODIGO,
                 MCC_CCC_NUMERO_CUENTA,
                 MAX(MCC_FECHA) FECHA,
                 MAX(MCC_CONSECUTIVO) CONSECUTIVO
            FROM GL_ULTIMOS_MOVIMIENTOS, MOVIMIENTOS_CUENTA_CORREDORES
           WHERE MCC_CCC_CLI_PER_NUM_IDEN = SDI_CCC_CLI_PER_NUM_IDEN
             AND MCC_CCC_CLI_PER_TID_CODIGO = SDI_CCC_CLI_PER_TID_CODIGO
             AND MCC_CCC_NUMERO_CUENTA = SDI_CCC_NUMERO_CUENTA
             AND TRUNC(MCC_FECHA) <= TRUNC(FECHA)
             AND SDI_DIA_ANTERIOR = 'N'
             AND SDI_FECHA_ULT_MOV_PLAZO IS NULL
             AND MCC_MONTO_A_PLAZO <> 0
           GROUP BY MCC_CCC_CLI_PER_NUM_IDEN,
                    MCC_CCC_CLI_PER_TID_CODIGO,
                    MCC_CCC_NUMERO_CUENTA;

        UPDATE GL_ULTIMOS_MOVIMIENTOS
           SET SDI_FECHA_ULT_MOV_PLAZO =
               (SELECT MCC_FECHA
                  FROM GL_ULTIMOS_MCC
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = SDI_CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       SDI_CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = SDI_CCC_NUMERO_CUENTA),
               SDI_CONSEC_ULT_MOV_PLAZO =
               (SELECT MCC_CONSECUTIVO
                  FROM GL_ULTIMOS_MCC
                 WHERE MCC_CCC_CLI_PER_NUM_IDEN = SDI_CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       SDI_CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = SDI_CCC_NUMERO_CUENTA)
         WHERE SDI_DIA_ANTERIOR = 'N'
           AND SDI_FECHA_ULT_MOV_PLAZO IS NULL;

      END IF;
      PASO := 'SALDOS_DIARIOS_CLIENTE';
      -- INSERTANDO LOS REGISTROS DE CLIENTES CON MOVIMIENTO EN LA FECHA EN SDI
      INSERT INTO SALDOS_DIARIOS_CLIENTE
        (SDI_CONSECUTIVO,
         SDI_FECHA_SALDO,
         SDI_FECHA_ULT_MOVIMIENTO,
         SDI_CONSECUTIVO_ULT_MOVIMIENTO,
         SDI_CCC_CLI_PER_NUM_IDEN,
         SDI_CCC_CLI_PER_TID_CODIGO,
         SDI_CCC_NUMERO_CUENTA,
         SDI_SALDO_CAPITAL,
         SDI_CONSEC_ULT_MOV_CAPITAL,
         SDI_FECHA_ULT_MOV_CAPITAL,
         SDI_SALDO_CC,
         SDI_CONSECUTIVO_ULT_MOV_CC,
         SDI_FECHA_ULT_MOV_CC,
         SDI_SALDO_BURSATIL,
         SDI_CONSEC_ULT_MOV_BURSATIL,
         SDI_FECHA_ULT_MOV_BURSATIL,
         SDI_SALDO_ADMON_VALORES,
         SDI_CONSEC_ULT_MOV_ADVAL,
         SDI_FECHA_ULT_MOV_ADVAL,
         SDI_SALDO_CANJE,
         SDI_CONSEC_ULT_MOV_CANJE,
         SDI_FECHA_ULT_MOV_CANJE,
         SDI_SALDO_CANJE_CC,
         SDI_CONSEC_ULT_MOV_CANJE_CC,
         SDI_FECHA_ULT_MOV_CANJE_CC,
         SDI_SALDO_A_CONTADO,
         SDI_CONSEC_ULT_MOV_CONTADO,
         SDI_FECHA_ULT_MOV_CONTADO,
         SDI_SALDO_A_PLAZO,
         SDI_CONSEC_ULT_MOV_PLAZO,
         SDI_FECHA_ULT_MOV_PLAZO)
        SELECT SDI_SEQ.NEXTVAL,
               TRUNC(FECHA),
               SDI_FECHA_ULT_MOVIMIENTO,
               SDI_CONSECUTIVO_ULT_MOVIMIENTO,
               SDI_CCC_CLI_PER_NUM_IDEN,
               SDI_CCC_CLI_PER_TID_CODIGO,
               SDI_CCC_NUMERO_CUENTA,
               SDI_SALDO_CAPITAL,
               SDI_CONSEC_ULT_MOV_CAPITAL,
               SDI_FECHA_ULT_MOV_CAPITAL,
               SDI_SALDO_CC,
               SDI_CONSECUTIVO_ULT_MOV_CC,
               SDI_FECHA_ULT_MOV_CC,
               SDI_SALDO_BURSATIL,
               SDI_CONSEC_ULT_MOV_BURSATIL,
               SDI_FECHA_ULT_MOV_BURSATIL,
               SDI_SALDO_ADMON_VALORES,
               SDI_CONSEC_ULT_MOV_ADVAL,
               SDI_FECHA_ULT_MOV_ADVAL,
               SDI_SALDO_CANJE,
               SDI_CONSEC_ULT_MOV_CANJE,
               SDI_FECHA_ULT_MOV_CANJE,
               SDI_SALDO_CANJE_CC,
               SDI_CONSEC_ULT_MOV_CANJE_CC,
               SDI_FECHA_ULT_MOV_CANJE_CC,
               SDI_SALDO_A_CONTADO,
               SDI_CONSEC_ULT_MOV_CONTADO,
               SDI_FECHA_ULT_MOV_CONTADO,
               SDI_SALDO_A_PLAZO,
               SDI_CONSEC_ULT_MOV_PLAZO,
               SDI_FECHA_ULT_MOV_PLAZO
          FROM GL_ULTIMOS_MOVIMIENTOS;
      COMMIT;
      PASO := 'SALDOS_DIARIOS_CLIENTE 2';
      -- INSERTANDO REGISTROS DE ULTIMOS SALDOS DE CLIENTES SIN MOVIMIENTO EN LA FECHA QUE SE ESTA ACTUALIZANDO
      INSERT INTO SALDOS_DIARIOS_CLIENTE
        (SDI_CONSECUTIVO,
         SDI_FECHA_SALDO,
         SDI_FECHA_ULT_MOVIMIENTO,
         SDI_CONSECUTIVO_ULT_MOVIMIENTO,
         SDI_CCC_CLI_PER_NUM_IDEN,
         SDI_CCC_CLI_PER_TID_CODIGO,
         SDI_CCC_NUMERO_CUENTA,
         SDI_SALDO_CAPITAL,
         SDI_CONSEC_ULT_MOV_CAPITAL,
         SDI_FECHA_ULT_MOV_CAPITAL,
         SDI_SALDO_CC,
         SDI_CONSECUTIVO_ULT_MOV_CC,
         SDI_FECHA_ULT_MOV_CC,
         SDI_SALDO_BURSATIL,
         SDI_CONSEC_ULT_MOV_BURSATIL,
         SDI_FECHA_ULT_MOV_BURSATIL,
         SDI_SALDO_ADMON_VALORES,
         SDI_CONSEC_ULT_MOV_ADVAL,
         SDI_FECHA_ULT_MOV_ADVAL,
         SDI_SALDO_CANJE,
         SDI_CONSEC_ULT_MOV_CANJE,
         SDI_FECHA_ULT_MOV_CANJE,
         SDI_SALDO_CANJE_CC,
         SDI_CONSEC_ULT_MOV_CANJE_CC,
         SDI_FECHA_ULT_MOV_CANJE_CC,
         SDI_SALDO_A_CONTADO,
         SDI_CONSEC_ULT_MOV_CONTADO,
         SDI_FECHA_ULT_MOV_CONTADO,
         SDI_SALDO_A_PLAZO,
         SDI_CONSEC_ULT_MOV_PLAZO,
         SDI_FECHA_ULT_MOV_PLAZO)
        SELECT SDI_SEQ.NEXTVAL,
               TRUNC(FECHA),
               SDI_FECHA_ULT_MOVIMIENTO,
               SDI_CONSECUTIVO_ULT_MOVIMIENTO,
               SDI_CCC_CLI_PER_NUM_IDEN,
               SDI_CCC_CLI_PER_TID_CODIGO,
               SDI_CCC_NUMERO_CUENTA,
               SDI_SALDO_CAPITAL,
               SDI_CONSEC_ULT_MOV_CAPITAL,
               SDI_FECHA_ULT_MOV_CAPITAL,
               SDI_SALDO_CC,
               SDI_CONSECUTIVO_ULT_MOV_CC,
               SDI_FECHA_ULT_MOV_CC,
               SDI_SALDO_BURSATIL,
               SDI_CONSEC_ULT_MOV_BURSATIL,
               SDI_FECHA_ULT_MOV_BURSATIL,
               SDI_SALDO_ADMON_VALORES,
               SDI_CONSEC_ULT_MOV_ADVAL,
               SDI_FECHA_ULT_MOV_ADVAL,
               SDI_SALDO_CANJE,
               SDI_CONSEC_ULT_MOV_CANJE,
               SDI_FECHA_ULT_MOV_CANJE,
               SDI_SALDO_CANJE_CC,
               SDI_CONSEC_ULT_MOV_CANJE_CC,
               SDI_FECHA_ULT_MOV_CANJE_CC,
               SDI_SALDO_A_CONTADO,
               SDI_CONSEC_ULT_MOV_CONTADO,
               SDI_FECHA_ULT_MOV_CONTADO,
               SDI_SALDO_A_PLAZO,
               SDI_CONSEC_ULT_MOV_PLAZO,
               SDI_FECHA_ULT_MOV_PLAZO
          FROM SALDOS_DIARIOS_CLIENTE SDI1
         WHERE SDI_FECHA_SALDO >= TRUNC(FECHA - 1)
           AND SDI_FECHA_SALDO < TRUNC(FECHA)
           AND NOT EXISTS
         (SELECT 'X'
                  FROM SALDOS_DIARIOS_CLIENTE SDI2
                 WHERE SDI2.SDI_FECHA_SALDO >= TRUNC(FECHA)
                   AND SDI2.SDI_FECHA_SALDO < TRUNC(FECHA + 1)
                   AND SDI2.SDI_CCC_CLI_PER_NUM_IDEN =
                       SDI1.SDI_CCC_CLI_PER_NUM_IDEN
                   AND SDI2.SDI_CCC_CLI_PER_TID_CODIGO =
                       SDI1.SDI_CCC_CLI_PER_TID_CODIGO
                   AND SDI2.SDI_CCC_NUMERO_CUENTA =
                       SDI1.SDI_CCC_NUMERO_CUENTA)
           AND NOT EXISTS
         (SELECT 'X'
                  FROM MOVIMIENTOS_CUENTA_CORREDORES
                 WHERE MCC_FECHA >= TRUNC(FECHA)
                   AND MCC_FECHA < TRUNC(FECHA + 1)
                   AND MCC_CCC_CLI_PER_NUM_IDEN =
                       SDI1.SDI_CCC_CLI_PER_NUM_IDEN
                   AND MCC_CCC_CLI_PER_TID_CODIGO =
                       SDI1.SDI_CCC_CLI_PER_TID_CODIGO
                   AND MCC_CCC_NUMERO_CUENTA = SDI1.SDI_CCC_NUMERO_CUENTA);
      COMMIT;
      FECHA := FECHA + 1;
    END LOOP;

    UPDATE CONSTANTES
       SET CON_VALOR_CHAR = CON_VALOR_CHAR || '     ' ||
                            TO_CHAR(SYSDATE, 'DD-MON-YYYY HH24:MI:SS')
     WHERE CON_MNEMONICO = 'HNO';

    COMMIT;

    -- Registrar traza FIN
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'F',
                                    'Fin P_PROCESOS_NOCTURNOS.P_SALDOS_DIARIOS_CLIENTES[2]. ' ||
                                    TO_CHAR(SYSDATE,
                                            'DD-MM-YYYY HH24:mi:ss') ||
                                    ' Rango de fechas procesado: ' ||
                                    TO_CHAR(FDESDE, 'DD-MON-YYYY') || ' a ' ||
                                    TO_CHAR(FHASTA, 'DD-MON-YYYY') ||
                                    ' Proceso terminado con exito',
                                    N_TX);
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
       P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                      'E',
                                      'Error P_PROCESOS_NOCTURNOS.P_SALDOS_DIARIOS_CLIENTES[2]. ' || PASO ||
                                      SUBSTR(SQLERRM, 1, 80) ||
                                      ' Fecha Proceso: ' ||
                                      TO_CHAR(SYSDATE,
                                              'DD-MM-YYYY HH24:mi:ss'),
                                      N_TX);
  END P_SALDOS_DIARIOS_CLIENTES;
  /**************************************** FINAL DEL NUEVO P_SALDOS_DIARIOS_CLIENTES ****************************/
  PROCEDURE P_SALDOS_DIARIOS_FONDOS(FDESDE IN DATE,
                                    FHASTA IN DATE,
                                    P_TX   IN NUMBER DEFAULT NULL) IS

    FECHA        DATE;
    N_ID_PROCESO NUMBER;
    N_TX         NUMBER;

  BEGIN

    --se asignar el consecutivo del proceso(tabla PARAMETRIZACION_PROCESOS)
    N_ID_PROCESO := P_TRAZA_CORE.FN_ID_PROCESO('P_PROCESOS_NOCTURNOS.P_SALDOS_DIARIOS_FONDOS');
    --se Asigna consecutivo para la transaccion, si el proceso es el primero que se llama, reinicia el consecutivo
    N_TX := P_TRAZA_CORE.FN_TRAE_TX(P_TX);
    --Registra Traza
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'I',
                                    'Inicio proceso P_PROCESOS_NOCTURNOS.P_SALDOS_DIARIOS_FONDOS . Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE,
                                            'DD-MM-YYYY HH24:mi:ss') ||
                                    ' Rango de fechas procesado: ' ||
                                    TO_CHAR(FDESDE, 'DD-MON-YYYY') || ' a ' ||
                                    TO_CHAR(FHASTA, 'DD-MON-YYYY'),
                                    N_TX);

    DELETE FROM SALDOS_DIARIOS_FONDOS
     WHERE SDF_FECHA_SALDO >= FDESDE
       AND SDF_FECHA_SALDO < FHASTA + 1;

    FECHA := TRUNC(FDESDE);

    WHILE FECHA <= FHASTA LOOP
      P_INSERT_SDF_MOVDIA(FECHA, N_TX);
      COMMIT;
      FECHA := FECHA + 1;
    END LOOP;
    COMMIT;

    -- Registrar traza FIN
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'F',
                                    'Fin P_PROCESOS_NOCTURNOS.P_SALDOS_DIARIOS_FONDOS . Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE,
                                            'DD-MM-YYYY HH24:mi:ss') ||
                                    ' Rango de fechas procesado: ' ||
                                    TO_CHAR(FDESDE, 'DD-MON-YYYY') || ' a ' ||
                                    TO_CHAR(FHASTA, 'DD-MON-YYYY') ||
                                    ' Proceso terminado con exito',
                                    N_TX);

    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
      P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                      'E',
                                      'Error P_PROCESOS_NOCTURNOS.P_SALDOS_DIARIOS_FONDOS.' ||
                                      SUBSTR(SQLERRM, 1, 80) ||
                                      ' Fecha Proceso: ' ||
                                      TO_CHAR(SYSDATE,'DD-MM-YYYY HH24:mi:ss'),
                                      N_TX);

  END P_SALDOS_DIARIOS_FONDOS;
  -- -----------------------------------------------------------------------
  PROCEDURE P_INSERT_SDF_MOVDIA(FECHA IN DATE, P_TX IN NUMBER DEFAULT NULL) IS
    FECHA_INI    DATE := FECHA;
    FECHA_FIN    DATE := FECHA;
    N_ID_PROCESO NUMBER;
    N_TX         NUMBER;

    CURSOR C_CLIENTES IS
      SELECT DISTINCT MCC_CCC_CLI_PER_NUM_IDEN,
                      MCC_CCC_CLI_PER_TID_CODIGO,
                      MCC_CCC_NUMERO_CUENTA
        FROM MOVIMIENTOS_CUENTA_CORREDORES
       WHERE MCC_MONTO_CARTERA != 0
         AND MCC_FECHA >= TRUNC(FECHA_INI)
         AND MCC_FECHA < TRUNC(FECHA_FIN) + 1
      --AND    MCC_CCC_CLI_PER_NUM_IDEN IN ('91229146', 'YXM0251340')
      UNION
      SELECT DISTINCT ASD_CCC_CLI_PER_NUM_IDEN,
                      ASD_CCC_CLI_PER_TID_CODIGO,
                      ASD_CCC_NUMERO_CUENTA
        FROM AJUSTES_SALDOS_DIARIOS_FONDOS
       WHERE ASD_FECHA_AJUSTE >= TRUNC(FECHA_INI)
         AND ASD_FECHA_AJUSTE < TRUNC(FECHA_FIN) + 1
      UNION
      SELECT DISTINCT SDF_CCC_CLI_PER_NUM_IDEN,
                      SDF_CCC_CLI_PER_TID_CODIGO,
                      SDF_CCC_NUMERO_CUENTA
        FROM SALDOS_DIARIOS_FONDOS
       WHERE SDF_FECHA_SALDO = TRUNC(FECHA_INI) - 1;
    -- AND    SDF_CCC_CLI_PER_NUM_IDEN IN ('91229146', 'YXM0251340');
    MCC1 C_CLIENTES%ROWTYPE;

    CURSOR C_MOVIMIENTO IS
      SELECT FON_CODIGO, SUM(TOTAL_FONDO) TOTAL
        FROM ( /* Se suman todos los movimientos de tesoreria del fondo asociados a recibos  de caja, giros y
                                                                                                                                                                                                                                                                                                                                     otros movimientos que no estan asociados a ordenes de fondos*/
              SELECT FON_CODIGO,
                      'TESORERIA' TIPO,
                      MCC_MONTO_CARTERA TOTAL_FONDO
                FROM MOVIMIENTOS_CUENTA_CORREDORES, FONDOS
               WHERE MCC_MONTO_CARTERA != 0
                 AND MCC_OFO_CONSECUTIVO IS NULL
                 AND MCC_NEG_CONSECUTIVO = FON_NEG_CONSECUTIVO
                 AND FON_CODIGO =
                     P_PROCESOS_NOCTURNOS.P_FONDO_PADRE(FON_NEG_CONSECUTIVO)
                 AND MCC_CCC_CLI_PER_NUM_IDEN = MCC1.MCC_CCC_CLI_PER_NUM_IDEN
                 AND MCC_CCC_CLI_PER_TID_CODIGO =
                     MCC1.MCC_CCC_CLI_PER_TID_CODIGO
                 AND MCC_CCC_NUMERO_CUENTA = MCC1.MCC_CCC_NUMERO_CUENTA
                 AND MCC_FECHA >= TRUNC(FECHA_INI)
                 AND MCC_FECHA < TRUNC(FECHA_FIN) + 1
              UNION ALL
              /* Se suman todos los movimientos generados en monto cartera asociados a las
              ordenes de fondos excluyendo las que son traslados */
              SELECT P_PROCESOS_NOCTURNOS.P_FONDO_PADRE(FON_NEG_CONSECUTIVO) FON_CODIGO,
                      'FONDOS' TIPO,
                      MCC_MONTO_CARTERA TOTAL_FONDO
                FROM MOVIMIENTOS_CUENTA_CORREDORES,
                      ORDENES_FONDOS OFO1,
                      FONDOS
               WHERE MCC_MONTO_CARTERA != 0
                 AND MCC_OFO_CONSECUTIVO = OFO1.OFO_CONSECUTIVO
                 AND MCC_OFO_SUC_CODIGO = OFO1.OFO_SUC_CODIGO
                 AND MCC_CCC_CLI_PER_NUM_IDEN = MCC1.MCC_CCC_CLI_PER_NUM_IDEN
                 AND MCC_CCC_CLI_PER_TID_CODIGO =
                     MCC1.MCC_CCC_CLI_PER_TID_CODIGO
                 AND MCC_CCC_NUMERO_CUENTA = MCC1.MCC_CCC_NUMERO_CUENTA
                 AND MCC_FECHA >= TRUNC(FECHA_INI)
                 AND MCC_FECHA < TRUNC(FECHA_FIN) + 1
                 AND OFO1.OFO_CFO_FON_CODIGO = FON_CODIGO
                 AND OFO1.OFO_OFO_CONSECUTIVO IS NULL
                 AND NOT EXISTS
               (SELECT 'X'
                        FROM ORDENES_FONDOS OFO2
                       WHERE OFO2.OFO_OFO_CONSECUTIVO = MCC_OFO_CONSECUTIVO
                         AND OFO2.OFO_OFO_SUC_CODIGO = MCC_OFO_SUC_CODIGO)
              UNION ALL
              /* Se suman todos los movimientos asociados a  ordenes de fondos de ingresos e incrementos
              provenientes de traslados entre fondos del mismo dia */
              SELECT P_PROCESOS_NOCTURNOS.P_FONDO_PADRE(FON_NEG_CONSECUTIVO) FON_CODIGO,
                      'FONDOS_ING' TIPO,
                      MCC_MONTO_CARTERA TOTAL_FONDO
                FROM MOVIMIENTOS_CUENTA_CORREDORES,
                      ORDENES_FONDOS                OFO1,
                      ORDENES_FONDOS                OFO2,
                      FONDOS
               WHERE MCC_MONTO_CARTERA != 0
                 AND MCC_OFO_CONSECUTIVO = OFO1.OFO_CONSECUTIVO
                 AND MCC_OFO_SUC_CODIGO = OFO1.OFO_SUC_CODIGO
                 AND MCC_CCC_CLI_PER_NUM_IDEN = MCC1.MCC_CCC_CLI_PER_NUM_IDEN
                 AND MCC_CCC_CLI_PER_TID_CODIGO =
                     MCC1.MCC_CCC_CLI_PER_TID_CODIGO
                 AND MCC_CCC_NUMERO_CUENTA = MCC1.MCC_CCC_NUMERO_CUENTA
                 AND MCC_FECHA >= TRUNC(FECHA_INI)
                 AND MCC_FECHA < TRUNC(FECHA_FIN) + 1
                 AND (MCC_TMC_MNEMONICO != 'RIFO' OR
                     (MCC_TMC_MNEMONICO = 'RIFO' AND
                     TRUNC(OFO1.OFO_FECHA_EJECUCION) = TRUNC(MCC_FECHA))) -- Se hace para movimientos diferentes a reversion ya que la revesion si aumenta el fondo del cual es la orden de transferencia
                 AND OFO1.OFO_OFO_CONSECUTIVO IS NOT NULL
                 AND OFO1.OFO_TTO_TOF_CODIGO IN ('ING', 'INC', 'PRI')
                 AND OFO1.OFO_OFO_CONSECUTIVO = OFO2.OFO_CONSECUTIVO
                 AND OFO1.OFO_OFO_SUC_CODIGO = OFO2.OFO_SUC_CODIGO
                 AND OFO2.OFO_CFO_FON_CODIGO = FON_CODIGO
                    -- Cuando existe transferencia entre cuentas del mismo fondo, se excluye el movimiento de Ingreso para evitar generar el movimiento de Retiro
                 AND NOT (OFO2.OFO_CFO_CCC_NUMERO_CUENTA <>
                      OFO1.OFO_CFO_CCC_NUMERO_CUENTA AND
                      OFO1.OFO_CFO_FON_CODIGO = OFO2.OFO_CFO_FON_CODIGO)

              UNION ALL
              /* Se suman todas las reversiones de ingresos e incrementos a fondos provenientes de transferencias
              pero que fueron hechos posterior al movimiento de ingreso e incremento */
              SELECT P_PROCESOS_NOCTURNOS.P_FONDO_PADRE(FON_NEG_CONSECUTIVO) FON_CODIGO,
                      'FONDOS_TRANS_REV' TIPO,
                      MCC_MONTO_CARTERA TOTAL_FONDO
                FROM MOVIMIENTOS_CUENTA_CORREDORES,
                      ORDENES_FONDOS OFO1,
                      FONDOS
               WHERE MCC_MONTO_CARTERA != 0
                 AND MCC_OFO_CONSECUTIVO = OFO1.OFO_CONSECUTIVO
                 AND MCC_OFO_SUC_CODIGO = OFO1.OFO_SUC_CODIGO
                 AND MCC_CCC_CLI_PER_NUM_IDEN = MCC1.MCC_CCC_CLI_PER_NUM_IDEN
                 AND MCC_CCC_CLI_PER_TID_CODIGO =
                     MCC1.MCC_CCC_CLI_PER_TID_CODIGO
                 AND MCC_CCC_NUMERO_CUENTA = MCC1.MCC_CCC_NUMERO_CUENTA
                 AND MCC_FECHA >= TRUNC(FECHA_INI)
                 AND MCC_FECHA < TRUNC(FECHA_FIN) + 1
                 AND MCC_TMC_MNEMONICO = 'RIFO' -- En los traslados la reversion del ingreso se aumenta a la cartera del mismo
                 AND TRUNC(OFO1.OFO_FECHA_EJECUCION) != TRUNC(MCC_FECHA)
                 AND OFO1.OFO_OFO_CONSECUTIVO IS NOT NULL
                 AND OFO1.OFO_TTO_TOF_CODIGO IN ('ING', 'INC', 'PRI')
                 AND OFO1.OFO_CFO_FON_CODIGO = FON_CODIGO
              UNION ALL
              /* Se suman todos los retiros de fondos provenientes de transferencias entre fondos */
              SELECT P_PROCESOS_NOCTURNOS.P_FONDO_PADRE(FON1.FON_NEG_CONSECUTIVO) FON_CODIGO,
                      'FONDOS_RET' TIPO,
                      MCC_MONTO_CARTERA TOTAL_FONDO
                FROM MOVIMIENTOS_CUENTA_CORREDORES,
                      ORDENES_FONDOS                OFO1,
                      FONDOS                        FON1
               WHERE MCC_MONTO_CARTERA != 0
                 AND MCC_OFO_CONSECUTIVO = OFO1.OFO_CONSECUTIVO
                 AND MCC_OFO_SUC_CODIGO = OFO1.OFO_SUC_CODIGO
                 AND MCC_CCC_CLI_PER_NUM_IDEN = MCC1.MCC_CCC_CLI_PER_NUM_IDEN
                 AND MCC_CCC_CLI_PER_TID_CODIGO =
                     MCC1.MCC_CCC_CLI_PER_TID_CODIGO
                 AND MCC_CCC_NUMERO_CUENTA = MCC1.MCC_CCC_NUMERO_CUENTA
                 AND MCC_FECHA >= TRUNC(FECHA_INI)
                 AND MCC_FECHA < TRUNC(FECHA_FIN) + 1
                 AND OFO1.OFO_OFO_CONSECUTIVO IS NULL
                 AND OFO1.OFO_TTO_TOF_CODIGO IN ('RP', 'RT', 'PRI')
                    -- Cuando existe transferencia entre cuentas del mismo fondo, se excluye el movimiento de Retiro para evitar generar el movimiento de Ingreso
                 AND NOT EXISTS
               (SELECT 'X'
                        FROM ORDENES_FONDOS OFO2, FONDOS FON2
                       WHERE OFO2.OFO_OFO_CONSECUTIVO = MCC_OFO_CONSECUTIVO
                         AND OFO2.OFO_OFO_SUC_CODIGO = MCC_OFO_SUC_CODIGO
                         AND OFO2.OFO_CFO_CCC_CLI_PER_NUM_IDEN =
                             MCC_CCC_CLI_PER_NUM_IDEN
                         AND OFO2.OFO_CFO_CCC_CLI_PER_TID_CODIGO =
                             MCC_CCC_CLI_PER_TID_CODIGO
                         AND OFO2.OFO_CFO_FON_CODIGO = FON2.FON_CODIGO
                         AND FON2.FON_CODIGO = FON1.FON_CODIGO
                         AND OFO2.OFO_CFO_CCC_NUMERO_CUENTA <>
                             MCC_CCC_NUMERO_CUENTA)
                 AND EXISTS
               (SELECT 'X'
                        FROM ORDENES_FONDOS OFO3
                       WHERE OFO3.OFO_OFO_CONSECUTIVO = MCC_OFO_CONSECUTIVO
                         AND OFO3.OFO_OFO_SUC_CODIGO = MCC_OFO_SUC_CODIGO)
                 AND OFO1.OFO_CFO_FON_CODIGO = FON1.FON_CODIGO
              UNION ALL
              /* Se suman todos los incrementos de los aportes que provienen
              de concepto cargo cuenta de otra cartera sin ser transferencias directas */
              SELECT P_PROCESOS_NOCTURNOS.P_FONDO_PADRE(FON_NEG_CONSECUTIVO) FON_CODIGO,
                      'CARGO_CTA_CARTERA' TIPO,
                      DAU_VALOR TOTAL_FONDO
                FROM DETALLES_CARGOS_CUENTAS,
                      MOVIMIENTOS_CUENTA_CORREDORES,
                      ORDENES_FONDOS OFO1,
                      FONDOS
               WHERE MCC_MONTO_CARTERA != 0
                 AND MCC_OFO_CONSECUTIVO = OFO1.OFO_CONSECUTIVO
                 AND MCC_OFO_SUC_CODIGO = OFO1.OFO_SUC_CODIGO
                 AND MCC_CCC_CLI_PER_NUM_IDEN = MCC1.MCC_CCC_CLI_PER_NUM_IDEN
                 AND MCC_CCC_CLI_PER_TID_CODIGO =
                     MCC1.MCC_CCC_CLI_PER_TID_CODIGO
                 AND MCC_CCC_NUMERO_CUENTA = MCC1.MCC_CCC_NUMERO_CUENTA
                 AND MCC_FECHA >= TRUNC(FECHA_INI)
                 AND MCC_FECHA < TRUNC(FECHA_FIN) + 1
                 AND MCC_TMC_MNEMONICO IN ('CICF', 'CIGF')
                 AND OFO1.OFO_CFO_FON_CODIGO = FON_CODIGO
                 AND OFO1.OFO_OFO_CONSECUTIVO IS NULL
                 AND DAU_OFO_CONSECUTIVO = OFO1.OFO_CONSECUTIVO
                 AND DAU_OFO_SUC_CODIGO = OFO1.OFO_SUC_CODIGO
                 AND EXISTS
               (SELECT 'X'
                        FROM TIPOS_CARGOS_CUENTAS
                       WHERE TIU_MNEMONICO = DAU_TIU_MNEMONICO
                         AND EXISTS
                       (SELECT 'X'
                                FROM FONDOS
                               WHERE FON_NPR_PRO_MNEMONICO = TIU_PRO_MNEMONICO
                                 AND FON_ESTADO = 'A'
                                 AND FON_TIPO_ADMINISTRACION = 'F'
                                 AND FON_NEG_CONSECUTIVO != 2
                                 AND FON_TIPO IN ('A', 'C')))
                 AND NOT EXISTS
               (SELECT 'X'
                        FROM ORDENES_FONDOS OFO2
                       WHERE OFO2.OFO_OFO_CONSECUTIVO = MCC_OFO_CONSECUTIVO
                         AND OFO2.OFO_OFO_SUC_CODIGO = MCC_OFO_SUC_CODIGO)
              UNION ALL
              /* Se suman todos las reversiones de incrementos de los aportes que provienen
              de concepto cargo cuenta de otra cartera sin ser transferencias directas */
              SELECT P_PROCESOS_NOCTURNOS.P_FONDO_PADRE(FON_NEG_CONSECUTIVO) FON_CODIGO,
                      'REV_CARGO_CTA_CARTERA' TIPO,
                      -DAU_VALOR TOTAL_FONDO
                FROM DETALLES_CARGOS_CUENTAS,
                      MOVIMIENTOS_CUENTA_CORREDORES,
                      ORDENES_FONDOS OFO1,
                      FONDOS
               WHERE MCC_MONTO_CARTERA != 0
                 AND MCC_OFO_CONSECUTIVO = OFO1.OFO_CONSECUTIVO
                 AND MCC_OFO_SUC_CODIGO = OFO1.OFO_SUC_CODIGO
                 AND MCC_CCC_CLI_PER_NUM_IDEN = MCC1.MCC_CCC_CLI_PER_NUM_IDEN
                 AND MCC_CCC_CLI_PER_TID_CODIGO =
                     MCC1.MCC_CCC_CLI_PER_TID_CODIGO
                 AND MCC_CCC_NUMERO_CUENTA = MCC1.MCC_CCC_NUMERO_CUENTA
                 AND MCC_FECHA >= TRUNC(FECHA_INI)
                 AND MCC_FECHA < TRUNC(FECHA_FIN) + 1
                 AND MCC_TMC_MNEMONICO IN ('RIFO')
                 AND OFO1.OFO_CFO_FON_CODIGO = FON_CODIGO
                 AND OFO1.OFO_OFO_CONSECUTIVO IS NULL
                 AND DAU_OFO_CONSECUTIVO = OFO1.OFO_CONSECUTIVO
                 AND DAU_OFO_SUC_CODIGO = OFO1.OFO_SUC_CODIGO
                 AND EXISTS
               (SELECT 'X'
                        FROM TIPOS_CARGOS_CUENTAS
                       WHERE TIU_MNEMONICO = DAU_TIU_MNEMONICO
                         AND EXISTS
                       (SELECT 'X'
                                FROM FONDOS
                               WHERE FON_NPR_PRO_MNEMONICO = TIU_PRO_MNEMONICO
                                 AND FON_ESTADO = 'A'
                                 AND FON_TIPO_ADMINISTRACION = 'F'
                                 AND FON_NEG_CONSECUTIVO != 2
                                 AND FON_TIPO IN ('A', 'C')))
                 AND NOT EXISTS
               (SELECT 'X'
                        FROM ORDENES_FONDOS OFO2
                       WHERE OFO2.OFO_OFO_CONSECUTIVO = MCC_OFO_CONSECUTIVO
                         AND OFO2.OFO_OFO_SUC_CODIGO = MCC_OFO_SUC_CODIGO)
              UNION ALL
              /* Se suman todos los incrementos de los aportes que provienen
              de concepto cargo cuenta de otra cartera sin ser transferencias directas */
              SELECT P_PROCESOS_NOCTURNOS.P_FONDO_PADRE((SELECT MIN(FON_NEG_CONSECUTIVO)
                                                           FROM FONDOS
                                                          WHERE FON_NPR_PRO_MNEMONICO =
                                                                TIU_PRO_MNEMONICO
                                                            AND FON_ESTADO = 'A'
                                                            AND FON_TIPO_ADMINISTRACION = 'F'
                                                            AND FON_NEG_CONSECUTIVO != 2
                                                            AND FON_TIPO IN
                                                                ('A', 'C'))) FON_CODIGO,
                      'ABONO_CTA_CARTERA' TIPO,
                      -DAU_VALOR TOTAL_FONDO
                FROM DETALLES_CARGOS_CUENTAS,
                      MOVIMIENTOS_CUENTA_CORREDORES,
                      ORDENES_FONDOS OFO1,
                      FONDOS,
                      TIPOS_CARGOS_CUENTAS
               WHERE MCC_MONTO_CARTERA != 0
                 AND MCC_OFO_CONSECUTIVO = OFO1.OFO_CONSECUTIVO
                 AND MCC_OFO_SUC_CODIGO = OFO1.OFO_SUC_CODIGO
                 AND MCC_CCC_CLI_PER_NUM_IDEN = MCC1.MCC_CCC_CLI_PER_NUM_IDEN
                 AND MCC_CCC_CLI_PER_TID_CODIGO =
                     MCC1.MCC_CCC_CLI_PER_TID_CODIGO
                 AND MCC_CCC_NUMERO_CUENTA = MCC1.MCC_CCC_NUMERO_CUENTA
                 AND MCC_FECHA >= TRUNC(FECHA_INI)
                 AND MCC_FECHA < TRUNC(FECHA_FIN) + 1
                 AND MCC_TMC_MNEMONICO IN ('CICF', 'CIGF')
                 AND OFO1.OFO_CFO_FON_CODIGO = FON_CODIGO
                 AND OFO1.OFO_OFO_CONSECUTIVO IS NULL
                 AND DAU_OFO_CONSECUTIVO = OFO1.OFO_CONSECUTIVO
                 AND DAU_OFO_SUC_CODIGO = OFO1.OFO_SUC_CODIGO
                 AND TIU_MNEMONICO = DAU_TIU_MNEMONICO
                 AND EXISTS
               (SELECT 'X'
                        FROM FONDOS
                       WHERE FON_NPR_PRO_MNEMONICO = TIU_PRO_MNEMONICO
                         AND FON_ESTADO = 'A'
                         AND FON_TIPO_ADMINISTRACION = 'F'
                         AND FON_NEG_CONSECUTIVO != 2
                         AND FON_TIPO IN ('A', 'C'))
                 AND NOT EXISTS
               (SELECT 'X'
                        FROM ORDENES_FONDOS OFO2
                       WHERE OFO2.OFO_OFO_CONSECUTIVO = MCC_OFO_CONSECUTIVO
                         AND OFO2.OFO_OFO_SUC_CODIGO = MCC_OFO_SUC_CODIGO)
              UNION ALL
              /* Se suman todos las reversiones de incrementos de los aportes que provienen
              de concepto cargo cuenta de otra cartera sin ser transferencias directas */
              SELECT P_PROCESOS_NOCTURNOS.P_FONDO_PADRE((SELECT MIN(FON_NEG_CONSECUTIVO)
                                                           FROM FONDOS
                                                          WHERE FON_NPR_PRO_MNEMONICO =
                                                                TIU_PRO_MNEMONICO
                                                            AND FON_ESTADO = 'A'
                                                            AND FON_TIPO_ADMINISTRACION = 'F'
                                                            AND FON_NEG_CONSECUTIVO != 2
                                                            AND FON_TIPO IN
                                                                ('A', 'C'))) FON_CODIGO,
                      'REV_ABONO_CTA_CARTERA' TIPO,
                      DAU_VALOR TOTAL_FONDO
                FROM DETALLES_CARGOS_CUENTAS,
                      MOVIMIENTOS_CUENTA_CORREDORES,
                      ORDENES_FONDOS OFO1,
                      FONDOS,
                      TIPOS_CARGOS_CUENTAS
               WHERE MCC_MONTO_CARTERA != 0
                 AND MCC_OFO_CONSECUTIVO = OFO1.OFO_CONSECUTIVO
                 AND MCC_OFO_SUC_CODIGO = OFO1.OFO_SUC_CODIGO
                 AND MCC_CCC_CLI_PER_NUM_IDEN = MCC1.MCC_CCC_CLI_PER_NUM_IDEN
                 AND MCC_CCC_CLI_PER_TID_CODIGO =
                     MCC1.MCC_CCC_CLI_PER_TID_CODIGO
                 AND MCC_CCC_NUMERO_CUENTA = MCC1.MCC_CCC_NUMERO_CUENTA
                 AND MCC_FECHA >= TRUNC(FECHA_INI)
                 AND MCC_FECHA < TRUNC(FECHA_FIN) + 1
                 AND MCC_TMC_MNEMONICO IN ('RIFO')
                 AND OFO1.OFO_CFO_FON_CODIGO = FON_CODIGO
                 AND OFO1.OFO_OFO_CONSECUTIVO IS NULL
                 AND DAU_OFO_CONSECUTIVO = OFO1.OFO_CONSECUTIVO
                 AND DAU_OFO_SUC_CODIGO = OFO1.OFO_SUC_CODIGO
                 AND TIU_MNEMONICO = DAU_TIU_MNEMONICO
                 AND EXISTS
               (SELECT 'X'
                        FROM FONDOS
                       WHERE FON_NPR_PRO_MNEMONICO = TIU_PRO_MNEMONICO
                         AND FON_ESTADO = 'A'
                         AND FON_TIPO_ADMINISTRACION = 'F'
                         AND FON_NEG_CONSECUTIVO != 2
                         AND FON_TIPO IN ('A', 'C'))
                 AND NOT EXISTS
               (SELECT 'X'
                        FROM ORDENES_FONDOS OFO2
                       WHERE OFO2.OFO_OFO_CONSECUTIVO = MCC_OFO_CONSECUTIVO
                         AND OFO2.OFO_OFO_SUC_CODIGO = MCC_OFO_SUC_CODIGO)
              UNION ALL
              /* Se toma el saldo de la cartera del dia anterior */
              SELECT SDF_FON_CODIGO FON_CODIGO,
                      'SALDO_ANT' TIPO,
                      SDF_SALDO_CC TOTAL_FONDO
                FROM SALDOS_DIARIOS_FONDOS
               WHERE SDF_FECHA_SALDO = TRUNC(FECHA_INI) - 1
                 AND SDF_CCC_CLI_PER_NUM_IDEN = MCC1.MCC_CCC_CLI_PER_NUM_IDEN
                 AND SDF_CCC_CLI_PER_TID_CODIGO =
                     MCC1.MCC_CCC_CLI_PER_TID_CODIGO
                 AND SDF_CCC_NUMERO_CUENTA = MCC1.MCC_CCC_NUMERO_CUENTA
              UNION ALL
              /* Se toman los ajustes creados a los saldos*/
              SELECT ASD_FON_CODIGO FON_CODIGO,
                      'AJUSTES_SALDOS' TIPO,
                      SUM(ASD_MONTO_AJUSTE) TOTAL_FONDO
                FROM AJUSTES_SALDOS_DIARIOS_FONDOS
               WHERE ASD_FECHA_AJUSTE >= TRUNC(FECHA_INI)
                 AND ASD_FECHA_AJUSTE < TRUNC(FECHA_FIN) + 1
                 AND ASD_CCC_CLI_PER_NUM_IDEN = MCC1.MCC_CCC_CLI_PER_NUM_IDEN
                 AND ASD_CCC_CLI_PER_TID_CODIGO =
                     MCC1.MCC_CCC_CLI_PER_TID_CODIGO
                 AND ASD_CCC_NUMERO_CUENTA = MCC1.MCC_CCC_NUMERO_CUENTA
               GROUP BY ASD_FON_CODIGO)
       GROUP BY FON_CODIGO;
    TOT1 C_MOVIMIENTO%ROWTYPE;

    CURSOR C_ULTIMO_MOVIMIENTO IS
      SELECT MCC_CONSECUTIVO, MCC_FECHA
        FROM MOVIMIENTOS_CUENTA_CORREDORES
       WHERE MCC_CCC_CLI_PER_NUM_IDEN = MCC1.MCC_CCC_CLI_PER_NUM_IDEN
         AND MCC_CCC_CLI_PER_TID_CODIGO = MCC1.MCC_CCC_CLI_PER_TID_CODIGO
         AND MCC_CCC_NUMERO_CUENTA = MCC1.MCC_CCC_NUMERO_CUENTA
         AND MCC_MONTO_CARTERA != 0
         AND MCC_FECHA < TRUNC(FECHA_FIN) + 1
       ORDER BY MCC_CONSECUTIVO DESC;
    MCC2 C_ULTIMO_MOVIMIENTO%ROWTYPE;

  BEGIN

     --se asignar el consecutivo del proceso(tabla PARAMETRIZACION_PROCESOS)
    N_ID_PROCESO := P_TRAZA_CORE.FN_ID_PROCESO('P_PROCESOS_NOCTURNOS.P_INSERT_SDF_MOVDIA');

    --se Asigna consecutivo para la transaccion, si el proceso es el primero que se llama, reinicia el consecutivo
    N_TX := P_TRAZA_CORE.FN_TRAE_TX(P_TX);

    --Registra Traza
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'I',
                                    'Inicio proceso P_PROCESOS_NOCTURNOS.P_INSERT_SDF_MOVDIA. Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE,
                                            'DD-MM-YYYY HH24:mi:ss'),
                                    N_TX);

    OPEN C_CLIENTES;
    FETCH C_CLIENTES
      INTO MCC1;
    WHILE C_CLIENTES%FOUND LOOP
      TOT1.FON_CODIGO := NULL;
      TOT1.TOTAL      := NULL;
      OPEN C_MOVIMIENTO;
      FETCH C_MOVIMIENTO
        INTO TOT1;
      WHILE C_MOVIMIENTO%FOUND LOOP
        IF NVL(TOT1.TOTAL, 0) != 0 THEN
          OPEN C_ULTIMO_MOVIMIENTO;
          FETCH C_ULTIMO_MOVIMIENTO
            INTO MCC2;
          CLOSE C_ULTIMO_MOVIMIENTO;
          INSERT INTO SALDOS_DIARIOS_FONDOS
            (SDF_CONSECUTIVO,
             SDF_FECHA_SALDO,
             SDF_CCC_CLI_PER_NUM_IDEN,
             SDF_CCC_CLI_PER_TID_CODIGO,
             SDF_CCC_NUMERO_CUENTA,
             SDF_SALDO_CC,
             SDF_FON_CODIGO,
             SDF_MCC_CONSECUTIVO,
             SDF_FECHA_ULT_MOVIMIENTO)
          VALUES
            (SDF_SEQ.NEXTVAL,
             TRUNC(FECHA_FIN),
             MCC1.MCC_CCC_CLI_PER_NUM_IDEN,
             MCC1.MCC_CCC_CLI_PER_TID_CODIGO,
             MCC1.MCC_CCC_NUMERO_CUENTA,
             TOT1.TOTAL,
             TOT1.FON_CODIGO,
             MCC2.MCC_CONSECUTIVO,
             MCC2.MCC_FECHA);
        END IF;
        FETCH C_MOVIMIENTO
          INTO TOT1;
      END LOOP;
      CLOSE C_MOVIMIENTO;
      FETCH C_CLIENTES
        INTO MCC1;
    END LOOP;
    CLOSE C_CLIENTES;

       -- Registrar traza FIN
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'F',
                                    'Fin P_PROCESOS_NOCTURNOS.P_INSERT_SDF_MOVDIA. Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE,
                                            'DD-MM-YYYY HH24:mi:ss'),
                                    N_TX);
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
        --Registra Traza ERROR
      P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                      'E',
                                      'P_PROCESOS_NOCTURNOS.P_INSERT_SDF_MOVDIA. Fecha: ' ||
                                      TO_CHAR(SYSDATE,
                                              'DD-MM-YYYY HH24:mi:ss') || ' ' ||
                                      SUBSTR(SQLERRM, 1, 80),
                                      N_TX);
  END P_INSERT_SDF_MOVDIA;
  -- ------------------------------------------------------------------------------
  FUNCTION P_FONDO_PADRE(P_NEGOCIO IN NUMBER) RETURN VARCHAR IS

    CURSOR C_COMPARTIMENTO IS
      SELECT PFO_RANGO_MIN_CHAR
        FROM PARAMETROS_FONDOS, FONDOS
       WHERE PFO_PAR_CODIGO = 71
         AND PFO_FON_CODIGO = FON_CODIGO
         AND FON_NEG_CONSECUTIVO = P_NEGOCIO
         AND FON_ESTADO = 'A';
    PFO1 C_COMPARTIMENTO%ROWTYPE;

    CURSOR C_ESCALONADO IS
      SELECT PFO_FON_CODIGO
        FROM PARAMETROS_FONDOS, FONDOS
       WHERE PFO_PAR_CODIGO = 30
         AND PFO_FON_CODIGO = FON_CODIGO
         AND FON_NEG_CONSECUTIVO = P_NEGOCIO;

    CURSOR C_AGRUPADOR IS
      SELECT PFO_FON_CODIGO
        FROM PARAMETROS_FONDOS, FONDOS
       WHERE PFO_PAR_CODIGO = 84
         AND PFO_FON_CODIGO = FON_CODIGO
         AND FON_NEG_CONSECUTIVO = P_NEGOCIO;

    CURSOR C_FONDO_NORMAL IS
      SELECT FON_CODIGO FROM FONDOS WHERE FON_NEG_CONSECUTIVO = P_NEGOCIO;

  BEGIN
    OPEN C_COMPARTIMENTO;
    FETCH C_COMPARTIMENTO
      INTO PFO1;
    IF C_COMPARTIMENTO%FOUND THEN
      CLOSE C_COMPARTIMENTO;
      RETURN SUBSTR(PFO1.PFO_RANGO_MIN_CHAR, 1, 20);
    END IF;
    CLOSE C_COMPARTIMENTO;

    OPEN C_ESCALONADO;
    FETCH C_ESCALONADO
      INTO PFO1;
    IF C_ESCALONADO%FOUND THEN
      CLOSE C_ESCALONADO;
      RETURN SUBSTR(PFO1.PFO_RANGO_MIN_CHAR, 1, 20);
    END IF;
    CLOSE C_ESCALONADO;

    OPEN C_AGRUPADOR;
    FETCH C_AGRUPADOR
      INTO PFO1;
    IF C_AGRUPADOR%FOUND THEN
      CLOSE C_AGRUPADOR;
      RETURN SUBSTR(PFO1.PFO_RANGO_MIN_CHAR, 1, 20);
    END IF;
    CLOSE C_AGRUPADOR;

    OPEN C_FONDO_NORMAL;
    FETCH C_FONDO_NORMAL
      INTO PFO1;
    IF C_FONDO_NORMAL%FOUND THEN
      CLOSE C_FONDO_NORMAL;
      RETURN SUBSTR(PFO1.PFO_RANGO_MIN_CHAR, 1, 20);
    ELSE
      CLOSE C_FONDO_NORMAL;
      RAISE_APPLICATION_ERROR(-20001,
                              'No se pudo deteminar el fondo para el negocio ' ||
                              P_NEGOCIO ||
                              '. Paquete P_PROCESOS_NOCTURNOS.P_FONDO_PADRE');
    END IF;
  END P_FONDO_PADRE;

  PROCEDURE P_SALDOS_INCUMPLIDOS(P_FECHA DATE, P_TX IN NUMBER DEFAULT NULL) IS
    --******************************************************************************
    --** 1) SE SELECCIONAN LOS FONDOS QUE TIENEN PARAMETRIZADO SALDO MINIMO       **
    --** 2) SE SELECCIONAN LOS CLIENTES DEL FONDO EN PROCESO                      **
    --** 3) SE AGRUPAN LAS CUENTAS DEL CLIENTE Y SE ACUMULA EL SALDO DE INVERSION **
    --**    SI EL SALDO DE INVERSION ES MENOR AL PARAMETRIZADO Y LA FECHA DE      **
    --**    INCUMPLIMIENTO ES NULA SE ACTUALIZA ESTA FECHA                        **
    --******************************************************************************
    --**       SE PUEDE EJECUTAR NUEVAMENTE SIN REQUSITIOS DE REPROCESO           **
    --******************************************************************************

    CURSOR C_PARAMETROS IS
      SELECT FON_CODIGO, PFO_RANGO_MIN_NUMBER
        FROM FONDOS, PARAMETROS_FONDOS
       WHERE FON_CODIGO = PFO_FON_CODIGO
         AND FON_ESTADO = 'A'
         AND PFO_PAR_CODIGO = 28
         AND PFO_RANGO_MIN_NUMBER > 0
       ORDER BY 1;
    C_PAR C_PARAMETROS%ROWTYPE;

    CURSOR C_CLIENTES IS
      SELECT MCF_CFO_CCC_CLI_PER_NUM_IDEN CFO_CCC_CLI_PER_NUM_IDEN,
             MCF_CFO_CCC_CLI_PER_TID_CODIGO CFO_CCC_CLI_PER_TID_CODIGO,
             MCF_CFO_FON_CODIGO CFO_FON_CODIGO,
             SUM(MCF_SALDO_INVERSION) SALDO
        FROM GL_MAX_MCF MCF1
       WHERE MCF_CONSECUTIVO =
             (SELECT MAX(MCF2.MCF_CONSECUTIVO)
                FROM GL_MAX_MCF MCF2
               WHERE MCF2.MCF_CFO_CCC_CLI_PER_NUM_IDEN =
                     MCF1.MCF_CFO_CCC_CLI_PER_NUM_IDEN
                 AND MCF2.MCF_CFO_CCC_CLI_PER_TID_CODIGO =
                     MCF1.MCF_CFO_CCC_CLI_PER_TID_CODIGO
                 AND MCF2.MCF_CFO_CCC_NUMERO_CUENTA =
                     MCF1.MCF_CFO_CCC_NUMERO_CUENTA
                 AND MCF2.MCF_CFO_CCC_NUMERO_CUENTA =
                     MCF1.MCF_CFO_CCC_NUMERO_CUENTA
                 AND MCF2.MCF_CFO_FON_CODIGO = MCF1.MCF_CFO_FON_CODIGO
                 AND MCF2.MCF_CFO_CODIGO = MCF1.MCF_CFO_CODIGO)
       group by MCF_CFO_CCC_CLI_PER_NUM_IDEN,
                MCF_CFO_CCC_CLI_PER_TID_CODIGO,
                MCF_CFO_FON_CODIGO
      HAVING SUM(MCF_SALDO_INVERSION) < C_PAR.PFO_RANGO_MIN_NUMBER AND SUM(MCF_SALDO_INVERSION) > 0
       ORDER BY 1;

    C_CLI C_CLIENTES%ROWTYPE;

    CURSOR C_MOVIMIENTOS IS
      SELECT 'X'
        FROM MOVIMIENTOS_CUENTAS_FONDOS
       WHERE MCF_CFO_CCC_CLI_PER_NUM_IDEN = C_CLI.CFO_CCC_CLI_PER_NUM_IDEN
         AND MCF_CFO_CCC_CLI_PER_TID_CODIGO =
             C_CLI.CFO_CCC_CLI_PER_TID_CODIGO
         AND MCF_CFO_FON_CODIGO = C_CLI.CFO_FON_CODIGO
         AND MCF_FECHA >= TRUNC(P_FECHA) - 1
         AND MCF_FECHA < TRUNC(P_FECHA)
         AND MCF_SALDO_INVER >= C_PAR.PFO_RANGO_MIN_NUMBER;
    C_MOV VARCHAR2(1);

    P_NUM_INI    NUMBER;
    P_NUM_FIN    NUMBER;
    N_ID_PROCESO NUMBER;
    N_TX         NUMBER;

  BEGIN

    --se asignar el consecutivo del proceso(tabla PARAMETRIZACION_PROCESOS)
    N_ID_PROCESO := P_TRAZA_CORE.FN_ID_PROCESO('P_PROCESOS_NOCTURNOS.P_SALDOS_INCUMPLIDOS');

    --se Asigna consecutivo para la transaccion, si el proceso es el primero que se llama, reinicia el consecutivo
    N_TX := P_TRAZA_CORE.FN_TRAE_TX(P_TX);

    --Registra Traza
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'I',
                                    'Inicio proceso P_PROCESOS_NOCTURNOS.P_SALDOS_INCUMPLIDOS. Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE,
                                            'DD-MM-YYYY HH24:mi:ss'),
                                    N_TX);

    OPEN C_PARAMETROS; --> Recupera los fondos con Parametro de Saldo Minimo
    FETCH C_PARAMETROS
      INTO C_PAR;
    WHILE C_PARAMETROS%FOUND LOOP
      DELETE FROM GL_MAX_MCF;

      INSERT INTO GL_MAX_MCF
        (FECHA_DIA,
         MCF_CFO_CCC_CLI_PER_NUM_IDEN,
         MCF_CFO_CCC_CLI_PER_TID_CODIGO,
         MCF_CFO_CCC_NUMERO_CUENTA,
         MCF_CFO_FON_CODIGO,
         MCF_CFO_CODIGO,
         MCF_FECHA,
         MCF_CONSECUTIVO,
         MCF_SALDO_INVERSION)
        (SELECT TRUNC(P_FECHA),
                MCF_CFO_CCC_CLI_PER_NUM_IDEN,
                MCF_CFO_CCC_CLI_PER_TID_CODIGO,
                MCF_CFO_CCC_NUMERO_CUENTA,
                MCF_CFO_FON_CODIGO,
                MCF_CFO_CODIGO,
                MCF_FECHA,
                MCF_CONSECUTIVO,
                MCF_SALDO_INVER
           FROM MOVIMIENTOS_CUENTAS_FONDOS
          WHERE MCF_CFO_FON_CODIGO = C_PAR.FON_CODIGO
            AND MCF_FECHA >= TRUNC(P_FECHA)
            AND MCF_FECHA < TRUNC(P_FECHA + 1));

      OPEN C_CLIENTES; --> Recupera los Clientes incumplidos del Fondo
      FETCH C_CLIENTES
        INTO C_CLI;
      WHILE C_CLIENTES%FOUND LOOP
        C_MOV := NULL;
        OPEN C_MOVIMIENTOS;
        FETCH C_MOVIMIENTOS
          INTO C_MOV;
        IF NVL(C_MOV, ' ') = 'X' THEN
          UPDATE CUENTAS_FONDOS
             SET CFO_FECHA_INCUMPLIMIENTO = TRUNC(P_FECHA)
           WHERE CFO_CCC_CLI_PER_NUM_IDEN = C_CLI.CFO_CCC_CLI_PER_NUM_IDEN
             AND CFO_CCC_CLI_PER_TID_CODIGO =
                 C_CLI.CFO_CCC_CLI_PER_TID_CODIGO
             AND CFO_FON_CODIGO = C_CLI.CFO_FON_CODIGO
             AND CFO_SALDO_INVER != 0
             AND TRUNC(NVL(CFO_FECHA_INCUMPLIMIENTO, '30-NOV-2010')) >=
                 '29-NOV-2010';
        END IF;
        CLOSE C_MOVIMIENTOS;
        COMMIT;
        FETCH C_CLIENTES
          INTO C_CLI;
      END LOOP;
      CLOSE C_CLIENTES;
      FETCH C_PARAMETROS
        INTO C_PAR;
    END LOOP;
    CLOSE C_PARAMETROS;
    COMMIT;

    -- Registrar traza FIN
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'F',
                                    'Fin P_PROCESOS_NOCTURNOS.P_SALDOS_INCUMPLIDOS . Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE,
                                            'DD-MM-YYYY HH24:mi:ss'),
                                    N_TX);

    COMMIT;

  END P_SALDOS_INCUMPLIDOS;

  --SPACHON_VAGTUD395_04/01/2012****
  PROCEDURE P_SALDOS_DIARIOS_DERIVADOS(FINICIO    IN DATE,
                                       FFIN       IN DATE,
                                       P_TEMPORAL IN VARCHAR2,
                                       P_TX       IN NUMBER DEFAULT NULL) IS

    FECHA        DATE;
    N_ID_PROCESO NUMBER;
    N_TX         NUMBER;

    CURSOR C_CUENTAS_CLIENTES_DERIVADOS IS
      SELECT CDD_CCC_CLI_PER_NUM_IDEN,
             CDD_CCC_CLI_PER_TID_CODIGO,
             CDD_CCC_NUMERO_CUENTA,
             CDD_SALDO,
             CDD_CUENTA_CRCC,
             PER_NOMBRE
        FROM CUENTAS_CLIENTES_DERIVADOS, FILTRO_PERSONAS
       WHERE CDD_CCC_CLI_PER_NUM_IDEN = PER_NUM_IDEN
         AND CDD_CCC_CLI_PER_TID_CODIGO = PER_TID_CODIGO
       ORDER BY 1;
    CDD1 C_CUENTAS_CLIENTES_DERIVADOS%ROWTYPE;

    CURSOR C_ULTIMO_MOVIMIENTO(P_FECHA DATE) IS
      SELECT MDD1.MDD_FECHA, MDD1.MDD_SALDO, MDD1.MDD_CONSECUTIVO
        FROM MOVIMIENTOS_CUENTAS_DERIVADOS MDD1
       WHERE MDD1.MDD_CDD_CCC_CLI_PER_NUM_IDEN =
             CDD1.CDD_CCC_CLI_PER_NUM_IDEN
         AND MDD1.MDD_CDD_CCC_CLI_PER_TID_CODIGO =
             CDD1.CDD_CCC_CLI_PER_TID_CODIGO
         AND MDD1.MDD_CDD_CCC_NUMERO_CUENTA = CDD1.CDD_CCC_NUMERO_CUENTA
         AND MDD1.MDD_CDD_CUENTA_CRCC = CDD1.CDD_CUENTA_CRCC
         AND MDD1.MDD_FECHA <= TRUNC(P_FECHA + 1)
       ORDER BY MDD1.MDD_FECHA DESC, MDD1.MDD_CONSECUTIVO DESC;
    MDD1 C_ULTIMO_MOVIMIENTO%ROWTYPE;

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN

    --se asignar el consecutivo del proceso(tabla PARAMETRIZACION_PROCESOS)
    N_ID_PROCESO := P_TRAZA_CORE.FN_ID_PROCESO('P_PROCESOS_NOCTURNOS.P_SALDOS_DIARIOS_DERIVADOS1');

    --se Asigna consecutivo para la transaccion, si el proceso es el primero que se llama, reinicia el consecutivo
    N_TX := P_TRAZA_CORE.FN_TRAE_TX(P_TX);

    --Registra Traza
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'I',
                                    'Inicio proceso P_PROCESOS_NOCTURNOS.P_SALDOS_DIARIOS_DERIVADOS. Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE,
                                            'DD-MM-YYYY HH24:mi:ss') ||
                                    'Rango de fechas procesado: ' ||
                                    TO_CHAR(FINICIO, 'DD-MON-YYYY') ||
                                    ' a ' || TO_CHAR(FFIN, 'DD-MON-YYYY'),
                                    N_TX);

    DELETE FROM SALDOS_DIARIOS_DERIVADOS
     WHERE SDD_FECHA_SALDO >= FINICIO
       AND SDD_FECHA_SALDO < FFIN + 1;
    FECHA := TRUNC(FINICIO);

    WHILE FECHA <= TRUNC(FFIN) LOOP
      OPEN C_CUENTAS_CLIENTES_DERIVADOS;
      FETCH C_CUENTAS_CLIENTES_DERIVADOS
        INTO CDD1;
      WHILE C_CUENTAS_CLIENTES_DERIVADOS%FOUND LOOP
        OPEN C_ULTIMO_MOVIMIENTO(P_FECHA => FECHA);
        FETCH C_ULTIMO_MOVIMIENTO
          INTO MDD1;
        IF C_ULTIMO_MOVIMIENTO%FOUND THEN
          IF MDD1.MDD_SALDO != 0 THEN
            IF NVL(P_TEMPORAL, 'N') = 'N' THEN
              INSERT INTO SALDOS_DIARIOS_DERIVADOS
                (SDD_CONSECUTIVO,
                 SDD_CDD_CCC_CLI_PER_NUM_IDEN,
                 SDD_CDD_CCC_CLI_PER_TID_CODIGO,
                 SDD_CDD_CCC_NUMERO_CUENTA,
                 SDD_CDD_CUENTA_CRCC,
                 SDD_MDD_FECHA,
                 SDD_MDD_SALDO,
                 SDD_MDD_CONSECUTIVO,
                 SDD_FECHA_SALDO)
              VALUES
                (SSD_SEQ.NEXTVAL,
                 CDD1.CDD_CCC_CLI_PER_NUM_IDEN,
                 CDD1.CDD_CCC_CLI_PER_TID_CODIGO,
                 CDD1.CDD_CCC_NUMERO_CUENTA,
                 CDD1.CDD_CUENTA_CRCC,
                 MDD1.MDD_FECHA,
                 MDD1.MDD_SALDO,
                 MDD1.MDD_CONSECUTIVO,
                 FECHA);
            ELSE
              INSERT INTO GL_SALDOS_DIARIOS_DERIVADOS
                (SDD_CDD_CCC_CLI_PER_NUM_IDEN,
                 SDD_CDD_CCC_CLI_PER_TID_CODIGO,
                 SDD_CDD_CCC_NUMERO_CUENTA,
                 SDD_CDD_CUENTA_CRCC,
                 SDD_MDD_FECHA,
                 SDD_MDD_SALDO)
              VALUES
                (CDD1.CDD_CCC_CLI_PER_NUM_IDEN,
                 CDD1.CDD_CCC_CLI_PER_TID_CODIGO,
                 CDD1.CDD_CCC_NUMERO_CUENTA,
                 CDD1.CDD_CUENTA_CRCC,
                 MDD1.MDD_FECHA,
                 MDD1.MDD_SALDO);
            END IF;
          END IF;
        END IF;
        CLOSE C_ULTIMO_MOVIMIENTO;
        FETCH C_CUENTAS_CLIENTES_DERIVADOS
          INTO CDD1;
      END LOOP;
      CLOSE C_CUENTAS_CLIENTES_DERIVADOS;
      FECHA := FECHA + 1;
    END LOOP;
    COMMIT;

    -- Registrar traza FIN
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'F',
                                    'Fin P_PROCESOS_NOCTURNOS.P_SALDOS_DIARIOS_DERIVADOS. Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE,
                                            'DD-MM-YYYY HH24:mi:ss') ||
                                    'Rango de fechas procesado: ' ||
                                    TO_CHAR(FINICIO, 'DD-MON-YYYY') ||
                                    ' a ' || TO_CHAR(FFIN, 'DD-MON-YYYY') ||
                                    ' Proceso terminado con exito',
                                    N_TX);
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
       P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                      'E',
                                      'P_PROCESOS_NOCTURNOS.P_SALDOS_DIARIOS_DERIVADOS. Fecha: ' ||
                                      TO_CHAR(SYSDATE,
                                              'DD-MM-YYYY HH24:mi:ss') || ' ' ||
                                      SUBSTR(SQLERRM, 1, 80),
                                      N_TX);

  END P_SALDOS_DIARIOS_DERIVADOS;

  --SPACHON_VAGTUD395_04/01/2012****
  PROCEDURE P_SALDOS_DIARIOS_DERIVADOS(FINICIO         IN DATE,
                                       FFIN            IN DATE,
                                       P_NUM_IDEN      IN VARCHAR2,
                                       P_TID_CODIGO    IN VARCHAR2,
                                       P_NUMERO_CUENTA IN VARCHAR2,
                                       P_TX            IN NUMBER DEFAULT NULL) IS

    FECHA        DATE;
    N_ID_PROCESO NUMBER;
    N_TX         NUMBER;

    CURSOR C_CUENTAS_CLIENTES_DERIVADOS(P_NUM_IDEN      VARCHAR2,
                                        P_TID_CODIGO    VARCHAR2,
                                        P_NUMERO_CUENTA VARCHAR2) IS
      SELECT CDD_CCC_CLI_PER_NUM_IDEN,
             CDD_CCC_CLI_PER_TID_CODIGO,
             CDD_CCC_NUMERO_CUENTA,
             CDD_SALDO,
             CDD_CUENTA_CRCC,
             PER_NOMBRE
        FROM CUENTAS_CLIENTES_DERIVADOS, FILTRO_PERSONAS
       WHERE CDD_CCC_CLI_PER_NUM_IDEN = P_NUM_IDEN
         AND CDD_CCC_CLI_PER_TID_CODIGO = P_TID_CODIGO
         AND CDD_CCC_NUMERO_CUENTA = P_NUMERO_CUENTA
         AND CDD_CCC_CLI_PER_NUM_IDEN = PER_NUM_IDEN
         AND CDD_CCC_CLI_PER_TID_CODIGO = PER_TID_CODIGO
       ORDER BY 1;
    CDD1 C_CUENTAS_CLIENTES_DERIVADOS%ROWTYPE;

    CURSOR C_ULTIMO_MOVIMIENTO(P_FECHA DATE) IS
      SELECT MDD1.MDD_FECHA, MDD1.MDD_SALDO, MDD1.MDD_CONSECUTIVO
        FROM MOVIMIENTOS_CUENTAS_DERIVADOS MDD1
       WHERE MDD1.MDD_CDD_CCC_CLI_PER_NUM_IDEN = P_NUM_IDEN
         AND MDD1.MDD_CDD_CCC_CLI_PER_TID_CODIGO = P_TID_CODIGO
         AND MDD1.MDD_CDD_CCC_NUMERO_CUENTA = CDD1.CDD_CCC_NUMERO_CUENTA
         AND MDD1.MDD_CDD_CUENTA_CRCC = CDD1.CDD_CUENTA_CRCC
         AND MDD1.MDD_FECHA <= TRUNC(P_FECHA + 1)
       ORDER BY MDD1.MDD_FECHA DESC, MDD1.MDD_CONSECUTIVO DESC;
    MDD1 C_ULTIMO_MOVIMIENTO%ROWTYPE;


  BEGIN

    --se asignar el consecutivo del proceso(tabla PARAMETRIZACION_PROCESOS)
    N_ID_PROCESO := P_TRAZA_CORE.FN_ID_PROCESO('P_PROCESOS_NOCTURNOS.P_SALDOS_DIARIOS_DERIVADOS[2]');

    --se Asigna consecutivo para la transaccion, si el proceso es el primero que se llama, reinicia el consecutivo
    N_TX := P_TRAZA_CORE.FN_TRAE_TX(P_TX);

    --Registra Traza
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'I',
                                    'Inicio proceso P_PROCESOS_NOCTURNOS.P_SALDOS_DIARIOS_DERIVADOS[2]. Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE,
                                            'DD-MM-YYYY HH24:mi:ss') ||
                                    'Rango de fechas procesado: ' ||
                                    TO_CHAR(FINICIO, 'DD-MON-YYYY') ||
                                    ' a ' || TO_CHAR(FFIN, 'DD-MON-YYYY'),
                                    N_TX);

    DELETE FROM SALDOS_DIARIOS_DERIVADOS
     WHERE SDD_MDD_FECHA >= FINICIO
       AND SDD_MDD_FECHA < FFIN + 1
       AND SDD_CDD_CCC_CLI_PER_NUM_IDEN = P_NUM_IDEN
       AND SDD_CDD_CCC_CLI_PER_TID_CODIGO = P_TID_CODIGO
       AND SDD_CDD_CCC_NUMERO_CUENTA = P_NUMERO_CUENTA;

    FECHA := TRUNC(FINICIO);

    WHILE FECHA <= TRUNC(FFIN) LOOP
      OPEN C_CUENTAS_CLIENTES_DERIVADOS(P_NUM_IDEN      => P_NUM_IDEN,
                                        P_TID_CODIGO    => P_TID_CODIGO,
                                        P_NUMERO_CUENTA => P_NUMERO_CUENTA);
      FETCH C_CUENTAS_CLIENTES_DERIVADOS
        INTO CDD1;
      WHILE C_CUENTAS_CLIENTES_DERIVADOS%FOUND LOOP
        OPEN C_ULTIMO_MOVIMIENTO(P_FECHA => FECHA);
        FETCH C_ULTIMO_MOVIMIENTO
          INTO MDD1;
        IF C_ULTIMO_MOVIMIENTO%FOUND THEN
          IF MDD1.MDD_SALDO != 0 THEN
            INSERT INTO SALDOS_DIARIOS_DERIVADOS
              (SDD_CONSECUTIVO,
               SDD_CDD_CCC_CLI_PER_NUM_IDEN,
               SDD_CDD_CCC_CLI_PER_TID_CODIGO,
               SDD_CDD_CCC_NUMERO_CUENTA,
               SDD_CDD_CUENTA_CRCC,
               SDD_MDD_FECHA,
               SDD_MDD_SALDO,
               SDD_MDD_CONSECUTIVO,
               SDD_FECHA_SALDO)
            VALUES
              (SSD_SEQ.NEXTVAL,
               CDD1.CDD_CCC_CLI_PER_NUM_IDEN,
               CDD1.CDD_CCC_CLI_PER_TID_CODIGO,
               CDD1.CDD_CCC_NUMERO_CUENTA,
               CDD1.CDD_CUENTA_CRCC,
               MDD1.MDD_FECHA,
               MDD1.MDD_SALDO,
               MDD1.MDD_CONSECUTIVO,
               FECHA);
          END IF;
        END IF;
        CLOSE C_ULTIMO_MOVIMIENTO;
        FETCH C_CUENTAS_CLIENTES_DERIVADOS
          INTO CDD1;
      END LOOP;
      CLOSE C_CUENTAS_CLIENTES_DERIVADOS;
      FECHA := FECHA + 1;
    END LOOP;
    COMMIT;

    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'F',
                                    'Fin P_PROCESOS_NOCTURNOS.P_SALDOS_DIARIOS_DERIVADOS[2]. Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE,
                                            'DD-MM-YYYY HH24:mi:ss') ||
                                    'Rango de fechas procesado: ' ||
                                    TO_CHAR(FINICIO, 'DD-MON-YYYY') ||
                                    ' a ' || TO_CHAR(FFIN, 'DD-MON-YYYY') ||
                                    ' Proceso terminado con exito',
                                    N_TX);
    COMMIT;

  EXCEPTION
    WHEN OTHERS THEN
        P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                      'E',
                                      'P_PROCESOS_NOCTURNOS.P_SALDOS_DIARIOS_DERIVADOS. Fecha: ' ||
                                      TO_CHAR(SYSDATE,
                                              'DD-MM-YYYY HH24:mi:ss') || ' ' ||
                                      SUBSTR(SQLERRM, 1, 80),
                                      N_TX);

  END P_SALDOS_DIARIOS_DERIVADOS;

  PROCEDURE P_ACT_CONS_COLOCACION(P_VALOR VARCHAR2,
                                  P_TX    IN NUMBER DEFAULT NULL) IS

    P_NUM_INI    NUMBER;
    P_NUM_FIN    NUMBER;
    N_ID_PROCESO NUMBER;
    N_TX         NUMBER;

  BEGIN

    --se asignar el consecutivo del proceso(tabla PARAMETRIZACION_PROCESOS)
    N_ID_PROCESO := P_TRAZA_CORE.FN_ID_PROCESO('P_PROCESOS_NOCTURNOS.P_ACT_CONS_COLOCACION');

    --se Asigna consecutivo para la transaccion, si el proceso es el primero que se llama, reinicia el consecutivo
    N_TX := P_TRAZA_CORE.FN_TRAE_TX(P_TX);
    --Registra Traza
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'I',
                                    'Inicio proceso P_PROCESOS_NOCTURNOS.P_ACT_CONS_COLOCACION. Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE,
                                            'DD-MM-YYYY HH24:mi:ss'),
                                    N_TX);

    UPDATE CONSTANTES
       SET CON_VALOR_CHAR = P_VALOR
     WHERE CON_MNEMONICO = 'COC';
    COMMIT;
     P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'F',
                                    'Fin P_PROCESOS_NOCTURNOS.P_ACT_CONS_COLOCACION. Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE,
                                            'DD-MM-YYYY HH24:mi:ss'),
                                    N_TX);
    commit;

  EXCEPTION
    WHEN OTHERS THEN
      P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                      'E',
                                      'P_ACT_CONS_COLOCACION. Fecha:' ||
                                      TO_CHAR(SYSDATE,
                                              'DD-MM-YYYY HH24:mi:ss') || ' ' ||
                                      SUBSTR(SQLERRM, 1, 80),
                                      N_TX);

  END P_ACT_CONS_COLOCACION;

  /*********************************************************************************
  ***  Procedimiento que llama el  calculo de IMGF diario                         **
  ***  Se corre en el proceso Nocturno                                            **
  ***  se debe correr despues de las 12:00 no tiene limite de horario             **
  ***  Siempre evia mail al finalizar el proceso : con ERROR o EXITOSO            **
  ***  SE DEBE CORRER TODOS LOS DIAS                                              **
  ******************************************************************************* */
  PROCEDURE GENERAR_IMGF_DIARIO(P_TX IN NUMBER DEFAULT NULL) is
    P_FECHA DATE;
    CURSOR C_ERRORES IS
      SELECT COUNT(*) T
        FROM ERRORES_PROCESOS
       WHERE ERP_FECHA_ERROR >= TRUNC(P_FECHA)
         AND ERP_PROCESO = 'P_COMPENSACION.CALCULO_IMGF_DIARIO';
    NUM_ERRORES NUMBER;
    -- VARIABLES PARA MAIL
    conn      utl_smtp.connection;
    req       utl_http.req;
    resp      utl_http.resp;
    data      RAW(200);
    NOM_ERROR VARCHAR2(80);

    P_NUM_INI    NUMBER;
    P_NUM_FIN    NUMBER;
    N_ID_PROCESO NUMBER;
    N_TX         NUMBER;

  BEGIN

     N_ID_PROCESO := P_TRAZA_CORE.FN_ID_PROCESO('P_PROCESOS_NOCTURNOS.GENERAR_IMGF_DIARIO');

    --se Asigna consecutivo para la transaccion, si el proceso es el primero que se llama, reinicia el consecutivo
    N_TX := P_TRAZA_CORE.FN_TRAE_TX(P_TX);

    --Registra Traza
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'I',
                                    'Inicio proceso P_PROCESOS_NOCTURNOS.GENERAR_IMGF_DIARIO. Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE,
                                            'DD-MM-YYYY HH24:mi:ss'),
                                    N_TX);

    SELECT TRUNC(SYSDATE - 1) INTO P_FECHA FROM DUAL;
    P_COMPENSACION.CALCULO_IMGF_DIARIO(P_FECHA, N_TX);
    -- verifica si se generaron errores
    OPEN C_ERRORES;
    FETCH C_ERRORES
      INTO NUM_ERRORES;
    CLOSE C_ERRORES;
    NUM_ERRORES := NVL(NUM_ERRORES, 0);
    IF NUM_ERRORES != 0 THEN
       P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                      'E',
                                      'P_PROCESOS_NOCTURNOS.GENERAR_IMGF_DIARIO  F A L L O !!!. Fecha: ' ||
                                      TO_CHAR(SYSDATE,
                                              'DD-MM-YYYY HH24:mi:ss') ||
                                      ' Se corrio procedimiento y genero errores. Verificar en la tabla ERRORES_PROCESO ',
                                      N_TX);
    ELSE
       P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                      'T',
                                      'P_PROCESOS_NOCTURNOS.GENERAR_IMGF_DIARIO  EXITOSO !!!. Fecha: ' ||
                                      TO_CHAR(SYSDATE,
                                              'DD-MM-YYYY HH24:mi:ss') ||
                                      ' Calculo de IMGF diario : EXITOSO ',
                                      N_TX);
    END IF;

     P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'F',
                                    'Fin P_PROCESOS_NOCTURNOS.GENERAR_IMGF_DIARIO. Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE,
                                            'DD-MM-YYYY HH24:mi:ss'),
                                    N_TX);
    COMMIT;
  EXCEPTION
    WHEN OTHERS THEN
       P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                      'E',
                                      'P_PROCESOS_NOCTURNOS.GENERAR_IMGF_DIARIO. Fecha: ' ||
                                      TO_CHAR(SYSDATE,
                                              'DD-MM-YYYY HH24:mi:ss') || ' ' ||
                                      SUBSTR(SQLERRM, 1, 80),
                                      N_TX);
  END GENERAR_IMGF_DIARIO;

  -- RCOCOMA VAGTUD381 29-05-2012
  PROCEDURE P_NOC_PORTAFOLIO_FACTURAS IS

    P_NUM_INI NUMBER;
    P_NUM_FIN NUMBER;

  BEGIN

    P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_NOC_PORTAFOLIO_FACTURAS',
                                                      'INI');

    BEGIN
      P_MAIL.ENVIO_MAIL_ERROR('Inicio proceso nocturno P_PORTAFOLIO.P_PORTAFOLIO_FACTURAS ',
                              '<br>' || 'Fecha Proceso: ' || SYSDATE,
                              DESTINATARIOS);
    EXCEPTION
      WHEN OTHERS THEN
        DBMS_OUTPUT.PUT_LINE('-20001 Fallo el llamado al paquete de Mail. ' ||
                             SQLERRM);
    END;
    P_PORTAFOLIO.P_PORTAFOLIO_FACTURAS;

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.P_NOC_PORTAFOLIO_FACTURAS',
                                                      'FIN');
    COMMIT;

  END P_NOC_PORTAFOLIO_FACTURAS;
