                             P_PARAMETROS => '+P_CONDICION=%20(CBA.CBA_BAN_CODIGO,%20CBA.CBA_NUMERO_CUENTA%20)%20IN%20((0,%2762250063%27)%20,(0,%2762255353%27)%20,(1,%27033406547%27)%20,(23,%27288063910%27))%20AND+P_MOVIMIENTO=%20AND%20MCB.MCB_TMB_MNEMONICO%20IN%20(%27CCHG%27,%27INT%27,%27PCOM%27,%27RCCHG%27,%27RCOM%27,%27RINT%27)+P_MOVIMIENTO1=%20AND%20PCB.PCB_TMB_MNEMONICO%20IN%20(%27CCHG%27,%27INT%27,%27PCOM%27,%27RCCHG%27,%27RCOM%27,%27RINT%27)+P_FECHAS=%20MCB.MCB_FECHA%20%3E=%27' ||
                                             V_FECHA ||
                                             '%27AND%20MCB.MCB_FECHA%20%3C%27' ||
                                             V_FECHA_N ||
                                             '%27+P_FECHAS1=%20PCB.PCB_FECHA%20%3E=%27' ||
                                             V_FECHA ||
                                             '%27%20AND%20PCB.PCB_FECHA%20%3C%27' ||
                                             V_FECHA ||
                                             '%27%20+P_FECHA_INI=%27' ||
                                             V_FECHA || '%27',
                             P_ARCHIVO    => '/apps/rep_nocturnos_a2/RMOVBA_CE_A2_' ||
                                             V_FECHAN);

  EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento PR_REPORTE_RMOVBA_CE_A2',
                              SUBSTR(SQLERRM, 1, 80),
                              'procesosnocturnos@corredores.com');
  END PR_REPORTE_RMOVBA_CE_A2;

