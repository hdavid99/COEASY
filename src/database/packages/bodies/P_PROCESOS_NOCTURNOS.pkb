                            '<br>' || 'Fecha Proceso: ' || SYSDATE,
                            DESTINATARIOS);

    P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_PROCESOS_NOCTURNOS.PR_NOC_CONTROL_CONVENIOS',
                                                      'FIN');
