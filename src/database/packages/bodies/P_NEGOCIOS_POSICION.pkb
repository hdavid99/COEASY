FUNCTION FECHA_VECIMIENTO_REPORTE
( P_NUMERO_CONSECUTIVO NUMBER) RETURN DATE IS
V_DATE DATE;
V_MNEMNONICO VARCHAR2(12);
BEGIN
     BEGIN
          SELECT  PPO_FUG_ISI_MNEMONICO, PPO_FECHA_VENCIMIENTO
          INTO   V_MNEMNONICO ,  V_DATE
      FROM    NEGOCIOS_POSICION
             ,PORTAFOLIOS_POSICION
      WHERE   NPO_CONSECUTIVO = P_NUMERO_CONSECUTIVO
      AND     NPO_PPO_CONSECUTIVO = PPO_CONSECUTIVO
      AND     PPO_FUG_ISI_MNEMONICO IS NOT NULL;
     EXCEPTION
        WHEN OTHERS THEN
     BEGIN

           SELECT TFO_FUG_ISI_MNEMONICO, PPO_FECHA_VENCIMIENTO
           INTO   V_MNEMNONICO ,  V_DATE
      FROM   NEGOCIOS_POSICION AA
            ,PORTAFOLIOS_POSICION PPO1
            ,TITULOS_FONDOS BB
      WHERE  NPO_CONSECUTIVO = P_NUMERO_CONSECUTIVO
      AND    NPO_PPO_CONSECUTIVO = PPO1.PPO_CONSECUTIVO
      AND    TFO_FON_CODIGO = '860079174'
      AND    NVL(TFO_ENA_MNEMONICO,' ') = NVL(PPO1.PPO_ENA_MNEMONICO,' ')
      AND    NVL(TFO_FECHA_EMISION,TRUNC(SYSDATE - 10000)) = NVL(PPO1.PPO_FECHA_EMISION,TRUNC(SYSDATE - 10000))
      AND    NVL(TFO_FECHA_VENCIMIENTO,TRUNC(SYSDATE - 10000)) = NVL(PPO1.PPO_FECHA_VENCIMIENTO,TRUNC(SYSDATE - 10000))
      AND    NVL(TFO_BMO_MNEMONICO,' ') = NVL(PPO1.PPO_BMO_MNEMONICO,' ')
      AND    NVL(TFO_PERIODICIDAD_TASA,-1)  = NVL(PPO1.PPO_PERIODICIDAD_TASA,-1)
      AND    NVL(TFO_BASE_CALCULO,-1) = NVL(PPO1.PPO_BASE_CALCULO,-1)
      AND    NVL(TFO_MODALIDAD_TASA,' ') = NVL(PPO1.PPO_MODALIDAD_TASA,' ')
      AND    NVL(TFO_TASA_FACIAL,-1) = NVL(PPO1.PPO_TASA_FACIAL/100,-1)
      AND    NVL(TFO_TRE_MNEMONICO,' ') = NVL(PPO1.PPO_TRE_MNEMONICO,' ')
      AND    NVL(TFO_PUNTOS_ADICIONALES,-1) = NVL(PPO1.PPO_PUNTOS_ADICIONALES,-1)
      AND    NVL(TFO_TIPO_PAGO_FLUJO,'XX') = NVL(PPO1.PPO_TIPO_PAGO_FLUJO,'XX')
      AND    NVL(TFO_AMORTIZABLE,'N') = NVL(PPO1.PPO_AMORTIZABLE,'N')
      AND    NVL(TFO_CAPITALIZABLE,'N') = NVL(PPO1.PPO_CAPITALIZABLE,'N')
      AND    NVL(TFO_CODIGO_PERIODO,'XX') = NVL(PPO1.PPO_CODIGO_PERIODO,'XX')
      AND    TRUNC(TFO_FECHA_OPERACION) <= TRUNC(NPO_FECHA)
      AND    TFO_FUG_ISI_MNEMONICO IS NOT NULL
      AND    ROWNUM = '1'
      ORDER BY TFO_FECHA_OPERACION DESC, NPO_CONSECUTIVO;

      EXCEPTION
         WHEN OTHERS THEN
          V_DATE := TO_DATE ('11/11/1911', 'DD/MM/YYYY') ;
     END;
    END;

   RETURN V_DATE;

END FECHA_VECIMIENTO_REPORTE;

/*******************/

FUNCTION OBTENER_NUMERO_OPERA_REPORTE
( P_NUMERO_OPERACION NUMBER,
  P_TIPO_OPERACION VARCHAR2) RETURN NUMBER IS

V_NUMERO NUMBER;
BEGIN
    BEGIN
      SELECT  DECODE (P_TIPO_OPERACION, 'C',LIC_OCO_CONSECUTIVO , 'V',LIC_OVE_CONSECUTIVO, NULL)
      INTO     V_NUMERO
      FROM   LIQUIDACIONES_COMERCIAL
      WHERE  LIC_NUMERO_OPERACION = P_NUMERO_OPERACION
      AND    LIC_TIPO_OPERACION = 'C'
      AND    LIC_NIT_1 = '860079174'
      AND    LIC_TIPO_IDENTIFICACION_1 = 'NIT';
    EXCEPTION
         WHEN OTHERS THEN
          V_NUMERO := NULL;
      END;


   RETURN V_NUMERO;
END OBTENER_NUMERO_OPERA_REPORTE;

/*******************/


FUNCTION OBTENER_ISIN_REPORTE (P_CONSECUTIVO NUMBER, TIPO_OPE VARCHAR2 )

RETURN VARCHAR2 IS
V_ISI VARCHAR2(25);
P_FECHA_VEN  VARCHAR2(25);
BEGIN
----CAMBIOS_ESTADOS_POSICION.CEP_PER_NUM_IDEN%TYPE
BEGIN
SELECT DECODE  (PPO_FUG_ISI_MNEMONICO, NULL, ' '),TO_CHAR ( PPO_FECHA_VENCIMIENTO, 'DD-MM-YYYY')
 INTO V_ISI   , P_FECHA_VEN
      FROM    NEGOCIOS_POSICION ,  PORTAFOLIOS_POSICION
      WHERE   NPO_CONSECUTIVO = P_CONSECUTIVO
      AND     NPO_PPO_CONSECUTIVO = PPO_CONSECUTIVO
      AND     PPO_FUG_ISI_MNEMONICO IS NOT NULL;
EXCEPTION
 WHEN OTHERS THEN
  IF   V_ISI IS NULL THEN
      BEGIN
       SELECT TFO_FUG_ISI_MNEMONICO, TO_CHAR (PPO_FECHA_VENCIMIENTO, 'DD-MM-YYYY')
  INTO V_ISI , P_FECHA_VEN
      FROM   NEGOCIOS_POSICION AA
            ,PORTAFOLIOS_POSICION PPO1
            ,TITULOS_FONDOS BB
      WHERE  NPO_CONSECUTIVO = P_CONSECUTIVO
      AND    NPO_PPO_CONSECUTIVO = PPO1.PPO_CONSECUTIVO
      AND    TFO_FON_CODIGO = '860079174'
      AND    NVL(TFO_ENA_MNEMONICO,' ') = NVL(PPO1.PPO_ENA_MNEMONICO,' ')
      AND    NVL(TFO_FECHA_EMISION,TRUNC(SYSDATE - 10000)) = NVL(PPO1.PPO_FECHA_EMISION,TRUNC(SYSDATE - 10000))
      AND    NVL(TFO_FECHA_VENCIMIENTO,TRUNC(SYSDATE - 10000)) = NVL(PPO1.PPO_FECHA_VENCIMIENTO,TRUNC(SYSDATE - 10000))
      AND    NVL(TFO_BMO_MNEMONICO,' ') = NVL(PPO1.PPO_BMO_MNEMONICO,' ')
      AND    NVL(TFO_PERIODICIDAD_TASA,-1)  = NVL(PPO1.PPO_PERIODICIDAD_TASA,-1)
      AND    NVL(TFO_BASE_CALCULO,-1) = NVL(PPO1.PPO_BASE_CALCULO,-1)
      AND    NVL(TFO_MODALIDAD_TASA,' ') = NVL(PPO1.PPO_MODALIDAD_TASA,' ')
      AND    NVL(TFO_TASA_FACIAL,-1) = NVL(PPO1.PPO_TASA_FACIAL/100,-1)
      AND    NVL(TFO_TRE_MNEMONICO,' ') = NVL(PPO1.PPO_TRE_MNEMONICO,' ')
      AND    NVL(TFO_PUNTOS_ADICIONALES,-1) = NVL(PPO1.PPO_PUNTOS_ADICIONALES,-1)
      AND    NVL(TFO_TIPO_PAGO_FLUJO,'XX') = NVL(PPO1.PPO_TIPO_PAGO_FLUJO,'XX')
      AND    NVL(TFO_AMORTIZABLE,'N') = NVL(PPO1.PPO_AMORTIZABLE,'N')
      AND    NVL(TFO_CAPITALIZABLE,'N') = NVL(PPO1.PPO_CAPITALIZABLE,'N')
      AND    NVL(TFO_CODIGO_PERIODO,'XX') = NVL(PPO1.PPO_CODIGO_PERIODO,'XX')
      AND    TRUNC(TFO_FECHA_OPERACION) <= TRUNC(NPO_FECHA)
      AND    TFO_FUG_ISI_MNEMONICO IS NOT NULL
      AND ROWNUM = '1'
      ORDER BY TFO_FECHA_OPERACION DESC, NPO_CONSECUTIVO;
      EXCEPTION
         WHEN OTHERS THEN
          V_ISI := 'SIN ISIN' ;
  END;
  END IF;
     END;
IF TIPO_OPE = 'F' THEN
RETURN P_FECHA_VEN ;

ELSE
RETURN V_ISI ;
END IF ;

 RETURN P_FECHA_VEN;
END OBTENER_ISIN_REPORTE;

/*******************/

FUNCTION OBTIENE_TASAS_REPORTE (  P_FECHA DATE ,
                                  P_CODIGO NUMBER,
                                  P_VALOR VARCHAR2)
RETURN NUMBER IS

P_TASA_PIP NUMBER;
P_TASA_INFOVA NUMBER;
P_NEW_FECHA DATE;
BEGIN

P_NEW_FECHA := P_FECHA - 1;
BEGIN
SELECT DECODE ( NVL (B.MRF_PROV_PRINCIPAL, ' '), 'INF', B.MRF_TASA_DESCUENTO_ALT, B.MRF_TASA_DESCUENTO), DECODE ( NVL (B.MRF_PROV_PRINCIPAL, ' '), 'INF', B.MRF_TASA_DESCUENTO, B.MRF_TASA_DESCUENTO_ALT)
INTO P_TASA_PIP, P_TASA_INFOVA
FROM   MVTOS_RENTA_FIJA B
WHERE  TRUNC(B.MRF_FECHA) >= P_NEW_FECHA ----TO_DATE ('240719','DDMMYY')
AND    TRUNC(B.MRF_FECHA) < P_NEW_FECHA + 1 ----TO_DATE ('240719','DDMMYY') +1
AND    B.MRF_TFO_FON_CODIGO = '860079174'
AND    B.MRF_TMT_MNEMONICO = 'VAF'
AND    B.MRF_TFO_CODIGO  =  P_CODIGO;


  EXCEPTION

        WHEN NO_DATA_FOUND THEN
        P_TASA_PIP := 0;
        P_TASA_INFOVA := 0;

   RETURN NULL;
     WHEN OTHERS THEN
        P_TASA_PIP := 0;
        P_TASA_INFOVA := 0;

         RETURN NULL;
END;
IF P_VALOR = 'PIP' THEN
     RETURN P_TASA_PIP;

ELSIF P_VALOR = 'INFVA' THEN
    RETURN P_TASA_INFOVA;

END IF;
END OBTIENE_TASAS_REPORTE;


FUNCTION OBTIENE_ISIN_REPORTE (     P_ESPECIE VARCHAR2  )
RETURN VARCHAR IS
    CURSOR califica IS
      SELECT a.clf_calificacion,
             b.clf_calificacion clf_calificacion_cor,
             a.clf_codigo_super,
             b.clf_codigo_super clf_codigo_super_cor,
             a.clf_cal_mnemonico,
             b.clf_cal_mnemonico clf_cal_mnemonico_cor,
             'E' externa,
             cae_clf_secuencial,
             cae_clf_secuencial_cor,
             cae_calificacion_interna,
             cae_codigo_super
      FROM calificaciones b,
           calificaciones a,
           calificaciones_especies
      WHERE b.clf_secuencial(+) = cae_clf_secuencial_cor
       AND a.clf_secuencial(+) = cae_clf_secuencial
       AND  cae_ena_mnemonico = P_ESPECIE
       ORDER BY cae_fecha_vigencia DESC;
    c_califica      califica%ROWTYPE;
    v_mensaje_error VARCHAR2(100);
    ERROR           EXCEPTION;
    P_CALIFICACION   VARCHAR2(12);
BEGIN
  BEGIN
    v_mensaje_error    := ' ';
    OPEN califica;
    FETCH califica INTO c_califica;
    IF califica%NOTFOUND THEN
      CLOSE califica;
        P_CALIFICACION := NULL;
    END IF;
    CLOSE califica;
    IF c_califica.cae_clf_secuencial IS NOT NULL OR  c_califica.cae_clf_secuencial_cor IS NOT NULL  THEN
      P_CALIFICACION            := c_califica.clf_calificacion;
    ELSIF c_califica.cae_calificacion_interna IS NOT NULL THEN
      P_CALIFICACION        := c_califica.cae_calificacion_interna;
    ELSE
      P_CALIFICACION :=  NULL;
    END IF;
    EXCEPTION
      WHEN ERROR THEN
       P_CALIFICACION :=  NULL;
      WHEN OTHERS THEN
       P_CALIFICACION :=  NULL;

END;

RETURN P_CALIFICACION;

END OBTIENE_ISIN_REPORTE;


  FUNCTION OBTIENE_COMERCIAL_REPORTE (
  P_NUM_IDEN VARCHAR2,
  P_PER_TID_CODIGO VARCHAR2
  )
    RETURN VARCHAR IS
    RESULTADO   VARCHAR2(12);
BEGIN

 BEGIN

     SELECT PER_NOMBRE_USUARIO
     INTO RESULTADO
      FROM   PERSONAS
      WHERE  PER_NUM_IDEN = P_NUM_IDEN
      AND    PER_TID_CODIGO = P_PER_TID_CODIGO;

      EXCEPTION

      WHEN NO_DATA_FOUND THEN
      RESULTADO := NULL;
 END;
 RETURN RESULTADO;
END OBTIENE_COMERCIAL_REPORTE;


  FUNCTION OBTIENE_ORDEN_REPORTE (
   P_NUMERO_OPE NUMBER,
   P_TIPO_OPE VARCHAR2
  )
    RETURN NUMBER IS
    RESULTADO   NUMBER(8);
BEGIN

 BEGIN
     SELECT DECODE (P_TIPO_OPE, 'C',LIC_OCO_CONSECUTIVO,'V',LIC_OVE_CONSECUTIVO, NULL)
      INTO RESULTADO
      FROM   LIQUIDACIONES_COMERCIAL
      WHERE  LIC_NUMERO_OPERACION = P_NUMERO_OPE-----:NPO3.NPO_NUMERO_OPERACION
      AND    LIC_TIPO_OPERACION = 'C'
      AND    LIC_NIT_1 = '860079174'
      AND    LIC_TIPO_IDENTIFICACION_1 = 'NIT';

      EXCEPTION

      WHEN NO_DATA_FOUND THEN
      RESULTADO := NULL;
 END;
 RETURN RESULTADO;
END OBTIENE_ORDEN_REPORTE;



/*******************************************/
FUNCTION CAL_SAL_SIMULTA_REPOR ( P_PPO_CONSECUTIVO NUMBER ,
                                             P_PPO_PER_NUM_IDEN VARCHAR2,
                                             P_FECHA DATE,
                                             CAMPO VARCHAR2  )
RETURN NUMBER IS
VALOR NUMBER (38);

V_PORTAFOLIO NUMBER(25);
V_PPO_TOTAL_FONDOS NUMBER(25);
V_SIMULTANEAS NUMBER(25);
V_4 NUMBER(25);
V_PPO_TOTAL_POSICION_T1 NUMBER(25);
V_PP_PPO_TOTAL_POSICION_T2 NUMBER(25);
V_PP_PPO_TOTAL_POSICION_T3 NUMBER(25);
V_PP_PPO_TOTAL_POSICION_TN NUMBER(25);
PP_PPO_TOTAL_PORTAFOLIO NUMBER(25);
PP_PPO_TOTAL_POSICION_T1 NUMBER(25);
PP_PPO_TOTAL_POSICION_T2 NUMBER(25);
PP_PPO_TOTAL_POSICION_T3 NUMBER(25);
PP_PPO_TOTAL_POSICION_TN NUMBER(25);
PP_PPO_TOTAL_SIMULTANEAS NUMBER (25);
PP_PPO_TOTAL_FONDEOS_INTERNOS NUMBER (25);


BEGIN

        P_NEGOCIOS_POSICION.CALCULAR_SALDOS_SIMULTANEAS (P_PPO_CONSECUTIVO,V_PORTAFOLIO,V_PPO_TOTAL_FONDOS,V_4,V_SIMULTANEAS,V_PPO_TOTAL_POSICION_T1,V_PP_PPO_TOTAL_POSICION_T2,V_PP_PPO_TOTAL_POSICION_T3,V_PP_PPO_TOTAL_POSICION_TN);---206336
            SELECT SUM (A.PPO_TOTAL_PORTAFOLIO), SUM (A.PPO_TOTAL_POSICION_T1), SUM (A.PPO_TOTAL_POSICION_T2), SUM (A.PPO_TOTAL_POSICION_T3), SUM (PPO_TOTAL_POSICION_TN), SUM (PPO_TOTAL_SIMULTANEAS), SUM (PPO_TOTAL_FONDEOS_INTERNOS)
              INTO  PP_PPO_TOTAL_PORTAFOLIO, PP_PPO_TOTAL_POSICION_T1, PP_PPO_TOTAL_POSICION_T2,PP_PPO_TOTAL_POSICION_T3 , PP_PPO_TOTAL_POSICION_TN ,  PP_PPO_TOTAL_SIMULTANEAS, PP_PPO_TOTAL_FONDEOS_INTERNOS
            FROM  PORTAFOLIOS_POSICION A
            WHERE A.PPO_FECHA >= P_FECHA
                AND  A.PPO_FECHA < P_FECHA + 1
                AND  A.PPO_TIPO = 'POS'
                AND  A.PPO_CONSECUTIVO = P_PPO_CONSECUTIVO
                AND  A.PPO_PER_NUM_IDEN = P_PPO_PER_NUM_IDEN
                AND  A.PPO_PER_TID_CODIGO = 'CC'
            GROUP BY A.PPO_CONSECUTIVO ;
            VALOR := ( ( PP_PPO_TOTAL_PORTAFOLIO + V_PORTAFOLIO )+ (PP_PPO_TOTAL_POSICION_T1+V_PPO_TOTAL_POSICION_T1) + (PP_PPO_TOTAL_POSICION_T2 + V_PP_PPO_TOTAL_POSICION_T2 ) + (PP_PPO_TOTAL_POSICION_T3 + V_PP_PPO_TOTAL_POSICION_T3 )+ (PP_PPO_TOTAL_POSICION_TN +V_PP_PPO_TOTAL_POSICION_TN ));

IF  (CAMPO = 'TOTAL') THEN
 RETURN VALOR;

ELSIF  (CAMPO = 'VALOR') THEN
     VALOR :=  PP_PPO_TOTAL_PORTAFOLIO + V_PORTAFOLIO;
     RETURN VALOR;

ELSIF (CAMPO =  'SIMUL') THEN
    VALOR :=  PP_PPO_TOTAL_SIMULTANEAS +  V_SIMULTANEAS ;
    RETURN VALOR;

ELSIF (CAMPO = 'FONDO') THEN
    VALOR :=  PP_PPO_TOTAL_SIMULTANEAS +  V_PPO_TOTAL_FONDOS ;
    RETURN VALOR;
  ---POSICION_1
  ELSIF (CAMPO = 'POSICION_1') THEN
    VALOR :=  V_PPO_TOTAL_POSICION_T1 +  PP_PPO_TOTAL_POSICION_T1 ;
    RETURN VALOR;
  ELSIF (CAMPO = 'POSICION_2') THEN
    VALOR :=  PP_PPO_TOTAL_POSICION_T2 +  V_PP_PPO_TOTAL_POSICION_T2 ;
    RETURN VALOR;
  ELSIF (CAMPO = 'POSICION_3') THEN
    VALOR :=  PP_PPO_TOTAL_POSICION_T3 +  V_PP_PPO_TOTAL_POSICION_T3 ;
    RETURN VALOR;
    ELSIF (CAMPO = 'POSICION_TN') THEN
    VALOR :=  PP_PPO_TOTAL_POSICION_TN +  V_PP_PPO_TOTAL_POSICION_TN ;
    RETURN VALOR;
END IF;

END CAL_SAL_SIMULTA_REPOR;
/*******************************/
PROCEDURE INSERTAR_CAMBIO_ESTADO
   (P_CEP_PER_NUM_IDEN       CAMBIOS_ESTADOS_POSICION.CEP_PER_NUM_IDEN%TYPE
   ,P_CEP_PER_TID_CODIGO     CAMBIOS_ESTADOS_POSICION.CEP_PER_TID_CODIGO%TYPE
   ,P_CEP_VALOR_ANTERIOR     CAMBIOS_ESTADOS_POSICION.CEP_VALOR_ANTERIOR%TYPE
   ,P_CEP_VALOR_POSTERIOR    CAMBIOS_ESTADOS_POSICION.CEP_VALOR_POSTERIOR%TYPE
   ,P_CEP_DESCRIPCION        CAMBIOS_ESTADOS_POSICION.CEP_DESCRIPCION%TYPE
   ,P_CEP_OFD_CONSECUTIVO    CAMBIOS_ESTADOS_POSICION.CEP_OFD_CONSECUTIVO%TYPE
   ,P_CEP_NPO_CONSECUTIVO    CAMBIOS_ESTADOS_POSICION.CEP_NPO_CONSECUTIVO%TYPE
   ,P_CEP_EXC_CONSECUTIVO    CAMBIOS_ESTADOS_POSICION.CEP_EXC_CONSECUTIVO%TYPE DEFAULT NULL) IS
   SIGUIENTE NUMBER;
   FECHA DATE;
BEGIN
   SELECT CEP_SEQ.NEXTVAL INTO SIGUIENTE FROM DUAL;
   INSERT INTO CAMBIOS_ESTADOS_POSICION
      (CEP_CONSECUTIVO
      ,CEP_FECHA
      ,CEP_PER_NUM_IDEN
      ,CEP_PER_TID_CODIGO
      ,CEP_TERMINAL
      ,CEP_VALOR_ANTERIOR
      ,CEP_VALOR_POSTERIOR
      ,CEP_DESCRIPCION
      ,CEP_OFD_CONSECUTIVO
      ,CEP_NPO_CONSECUTIVO
      ,CEP_EXC_CONSECUTIVO)
   VALUES
      (SIGUIENTE
      ,SYSDATE
      ,P_CEP_PER_NUM_IDEN
      ,P_CEP_PER_TID_CODIGO
      ,NVL(FN_TERMINAL,'AUTOMATICO')
      ,P_CEP_VALOR_ANTERIOR
      ,P_CEP_VALOR_POSTERIOR
      ,P_CEP_DESCRIPCION
      ,P_CEP_OFD_CONSECUTIVO
      ,P_CEP_NPO_CONSECUTIVO
      ,P_CEP_EXC_CONSECUTIVO);
EXCEPTION
   WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20051,SQLERRM);
END INSERTAR_CAMBIO_ESTADO;
/*******************************************/
FUNCTION VALIDAR_HORA_CIERRE
   (P_CON_MNEMONICO   CONSTANTES.CON_MNEMONICO%TYPE)
   RETURN NUMBER IS
   CURSOR C_CONSTANTES IS
      SELECT CON_VALOR_CHAR
      FROM   CONSTANTES
      WHERE  CON_MNEMONICO = P_CON_MNEMONICO;
   CON1   C_CONSTANTES%ROWTYPE;
   HORA VARCHAR2(5);
BEGIN
   OPEN C_CONSTANTES;
   FETCH C_CONSTANTES INTO CON1;
   IF C_CONSTANTES%NOTFOUND THEN
      CLOSE C_CONSTANTES;
      RETURN 2;
   END IF;
   CLOSE C_CONSTANTES;
   SELECT TO_CHAR(SYSDATE,'HH24:MI') INTO HORA FROM DUAL;
   IF HORA >= CON1.CON_VALOR_CHAR THEN
      RETURN 3;
   END IF;
   RETURN 1;
EXCEPTION
   WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20052,SQLERRM);
END VALIDAR_HORA_CIERRE;
/*******************************************/
FUNCTION CALCULAR_TASA_FACIAL(P_MODALIDAD_TASA    PORTAFOLIOS_POSICION.PPO_MODALIDAD_TASA%TYPE
                             ,P_FECHA_EMISION     PORTAFOLIOS_POSICION.PPO_FECHA_EMISION%TYPE
                             ,P_FECHA_VENCIMIENTO PORTAFOLIOS_POSICION.PPO_FECHA_VENCIMIENTO%TYPE
                             ,P_BASE_CALCULO      PORTAFOLIOS_POSICION.PPO_BASE_CALCULO%TYPE
                             ,P_TASA_EFECTIVA     PORTAFOLIOS_POSICION.PPO_TASA_EFECTIVA%TYPE
                             ,P_REDONDEO          NUMBER)
RETURN NUMBER IS
   DIAS        NUMBER;
   TASA_FACIAL NUMBER;
BEGIN
   IF P_MODALIDAD_TASA = 'V' THEN
      IF P_BASE_CALCULO = 360 THEN
         DIAS := P_FINANCIERO.DIAS360(P_FECHA_VENCIMIENTO,P_FECHA_EMISION);
      ELSIF P_BASE_CALCULO = 365 THEN
         DIAS := P_FINANCIERO.DIAS_365(P_FECHA_EMISION,P_FECHA_VENCIMIENTO);
      ELSIF P_BASE_CALCULO = 366 THEN
         DIAS := P_FECHA_VENCIMIENTO - P_FECHA_EMISION;
      END IF;
      TASA_FACIAL := ((POWER(1 + P_TASA_EFECTIVA/100,DIAS/P_BASE_CALCULO) - 1 ) * P_BASE_CALCULO/DIAS) * 100 ;
      IF P_REDONDEO = 1 THEN
         TASA_FACIAL := ROUND(TASA_FACIAL,1);
      ELSIF P_REDONDEO = 2 THEN
         TASA_FACIAL := ROUND(TASA_FACIAL,2);
      ELSIF P_REDONDEO = 3 THEN
         TASA_FACIAL := ROUND(TASA_FACIAL,3);
      ELSIF P_REDONDEO = 4 THEN
         TASA_FACIAL := ROUND(TASA_FACIAL,4);
      ELSIF P_REDONDEO = 5 THEN
         TASA_FACIAL := ROUND(TASA_FACIAL,5);
      END IF;
   ELSE
      TASA_FACIAL := P_TASA_EFECTIVA;
   END IF;
   RETURN TASA_FACIAL;
END CALCULAR_TASA_FACIAL;
/*******************************************/
FUNCTION CALCULAR_NOMINAL(P_TASA_FACIAL_EMI       PORTAFOLIOS_POSICION.PPO_TASA_FACIAL%TYPE
                         ,P_TASA_EFECTIVA_CLI     OFERTAS_DEMANDAS_POSICION.OFD_TASA%TYPE
                         ,P_PPO_PERIODICIDAD_TASA PORTAFOLIOS_POSICION.PPO_PERIODICIDAD_TASA%TYPE
                         ,P_PPO_BASE_CALCULO      PORTAFOLIOS_POSICION.PPO_BASE_CALCULO%TYPE
                         ,P_OFD_MONTO_PESOS       OFERTAS_DEMANDAS_POSICION.OFD_MONTO_PESOS%TYPE)
   RETURN NUMBER IS
   VFE     NUMBER;
   VPC     NUMBER;
   PRECIO  NUMBER;
   NOMINAL NUMBER;
BEGIN
     VFE := (1 + (P_TASA_FACIAL_EMI/100) * P_PPO_PERIODICIDAD_TASA/P_PPO_BASE_CALCULO) * 100;
     PRECIO := P_OFD_MONTO_PESOS / (VFE /POWER(1 + P_TASA_EFECTIVA_CLI/100,P_PPO_PERIODICIDAD_TASA/P_PPO_BASE_CALCULO)/100 * P_OFD_MONTO_PESOS) * 100;
     NOMINAL := (PRECIO / 100) * P_OFD_MONTO_PESOS;
     -- Estas instrucciones se adicionaron porque el precio en bolsa esta redeondeado a 3 decimales
     -- y genera diferencia en los nominales */
     PRECIO := ROUND((P_OFD_MONTO_PESOS / ROUND(NOMINAL,0)) * 100,3);
     NOMINAL := ROUND(P_OFD_MONTO_PESOS / (PRECIO / 100),0);
   RETURN NOMINAL;
END CALCULAR_NOMINAL;
/*******************************************/
FUNCTION PORCENTAJE_COMISION(P_NPO_CONSECUTIVO       NEGOCIOS_POSICION.NPO_CONSECUTIVO%TYPE
                            ,P_TASA_EFECTIVA_EMI     PORTAFOLIOS_POSICION.PPO_TASA_EFECTIVA%TYPE
                            ,P_PPO_PERIODICIDAD_TASA PORTAFOLIOS_POSICION.PPO_PERIODICIDAD_TASA%TYPE
                            ,P_PPO_BASE_CALCULO      PORTAFOLIOS_POSICION.PPO_BASE_CALCULO%TYPE
                            ,P_TASA                  OFERTAS_DEMANDAS_POSICION.OFD_TASA%TYPE)
   RETURN NUMBER IS
   CURSOR C_TASA_CLIENTE IS
      SELECT OFD_TASA
      FROM   OFERTAS_DEMANDAS_POSICION
      WHERE  OFD_NPO_CONSECUTIVO = P_NPO_CONSECUTIVO
      AND    OFD_ESTADO != 'ANU';
   OFD1   C_TASA_CLIENTE%ROWTYPE;
   CURSOR C_EMISOR IS
      SELECT EMI_NUMERO_IDENTIFICACION
      FROM   EMISORES
            ,ESPECIES_NACIONALES
            ,NEGOCIOS_POSICION
      WHERE  EMI_MNEMONICO = ENA_EMI_MNEMONICO
      AND    ENA_MNEMONICO = NPO_ENA_MNEMONICO
      AND    NPO_CONSECUTIVO = P_NPO_CONSECUTIVO;
   EMI1   C_EMISOR%ROWTYPE;
   VFC    NUMBER;
   VPE    NUMBER;
   VPC    NUMBER;
   TASA   NUMBER;
BEGIN
   IF P_TASA IS NOT NULL THEN
      OFD1.OFD_TASA := P_TASA;
   ELSE
      OPEN C_TASA_CLIENTE;
      FETCH C_TASA_CLIENTE INTO OFD1;
      CLOSE C_TASA_CLIENTE;
      OFD1.OFD_TASA := NVL(OFD1.OFD_TASA,0);
   END IF;
   OPEN C_EMISOR;
   FETCH C_EMISOR INTO EMI1;
   CLOSE C_EMISOR;
   IF EMI1.EMI_NUMERO_IDENTIFICACION IN ('800051334','900047981','860032330') THEN -- METODO MALO
      VPE := 100 / POWER((1 + P_TASA_EFECTIVA_EMI/100),P_PPO_PERIODICIDAD_TASA/P_PPO_BASE_CALCULO);
      VPC := 100 / POWER((1 + OFD1.OFD_TASA/100),P_PPO_PERIODICIDAD_TASA/P_PPO_BASE_CALCULO);
      TASA := ROUND(VPC - VPE,3);
   ELSE   -- METODO BUENO
      VFC := 100 * POWER((1 + OFD1.OFD_TASA/100),P_PPO_PERIODICIDAD_TASA/P_PPO_BASE_CALCULO);
      VPE := VFC / POWER((1 + P_TASA_EFECTIVA_EMI/100),P_PPO_PERIODICIDAD_TASA/P_PPO_BASE_CALCULO);
      TASA := ROUND(100 - VPE,3);
   END IF;
   RETURN TASA;
END PORCENTAJE_COMISION;
/*******************************************/
FUNCTION TOTAL_PENDIENTE(P_NOMINAL_OFRECIDO   NEGOCIOS_POSICION.NPO_VALOR_NOMINAL%TYPE
                        ,P_NOMINAL_CAPTADO    NEGOCIOS_POSICION.NPO_VALOR_NOMINAL%TYPE)
   RETURN NUMBER IS
BEGIN
   IF SIGN(NVL(P_NOMINAL_OFRECIDO,0) - NVL(P_NOMINAL_CAPTADO,0)) IN (-1,0) THEN
      RETURN 0;
   ELSE
      RETURN NVL(P_NOMINAL_OFRECIDO,0) - NVL(P_NOMINAL_CAPTADO,0);
   END IF;
END TOTAL_PENDIENTE;
/*******************************************/
PROCEDURE CREAR_NEGOCIO
   (P_ENA_MNEMONICO      NEGOCIOS_POSICION.NPO_ENA_MNEMONICO%TYPE
   ,P_PLAZO              PORTAFOLIOS_POSICION.PPO_PERIODICIDAD_TASA%TYPE
   ,P_TASA               PORTAFOLIOS_POSICION.PPO_TASA_EFECTIVA%TYPE
   ,P_REDONDEO_FACIAL    PORTAFOLIOS_POSICION.PPO_REDONDEO_FACIAL%TYPE
   ,P_VALOR_NOMINAL      NEGOCIOS_POSICION.NPO_VALOR_NOMINAL%TYPE
   ,P_MONTO_MINIMO       NEGOCIOS_POSICION.NPO_MONTO_MINIMO%TYPE
   ,P_PER_NUM_IDEN       PERSONAS.PER_NUM_IDEN%TYPE
   ,P_PER_TID_CODIGO     PERSONAS.PER_TID_CODIGO%TYPE
   ,P_TIPO_PRIMARIO      NEGOCIOS_POSICION.NPO_TIPO_PRIMARIO%TYPE
   ,P_BASE_CALCULO       PORTAFOLIOS_POSICION.PPO_BASE_CALCULO%TYPE) IS
   CURSOR C_NEGOCIOS(P_ENA_MNEMONICO    NEGOCIOS_POSICION.NPO_ENA_MNEMONICO%TYPE
                    ,P_PLAZO            PORTAFOLIOS_POSICION.PPO_PERIODICIDAD_TASA%TYPE) IS
      SELECT 'X'
      FROM   NEGOCIOS_POSICION
            ,PORTAFOLIOS_POSICION
      WHERE  NPO_PPO_CONSECUTIVO = PPO_CONSECUTIVO
      AND    NPO_ESTADO != 'ANU'
      AND    NPO_FECHA >= TRUNC(SYSDATE)
      AND    NPO_FECHA < TRUNC(SYSDATE + 1)
      AND    NPO_TIPO_PRIMARIO = P_TIPO_PRIMARIO
      AND    PPO_ENA_MNEMONICO = P_ENA_MNEMONICO
      AND    PPO_PERIODICIDAD_TASA = P_PLAZO;
   SIGUIENTE     NUMBER;
   SIGUIENTE1    NUMBER;
   COND1         VARCHAR2(1);
   FECHA_FIN     DATE;
   DIAS          NUMBER;
   TASA_FACIAL   NUMBER;
   TASA_EFECTIVA NUMBER;
BEGIN
   IF P_TIPO_PRIMARIO IS NULL THEN
      RAISE_APPLICATION_ERROR(-20053,'Debe indicar si el nemotecnico ' || P_ENA_MNEMONICO || ' para el plazo '
         || TO_CHAR(P_PLAZO) || ' es por Margen o Comisiżn. Verifique el plano');
   END IF;
   IF P_BASE_CALCULO = 360 THEN
      FECHA_FIN := P_FINANCIERO.SUMAR360(TRUNC(SYSDATE),P_PLAZO);
      --FECHA_FIN := P_SALDOS_CLIENTES.F_FECHA_HABIL(FECHA_FIN);
      DIAS := P_FINANCIERO.DIAS360(FECHA_FIN
                                  ,TRUNC(SYSDATE));
   ELSIF P_BASE_CALCULO = 365 THEN
      FECHA_FIN := P_FINANCIERO.SUMAR365(TRUNC(SYSDATE),P_PLAZO);
      FECHA_FIN := P_SALDOS_CLIENTES.F_FECHA_HABIL(FECHA_FIN);
      DIAS := P_FINANCIERO.DIAS_365(TRUNC(SYSDATE)
                                  ,FECHA_FIN);
   ELSIF P_BASE_CALCULO = 366 THEN
      SELECT TRUNC(SYSDATE) + P_PLAZO INTO FECHA_FIN FROM DUAL;
      FECHA_FIN := P_SALDOS_CLIENTES.F_FECHA_HABIL(FECHA_FIN);
      SELECT FECHA_FIN - TRUNC(SYSDATE) INTO DIAS FROM DUAL;
   END IF;
   TASA_EFECTIVA := P_TASA * 100;
   OPEN C_NEGOCIOS(P_ENA_MNEMONICO
                  ,DIAS);
   FETCH C_NEGOCIOS INTO COND1 ;
   IF C_NEGOCIOS%NOTFOUND THEN
      IF P_BASE_CALCULO = 365 THEN
         TASA_FACIAL := (P_FINANCIERO.NOMINAL
                          (MODALIDAD   => 'V'
                          ,DIAS        => DIAS
                          ,TASAE       => TASA_EFECTIVA/100
                          ,BASECALCULO => 365)) * 100;
      ELSIF P_BASE_CALCULO = 360 THEN
         TASA_FACIAL := (P_FINANCIERO.NOMINAL
                          (MODALIDAD   => 'V'
                          ,DIAS        => DIAS
                          ,TASAE       => TASA_EFECTIVA/100
                          ,BASECALCULO => 360)) * 100;
      END IF;

      IF P_REDONDEO_FACIAL = 1 THEN
         TASA_FACIAL := ROUND(TASA_FACIAL,1);
      ELSIF P_REDONDEO_FACIAL = 2 THEN
         TASA_FACIAL := ROUND(TASA_FACIAL,2);
      ELSIF P_REDONDEO_FACIAL = 3 THEN
         TASA_FACIAL := ROUND(TASA_FACIAL,3);
      ELSIF P_REDONDEO_FACIAL = 4 THEN
         TASA_FACIAL := ROUND(TASA_FACIAL,4);
      ELSIF P_REDONDEO_FACIAL = 5 THEN
         TASA_FACIAL := ROUND(TASA_FACIAL,5);
      END IF;
      SELECT PPO_SEQ.NEXTVAL INTO SIGUIENTE FROM DUAL;
      INSERT INTO PORTAFOLIOS_POSICION
         (PPO_CONSECUTIVO
         ,PPO_FECHA
         ,PPO_ENA_MNEMONICO
         ,PPO_TOTAL_PORTAFOLIO
         ,PPO_TIPO
         ,PPO_BMO_MNEMONICO
         ,PPO_FECHA_EMISION
         ,PPO_FECHA_VENCIMIENTO
         ,PPO_PERIODICIDAD_TASA
         ,PPO_BASE_CALCULO
         ,PPO_MODALIDAD_TASA
         ,PPO_TASA_FACIAL
         ,PPO_TASA_EFECTIVA
         ,PPO_CODIGO_PERIODO
         ,PPO_REDONDEO_FACIAL
         ,PPO_PER_NUM_IDEN
         ,PPO_PER_TID_CODIGO)
      VALUES
         (SIGUIENTE
         ,SYSDATE
         ,P_ENA_MNEMONICO
         ,P_VALOR_NOMINAL
         ,'PRI'
         ,'PESOS'
         ,TRUNC(SYSDATE)
         ,FECHA_FIN
         ,DIAS
         ,P_BASE_CALCULO
         ,'V'
         ,TASA_FACIAL
         ,TASA_EFECTIVA
         ,'PV'
         ,P_REDONDEO_FACIAL
         ,P_PER_NUM_IDEN
         ,P_PER_TID_CODIGO);
      SELECT NPO_SEQ.NEXTVAL INTO SIGUIENTE1 FROM DUAL;
      INSERT INTO NEGOCIOS_POSICION
         (NPO_CONSECUTIVO
         ,NPO_FECHA
         ,NPO_TIPO_NEGOCIO
         ,NPO_ESTADO
         ,NPO_ENA_MNEMONICO
         ,NPO_TIPO_OPERACION
         ,NPO_CLASE_OPERACION
         ,NPO_VALOR_NOMINAL
         ,NPO_MONTO_MINIMO
         ,NPO_DEPOSITO
         ,NPO_TIPO_RANGO
         ,NPO_PPO_CONSECUTIVO
         ,NPO_TIPO_PRIMARIO
         ,NPO_VALOR_EXCESO)
      VALUES
         (SIGUIENTE1
         ,SYSDATE
         ,'DIS'
         ,'EOP'
         ,P_ENA_MNEMONICO
         ,'V'
         ,'CON'
         ,DECODE(P_TIPO_PRIMARIO,'R',0,P_VALOR_NOMINAL)
         ,P_MONTO_MINIMO
         ,'DCVAL'
         ,'RM'
         ,SIGUIENTE
         ,P_TIPO_PRIMARIO
         ,DECODE(P_TIPO_PRIMARIO,'R',NVL(P_VALOR_NOMINAL,0),0));
      P_NEGOCIOS_POSICION.INSERTAR_CAMBIO_ESTADO
         (P_CEP_PER_NUM_IDEN       => P_PER_NUM_IDEN
         ,P_CEP_PER_TID_CODIGO     => P_PER_TID_CODIGO
         ,P_CEP_VALOR_ANTERIOR     => NULL
         ,P_CEP_VALOR_POSTERIOR    => 'EOP'
         ,P_CEP_DESCRIPCION        => NULL
         ,P_CEP_OFD_CONSECUTIVO    => NULL
         ,P_CEP_NPO_CONSECUTIVO    => SIGUIENTE1);
   END IF;
   CLOSE C_NEGOCIOS;
EXCEPTION
   WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20054,SQLERRM);
END CREAR_NEGOCIO;
/*****************************************************/
PROCEDURE CREAR_PREORDEN_FONDOS
   (P_FONDO                   PREORDENES_FONDOS.PRF_FON_CODIGO%TYPE
   ,P_CONSECUTIVO      IN OUT PREORDENES_FONDOS.PRF_CONSECUTIVO%TYPE
   ,P_ENA_MNEMONICO           PREORDENES_FONDOS.PRF_ENA_MNEMONICO%TYPE
   ,P_FECHA_OPERACION         PREORDENES_FONDOS.PRF_FECHA_OPERACION%TYPE
   ,P_EOF_CODIGO              PREORDENES_FONDOS.PRF_EOF_CODIGO%TYPE
   ,P_TIPO_NEGOCIO            PREORDENES_FONDOS.PRF_TIPO_NEGOCIO%TYPE
   ,P_TIPO                    PREORDENES_FONDOS.PRF_TIPO%TYPE
   ,P_TITULO_EXTERIOR         PREORDENES_FONDOS.PRF_TITULO_EXTERIOR%TYPE
   ,P_VALOR_NOMINAL           PREORDENES_FONDOS.PRF_VALOR_NOMINAL%TYPE
   ,P_CANTIDAD                PREORDENES_FONDOS.PRF_CANTIDAD%TYPE
   ,P_NETEO                   PREORDENES_FONDOS.PRF_NETEO%TYPE
   ,P_FECHA_EMISION           PREORDENES_FONDOS.PRF_FECHA_EMISION%TYPE
   ,P_FECHA_VENCIMIENTO       PREORDENES_FONDOS.PRF_FECHA_VENCIMIENTO%TYPE
   ,P_BMO_MNEMONICO           PREORDENES_FONDOS.PRF_BMO_MNEMONICO%TYPE
   ,P_PERIODICIDAD_TASA       PREORDENES_FONDOS.PRF_PERIODICIDAD_TASA%TYPE
   ,P_MODALIDAD_TASA          PREORDENES_FONDOS.PRF_MODALIDAD_TASA%TYPE
   ,P_BASE_CALCULO            PREORDENES_FONDOS.PRF_BASE_CALCULO%TYPE
   ,P_TASA_FACIAL             PREORDENES_FONDOS.PRF_TASA_FACIAL%TYPE
   ,P_AMORTIZABLE             PREORDENES_FONDOS.PRF_AMORTIZABLE%TYPE
   ,P_TRE_MNEMONICO           PREORDENES_FONDOS.PRF_TRE_MNEMONICO%TYPE
   ,P_CAPITALIZABLE           PREORDENES_FONDOS.PRF_CAPITALIZABLE%TYPE
   ,P_FECHA_PRIMER_FLUJO      PREORDENES_FONDOS.PRF_FECHA_PRIMER_FLUJO%TYPE
   ,P_TIPO_PAGO_FLUJO         PREORDENES_FONDOS.PRF_TIPO_PAGO_FLUJO%TYPE
   ,P_PUNTOS_ADICIONALES      PREORDENES_FONDOS.PRF_PUNTOS_ADICIONALES%TYPE
   ,P_CODIGO_PERIODO          PREORDENES_FONDOS.PRF_CODIGO_PERIODO%TYPE
   ,P_PER_NUM_IDEN            PORTAFOLIOS_POSICION.PPO_PER_NUM_IDEN%TYPE
   ,P_PER_TID_CODIGO          PORTAFOLIOS_POSICION.PPO_PER_TID_CODIGO%TYPE
   ,P_FECHA_NEGOCIACION_YANKEE    PREORDENES_FONDOS.PRF_FECHA_NEGOCIACION_YANKEE%TYPE  DEFAULT NULL--NUEVO
   ,P_CBE_BEX_MNEMONICO           PREORDENES_FONDOS.PRF_CBE_BEX_MNEMONICO%TYPE DEFAULT NULL --NUEVO
   ,P_CBE_NUMERO_CUENTA           PREORDENES_FONDOS.PRF_CBE_NUMERO_CUENTA%TYPE DEFAULT NULL--NUEVO
   ,P_CNE_MNEMONICO           PREORDENES_FONDOS.PRF_CNE_MNEMONICO%TYPE DEFAULT NULL
   ,P_POSICION_CTTO           PREORDENES_FONDOS.PRF_POSICION_CTTO%TYPE DEFAULT NULL
   ,P_FECHA_OPERACION_FINAL   PREORDENES_FONDOS.PRF_FECHA_OPERACION_FINAL%TYPE DEFAULT NULL
 ) IS
   CURSOR C_CONSECUTIVO IS
      SELECT MAX(PRF_CONSECUTIVO) SIGUIENTE
      FROM   PREORDENES_FONDOS
      WHERE  PRF_FON_CODIGO = P_FONDO;
   CONSECUTIVO   NUMBER;
BEGIN
   OPEN C_CONSECUTIVO;
   FETCH C_CONSECUTIVO INTO P_CONSECUTIVO;
   CLOSE C_CONSECUTIVO;
   P_CONSECUTIVO := NVL(P_CONSECUTIVO,0) + 1;
   INSERT INTO PREORDENES_FONDOS
      (PRF_CONSECUTIVO
      ,PRF_FON_CODIGO
      ,PRF_EOF_CODIGO
      ,PRF_ENA_MNEMONICO
      ,PRF_FECHA_OPERACION
      ,PRF_TIPO_NEGOCIO
      ,PRF_TIPO
      ,PRF_TITULO_EXTERIOR
      ,PRF_VALOR_NOMINAL
      ,PRF_CANTIDAD
      ,PRF_NETEO
      ,PRF_FECHA_EMISION
      ,PRF_FECHA_VENCIMIENTO
      ,PRF_BMO_MNEMONICO
      ,PRF_PERIODICIDAD_TASA
      ,PRF_MODALIDAD_TASA
      ,PRF_BASE_CALCULO
      ,PRF_TASA_FACIAL
      ,PRF_AMORTIZABLE
      ,PRF_TRE_MNEMONICO
      ,PRF_CAPITALIZABLE
      ,PRF_FECHA_PRIMER_FLUJO
      ,PRF_TIPO_PAGO_FLUJO
      ,PRF_PUNTOS_ADICIONALES
      ,PRF_CODIGO_PERIODO
      ,PRF_PER_NUM_IDEN
      ,PRF_PER_TID_CODIGO
      ,PRF_FECHA_NEGOCIACION_YANKEE
      ,PRF_CBE_BEX_MNEMONICO
      ,PRF_CBE_NUMERO_CUENTA
      ,PRF_CNE_MNEMONICO
      ,PRF_POSICION_CTTO
      ,PRF_FECHA_OPERACION_FINAL)
   VALUES
      (P_CONSECUTIVO
      ,P_FONDO
      ,P_EOF_CODIGO
      ,P_ENA_MNEMONICO
      ,P_FECHA_OPERACION
      ,P_TIPO_NEGOCIO
      ,P_TIPO
      ,P_TITULO_EXTERIOR
      ,P_VALOR_NOMINAL
      ,P_CANTIDAD
      ,P_NETEO
      ,P_FECHA_EMISION
      ,P_FECHA_VENCIMIENTO
      ,P_BMO_MNEMONICO
      ,P_PERIODICIDAD_TASA
      ,P_MODALIDAD_TASA
      ,P_BASE_CALCULO
      ,P_TASA_FACIAL
      ,P_AMORTIZABLE
      ,P_TRE_MNEMONICO
      ,P_CAPITALIZABLE
      ,P_FECHA_PRIMER_FLUJO
      ,P_TIPO_PAGO_FLUJO
      ,P_PUNTOS_ADICIONALES
      ,P_CODIGO_PERIODO
      ,P_PER_NUM_IDEN
      ,P_PER_TID_CODIGO
      ,P_FECHA_NEGOCIACION_YANKEE
      ,P_CBE_BEX_MNEMONICO
      ,P_CBE_NUMERO_CUENTA
      ,P_CNE_MNEMONICO
      ,P_POSICION_CTTO
      ,P_FECHA_OPERACION_FINAL);
END CREAR_PREORDEN_FONDOS;
/**********************************************************/
PROCEDURE CREAR_PREORDEN_COMPRA
   (P_FONDO                       PREORDENES_COMPRA.PRC_PRF_FON_CODIGO%TYPE
   ,P_PRF_CONSECUTIVO             PREORDENES_COMPRA.PRC_PRF_CONSECUTIVO%TYPE
   ,P_CLI_PER_NUM_IDEN            PREORDENES_COMPRA.PRC_CLI_PER_NUM_IDEN%TYPE
   ,P_CLI_PER_TID_CODIGO          PREORDENES_COMPRA.PRC_CLI_PER_TID_CODIGO%TYPE
   ,P_PER_NUM_IDEN                PREORDENES_COMPRA.PRC_PER_NUM_IDEN%TYPE
   ,P_PER_TID_CODIGO              PREORDENES_COMPRA.PRC_PER_TID_CODIGO%TYPE
   ,P_LTI_MNEMONICO               PREORDENES_COMPRA.PRC_LTI_MNEMONICO%TYPE
   ,P_MONTO                       PREORDENES_COMPRA.PRC_MONTO%TYPE
   ,P_VALOR_NOMINAL               PREORDENES_COMPRA.PRC_VALOR_NOMINAL%TYPE
   ,P_PORCENTAJE_CLIENTE          PREORDENES_COMPRA.PRC_PORCENTAJE_CLIENTE%TYPE
   ,P_COMPROMISO_VENTA_FUTURA     PREORDENES_COMPRA.PRC_COMPROMISO_VENTA_FUTURA%TYPE
   ,P_PER_NUM_IDEN_ES_MODIFICADA  PREORDENES_COMPRA.PRC_PER_NUM_IDEN_ES_MODIFICADA%TYPE
   ,P_PER_TID_CODIGO_ES_MODIFICA  PREORDENES_COMPRA.PRC_PER_TID_CODIGO_ES_MODIFICA%TYPE
   ,P_FECHA_MODIFICACION          PREORDENES_COMPRA.PRC_FECHA_MODIFICACION%TYPE
   ,P_FECHA_CUMPLIMIENTO          PREORDENES_COMPRA.PRC_FECHA_CUMPLIMIENTO%TYPE
   ,P_NUMERO_OPERACION            PREORDENES_COMPRA.PRC_NUMERO_OPERACION%TYPE
   ,P_CNE_MNEMONICO               PREORDENES_COMPRA.PRC_CNE_MNEMONICO%TYPE
   ,P_MERCADO                     PREORDENES_COMPRA.PRC_MERCADO%TYPE
   ,P_BOL_MNEMONICO               PREORDENES_COMPRA.PRC_BOL_MNEMONICO%TYPE
   ,P_PER_NUM_IDEN_CONTRAPARTE    PREORDENES_COMPRA.PRC_PER_NUM_IDEN_CONTRAPARTE%TYPE
   ,P_PER_TID_CODIGO_CONTRAPARTE  PREORDENES_COMPRA.PRC_PER_TID_CODIGO_CONTRAPARTE%TYPE
   ,P_CCO_MNEMONICO               PREORDENES_COMPRA.PRC_CCO_MNEMONICO%TYPE
   ,P_MONTO_PESOS                 PREORDENES_COMPRA.PRC_MONTO_PESOS%TYPE
   ,P_NPO_CONSECUTIVO             PREORDENES_COMPRA.PRC_NPO_CONSECUTIVO%TYPE
   ,P_OFD_CONSECUTIVO             PREORDENES_COMPRA.PRC_OFD_CONSECUTIVO%TYPE
   ,P_LIC_NUMERO_FRACCION         PREORDENES_COMPRA.PRC_LIC_NUMERO_FRACCION%TYPE
   ,P_LIC_TIPO_OPERACION          PREORDENES_COMPRA.PRC_LIC_TIPO_OPERACION%TYPE
   ,P_MONTO_DOLARES               PREORDENES_COMPRA.PRC_MONTO_DOLARES%TYPE DEFAULT NULL  ---  NUEVO
   ,P_FECHA_VENTA_FUTURA          PREORDENES_COMPRA.PRC_FECHA_VENTA_FUTURA%TYPE DEFAULT NULL  --- NUEVO
   ,P_TASA_FUTURA                 PREORDENES_COMPRA.PRC_TASA_FUTURA%TYPE DEFAULT NULL  ---  NUEVO
   ,P_BASE_CALCULO_FUTURA         PREORDENES_COMPRA.PRC_BASE_CALCULO_FUTURA%TYPE DEFAULT NULL  --- NUEVO
   ,P_VALOR_FUTURO                PREORDENES_COMPRA.PRC_VALOR_FUTURO%TYPE DEFAULT NULL  --- NUEVO
   ,P_PRC_PRV_PRF_CONSECUTIVO     PREORDENES_COMPRA.PRC_PRV_PRF_CONSECUTIVO%TYPE DEFAULT NULL  --- NUEVO
   ,P_PRC_PRV_CONSECUTIVO         PREORDENES_COMPRA.PRC_PRV_CONSECUTIVO%TYPE DEFAULT NULL
   ,P_PRC_CCC_NUMERO_CUENTA       PREORDENES_COMPRA.PRC_CCC_NUMERO_CUENTA%TYPE DEFAULT NULL
   ,P_PRC_CONTRAPARTIDA           PREORDENES_COMPRA.PRC_CONTRAPARTIDA%TYPE DEFAULT NULL
   ,P_PRC_CONSECUTIVO             IN OUT PREORDENES_COMPRA.PRC_CONSECUTIVO%TYPE)  ---   NUEVO
   IS
   CURSOR C_SIGUIENTE_C IS
      SELECT MAX(PRC_CONSECUTIVO)
      FROM   PREORDENES_COMPRA
      WHERE  PRC_PRF_FON_CODIGO = P_FONDO
      AND    PRC_PRF_CONSECUTIVO = P_PRF_CONSECUTIVO;
   SIGUIENTE_C   NUMBER;
   CURSOR C_ORDENANTE IS
      SELECT SUBSTR(PER3.PER_PRIMER_APELLIDO||' '||
                    PER3.PER_SEGUNDO_APELLIDO||' '||
                    PER3.PER_NOMBRE,1,40) CONTACTO
      FROM   PERSONAS_RELACIONADAS RLC1
            ,PERSONAS PER3
      WHERE  RLC1.RLC_CLI_PER_NUM_IDEN = P_CLI_PER_NUM_IDEN
      AND    RLC1.RLC_CLI_PER_TID_CODIGO = P_CLI_PER_TID_CODIGO
      AND    RLC1.RLC_ROL_CODIGO = 1 /* ordenante */
      AND    RLC1.RLC_ESTADO = 'A' /* Activo */
      AND    PER3.PER_NUM_IDEN = RLC1.RLC_PER_NUM_IDEN
      AND    PER3.PER_TID_CODIGO = RLC1.RLC_PER_TID_CODIGO;
   PER1   C_ORDENANTE%ROWTYPE;
   CURSOR C_ENVIO IS
      SELECT CLI_TEC_MNEMONICO
            ,CLI_TELEFONO_RESIDENCIA
            ,CLI_TELEFONO_OFICINA
            ,PER_TIPO
      FROM   CLIENTES
            ,PERSONAS
      WHERE  CLI_PER_NUM_IDEN = PER_NUM_IDEN
      AND    CLI_PER_TID_CODIGO = PER_TID_CODIGO
      AND    PER_NUM_IDEN = P_CLI_PER_NUM_IDEN
      AND    PER_TID_CODIGO = P_CLI_PER_TID_CODIGO;
   TEC1   C_ENVIO%ROWTYPE;
BEGIN
   OPEN C_SIGUIENTE_C;
   FETCH C_SIGUIENTE_C INTO SIGUIENTE_C;
   CLOSE C_SIGUIENTE_C;
   SIGUIENTE_C := NVL(SIGUIENTE_C,0) + 1;
   P_PRC_CONSECUTIVO := SIGUIENTE_C;
   OPEN C_ORDENANTE;
   FETCH C_ORDENANTE INTO PER1.CONTACTO;
   CLOSE C_ORDENANTE;
   OPEN C_ENVIO;
   FETCH C_ENVIO INTO TEC1;
   CLOSE C_ENVIO;
   INSERT INTO PREORDENES_COMPRA
      (PRC_PRF_CONSECUTIVO
      ,PRC_PRF_FON_CODIGO
      ,PRC_CONSECUTIVO
      ,PRC_CLI_PER_NUM_IDEN
      ,PRC_CLI_PER_TID_CODIGO
      ,PRC_CONTACTO_VENDEDOR
      ,PRC_TELEFONO
      ,PRC_PER_NUM_IDEN
      ,PRC_PER_TID_CODIGO
      ,PRC_LTI_MNEMONICO
      ,PRC_COP_MNEMONICO
      ,PRC_MONTO
      ,PRC_VALOR_NOMINAL
      ,PRC_PORCENTAJE_CLIENTE
      ,PRC_REPO_ACTIVO
      ,PRC_COMPROMISO_VENTA_FUTURA
      ,PRC_PER_NUM_IDEN_ES_MODIFICADA
      ,PRC_PER_TID_CODIGO_ES_MODIFICA
      ,PRC_FECHA_MODIFICACION
      ,PRC_REGISTRA_CLIENTE
      ,PRC_AUTORIZACION                 /* VALIDAR PARA OTROS NEGOCIOS */
      ,PRC_FECHA_CUMPLIMIENTO
      ,PRC_NUMERO_OPERACION
      ,PRC_CNE_MNEMONICO
      ,PRC_MERCADO
      ,PRC_BOL_MNEMONICO
      ,PRC_BRO_MNEMONICO
      ,PRC_POSICION_ABIERTA
      ,PRC_PER_NUM_IDEN_CONTRAPARTE
      ,PRC_PER_TID_CODIGO_CONTRAPARTE
      ,PRC_CCO_MNEMONICO
      ,PRC_MONTO_PESOS
      ,PRC_NPO_CONSECUTIVO
      ,PRC_OFD_CONSECUTIVO
      ,PRC_LIC_NUMERO_FRACCION
      ,PRC_LIC_TIPO_OPERACION
      ,PRC_MONTO_DOLARES  -- NUEVO
      ,PRC_FECHA_VENTA_FUTURA     -- NUEVO
      ,PRC_TASA_FUTURA            -- NUEVO
      ,PRC_BASE_CALCULO_FUTURA    -- NUEVO
      ,PRC_VALOR_FUTURO           -- NUEVO
      ,PRC_PRV_PRF_CONSECUTIVO    -- NUEVO
      ,PRC_PRV_CONSECUTIVO        -- NUEVO
      ,PRC_CCC_NUMERO_CUENTA
      ,PRC_NUMERO_ACCIONES_REPO
      ,PRC_CONTRAPARTIDA)
   VALUES
      (P_PRF_CONSECUTIVO
      ,P_FONDO
      ,SIGUIENTE_C
      ,P_CLI_PER_NUM_IDEN
      ,P_CLI_PER_TID_CODIGO
      ,PER1.CONTACTO
      ,DECODE(TEC1.CLI_TEC_MNEMONICO,'OFI',TEC1.CLI_TELEFONO_OFICINA
                                    ,'RES',TEC1.CLI_TELEFONO_RESIDENCIA
                                    ,DECODE(TEC1.PER_TIPO,'PNA',TEC1.CLI_TELEFONO_RESIDENCIA
                                                               ,TEC1.CLI_TELEFONO_OFICINA))
      ,P_PER_NUM_IDEN
      ,P_PER_TID_CODIGO
      ,P_LTI_MNEMONICO
      ,DECODE(P_LTI_MNEMONICO,'DA','DCVAL'
                             ,'DV','DCV'
                             ,'EX','EX'
                             ,'CCOMP')
      ,P_MONTO
      ,P_VALOR_NOMINAL
      ,P_PORCENTAJE_CLIENTE
      ,'N'
      ,P_COMPROMISO_VENTA_FUTURA
      ,P_PER_NUM_IDEN_ES_MODIFICADA
      ,P_PER_TID_CODIGO_ES_MODIFICA
      ,P_FECHA_MODIFICACION
      ,'N'
      ,'N'
      ,P_FECHA_CUMPLIMIENTO
      ,P_NUMERO_OPERACION
      ,P_CNE_MNEMONICO
      ,P_MERCADO
      ,P_BOL_MNEMONICO
      ,NULL
      ,'N'
      ,P_PER_NUM_IDEN_CONTRAPARTE
      ,P_PER_TID_CODIGO_CONTRAPARTE
      ,P_CCO_MNEMONICO
      ,P_MONTO_PESOS
      ,P_NPO_CONSECUTIVO
      ,P_OFD_CONSECUTIVO
      ,P_LIC_NUMERO_FRACCION
      ,P_LIC_TIPO_OPERACION
      ,P_MONTO_DOLARES   -- NUEVO
      ,P_FECHA_VENTA_FUTURA     -- NUEVO
      ,P_TASA_FUTURA            -- NUEVO
      ,P_BASE_CALCULO_FUTURA    -- NUEVO
      ,P_VALOR_FUTURO           -- NUEVO
      ,P_PRC_PRV_PRF_CONSECUTIVO    -- NUEVO
      ,P_PRC_PRV_CONSECUTIVO     --NUEVO
      ,P_PRC_CCC_NUMERO_CUENTA
      ,DECODE(P_CNE_MNEMONICO, 'REPO', P_VALOR_NOMINAL, NULL)
      ,P_PRC_CONTRAPARTIDA);
END CREAR_PREORDEN_COMPRA;
/*********************************************************************/
PROCEDURE CREAR_PREORDEN_VENTA
   (P_FONDO                       PREORDENES_VENTA.PRV_PRF_FON_CODIGO%TYPE
   ,P_PRF_CONSECUTIVO             PREORDENES_VENTA.PRV_PRF_CONSECUTIVO%TYPE
   ,P_CLI_PER_NUM_IDEN            PREORDENES_VENTA.PRV_CLI_PER_NUM_IDEN%TYPE
   ,P_CLI_PER_TID_CODIGO          PREORDENES_VENTA.PRV_CLI_PER_TID_CODIGO%TYPE
   ,P_PER_NUM_IDEN                PREORDENES_VENTA.PRV_PER_NUM_IDEN%TYPE
   ,P_PER_TID_CODIGO              PREORDENES_VENTA.PRV_PER_TID_CODIGO%TYPE
   ,P_LTI_MNEMONICO               PREORDENES_VENTA.PRV_LTI_MNEMONICO%TYPE
   ,P_MONTO                       PREORDENES_VENTA.PRV_MONTO%TYPE
   ,P_VALOR_NOMINAL               PREORDENES_VENTA.PRV_VALOR_NOMINAL%TYPE
   ,P_PORCENTAJE_CLIENTE          PREORDENES_VENTA.PRV_PORCENTAJE_CLIENTE%TYPE
   ,P_COMPROMISO_COMPRA_FUTURA    PREORDENES_VENTA.PRV_COMPROMISO_COMPRA_FUTURA%TYPE
   ,P_PER_NUM_IDEN_ES_MODIFICADA  PREORDENES_VENTA.PRV_PER_NUM_IDEN_ES_MODIFICADA%TYPE
   ,P_PER_TID_CODIGO_ES_MODIFICA  PREORDENES_VENTA.PRV_PER_TID_CODIGO_ES_MODIFICA%TYPE
   ,P_FECHA_MODIFICACION          PREORDENES_VENTA.PRV_FECHA_MODIFICACION%TYPE
   ,P_FECHA_CUMPLIMIENTO          PREORDENES_VENTA.PRV_FECHA_CUMPLIMIENTO%TYPE
   ,P_NUMERO_OPERACION            PREORDENES_VENTA.PRV_NUMERO_OPERACION%TYPE
   ,P_CNE_MNEMONICO               PREORDENES_VENTA.PRV_CNE_MNEMONICO%TYPE
   ,P_MERCADO                     PREORDENES_VENTA.PRV_MERCADO%TYPE
   ,P_BOL_MNEMONICO               PREORDENES_VENTA.PRV_BOL_MNEMONICO%TYPE
   ,P_PER_NUM_IDEN_CONTRAPARTE    PREORDENES_VENTA.PRV_PER_NUM_IDEN_CONTRAPARTE%TYPE
   ,P_PER_TID_CODIGO_CONTRAPARTE  PREORDENES_VENTA.PRV_PER_TID_CODIGO_CONTRAPARTE%TYPE
   ,P_CCO_MNEMONICO               PREORDENES_VENTA.PRV_CCO_MNEMONICO%TYPE
   ,P_MONTO_PESOS                 PREORDENES_VENTA.PRV_MONTO_PESOS%TYPE
   ,P_NPO_CONSECUTIVO             PREORDENES_VENTA.PRV_NPO_CONSECUTIVO%TYPE
   ,P_OFD_CONSECUTIVO             PREORDENES_VENTA.PRV_OFD_CONSECUTIVO%TYPE
   ,P_ARBITRAJE                   PREORDENES_VENTA.PRV_ARBITRAJE%TYPE
   ,P_LIC_NUMERO_FRACCION         PREORDENES_VENTA.PRV_LIC_NUMERO_FRACCION%TYPE
   ,P_LIC_TIPO_OPERACION          PREORDENES_VENTA.PRV_LIC_TIPO_OPERACION%TYPE
   ,P_MONTO_DOLARES               PREORDENES_VENTA.PRV_MONTO_DOLARES%TYPE DEFAULT NULL --- NUEVO
   ,P_FECHA_COMPRA_FUTURA         PREORDENES_VENTA.PRV_FECHA_COMPRA_FUTURA%TYPE DEFAULT NULL  --- NUEVO
   ,P_TASA_FUTURA                 PREORDENES_VENTA.PRV_TASA_FUTURA%TYPE DEFAULT NULL  ---  NUEVO
   ,P_BASE_CALCULO_FUTURA         PREORDENES_VENTA.PRV_BASE_CALCULO_FUTURA%TYPE DEFAULT NULL  --- NUEVO
   ,P_VALOR_FUTURO                PREORDENES_VENTA.PRV_VALOR_FUTURO%TYPE DEFAULT NULL  --- NUEVO
   ,P_PRV_PRC_PRF_CONSECUTIVO     PREORDENES_VENTA.PRV_PRC_PRF_CONSECUTIVO%TYPE DEFAULT NULL  --- NUEVO
   ,P_PRV_PRC_CONSECUTIVO         PREORDENES_VENTA.PRV_PRC_CONSECUTIVO%TYPE DEFAULT NULL
   ,P_PRV_CCC_NUMERO_CUENTA       PREORDENES_VENTA.PRV_CCC_NUMERO_CUENTA%TYPE DEFAULT NULL
   ,P_PRV_CONTRAPARTIDA           PREORDENES_VENTA.PRV_CONTRAPARTIDA%TYPE DEFAULT NULL
   ,P_PRV_CONSECUTIVO             IN OUT PREORDENES_VENTA.PRV_CONSECUTIVO%TYPE)  ---   NUEVO
   IS
   CURSOR C_SIGUIENTE_V IS
      SELECT MAX(PRV_CONSECUTIVO)
      FROM   PREORDENES_VENTA
      WHERE  PRV_PRF_FON_CODIGO = P_FONDO
      AND    PRV_PRF_CONSECUTIVO = P_PRF_CONSECUTIVO;
   SIGUIENTE_V   NUMBER;
   CURSOR C_ORDENANTE IS
      SELECT SUBSTR(PER3.PER_PRIMER_APELLIDO||' '||
                    PER3.PER_SEGUNDO_APELLIDO||' '||
                    PER3.PER_NOMBRE,1,40) CONTACTO
      FROM   PERSONAS_RELACIONADAS RLC1
            ,PERSONAS PER3
      WHERE  RLC1.RLC_CLI_PER_NUM_IDEN = P_CLI_PER_NUM_IDEN
      AND    RLC1.RLC_CLI_PER_TID_CODIGO = P_CLI_PER_TID_CODIGO
      AND    RLC1.RLC_ROL_CODIGO = 1 /* ordenante */
      AND    RLC1.RLC_ESTADO = 'A' /* Activo */
      AND    PER3.PER_NUM_IDEN = RLC1.RLC_PER_NUM_IDEN
      AND    PER3.PER_TID_CODIGO = RLC1.RLC_PER_TID_CODIGO;
   PER1   C_ORDENANTE%ROWTYPE;
   CURSOR C_ENVIO IS
      SELECT CLI_TEC_MNEMONICO
            ,CLI_TELEFONO_RESIDENCIA
            ,CLI_TELEFONO_OFICINA
            ,PER_TIPO
      FROM   CLIENTES
            ,PERSONAS
      WHERE  CLI_PER_NUM_IDEN = PER_NUM_IDEN
      AND    CLI_PER_TID_CODIGO = PER_TID_CODIGO
      AND    PER_NUM_IDEN = P_CLI_PER_NUM_IDEN
      AND    PER_TID_CODIGO = P_CLI_PER_TID_CODIGO;
   TEC1   C_ENVIO%ROWTYPE;
BEGIN
   OPEN C_SIGUIENTE_V;
   FETCH C_SIGUIENTE_V INTO SIGUIENTE_V;
   CLOSE C_SIGUIENTE_V;
   SIGUIENTE_V := NVL(SIGUIENTE_V,0) + 1;
   P_PRV_CONSECUTIVO := SIGUIENTE_V;
   OPEN C_ORDENANTE;
   FETCH C_ORDENANTE INTO PER1.CONTACTO;
   CLOSE C_ORDENANTE;
   OPEN C_ENVIO;
   FETCH C_ENVIO INTO TEC1;
   CLOSE C_ENVIO;
   INSERT INTO PREORDENES_VENTA
      (PRV_PRF_CONSECUTIVO
      ,PRV_PRF_FON_CODIGO
      ,PRV_CONSECUTIVO
      ,PRV_CLI_PER_NUM_IDEN
      ,PRV_CLI_PER_TID_CODIGO
      ,PRV_CONTACTO_COMPRADOR
      ,PRV_TELEFONO_CONTACTO
      ,PRV_PER_NUM_IDEN
      ,PRV_PER_TID_CODIGO
      ,PRV_MONTO
      ,PRV_VALOR_NOMINAL
      ,PRV_LTI_MNEMONICO
      ,PRV_COP_MNEMONICO
      ,PRV_PORCENTAJE_CLIENTE
      ,PRV_ENVIA_RECOGE_DOCUMENTOS
      ,PRV_ENVIA_FAX
      ,PRV_REPO_PASIVO
      ,PRV_COMPROMISO_COMPRA_FUTURA
      ,PRV_FECHA_MODIFICACION
      ,PRV_PER_NUM_IDEN_ES_MODIFICADA
      ,PRV_PER_TID_CODIGO_ES_MODIFICA
      ,PRV_REGISTRA_CLIENTE
      ,PRV_AUTORIZACION
      ,PRV_FECHA_CUMPLIMIENTO
      ,PRV_BOL_MNEMONICO
      ,PRV_NUMERO_OPERACION
      ,PRV_MERCADO
      ,PRV_POSICION_ABIERTA
      ,PRV_PER_NUM_IDEN_CONTRAPARTE
      ,PRV_PER_TID_CODIGO_CONTRAPARTE
      ,PRV_CCO_MNEMONICO
      ,PRV_MONTO_PESOS
      ,PRV_CNE_MNEMONICO
      ,PRV_ARBITRAJE
      ,PRV_NPO_CONSECUTIVO
      ,PRV_OFD_CONSECUTIVO
      ,PRV_LIC_NUMERO_FRACCION
      ,PRV_LIC_TIPO_OPERACION
      ,PRV_MONTO_DOLARES  -- NUEVO
      ,PRV_FECHA_COMPRA_FUTURA      -- NUEVO
      ,PRV_TASA_FUTURA             -- NUEVO
      ,PRV_BASE_CALCULO_FUTURA     -- NUEVO
      ,PRV_VALOR_FUTURO            -- NUEVO
      ,PRV_PRC_PRF_CONSECUTIVO     -- NUEVO
      ,PRV_PRC_CONSECUTIVO        -- NUEVO
      ,PRV_CCC_NUMERO_CUENTA
      ,PRV_NUMERO_ACCIONES_REPO
      ,PRV_CONTRAPARTIDA)
   VALUES
      (P_PRF_CONSECUTIVO
      ,P_FONDO
      ,SIGUIENTE_V
      ,P_CLI_PER_NUM_IDEN
      ,P_CLI_PER_TID_CODIGO
      ,PER1.CONTACTO
      ,DECODE(TEC1.CLI_TEC_MNEMONICO,'OFI',TEC1.CLI_TELEFONO_OFICINA
                                    ,'RES',TEC1.CLI_TELEFONO_RESIDENCIA
                                    ,DECODE(TEC1.PER_TIPO,'PNA',TEC1.CLI_TELEFONO_RESIDENCIA
                                                               ,TEC1.CLI_TELEFONO_OFICINA))
      ,P_PER_NUM_IDEN
      ,P_PER_TID_CODIGO
      ,P_MONTO
      ,P_VALOR_NOMINAL
      ,P_LTI_MNEMONICO
      ,DECODE(P_LTI_MNEMONICO,'DA','DCVAL'
                             ,'DV','DCV'
                             ,'EX','EX'
                             ,'CCOMP')
      ,P_PORCENTAJE_CLIENTE
      ,'R'
      ,'N'
      ,'N'
      ,P_COMPROMISO_COMPRA_FUTURA
      ,P_FECHA_MODIFICACION
      ,P_PER_NUM_IDEN_ES_MODIFICADA
      ,P_PER_TID_CODIGO_ES_MODIFICA
      ,'N'
      ,'N'
      ,P_FECHA_CUMPLIMIENTO
      ,P_BOL_MNEMONICO
      ,P_NUMERO_OPERACION
      ,P_MERCADO
      ,'N'
      ,P_PER_NUM_IDEN_CONTRAPARTE
      ,P_PER_TID_CODIGO_CONTRAPARTE
      ,P_CCO_MNEMONICO
      ,P_MONTO_PESOS
      ,P_CNE_MNEMONICO
      ,P_ARBITRAJE
      ,P_NPO_CONSECUTIVO
      ,P_OFD_CONSECUTIVO
      ,P_LIC_NUMERO_FRACCION
      ,P_LIC_TIPO_OPERACION
      ,P_MONTO_DOLARES  --- NUEVO
      ,P_FECHA_COMPRA_FUTURA   --- NUEVO
      ,P_TASA_FUTURA          --- NUEVO
      ,P_BASE_CALCULO_FUTURA         --- NUEVO
      ,P_VALOR_FUTURO                --- NUEVO
      ,P_PRV_PRC_PRF_CONSECUTIVO     --- NUEVO
      ,P_PRV_PRC_CONSECUTIVO    --- NUEVO
      ,P_PRV_CCC_NUMERO_CUENTA
      ,DECODE(P_CNE_MNEMONICO, 'REPO', P_VALOR_NOMINAL, NULL)
      ,P_PRV_CONTRAPARTIDA);
END CREAR_PREORDEN_VENTA;
/**********************************************************/
PROCEDURE EJECUCION_PREORDENES_COMPRA
   (P_PRF_FON_CODIGO           PREORDENES_FONDOS.PRF_FON_CODIGO%TYPE
   ,P_PRF_CONSECUTIVO          PREORDENES_FONDOS.PRF_CONSECUTIVO%TYPE
   ,P_FECHA                    DATE
   ,P_TIPO_OPERACION           VARCHAR2)
   IS
   CURSOR C_PREORDEN_COMPRA IS
      SELECT PRC_CONSECUTIVO
            ,PRF_BMO_MNEMONICO
            ,PRF_TIPO
            ,PRF_ENA_MNEMONICO
            ,PRC_LTI_MNEMONICO
            ,PRC_MONTO
            ,PRF_TRE_MNEMONICO
            ,PRF_FECHA_EMISION
            ,PRF_FECHA_VENCIMIENTO
            ,PRC_VALOR_NOMINAL
            ,PRF_PERIODICIDAD_TASA
            ,PRF_BASE_CALCULO
            ,PRF_MODALIDAD_TASA
            ,PRF_PUNTOS_ADICIONALES
            ,PRF_TASA_FACIAL
            ,PRF_AMORTIZABLE
            ,PRF_TIPO_PAGO_FLUJO
            ,PRF_FECHA_PRIMER_FLUJO
            ,PRF_CAPITALIZABLE
            ,PRC_CNE_MNEMONICO
            ,PRC_MERCADO
            ,PRF_CODIGO_PERIODO
            ,PRF_PER_NUM_IDEN
            ,PRF_PER_TID_CODIGO
            ,PRC_BOL_MNEMONICO
            ,PRC_NUMERO_OPERACION
            ,PRC_LIC_NUMERO_FRACCION
            ,PRC_LIC_TIPO_OPERACION
            ,PRC_PER_NUM_IDEN
            ,PRC_PER_TID_CODIGO
            ,PRC_FECHA_VENTA_FUTURA
            ,PRC_VALOR_FUTURO
            ,PRC_BASE_CALCULO_FUTURA
            ,PRC_FECHA_CUMPLIMIENTO
            ,PRC_NPO_CONSECUTIVO
            ,PRC_OFD_CONSECUTIVO
      FROM   PREORDENES_COMPRA
            ,PREORDENES_FONDOS
      WHERE  PRC_PRF_FON_CODIGO = PRF_FON_CODIGO
      AND    PRC_PRF_CONSECUTIVO = PRF_CONSECUTIVO
      AND    PRF_FON_CODIGO = P_PRF_FON_CODIGO
      AND    PRF_CONSECUTIVO = P_PRF_CONSECUTIVO;
   PRC1   C_PREORDEN_COMPRA%ROWTYPE;
   CURSOR C_COTIZACION_BASE(FECHA  DATE
                           ,BASE   VARCHAR2) IS
      SELECT CBM_VALOR
      FROM   COTIZACIONES_BASE_MONETARIAS
      WHERE  TRUNC(CBM_FECHA) = TRUNC(FECHA)
      AND    CBM_BMO_MNEMONICO = BASE;
   CURSOR C_VENTA_FONDEADA IS
      SELECT PRV_PRF_FON_CODIGO
            ,PRV_PRF_CONSECUTIVO
            ,PRV_CONSECUTIVO
      FROM   PREORDENES_VENTA
      WHERE  PRV_PRF_FON_CODIGO = P_PRF_FON_CODIGO
      AND    PRV_PRC_PRF_CONSECUTIVO = P_PRF_CONSECUTIVO
      AND    PRV_PRC_CONSECUTIVO = PRC1.PRC_CONSECUTIVO;
   PRV1   C_VENTA_FONDEADA%ROWTYPE;
   CURSOR C_OPERACION_INTERNA IS
      SELECT NPO_TIPO_REGISTRO
            ,NPO_TIPO_NEGOCIO
      FROM   NEGOCIOS_POSICION
      WHERE  NPO_CONSECUTIVO = PRC1.PRC_NPO_CONSECUTIVO;
   NPO1   C_OPERACION_INTERNA%ROWTYPE;

   COTIZACION      NUMBER;
   ESTADO          VARCHAR2(5);
   MOVIMIENTO      VARCHAR2(5);
   INSERTA_CVS     VARCHAR2(1);
   CONSECUTIVO_CVS NUMBER;
   P_TFO_CODIGO    TITULOS_FONDOS.TFO_CODIGO%TYPE;
   VALOR_TM        NUMBER;
BEGIN
   OPEN C_PREORDEN_COMPRA;
   FETCH C_PREORDEN_COMPRA INTO PRC1;
   WHILE C_PREORDEN_COMPRA%FOUND LOOP
      IF PRC1.PRF_BMO_MNEMONICO != 'PESOS' THEN
         OPEN C_COTIZACION_BASE(P_FECHA
                               ,PRC1.PRF_BMO_MNEMONICO);
         FETCH C_COTIZACION_BASE INTO COTIZACION;
         IF C_COTIZACION_BASE%NOTFOUND THEN
            CLOSE C_COTIZACION_BASE;
            RAISE_APPLICATION_ERROR(-20056,'Cotizacion Monetaria de ' || PRC1.PRF_BMO_MNEMONICO || ' no encontrada');
         END IF;
         CLOSE C_COTIZACION_BASE;
      ELSE
         COTIZACION := 1;
      END IF;
      OPEN C_OPERACION_INTERNA;
      FETCH C_OPERACION_INTERNA INTO NPO1;
      CLOSE C_OPERACION_INTERNA;
      IF NPO1.NPO_TIPO_REGISTRO = 'INTME' AND
         NPO1.NPO_TIPO_NEGOCIO = 'INT' THEN
         ESTADO := 'VIG';
         MOVIMIENTO := 'CRF';
         INSERTA_CVS := 'S';
      ELSE
         IF P_TIPO_OPERACION = 'DEF' OR
            (P_TIPO_OPERACION = 'POS' AND
             PRC1.PRC_CNE_MNEMONICO = 'CONT') OR
            (P_TIPO_OPERACION = 'POSF' AND
             PRC1.PRC_CNE_MNEMONICO IN ('SIM','CON','PLA')) THEN
             ESTADO := 'VIG';
             MOVIMIENTO := 'CRF';
             INSERTA_CVS := 'S';
         ELSIF P_TIPO_OPERACION = 'POS' AND
            PRC1.PRC_CNE_MNEMONICO = 'SIM' THEN
            ESTADO := 'GAF';
            MOVIMIENTO := 'FAC';
            INSERTA_CVS := 'S';
         ELSIF P_TIPO_OPERACION = 'POS' AND
            PRC1.PRC_CNE_MNEMONICO IN ('CON','PLA') THEN
            ESTADO := 'VIG';
            MOVIMIENTO := 'DCO';
            INSERTA_CVS := 'N';
         END IF;
      END IF;

      P_NEGOCIOS_POSICION.CREAR_TITULO_POSICION
         (P_PRF_FON_CODIGO           => P_PRF_FON_CODIGO
         ,P_PRF_TIPO                 => PRC1.PRF_TIPO
         ,P_PRF_TIPO_NEGOCIO         => 'C'
         ,P_PRF_ENA_MNEMONICO        => PRC1.PRF_ENA_MNEMONICO
         ,P_PRF_BMO_MNEMONICO        => PRC1.PRF_BMO_MNEMONICO
         ,P_PRF_TRE_MNEMONICO        => PRC1.PRF_TRE_MNEMONICO
         ,P_PRF_FECHA_EMISION        => PRC1.PRF_FECHA_EMISION
         ,P_PRF_FECHA_VENCIMIENTO    => PRC1.PRF_FECHA_VENCIMIENTO
         ,P_PRF_PERIODICIDAD_TASA    => PRC1.PRF_PERIODICIDAD_TASA
         ,P_PRF_BASE_CALCULO         => PRC1.PRF_BASE_CALCULO
         ,P_PRF_MODALIDAD_TASA       => PRC1.PRF_MODALIDAD_TASA
         ,P_PRF_PUNTOS_ADICIONALES   => PRC1.PRF_PUNTOS_ADICIONALES
         ,P_PRF_TASA_FACIAL          => PRC1.PRF_TASA_FACIAL
         ,P_PRF_AMORTIZABLE          => PRC1.PRF_AMORTIZABLE
         ,P_PRF_TIPO_PAGO_FLUJO      => PRC1.PRF_TIPO_PAGO_FLUJO
         ,P_PRF_FECHA_PRIMER_FLUJO   => PRC1.PRF_FECHA_PRIMER_FLUJO
         ,P_PRF_CAPITALIZABLE        => PRC1.PRF_CAPITALIZABLE
         ,P_PRF_CODIGO_PERIODO       => PRC1.PRF_CODIGO_PERIODO
         ,P_PRF_CONSECUTIVO          => P_PRF_CONSECUTIVO
         ,P_PRF_PER_NUM_IDEN         => PRC1.PRF_PER_NUM_IDEN
         ,P_PRF_PER_TID_CODIGO       => PRC1.PRF_PER_TID_CODIGO
         ,P_PRC_LTI_MNEMONICO        => PRC1.PRC_LTI_MNEMONICO
         ,P_PRC_MONTO                => PRC1.PRC_MONTO
         ,P_PRC_VALOR_NOMINAL        => PRC1.PRC_VALOR_NOMINAL
         ,P_PRC_CNE_MNEMONICO        => PRC1.PRC_CNE_MNEMONICO
         ,P_PRC_MERCADO              => PRC1.PRC_MERCADO
         ,P_PRC_CONSECUTIVO          => PRC1.PRC_CONSECUTIVO
         ,P_PRC_BOL_MNEMONICO        => PRC1.PRC_BOL_MNEMONICO
         ,P_PRC_NUMERO_OPERACION     => PRC1.PRC_NUMERO_OPERACION
         ,P_PRC_LIC_TIPO_OPERACION   => PRC1.PRC_LIC_TIPO_OPERACION
         ,P_PRC_LIC_NUMERO_FRACCION  => PRC1.PRC_LIC_NUMERO_FRACCION
         ,P_PRC_PER_NUM_IDEN         => PRC1.PRC_PER_NUM_IDEN
         ,P_PRC_PER_TID_CODIGO       => PRC1.PRC_PER_TID_CODIGO
         ,P_PRV_CONSECUTIVO          => NULL
         ,P_FECHA                    => P_FECHA
         ,P_ETI_CODIGO               => ESTADO
         ,P_COTIZACION               => COTIZACION
         ,P_MRF_TMT_MNEMONICO        => MOVIMIENTO
         ,P_INSERTA_CVS              => INSERTA_CVS
         ,P_MVTO_CVS                 => 'CRF'
         ,P_CVS_CONSECUTIVO          => CONSECUTIVO_CVS
         ,P_TFO_CODIGO               => P_TFO_CODIGO
         ,P_TOTAL_TC                 => NULL
         ,P_FECHA_CUMPLIMIENTO       => PRC1.PRC_FECHA_CUMPLIMIENTO
         ,P_VALOR_TM                 => VALOR_TM);

      IF P_TIPO_OPERACION = 'POS' AND
         PRC1.PRC_CNE_MNEMONICO = 'SIM' THEN
         P_NEGOCIOS_POSICION.CREAR_TITULO_POSICION
            (P_PRF_FON_CODIGO           => P_PRF_FON_CODIGO
            ,P_PRF_TIPO                 => PRC1.PRF_TIPO
            ,P_PRF_TIPO_NEGOCIO         => 'C'
            ,P_PRF_ENA_MNEMONICO        => PRC1.PRF_ENA_MNEMONICO
            ,P_PRF_BMO_MNEMONICO        => PRC1.PRF_BMO_MNEMONICO
            ,P_PRF_TRE_MNEMONICO        => PRC1.PRF_TRE_MNEMONICO
            ,P_PRF_FECHA_EMISION        => PRC1.PRF_FECHA_EMISION
            ,P_PRF_FECHA_VENCIMIENTO    => PRC1.PRF_FECHA_VENCIMIENTO
            ,P_PRF_PERIODICIDAD_TASA    => PRC1.PRF_PERIODICIDAD_TASA
            ,P_PRF_BASE_CALCULO         => PRC1.PRF_BASE_CALCULO
            ,P_PRF_MODALIDAD_TASA       => PRC1.PRF_MODALIDAD_TASA
            ,P_PRF_PUNTOS_ADICIONALES   => PRC1.PRF_PUNTOS_ADICIONALES
            ,P_PRF_TASA_FACIAL          => PRC1.PRF_TASA_FACIAL
            ,P_PRF_AMORTIZABLE          => PRC1.PRF_AMORTIZABLE
            ,P_PRF_TIPO_PAGO_FLUJO      => PRC1.PRF_TIPO_PAGO_FLUJO
            ,P_PRF_FECHA_PRIMER_FLUJO   => PRC1.PRF_FECHA_PRIMER_FLUJO
            ,P_PRF_CAPITALIZABLE        => PRC1.PRF_CAPITALIZABLE
            ,P_PRF_CODIGO_PERIODO       => PRC1.PRF_CODIGO_PERIODO
            ,P_PRF_CONSECUTIVO          => P_PRF_CONSECUTIVO
            ,P_PRF_PER_NUM_IDEN         => PRC1.PRF_PER_NUM_IDEN
            ,P_PRF_PER_TID_CODIGO       => PRC1.PRF_PER_TID_CODIGO
            ,P_PRC_LTI_MNEMONICO        => PRC1.PRC_LTI_MNEMONICO
            ,P_PRC_MONTO                => PRC1.PRC_MONTO
            ,P_PRC_VALOR_NOMINAL        => PRC1.PRC_VALOR_NOMINAL
            ,P_PRC_CNE_MNEMONICO        => PRC1.PRC_CNE_MNEMONICO
            ,P_PRC_MERCADO              => PRC1.PRC_MERCADO
            ,P_PRC_CONSECUTIVO          => PRC1.PRC_CONSECUTIVO
            ,P_PRC_BOL_MNEMONICO        => PRC1.PRC_BOL_MNEMONICO
            ,P_PRC_NUMERO_OPERACION     => PRC1.PRC_NUMERO_OPERACION
            ,P_PRC_LIC_TIPO_OPERACION   => PRC1.PRC_LIC_TIPO_OPERACION
            ,P_PRC_LIC_NUMERO_FRACCION  => PRC1.PRC_LIC_NUMERO_FRACCION
            ,P_PRC_PER_NUM_IDEN         => PRC1.PRC_PER_NUM_IDEN
            ,P_PRC_PER_TID_CODIGO       => PRC1.PRC_PER_TID_CODIGO
            ,P_PRV_CONSECUTIVO          => NULL
            ,P_FECHA                    => P_FECHA
            ,P_ETI_CODIGO               => 'TGA'
            ,P_COTIZACION               => COTIZACION
            ,P_MRF_TMT_MNEMONICO        => 'TGA'
            ,P_INSERTA_CVS              => 'N'
            ,P_MVTO_CVS                 => NULL
            ,P_CVS_CONSECUTIVO          => CONSECUTIVO_CVS
            ,P_TFO_CODIGO               => P_TFO_CODIGO
            ,P_TOTAL_TC                 => NULL
            ,P_FECHA_CUMPLIMIENTO       => PRC1.PRC_FECHA_CUMPLIMIENTO
            ,P_VALOR_TM                 => VALOR_TM);

         P_NEGOCIOS_POSICION.CREAR_TITULO_POSICION
            (P_PRF_FON_CODIGO           => P_PRF_FON_CODIGO
            ,P_PRF_TIPO                 => PRC1.PRF_TIPO
            ,P_PRF_TIPO_NEGOCIO         => 'C'
            ,P_PRF_ENA_MNEMONICO        => PRC1.PRF_ENA_MNEMONICO
            ,P_PRF_BMO_MNEMONICO        => 'PESOS'
            ,P_PRF_TRE_MNEMONICO        => NULL
            ,P_PRF_FECHA_EMISION        => P_FECHA
            ,P_PRF_FECHA_VENCIMIENTO    => PRC1.PRC_FECHA_VENTA_FUTURA
            ,P_PRF_PERIODICIDAD_TASA    => 0
            ,P_PRF_BASE_CALCULO         => PRC1.PRC_BASE_CALCULO_FUTURA
            ,P_PRF_MODALIDAD_TASA       => 'D'
            ,P_PRF_PUNTOS_ADICIONALES   => NULL
            ,P_PRF_TASA_FACIAL          => 0
            ,P_PRF_AMORTIZABLE          => NULL
            ,P_PRF_TIPO_PAGO_FLUJO      => NULL
            ,P_PRF_FECHA_PRIMER_FLUJO   => NULL
            ,P_PRF_CAPITALIZABLE        => NULL
            ,P_PRF_CODIGO_PERIODO       => 'D'
            ,P_PRF_CONSECUTIVO          => P_PRF_CONSECUTIVO
            ,P_PRF_PER_NUM_IDEN         => PRC1.PRF_PER_NUM_IDEN
            ,P_PRF_PER_TID_CODIGO       => PRC1.PRF_PER_TID_CODIGO
            ,P_PRC_LTI_MNEMONICO        => PRC1.PRC_LTI_MNEMONICO
            ,P_PRC_MONTO                => PRC1.PRC_MONTO
            ,P_PRC_VALOR_NOMINAL        => PRC1.PRC_VALOR_FUTURO
            ,P_PRC_CNE_MNEMONICO        => PRC1.PRC_CNE_MNEMONICO
            ,P_PRC_MERCADO              => NULL
            ,P_PRC_CONSECUTIVO          => PRC1.PRC_CONSECUTIVO
            ,P_PRC_BOL_MNEMONICO        => PRC1.PRC_BOL_MNEMONICO
            ,P_PRC_NUMERO_OPERACION     => PRC1.PRC_NUMERO_OPERACION
            ,P_PRC_LIC_TIPO_OPERACION   => PRC1.PRC_LIC_TIPO_OPERACION
            ,P_PRC_LIC_NUMERO_FRACCION  => PRC1.PRC_LIC_NUMERO_FRACCION
            ,P_PRC_PER_NUM_IDEN         => PRC1.PRC_PER_NUM_IDEN
            ,P_PRC_PER_TID_CODIGO       => PRC1.PRC_PER_TID_CODIGO
            ,P_PRV_CONSECUTIVO          => NULL
            ,P_FECHA                    => P_FECHA
            ,P_ETI_CODIGO               => 'VIG'
            ,P_COTIZACION               => COTIZACION
            ,P_MRF_TMT_MNEMONICO        => 'FAF'
            ,P_INSERTA_CVS              => 'N'
            ,P_MVTO_CVS                 => NULL
            ,P_CVS_CONSECUTIVO          => CONSECUTIVO_CVS
            ,P_TFO_CODIGO               => P_TFO_CODIGO
            ,P_TOTAL_TC                 => NULL
            ,P_FECHA_CUMPLIMIENTO       => PRC1.PRC_FECHA_CUMPLIMIENTO
            ,P_VALOR_TM                 => VALOR_TM);
      ELSIF P_TIPO_OPERACION = 'POS' AND
         PRC1.PRC_CNE_MNEMONICO IN ('CON','PLA') THEN
         P_NEGOCIOS_POSICION.CREAR_TITULO_POSICION
            (P_PRF_FON_CODIGO           => P_PRF_FON_CODIGO
            ,P_PRF_TIPO                 => PRC1.PRF_TIPO
            ,P_PRF_TIPO_NEGOCIO         => 'C'
            ,P_PRF_ENA_MNEMONICO        => PRC1.PRF_ENA_MNEMONICO
            ,P_PRF_BMO_MNEMONICO        => 'PESOS'
            ,P_PRF_TRE_MNEMONICO        => NULL
            ,P_PRF_FECHA_EMISION        => P_FECHA
            ,P_PRF_FECHA_VENCIMIENTO    => PRC1.PRC_FECHA_CUMPLIMIENTO
            ,P_PRF_PERIODICIDAD_TASA    => 0
            ,P_PRF_BASE_CALCULO         => PRC1.PRC_BASE_CALCULO_FUTURA
            ,P_PRF_MODALIDAD_TASA       => 'D'
            ,P_PRF_PUNTOS_ADICIONALES   => NULL
            ,P_PRF_TASA_FACIAL          => 0
            ,P_PRF_AMORTIZABLE          => NULL
            ,P_PRF_TIPO_PAGO_FLUJO      => NULL
            ,P_PRF_FECHA_PRIMER_FLUJO   => NULL
            ,P_PRF_CAPITALIZABLE        => NULL
            ,P_PRF_CODIGO_PERIODO       => 'D'
            ,P_PRF_CONSECUTIVO          => P_PRF_CONSECUTIVO
            ,P_PRF_PER_NUM_IDEN         => PRC1.PRF_PER_NUM_IDEN
            ,P_PRF_PER_TID_CODIGO       => PRC1.PRF_PER_TID_CODIGO
            ,P_PRC_LTI_MNEMONICO        => PRC1.PRC_LTI_MNEMONICO
            ,P_PRC_MONTO                => VALOR_TM
            ,P_PRC_VALOR_NOMINAL        => PRC1.PRC_MONTO
            ,P_PRC_CNE_MNEMONICO        => PRC1.PRC_CNE_MNEMONICO
            ,P_PRC_MERCADO              => NULL
            ,P_PRC_CONSECUTIVO          => PRC1.PRC_CONSECUTIVO
            ,P_PRC_BOL_MNEMONICO        => PRC1.PRC_BOL_MNEMONICO
            ,P_PRC_NUMERO_OPERACION     => PRC1.PRC_NUMERO_OPERACION
            ,P_PRC_LIC_TIPO_OPERACION   => PRC1.PRC_LIC_TIPO_OPERACION
            ,P_PRC_LIC_NUMERO_FRACCION  => PRC1.PRC_LIC_NUMERO_FRACCION
            ,P_PRC_PER_NUM_IDEN         => PRC1.PRC_PER_NUM_IDEN
            ,P_PRC_PER_TID_CODIGO       => PRC1.PRC_PER_TID_CODIGO
            ,P_PRV_CONSECUTIVO          => NULL
            ,P_FECHA                    => P_FECHA
            ,P_ETI_CODIGO               => 'VIG'
            ,P_COTIZACION               => COTIZACION
            ,P_MRF_TMT_MNEMONICO        => 'OCO'
            ,P_INSERTA_CVS              => 'N'
            ,P_MVTO_CVS                 => NULL
            ,P_CVS_CONSECUTIVO          => CONSECUTIVO_CVS
            ,P_TFO_CODIGO               => P_TFO_CODIGO
            ,P_TOTAL_TC                 => NULL
            ,P_FECHA_CUMPLIMIENTO       => PRC1.PRC_FECHA_CUMPLIMIENTO
            ,P_VALOR_TM                 => VALOR_TM);
      ELSIF (P_TIPO_OPERACION = 'POSF' AND
         PRC1.PRC_CNE_MNEMONICO IN ('SIM','CON','PLA')) THEN
         /* Se verifica si se esta ejecutando una recompra de una venta fondeada */
         OPEN C_VENTA_FONDEADA;
         FETCH C_VENTA_FONDEADA INTO PRV1;
         IF C_VENTA_FONDEADA%FOUND THEN
            UPDATE TITULOS_FONDOS
            SET    TFO_ETI_CODIGO = 'RCO'
            WHERE  TFO_ETI_CODIGO = 'VIG'
            AND    TFO_FONDEO = 'N'
            AND    TFO_FON_CODIGO = PRV1.PRV_PRF_FON_CODIGO
            AND    TFO_PRV_PRF_CONSECUTIVO = PRV1.PRV_PRF_CONSECUTIVO
            AND    TFO_PRV_CONSECUTIVO = PRV1.PRV_CONSECUTIVO;
         ELSE
            UPDATE TITULOS_FONDOS
            SET    TFO_ETI_CODIGO = 'CDC'
            WHERE  TFO_ETI_CODIGO = 'VIG'
            AND    TFO_DERIVADO = 'S'
            AND    TFO_FONDEO = 'N'
            AND    TFO_FON_CODIGO = P_PRF_FON_CODIGO
            AND    TFO_PRC_PRF_CONSECUTIVO = P_PRF_CONSECUTIVO
            AND    TFO_PRC_CONSECUTIVO = PRC1.PRC_CONSECUTIVO;
         END IF;
         CLOSE C_VENTA_FONDEADA;
      END IF;
      FETCH C_PREORDEN_COMPRA INTO PRC1;
   END LOOP;
   CLOSE C_PREORDEN_COMPRA;
END EJECUCION_PREORDENES_COMPRA;
/******************************************************************/
PROCEDURE VERIFICAR_Y_FRACCIONAR
   (P_PRF_FON_CODIGO          PREORDENES_FONDOS.PRF_FON_CODIGO%TYPE
   ,P_PRF_CONSECUTIVO         PREORDENES_FONDOS.PRF_CONSECUTIVO%TYPE
   ,P_FECHA                   DATE)
   IS
   CURSOR C_NEGOCIO IS
      SELECT PRF_TFO_CODIGO
      FROM   PREORDENES_FONDOS
      WHERE  PRF_CONSECUTIVO = P_PRF_CONSECUTIVO
      AND    PRF_FON_CODIGO = P_PRF_FON_CODIGO;
   PRF1   C_NEGOCIO%ROWTYPE;
   CURSOR C_COMPRAS IS
      SELECT COUNT(*)
      FROM   TITULOS_FONDOS
      WHERE  TFO_FON_CODIGO = P_PRF_FON_CODIGO
      AND    TFO_PRC_PRF_CONSECUTIVO = P_PRF_CONSECUTIVO
      AND    (TFO_ETI_CODIGO = 'GAF'
             OR
             (TFO_ETI_CODIGO = 'VIG' AND
              NVL(TFO_DERIVADO,'N') = 'N' AND
              NVL(TFO_FONDEO,'N') = 'N'));
   TOT_COMPRAS  NUMBER;
   CURSOR C_ORD_COMPRA IS
      SELECT 'X'
      FROM   PREORDENES_COMPRA
      WHERE  PRC_PRF_FON_CODIGO = P_PRF_FON_CODIGO
      AND    PRC_PRF_CONSECUTIVO = P_PRF_CONSECUTIVO
      AND    NOT EXISTS (SELECT 'X'
                         FROM   TITULOS_FONDOS
                         WHERE  TFO_FON_CODIGO = PRC_PRF_FON_CODIGO
                         AND    TFO_PRC_PRF_CONSECUTIVO = PRC_PRF_CONSECUTIVO
                         AND    TFO_PRC_CONSECUTIVO = PRC_CONSECUTIVO
                         AND    NVL(TFO_DERIVADO,'N') = 'N');
   EXI_ORD  VARCHAR2(1);
   CURSOR C_ORD_VENTA IS
      SELECT 'X'
      FROM   PREORDENES_VENTA
      WHERE  PRV_PRF_FON_CODIGO = P_PRF_FON_CODIGO
      AND    PRV_PRF_CONSECUTIVO = P_PRF_CONSECUTIVO
      AND    PRV_TFO_CODIGO IS NOT NULL;
   CURSOR C_TITULO_COMPRA IS
      SELECT TFO_CODIGO
         , TFO_FON_CODIGO
       , TFO_TYPE
       , TFO_ENA_MNEMONICO
       , TFO_ETI_CODIGO
       , TFO_LTI_MNEMONICO
       , TFO_FECHA_OPERACION
       , TFO_VALOR_OPERACION
       , TFO_FECHA_CUMPLIMIENTO
       , TFO_DIA_SIGUIENTE
       , TFO_PRC_PRF_CONSECUTIVO
       , TFO_PRC_CONSECUTIVO
       , TFO_PRV_PRF_CONSECUTIVO
       , TFO_PRV_CONSECUTIVO
       , TFO_FUG_MNEMONICO
       , TFO_FUG_ISI_MNEMONICO
       , TFO_CVS_CONSECUTIVO
       , TFO_CVS_CONSECUTIVO_ES_VENDIDO
       , TFO_BOL_MNEMONICO, TFO_FONDEO
       , TFO_DERIVADO, TFO_CANTIDAD
       , TFO_MERCADO_COMPRA
       , TFO_VALOR_NOMINAL
       , TFO_BMO_MNEMONICO
       , TFO_FECHA_EMISION
       , TFO_FECHA_VENCIMIENTO
       , TFO_PERIODICIDAD_TASA
       , TFO_BASE_CALCULO
       , TFO_MODALIDAD_TASA
       , TFO_TASA_FACIAL
       , TFO_AMORTIZABLE
       , TFO_TRE_MNEMONICO
       , TFO_PUNTOS_ADICIONALES
       , TFO_FECHA_PRIMER_FLUJO
       , TFO_TIPO_PAGO_FLUJO
       , TFO_CAPITALIZABLE
       , TFO_TASA_MRC_CONGELADA
       , TFO_CRUZADA_CONVENIDA
       , TFO_AGE_CODIGO
       , TFO_COMISION_BOLSA
       , TFO_MERCADO
       , TFO_VALOR_UNITARIO
       , TFO_FECHA_CMPLMNTO_ESPECIAL
       , TFO_DISTRIBUCION_ACUMULADA
       , TFO_VALOR_TITULO_TM
       , TFO_FECHA_VALORIZACION
       , TFO_TASA_DESCUENTO
       , TFO_TFA_TIPO_INVERSION
       , TFO_TFA_CLT_MNEMONICO
       , TFO_DURACION
       , TFO_DURACION_MODIFICADA
       , TFO_VAR_TASA
       , TFO_VAR_MONEDA
       , TFO_CONVEXIDAD
       , TFO_NUMERO_EMISION_DCV
       , TFO_LIQ_NUMERO_OPERACION
       , TFO_LIQ_NUMERO_FRACCION
       , TFO_LIQ_TIPO_OPERACION
       , TFO_NUMERO_TITULO_FISICO
       , TFO_REFERENCIA_DECEVAL
       , TFO_LIQ_NUMERO_OPERACION_ES_VE
       , TFO_LIQ_NUMERO_FRACCION_ES_VEN
       , TFO_LIQ_TIPO_OPERACION_ES_VEND
       , TFO_FECHA_VENTA
       , TFO_VALOR_VENTA
       , TFO_PROSPECTO_VENTA
       , TFO_FECHA_PROSPECTO_VENTA
       , TFO_FECHA_VENTA_PLAZO
       , TFO_VALOR_VENTA_PLAZO
       , TFO_ENTE_VENTA_PLAZO
       , TFO_NUM_IDEN_VENTA_PLAZO
       , TFO_TELEFONO_VENTA_PLAZO
       , TFO_DIRECCION_VENTA_PLAZO
       , TFO_VENCIDO_ESPECIAL
       , TFO_LIC_NUMERO_OPERACION
       , TFO_LIC_NUMERO_FRACCION
       , TFO_LIC_TIPO_OPERACION
       , TFO_LIC_BOL_MNEMONICO
       , TFO_GARANTIA_ACTIVA
       , TFO_CODIGO_PERIODO
       , TFO_CALIFICADO
       , TFO_FECHA_CAMBIO_ESTADO
       , TFO_USUARIO_CAMBIO_ESTADO
       , TFO_TERMINAL_CAMBIO_ESTADO
       , TFO_PER_NUM_IDEN
       , TFO_PER_TID_CODIGO
       , TFO_TIPO_GARANTIA
       , TFO_CUENTA_CRCC
       , TFO_SEGMENTO
       , TFO_CCC_CLI_PER_NUM_IDEN
       , TFO_CCC_CLI_PER_TID_CODIGO
       , TFO_CCC_NUMERO_CUENTA
       , TFO_REPO
       , TFO_SALDO_GARANTIA_SIM
       , TFO_ESTADO_SIM
      FROM   TITULOS_FONDOS
      WHERE  TFO_FON_CODIGO = P_PRF_FON_CODIGO
      AND    TFO_PRC_PRF_CONSECUTIVO = P_PRF_CONSECUTIVO
      AND    (TFO_ETI_CODIGO = 'GAF'
             OR
             (TFO_ETI_CODIGO = 'VIG' AND
              NVL(TFO_DERIVADO,'N') = 'N' AND
              NVL(TFO_FONDEO,'N') = 'N'));
   TFO1   C_TITULO_COMPRA%ROWTYPE;
   CURSOR C_CODIGO IS
      SELECT NVL(MAX(TF1.TFO_CODIGO)+1 ,1)
      FROM   TITULOS_FONDOS TF1
      WHERE  TFO_FON_CODIGO = P_PRF_FON_CODIGO;
   CURSOR C_ESTADO_TITULOS IS
      SELECT ETI_VALORIZAR
      FROM   ESTADO_TITULOS
      WHERE  ETI_CODIGO = TFO1.TFO_ETI_CODIGO;
   ETI1   C_ESTADO_TITULOS%ROWTYPE;
   CURSOR C_PREORDEN_COMPRA(P_PRC_PRF_CONSECUTIVO     NUMBER
                           ,P_PRC_PRF_FON_CODIGO      VARCHAR2
                           ,P_PRC_CONSECUTIVO         NUMBER) IS
     SELECT PRC_PRF_CONSECUTIVO
        , PRC_PRF_FON_CODIGO
      , PRC_CONSECUTIVO
      , PRC_CLI_PER_NUM_IDEN
      , PRC_CLI_PER_TID_CODIGO
      , PRC_CONTACTO_VENDEDOR
      , PRC_TELEFONO
      , PRC_PER_NUM_IDEN
      , PRC_PER_TID_CODIGO
      , PRC_LTI_MNEMONICO
      , PRC_COP_MNEMONICO
      , PRC_MONTO
      , PRC_VALOR_NOMINAL
      , PRC_PORCENTAJE_CLIENTE
      , PRC_REPO_ACTIVO
      , PRC_COMPROMISO_VENTA_FUTURA
      , PRC_PER_NUM_IDEN_ES_MODIFICADA
      , PRC_PER_TID_CODIGO_ES_MODIFICA
      , PRC_FECHA_MODIFICACION
      , PRC_REGISTRA_CLIENTE
      , PRC_AUTORIZACION
      , PRC_FECHA_CUMPLIMIENTO
      , PRC_NUMERO_OPERACION
      , PRC_CNE_MNEMONICO
      , PRC_MERCADO
      , PRC_BOL_MNEMONICO
      , PRC_BRO_MNEMONICO
      , PRC_POSICION_ABIERTA
      , PRC_POR_CORREDORES
      , PRC_PER_NUM_IDEN_CONTRAPARTE
      , PRC_PER_TID_CODIGO_CONTRAPARTE
      , PRC_CCO_MNEMONICO
      , PRC_DIRECCION_TITULOS
      , PRC_PREGUNTAR_POR_TITULOS
      , PRC_AGE_CODIGO
      , PRC_TASA_NOMINAL_REPO
      , PRC_FECHA_VENCIMIENTO_REPO
      , PRC_FECHA_VENTA_FUTURA
      , PRC_PRV_PRF_CONSECUTIVO
      , PRC_PRV_CONSECUTIVO
      , PRC_FPO_CONSECUTIVO
      , PRC_MONTO_DOLARES
      , PRC_MONTO_PESOS
      , PRC_AUTORIZADO_POR
      , PRC_FECHA_AUTORIZACION
      , PRC_MOTIVO_AUTORIZACION
      , PRC_TASA_FUTURA
      , PRC_BASE_CALCULO_FUTURA
      , PRC_VALOR_FUTURO
      , PRC_OVE_CONSECUTIVO
      , PRC_OVE_COC_CTO_MNEMONICO
      , PRC_NUMERO_ACCIONES_REPO
      , PRC_NPO_CONSECUTIVO
      , PRC_OFD_CONSECUTIVO
      , PRC_LIC_NUMERO_FRACCION
      , PRC_LIC_TIPO_OPERACION
      , PRC_VALOR_COMISION
      , PRC_RETENCION_FUENTE
      , PRC_VALOR_IVA_COMISION
      , PRC_VALOR_EXTEMPO
      , PRC_FECHA_CUM_CON
      , PRC_VOLUMEN_FRACCION
      , PRC_FRACCIONADA_UNIFICADA
      , PRC_CRUZADA_CONVENIDA
      , PRC_CCC_NUMERO_CUENTA
      , PRC_PRECIO_PACTADO
      , PRC_CONTRAPARTIDA
      , PRC_FECHA_CUMPLIMIENTO_NUEVA
      , PRC_RETARDO
      , PRC_VALOR_RETARDO
     FROM PREORDENES_COMPRA
     WHERE PRC_PRF_CONSECUTIVO = P_PRC_PRF_CONSECUTIVO
       AND PRC_PRF_FON_CODIGO = P_PRC_PRF_FON_CODIGO
       AND PRC_CONSECUTIVO = P_PRC_CONSECUTIVO;
   PRC1  C_PREORDEN_COMPRA%ROWTYPE;
   CURSOR C_COTIZACION_BASE(P_FECHA  DATE
                           ,P_BASE   VARCHAR2) IS
      SELECT CBM_VALOR
      FROM   COTIZACIONES_BASE_MONETARIAS
      WHERE  TRUNC(CBM_FECHA)= TRUNC(P_FECHA)
      AND    CBM_BMO_MNEMONICO = P_BASE;
   CURSOR C_PENSIONAL(P_ENA VARCHAR2)  IS
      SELECT ENA_PENSIONAL
      FROM   ESPECIES_NACIONALES
      WHERE  ENA_MNEMONICO = P_ENA;
   ENA2   C_PENSIONAL%ROWTYPE;
   CURSOR C_TFO(P_FDO VARCHAR2
               ,P_COD NUMBER) IS
      SELECT TFO_CODIGO
         , TFO_FON_CODIGO
       , TFO_TYPE
       , TFO_ENA_MNEMONICO
       , TFO_ETI_CODIGO
       , TFO_LTI_MNEMONICO
       , TFO_FECHA_OPERACION
       , TFO_VALOR_OPERACION
       , TFO_FECHA_CUMPLIMIENTO
       , TFO_DIA_SIGUIENTE
       , TFO_PRC_PRF_CONSECUTIVO
       , TFO_PRC_CONSECUTIVO
       , TFO_PRV_PRF_CONSECUTIVO
       , TFO_PRV_CONSECUTIVO
       , TFO_FUG_MNEMONICO
       , TFO_FUG_ISI_MNEMONICO
       , TFO_CVS_CONSECUTIVO
       , TFO_CVS_CONSECUTIVO_ES_VENDIDO
       , TFO_BOL_MNEMONICO, TFO_FONDEO
       , TFO_DERIVADO, TFO_CANTIDAD
       , TFO_MERCADO_COMPRA
       , TFO_VALOR_NOMINAL
       , TFO_BMO_MNEMONICO
       , TFO_FECHA_EMISION
       , TFO_FECHA_VENCIMIENTO
       , TFO_PERIODICIDAD_TASA
       , TFO_BASE_CALCULO
       , TFO_MODALIDAD_TASA
       , TFO_TASA_FACIAL
       , TFO_AMORTIZABLE
       , TFO_TRE_MNEMONICO
       , TFO_PUNTOS_ADICIONALES
       , TFO_FECHA_PRIMER_FLUJO
       , TFO_TIPO_PAGO_FLUJO
       , TFO_CAPITALIZABLE
       , TFO_TASA_MRC_CONGELADA
       , TFO_CRUZADA_CONVENIDA
       , TFO_AGE_CODIGO
       , TFO_COMISION_BOLSA
       , TFO_MERCADO
       , TFO_VALOR_UNITARIO
       , TFO_FECHA_CMPLMNTO_ESPECIAL
       , TFO_DISTRIBUCION_ACUMULADA
       , TFO_VALOR_TITULO_TM
       , TFO_FECHA_VALORIZACION
       , TFO_TASA_DESCUENTO
       , TFO_TFA_TIPO_INVERSION
       , TFO_TFA_CLT_MNEMONICO
       , TFO_DURACION
       , TFO_DURACION_MODIFICADA
       , TFO_VAR_TASA
       , TFO_VAR_MONEDA
       , TFO_CONVEXIDAD
       , TFO_NUMERO_EMISION_DCV
       , TFO_LIQ_NUMERO_OPERACION
       , TFO_LIQ_NUMERO_FRACCION
       , TFO_LIQ_TIPO_OPERACION
       , TFO_NUMERO_TITULO_FISICO
       , TFO_REFERENCIA_DECEVAL
       , TFO_LIQ_NUMERO_OPERACION_ES_VE
       , TFO_LIQ_NUMERO_FRACCION_ES_VEN
       , TFO_LIQ_TIPO_OPERACION_ES_VEND
       , TFO_FECHA_VENTA
       , TFO_VALOR_VENTA
       , TFO_PROSPECTO_VENTA
       , TFO_FECHA_PROSPECTO_VENTA
       , TFO_FECHA_VENTA_PLAZO
       , TFO_VALOR_VENTA_PLAZO
       , TFO_ENTE_VENTA_PLAZO
       , TFO_NUM_IDEN_VENTA_PLAZO
       , TFO_TELEFONO_VENTA_PLAZO
       , TFO_DIRECCION_VENTA_PLAZO
       , TFO_VENCIDO_ESPECIAL
       , TFO_LIC_NUMERO_OPERACION
       , TFO_LIC_NUMERO_FRACCION
       , TFO_LIC_TIPO_OPERACION
       , TFO_LIC_BOL_MNEMONICO
       , TFO_GARANTIA_ACTIVA
       , TFO_CODIGO_PERIODO
       , TFO_CALIFICADO
       , TFO_FECHA_CAMBIO_ESTADO
       , TFO_USUARIO_CAMBIO_ESTADO
       , TFO_TERMINAL_CAMBIO_ESTADO
       , TFO_PER_NUM_IDEN
       , TFO_PER_TID_CODIGO
       , TFO_TIPO_GARANTIA
       , TFO_CUENTA_CRCC
       , TFO_SEGMENTO
       , TFO_CCC_CLI_PER_NUM_IDEN
       , TFO_CCC_CLI_PER_TID_CODIGO
       , TFO_CCC_NUMERO_CUENTA
       , TFO_REPO
       , TFO_SALDO_GARANTIA_SIM
       , TFO_ESTADO_SIM
       , TFO_CLASIF_INVERSION
       ,TFO_FECHA_COMPRA_INICIAL
	     ,TFO_NPO_PROPORCION_CORTO
       ,TFO_NPO_NOMINAL_CORTO
       ,TFO_NPO_CORTO
       ,TFO_NPO_CUPON
       ,TFO_NUMERO_EMISION_DCV_HIST --mb proyecto mit dcv
       ,TFO_ORIGEN_TITULO -- OMORA F351
      FROM TITULOS_FONDOS
      WHERE TFO_FON_CODIGO = P_FDO
        AND TFO_CODIGO = P_COD;
   TIT C_TFO%ROWTYPE;
   CURSOR C_TASA_REF(P_TASA   VARCHAR2
                    ,P_FECHA1 DATE) IS
      SELECT CTR_TASA_NOMINAL
      FROM   COTIZACIONES_TASA_REFERENCIA
      WHERE  CTR_TRE_MNEMONICO = P_TASA
      AND    TRUNC(CTR_FECHA) <= TRUNC(P_FECHA1)
      ORDER BY CTR_FECHA DESC;
   SIGUIENTE     NUMBER;
   TOT_OPERACION NUMBER;
   TOT_COMISION  NUMBER;
   TOT_NOMINAL   NUMBER;
   TOT_CANTIDAD  NUMBER;
   P_UBICACION   VARCHAR2(5);
   COND          VARCHAR2(1);
   FECSYS        DATE;
   COTIZACION    NUMBER;
   ISIN          VARCHAR2(12);
   EMISION       VARCHAR2(20);
   FUNGIBLE      NUMBER(10);
   VALOR_TB      NUMBER;
   MRF1   MVTOS_RENTA_FIJA%ROWTYPE;
BEGIN
   OPEN C_NEGOCIO;
   FETCH C_NEGOCIO INTO PRF1;
   CLOSE C_NEGOCIO;
   OPEN C_COMPRAS;
   FETCH C_COMPRAS INTO TOT_COMPRAS;
   CLOSE C_COMPRAS;
   OPEN C_ORD_COMPRA;
   FETCH C_ORD_COMPRA INTO EXI_ORD;
   CLOSE C_ORD_COMPRA;
   IF NVL(EXI_ORD,' ') = 'X' THEN
      RAISE_APPLICATION_ERROR(-20057,'Tiene que ejecutar primero todas las compras del negocio '
         || TO_CHAR(P_PRF_CONSECUTIVO));
   END IF;
   EXI_ORD := NULL;
   OPEN C_ORD_VENTA;
   FETCH C_ORD_VENTA INTO EXI_ORD;
   CLOSE C_ORD_VENTA;
   IF NVL(EXI_ORD,' ') = 'X' THEN
      RAISE_APPLICATION_ERROR(-20058,'El proceso de fraccionamiento del negocio ' || TO_CHAR(P_PRF_CONSECUTIVO)
         || ' ya fue hecho');
   END IF;
   IF PRF1.PRF_TFO_CODIGO IS NOT NULL THEN
      P_NEGOCIOS_POSICION.FRACCION
          (P_TFO_FON_CODIGO   => P_PRF_FON_CODIGO
          ,P_TFO_CODIGO       => PRF1.PRF_TFO_CODIGO
          ,P_PRF_CONSECUTIVO  => P_PRF_CONSECUTIVO
          ,P_FECHA            => P_FECHA);
   ELSE
      IF TOT_COMPRAS = 1 THEN
         OPEN C_TITULO_COMPRA;
         FETCH C_TITULO_COMPRA INTO TFO1;
         IF C_TITULO_COMPRA%NOTFOUND THEN
            RAISE_APPLICATION_ERROR(-20059,'No se pudo determinar el titulo de compra del negocio '
               || TO_CHAR(P_PRF_CONSECUTIVO));
         END IF;
         CLOSE C_TITULO_COMPRA;
         P_NEGOCIOS_POSICION.FRACCION
             (P_TFO_FON_CODIGO   => TFO1.TFO_FON_CODIGO
             ,P_TFO_CODIGO       => TFO1.TFO_CODIGO
             ,P_PRF_CONSECUTIVO  => P_PRF_CONSECUTIVO
             ,P_FECHA            => P_FECHA);
      ELSE
         LOCK TABLE TITULOS_FONDOS IN EXCLUSIVE MODE;
         OPEN C_CODIGO;
         FETCH C_CODIGO INTO SIGUIENTE;
         CLOSE C_CODIGO;
         TOT_OPERACION := 0;
         TOT_COMISION := 0;
         TOT_NOMINAL := 0;
         TOT_CANTIDAD := 0;
         COND := 'S';
         OPEN C_TITULO_COMPRA;
         FETCH C_TITULO_COMPRA INTO TFO1;
         P_UBICACION := TFO1.TFO_LTI_MNEMONICO;
         WHILE C_TITULO_COMPRA%FOUND LOOP
            IF TFO1.TFO_ETI_CODIGO != 'GAF' THEN
               OPEN C_ESTADO_TITULOS;
               FETCH C_ESTADO_TITULOS INTO ETI1;
               CLOSE C_ESTADO_TITULOS;
               IF NVL(ETI1.ETI_VALORIZAR,'N') != 'S' THEN
                  RAISE_APPLICATION_ERROR(-20060,'El titulo ' || TO_CHAR(TFO1.TFO_CODIGO)
                     || ' se encuentra en un estado no vigente');
               END IF;
            END IF;
            TOT_OPERACION := TOT_OPERACION + NVL(TFO1.TFO_VALOR_OPERACION,0);
            TOT_COMISION := TOT_COMISION + NVL(TFO1.TFO_COMISION_BOLSA,0);
            IF TFO1.TFO_TYPE = 'TRF' THEN
               TOT_NOMINAL := TOT_NOMINAL + NVL(TFO1.TFO_VALOR_NOMINAL,0);
            ELSE
               TOT_CANTIDAD := TOT_CANTIDAD + NVL(TFO1.TFO_CANTIDAD,0);
            END IF;
            IF TFO1.TFO_LTI_MNEMONICO != P_UBICACION AND
               COND = 'S' THEN
               OPEN C_PREORDEN_COMPRA(TFO1.TFO_PRC_PRF_CONSECUTIVO
                                     ,TFO1.TFO_FON_CODIGO
                                     ,TFO1.TFO_PRC_CONSECUTIVO);
               FETCH C_PREORDEN_COMPRA INTO PRC1;
               IF C_PREORDEN_COMPRA%FOUND THEN
                 P_UBICACION := PRC1.PRC_LTI_MNEMONICO;
               END IF;
               CLOSE C_PREORDEN_COMPRA;
               P_UBICACION := NVL(PRC1.PRC_LTI_MNEMONICO,'CR');
               COND := 'N';
            END IF;
            FETCH C_TITULO_COMPRA INTO TFO1;
         END LOOP;
         CLOSE C_TITULO_COMPRA;
         FECSYS := P_FECHA;
         IF TFO1.TFO_BMO_MNEMONICO != 'PESOS' THEN
            OPEN C_COTIZACION_BASE(FECSYS,TFO1.TFO_BMO_MNEMONICO);
            FETCH C_COTIZACION_BASE INTO COTIZACION;
            IF C_COTIZACION_BASE%NOTFOUND THEN
               RAISE_APPLICATION_ERROR(-20061,'Cotizacion de la base ' || TFO1.TFO_BMO_MNEMONICO || ' no encontrada' );
            END IF;
            CLOSE C_COTIZACION_BASE;
         ELSE
            COTIZACION := 1;
         END IF;
         INSERT INTO TITULOS_FONDOS
            (TFO_FON_CODIGO
            ,TFO_CODIGO
            ,TFO_TYPE
            ,TFO_ENA_MNEMONICO
            ,TFO_ETI_CODIGO
            ,TFO_LTI_MNEMONICO
            ,TFO_FECHA_OPERACION
            ,TFO_VALOR_OPERACION
            ,TFO_FECHA_CUMPLIMIENTO
            ,TFO_COMISION_BOLSA
            ,TFO_AGE_CODIGO
            ,TFO_BMO_MNEMONICO
            ,TFO_TRE_MNEMONICO
            ,TFO_FECHA_EMISION
            ,TFO_FECHA_VENCIMIENTO
            ,TFO_VALOR_NOMINAL
            ,TFO_PERIODICIDAD_TASA
            ,TFO_BASE_CALCULO
            ,TFO_MODALIDAD_TASA
            ,TFO_MERCADO_COMPRA
            ,TFO_VENCIDO_ESPECIAL
            ,TFO_VALOR_UNITARIO
            ,TFO_CANTIDAD
            ,TFO_PUNTOS_ADICIONALES
            ,TFO_TASA_FACIAL
            ,TFO_AMORTIZABLE
            ,TFO_TIPO_PAGO_FLUJO
            ,TFO_FECHA_PRIMER_FLUJO
            ,TFO_TASA_MRC_CONGELADA
            ,TFO_FECHA_CMPLMNTO_ESPECIAL
            ,TFO_DERIVADO
            ,TFO_DIA_SIGUIENTE
            ,TFO_CAPITALIZABLE
            ,TFO_FONDEO
            ,TFO_MERCADO
            ,TFO_NUMERO_EMISION_DCV
            ,TFO_CODIGO_PERIODO
            ,TFO_CCC_CLI_PER_NUM_IDEN
            ,TFO_CCC_CLI_PER_TID_CODIGO
            ,TFO_CCC_NUMERO_CUENTA)
         VALUES
            (TFO1.TFO_FON_CODIGO
            ,SIGUIENTE
            ,TFO1.TFO_TYPE
            ,TFO1.TFO_ENA_MNEMONICO
            ,TFO1.TFO_ETI_CODIGO
            ,P_UBICACION
            ,TFO1.TFO_FECHA_OPERACION
            ,TOT_OPERACION
            ,TFO1.TFO_FECHA_CUMPLIMIENTO
            ,TOT_COMISION
            ,TFO1.TFO_AGE_CODIGO
            ,TFO1.TFO_BMO_MNEMONICO
            ,TFO1.TFO_TRE_MNEMONICO
            ,TFO1.TFO_FECHA_EMISION
            ,TFO1.TFO_FECHA_VENCIMIENTO
            ,DECODE(TFO1.TFO_TYPE,'TRF',TOT_NOMINAL,NULL)
            ,TFO1.TFO_PERIODICIDAD_TASA
            ,TFO1.TFO_BASE_CALCULO
            ,TFO1.TFO_MODALIDAD_TASA
            ,TFO1.TFO_MERCADO_COMPRA
            ,TFO1.TFO_VENCIDO_ESPECIAL
            ,DECODE(TFO1.TFO_TYPE,'TAC',TOT_OPERACION/TOT_CANTIDAD,NULL)
            ,DECODE(TFO1.TFO_TYPE,'TAC',TOT_CANTIDAD,NULL)
            ,TFO1.TFO_PUNTOS_ADICIONALES
            ,TFO1.TFO_TASA_FACIAL
            ,TFO1.TFO_AMORTIZABLE
            ,TFO1.TFO_TIPO_PAGO_FLUJO
            ,TFO1.TFO_FECHA_PRIMER_FLUJO
            ,TFO1.TFO_TASA_MRC_CONGELADA
            ,TFO1.TFO_FECHA_CMPLMNTO_ESPECIAL
            ,TFO1.TFO_DERIVADO
            ,TFO1.TFO_DIA_SIGUIENTE
            ,TFO1.TFO_CAPITALIZABLE
            ,TFO1.TFO_FONDEO
            ,TFO1.TFO_MERCADO
            ,TFO1.TFO_NUMERO_EMISION_DCV
            ,TFO1.TFO_CODIGO_PERIODO
            ,TFO1.TFO_CCC_CLI_PER_NUM_IDEN
            ,TFO1.TFO_CCC_CLI_PER_TID_CODIGO
            ,TFO1.TFO_CCC_NUMERO_CUENTA);
         P_TITULOS.P_ISIN_EMI_ANTERIOR(TFO1.TFO_FON_CODIGO
                                      ,SIGUIENTE
                                      ,ISIN
                                      ,FUNGIBLE
                                      ,EMISION);
         UPDATE TITULOS_FONDOS
         SET    TFO_FUG_ISI_MNEMONICO = ISIN
               ,TFO_FUG_MNEMONICO = FUNGIBLE
               ,TFO_NUMERO_EMISION_DCV = EMISION
         WHERE  TFO_FON_CODIGO = TFO1.TFO_FON_CODIGO
         AND    TFO_CODIGO = SIGUIENTE;
         IF TFO1.TFO_TYPE = 'TRF' THEN
            OPEN C_PENSIONAL(TFO1.TFO_ENA_MNEMONICO);
            FETCH C_PENSIONAL INTO ENA2;
            IF NVL(ENA2.ENA_PENSIONAL,'N') = 'S' THEN
               OPEN C_TFO(TFO1.TFO_FON_CODIGO, SIGUIENTE);
               FETCH C_TFO INTO TIT;
               CLOSE C_TFO;
               P_FLUJOS.GENERE_AMORT_PENSIONAL(TIT);
            ELSE
               IF NVL(TFO1.TFO_AMORTIZABLE,'N') = 'N' THEN
                  IF TFO1.TFO_MODALIDAD_TASA != 'D' THEN
                     P_FLUJOS_FRM.FLUJOS_RENDIMIENTOS(P_PRF_FON_CODIGO,SIGUIENTE);
                  END IF;
                  P_FLUJOS_FRM.FLUJOS_AMORTIZACIONES(P_PRF_FON_CODIGO,SIGUIENTE);
               ELSE
                  P_FLUJOS_FRM.FLUJOS_AMORTIZACIONES(P_PRF_FON_CODIGO,SIGUIENTE);
                  IF TFO1.TFO_MODALIDAD_TASA != 'D' THEN
                     P_FLUJOS_FRM.FLUJOS_RENDIMIENTOS(P_PRF_FON_CODIGO,SIGUIENTE);
                  END IF;
               END IF;
            END IF;
            UPDATE FLUJOS_AMORTIZACION_TITULOS
            SET    FAT_ESTADO = 'C'
            WHERE  FAT_TFO_FON_CODIGO = P_PRF_FON_CODIGO
            AND    FAT_TFO_CODIGO = SIGUIENTE
            AND    TRUNC(FAT_FECHA) <= TRUNC(P_FECHA);
            UPDATE FLUJOS_RENDIMIENTOS_TITULOS
            SET    FRT_ESTADO = 'C'
            WHERE  FRT_TFO_FON_CODIGO = P_PRF_FON_CODIGO
            AND    FRT_TFO_CODIGO = SIGUIENTE
            AND    TRUNC(FRT_FECHA) <= TRUNC(P_FECHA);
            IF TFO1.TFO_TRE_MNEMONICO IS NOT NULL THEN
               OPEN C_TASA_REF(TFO1.TFO_TRE_MNEMONICO
                              ,P_FECHA);
               FETCH C_TASA_REF INTO VALOR_TB;
               IF C_TASA_REF%NOTFOUND THEN
                  CLOSE C_TASA_REF;
                  RAISE_APPLICATION_ERROR(-20062,'No se encontro cotizaciżn de la tasa: ' || TFO1.TFO_TRE_MNEMONICO
                     || ' para la fecha ' || TO_CHAR(P_FECHA,'DD-MON-YYYY'));
               END IF;
               CLOSE C_TASA_REF;
            ELSE
               VALOR_TB := TFO1.TFO_TASA_FACIAL;
            END IF;
            MRF1.MRF_TIR360_C := P_TITULOS.TIR_360_COMPRA_RF(TFO1.TFO_FON_CODIGO
                                                            ,SIGUIENTE
                                                            ,TFO1.TFO_FECHA_OPERACION
                                                            ,(ROUND(TOT_OPERACION / COTIZACION,2))
                                                            ,VALOR_TB);
            MRF1.MRF_TIR365_C := P_TITULOS.TIR_365_COMPRA_RF(TFO1.TFO_FON_CODIGO
                                                            ,SIGUIENTE
                                                            ,TFO1.TFO_FECHA_OPERACION
                                                            ,(ROUND(TOT_OPERACION / COTIZACION,2))
                                                            ,VALOR_TB);
            MRF1.MRF_TIR360_M := P_TITULOS.TIR_360_MERCADO_RF(TFO1.TFO_FON_CODIGO
                                                             ,SIGUIENTE
                                                             ,TFO1.TFO_FECHA_OPERACION
                                                             ,(ROUND(TOT_OPERACION / COTIZACION,2))
                                                             ,VALOR_TB);
            MRF1.MRF_TIR365_M := P_TITULOS.TIR_365_MERCADO_RF(TFO1.TFO_FON_CODIGO
                                                             ,SIGUIENTE
                                                             ,TFO1.TFO_FECHA_OPERACION
                                                             ,(ROUND(TOT_OPERACION / COTIZACION,2))
                                                             ,VALOR_TB);
            MRF1.MRF_VALOR_TITULO_TM := (TOT_OPERACION / COTIZACION);
            MRF1.MRF_AAI := 0;
            MRF1.MRF_MPE := 0;
            MRF1.MRF_TAI := 0;
            IF SUBSTR(TFO1.TFO_ENA_MNEMONICO,1,3) = 'TRD' THEN
               MRF1.MRF_AAI := 0;
               MRF1.MRF_TAI := 0;
               MRF1.MRF_MPE := 0;
               MRF1.MRF_TIR360_M := 0;
               MRF1.MRF_TIR360_C := 0;
               MRF1.MRF_TIR365_M := 0;
               MRF1.MRF_TIR365_C := 0;
            END IF;
            INSERT INTO MVTOS_RENTA_FIJA
               (MRF_TFO_FON_CODIGO
               ,MRF_TFO_CODIGO
               ,MRF_TMT_MNEMONICO
               ,MRF_FECHA
               ,MRF_UTILIDAD
               ,MRF_PERDIDA
               ,MRF_CAPITAL
               ,MRF_INTERES
               ,MRF_VALOR_TITULO_TM
               ,MRF_VALOR_TITULO_TC
               ,MRF_VALORIZACION_TM
               ,MRF_VALORIZACION_TC
               ,MRF_VALOR_DISTRIBUIR_DIA
               ,MRF_VALOR_DIST_REND_FINANCIERO
               ,MRF_DIFERENCIA_CAMBIO
               ,MRF_MPE
               ,MRF_AAI
               ,MRF_TAI
               ,MRF_TIR360_M
               ,MRF_TIR360_C
               ,MRF_TIR365_M
               ,MRF_TIR365_C)
            VALUES
               (TFO1.TFO_FON_CODIGO
               ,SIGUIENTE
               ,'UNI'
               ,SYSDATE
               ,0
               ,0
               ,0
               ,0
               ,MRF1.MRF_VALOR_TITULO_TM
               ,MRF1.MRF_VALOR_TITULO_TM
               ,0
               ,0
               ,0
               ,0
               ,0
               ,MRF1.MRF_MPE
               ,MRF1.MRF_AAI
               ,MRF1.MRF_TAI
               ,MRF1.MRF_TIR360_M
               ,MRF1.MRF_TIR360_C
               ,MRF1.MRF_TIR365_M
               ,MRF1.MRF_TIR365_C);
         ELSE
            P_FLUJOS_FRM.FLUJOS_DIVIDENDOS(P_PRF_FON_CODIGO,SIGUIENTE);
            INSERT INTO MVTOS_ACCION
               (MAC_FECHA
               ,MAC_TFO_FON_CODIGO
               ,MAC_TFO_CODIGO
               ,MAC_TMT_MNEMONICO
               ,MAC_MONTO
               ,MAC_DIVIDENDOS_CAUSADOS
               ,MAC_DIVIDENDOS_PAGADOS
               ,MAC_UTILIDAD
               ,MAC_PERDIDA)
             VALUES
                (SYSDATE
                ,P_PRF_FON_CODIGO
                ,SIGUIENTE
                ,'UNI'
                ,TOT_OPERACION
                ,0
                ,0
                ,0
                ,0);
         END IF;
         OPEN C_TITULO_COMPRA;
         FETCH C_TITULO_COMPRA INTO TFO1;
         WHILE C_TITULO_COMPRA%FOUND LOOP
            -- Elimina los Flujos de los Titulos Originales
            P_FLUJOS_FRM.ANULE_FLUJOS(TFO1.TFO_FON_CODIGO
                                     ,TFO1.TFO_CODIGO);
            UPDATE TITULOS_FONDOS
            SET    TFO_ETI_CODIGO = 'UNI'
                  ,TFO_DIA_SIGUIENTE = NULL
            WHERE  TFO_FON_CODIGO = TFO1.TFO_FON_CODIGO
            AND    TFO_CODIGO = TFO1.TFO_CODIGO;
            INSERT INTO FRACCIONAMIENTOS_UNIFICACIONES
               (FUN_TFO_FON_CODIGO
               ,FUN_TFO_CODIGO
               ,FUN_TFO_FON_CODIGO_ES_PRODUCID
               ,FUN_TFO_CODIGO_ES_PRODUCIDA
               ,FUN_FECHA
               ,FUN_TIPO_OPERACION)
            VALUES
               (TFO1.TFO_FON_CODIGO
               ,TFO1.TFO_CODIGO
               ,TFO1.TFO_FON_CODIGO
               ,SIGUIENTE
               ,SYSDATE
               ,'U');

			INSERT INTO SEGUIMIENTOS
				(FONDO,
				 TITULO,
				 TITULO_CREADO,
				 OPERACION,
				 FECHA,
				 OREIGEN)
			VALUES
				(TFO1.TFO_FON_CODIGO,
				 TFO1.TFO_CODIGO,
				 SIGUIENTE,
				 'U',
				 SYSDATE,
				 'P_NEGOCIOS_POSICION 2311');

            FETCH C_TITULO_COMPRA INTO TFO1;
         END LOOP;
         CLOSE C_TITULO_COMPRA;
         P_NEGOCIOS_POSICION.FRACCION
             (P_TFO_FON_CODIGO   => TFO1.TFO_FON_CODIGO
             ,P_TFO_CODIGO       => TFO1.TFO_CODIGO
             ,P_PRF_CONSECUTIVO  => P_PRF_CONSECUTIVO
             ,P_FECHA            => P_FECHA);
      END IF;
   END IF;
   NULL;
EXCEPTION
   WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20063,'VERIFICAR - Titulo:'||TO_CHAR(TFO1.TFO_CODIGO)||CHR(13)||SQLERRM);
END VERIFICAR_Y_FRACCIONAR;
/*************************************************************************/
PROCEDURE FRACCION
   (P_TFO_FON_CODIGO    TITULOS_FONDOS.TFO_FON_CODIGO%TYPE
   ,P_TFO_CODIGO        TITULOS_FONDOS.TFO_CODIGO%TYPE
   ,P_PRF_CONSECUTIVO   PREORDENES_VENTA.PRV_PRF_CONSECUTIVO%TYPE
   ,P_FECHA             DATE) IS
   CURSOR C_TITULO IS
      SELECT TFO_CODIGO
         , TFO_FON_CODIGO
       , TFO_TYPE
       , TFO_ENA_MNEMONICO
       , TFO_ETI_CODIGO
       , TFO_LTI_MNEMONICO
       , TFO_FECHA_OPERACION
       , TFO_VALOR_OPERACION
       , TFO_FECHA_CUMPLIMIENTO
       , TFO_DIA_SIGUIENTE
       , TFO_PRC_PRF_CONSECUTIVO
       , TFO_PRC_CONSECUTIVO
       , TFO_PRV_PRF_CONSECUTIVO
       , TFO_PRV_CONSECUTIVO
       , TFO_FUG_MNEMONICO
       , TFO_FUG_ISI_MNEMONICO
       , TFO_CVS_CONSECUTIVO
       , TFO_CVS_CONSECUTIVO_ES_VENDIDO
       , TFO_BOL_MNEMONICO, TFO_FONDEO
       , TFO_DERIVADO, TFO_CANTIDAD
       , TFO_MERCADO_COMPRA
       , TFO_VALOR_NOMINAL
       , TFO_BMO_MNEMONICO
       , TFO_FECHA_EMISION
       , TFO_FECHA_VENCIMIENTO
       , TFO_PERIODICIDAD_TASA
       , TFO_BASE_CALCULO
       , TFO_MODALIDAD_TASA
       , TFO_TASA_FACIAL
       , TFO_AMORTIZABLE
       , TFO_TRE_MNEMONICO
       , TFO_PUNTOS_ADICIONALES
       , TFO_FECHA_PRIMER_FLUJO
       , TFO_TIPO_PAGO_FLUJO
       , TFO_CAPITALIZABLE
       , TFO_TASA_MRC_CONGELADA
       , TFO_CRUZADA_CONVENIDA
       , TFO_AGE_CODIGO
       , TFO_COMISION_BOLSA
       , TFO_MERCADO
       , TFO_VALOR_UNITARIO
       , TFO_FECHA_CMPLMNTO_ESPECIAL
       , TFO_DISTRIBUCION_ACUMULADA
       , TFO_VALOR_TITULO_TM
       , TFO_FECHA_VALORIZACION
       , TFO_TASA_DESCUENTO
       , TFO_TFA_TIPO_INVERSION
       , TFO_TFA_CLT_MNEMONICO
       , TFO_DURACION
       , TFO_DURACION_MODIFICADA
       , TFO_VAR_TASA
       , TFO_VAR_MONEDA
       , TFO_CONVEXIDAD
       , TFO_NUMERO_EMISION_DCV
       , TFO_LIQ_NUMERO_OPERACION
       , TFO_LIQ_NUMERO_FRACCION
       , TFO_LIQ_TIPO_OPERACION
       , TFO_NUMERO_TITULO_FISICO
       , TFO_REFERENCIA_DECEVAL
       , TFO_LIQ_NUMERO_OPERACION_ES_VE
       , TFO_LIQ_NUMERO_FRACCION_ES_VEN
       , TFO_LIQ_TIPO_OPERACION_ES_VEND
       , TFO_FECHA_VENTA
       , TFO_VALOR_VENTA
       , TFO_PROSPECTO_VENTA
       , TFO_FECHA_PROSPECTO_VENTA
       , TFO_FECHA_VENTA_PLAZO
       , TFO_VALOR_VENTA_PLAZO
       , TFO_ENTE_VENTA_PLAZO
       , TFO_NUM_IDEN_VENTA_PLAZO
       , TFO_TELEFONO_VENTA_PLAZO
       , TFO_DIRECCION_VENTA_PLAZO
       , TFO_VENCIDO_ESPECIAL
       , TFO_LIC_NUMERO_OPERACION
       , TFO_LIC_NUMERO_FRACCION
       , TFO_LIC_TIPO_OPERACION
       , TFO_LIC_BOL_MNEMONICO
       , TFO_GARANTIA_ACTIVA
       , TFO_CODIGO_PERIODO
       , TFO_CALIFICADO
       , TFO_FECHA_CAMBIO_ESTADO
       , TFO_USUARIO_CAMBIO_ESTADO
       , TFO_TERMINAL_CAMBIO_ESTADO
       , TFO_PER_NUM_IDEN
       , TFO_PER_TID_CODIGO
       , TFO_TIPO_GARANTIA
       , TFO_CUENTA_CRCC
       , TFO_SEGMENTO
       , TFO_CCC_CLI_PER_NUM_IDEN
       , TFO_CCC_CLI_PER_TID_CODIGO
       , TFO_CCC_NUMERO_CUENTA
       , TFO_REPO
       , TFO_SALDO_GARANTIA_SIM
       , TFO_ESTADO_SIM
       , TFO_CLASIF_INVERSION
       ,TFO_FECHA_COMPRA_INICIAL
	     ,TFO_NPO_PROPORCION_CORTO
       ,TFO_NPO_NOMINAL_CORTO
       ,TFO_NPO_CORTO
       ,TFO_NPO_CUPON
       ,TFO_NUMERO_EMISION_DCV_HIST
       ,TFO_ORIGEN_TITULO -- OMORA F351
      FROM   TITULOS_FONDOS
      WHERE  TFO_FON_CODIGO = P_TFO_FON_CODIGO
      AND    TFO_CODIGO = P_TFO_CODIGO;
   TFO1   C_TITULO%ROWTYPE;
   CURSOR C_PREORDEN_VENTA IS
      SELECT PRV_CONSECUTIVO
            ,PRV_VALOR_NOMINAL
      FROM   PREORDENES_VENTA
      WHERE  PRV_PRF_FON_CODIGO = P_TFO_FON_CODIGO
      AND    PRV_PRF_CONSECUTIVO = P_PRF_CONSECUTIVO
      ORDER BY PRV_CONSECUTIVO;
   PRV1   C_PREORDEN_VENTA%ROWTYPE;
   CURSOR C_PENSIONAL(P_ENA VARCHAR2)  IS
      SELECT ENA_PENSIONAL
      FROM   ESPECIES_NACIONALES
      WHERE  ENA_MNEMONICO = P_ENA;
   ENA2   C_PENSIONAL%ROWTYPE;
   CURSOR C_TFO (P_FDO   VARCHAR2
                ,P_COD   NUMBER) IS
      SELECT TFO_CODIGO
         , TFO_FON_CODIGO
       , TFO_TYPE
       , TFO_ENA_MNEMONICO
       , TFO_ETI_CODIGO
       , TFO_LTI_MNEMONICO
       , TFO_FECHA_OPERACION
       , TFO_VALOR_OPERACION
       , TFO_FECHA_CUMPLIMIENTO
       , TFO_DIA_SIGUIENTE
       , TFO_PRC_PRF_CONSECUTIVO
       , TFO_PRC_CONSECUTIVO
       , TFO_PRV_PRF_CONSECUTIVO
       , TFO_PRV_CONSECUTIVO
       , TFO_FUG_MNEMONICO
       , TFO_FUG_ISI_MNEMONICO
       , TFO_CVS_CONSECUTIVO
       , TFO_CVS_CONSECUTIVO_ES_VENDIDO
       , TFO_BOL_MNEMONICO, TFO_FONDEO
       , TFO_DERIVADO, TFO_CANTIDAD
       , TFO_MERCADO_COMPRA
       , TFO_VALOR_NOMINAL
       , TFO_BMO_MNEMONICO
       , TFO_FECHA_EMISION
       , TFO_FECHA_VENCIMIENTO
       , TFO_PERIODICIDAD_TASA
       , TFO_BASE_CALCULO
       , TFO_MODALIDAD_TASA
       , TFO_TASA_FACIAL
       , TFO_AMORTIZABLE
       , TFO_TRE_MNEMONICO
       , TFO_PUNTOS_ADICIONALES
       , TFO_FECHA_PRIMER_FLUJO
       , TFO_TIPO_PAGO_FLUJO
       , TFO_CAPITALIZABLE
       , TFO_TASA_MRC_CONGELADA
       , TFO_CRUZADA_CONVENIDA
       , TFO_AGE_CODIGO
       , TFO_COMISION_BOLSA
       , TFO_MERCADO
       , TFO_VALOR_UNITARIO
       , TFO_FECHA_CMPLMNTO_ESPECIAL
       , TFO_DISTRIBUCION_ACUMULADA
       , TFO_VALOR_TITULO_TM
       , TFO_FECHA_VALORIZACION
       , TFO_TASA_DESCUENTO
       , TFO_TFA_TIPO_INVERSION
       , TFO_TFA_CLT_MNEMONICO
       , TFO_DURACION
       , TFO_DURACION_MODIFICADA
       , TFO_VAR_TASA
       , TFO_VAR_MONEDA
       , TFO_CONVEXIDAD
       , TFO_NUMERO_EMISION_DCV
       , TFO_LIQ_NUMERO_OPERACION
       , TFO_LIQ_NUMERO_FRACCION
       , TFO_LIQ_TIPO_OPERACION
       , TFO_NUMERO_TITULO_FISICO
       , TFO_REFERENCIA_DECEVAL
       , TFO_LIQ_NUMERO_OPERACION_ES_VE
       , TFO_LIQ_NUMERO_FRACCION_ES_VEN
       , TFO_LIQ_TIPO_OPERACION_ES_VEND
       , TFO_FECHA_VENTA
       , TFO_VALOR_VENTA
       , TFO_PROSPECTO_VENTA
       , TFO_FECHA_PROSPECTO_VENTA
       , TFO_FECHA_VENTA_PLAZO
       , TFO_VALOR_VENTA_PLAZO
       , TFO_ENTE_VENTA_PLAZO
       , TFO_NUM_IDEN_VENTA_PLAZO
       , TFO_TELEFONO_VENTA_PLAZO
       , TFO_DIRECCION_VENTA_PLAZO
       , TFO_VENCIDO_ESPECIAL
       , TFO_LIC_NUMERO_OPERACION
       , TFO_LIC_NUMERO_FRACCION
       , TFO_LIC_TIPO_OPERACION
       , TFO_LIC_BOL_MNEMONICO
       , TFO_GARANTIA_ACTIVA
       , TFO_CODIGO_PERIODO
       , TFO_CALIFICADO
       , TFO_FECHA_CAMBIO_ESTADO
       , TFO_USUARIO_CAMBIO_ESTADO
       , TFO_TERMINAL_CAMBIO_ESTADO
       , TFO_PER_NUM_IDEN
       , TFO_PER_TID_CODIGO
       , TFO_TIPO_GARANTIA
       , TFO_CUENTA_CRCC
       , TFO_SEGMENTO
       , TFO_CCC_CLI_PER_NUM_IDEN
       , TFO_CCC_CLI_PER_TID_CODIGO
       , TFO_CCC_NUMERO_CUENTA
       , TFO_REPO
       , TFO_SALDO_GARANTIA_SIM
       , TFO_ESTADO_SIM
       , TFO_CLASIF_INVERSION
       ,TFO_FECHA_COMPRA_INICIAL
	     ,TFO_NPO_PROPORCION_CORTO
       ,TFO_NPO_NOMINAL_CORTO
       ,TFO_NPO_CORTO
       ,TFO_NPO_CUPON
       ,TFO_NUMERO_EMISION_DCV_HIST
       ,TFO_ORIGEN_TITULO -- OMORA F351
      FROM TITULOS_FONDOS
      WHERE TFO_FON_CODIGO = P_FDO
        AND TFO_CODIGO = P_COD;
   TIT C_TFO%ROWTYPE;
   CURSOR C_CODIGO IS
      SELECT NVL(MAX(TF1.TFO_CODIGO)+ 1 ,1)
      FROM   TITULOS_FONDOS   TF1
      WHERE  TFO_FON_CODIGO = P_TFO_FON_CODIGO;
   TOTAL               NUMBER;
   NVO_COD_TITULO      NUMBER;
   ULTIMO              NUMBER;
   CODIGO_TIT          NUMBER;
   CANTIDAD_NUEVO_TIT  NUMBER;
   PORCENTAJE          NUMBER;
   NO_CODIGO           EXCEPTION;
   NO_INSERCION_TITULO EXCEPTION;
   NO_FRACCION_UNIFIC  EXCEPTION;
BEGIN
   OPEN C_TITULO;
   FETCH C_TITULO INTO TFO1;
   CLOSE C_TITULO;
   IF TFO1.TFO_ETI_CODIGO NOT IN ('VIG','CVE','GAF') THEN
      RAISE_APPLICATION_ERROR(-20064,'El titulo: ' || TO_CHAR(TFO1.TFO_CODIGO)
              ||' se encuentra en un estado que no permite ser vendido');
   ELSE
      OPEN C_PREORDEN_VENTA;
      FETCH C_PREORDEN_VENTA INTO PRV1;
      IF C_PREORDEN_VENTA%NOTFOUND THEN
         RAISE_APPLICATION_ERROR(-20065,'El negocio ' || TO_CHAR(P_PRF_CONSECUTIVO) || ' no tiene ventas');
      END IF;
      IF TFO1.TFO_TYPE = 'TRF' THEN
         IF ABS(TFO1.TFO_VALOR_NOMINAL) = PRV1.PRV_VALOR_NOMINAL THEN
            UPDATE PREORDENES_VENTA
            SET    PRV_TFO_CODIGO = P_TFO_CODIGO
            WHERE  PRV_PRF_FON_CODIGO = P_TFO_FON_CODIGO
            AND    PRV_PRF_CONSECUTIVO = P_PRF_CONSECUTIVO
            AND    PRV_CONSECUTIVO = PRV1.PRV_CONSECUTIVO;
         ELSE
            TOTAL := 0;
            -- Elimina los Flujos del Titulo Original
            P_FLUJOS_FRM.ANULE_FLUJOS(P_TFO_FON_CODIGO, P_TFO_CODIGO);
            WHILE C_PREORDEN_VENTA%FOUND LOOP
               IF TFO1.TFO_ETI_CODIGO = 'GAF' THEN
                  NVO_COD_TITULO := P_CREAR_TITULO_RF.CREAR_TITULO_RF(P_TFO_FON_CODIGO
                                                                     ,P_TFO_CODIGO
                                                                     ,- PRV1.PRV_VALOR_NOMINAL);
               ELSE
                  NVO_COD_TITULO := P_CREAR_TITULO_RF.CREAR_TITULO_RF(P_TFO_FON_CODIGO
                                                                     ,P_TFO_CODIGO
                                                                     ,PRV1.PRV_VALOR_NOMINAL);
               END IF;
               IF NVO_COD_TITULO > 0 THEN
                  UPDATE PREORDENES_VENTA
                  SET    PRV_TFO_CODIGO = NVO_COD_TITULO
                  WHERE  PRV_PRF_FON_CODIGO = P_TFO_FON_CODIGO
                  AND    PRV_PRF_CONSECUTIVO = P_PRF_CONSECUTIVO
                  AND    PRV_CONSECUTIVO = PRV1.PRV_CONSECUTIVO;
                  OPEN C_PENSIONAL(TFO1.TFO_ENA_MNEMONICO);
                  FETCH C_PENSIONAL INTO ENA2;
                  IF NVL(ENA2.ENA_PENSIONAL,'N') = 'S' THEN
                     /* Creacion del flujo de amortizaciones para Titulo de bono pensional */
                     OPEN C_TFO(P_TFO_FON_CODIGO
                               ,NVO_COD_TITULO);
                     FETCH C_TFO INTO TIT;
                     CLOSE C_TFO;
                     P_FLUJOS.GENERE_AMORT_PENSIONAL(TIT);
                  ELSE
                     IF NVL(TFO1.TFO_AMORTIZABLE,'N') = 'N' THEN
                        IF TFO1.TFO_MODALIDAD_TASA != 'D' THEN
                           P_FLUJOS_FRM.FLUJOS_RENDIMIENTOS(P_TFO_FON_CODIGO
                                                           ,NVO_COD_TITULO);
                        END IF;
                        P_FLUJOS_FRM.FLUJOS_AMORTIZACIONES(P_TFO_FON_CODIGO
                                                          ,NVO_COD_TITULO);
                     ELSE
                        P_FLUJOS_FRM.FLUJOS_AMORTIZACIONES(P_TFO_FON_CODIGO
                                                          ,NVO_COD_TITULO);
                        IF TFO1.TFO_MODALIDAD_TASA != 'D' THEN
                           P_FLUJOS_FRM.FLUJOS_RENDIMIENTOS(P_TFO_FON_CODIGO
                                                           ,NVO_COD_TITULO);
                        END IF;
                     END IF;
                  END IF;
                  CLOSE C_PENSIONAL;
                  UPDATE FLUJOS_AMORTIZACION_TITULOS
                  SET    FAT_ESTADO = 'C'
                  WHERE  FAT_TFO_FON_CODIGO = P_TFO_FON_CODIGO
                  AND    FAT_TFO_CODIGO = NVO_COD_TITULO
                  AND    TRUNC(FAT_FECHA) <= TRUNC(P_FECHA);
                  UPDATE FLUJOS_RENDIMIENTOS_TITULOS
                  SET    FRT_ESTADO = 'C'
                  WHERE  FRT_TFO_FON_CODIGO = P_TFO_FON_CODIGO
                  AND    FRT_TFO_CODIGO = NVO_COD_TITULO
                  AND    TRUNC(FRT_FECHA) <= TRUNC(P_FECHA);
               ELSE
                  RAISE NO_CODIGO;
               END IF;
               TOTAL := TOTAL + PRV1.PRV_VALOR_NOMINAL;
               FETCH C_PREORDEN_VENTA INTO PRV1;
            END LOOP;
            CLOSE C_PREORDEN_VENTA;
            ULTIMO := ABS(TFO1.TFO_VALOR_NOMINAL) - TOTAL;
            IF ULTIMO > 0 THEN
               IF TFO1.TFO_ETI_CODIGO = 'GAF' THEN
                  NVO_COD_TITULO := P_CREAR_TITULO_RF.CREAR_TITULO_RF(P_TFO_FON_CODIGO
                                                                     ,TFO1.TFO_CODIGO
                                                                     ,- ULTIMO);
               ELSE
                  NVO_COD_TITULO := P_CREAR_TITULO_RF.CREAR_TITULO_RF(P_TFO_FON_CODIGO
                                                                     ,TFO1.TFO_CODIGO
                                                                     ,ULTIMO);
               END IF;
               IF NVO_COD_TITULO > 0 THEN
                  OPEN C_PENSIONAL(TFO1.TFO_ENA_MNEMONICO);
                  FETCH C_PENSIONAL INTO ENA2;
                  IF NVL(ENA2.ENA_PENSIONAL,'N') = 'S' THEN
                     /* Creacion del flujo de amortizaciones para Titulo de bono pensional */
                     OPEN C_TFO(P_TFO_FON_CODIGO
                               ,NVO_COD_TITULO);
                     FETCH C_TFO INTO TIT;
                     CLOSE C_TFO;
                     P_FLUJOS.GENERE_AMORT_PENSIONAL(TIT);
                  ELSE
                     IF NVL(TFO1.TFO_AMORTIZABLE,'N') = 'N' THEN
                        IF TFO1.TFO_MODALIDAD_TASA != 'D' THEN
                           P_FLUJOS_FRM.FLUJOS_RENDIMIENTOS(P_TFO_FON_CODIGO
                                                           ,NVO_COD_TITULO);
                        END IF;
                        P_FLUJOS_FRM.FLUJOS_AMORTIZACIONES(P_TFO_FON_CODIGO
                                                          ,NVO_COD_TITULO);
                     ELSE
                        P_FLUJOS_FRM.FLUJOS_AMORTIZACIONES(P_TFO_FON_CODIGO
                                                          ,NVO_COD_TITULO);
                        IF TFO1.TFO_MODALIDAD_TASA != 'D' THEN
                           P_FLUJOS_FRM.FLUJOS_RENDIMIENTOS(P_TFO_FON_CODIGO
                                                           ,NVO_COD_TITULO);
                        END IF;
                     END IF;
                  END IF;
                  CLOSE C_PENSIONAL;
                  UPDATE FLUJOS_AMORTIZACION_TITULOS
                  SET    FAT_ESTADO = 'C'
                  WHERE  FAT_TFO_FON_CODIGO = P_TFO_FON_CODIGO
                  AND    FAT_TFO_CODIGO = NVO_COD_TITULO
                  AND    TRUNC(FAT_FECHA) <= TRUNC(P_FECHA);
                  UPDATE FLUJOS_RENDIMIENTOS_TITULOS
                  SET    FRT_ESTADO = 'C'
                  WHERE  FRT_TFO_FON_CODIGO = P_TFO_FON_CODIGO
                  AND    FRT_TFO_CODIGO = NVO_COD_TITULO
                  AND    TRUNC(FRT_FECHA) <= TRUNC(P_FECHA);
               ELSE
                  RAISE NO_CODIGO;
               END IF;
            END IF;
            UPDATE TITULOS_FONDOS
            SET    TFO_ETI_CODIGO = 'FRC'
                  ,TFO_DIA_SIGUIENTE = NULL
            WHERE  TFO_FON_CODIGO = P_TFO_FON_CODIGO
            AND    TFO_CODIGO = TFO1.TFO_CODIGO;
         END IF;
      ELSE
         IF TFO1.TFO_CANTIDAD = PRV1.PRV_VALOR_NOMINAL THEN
            UPDATE PREORDENES_VENTA
            SET    PRV_TFO_CODIGO = TFO1.TFO_CODIGO
            WHERE  PRV_PRF_FON_CODIGO = P_TFO_FON_CODIGO
            AND    PRV_PRF_CONSECUTIVO = P_PRF_CONSECUTIVO
            AND    PRV_CONSECUTIVO = PRV1.PRV_CONSECUTIVO;
         ELSE
            TOTAL := 0;
            P_FLUJOS_FRM.ANULE_FLUJOS(P_TFO_FON_CODIGO
                                     ,TFO1.TFO_CODIGO);
            WHILE C_PREORDEN_VENTA%FOUND LOOP
               OPEN C_CODIGO;
               FETCH C_CODIGO INTO CODIGO_TIT;
               IF C_CODIGO%NOTFOUND THEN
                  CLOSE C_CODIGO;
                  RAISE NO_CODIGO;
               ELSE
                  CLOSE C_CODIGO;
                  UPDATE PREORDENES_VENTA
                  SET    PRV_TFO_CODIGO = CODIGO_TIT
                  WHERE  PRV_PRF_FON_CODIGO = P_TFO_FON_CODIGO
                  AND    PRV_PRF_CONSECUTIVO = P_PRF_CONSECUTIVO
                  AND    PRV_CONSECUTIVO = PRV1.PRV_CONSECUTIVO;
                  CANTIDAD_NUEVO_TIT := PRV1.PRV_VALOR_NOMINAL;
                  PORCENTAJE := CANTIDAD_NUEVO_TIT / TFO1.TFO_CANTIDAD;
                  IF NOT P_FRACCION_ACCION.INSERCION_TITULO(TFO1
                                                           ,CODIGO_TIT
                                                           ,PORCENTAJE
                                                           ,CANTIDAD_NUEVO_TIT) THEN
                     RAISE NO_INSERCION_TITULO;
                  END IF;
                  IF NOT P_FRACCION_ACCION.INSERCION_FRAC_UNIF(P_TFO_FON_CODIGO
                                                              ,TFO1.TFO_CODIGO
                                                              ,CODIGO_TIT
                                                              ,P_FECHA) THEN
                     RAISE NO_FRACCION_UNIFIC;
                  END IF;
                  P_FLUJOS_FRM.FLUJOS_DIVIDENDOS(P_TFO_FON_CODIGO
                                                ,CODIGO_TIT);
                  INSERT INTO MVTOS_ACCION
                     (MAC_FECHA
                     ,MAC_TFO_FON_CODIGO
                     ,MAC_TFO_CODIGO
                     ,MAC_TMT_MNEMONICO
                     ,MAC_MONTO
                     ,MAC_DIVIDENDOS_CAUSADOS
                     ,MAC_DIVIDENDOS_PAGADOS
                     ,MAC_UTILIDAD
                     ,MAC_PERDIDA)
                  VALUES
                     (P_FECHA
                     ,P_TFO_FON_CODIGO
                     ,CODIGO_TIT
                     ,'FRA'
                     ,0
                     ,0
                     ,0
                     ,0
                     ,0);
               END IF;
               TOTAL := TOTAL + PRV1.PRV_VALOR_NOMINAL;
               FETCH C_PREORDEN_VENTA INTO PRV1;
            END LOOP;
            ULTIMO := TFO1.TFO_CANTIDAD - TOTAL;
            IF ULTIMO > 0 THEN
               OPEN C_CODIGO;
               FETCH C_CODIGO INTO CODIGO_TIT;
               IF C_CODIGO%NOTFOUND THEN
                  CLOSE C_CODIGO;
                  RAISE NO_CODIGO;
               ELSE
                  CLOSE C_CODIGO;
                  CANTIDAD_NUEVO_TIT := ULTIMO;
                  PORCENTAJE := CANTIDAD_NUEVO_TIT / TFO1.TFO_CANTIDAD;
                  IF NOT P_FRACCION_ACCION.INSERCION_TITULO(TFO1
                                                           ,CODIGO_TIT
                                                           ,PORCENTAJE
                                                           ,CANTIDAD_NUEVO_TIT) THEN
                     RAISE NO_INSERCION_TITULO;
                  END IF;
                  IF NOT P_FRACCION_ACCION.INSERCION_FRAC_UNIF(P_TFO_FON_CODIGO
                                                              ,TFO1.TFO_CODIGO
                                                              ,CODIGO_TIT
                                                              ,P_FECHA) THEN
                     RAISE NO_FRACCION_UNIFIC;
                  END IF;
                  P_FLUJOS_FRM.FLUJOS_DIVIDENDOS(P_TFO_FON_CODIGO
                                                ,CODIGO_TIT);
                  INSERT INTO MVTOS_ACCION
                     (MAC_FECHA
                     ,MAC_TFO_FON_CODIGO
                     ,MAC_TFO_CODIGO
                     ,MAC_TMT_MNEMONICO
                     ,MAC_MONTO
                     ,MAC_DIVIDENDOS_CAUSADOS
                     ,MAC_DIVIDENDOS_PAGADOS
                     ,MAC_UTILIDAD
                     ,MAC_PERDIDA)
                  VALUES
                     (P_FECHA
                     ,P_TFO_FON_CODIGO
                     ,CODIGO_TIT
                     ,'FRA'
                     ,0
                     ,0
                     ,0
                     ,0
                     ,0);
               END IF;
            END IF;
            UPDATE TITULOS_FONDOS
            SET    TFO_ETI_CODIGO = 'FRC'
                  ,TFO_DIA_SIGUIENTE = NULL
            WHERE  TFO_FON_CODIGO = P_TFO_FON_CODIGO
            AND    TFO_CODIGO = TFO1.TFO_CODIGO;
         END IF;
      END IF;
   END IF;
EXCEPTION
   WHEN NO_CODIGO THEN
      RAISE_APPLICATION_ERROR(-20066,'Error al generar el codigo para el nuevo titulo en el fraccionamiento '
         || ' para el negocio ' || TO_CHAR(P_PRF_CONSECUTIVO));
   WHEN NO_INSERCION_TITULO THEN
      RAISE_APPLICATION_ERROR(-20067,'Error insertanto el titulo:' || TO_CHAR(TFO1.TFO_CODIGO) || ' '
         || SQLERRM);
   WHEN NO_FRACCION_UNIFIC THEN
      RAISE_APPLICATION_ERROR(-20068,'Error fraccionando ' || SQLERRM);
   WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20069,'Error FRACCIONANDO TITULO:' || TO_CHAR(TFO1.TFO_CODIGO) || CHR(13)
         || SQLERRM);
END FRACCION;
/***************************************************************/
PROCEDURE EJECUTAR_PREORDENES_VENTA
   (P_PRF_FON_CODIGO        PREORDENES_FONDOS.PRF_FON_CODIGO%TYPE
   ,P_PRF_CONSECUTIVO       PREORDENES_FONDOS.PRF_CONSECUTIVO%TYPE
   ,P_FECHA                 DATE
   ,P_COMISION              NUMBER
   ,P_TIPO_OPERACION        VARCHAR2)
   IS
   CURSOR C_PREORDEN_VENTA IS
      SELECT PRV_CONSECUTIVO
            ,PRV_TFO_CODIGO
            ,PRV_MONTO
            ,PER_NOMBRE
            ,PRV_NUMERO_OPERACION
            ,PRV_LIC_NUMERO_FRACCION
            ,PRV_LIC_TIPO_OPERACION
            ,PRV_BOL_MNEMONICO
            ,PRV_PER_NUM_IDEN
            ,PRV_PER_TID_CODIGO
            ,PRV_FECHA_CUMPLIMIENTO
            ,PRF_FECHA_OPERACION
            ,PRF_TIPO
            ,PRF_ENA_MNEMONICO
            ,PRV_LTI_MNEMONICO
            ,PRF_BMO_MNEMONICO
            ,PRF_TRE_MNEMONICO
            ,PRF_FECHA_EMISION
            ,PRF_FECHA_VENCIMIENTO
            ,PRV_VALOR_NOMINAL
            ,PRF_PERIODICIDAD_TASA
            ,PRF_BASE_CALCULO
            ,PRF_MODALIDAD_TASA
            ,PRF_PUNTOS_ADICIONALES
            ,PRF_TASA_FACIAL
            ,PRF_AMORTIZABLE
            ,PRF_TIPO_PAGO_FLUJO
            ,PRF_FECHA_PRIMER_FLUJO
            ,PRF_CAPITALIZABLE
            ,PRV_CNE_MNEMONICO
            ,PRV_MERCADO
            ,PRF_CODIGO_PERIODO
            ,PRF_CONSECUTIVO
            ,PRF_PER_NUM_IDEN
            ,PRF_PER_TID_CODIGO
            ,PRV_FECHA_COMPRA_FUTURA
            ,PRV_VALOR_FUTURO
            ,PRV_BASE_CALCULO_FUTURA
            ,PRV_NPO_CONSECUTIVO
            ,PRV_OFD_CONSECUTIVO
      FROM   FILTRO_PERSONAS
            ,PREORDENES_VENTA
            ,PREORDENES_FONDOS
      WHERE  PER_NUM_IDEN = PRV_CLI_PER_NUM_IDEN
      AND    PER_TID_CODIGO = PRV_CLI_PER_TID_CODIGO
      AND    PRF_FON_CODIGO = PRV_PRF_FON_CODIGO
      AND    PRF_CONSECUTIVO = PRV_PRF_CONSECUTIVO
      AND    PRV_PRF_FON_CODIGO = P_PRF_FON_CODIGO
      AND    PRV_PRF_CONSECUTIVO = P_PRF_CONSECUTIVO
      ORDER BY PRV_CONSECUTIVO;
   PRV1   C_PREORDEN_VENTA%ROWTYPE;
   CURSOR C_TITULOS IS
      SELECT TFO_BMO_MNEMONICO
            ,TFO_ETI_CODIGO
            ,TFO_TYPE
      FROM   TITULOS_FONDOS
      WHERE  TFO_CODIGO = PRV1.PRV_TFO_CODIGO
      AND    TFO_FON_CODIGO = P_PRF_FON_CODIGO;
   TFO1   C_TITULOS%ROWTYPE;
   CURSOR C_SIGUIENTE IS
      SELECT MAX(CVS_CONSECUTIVO)
      FROM   COMPRAS_VENTAS_SIN_LIQ;
   SIGUIENTE  NUMBER;
   CURSOR C_COTIZACION_BASE(FECHA  DATE
                           ,BASE   VARCHAR2) IS
      SELECT CBM_VALOR
      FROM   COTIZACIONES_BASE_MONETARIAS
      WHERE  TRUNC(CBM_FECHA) = TRUNC(FECHA)
      AND    CBM_BMO_MNEMONICO = BASE;
   CURSOR C_OPERACION_INTERNA IS
      SELECT NPO_TIPO_REGISTRO
            ,NPO_TIPO_NEGOCIO
      FROM   NEGOCIOS_POSICION
      WHERE  NPO_CONSECUTIVO = PRV1.PRV_NPO_CONSECUTIVO;
   NPO1   C_OPERACION_INTERNA%ROWTYPE;
   COTIZACION      NUMBER;
   P_TFO_CODIGO    NUMBER;
   VALOR_TM        NUMBER;
BEGIN
   OPEN C_PREORDEN_VENTA;
   FETCH C_PREORDEN_VENTA INTO PRV1;
   WHILE C_PREORDEN_VENTA%FOUND LOOP
      IF PRV1.PRF_BMO_MNEMONICO != 'PESOS' THEN
         OPEN C_COTIZACION_BASE(P_FECHA
                               ,PRV1.PRF_BMO_MNEMONICO);
         FETCH C_COTIZACION_BASE INTO COTIZACION;
         IF C_COTIZACION_BASE%NOTFOUND THEN
            CLOSE C_COTIZACION_BASE;
            RAISE_APPLICATION_ERROR(-20070,'Cotizacion Monetaria de ' || PRV1.PRF_BMO_MNEMONICO || ' no encontrada');
         END IF;
         CLOSE C_COTIZACION_BASE;
      ELSE
         COTIZACION := 1;
      END IF;
      IF PRV1.PRV_CNE_MNEMONICO IN ('CON','PLA') AND
         TRUNC(PRV1.PRV_FECHA_CUMPLIMIENTO) != TRUNC(P_FECHA) THEN
         -- Es una operaciżn de venta de contado o plazo que cumple en t+n
         P_NEGOCIOS_POSICION.CREAR_TITULO_POSICION
            (P_PRF_FON_CODIGO           => P_PRF_FON_CODIGO
            ,P_PRF_TIPO                 => PRV1.PRF_TIPO
            ,P_PRF_TIPO_NEGOCIO         => 'V'
            ,P_PRF_ENA_MNEMONICO        => PRV1.PRF_ENA_MNEMONICO
            ,P_PRF_BMO_MNEMONICO        => PRV1.PRF_BMO_MNEMONICO
            ,P_PRF_TRE_MNEMONICO        => PRV1.PRF_TRE_MNEMONICO
            ,P_PRF_FECHA_EMISION        => PRV1.PRF_FECHA_EMISION
            ,P_PRF_FECHA_VENCIMIENTO    => PRV1.PRF_FECHA_VENCIMIENTO
            ,P_PRF_PERIODICIDAD_TASA    => PRV1.PRF_PERIODICIDAD_TASA
            ,P_PRF_BASE_CALCULO         => PRV1.PRF_BASE_CALCULO
            ,P_PRF_MODALIDAD_TASA       => PRV1.PRF_MODALIDAD_TASA
            ,P_PRF_PUNTOS_ADICIONALES   => PRV1.PRF_PUNTOS_ADICIONALES
            ,P_PRF_TASA_FACIAL          => PRV1.PRF_TASA_FACIAL
            ,P_PRF_AMORTIZABLE          => PRV1.PRF_AMORTIZABLE
            ,P_PRF_TIPO_PAGO_FLUJO      => PRV1.PRF_TIPO_PAGO_FLUJO
            ,P_PRF_FECHA_PRIMER_FLUJO   => PRV1.PRF_FECHA_PRIMER_FLUJO
            ,P_PRF_CAPITALIZABLE        => PRV1.PRF_CAPITALIZABLE
            ,P_PRF_CODIGO_PERIODO       => PRV1.PRF_CODIGO_PERIODO
            ,P_PRF_CONSECUTIVO          => P_PRF_CONSECUTIVO
            ,P_PRF_PER_NUM_IDEN         => PRV1.PRF_PER_NUM_IDEN
            ,P_PRF_PER_TID_CODIGO       => PRV1.PRF_PER_TID_CODIGO
            ,P_PRC_LTI_MNEMONICO        => PRV1.PRV_LTI_MNEMONICO
            ,P_PRC_MONTO                => PRV1.PRV_MONTO
            ,P_PRC_VALOR_NOMINAL        => PRV1.PRV_VALOR_NOMINAL
            ,P_PRC_CNE_MNEMONICO        => PRV1.PRV_CNE_MNEMONICO
            ,P_PRC_MERCADO              => PRV1.PRV_MERCADO
            ,P_PRC_CONSECUTIVO          => NULL
            ,P_PRC_BOL_MNEMONICO        => PRV1.PRV_BOL_MNEMONICO
            ,P_PRC_NUMERO_OPERACION     => PRV1.PRV_NUMERO_OPERACION
            ,P_PRC_LIC_TIPO_OPERACION   => PRV1.PRV_LIC_TIPO_OPERACION
            ,P_PRC_LIC_NUMERO_FRACCION  => PRV1.PRV_LIC_NUMERO_FRACCION
            ,P_PRC_PER_NUM_IDEN         => PRV1.PRV_PER_NUM_IDEN
            ,P_PRC_PER_TID_CODIGO       => PRV1.PRV_PER_TID_CODIGO
            ,P_PRV_CONSECUTIVO          => PRV1.PRV_CONSECUTIVO
            ,P_FECHA                    => P_FECHA
            ,P_ETI_CODIGO               => 'VIG'
            ,P_COTIZACION               => COTIZACION
            ,P_MRF_TMT_MNEMONICO        => 'OVE'
            ,P_INSERTA_CVS              => 'N'
            ,P_MVTO_CVS                 => NULL
            ,P_CVS_CONSECUTIVO          => SIGUIENTE
            ,P_TFO_CODIGO               => P_TFO_CODIGO
            ,P_TOTAL_TC                 => NULL
            ,P_FECHA_CUMPLIMIENTO       => PRV1.PRV_FECHA_CUMPLIMIENTO
            ,P_VALOR_TM                 => VALOR_TM);
         P_NEGOCIOS_POSICION.CREAR_TITULO_POSICION
            (P_PRF_FON_CODIGO           => P_PRF_FON_CODIGO
            ,P_PRF_TIPO                 => PRV1.PRF_TIPO
            ,P_PRF_TIPO_NEGOCIO         => 'V'
            ,P_PRF_ENA_MNEMONICO        => PRV1.PRF_ENA_MNEMONICO
            ,P_PRF_BMO_MNEMONICO        => 'PESOS'
            ,P_PRF_TRE_MNEMONICO        => NULL
            ,P_PRF_FECHA_EMISION        => P_FECHA
            ,P_PRF_FECHA_VENCIMIENTO    => PRV1.PRV_FECHA_CUMPLIMIENTO
            ,P_PRF_PERIODICIDAD_TASA    => 0
            ,P_PRF_BASE_CALCULO         => PRV1.PRV_BASE_CALCULO_FUTURA
            ,P_PRF_MODALIDAD_TASA       => 'D'
            ,P_PRF_PUNTOS_ADICIONALES   => NULL
            ,P_PRF_TASA_FACIAL          => 0
            ,P_PRF_AMORTIZABLE          => NULL
            ,P_PRF_TIPO_PAGO_FLUJO      => NULL
            ,P_PRF_FECHA_PRIMER_FLUJO   => NULL
            ,P_PRF_CAPITALIZABLE        => NULL
            ,P_PRF_CODIGO_PERIODO       => 'D'
            ,P_PRF_CONSECUTIVO          => P_PRF_CONSECUTIVO
            ,P_PRF_PER_NUM_IDEN         => PRV1.PRF_PER_NUM_IDEN
            ,P_PRF_PER_TID_CODIGO       => PRV1.PRF_PER_TID_CODIGO
            ,P_PRC_LTI_MNEMONICO        => PRV1.PRV_LTI_MNEMONICO
            ,P_PRC_MONTO                => VALOR_TM
            ,P_PRC_VALOR_NOMINAL        => PRV1.PRV_MONTO
            ,P_PRC_CNE_MNEMONICO        => PRV1.PRV_CNE_MNEMONICO
            ,P_PRC_MERCADO              => NULL
            ,P_PRC_CONSECUTIVO          => NULL
            ,P_PRC_BOL_MNEMONICO        => PRV1.PRV_BOL_MNEMONICO
            ,P_PRC_NUMERO_OPERACION     => PRV1.PRV_NUMERO_OPERACION
            ,P_PRC_LIC_TIPO_OPERACION   => PRV1.PRV_LIC_TIPO_OPERACION
            ,P_PRC_LIC_NUMERO_FRACCION  => PRV1.PRV_LIC_NUMERO_FRACCION
            ,P_PRC_PER_NUM_IDEN         => PRV1.PRV_PER_NUM_IDEN
            ,P_PRC_PER_TID_CODIGO       => PRV1.PRV_PER_TID_CODIGO
            ,P_PRV_CONSECUTIVO          => PRV1.PRV_CONSECUTIVO
            ,P_FECHA                    => P_FECHA
            ,P_ETI_CODIGO               => 'VIG'
            ,P_COTIZACION               => COTIZACION
            ,P_MRF_TMT_MNEMONICO        => 'DVE'
            ,P_INSERTA_CVS              => 'N'
            ,P_MVTO_CVS                 => NULL
            ,P_CVS_CONSECUTIVO          => SIGUIENTE
            ,P_TFO_CODIGO               => P_TFO_CODIGO
            ,P_TOTAL_TC                 => NULL
            ,P_FECHA_CUMPLIMIENTO       => PRV1.PRV_FECHA_CUMPLIMIENTO
            ,P_VALOR_TM                 => VALOR_TM);
      ELSE
         IF PRV1.PRV_TFO_CODIGO IS NULL THEN
            RAISE_APPLICATION_ERROR(-20071,'El negocio ' || TO_CHAR(P_PRF_CONSECUTIVO)
               || ' no tiene titulos asociados para la venta');
         END IF;
         OPEN C_TITULOS;
         FETCH C_TITULOS INTO TFO1;
         CLOSE C_TITULOS;
         IF TFO1.TFO_ETI_CODIGO NOT IN ('VIG','GAF') THEN
            RAISE_APPLICATION_ERROR(-20072,'El negocio ' || TO_CHAR(P_PRF_CONSECUTIVO)
               || ' tiene titulos que ya no estan vigentes');
         END IF;

         OPEN C_OPERACION_INTERNA;
         FETCH C_OPERACION_INTERNA INTO NPO1;
         CLOSE C_OPERACION_INTERNA;
--         IF NPO1.NPO_TIPO_REGISTRO = 'INTME' AND
--            NPO1.NPO_TIPO_NEGOCIO = 'INT' THEN
--            SIGUIENTE := NULL;
--         ELSE
         SIGUIENTE := NULL;
         OPEN C_SIGUIENTE;
         FETCH C_SIGUIENTE INTO SIGUIENTE;
         CLOSE C_SIGUIENTE;
         SIGUIENTE := NVL(SIGUIENTE,0) + 1;
         INSERT INTO COMPRAS_VENTAS_SIN_LIQ
            (CVS_CONSECUTIVO
            ,CVS_TMT_MNEMONICO
            ,CVS_FON_CODIGO
            ,CVS_VENDEDOR_COMPRADOR
            ,CVS_VALOR_OPERACION
            ,CVS_COMISION
            ,CVS_FECHA_CUMPLIMIENTO
            ,CVS_NUMERO_OPERACION
            ,CVS_TIPO_OPERACION
            ,CVS_NUMERO_FRACCION
            ,CVS_BOL_MNEMONICO
            ,CVS_FECHA_CUMPLIMIENTO_ESPECIA
            ,CVS_PER_NUM_IDEN
            ,CVS_PER_TID_CODIGO
            ,CVS_IDENT_OPERACION_SISTEMA)
         VALUES
            (SIGUIENTE
            ,DECODE(TFO1.TFO_TYPE,'TRF','VRF'
                                 ,'TAC','VRV')
            ,P_PRF_FON_CODIGO
            ,PRV1.PER_NOMBRE
            ,PRV1.PRV_MONTO
            ,P_COMISION
            ,P_FECHA
            ,PRV1.PRV_NUMERO_OPERACION
            ,NVL(PRV1.PRV_LIC_TIPO_OPERACION,'V')
            ,NVL(PRV1.PRV_LIC_NUMERO_FRACCION,0)
            ,PRV1.PRV_BOL_MNEMONICO
            ,P_FECHA
            ,PRV1.PRV_PER_NUM_IDEN
            ,PRV1.PRV_PER_TID_CODIGO
            ,DECODE(TFO1.TFO_TYPE,'TRF','R'
                                 ,'TAC',NULL));
--         END IF;
         UPDATE TITULOS_FONDOS
         SET    TFO_ETI_CODIGO = 'VEN'
               ,TFO_FECHA_VENTA = P_FECHA
               ,TFO_VALOR_VENTA = PRV1.PRV_MONTO
               ,TFO_PRV_PRF_CONSECUTIVO = P_PRF_CONSECUTIVO
               ,TFO_PRV_CONSECUTIVO = PRV1.PRV_CONSECUTIVO
               ,TFO_CVS_CONSECUTIVO_ES_VENDIDO = SIGUIENTE
         WHERE  TFO_CODIGO = PRV1.PRV_TFO_CODIGO
         AND    TFO_FON_CODIGO = P_PRF_FON_CODIGO;
         IF TFO1.TFO_ETI_CODIGO = 'GAF' THEN
            UPDATE FLUJOS_RENDIMIENTOS_TITULOS
            SET    FRT_ESTADO = 'A'
            WHERE  FRT_TFO_FON_CODIGO = P_PRF_FON_CODIGO
            AND    FRT_TFO_CODIGO = PRV1.PRV_TFO_CODIGO
            AND    FRT_ESTADO = 'V';
            UPDATE FLUJOS_AMORTIZACION_TITULOS
            SET    FAT_ESTADO = 'A'
            WHERE  FAT_TFO_FON_CODIGO = P_PRF_FON_CODIGO
            AND    FAT_TFO_CODIGO = PRV1.PRV_TFO_CODIGO
            AND    FAT_ESTADO = 'V';
         END IF;
         IF P_TIPO_OPERACION = 'POS' AND
            PRV1.PRV_CNE_MNEMONICO = 'SIM' THEN
            P_NEGOCIOS_POSICION.CREAR_TITULO_POSICION
               (P_PRF_FON_CODIGO           => P_PRF_FON_CODIGO
               ,P_PRF_TIPO                 => PRV1.PRF_TIPO
               ,P_PRF_TIPO_NEGOCIO         => 'V'
               ,P_PRF_ENA_MNEMONICO        => PRV1.PRF_ENA_MNEMONICO
               ,P_PRF_BMO_MNEMONICO        => PRV1.PRF_BMO_MNEMONICO
               ,P_PRF_TRE_MNEMONICO        => PRV1.PRF_TRE_MNEMONICO
               ,P_PRF_FECHA_EMISION        => PRV1.PRF_FECHA_EMISION
               ,P_PRF_FECHA_VENCIMIENTO    => PRV1.PRF_FECHA_VENCIMIENTO
               ,P_PRF_PERIODICIDAD_TASA    => PRV1.PRF_PERIODICIDAD_TASA
               ,P_PRF_BASE_CALCULO         => PRV1.PRF_BASE_CALCULO
               ,P_PRF_MODALIDAD_TASA       => PRV1.PRF_MODALIDAD_TASA
               ,P_PRF_PUNTOS_ADICIONALES   => PRV1.PRF_PUNTOS_ADICIONALES
               ,P_PRF_TASA_FACIAL          => PRV1.PRF_TASA_FACIAL
               ,P_PRF_AMORTIZABLE          => PRV1.PRF_AMORTIZABLE
               ,P_PRF_TIPO_PAGO_FLUJO      => PRV1.PRF_TIPO_PAGO_FLUJO
               ,P_PRF_FECHA_PRIMER_FLUJO   => PRV1.PRF_FECHA_PRIMER_FLUJO
               ,P_PRF_CAPITALIZABLE        => PRV1.PRF_CAPITALIZABLE
               ,P_PRF_CODIGO_PERIODO       => PRV1.PRF_CODIGO_PERIODO
               ,P_PRF_CONSECUTIVO          => P_PRF_CONSECUTIVO
               ,P_PRF_PER_NUM_IDEN         => PRV1.PRF_PER_NUM_IDEN
               ,P_PRF_PER_TID_CODIGO       => PRV1.PRF_PER_TID_CODIGO
               ,P_PRC_LTI_MNEMONICO        => PRV1.PRV_LTI_MNEMONICO
               ,P_PRC_MONTO                => PRV1.PRV_MONTO
               ,P_PRC_VALOR_NOMINAL        => PRV1.PRV_VALOR_NOMINAL
               ,P_PRC_CNE_MNEMONICO        => PRV1.PRV_CNE_MNEMONICO
               ,P_PRC_MERCADO              => PRV1.PRV_MERCADO
               ,P_PRC_CONSECUTIVO          => NULL
               ,P_PRC_BOL_MNEMONICO        => PRV1.PRV_BOL_MNEMONICO
               ,P_PRC_NUMERO_OPERACION     => PRV1.PRV_NUMERO_OPERACION
               ,P_PRC_LIC_TIPO_OPERACION   => PRV1.PRV_LIC_TIPO_OPERACION
               ,P_PRC_LIC_NUMERO_FRACCION  => PRV1.PRV_LIC_NUMERO_FRACCION
               ,P_PRC_PER_NUM_IDEN         => PRV1.PRV_PER_NUM_IDEN
               ,P_PRC_PER_TID_CODIGO       => PRV1.PRV_PER_TID_CODIGO
               ,P_PRV_CONSECUTIVO          => PRV1.PRV_CONSECUTIVO
               ,P_FECHA                    => P_FECHA
               ,P_ETI_CODIGO               => 'VIG'
               ,P_COTIZACION               => COTIZACION
               ,P_MRF_TMT_MNEMONICO        => 'FPA'
               ,P_INSERTA_CVS              => 'N'
               ,P_MVTO_CVS                 => NULL
               ,P_CVS_CONSECUTIVO          => SIGUIENTE
               ,P_TFO_CODIGO               => P_TFO_CODIGO
               ,P_TOTAL_TC                 => NULL
               ,P_FECHA_CUMPLIMIENTO       => PRV1.PRV_FECHA_CUMPLIMIENTO
               ,P_VALOR_TM                 => VALOR_TM);
            P_NEGOCIOS_POSICION.CREAR_TITULO_POSICION
               (P_PRF_FON_CODIGO           => P_PRF_FON_CODIGO
               ,P_PRF_TIPO                 => PRV1.PRF_TIPO
               ,P_PRF_TIPO_NEGOCIO         => 'V'
               ,P_PRF_ENA_MNEMONICO        => PRV1.PRF_ENA_MNEMONICO
               ,P_PRF_BMO_MNEMONICO        => 'PESOS'
               ,P_PRF_TRE_MNEMONICO        => NULL
               ,P_PRF_FECHA_EMISION        => P_FECHA
               ,P_PRF_FECHA_VENCIMIENTO    => PRV1.PRV_FECHA_COMPRA_FUTURA
               ,P_PRF_PERIODICIDAD_TASA    => 0
               ,P_PRF_BASE_CALCULO         => PRV1.PRV_BASE_CALCULO_FUTURA
               ,P_PRF_MODALIDAD_TASA       => 'D'
               ,P_PRF_PUNTOS_ADICIONALES   => NULL
               ,P_PRF_TASA_FACIAL          => 0
               ,P_PRF_AMORTIZABLE          => NULL
               ,P_PRF_TIPO_PAGO_FLUJO      => NULL
               ,P_PRF_FECHA_PRIMER_FLUJO   => NULL
               ,P_PRF_CAPITALIZABLE        => NULL
               ,P_PRF_CODIGO_PERIODO       => 'D'
               ,P_PRF_CONSECUTIVO          => P_PRF_CONSECUTIVO
               ,P_PRF_PER_NUM_IDEN         => PRV1.PRF_PER_NUM_IDEN
               ,P_PRF_PER_TID_CODIGO       => PRV1.PRF_PER_TID_CODIGO
               ,P_PRC_LTI_MNEMONICO        => PRV1.PRV_LTI_MNEMONICO
               ,P_PRC_MONTO                => PRV1.PRV_MONTO
               ,P_PRC_VALOR_NOMINAL        => PRV1.PRV_VALOR_FUTURO
               ,P_PRC_CNE_MNEMONICO        => PRV1.PRV_CNE_MNEMONICO
               ,P_PRC_MERCADO              => NULL
               ,P_PRC_CONSECUTIVO          => NULL
               ,P_PRC_BOL_MNEMONICO        => PRV1.PRV_BOL_MNEMONICO
               ,P_PRC_NUMERO_OPERACION     => PRV1.PRV_NUMERO_OPERACION
               ,P_PRC_LIC_TIPO_OPERACION   => PRV1.PRV_LIC_TIPO_OPERACION
               ,P_PRC_LIC_NUMERO_FRACCION  => PRV1.PRV_LIC_NUMERO_FRACCION
               ,P_PRC_PER_NUM_IDEN         => PRV1.PRV_PER_NUM_IDEN
               ,P_PRC_PER_TID_CODIGO       => PRV1.PRV_PER_TID_CODIGO
               ,P_PRV_CONSECUTIVO          => PRV1.PRV_CONSECUTIVO
               ,P_FECHA                    => P_FECHA
               ,P_ETI_CODIGO               => 'VIG'
               ,P_COTIZACION               => COTIZACION
               ,P_MRF_TMT_MNEMONICO        => 'FPF'
               ,P_INSERTA_CVS              => 'N'
               ,P_MVTO_CVS                 => NULL
               ,P_CVS_CONSECUTIVO          => SIGUIENTE
               ,P_TFO_CODIGO               => P_TFO_CODIGO
               ,P_TOTAL_TC                 => NULL
               ,P_FECHA_CUMPLIMIENTO       => PRV1.PRV_FECHA_CUMPLIMIENTO
               ,P_VALOR_TM                 => VALOR_TM);
         ELSIF P_TIPO_OPERACION = 'POSF' AND
            PRV1.PRV_CNE_MNEMONICO IN ('SIM','CON','PLA') THEN
            /* Se verifica si se esta ejecutando una recompra de una venta fondeada */
            UPDATE TITULOS_FONDOS
            SET    TFO_ETI_CODIGO = 'COV'
            WHERE  TFO_ETI_CODIGO = 'VIG'
            AND    TFO_DERIVADO = 'S'
            AND    TFO_FONDEO = 'N'
            AND    TFO_FON_CODIGO = P_PRF_FON_CODIGO
            AND    TFO_PRV_PRF_CONSECUTIVO = P_PRF_CONSECUTIVO
            AND    TFO_PRV_CONSECUTIVO = PRV1.PRV_CONSECUTIVO;
         END IF;
      END IF;
      FETCH C_PREORDEN_VENTA INTO PRV1;
   END LOOP;
   CLOSE C_PREORDEN_VENTA;
EXCEPTION
   WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20073,'Error ejecutando venta del negocio ' || TO_CHAR(P_PRF_CONSECUTIVO) || ' ' ||
         SQLERRM);
END EJECUTAR_PREORDENES_VENTA;
/**************************************************************************/
PROCEDURE CALCULAR_COMISION_PRIMARIO
   (P_PRF_FON_CODIGO         PREORDENES_FONDOS.PRF_FON_CODIGO%TYPE
   ,P_PRF_CONSECUTIVO        PREORDENES_FONDOS.PRF_CONSECUTIVO%TYPE
   ,P_NPO_CONSECUTIVO        NEGOCIOS_POSICION.NPO_CONSECUTIVO%TYPE)
   IS
   CURSOR C_NEGOCIOS_POSICION IS
      SELECT NPO_TIPO_PRIMARIO
            ,NPO_ESTADO
            ,PPO_TASA_EFECTIVA
            ,PPO_PERIODICIDAD_TASA
            ,PPO_BASE_CALCULO
            ,CCC_CLI_PER_NUM_IDEN
            ,CCC_CLI_PER_TID_CODIGO
            ,CCC_NUMERO_CUENTA
            ,CCC_PER_NUM_IDEN
            ,CCC_PER_TID_CODIGO
      FROM   NEGOCIOS_POSICION
            ,PORTAFOLIOS_POSICION
            ,ORDENES_VENTA
            ,CUENTAS_CLIENTE_CORREDORES
      WHERE  NPO_CONSECUTIVO = P_NPO_CONSECUTIVO
      AND    NPO_PPO_CONSECUTIVO = PPO_CONSECUTIVO
      AND    NPO_OVE_CONSECUTIVO = OVE_CONSECUTIVO
      AND    NPO_OVE_BOL_MNEMONICO = OVE_BOL_MNEMONICO
      AND    NPO_OVE_COC_CTO_MNEMONICO = OVE_COC_CTO_MNEMONICO
      AND    OVE_CCC_CLI_PER_NUM_IDEN = CCC_CLI_PER_NUM_IDEN
      AND    OVE_CCC_CLI_PER_TID_CODIGO = CCC_CLI_PER_TID_CODIGO
      AND    OVE_CCC_NUMERO_CUENTA = CCC_NUMERO_CUENTA;
   NPO1   C_NEGOCIOS_POSICION%ROWTYPE;
   CURSOR C_RENOV_SIN_COMPLEMENTAR IS
      SELECT 'X'
      FROM   OFERTAS_DEMANDAS_POSICION
      WHERE  OFD_NPO_CONSECUTIVO = P_NPO_CONSECUTIVO
      AND    OFD_ESTADO NOT IN ('ANU','COM');
   CURSOR C_OFERTAS_DEMANDAS_POSICION(P_ESTADO  OFERTAS_DEMANDAS_POSICION.OFD_ESTADO%TYPE) IS
      SELECT OFD_CONSECUTIVO
            ,OFD_VALOR_PESOS_ADQUIRIDO
            ,OFD_NOMINAL_ADQUIRIDO
            ,CCC_CLI_PER_NUM_IDEN
            ,CCC_CLI_PER_TID_CODIGO
            ,CCC_NUMERO_CUENTA
            ,CCC_PER_NUM_IDEN
            ,CCC_PER_TID_CODIGO
      FROM   OFERTAS_DEMANDAS_POSICION
            ,ORDENES_COMPRA
            ,CUENTAS_CLIENTE_CORREDORES
      WHERE  OFD_NPO_CONSECUTIVO = P_NPO_CONSECUTIVO
      AND    OFD_ESTADO = P_ESTADO
      AND    OFD_OCO_CONSECUTIVO = OCO_CONSECUTIVO
      AND    OFD_OCO_BOL_MNEMONICO = OCO_BOL_MNEMONICO
      AND    OFD_OCO_COC_CTO_MNEMONICO = OCO_COC_CTO_MNEMONICO
      AND    OCO_CCC_CLI_PER_NUM_IDEN = CCC_CLI_PER_NUM_IDEN
      AND    OCO_CCC_CLI_PER_TID_CODIGO = CCC_CLI_PER_TID_CODIGO
      AND    OCO_CCC_NUMERO_CUENTA = CCC_NUMERO_CUENTA;
   OFD1   C_OFERTAS_DEMANDAS_POSICION%ROWTYPE;
   CURSOR C_CONSTANTES IS
      SELECT CON_VALOR
      FROM   CONSTANTES
      WHERE  CON_MNEMONICO = 'CCP';
   CON1   C_CONSTANTES%ROWTYPE;
   CURSOR C_CONSTANTES_CLI IS
      SELECT CON_VALOR
      FROM   CONSTANTES
      WHERE  CON_MNEMONICO = 'CEP';
   CON2   C_CONSTANTES%ROWTYPE;
   COMISION       NUMBER;
   PORC           NUMBER;
   TOTAL_COM      NUMBER;
   COMISION_C     NUMBER;
   COMISION_V     NUMBER;
   COMISION_CLI   NUMBER;
   TOTAL_COM_CLI  NUMBER;
   COMISION_C_CLI NUMBER;
   COMISION_V_CLI NUMBER;
   COND           VARCHAR2(1);
   SIGUIENTE      NUMBER;
BEGIN
   OPEN C_NEGOCIOS_POSICION;
   FETCH C_NEGOCIOS_POSICION INTO NPO1;
   CLOSE C_NEGOCIOS_POSICION;
   IF NPO1.NPO_ESTADO != 'ECO' AND
      NPO1.NPO_TIPO_PRIMARIO != 'R' THEN
      RAISE_APPLICATION_ERROR(-20074,'El negocio primario ' || TO_CHAR(P_NPO_CONSECUTIVO)
         || ' no se encuentra en estado ECO Ejecuciżn COEASY');
   END IF;
   IF NPO1.NPO_ESTADO != 'COM' AND
      NPO1.NPO_TIPO_PRIMARIO = 'R' THEN
      RAISE_APPLICATION_ERROR(-20075,'La renovaciżn ' || TO_CHAR(P_NPO_CONSECUTIVO)
         || ' no se encuentra en estado COM Complementada');
   END IF;
   OPEN C_CONSTANTES;
   FETCH C_CONSTANTES INTO CON1;
   IF C_CONSTANTES%NOTFOUND THEN
      CLOSE C_CONSTANTES;
      RAISE_APPLICATION_ERROR(-20076,'No se encontro el valor de la constante '
         || ' CPP comision comercial emisor primario');
   END IF;
   CLOSE C_CONSTANTES;
   OPEN C_CONSTANTES_CLI;
   FETCH C_CONSTANTES_CLI INTO CON2;
   IF C_CONSTANTES_CLI%NOTFOUND THEN
      CLOSE C_CONSTANTES_CLI;
      RAISE_APPLICATION_ERROR(-20077,'No se encontro el valor de la constante '
         || ' CEP comision cliente emisor primario');
   END IF;
   CLOSE C_CONSTANTES_CLI;
   CON1.CON_VALOR := NVL(CON1.CON_VALOR,0);
   TOTAL_COM := 0;
   COMISION_C := 0;
   COMISION_V := 0;
   CON2.CON_VALOR := NVL(CON2.CON_VALOR,0);
   TOTAL_COM_CLI := 0;
   COMISION_C_CLI := 0;
   COMISION_V_CLI := 0;
   IF NPO1.NPO_TIPO_PRIMARIO = 'R' THEN
      OPEN C_RENOV_SIN_COMPLEMENTAR;
      FETCH C_RENOV_SIN_COMPLEMENTAR INTO COND;
      CLOSE C_RENOV_SIN_COMPLEMENTAR;
      IF NVL(COND,' ') = 'X' THEN
         RAISE_APPLICATION_ERROR(-20078,'Hay renovaciones que no se encuntran en estado COM Complementado.'
            || ' Complemente primero las renovaciones de clientes');
      END IF;
      OPEN C_OFERTAS_DEMANDAS_POSICION('COM');
   ELSE
      OPEN C_OFERTAS_DEMANDAS_POSICION('ECO');
   END IF;
   FETCH C_OFERTAS_DEMANDAS_POSICION INTO OFD1;
   WHILE C_OFERTAS_DEMANDAS_POSICION%FOUND LOOP
      IF NPO1.NPO_TIPO_PRIMARIO = 'M' THEN
         COMISION_V := OFD1.OFD_VALOR_PESOS_ADQUIRIDO - OFD1.OFD_NOMINAL_ADQUIRIDO;
      ELSIF NPO1.NPO_TIPO_PRIMARIO IN ('C','R') THEN
         PORC := P_NEGOCIOS_POSICION.PORCENTAJE_COMISION
                    (P_NPO_CONSECUTIVO       => P_NPO_CONSECUTIVO
                    ,P_TASA_EFECTIVA_EMI     => NPO1.PPO_TASA_EFECTIVA
                    ,P_PPO_PERIODICIDAD_TASA => NPO1.PPO_PERIODICIDAD_TASA
                    ,P_PPO_BASE_CALCULO      => NPO1.PPO_BASE_CALCULO
                    ,P_TASA                  => NULL);
         COMISION_V := ROUND(OFD1.OFD_NOMINAL_ADQUIRIDO * PORC/100,2);
      ELSE
         COMISION_V := 0;
      END IF;
      COMISION_V_CLI := COMISION_V;
      COMISION := ROUND(COMISION_V * (100 - CON1.CON_VALOR) / 100,2);
      COMISION_C := COMISION_C + (COMISION_V - COMISION);
      TOTAL_COM := TOTAL_COM + ROUND(COMISION_V,2);
      COMISION_CLI := ROUND(COMISION_V_CLI * (100 - CON2.CON_VALOR) / 100,2);
      COMISION_C_CLI := COMISION_C_CLI + (COMISION_V_CLI - COMISION_CLI);
      TOTAL_COM_CLI := TOTAL_COM_CLI + ROUND(COMISION_V_CLI,2);
      SELECT CPP_SEQ.NEXTVAL INTO SIGUIENTE FROM DUAL;
      INSERT INTO COMISIONES_POSICION_PROPIA
         (CPP_CONSECUTIVO
         ,CPP_PORCENTAJE_COMISION
         ,CPP_VALOR_COMISION
         ,CPP_CCC_CLI_PER_NUM_IDEN
         ,CPP_CCC_CLI_PER_TID_CODIGO
         ,CPP_CCC_NUMERO_CUENTA
         ,CPP_PER_NUM_IDEN
         ,CPP_PER_TID_CODIGO
         ,CPP_NPO_CONSECUTIVO
         ,CPP_OFD_CONSECUTIVO
         ,CPP_PORCENTAJE_COMISION_CLI
         ,CPP_VALOR_COMISION_CLI)
      VALUES
         (SIGUIENTE
         ,0
         ,COMISION
         ,OFD1.CCC_CLI_PER_NUM_IDEN
         ,OFD1.CCC_CLI_PER_TID_CODIGO
         ,OFD1.CCC_NUMERO_CUENTA
         ,OFD1.CCC_PER_NUM_IDEN
         ,OFD1.CCC_PER_TID_CODIGO
         ,P_NPO_CONSECUTIVO
         ,OFD1.OFD_CONSECUTIVO
         ,0
         ,COMISION_CLI);
      FETCH C_OFERTAS_DEMANDAS_POSICION INTO OFD1;
   END LOOP;
   CLOSE C_OFERTAS_DEMANDAS_POSICION;
   IF ROUND(COMISION_C,2) != 0 OR
      ROUND(COMISION_C_CLI,2) != 0 THEN
      SELECT CPP_SEQ.NEXTVAL INTO SIGUIENTE FROM DUAL;
      INSERT INTO COMISIONES_POSICION_PROPIA
         (CPP_CONSECUTIVO
         ,CPP_PORCENTAJE_COMISION
         ,CPP_VALOR_COMISION
         ,CPP_CCC_CLI_PER_NUM_IDEN
         ,CPP_CCC_CLI_PER_TID_CODIGO
         ,CPP_CCC_NUMERO_CUENTA
         ,CPP_PER_NUM_IDEN
         ,CPP_PER_TID_CODIGO
         ,CPP_NPO_CONSECUTIVO
         ,CPP_OFD_CONSECUTIVO
         ,CPP_PORCENTAJE_COMISION_CLI
         ,CPP_VALOR_COMISION_CLI)
      VALUES
         (SIGUIENTE
         ,0
         ,COMISION_C
         ,NPO1.CCC_CLI_PER_NUM_IDEN
         ,NPO1.CCC_CLI_PER_TID_CODIGO
         ,NPO1.CCC_NUMERO_CUENTA
         ,NPO1.CCC_PER_NUM_IDEN
         ,NPO1.CCC_PER_TID_CODIGO
         ,P_NPO_CONSECUTIVO
         ,NULL
         ,0
         ,COMISION_C_CLI);
   END IF;
   UPDATE COMISIONES_POSICION_PROPIA
   SET    CPP_PORCENTAJE_COMISION = ROUND((CPP_VALOR_COMISION / TOTAL_COM) * 100,2)
         ,CPP_PORCENTAJE_COMISION_CLI = ROUND((CPP_VALOR_COMISION_CLI / TOTAL_COM_CLI) * 100,2)
   WHERE  CPP_NPO_CONSECUTIVO = P_NPO_CONSECUTIVO;
   /* Estas instrucciżnes se corren por los redondeos para garantizar que el comercial dueżo
      del emisor es el que coje la diferencia para que la suma de los porcentajes de 100. Si ellos
      estan en ceros se asigna al primer comercial que se encuentre en el query */
   IF ROUND(COMISION_C,2) != 0 THEN
      UPDATE COMISIONES_POSICION_PROPIA CPP1
      SET    CPP1.CPP_PORCENTAJE_COMISION = 100 - NVL((SELECT SUM(CPP2.CPP_PORCENTAJE_COMISION)
                                                       FROM   COMISIONES_POSICION_PROPIA CPP2
                                                       WHERE  CPP2.CPP_NPO_CONSECUTIVO = P_NPO_CONSECUTIVO
                                                       AND    CPP2.CPP_OFD_CONSECUTIVO IS NOT NULL),0)
      WHERE  CPP1.CPP_NPO_CONSECUTIVO = P_NPO_CONSECUTIVO
      AND    CPP1.CPP_OFD_CONSECUTIVO IS NULL;
   ELSE
      UPDATE COMISIONES_POSICION_PROPIA CPP1
      SET    CPP1.CPP_PORCENTAJE_COMISION = 100 - NVL((SELECT SUM(CPP2.CPP_PORCENTAJE_COMISION)
                                                       FROM   COMISIONES_POSICION_PROPIA CPP2
                                                       WHERE  CPP2.CPP_NPO_CONSECUTIVO = P_NPO_CONSECUTIVO
                                                       AND    CPP2.CPP_OFD_CONSECUTIVO != (SELECT MIN(CPP3.CPP_OFD_CONSECUTIVO)
                                                                                           FROM   COMISIONES_POSICION_PROPIA CPP3
                                                                                           WHERE  CPP3.CPP_NPO_CONSECUTIVO = P_NPO_CONSECUTIVO)),0)
      WHERE  CPP1.CPP_NPO_CONSECUTIVO = P_NPO_CONSECUTIVO
      AND    CPP1.CPP_OFD_CONSECUTIVO = (SELECT MIN(CPP3.CPP_OFD_CONSECUTIVO)
                                         FROM   COMISIONES_POSICION_PROPIA CPP3
                                         WHERE  CPP3.CPP_NPO_CONSECUTIVO = P_NPO_CONSECUTIVO);
   END IF;
   IF ROUND(COMISION_C_CLI,2) != 0 THEN
      UPDATE COMISIONES_POSICION_PROPIA CPP1
      SET    CPP1.CPP_PORCENTAJE_COMISION_CLI = 100 - NVL((SELECT SUM(CPP2.CPP_PORCENTAJE_COMISION_CLI)
                                                           FROM   COMISIONES_POSICION_PROPIA CPP2
                                                           WHERE  CPP2.CPP_NPO_CONSECUTIVO = P_NPO_CONSECUTIVO
                                                           AND    CPP2.CPP_OFD_CONSECUTIVO IS NOT NULL),0)
      WHERE  CPP1.CPP_NPO_CONSECUTIVO = P_NPO_CONSECUTIVO
      AND    CPP1.CPP_OFD_CONSECUTIVO IS NULL;
   ELSE
      UPDATE COMISIONES_POSICION_PROPIA CPP1
      SET    CPP1.CPP_PORCENTAJE_COMISION_CLI = 100 - NVL((SELECT SUM(CPP2.CPP_PORCENTAJE_COMISION_CLI)
                                                           FROM   COMISIONES_POSICION_PROPIA CPP2
                                                           WHERE  CPP2.CPP_NPO_CONSECUTIVO = P_NPO_CONSECUTIVO
                                                           AND    CPP2.CPP_OFD_CONSECUTIVO != (SELECT MIN(CPP3.CPP_OFD_CONSECUTIVO)
                                                                                               FROM   COMISIONES_POSICION_PROPIA CPP3
                                                                                               WHERE  CPP3.CPP_NPO_CONSECUTIVO = P_NPO_CONSECUTIVO)),0)
      WHERE  CPP1.CPP_NPO_CONSECUTIVO = P_NPO_CONSECUTIVO
      AND    CPP1.CPP_OFD_CONSECUTIVO = (SELECT MIN(CPP3.CPP_OFD_CONSECUTIVO)
                                         FROM   COMISIONES_POSICION_PROPIA CPP3
                                         WHERE  CPP3.CPP_NPO_CONSECUTIVO = P_NPO_CONSECUTIVO);
   END IF;
   /***************************/
   IF NPO1.NPO_TIPO_PRIMARIO != 'R' THEN
      INSERT INTO PARTICIPACIONES_PREORDENES
         SELECT P_PRF_FON_CODIGO
               ,P_PRF_CONSECUTIVO
               ,CPP_PER_NUM_IDEN
               ,CPP_PER_TID_CODIGO
               ,SUM(CPP_PORCENTAJE_COMISION)
         FROM   COMISIONES_POSICION_PROPIA
         WHERE  CPP_NPO_CONSECUTIVO = P_NPO_CONSECUTIVO
         GROUP BY CPP_PER_NUM_IDEN
                 ,CPP_PER_TID_CODIGO
         HAVING SUM(CPP_PORCENTAJE_COMISION) > 0;
   END IF;
EXCEPTION
   WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20079,'Error ejecutando comisiones del negocio ' || TO_CHAR(P_PRF_CONSECUTIVO) || ' ' ||
         SQLERRM);
END CALCULAR_COMISION_PRIMARIO;
/**************************************************************************/
PROCEDURE ANULAR_ORDENES_SIMULTANEAS
   (P_NPO_CONSECUTIVO        NEGOCIOS_POSICION.NPO_CONSECUTIVO%TYPE
   ,P_OFD_CONSECUTIVO        OFERTAS_DEMANDAS_POSICION.OFD_CONSECUTIVO%TYPE
   ,P_ANU_DESCRIPCION        CAMBIOS_ESTADOS_POSICION.CEP_DESCRIPCION%TYPE) IS
   CURSOR C_NEGOCIO IS
      SELECT NPO_OVE_CONSECUTIVO
            ,NPO_OVE_BOL_MNEMONICO
            ,NPO_OVE_COC_CTO_MNEMONICO
            ,NPO_OCO_CONSECUTIVO
            ,NPO_OCO_BOL_MNEMONICO
            ,NPO_OCO_COC_CTO_MNEMONICO
      FROM   NEGOCIOS_POSICION
      WHERE  NPO_CONSECUTIVO = P_NPO_CONSECUTIVO;
   NPO1   C_NEGOCIO%ROWTYPE;
   CURSOR C_OFERTA IS
      SELECT OFD_OVE_CONSECUTIVO
            ,OFD_OVE_BOL_MNEMONICO
            ,OFD_OVE_COC_CTO_MNEMONICO
            ,OFD_OCO_CONSECUTIVO
            ,OFD_OCO_BOL_MNEMONICO
            ,OFD_OCO_COC_CTO_MNEMONICO
      FROM   OFERTAS_DEMANDAS_POSICION
      WHERE  OFD_CONSECUTIVO = P_OFD_CONSECUTIVO
      AND    OFD_ESTADO IN ('COL','DEM','REG','COM');
   OFD1   C_OFERTA%ROWTYPE;
   CURSOR C_ORDENES_NEGOCIO(P_OVE_CONSECUTIVO       ORDENES_VENTA.OVE_CONSECUTIVO%TYPE
                           ,P_OVE_BOL_MNEMONICO     ORDENES_VENTA.OVE_BOL_MNEMONICO%TYPE
                           ,P_OVE_COC_CTO_MNEMONICO ORDENES_VENTA.OVE_COC_CTO_MNEMONICO%TYPE
                           ,P_OCO_CONSECUTIVO       ORDENES_COMPRA.OCO_CONSECUTIVO%TYPE
                           ,P_OCO_BOL_MNEMONICO     ORDENES_COMPRA.OCO_BOL_MNEMONICO%TYPE
                           ,P_OCO_COC_CTO_MNEMONICO ORDENES_COMPRA.OCO_COC_CTO_MNEMONICO%TYPE)IS
      SELECT OCO_CONSECUTIVO        ORD_CONSECUTIVO
            ,OCO_BOL_MNEMONICO      ORD_BOL_MNEMONICO
            ,OCO_COC_CTO_MNEMONICO  ORD_COC_CTO_MNEMONICO
            ,OCO_EOC_MNEMONICO      ORD_EOC_MNEMONICO
            ,'C'                    ORD_TIPO
      FROM   ORDENES_COMPRA
      WHERE  OCO_CONSECUTIVO = P_OCO_CONSECUTIVO
      AND    OCO_BOL_MNEMONICO = P_OCO_BOL_MNEMONICO
      AND    OCO_COC_CTO_MNEMONICO = P_OCO_COC_CTO_MNEMONICO
      UNION
      SELECT OVE_CONSECUTIVO        ORD_CONSECUTIVO
            ,OVE_BOL_MNEMONICO      ORD_BOL_MNEMONICO
            ,OVE_COC_CTO_MNEMONICO  ORD_COC_CTO_MNEMONICO
            ,OVE_EOC_MNEMONICO      ORD_EOC_MNEMONICO
            ,'V'                    ORD_TIPO
      FROM   ORDENES_VENTA
            ,ORDENES_COMPRA
      WHERE  OVE_CONSECUTIVO = OCO_OVE_CONSECUTIVO
      AND    OVE_BOL_MNEMONICO = OCO_BOL_MNEMONICO
      AND    OVE_COC_CTO_MNEMONICO = OCO_COC_CTO_MNEMONICO
      AND    OCO_CONSECUTIVO = P_OCO_CONSECUTIVO
      AND    OCO_BOL_MNEMONICO = P_OCO_BOL_MNEMONICO
      AND    OCO_COC_CTO_MNEMONICO = P_OCO_COC_CTO_MNEMONICO
      UNION
      SELECT OVE_CONSECUTIVO        ORD_CONSECUTIVO
            ,OVE_BOL_MNEMONICO      ORD_BOL_MNEMONICO
            ,OVE_COC_CTO_MNEMONICO  ORD_COC_CTO_MNEMONICO
            ,OVE_EOC_MNEMONICO      ORD_EOC_MNEMONICO
            ,'V'                    ORD_TIPO
      FROM   ORDENES_VENTA
      WHERE  OVE_CONSECUTIVO = P_OVE_CONSECUTIVO
      AND    OVE_BOL_MNEMONICO = P_OVE_BOL_MNEMONICO
      AND    OVE_COC_CTO_MNEMONICO = P_OVE_COC_CTO_MNEMONICO
      UNION
      SELECT OCO_CONSECUTIVO        ORD_CONSECUTIVO
            ,OCO_BOL_MNEMONICO      ORD_BOL_MNEMONICO
            ,OCO_COC_CTO_MNEMONICO  ORD_COC_CTO_MNEMONICO
            ,OCO_EOC_MNEMONICO      ORD_EOC_MNEMONICO
            ,'C'                    ORD_TIPO
      FROM   ORDENES_COMPRA
            ,ORDENES_VENTA
      WHERE  OCO_CONSECUTIVO = OVE_OCO_CONSECUTIVO
      AND    OCO_BOL_MNEMONICO = OVE_BOL_MNEMONICO
      AND    OCO_COC_CTO_MNEMONICO = OVE_COC_CTO_MNEMONICO
      AND    OVE_CONSECUTIVO = P_OVE_CONSECUTIVO
      AND    OVE_BOL_MNEMONICO = P_OVE_BOL_MNEMONICO
      AND    OVE_COC_CTO_MNEMONICO = P_OVE_COC_CTO_MNEMONICO;
   ORD1   C_ORDENES_NEGOCIO%ROWTYPE;
   CURSOR C_ORDEN_DE_PAGO IS
      SELECT ODP_CONSECUTIVO
            ,ODP_ESTADO
      FROM   ORDENES_DE_PAGO
            ,ORDENES_VENTA
      WHERE  ODP_OVE_CONSECUTIVO = ORD1.ORD_CONSECUTIVO
      AND    ODP_OVE_BOL_MNEMONICO = ORD1.ORD_BOL_MNEMONICO
      AND    ODP_OVE_COC_CTO_MNEMONICO = ORD1.ORD_COC_CTO_MNEMONICO
      AND    (ODP_CEG_CONSECUTIVO IS NOT NULL OR
              ODP_CGE_CONSECUTIVO IS NOT NULL OR
              ODP_TBC_CONSECUTIVO IS NOT NULL OR
              ODP_TCC_CONSECUTIVO IS NOT NULL);
   ODP1   C_ORDEN_DE_PAGO%ROWTYPE;
BEGIN
   IF P_NPO_CONSECUTIVO IS NULL AND
      P_OFD_CONSECUTIVO IS NULL THEN
      RAISE_APPLICATION_ERROR(-20080,'El negocio y la oferta estan nulos no puede correr la anulaciżn');
   END IF;
   IF P_NPO_CONSECUTIVO IS NOT NULL THEN
      OPEN C_NEGOCIO;
      FETCH C_NEGOCIO INTO NPO1;
      CLOSE C_NEGOCIO;
      OPEN C_ORDENES_NEGOCIO(NPO1.NPO_OVE_CONSECUTIVO
                            ,NPO1.NPO_OVE_BOL_MNEMONICO
                            ,NPO1.NPO_OVE_COC_CTO_MNEMONICO
                            ,NPO1.NPO_OCO_CONSECUTIVO
                            ,NPO1.NPO_OCO_BOL_MNEMONICO
                            ,NPO1.NPO_OCO_COC_CTO_MNEMONICO);
   ELSE
      IF P_OFD_CONSECUTIVO IS NOT NULL THEN
         OPEN C_OFERTA;
         FETCH C_OFERTA INTO OFD1;
         CLOSE C_OFERTA;
         OPEN C_ORDENES_NEGOCIO(OFD1.OFD_OVE_CONSECUTIVO
                               ,OFD1.OFD_OVE_BOL_MNEMONICO
                               ,OFD1.OFD_OVE_COC_CTO_MNEMONICO
                               ,OFD1.OFD_OCO_CONSECUTIVO
                               ,OFD1.OFD_OCO_BOL_MNEMONICO
                               ,OFD1.OFD_OCO_COC_CTO_MNEMONICO);
     END IF;
   END IF;
   FETCH C_ORDENES_NEGOCIO INTO ORD1;
   WHILE C_ORDENES_NEGOCIO%FOUND LOOP
      IF NVL(ORD1.ORD_EOC_MNEMONICO,' ') NOT IN('COL','AUT','ANU') THEN
         CLOSE C_ORDENES_NEGOCIO;
         IF ORD1.ORD_TIPO = 'C' THEN
            RAISE_APPLICATION_ERROR(-20081,'La orden de compra ' || TO_CHAR(ORD1.ORD_CONSECUTIVO) || ' asociada a negocio se encuentra en estado '
               || ORD1.ORD_EOC_MNEMONICO || '. No puede ser anulado el negocio');
         ELSE
            RAISE_APPLICATION_ERROR(-20082,'La orden de venta ' || TO_CHAR(ORD1.ORD_CONSECUTIVO) || ' asociada a negocio se encuentra en estado '
               || ORD1.ORD_EOC_MNEMONICO || '. No puede ser anulado el negocio');
         END IF;
      END IF;
      IF ORD1.ORD_TIPO = 'C' THEN
         UPDATE ORDENES_COMPRA
         SET    OCO_EOC_MNEMONICO = 'ANU'
               ,OCO_FECHA_ANU_CAN = SYSDATE
               ,OCO_ANU_CAN_POR = USER
               ,OCO_TERMINAL_ANU_CAN = FN_TERMINAL
               ,OCO_RAZON_ANU_CAN = P_ANU_DESCRIPCION
         WHERE  OCO_CONSECUTIVO = ORD1.ORD_CONSECUTIVO
         AND    OCO_BOL_MNEMONICO = ORD1.ORD_BOL_MNEMONICO
         AND    OCO_COC_CTO_MNEMONICO = ORD1.ORD_COC_CTO_MNEMONICO;
      ELSE
         UPDATE ORDENES_VENTA
         SET    OVE_EOC_MNEMONICO = 'ANU'
               ,OVE_FECHA_ANU_CAN = SYSDATE
               ,OVE_ANU_CAN_POR = USER
               ,OVE_TERMINAL_ANU_CAN = FN_TERMINAL
               ,OVE_RAZON_ANU_CAN = P_ANU_DESCRIPCION
         WHERE  OVE_CONSECUTIVO = ORD1.ORD_CONSECUTIVO
         AND    OVE_BOL_MNEMONICO = ORD1.ORD_BOL_MNEMONICO
         AND    OVE_COC_CTO_MNEMONICO = ORD1.ORD_COC_CTO_MNEMONICO;
         OPEN C_ORDEN_DE_PAGO;
         FETCH C_ORDEN_DE_PAGO INTO ODP1;
         IF C_ORDEN_DE_PAGO%FOUND THEN
            CLOSE C_ORDEN_DE_PAGO;
            RAISE_APPLICATION_ERROR(-20083,'La orden de pago asociada a la venta ' || TO_CHAR(ORD1.ORD_CONSECUTIVO) || ' se encuentra ejecutada.'
               || ' No puede hacer la anulaciżn');
         END IF;
         CLOSE C_ORDEN_DE_PAGO;
         UPDATE ORDENES_DE_PAGO
         SET    ODP_ESTADO = 'ANU'
               ,ODP_ANULADA_POR = USER
               ,ODP_FECHA_ANULACION = SYSDATE
               ,ODP_RAZON_ANULACION = 'ANULACION ORDEN VENTA'
         WHERE  ODP_OVE_CONSECUTIVO = ORD1.ORD_CONSECUTIVO
         AND    ODP_OVE_BOL_MNEMONICO = ORD1.ORD_BOL_MNEMONICO
         AND    ODP_OVE_COC_CTO_MNEMONICO = ORD1.ORD_COC_CTO_MNEMONICO;
      END IF;
      FETCH C_ORDENES_NEGOCIO INTO ORD1;
   END LOOP;
   CLOSE C_ORDENES_NEGOCIO;
EXCEPTION
   WHEN OTHERS THEN
      IF P_NPO_CONSECUTIVO IS NOT NULL THEN
         RAISE_APPLICATION_ERROR(-20084,'Error ejecutando la anulaciżn del negocio ' || TO_CHAR(P_NPO_CONSECUTIVO) || ' ' ||
            SQLERRM);
      ELSE
         RAISE_APPLICATION_ERROR(-20085,'Error ejecutando la anulaciżn de la oferta ' || TO_CHAR(P_NPO_CONSECUTIVO) || ' ' ||
            SQLERRM);
      END IF;
END ANULAR_ORDENES_SIMULTANEAS;
/*************************************************/
PROCEDURE CALCULAR_SALDOS_SIMULTANEAS
   (P_PPO_CONSECUTIVO        PORTAFOLIOS_POSICION.PPO_CONSECUTIVO%TYPE
   ,P_TOTAL_PORTAFOLIO       IN OUT PORTAFOLIOS_POSICION.PPO_TOTAL_PORTAFOLIO%TYPE
   ,P_TOTAL_FONDEOS          IN OUT PORTAFOLIOS_POSICION.PPO_TOTAL_PORTAFOLIO%TYPE
   ,P_TOTAL_POSICION_DEFINI  IN OUT PORTAFOLIOS_POSICION.PPO_TOTAL_POSICION_DEFINITIVAS%TYPE
   ,P_TOTAL_SIMULTANEAS      IN OUT PORTAFOLIOS_POSICION.PPO_TOTAL_SIMULTANEAS%TYPE
   ,P_TOTAL_POSICION_T1      IN OUT PORTAFOLIOS_POSICION.PPO_TOTAL_POSICION_T1%TYPE
   ,P_TOTAL_POSICION_T2      IN OUT PORTAFOLIOS_POSICION.PPO_TOTAL_POSICION_T2%TYPE
   ,P_TOTAL_POSICION_T3      IN OUT PORTAFOLIOS_POSICION.PPO_TOTAL_POSICION_T3%TYPE
   ,P_TOTAL_POSICION_TN      IN OUT PORTAFOLIOS_POSICION.PPO_TOTAL_POSICION_TN%TYPE) IS
   CURSOR C_NEGOCIOS_POSICION IS
      SELECT NPO_CONSECUTIVO
            ,NPO_TIPO_OPERACION
            ,NPO_VALOR_NOMINAL
            ,NPO_TIPO_NEGOCIO
            ,NPO_FECHA
            ,NPO_FECHA_FUTURA
            ,NPO_CLASE_OPERACION
      FROM   NEGOCIOS_POSICION
      WHERE  NPO_ESTADO != 'ANU'
      AND    NPO_PPO_CONSECUTIVO = P_PPO_CONSECUTIVO;
   NPO1   C_NEGOCIOS_POSICION%ROWTYPE;
   CURSOR C_OFERTAS_DEMANDAS_POSICION IS
      SELECT OFD_TIPO_OPERACION
            ,OFD_PLAZO
            ,OFD_NOMINAL_ADQUIRIDO
      FROM   OFERTAS_DEMANDAS_POSICION
      WHERE  OFD_ESTADO != 'ANU'
      AND    OFD_NPO_CONSECUTIVO = NPO1.NPO_CONSECUTIVO;
   OFD1   C_OFERTAS_DEMANDAS_POSICION%ROWTYPE;
   VALOR_NOMINAL              NUMBER := 0;
   VALOR_NOMINAL1             NUMBER := 0;
   DIAS                       NUMBER;
BEGIN
   P_TOTAL_PORTAFOLIO := 0;
   P_TOTAL_POSICION_DEFINI := 0;
   P_TOTAL_SIMULTANEAS := 0;
   P_TOTAL_FONDEOS := 0;
   P_TOTAL_POSICION_T1 := 0;
   P_TOTAL_POSICION_T2 := 0;
   P_TOTAL_POSICION_T3 := 0;
   P_TOTAL_POSICION_TN := 0;
   OPEN C_NEGOCIOS_POSICION;
   FETCH C_NEGOCIOS_POSICION INTO NPO1;
   WHILE C_NEGOCIOS_POSICION%FOUND LOOP
      IF NPO1.NPO_TIPO_OPERACION = 'C' THEN
         VALOR_NOMINAL := NPO1.NPO_VALOR_NOMINAL;
      ELSIF NPO1.NPO_TIPO_OPERACION = 'V' THEN
         VALOR_NOMINAL := - NPO1.NPO_VALOR_NOMINAL;
      END IF;

      IF NPO1.NPO_CLASE_OPERACION = 'CON' AND
         NPO1.NPO_TIPO_NEGOCIO = 'DIS' THEN
         P_TOTAL_PORTAFOLIO := P_TOTAL_PORTAFOLIO + VALOR_NOMINAL;
      END IF;

      IF NPO1.NPO_CLASE_OPERACION = 'SIM' AND
         NPO1.NPO_TIPO_NEGOCIO = 'DIS' THEN
         P_TOTAL_PORTAFOLIO := P_TOTAL_PORTAFOLIO + VALOR_NOMINAL;
         P_TOTAL_SIMULTANEAS := P_TOTAL_SIMULTANEAS + VALOR_NOMINAL;
         OPEN C_OFERTAS_DEMANDAS_POSICION;
         FETCH C_OFERTAS_DEMANDAS_POSICION INTO OFD1;
         WHILE C_OFERTAS_DEMANDAS_POSICION%FOUND LOOP
            IF OFD1.OFD_TIPO_OPERACION = 'C' THEN
               VALOR_NOMINAL1 := OFD1.OFD_NOMINAL_ADQUIRIDO;
            ELSIF OFD1.OFD_TIPO_OPERACION = 'V' THEN
               VALOR_NOMINAL1 := - OFD1.OFD_NOMINAL_ADQUIRIDO;
            END IF;
            IF OFD1.OFD_PLAZO = 1 THEN
               P_TOTAL_POSICION_T1 := P_TOTAL_POSICION_T1 + VALOR_NOMINAL1;
            ELSIF OFD1.OFD_PLAZO = 2 THEN
               P_TOTAL_POSICION_T2 := P_TOTAL_POSICION_T2 + VALOR_NOMINAL1;
            ELSIF OFD1.OFD_PLAZO = 3 THEN
               P_TOTAL_POSICION_T3 := P_TOTAL_POSICION_T3 + VALOR_NOMINAL1;
            ELSE
               P_TOTAL_POSICION_TN := P_TOTAL_POSICION_TN + VALOR_NOMINAL1;
            END IF;
            FETCH C_OFERTAS_DEMANDAS_POSICION INTO OFD1;
         END LOOP;
         CLOSE C_OFERTAS_DEMANDAS_POSICION;
      END IF;

      IF NPO1.NPO_TIPO_NEGOCIO IN ('POS','INT','CLI','MER') THEN
         DIAS := P_CLIENTES_TITULOS.DIA_HABIL(TRUNC(NPO1.NPO_FECHA),TRUNC(NPO1.NPO_FECHA_FUTURA));
         IF DIAS = 0 THEN
            P_TOTAL_PORTAFOLIO := P_TOTAL_PORTAFOLIO + VALOR_NOMINAL;
            P_TOTAL_POSICION_DEFINI := P_TOTAL_POSICION_DEFINI + VALOR_NOMINAL;
         ELSIF DIAS = 1 THEN
            IF NPO1.NPO_CLASE_OPERACION  = 'SIM' THEN
               P_TOTAL_POSICION_T1 := P_TOTAL_POSICION_T1 - VALOR_NOMINAL;
               P_TOTAL_PORTAFOLIO := P_TOTAL_PORTAFOLIO + VALOR_NOMINAL;
               P_TOTAL_SIMULTANEAS := P_TOTAL_SIMULTANEAS + VALOR_NOMINAL;
            ELSIF NPO1.NPO_CLASE_OPERACION = 'FON' THEN
               P_TOTAL_POSICION_T1 := P_TOTAL_POSICION_T1 - VALOR_NOMINAL;
               P_TOTAL_PORTAFOLIO := P_TOTAL_PORTAFOLIO + VALOR_NOMINAL;
               P_TOTAL_FONDEOS := P_TOTAL_FONDEOS + VALOR_NOMINAL;
            ELSE
               P_TOTAL_POSICION_T1 := P_TOTAL_POSICION_T1 + VALOR_NOMINAL;
            END IF;
         ELSIF DIAS = 2 THEN
            IF NPO1.NPO_CLASE_OPERACION  = 'SIM' THEN
               P_TOTAL_POSICION_T2 := P_TOTAL_POSICION_T2 - VALOR_NOMINAL;
               P_TOTAL_PORTAFOLIO := P_TOTAL_PORTAFOLIO + VALOR_NOMINAL;
               P_TOTAL_SIMULTANEAS := P_TOTAL_SIMULTANEAS + VALOR_NOMINAL;
            ELSIF NPO1.NPO_CLASE_OPERACION = 'FON' THEN
               P_TOTAL_POSICION_T2 := P_TOTAL_POSICION_T2 - VALOR_NOMINAL;
               P_TOTAL_PORTAFOLIO := P_TOTAL_PORTAFOLIO + VALOR_NOMINAL;
               P_TOTAL_FONDEOS := P_TOTAL_FONDEOS + VALOR_NOMINAL;
            ELSE
               P_TOTAL_POSICION_T2 := P_TOTAL_POSICION_T2 + VALOR_NOMINAL;
            END IF;
         ELSIF DIAS = 3 THEN
            IF NPO1.NPO_CLASE_OPERACION  = 'SIM' THEN
               P_TOTAL_POSICION_T3 := P_TOTAL_POSICION_T3 - VALOR_NOMINAL;
               P_TOTAL_PORTAFOLIO := P_TOTAL_PORTAFOLIO + VALOR_NOMINAL;
               P_TOTAL_SIMULTANEAS := P_TOTAL_SIMULTANEAS + VALOR_NOMINAL;
            ELSIF NPO1.NPO_CLASE_OPERACION = 'FON' THEN
               P_TOTAL_POSICION_T3 := P_TOTAL_POSICION_T3 - VALOR_NOMINAL;
               P_TOTAL_PORTAFOLIO := P_TOTAL_PORTAFOLIO + VALOR_NOMINAL;
               P_TOTAL_FONDEOS := P_TOTAL_FONDEOS + VALOR_NOMINAL;
            ELSE
               P_TOTAL_POSICION_T3 := P_TOTAL_POSICION_T3 + VALOR_NOMINAL;
            END IF;
         ELSE
            IF NPO1.NPO_CLASE_OPERACION  = 'SIM' THEN
               P_TOTAL_POSICION_TN := P_TOTAL_POSICION_TN - VALOR_NOMINAL;
               P_TOTAL_PORTAFOLIO := P_TOTAL_PORTAFOLIO + VALOR_NOMINAL;
               P_TOTAL_SIMULTANEAS := P_TOTAL_SIMULTANEAS + VALOR_NOMINAL;
            ELSIF NPO1.NPO_CLASE_OPERACION = 'FON' THEN
               P_TOTAL_POSICION_TN := P_TOTAL_POSICION_TN - VALOR_NOMINAL;
               P_TOTAL_PORTAFOLIO := P_TOTAL_PORTAFOLIO + VALOR_NOMINAL;
               P_TOTAL_FONDEOS := P_TOTAL_FONDEOS + VALOR_NOMINAL;
            ELSE
               P_TOTAL_POSICION_TN := P_TOTAL_POSICION_TN + VALOR_NOMINAL;
            END IF;
         END IF;
      END IF;
      FETCH C_NEGOCIOS_POSICION INTO NPO1;
   END LOOP;
   CLOSE C_NEGOCIOS_POSICION;
END CALCULAR_SALDOS_SIMULTANEAS;
/*************************************************/
PROCEDURE VALIDAR_CUMPLIMIENTO
   (P_LIC_NUMERO_OPERACION   LIQUIDACIONES_COMERCIAL.LIC_NUMERO_OPERACION%TYPE
   ,P_LIC_TIPO_OPERACION     LIQUIDACIONES_COMERCIAL.LIC_TIPO_OPERACION%TYPE
   ,P_LIC_FECHA_EMISION      LIQUIDACIONES_COMERCIAL.LIC_FECHA_EMISION%TYPE
   ,P_LIC_FECHA_VENCIMIENTO  LIQUIDACIONES_COMERCIAL.LIC_FECHA_VENCIMIENTO%TYPE
   ,P_LIC_VOLUMEN_FRACCION   LIQUIDACIONES_COMERCIAL.LIC_VOLUMEN_FRACCION%TYPE
   ,P_LIC_NIT_1              LIQUIDACIONES_COMERCIAL.LIC_NIT_1%TYPE
   ,P_LIC_CANTIDAD_FRACCION  LIQUIDACIONES_COMERCIAL.LIC_CANTIDAD_FRACCION%TYPE
   ,P_LIC_TIPO_OFERTA        OFERTAS_DEMANDAS_POSICION.OFD_CLASE_OPERACION%TYPE
   ,P_LIC_TASA_EMISION       LIQUIDACIONES_COMERCIAL.LIC_TASA_EMISION%TYPE
   ,P_FECHA                  LIQUIDACIONES_COMERCIAL.LIC_FECHA_OPERACION%TYPE
   ,P_FECHA_FUTURA           LIQUIDACIONES_COMERCIAL.LIC_FECHA_OPERACION%TYPE
   ,P_TASA_REFERENCIA        LIQUIDACIONES_COMERCIAL.LIC_TASA_REFERENCIA%TYPE
   ,P_PUNTOS_AJUSTE          LIQUIDACIONES_COMERCIAL.LIC_PUNTOS_AJUSTE%TYPE
   ,P_RESPUESTA              IN OUT VARCHAR2) IS
   CURSOR C_LIQUIDACION IS
      SELECT LIC_FECHA_EMISION
            ,LIC_FECHA_VENCIMIENTO
            ,LIC_VOLUMEN_FRACCION
            ,LIC_NIT_1
            ,LIC_CANTIDAD_FRACCION
            ,LIC_FECHA_CUMPLIMIENTO
            ,RTRIM(LIC_TIPO_OFERTA) LIC_TIPO_OFERTA
            ,LIC_TIPO_OPERACION
            ,LIC_TASA_EMISION
            ,LIC_TASA_REFERENCIA
            ,LIC_PUNTOS_AJUSTE
      ,LIC_NUMERO_OPERACION
            ,LIC_NUMERO_FRACCION
            ,LIC_BOL_MNEMONICO
      FROM   LIQUIDACIONES_COMERCIAL
      WHERE  LIC_NUMERO_OPERACION = P_LIC_NUMERO_OPERACION
      AND    LIC_TIPO_OPERACION = P_LIC_TIPO_OPERACION;
   LIC1   C_LIQUIDACION%ROWTYPE;

   CURSOR C_AUTORIZACIONES IS
    SELECT 'S'
    FROM   AUTORIZACIONES_COEASY
    WHERE  ACO_LIC_NUMERO_OPERACION = LIC1.LIC_NUMERO_OPERACION
    AND    ACO_LIC_TIPO_OPERACION = LIC1.LIC_TIPO_OPERACION
    AND    ACO_LIC_NUMERO_FRACCION = LIC1.LIC_NUMERO_FRACCION
    AND    ACO_LIC_BOL_MNEMONICO = LIC1.LIC_BOL_MNEMONICO
    AND    ACO_PAU_MNEMONICO = 'AFI'
    AND    ACO_FECHA >= TRUNC(SYSDATE)
    AND    ACO_FECHA < TRUNC(SYSDATE + 1);
   AUT   VARCHAR2(1);

   COND   VARCHAR2(1) := 'N';
BEGIN
   P_RESPUESTA := ' ';
   OPEN C_LIQUIDACION;
   FETCH C_LIQUIDACION INTO LIC1;
   IF C_LIQUIDACION%NOTFOUND THEN
      CLOSE C_LIQUIDACION;
      P_RESPUESTA := 'No se ha cargado esta operaciżn en COEASY. No puede hacer el proceso';
   ELSE
      WHILE C_LIQUIDACION%FOUND LOOP
     OPEN C_AUTORIZACIONES;
     FETCH C_AUTORIZACIONES INTO AUT;
     CLOSE C_AUTORIZACIONES;

         IF (P_LIC_TIPO_OFERTA = 'SIM' AND LIC1.LIC_TIPO_OFERTA NOT IN ('1','2','3','4','5','6'))
                 OR (P_LIC_TIPO_OFERTA != 'SIM' AND LIC1.LIC_TIPO_OFERTA IN ('1','2','3','4','5','6')) THEN
             P_RESPUESTA := 'La liquidaciżn de bolsa asociada no coincide. Por favor revisar';
             Exit;
         END IF;
         IF TRUNC(LIC1.LIC_FECHA_EMISION) != TRUNC(P_LIC_FECHA_EMISION) THEN
             P_RESPUESTA := 'La liquidaciżn de bolsa asociada no coincide en la fecha de Emision ('||
                            TRUNC(LIC1.LIC_FECHA_EMISION)||' - '||TRUNC(P_LIC_FECHA_EMISION)||')';
             Exit;
         END IF;
         IF TRUNC(LIC1.LIC_FECHA_VENCIMIENTO) != TRUNC(P_LIC_FECHA_VENCIMIENTO) THEN
             P_RESPUESTA := 'La liquidaciżn de bolsa asociada no coincide en la fecha de Vencimiento ('||
                            TRUNC(LIC1.LIC_FECHA_VENCIMIENTO)||' - '||TRUNC(P_LIC_FECHA_VENCIMIENTO)||')';
             Exit;
         END IF;
         IF ABS(LIC1.LIC_VOLUMEN_FRACCION - P_LIC_VOLUMEN_FRACCION) >= 1000 THEN
       IF NVL(AUT, 'N') != 'S' THEN
         P_RESPUESTA := 'La liquidaciżn de bolsa asociada no coincide en el volumen de la fraccion ('||
                LIC1.LIC_VOLUMEN_FRACCION||' - '||P_LIC_VOLUMEN_FRACCION||')';
         Exit;
       END IF;
         END IF;
         IF LIC1.LIC_NIT_1 != P_LIC_NIT_1 THEN
             P_RESPUESTA := 'La liquidaciżn de bolsa asociada no coincide en el NIT('||
                            LIC1.LIC_NIT_1||' - '||P_LIC_NIT_1||')';
             Exit;
         END IF;
         IF ABS(LIC1.LIC_CANTIDAD_FRACCION - P_LIC_CANTIDAD_FRACCION) >= 1000  THEN
       IF NVL(AUT, 'N') != 'S' THEN
         P_RESPUESTA := 'La liquidaciżn de bolsa asociada no coincide en la cantidad de la fraccion('||
                LIC1.LIC_CANTIDAD_FRACCION||' - '||P_LIC_CANTIDAD_FRACCION||')';
         Exit;
       END IF;
         END IF;
         IF LIC1.LIC_TIPO_OPERACION != P_LIC_TIPO_OPERACION THEN
             P_RESPUESTA := 'La liquidaciżn de bolsa asociada no coincide en el tipo de operacion('||
                             LIC1.LIC_TIPO_OPERACION||' - '||P_LIC_TIPO_OPERACION||')';
             Exit;
         END IF;
         IF NVL(TRUNC(LIC1.LIC_TASA_EMISION,5),0) != NVL(TRUNC(P_LIC_TASA_EMISION,5),0) THEN
             P_RESPUESTA := 'La liquidaciżn de bolsa asociada no coincide en la tasa de emision('||
                             NVL(TRUNC(LIC1.LIC_TASA_EMISION,5),0)||' - '||NVL(TRUNC(P_LIC_TASA_EMISION,5),0)||')';
             Exit;
         END IF;


         IF LIC1.LIC_TASA_REFERENCIA IS NOT NULL THEN
            IF P_TOOLS.FN_LIC_TASA_REFERENCIA(LIC1.LIC_TASA_REFERENCIA) != P_TASA_REFERENCIA THEN
               P_RESPUESTA := 'La liquidaciżn de bolsa asociada no coincide en la tasa de referencia('||
                             P_TOOLS.FN_LIC_TASA_REFERENCIA(LIC1.LIC_TASA_REFERENCIA) ||' - '||P_TASA_REFERENCIA||')';
               EXIT;
            END IF;
            IF LIC1.LIC_PUNTOS_AJUSTE != P_PUNTOS_AJUSTE THEN
               P_RESPUESTA := 'La liquidaciżn de bolsa asociada no coincide en los puntos de ajuste('||
                                 LIC1.LIC_PUNTOS_AJUSTE||' - '||P_PUNTOS_AJUSTE||')';
                EXIT;
            END IF;
         END IF;

         IF TRUNC(LIC1.LIC_FECHA_CUMPLIMIENTO) != TRUNC(P_FECHA)        AND
            TRUNC(LIC1.LIC_FECHA_CUMPLIMIENTO) != TRUNC(P_FECHA_FUTURA) THEN
                 P_RESPUESTA := 'La liquidaciżn de bolsa asociada no coincide en la fecha de cumplimiento('||
                             TRUNC(LIC1.LIC_FECHA_CUMPLIMIENTO)||' - '||TRUNC(P_FECHA)||' - '||TRUNC(P_FECHA_FUTURA)||')';
                 Exit;
         End If;

         FETCH C_LIQUIDACION INTO LIC1;
      END LOOP;
      CLOSE C_LIQUIDACION;
   END IF;
END VALIDAR_CUMPLIMIENTO;
/*************************************************/
PROCEDURE CALCULAR_SALDOS_INICIO_DIA
   (P_FECHA DATE,P_TX IN NUMBER DEFAULT NULL) IS
   CURSOR C_PORTAFOLIO_DIA_ANTERIOR(P_FECHA_P DATE) IS
      SELECT PPO_CONSECUTIVO
            ,PPO_TOTAL_PORTAFOLIO
            ,PPO_TOTAL_POSICION_DEFINITIVAS
            ,PPO_TOTAL_SIMULTANEAS
            ,PPO_TOTAL_FONDEOS_INTERNOS
            ,PPO_TOTAL_POSICION_T1
            ,PPO_TOTAL_POSICION_T2
            ,PPO_TOTAL_POSICION_T3
            ,PPO_TOTAL_POSICION_TN
            ,PPO_ENA_MNEMONICO
            ,PPO_BMO_MNEMONICO
            ,PPO_FECHA_EMISION
            ,PPO_FECHA_VENCIMIENTO
            ,PPO_PERIODICIDAD_TASA
            ,PPO_BASE_CALCULO
            ,PPO_MODALIDAD_TASA
            ,PPO_TASA_FACIAL
            ,PPO_TASA_EFECTIVA
            ,PPO_TRE_MNEMONICO
            ,PPO_PUNTOS_ADICIONALES
            ,PPO_TIPO_PAGO_FLUJO
            ,PPO_AMORTIZABLE
            ,PPO_CAPITALIZABLE
            ,PPO_CODIGO_PERIODO
            ,PPO_PER_NUM_IDEN
            ,PPO_PER_TID_CODIGO
            ,PPO_TIPO
            ,PPO_COSTO_PROM_COMPRA_INICIAL
            ,PPO_TOTAL_NOMINAL_INICIAL
            ,PPO_COSTO_PROM_COMPRA_FINAL
      FROM   PORTAFOLIOS_POSICION
      WHERE  PPO_FECHA >= TRUNC(P_FECHA_P)
      AND    PPO_FECHA < TRUNC(P_FECHA_P + 1)
--      AND    PPO_ENA_MNEMONICO = 'TFIT04150812'
--      AND    PPO_PER_NUM_IDEN = '80244672'
      AND    PPO_TIPO = 'POS';
   PPO1   C_PORTAFOLIO_DIA_ANTERIOR%ROWTYPE;

   /* Este query compara todos los faciales del (negocio - portafolio) contra todos los faciales del portafolio vigente
      debido a que hay negocios que son  de dżas anteriores que estan asociados al saldo de ese dża lo que lleva a hacer
      este calculo para que los saldos de las futuras se encuentren correctos*/
   CURSOR C_NEGOCIOS_POSICION IS
      SELECT NPO_CONSECUTIVO
            ,NPO_TIPO_OPERACION
            ,NPO_VALOR_NOMINAL
            ,NPO_VALOR_PESOS
            ,NPO_TIPO_NEGOCIO
            ,NPO_FECHA
            ,NPO_FECHA_FUTURA
            ,NPO_CLASE_OPERACION
            ,OFD_TIPO_OPERACION
            ,OFD_PLAZO
            ,OFD_FECHA_FUTURA
            ,OFD_NOMINAL_ADQUIRIDO
            ,OFD_VALOR_PESOS_ADQUIRIDO
            ,OFD_CONSECUTIVO
            ,NPO_TIPO_REGISTRO
            ,NPO_COMISION_INTRAMESA
      FROM   NEGOCIOS_POSICION
            ,OFERTAS_DEMANDAS_POSICION
            ,PORTAFOLIOS_POSICION
      WHERE  NPO_ESTADO != 'ANU'
      AND    NPO_TIPO_NEGOCIO = 'DIS'
      AND    NPO_CONSECUTIVO = OFD_NPO_CONSECUTIVO
      AND    OFD_FECHA_FUTURA >= TRUNC(P_FECHA)
      AND    OFD_ESTADO != 'ANU'
      AND    NPO_PPO_CONSECUTIVO = PPO_CONSECUTIVO
      AND    NVL(PPO_ENA_MNEMONICO,' ') = NVL(PPO1.PPO_ENA_MNEMONICO,' ')
      AND    NVL(PPO_BMO_MNEMONICO,' ') = NVL(PPO1.PPO_BMO_MNEMONICO,' ')
      AND    NVL(PPO_FECHA_EMISION,TRUNC(SYSDATE - 10000)) = NVL(PPO1.PPO_FECHA_EMISION,TRUNC(SYSDATE - 10000))
      AND    NVL(PPO_FECHA_VENCIMIENTO,TRUNC(SYSDATE - 10000)) = NVL(PPO1.PPO_FECHA_VENCIMIENTO,TRUNC(SYSDATE - 10000))
      AND    NVL(PPO_PERIODICIDAD_TASA,-1) = NVL(PPO1.PPO_PERIODICIDAD_TASA,-1)
      AND    NVL(PPO_BASE_CALCULO,-1) = NVL(PPO1.PPO_BASE_CALCULO,-1)
      AND    NVL(PPO_MODALIDAD_TASA,' ') = NVL(PPO1.PPO_MODALIDAD_TASA,' ')
      AND    NVL(PPO_TASA_FACIAL,-1) = NVL(PPO1.PPO_TASA_FACIAL,-1)
      AND    NVL(PPO_TRE_MNEMONICO,' ') = NVL(PPO1.PPO_TRE_MNEMONICO,' ')
      AND    NVL(PPO_PUNTOS_ADICIONALES,-1) = NVL(PPO1.PPO_PUNTOS_ADICIONALES,-1)
      AND    NVL(PPO_TIPO_PAGO_FLUJO,'XX') = NVL(PPO1.PPO_TIPO_PAGO_FLUJO,'XX')
      AND    NVL(PPO_AMORTIZABLE,'N') = NVL(PPO1.PPO_AMORTIZABLE,'N')
      AND    NVL(PPO_CAPITALIZABLE,'N') = NVL(PPO1.PPO_CAPITALIZABLE,'N')
      AND    NVL(PPO_CODIGO_PERIODO,'XX') = NVL(PPO1.PPO_CODIGO_PERIODO,'XX')
      AND    NVL(PPO_PER_NUM_IDEN,' ') = NVL(PPO1.PPO_PER_NUM_IDEN,' ')
      AND    NVL(PPO_PER_TID_CODIGO,' ') = NVL(PPO1.PPO_PER_TID_CODIGO,' ')
      UNION
      SELECT NPO_CONSECUTIVO
            ,NPO_TIPO_OPERACION
            ,NPO_VALOR_NOMINAL
            ,NPO_VALOR_PESOS
            ,NPO_TIPO_NEGOCIO
            ,NPO_FECHA
            ,NPO_FECHA_FUTURA
            ,NPO_CLASE_OPERACION
            ,NULL
            ,NULL
            ,NULL
            ,NULL
            ,NULL
            ,NULL
            ,NPO_TIPO_REGISTRO
            ,NPO_COMISION_INTRAMESA
      FROM   NEGOCIOS_POSICION
            ,PORTAFOLIOS_POSICION
      WHERE  NPO_ESTADO != 'ANU'
      AND    NPO_FECHA_FUTURA >= TRUNC(P_FECHA)
      AND    NPO_TIPO_NEGOCIO IN ('POS','INT')
      AND    NPO_PPO_CONSECUTIVO = PPO_CONSECUTIVO
      AND    NVL(PPO_ENA_MNEMONICO,' ') = NVL(PPO1.PPO_ENA_MNEMONICO,' ')
      AND    NVL(PPO_BMO_MNEMONICO,' ') = NVL(PPO1.PPO_BMO_MNEMONICO,' ')
      AND    NVL(PPO_FECHA_EMISION,TRUNC(SYSDATE - 10000)) = NVL(PPO1.PPO_FECHA_EMISION,TRUNC(SYSDATE - 10000))
      AND    NVL(PPO_FECHA_VENCIMIENTO,TRUNC(SYSDATE - 10000)) = NVL(PPO1.PPO_FECHA_VENCIMIENTO,TRUNC(SYSDATE - 10000))
      AND    NVL(PPO_PERIODICIDAD_TASA,-1) = NVL(PPO1.PPO_PERIODICIDAD_TASA,-1)
      AND    NVL(PPO_BASE_CALCULO,-1) = NVL(PPO1.PPO_BASE_CALCULO,-1)
      AND    NVL(PPO_MODALIDAD_TASA,' ') = NVL(PPO1.PPO_MODALIDAD_TASA,' ')
      AND    NVL(PPO_TASA_FACIAL,-1) = NVL(PPO1.PPO_TASA_FACIAL,-1)
      AND    NVL(PPO_TRE_MNEMONICO,' ') = NVL(PPO1.PPO_TRE_MNEMONICO,' ')
      AND    NVL(PPO_PUNTOS_ADICIONALES,-1) = NVL(PPO1.PPO_PUNTOS_ADICIONALES,-1)
      AND    NVL(PPO_TIPO_PAGO_FLUJO,'XX') = NVL(PPO1.PPO_TIPO_PAGO_FLUJO,'XX')
      AND    NVL(PPO_AMORTIZABLE,'N') = NVL(PPO1.PPO_AMORTIZABLE,'N')
      AND    NVL(PPO_CAPITALIZABLE,'N') = NVL(PPO1.PPO_CAPITALIZABLE,'N')
      AND    NVL(PPO_CODIGO_PERIODO,'XX') = NVL(PPO1.PPO_CODIGO_PERIODO,'XX')
      AND    NVL(PPO_PER_NUM_IDEN,' ') = NVL(PPO1.PPO_PER_NUM_IDEN,' ')
      AND    NVL(PPO_PER_TID_CODIGO,' ') = NVL(PPO1.PPO_PER_TID_CODIGO,' ');
   NPO1   C_NEGOCIOS_POSICION%ROWTYPE;

   -- CURSOR PARA TRAER EL ISIN QUE CORRESPONDE AL PORTAFOLIO
   CURSOR C_TFO IS
      SELECT TFO_CODIGO, TFO_FUG_ISI_MNEMONICO
    FROM   TITULOS_FONDOS
    WHERE  TFO_FON_CODIGO = '860079174'
      AND   NVL(TFO_ENA_MNEMONICO,' ') = NVL(PPO1.PPO_ENA_MNEMONICO,' ')
      AND   NVL(TFO_FECHA_EMISION,TRUNC(SYSDATE - 10000)) = NVL(PPO1.PPO_FECHA_EMISION,TRUNC(SYSDATE - 10000))
      AND   NVL(TFO_FECHA_VENCIMIENTO,TRUNC(SYSDATE - 10000)) = NVL(PPO1.PPO_FECHA_VENCIMIENTO,TRUNC(SYSDATE - 10000))
      AND   NVL(TFO_BMO_MNEMONICO,' ') = NVL(PPO1.PPO_BMO_MNEMONICO,' ')
      AND   NVL(TFO_PERIODICIDAD_TASA,-1)  = NVL(PPO1.PPO_PERIODICIDAD_TASA,-1)
      AND   NVL(TFO_BASE_CALCULO,-1) = NVL(PPO1.PPO_BASE_CALCULO,-1)
      AND   NVL(TFO_MODALIDAD_TASA,' ') = NVL(PPO1.PPO_MODALIDAD_TASA,' ')
      AND   NVL(TFO_TASA_FACIAL,-1) = NVL(PPO1.PPO_TASA_FACIAL/100,-1)
      AND   NVL(TFO_TRE_MNEMONICO,' ') = NVL(PPO1.PPO_TRE_MNEMONICO,' ')
      AND   NVL(TFO_PUNTOS_ADICIONALES,-1) = NVL(PPO1.PPO_PUNTOS_ADICIONALES,-1)
      AND   NVL(TFO_TIPO_PAGO_FLUJO,'XX') = NVL(PPO1.PPO_TIPO_PAGO_FLUJO,'XX')
      AND   NVL(TFO_AMORTIZABLE,'N') = NVL(PPO1.PPO_AMORTIZABLE,'N')
      AND   NVL(TFO_CAPITALIZABLE,'N') = NVL(PPO1.PPO_CAPITALIZABLE,'N')
      AND   NVL(TFO_CODIGO_PERIODO,'XX') = NVL(PPO1.PPO_CODIGO_PERIODO,'XX')
      AND   TFO_ETI_CODIGO = 'VIG';
   V_ISIN VARCHAR2(12);
   V_TFO NUMBER(10);

   CURSOR C_DIA_HABIL(P_FECHA_P DATE) IS
      SELECT 'X'
      FROM   DIAS_NO_HABILES
      WHERE  TRUNC(DNH_FECHA) = TRUNC(P_FECHA_P);
   COND   VARCHAR2(1);

   VALOR_NOMINAL            NUMBER;
   VALOR_NOMINAL1           NUMBER;
   VALOR_PESOS              NUMBER;
   DIAS                     NUMBER;
   P_TOTAL_PORTAFOLIO       NUMBER;
   P_TOTAL_COMPRAS_VENTAS   NUMBER;
   P_TOTAL_DEFINITIVAS      NUMBER;
   P_TOTAL_SIMULTANEAS      NUMBER;
   P_TOTAL_POSICION_T1      NUMBER;
   P_TOTAL_POSICION_T2      NUMBER;
   P_TOTAL_POSICION_T3      NUMBER;
   P_TOTAL_POSICION_TN      NUMBER;
   P_TOTAL_FONDEOS_INTERNOS NUMBER;
   FECHA                    DATE;
   EXISTEN_NEGOCIOS         VARCHAR2(1);
   conn      utl_smtp.connection;
   REQ       UTL_HTTP.REQ;
   RESP      UTL_HTTP.RESP;
   DIRECCION           VARCHAR2(1000);

   V_COSTO_PROM        NUMBER;
   V_TOTAL_NOMINAL     NUMBER;
   P_TOTAL_PESOS       NUMBER;
   P_TOTAL_POSICION    NUMBER;
   V_NPO               NUMBER(10,0);
   V_NPOT              NUMBER(10,0);
   N_ID_PROCESO        NUMBER;
   N_TX                NUMBER;


BEGIN
  /* DIRECCION := 'aangel@corredores.com;msanchez@corredores.com';
   conn := p_mail.begin_mail(sender     => 'administrador@corredores.com',
                             recipients => DIRECCION,
                             subject    => 'Generaciżn de saldos de simultaneas',
                             mime_type  => p_mail.MULTIPART_MIME_TYPE);
   p_mail.write_text(conn,'Iniciando proceso de fecha ' || TO_CHAR(P_FECHA,'DD-MON-YYYY')||CHR(13));
*/
    --se asigna el consecutivo del proceso(tabla PARAMETRIZACION_PROCESOS)
    N_ID_PROCESO := P_TRAZA_CORE.FN_ID_PROCESO('P_NEGOCIOS_POSICION.CALCULAR_SALDOS_INICIO_DIA');

    --se Asigna consecutivo para la transaccion, si el proceso es el primero que se llama, reinicia el consecutivo
    N_TX := P_TRAZA_CORE.FN_TRAE_TX(P_TX);

    --Registra Traza
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'I',
                                    'Inicio proceso P_NEGOCIOS_POSICION.CALCULAR_SALDOS_INICIO_DIA. Generaciżn de saldos de simultaneas. Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss'),
                                    N_TX);

   -- SE BORRA LA TABLA DE DETALLES DE POSICION TN
   DELETE FROM TMP_DETALLE_POSICION_TN;

   OPEN C_DIA_HABIL(P_FECHA);
   FETCH C_DIA_HABIL INTO COND;
   CLOSE C_DIA_HABIL;

   IF NVL(COND,' ') = 'X' OR
      TO_CHAR(P_FECHA,'D') IN ('1','7') THEN
      NULL;
   ELSE
      /* Proceso para determinar la fecha desde la cual se debe hacer el calculo */
      FECHA := TRUNC(P_FECHA) - 1;
      LOOP
         COND := NULL;
         OPEN C_DIA_HABIL(FECHA);
         FETCH C_DIA_HABIL INTO COND;
         CLOSE C_DIA_HABIL;

         IF NVL(COND,' ') = 'X' OR
            TO_CHAR(FECHA,'D') IN ('1','7') THEN
            FECHA := FECHA - 1;
         ELSE
            EXIT;
         END IF;
      END LOOP;

      OPEN C_PORTAFOLIO_DIA_ANTERIOR(FECHA);
      FETCH C_PORTAFOLIO_DIA_ANTERIOR INTO PPO1;
      WHILE C_PORTAFOLIO_DIA_ANTERIOR%FOUND LOOP
         /* Las variables que se van a recalcular se reinician */
         P_TOTAL_PORTAFOLIO := 0;
         P_TOTAL_DEFINITIVAS := 0;
         P_TOTAL_SIMULTANEAS := 0;
         P_TOTAL_POSICION_T1 := 0;
         P_TOTAL_POSICION_T2 := 0;
         P_TOTAL_POSICION_T3 := 0;
         P_TOTAL_POSICION_TN := 0;
         P_TOTAL_FONDEOS_INTERNOS := 0;
         P_TOTAL_PESOS := 0;
         P_TOTAL_POSICION := 0;
         EXISTEN_NEGOCIOS := 'N';
         OPEN C_NEGOCIOS_POSICION;
         FETCH C_NEGOCIOS_POSICION INTO NPO1;
         WHILE C_NEGOCIOS_POSICION%FOUND LOOP
            EXISTEN_NEGOCIOS := 'S';
            V_NPOT := NULL;
            V_NPO  := NULL;
            V_NPOT := NPO1.NPO_CONSECUTIVO;
            VALOR_PESOS := 0;
            IF NPO1.NPO_CLASE_OPERACION = 'SIM' AND
               NPO1.NPO_TIPO_NEGOCIO = 'DIS' THEN
               IF NPO1.OFD_TIPO_OPERACION = 'C' THEN
                  VALOR_NOMINAL1 := NPO1.OFD_NOMINAL_ADQUIRIDO;
                  VALOR_PESOS    := NPO1.OFD_VALOR_PESOS_ADQUIRIDO;
               ELSIF NPO1.OFD_TIPO_OPERACION = 'V' THEN
                  VALOR_NOMINAL1 := - NPO1.OFD_NOMINAL_ADQUIRIDO;
                  VALOR_PESOS    := - NPO1.OFD_VALOR_PESOS_ADQUIRIDO;
               END IF;
               DIAS := P_CLIENTES_TITULOS.DIA_HABIL(TRUNC(P_FECHA),TRUNC(NPO1.OFD_FECHA_FUTURA));
               IF DIAS = 0 THEN
                  P_TOTAL_PORTAFOLIO := P_TOTAL_PORTAFOLIO + VALOR_NOMINAL1;
                  P_TOTAL_DEFINITIVAS := P_TOTAL_DEFINITIVAS + VALOR_NOMINAL1;
                  V_NPO := NPO1.NPO_CONSECUTIVO;
               ELSIF DIAS = 1 THEN
                  P_TOTAL_POSICION_T1 := P_TOTAL_POSICION_T1 + VALOR_NOMINAL1;
               ELSIF DIAS = 2 THEN
                  P_TOTAL_POSICION_T2 := P_TOTAL_POSICION_T2 + VALOR_NOMINAL1;
               ELSIF DIAS = 3 THEN
                  P_TOTAL_POSICION_T3 := P_TOTAL_POSICION_T3 + VALOR_NOMINAL1;
               ELSE
                  P_TOTAL_POSICION_TN := P_TOTAL_POSICION_TN + VALOR_NOMINAL1;
               END IF;
               P_TOTAL_PESOS := P_TOTAL_PESOS + VALOR_PESOS;
               P_TOTAL_POSICION := P_TOTAL_POSICION + VALOR_NOMINAL1;
            END IF;
            IF NPO1.NPO_TIPO_OPERACION = 'C' THEN
               VALOR_NOMINAL := NPO1.NPO_VALOR_NOMINAL;
               VALOR_PESOS   := NPO1.NPO_VALOR_PESOS;
            ELSIF NPO1.NPO_TIPO_OPERACION = 'V' THEN
               VALOR_NOMINAL := - NPO1.NPO_VALOR_NOMINAL;
               VALOR_PESOS := -NPO1.NPO_VALOR_PESOS;
            END IF;
            IF NPO1.NPO_TIPO_NEGOCIO IN ('POS','INT') THEN
               DIAS := P_CLIENTES_TITULOS.DIA_HABIL(TRUNC(P_FECHA),TRUNC(NPO1.NPO_FECHA_FUTURA));
               IF DIAS = 0 THEN
                  IF NPO1.NPO_CLASE_OPERACION IN ('SIM','FON') THEN
                     P_TOTAL_DEFINITIVAS := P_TOTAL_DEFINITIVAS - VALOR_NOMINAL;
                     P_TOTAL_PORTAFOLIO := P_TOTAL_PORTAFOLIO -  VALOR_NOMINAL;
                     P_TOTAL_POSICION := P_TOTAL_POSICION - VALOR_NOMINAL;
                     P_TOTAL_PESOS := P_TOTAL_PESOS - VALOR_PESOS;
                     V_NPO := NPO1.NPO_CONSECUTIVO;
                     IF NPO1.NPO_TIPO_REGISTRO = 'OTRAS' AND
                        NPO1.NPO_CLASE_OPERACION = 'SIM' THEN
                        UPDATE NEGOCIOS_POSICION
                        SET    NPO_ESTADO_CUMPLIMIENTO = 'CUF'
                        WHERE  NPO_CONSECUTIVO = NPO1.NPO_CONSECUTIVO;
                     END IF;
                  ELSE
                     P_TOTAL_DEFINITIVAS := P_TOTAL_DEFINITIVAS + VALOR_NOMINAL;
                     P_TOTAL_PORTAFOLIO := P_TOTAL_PORTAFOLIO + VALOR_NOMINAL;
                     P_TOTAL_POSICION := P_TOTAL_POSICION + VALOR_NOMINAL;
                     IF NPO1.NPO_CLASE_OPERACION = 'CON' AND
                        NPO1.NPO_TIPO_OPERACION = 'C'    AND
                        NPO1.NPO_TIPO_REGISTRO = 'INTME' THEN
                        P_TOTAL_PESOS := P_TOTAL_PESOS + VALOR_PESOS + NVL(NPO1.NPO_COMISION_INTRAMESA,0);
                     ELSE
                        P_TOTAL_PESOS := P_TOTAL_PESOS + VALOR_PESOS;
                     END IF;
                  END IF;
               ELSIF DIAS = 1 THEN
                  IF NPO1.NPO_CLASE_OPERACION IN ('SIM','FON') THEN
                     P_TOTAL_POSICION_T1 := P_TOTAL_POSICION_T1 - VALOR_NOMINAL;
                     P_TOTAL_POSICION := P_TOTAL_POSICION - VALOR_NOMINAL;
                     P_TOTAL_PESOS := P_TOTAL_PESOS - VALOR_PESOS;
                  ELSE
                     P_TOTAL_POSICION_T1 := P_TOTAL_POSICION_T1 + VALOR_NOMINAL;
                     P_TOTAL_POSICION := P_TOTAL_POSICION + VALOR_NOMINAL;
                     IF NPO1.NPO_CLASE_OPERACION = 'CON' AND
                        NPO1.NPO_TIPO_OPERACION = 'C'    AND
                        NPO1.NPO_TIPO_REGISTRO = 'INTME' THEN
                        P_TOTAL_PESOS := P_TOTAL_PESOS + VALOR_PESOS + NVL(NPO1.NPO_COMISION_INTRAMESA,0);
                     ELSE
                        P_TOTAL_PESOS := P_TOTAL_PESOS + VALOR_PESOS;
                     END IF;
                  END IF;
               ELSIF DIAS = 2 THEN
                  IF NPO1.NPO_CLASE_OPERACION IN ('SIM','FON') THEN
                     P_TOTAL_POSICION_T2 := P_TOTAL_POSICION_T2 - VALOR_NOMINAL;
                     P_TOTAL_POSICION := P_TOTAL_POSICION - VALOR_NOMINAL;
                     P_TOTAL_PESOS := P_TOTAL_PESOS - VALOR_PESOS;
                  ELSE
                     P_TOTAL_POSICION_T2 := P_TOTAL_POSICION_T2 + VALOR_NOMINAL;
                     P_TOTAL_POSICION := P_TOTAL_POSICION + VALOR_NOMINAL;
                     IF NPO1.NPO_CLASE_OPERACION = 'CON' AND
                        NPO1.NPO_TIPO_OPERACION = 'C'    AND
                        NPO1.NPO_TIPO_REGISTRO = 'INTME' THEN
                        P_TOTAL_PESOS := P_TOTAL_PESOS + VALOR_PESOS + NVL(NPO1.NPO_COMISION_INTRAMESA,0);
                     ELSE
                        P_TOTAL_PESOS := P_TOTAL_PESOS + VALOR_PESOS;
                     END IF;
                  END IF;
               ELSIF DIAS = 3 THEN
                  IF NPO1.NPO_CLASE_OPERACION IN ('SIM','FON') THEN
                     P_TOTAL_POSICION_T3 := P_TOTAL_POSICION_T3 - VALOR_NOMINAL;
                     P_TOTAL_POSICION := P_TOTAL_POSICION - VALOR_NOMINAL;
                     P_TOTAL_PESOS := P_TOTAL_PESOS - VALOR_PESOS;
                  ELSE
                     P_TOTAL_POSICION_T3 := P_TOTAL_POSICION_T3 + VALOR_NOMINAL;
                     P_TOTAL_POSICION := P_TOTAL_POSICION + VALOR_NOMINAL;
                     IF NPO1.NPO_CLASE_OPERACION = 'CON' AND
                        NPO1.NPO_TIPO_OPERACION = 'C'    AND
                        NPO1.NPO_TIPO_REGISTRO = 'INTME' THEN
                        P_TOTAL_PESOS := P_TOTAL_PESOS + VALOR_PESOS + NVL(NPO1.NPO_COMISION_INTRAMESA,0);
                     ELSE
                        P_TOTAL_PESOS := P_TOTAL_PESOS + VALOR_PESOS;
                     END IF;
                  END IF;
               ELSE
                  IF NPO1.NPO_CLASE_OPERACION IN ('SIM','FON') THEN
                     P_TOTAL_POSICION_TN := P_TOTAL_POSICION_TN - VALOR_NOMINAL;
                     P_TOTAL_POSICION := P_TOTAL_POSICION - VALOR_NOMINAL;
                     P_TOTAL_PESOS := P_TOTAL_PESOS - VALOR_PESOS;
                  ELSE
                     P_TOTAL_POSICION_TN := P_TOTAL_POSICION_TN + VALOR_NOMINAL;
                     P_TOTAL_POSICION := P_TOTAL_POSICION + VALOR_NOMINAL;
                     IF NPO1.NPO_CLASE_OPERACION = 'CON' AND
                        NPO1.NPO_TIPO_OPERACION = 'C'    AND
                        NPO1.NPO_TIPO_REGISTRO = 'INTME' THEN
                        P_TOTAL_PESOS := P_TOTAL_PESOS + VALOR_PESOS + NVL(NPO1.NPO_COMISION_INTRAMESA,0);
                     ELSE
                        P_TOTAL_PESOS := P_TOTAL_PESOS + VALOR_PESOS;
                     END IF;
                  END IF;
               END IF;
            END IF;
            FETCH C_NEGOCIOS_POSICION INTO NPO1;
         END LOOP;
         CLOSE C_NEGOCIOS_POSICION;
         /* Si el saldo inicial es cero y el actual tambien es cero no se inserta saldo inicial */
         IF NVL(P_TOTAL_PORTAFOLIO,0) != 0 OR
            NVL(P_TOTAL_DEFINITIVAS,0) != 0 OR
            NVL(P_TOTAL_FONDEOS_INTERNOS,0) != 0 OR
            NVL(P_TOTAL_SIMULTANEAS,0) != 0 OR
            NVL(P_TOTAL_POSICION_T1,0) != 0 OR
            NVL(P_TOTAL_POSICION_T2,0) != 0 OR
            NVL(P_TOTAL_POSICION_T3,0) != 0 OR
            NVL(P_TOTAL_POSICION_TN,0) != 0 OR
            NVL(EXISTEN_NEGOCIOS,'N') = 'S' THEN
            IF V_NPO IS NULL THEN
               V_NPO := V_NPOT;
            END IF;
            V_ISIN := NULL;
            V_TFO := NULL;
            OPEN C_TFO;
            FETCH C_TFO INTO V_TFO, V_ISIN;
            CLOSE C_TFO;
            IF P_TOTAL_POSICION <> 0 THEN
               V_COSTO_PROM := P_TOTAL_PESOS / P_TOTAL_POSICION;
            END IF;
            INSERT INTO PORTAFOLIOS_POSICION
               (PPO_CONSECUTIVO
               ,PPO_FECHA
               ,PPO_ENA_MNEMONICO
               ,PPO_TOTAL_PORTAFOLIO
               ,PPO_BMO_MNEMONICO
               ,PPO_FECHA_EMISION
               ,PPO_FECHA_VENCIMIENTO
               ,PPO_PERIODICIDAD_TASA
               ,PPO_BASE_CALCULO
               ,PPO_MODALIDAD_TASA
               ,PPO_TASA_FACIAL
               ,PPO_TASA_EFECTIVA
               ,PPO_TRE_MNEMONICO
               ,PPO_PUNTOS_ADICIONALES
               ,PPO_TIPO_PAGO_FLUJO
               ,PPO_AMORTIZABLE
               ,PPO_CAPITALIZABLE
               ,PPO_CODIGO_PERIODO
               ,PPO_TOTAL_POSICION_DEFINITIVAS
               ,PPO_TOTAL_FONDEOS_INTERNOS
               ,PPO_TOTAL_SIMULTANEAS
               ,PPO_TOTAL_POSICION_T1
               ,PPO_TOTAL_POSICION_T2
               ,PPO_TOTAL_POSICION_T3
               ,PPO_TOTAL_POSICION_TN
               ,PPO_TIPO
               ,PPO_PER_NUM_IDEN
               ,PPO_PER_TID_CODIGO
               ,PPO_TOTAL_NOMINAL_INICIAL
               ,PPO_TOTAL_PESOS
               ,PPO_COSTO_PROM_COMPRA_INICIAL
               ,PPO_NPO_CONSECUTIVO
               ,PPO_FUG_ISI_MNEMONICO
               ,PPO_TFO_CODIGO)
            VALUES
               (PPO_SEQ.NEXTVAL
               ,P_FECHA
               ,PPO1.PPO_ENA_MNEMONICO
               ,P_TOTAL_PORTAFOLIO
               ,PPO1.PPO_BMO_MNEMONICO
               ,PPO1.PPO_FECHA_EMISION
               ,PPO1.PPO_FECHA_VENCIMIENTO
               ,PPO1.PPO_PERIODICIDAD_TASA
               ,PPO1.PPO_BASE_CALCULO
               ,PPO1.PPO_MODALIDAD_TASA
               ,PPO1.PPO_TASA_FACIAL
               ,NULL
               ,PPO1.PPO_TRE_MNEMONICO
               ,PPO1.PPO_PUNTOS_ADICIONALES
               ,PPO1.PPO_TIPO_PAGO_FLUJO
               ,PPO1.PPO_AMORTIZABLE
               ,PPO1.PPO_CAPITALIZABLE
               ,PPO1.PPO_CODIGO_PERIODO
               ,P_TOTAL_DEFINITIVAS
               ,P_TOTAL_FONDEOS_INTERNOS
               ,P_TOTAL_SIMULTANEAS
               ,P_TOTAL_POSICION_T1
               ,P_TOTAL_POSICION_T2
               ,P_TOTAL_POSICION_T3
               ,P_TOTAL_POSICION_TN
               ,PPO1.PPO_TIPO
               ,PPO1.PPO_PER_NUM_IDEN
               ,PPO1.PPO_PER_TID_CODIGO
               -- MSANCHEZ
               ,P_TOTAL_POSICION                  -- PARA TENER EL VALOR TOTAL DE LA POSICION CON EL QUE INICIA
               ,P_TOTAL_PESOS
               ,V_COSTO_PROM                        -- EL DIA INICIA EL COSTO PROMEDIO CON EL QUE FINALIZA EL DIA ANTERIOR
               ,V_NPO                             -- NPO RELACIONADO CON UN PORTAFOLIO SIMILAR
               ,V_ISIN
               ,V_TFO);
         END IF;
         FETCH C_PORTAFOLIO_DIA_ANTERIOR INTO PPO1;
      END LOOP;
      CLOSE C_PORTAFOLIO_DIA_ANTERIOR;
      COMMIT;
   END IF;
   /*p_mail.write_text(conn,'Proceso Generado Exitosamente ');
   p_mail.end_mail( conn => conn );*/
    --Registra Traza
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'F',
                                    'Fin proceso P_NEGOCIOS_POSICION.CALCULAR_SALDOS_INICIO_DIA. Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss'),
                                    N_TX);
EXCEPTION
   WHEN OTHERS THEN
    /*  p_mail.write_text(conn,'Proceso genero el siguiente error: ' || SQLERRM);
      p_mail.end_mail( conn => conn );*/
    --Registra Traza
    P_TRAZA_CORE.PR_REGISTRAR_TRAZA(N_ID_PROCESO,
                                    'E',
                                    'Error proceso P_NEGOCIOS_POSICION.CALCULAR_SALDOS_INICIO_DIA. Fecha Proceso: ' ||
                                    TO_CHAR(SYSDATE, 'DD-MM-YYYY HH24:mi:ss')||'-'||SQLERRM,
                                    N_TX); 
END CALCULAR_SALDOS_INICIO_DIA;
/*************************************************/
PROCEDURE CALCULAR_COMISION_Y_FUTURO
   (P_OFD_TASA                  OFERTAS_DEMANDAS_POSICION.OFD_TASA%TYPE
   ,P_OFD_PLAZO                 OFERTAS_DEMANDAS_POSICION.OFD_PLAZO%TYPE
   ,P_OFD_VALOR_PESOS_ADQUIRIDO OFERTAS_DEMANDAS_POSICION.OFD_VALOR_PESOS_ADQUIRIDO%TYPE
   ,P_OFD_FECHA                 OFERTAS_DEMANDAS_POSICION.OFD_FECHA%TYPE
   ,P_NPO_CONSECUTIVO           NEGOCIOS_POSICION.NPO_CONSECUTIVO%TYPE
   ,P_OFD_FECHA_FUTURA          IN OUT OFERTAS_DEMANDAS_POSICION.OFD_FECHA_FUTURA%TYPE
   ,P_OFD_VALOR_FUTURO          IN OUT OFERTAS_DEMANDAS_POSICION.OFD_VALOR_FUTURO%TYPE
   ,P_COMISION                  IN OUT NUMBER) IS
   CURSOR C_NEGOCIO IS
      SELECT NPO_TIPO_RANGO
            ,NPO_TASA_NEGOCIACION
      FROM   NEGOCIOS_POSICION
      WHERE  NPO_CONSECUTIVO = P_NPO_CONSECUTIVO;
   NPO1   C_NEGOCIO%ROWTYPE;
   CURSOR C_TASA_MONTO IS
      SELECT RMP_TASA
      FROM   RANGOS_MONTOS_POSICION
      WHERE  RMP_NPO_CONSECUTIVO = P_NPO_CONSECUTIVO
      AND    RMP_MONTO_INICIAL <= P_OFD_VALOR_PESOS_ADQUIRIDO
      AND    RMP_MONTO_FINAL >= P_OFD_VALOR_PESOS_ADQUIRIDO;
   RMP1   C_TASA_MONTO%ROWTYPE;
   CURSOR C_TASA_PLAZO IS
      SELECT RPP_TASA
      FROM   RANGOS_PLAZOS_POSICION
      WHERE  RPP_NPO_CONSECUTIVO = P_NPO_CONSECUTIVO
      AND    RPP_PLAZO_INICIAL <= P_OFD_PLAZO
      AND    RPP_PLAZO_FINAL >= P_OFD_PLAZO;
   RPP1   C_TASA_PLAZO%ROWTYPE;
   CURSOR C_DIAS_NO_HABILES(P_FECHA DATE) IS
      SELECT 'X'
      FROM   DIAS_NO_HABILES
      WHERE  DNH_FECHA = TRUNC(P_FECHA);


   CURSOR  C_PORTA_PP(P_CONSEC NUMBER) IS
      SELECT PPO_ENA_MNEMONICO MNEMONICO,
         PPO_FECHA_EMISION FECHA_EMI, PPO_FECHA_VENCIMIENTO FECHA_VENCI,
         PPO_BMO_MNEMONICO BASE_MON, PPO_PERIODICIDAD_TASA PERIODICIDAD_TASA,
         PPO_BASE_CALCULO BASE_CALCULO, PPO_MODALIDAD_TASA MODALIDAD_TASA
      FROM PORTAFOLIOS_POSICION WHERE PPO_CONSECUTIVO = P_CONSEC;
    R_PORTA_PP C_PORTA_PP%ROWTYPE;

    CURSOR C_NPO IS
      SELECT NPO_PPO_CONSECUTIVO PPO_CONSECUTIVO, NPO_VALOR_PESOS VALOR_PESOS,
         NPO_FECHA_FUTURA FECHA_FUTURA, NPO_FECHA FECHA, NPO_VALOR_NOMINAL NOMINAL,
         NPO_TASA_NEGOCIACION TASA_NEGOCIACION
      FROM NEGOCIOS_POSICION WHERE NPO_CONSECUTIVO = P_NPO_CONSECUTIVO;
    R_NPO C_NPO%ROWTYPE;

   COND         VARCHAR2(1);
   DIAS         NUMBER;
   VALOR_FUTURO NUMBER;
   TASA         NUMBER;


   V_VC_ISI_MNEMONICO   VARCHAR2(15) := 0;
   V_NM_PORC_CUPON      NUMBER       := 0;
   V_BASE               NUMBER       := 0;
   V_FRF_FECHA          DATE         := NULL;
   V_FECHA_FUR_FECHA_OFER      NUMBER         := 0;
   V_FECHA_FUT_FECHA_FLUJO     NUMBER         := 0;
   V_PRUEBA NUMBER;

BEGIN
   OPEN C_NEGOCIO;
   FETCH C_NEGOCIO INTO NPO1;
   IF C_NEGOCIO%FOUND THEN
      IF NPO1.NPO_TIPO_RANGO = 'TG' THEN
         TASA := NPO1.NPO_TASA_NEGOCIACION;
      ELSIF NPO1.NPO_TIPO_RANGO = 'RM' THEN
         OPEN C_TASA_MONTO;
         FETCH C_TASA_MONTO INTO RMP1;
         CLOSE C_TASA_MONTO;
         TASA := RMP1.RMP_TASA;
      ELSIF NPO1.NPO_TIPO_RANGO = 'RP' THEN
         OPEN C_TASA_PLAZO;
         FETCH C_TASA_PLAZO INTO RPP1;
         CLOSE C_TASA_PLAZO;
         TASA := RPP1.RPP_TASA;
      END IF;
   END IF;
   DIAS := 1;
   P_OFD_FECHA_FUTURA := P_OFD_FECHA;
   WHILE DIAS <= P_OFD_PLAZO LOOP
      P_OFD_FECHA_FUTURA := P_OFD_FECHA_FUTURA + 1;
      COND := NULL;
      OPEN C_DIAS_NO_HABILES(P_OFD_FECHA_FUTURA);
      FETCH C_DIAS_NO_HABILES INTO COND;
      CLOSE C_DIAS_NO_HABILES;
      IF NVL(COND,' ') = 'X' OR
         TO_CHAR(P_OFD_FECHA_FUTURA,'D') IN ('1','7') THEN
         NULL;
      ELSE
         DIAS := DIAS + 1;
      END IF;
   END LOOP;


   BEGIN

     OPEN C_NPO;
     FETCH C_NPO INTO R_NPO;
     CLOSE C_NPO;

     OPEN C_PORTA_PP(R_NPO.PPO_CONSECUTIVO);
     FETCH C_PORTA_PP INTO R_PORTA_PP;
     IF C_PORTA_PP%FOUND THEN
       SELECT FUG_ISI_MNEMONICO INTO V_VC_ISI_MNEMONICO FROM FUNGIBLES F
         WHERE F.FUG_ENA_MNEMONICO = R_PORTA_PP.MNEMONICO
         AND F.FUG_ESTADO = 'A'
         AND FUG_FECHA_EMISION = R_PORTA_PP.FECHA_EMI  AND FUG_FECHA_VENCIMIENTO = R_PORTA_PP.FECHA_VENCI
         AND FUG_BMO_MNEMONICO = R_PORTA_PP.BASE_MON
         AND FUG_PERIODICIDAD_TASA = R_PORTA_PP.PERIODICIDAD_TASA
         AND FUG_BASE_CALCULO = R_PORTA_PP.BASE_CALCULO
         AND FUG_MODALIDAD_TASA = R_PORTA_PP.MODALIDAD_TASA
        ;


        BEGIN
           V_NM_PORC_CUPON := 0;
           SELECT NVL(FRF_PORCENTAJE,0), FRF_FECHA INTO V_NM_PORC_CUPON, V_FRF_FECHA FROM FLUJOS_RENDIMIENTO_FUNGIBLE
              WHERE FRF_FECHA >= TRUNC(R_NPO.FECHA +1)
              AND FRF_FECHA <= TRUNC(P_OFD_FECHA_FUTURA)
              AND FRF_FUG_ISI_MNEMONICO = V_VC_ISI_MNEMONICO
              AND ROWNUM = 1
              ORDER BY FRF_FECHA DESC;
        EXCEPTION WHEN NO_DATA_FOUND THEN
           V_NM_PORC_CUPON := 0;
           V_FRF_FECHA     := NULL;
        WHEN OTHERS THEN
           V_NM_PORC_CUPON := 0;
           V_FRF_FECHA     := NULL;
        END;

     END IF;
     CLOSE C_PORTA_PP;
   END;

   IF R_PORTA_PP.BASE_MON = 'PESOS' THEN
      V_BASE := 1;
   ELSE
     BEGIN
        SELECT CBM_VALOR INTO V_BASE
        FROM COTIZACIONES_BASE_MONETARIAS
        WHERE CBM_BMO_MNEMONICO = R_PORTA_PP.BASE_MON
        AND ROWNUM = 1
        ORDER BY CBM_FECHA DESC;
     EXCEPTION WHEN OTHERS THEN
      V_BASE := 1;
     END;
   END IF;

   V_FECHA_FUR_FECHA_OFER := TRUNC(P_OFD_FECHA_FUTURA)-TRUNC(R_NPO.FECHA);
   V_PRUEBA := V_NM_PORC_CUPON * R_NPO.VALOR_PESOS;
   IF V_FRF_FECHA IS NULL THEN
      V_FECHA_FUT_FECHA_FLUJO := 0;
   ELSE
      V_FECHA_FUT_FECHA_FLUJO := TRUNC(P_OFD_FECHA_FUTURA) - TRUNC(V_FRF_FECHA);
   END IF;

   DIAS := P_FINANCIERO.DIAS_365(TRUNC(P_OFD_FECHA),TRUNC(P_OFD_FECHA_FUTURA));

   --P_OFD_VALOR_FUTURO := ROUND(P_OFD_VALOR_PESOS_ADQUIRIDO * POWER((1 + P_OFD_TASA/100),DIAS/365),2);
   P_OFD_VALOR_FUTURO := R_NPO.VALOR_PESOS * POWER((P_OFD_TASA+100)/100,(V_FECHA_FUR_FECHA_OFER)/365)-((V_BASE * R_NPO.NOMINAL) * (V_NM_PORC_CUPON * POWER((P_OFD_TASA+100)/100,(V_FECHA_FUT_FECHA_FLUJO)/365)));
   P_OFD_VALOR_FUTURO := ROUND(P_OFD_VALOR_FUTURO);

  -- VALOR_FUTURO := ROUND(P_OFD_VALOR_PESOS_ADQUIRIDO * POWER((1 + TASA/100),DIAS/365),2); -- OSJSANCHEZ CUPONES 6 SE ACTUALIZA 16112023
  VALOR_FUTURO := R_NPO.VALOR_PESOS * POWER((TASA+100)/100,(V_FECHA_FUR_FECHA_OFER)/365)-((V_BASE * R_NPO.NOMINAL) * (V_NM_PORC_CUPON * POWER((TASA+100)/100,(V_FECHA_FUT_FECHA_FLUJO)/365)));
  VALOR_FUTURO := ROUND(VALOR_FUTURO);
   P_COMISION := VALOR_FUTURO - P_OFD_VALOR_FUTURO;
END CALCULAR_COMISION_Y_FUTURO;
/*************************************************/
PROCEDURE EJECUTAR_NEGOCIO_POSICION
   (P_PPO_ENA_MNEMONICO         PORTAFOLIOS_POSICION.PPO_ENA_MNEMONICO%TYPE
   ,P_PPO_CONSECUTIVO           PORTAFOLIOS_POSICION.PPO_CONSECUTIVO%TYPE
   ,P_PER_NUM_IDEN              PERSONAS.PER_NUM_IDEN%TYPE /*Esta es la persona que genera el negocio*/
   ,P_PER_TID_CODIGO            PERSONAS.PER_TID_CODIGO%TYPE
   ,P_PRF_FON_CODIGO            PREORDENES_FONDOS.PRF_FON_CODIGO%TYPE) IS
   CURSOR C_FACIALES IS
      SELECT PPO_ENA_MNEMONICO
            ,PPO_PER_NUM_IDEN
            ,PPO_PER_TID_CODIGO
            ,PPO_BMO_MNEMONICO
            ,PPO_FECHA_EMISION
            ,PPO_FECHA_VENCIMIENTO
            ,PPO_CODIGO_PERIODO
            ,PPO_PERIODICIDAD_TASA
            ,PPO_MODALIDAD_TASA
            ,PPO_BASE_CALCULO
            ,PPO_TASA_FACIAL
            ,PPO_TRE_MNEMONICO
            ,PPO_PUNTOS_ADICIONALES
            ,PPO_TIPO_PAGO_FLUJO
            ,PPO_CAPITALIZABLE
            ,PPO_AMORTIZABLE
            ,PPO_FECHA
            ,PPO_TOTAL_REDENCION
      FROM   PORTAFOLIOS_POSICION
      WHERE  PPO_CONSECUTIVO = P_PPO_CONSECUTIVO;
   PPO1   C_FACIALES%ROWTYPE;
   CURSOR C_TOTAL_NEGOCIO (P_TIPO_OPERACION EJECUCION_NEGOCIOS_POSICION.VRP_TIPO_OPERACION%TYPE) IS
      SELECT SUM(VRP_VALOR_NOMINAL) TOTAL_NOMINAL
      FROM   EJECUCION_NEGOCIOS_POSICION
      WHERE  VRP_ENA_MNEMONICO = P_PPO_ENA_MNEMONICO
      AND    VRP_PPO_CONSECUTIVO = P_PPO_CONSECUTIVO
      AND    VRP_TIPO_OPERACION = P_TIPO_OPERACION
      AND    NOT (VRP_CLASE_OPERACION = 'FON' AND
                  VRP_TIPO_REGISTRO = 'COASA');
   CURSOR C_DETALLE_NEGOCIO(P_TIPO_OPERACION EJECUCION_NEGOCIOS_POSICION.VRP_TIPO_OPERACION%TYPE) IS
      SELECT VRP_NPO_CONSECUTIVO
            ,VRP_OFD_CONSECUTIVO
            ,VRP_CLASE_OPERACION
            ,VRP_FECHA
            ,VRP_NUMERO_OPERACION
            ,VRP_NUMERO_FRACCION
            ,VRP_VALOR_NOMINAL
            ,VRP_VALOR_PESOS
            ,VRP_CCC_CLI_PER_NUM_IDEN
            ,VRP_CCC_CLI_PER_TID_CODIGO
            ,VRP_CCC_NUMERO_CUENTA
            ,VRP_PER_NOMBRE
            ,VRP_DEPOSITO
            ,VRP_FECHA_FUTURA
            ,VRP_VALOR_FUTURO
            ,VRP_TASA_SIMULTANEA
            ,VRP_BASE_CALCULO_FUT
            ,VRP_ORDEN
            ,VRP_TIPO_NEGOCIO
            ,VRP_TIPO_REGISTRO
            ,VRP_PPO_PER_NUM_IDEN
            ,VRP_PPO_PER_TID_CODIGO
            ,VRP_FIC_PER_NUM_IDEN
            ,VRP_FIC_PER_TID_CODIGO
            ,VRP_FIC_CODIGO_BOLSA
      FROM   EJECUCION_NEGOCIOS_POSICION
      WHERE  VRP_ENA_MNEMONICO = P_PPO_ENA_MNEMONICO
      AND    VRP_PPO_CONSECUTIVO = P_PPO_CONSECUTIVO
      AND    VRP_TIPO_OPERACION = P_TIPO_OPERACION
      AND    NOT (VRP_CLASE_OPERACION = 'FON' AND
                  VRP_TIPO_REGISTRO = 'COASA');
   VRP1   C_DETALLE_NEGOCIO%ROWTYPE;
   CURSOR C_LIQUIDACION_CORREDORES(P_NUMERO_OPERACION    LIQUIDACIONES_COMERCIAL.LIC_NUMERO_OPERACION%TYPE
                                  ,P_TIPO_OPERACION      LIQUIDACIONES_COMERCIAL.LIC_TIPO_OPERACION%TYPE) IS
      SELECT LIC_BOL_MNEMONICO
            ,LIC_NUMERO_OPERACION
            ,LIC_NUMERO_FRACCION
            ,LIC_TIPO_OPERACION
            ,LIC_OVE_CONSECUTIVO
            ,LIC_OVE_COC_CTO_MNEMONICO
            ,LIC_OCO_CONSECUTIVO
            ,LIC_OCO_COC_CTO_MNEMONICO
            ,LIC_COD_CMSNSTA_CMPRDOR
            ,LIC_COD_CMSNSTA_VNDDOR
      FROM   LIQUIDACIONES_COMERCIAL
      WHERE  LIC_NUMERO_OPERACION = P_NUMERO_OPERACION
      AND    LIC_TIPO_OPERACION = P_TIPO_OPERACION
      AND    LIC_NIT_1 = P_PRF_FON_CODIGO
      AND    LIC_TIPO_IDENTIFICACION_1 = 'NIT';
   LIC1   C_LIQUIDACION_CORREDORES%ROWTYPE;
   CURSOR C_COMERCIAL_CUENTA(P_TABLA VARCHAR2) IS
      SELECT CCC_PER_NUM_IDEN
            ,CCC_PER_TID_CODIGO
      FROM   CUENTAS_CLIENTE_CORREDORES
            ,ORDENES_VENTA
      WHERE  CCC_CLI_PER_NUM_IDEN = OVE_CCC_CLI_PER_NUM_IDEN
      AND    CCC_CLI_PER_TID_CODIGO = OVE_CCC_CLI_PER_TID_CODIGO
      AND    CCC_NUMERO_CUENTA = OVE_CCC_NUMERO_CUENTA
      AND    OVE_CONSECUTIVO = LIC1.LIC_OVE_CONSECUTIVO
      AND    OVE_BOL_MNEMONICO = LIC1.LIC_BOL_MNEMONICO
      AND    OVE_COC_CTO_MNEMONICO = LIC1.LIC_OVE_COC_CTO_MNEMONICO
      AND    P_TABLA = 'V'
      UNION
      SELECT CCC_PER_NUM_IDEN
            ,CCC_PER_TID_CODIGO
      FROM   CUENTAS_CLIENTE_CORREDORES
            ,ORDENES_COMPRA
      WHERE  CCC_CLI_PER_NUM_IDEN = OCO_CCC_CLI_PER_NUM_IDEN
      AND    CCC_CLI_PER_TID_CODIGO = OCO_CCC_CLI_PER_TID_CODIGO
      AND    CCC_NUMERO_CUENTA = OCO_CCC_NUMERO_CUENTA
      AND    OCO_CONSECUTIVO = LIC1.LIC_OCO_CONSECUTIVO
      AND    OCO_BOL_MNEMONICO = LIC1.LIC_BOL_MNEMONICO
      AND    OCO_COC_CTO_MNEMONICO = LIC1.LIC_OCO_COC_CTO_MNEMONICO
      AND    P_TABLA = 'C';
   CCC1   C_COMERCIAL_CUENTA%ROWTYPE;
   CURSOR C_COMERCIAL_CENTRO_PRO IS
      SELECT PCP_CPR_MNEMONICO
      FROM   PERSONAS_CENTROS_PRODUCCION
      WHERE  PCP_PER_NUM_IDEN = VRP1.VRP_PPO_PER_NUM_IDEN
      AND    PCP_PER_TID_CODIGO = VRP1.VRP_PPO_PER_TID_CODIGO
      AND    PCP_PRINCIPAL = 'S';
   PCP1   C_COMERCIAL_CENTRO_PRO%ROWTYPE;
   CURSOR C_CONTRAPARTE(P_CODIGO  VARCHAR2) IS
      SELECT FIC_PER_NUM_IDEN   PER_NUM_IDEN
            ,FIC_PER_TID_CODIGO PER_TID_CODIGO
      FROM   FIRMAS_COMISIONISTAS
      WHERE  FIC_CODIGO_BOLSA = P_CODIGO;
   FIC1   C_CONTRAPARTE%ROWTYPE;
   CURSOR C_FUTURAS_COMPRA IS
      SELECT VRP_NPO_CONSECUTIVO
            ,VRP_OFD_CONSECUTIVO
            ,VRP_VALOR_PESOS
            ,PRC_PRF_CONSECUTIVO
            ,PRC_CONSECUTIVO
      FROM   EJECUCION_NEGOCIOS_POSICION
            ,PREORDENES_COMPRA
      WHERE  VRP_ENA_MNEMONICO = P_PPO_ENA_MNEMONICO
      AND    VRP_TIPO_OPERACION = 'C'
      AND    TRUNC(VRP_FECHA_EMISION) = TRUNC(PPO1.PPO_FECHA_EMISION)
      AND    TRUNC(VRP_FECHA_VENCIMIENTO) = TRUNC(PPO1.PPO_FECHA_VENCIMIENTO)
      AND    NVL(VRP_TASA_FACIAL,-.01) = NVL(PPO1.PPO_TASA_FACIAL,-.01)
      AND    NVL(VRP_TRE_MNEMONICO,' ') = NVL(PPO1.PPO_TRE_MNEMONICO,' ')
      AND    NVL(VRP_PUNTOS_ADICIONALES,-.000001) = NVL(PPO1.PPO_PUNTOS_ADICIONALES,-.000001)
      AND    NVL(VRP_PERIODICIDAD_TASA,-1) = NVL(PPO1.PPO_PERIODICIDAD_TASA,-1)
      AND    NVL(VRP_MODALIDAD_TASA,' ') = NVL(PPO1.PPO_MODALIDAD_TASA,' ')
      AND    NVL(VRP_CODIGO_PERIODO,' ') = NVL(PPO1.PPO_CODIGO_PERIODO,' ')
      AND    NVL(VRP_BASE_CALCULO,-1) = NVL(PPO1.PPO_BASE_CALCULO,-1)
      AND    NVL(VRP_TIPO_PAGO_FLUJO,' ') = NVL(PPO1.PPO_TIPO_PAGO_FLUJO,' ')
      AND    NVL(VRP_CAPITALIZABLE,'N') = NVL(PPO1.PPO_CAPITALIZABLE,'N')
      AND    NVL(VRP_AMORTIZABLE,'N') = NVL(PPO1.PPO_AMORTIZABLE,'N')
      AND    NVL(VRP_BMO_MNEMONICO,' ') = NVL(PPO1.PPO_BMO_MNEMONICO,' ')
      AND    VRP_PPO_CONSECUTIVO != P_PPO_CONSECUTIVO
      AND    VRP_PPO_PER_NUM_IDEN = PPO1.PPO_PER_NUM_IDEN
      AND    VRP_PPO_PER_TID_CODIGO = PPO1.PPO_PER_TID_CODIGO
      AND    VRP_NPO_CONSECUTIVO = PRC_NPO_CONSECUTIVO
      AND    (VRP_OFD_CONSECUTIVO IS NULL OR
              (VRP_OFD_CONSECUTIVO IS NOT NULL AND
               VRP_OFD_CONSECUTIVO = PRC_OFD_CONSECUTIVO))
      AND    PRC_FECHA_CUMPLIMIENTO >= TRUNC(PPO1.PPO_FECHA)
      AND    PRC_FECHA_CUMPLIMIENTO < TRUNC(PPO1.PPO_FECHA + 1);
   PRC1   C_FUTURAS_COMPRA%ROWTYPE;
   CURSOR C_FUTURAS_VENTA IS
      SELECT VRP_NPO_CONSECUTIVO
            ,VRP_OFD_CONSECUTIVO
            ,VRP_VALOR_PESOS
            ,PRV_PRF_CONSECUTIVO
            ,PRV_CONSECUTIVO
      FROM   EJECUCION_NEGOCIOS_POSICION
            ,PREORDENES_VENTA
      WHERE  VRP_ENA_MNEMONICO = P_PPO_ENA_MNEMONICO
      AND    VRP_TIPO_OPERACION = 'V'
      AND    TRUNC(VRP_FECHA_EMISION) = TRUNC(PPO1.PPO_FECHA_EMISION)
      AND    TRUNC(VRP_FECHA_VENCIMIENTO) = TRUNC(PPO1.PPO_FECHA_VENCIMIENTO)
      AND    NVL(VRP_TASA_FACIAL,-.01) = NVL(PPO1.PPO_TASA_FACIAL,-.01)
      AND    NVL(VRP_TRE_MNEMONICO,' ') = NVL(PPO1.PPO_TRE_MNEMONICO,' ')
      AND    NVL(VRP_PUNTOS_ADICIONALES,-.000001) = NVL(PPO1.PPO_PUNTOS_ADICIONALES,-.000001)
      AND    NVL(VRP_PERIODICIDAD_TASA,-1) = NVL(PPO1.PPO_PERIODICIDAD_TASA,-1)
      AND    NVL(VRP_MODALIDAD_TASA,' ') = NVL(PPO1.PPO_MODALIDAD_TASA,' ')
      AND    NVL(VRP_CODIGO_PERIODO,' ') = NVL(PPO1.PPO_CODIGO_PERIODO,' ')
      AND    NVL(VRP_BASE_CALCULO,-1) = NVL(PPO1.PPO_BASE_CALCULO,-1)
      AND    NVL(VRP_TIPO_PAGO_FLUJO,' ') = NVL(PPO1.PPO_TIPO_PAGO_FLUJO,' ')
      AND    NVL(VRP_CAPITALIZABLE,'N') = NVL(PPO1.PPO_CAPITALIZABLE,'N')
      AND    NVL(VRP_AMORTIZABLE,'N') = NVL(PPO1.PPO_AMORTIZABLE,'N')
      AND    NVL(VRP_BMO_MNEMONICO,' ') = NVL(PPO1.PPO_BMO_MNEMONICO,' ')
      AND    VRP_PPO_CONSECUTIVO != P_PPO_CONSECUTIVO
      AND    VRP_PPO_PER_NUM_IDEN = PPO1.PPO_PER_NUM_IDEN
      AND    VRP_PPO_PER_TID_CODIGO = PPO1.PPO_PER_TID_CODIGO
      AND    VRP_NPO_CONSECUTIVO = PRV_NPO_CONSECUTIVO
      AND    (VRP_OFD_CONSECUTIVO IS NULL OR
              (VRP_OFD_CONSECUTIVO IS NOT NULL AND
               VRP_OFD_CONSECUTIVO = PRV_OFD_CONSECUTIVO))
      AND    PRV_FECHA_CUMPLIMIENTO >= TRUNC(PPO1.PPO_FECHA)
      AND    PRV_FECHA_CUMPLIMIENTO < TRUNC(PPO1.PPO_FECHA + 1);
   PRV1   C_FUTURAS_VENTA%ROWTYPE;
   CURSOR C_NEGOCIOS_POSICION IS
      SELECT VRP_NPO_CONSECUTIVO
            ,VRP_OFD_CONSECUTIVO
            ,VRP_ESTADO
            ,VRP_TIPO_OPERACION
            ,VRP_VALOR_PESOS
            ,VRP_ESTADO_CUMPLIMIENTO
            ,VRP_CLASE_OPERACION
            ,VRP_FECHA_FUTURA
            ,VRP_CCC_CLI_PER_NUM_IDEN
            ,VRP_CCC_CLI_PER_TID_CODIGO
            ,VRP_CCC_NUMERO_CUENTA
            ,VRP_TIPO_REGISTRO
            ,VRP_COMISION_INTRAMESA
            ,VRP_VALOR_NOMINAL
            ,VRP_PPO_PER_NUM_IDEN
            ,VRP_PPO_PER_TID_CODIGO
            ,VRP_TIPO_NEGOCIO
      FROM   EJECUCION_NEGOCIOS_POSICION
      WHERE  VRP_ENA_MNEMONICO = P_PPO_ENA_MNEMONICO
      AND    TRUNC(VRP_FECHA_EMISION) = TRUNC(PPO1.PPO_FECHA_EMISION)
      AND    TRUNC(VRP_FECHA_VENCIMIENTO) = TRUNC(PPO1.PPO_FECHA_VENCIMIENTO)
      AND    NVL(VRP_TASA_FACIAL,-.01) = NVL(PPO1.PPO_TASA_FACIAL,-.01)
      AND    NVL(VRP_TRE_MNEMONICO,' ') = NVL(PPO1.PPO_TRE_MNEMONICO,' ')
      AND    NVL(VRP_PUNTOS_ADICIONALES,-.000001) = NVL(PPO1.PPO_PUNTOS_ADICIONALES,-.000001)
      AND    NVL(VRP_PERIODICIDAD_TASA,-1) = NVL(PPO1.PPO_PERIODICIDAD_TASA,-1)
      AND    NVL(VRP_MODALIDAD_TASA,' ') = NVL(PPO1.PPO_MODALIDAD_TASA,' ')
      AND    NVL(VRP_CODIGO_PERIODO,' ') = NVL(PPO1.PPO_CODIGO_PERIODO,' ')
      AND    NVL(VRP_BASE_CALCULO,-1) = NVL(PPO1.PPO_BASE_CALCULO,-1)
      AND    NVL(VRP_TIPO_PAGO_FLUJO,' ') = NVL(PPO1.PPO_TIPO_PAGO_FLUJO,' ')
      AND    NVL(VRP_CAPITALIZABLE,'N') = NVL(PPO1.PPO_CAPITALIZABLE,'N')
      AND    NVL(VRP_AMORTIZABLE,'N') = NVL(PPO1.PPO_AMORTIZABLE,'N')
      AND    NVL(VRP_BMO_MNEMONICO,' ') = NVL(PPO1.PPO_BMO_MNEMONICO,' ')
      AND    VRP_PPO_PER_NUM_IDEN = PPO1.PPO_PER_NUM_IDEN
      AND    VRP_PPO_PER_TID_CODIGO = PPO1.PPO_PER_TID_CODIGO;
   VRP2   C_NEGOCIOS_POSICION%ROWTYPE;
   CURSOR C_OFERTAS_SIMULTANEAS IS
      SELECT OFD_TASA
            ,OFD_PLAZO
            ,OFD_VALOR_PESOS_ADQUIRIDO
            ,OFD_FECHA
            ,OFD_NPO_CONSECUTIVO
            ,OFD_FECHA_FUTURA
            ,PRC_PRF_CONSECUTIVO
            ,PRC_PRF_FON_CODIGO
            ,PRC_CONSECUTIVO
            ,PRV_PRF_CONSECUTIVO
            ,PRV_PRF_FON_CODIGO
            ,PRV_CONSECUTIVO
            ,CCC_PER_NUM_IDEN
            ,CCC_PER_TID_CODIGO
            ,OFD_NOMINAL_ADQUIRIDO
      FROM   OFERTAS_DEMANDAS_POSICION
            ,PREORDENES_COMPRA
            ,PREORDENES_VENTA
            ,ORDENES_COMPRA
            ,CUENTAS_CLIENTE_CORREDORES
      WHERE  OFD_CONSECUTIVO = VRP2.VRP_OFD_CONSECUTIVO
      AND    PRC_OFD_CONSECUTIVO = OFD_CONSECUTIVO
      AND    PRV_OFD_CONSECUTIVO = OFD_CONSECUTIVO
      AND    OFD_OCO_CONSECUTIVO = OCO_CONSECUTIVO
      AND    OFD_OCO_BOL_MNEMONICO = OCO_BOL_MNEMONICO
      AND    OFD_OCO_COC_CTO_MNEMONICO = OCO_COC_CTO_MNEMONICO
      AND    OCO_CCC_CLI_PER_NUM_IDEN = CCC_CLI_PER_NUM_IDEN
      AND    OCO_CCC_CLI_PER_TID_CODIGO = CCC_CLI_PER_TID_CODIGO
      AND    OCO_CCC_NUMERO_CUENTA = CCC_NUMERO_CUENTA;
   OFD2   C_OFERTAS_SIMULTANEAS%ROWTYPE;
   CURSOR C_NEGOCIOS_POSICION_INT IS
      SELECT NPO_PER_NUM_IDEN
            ,NPO_PER_TID_CODIGO
            ,PRC_PRF_CONSECUTIVO
            ,PRC_PRF_FON_CODIGO
            ,PRC_CONSECUTIVO
            ,PRC_PER_NUM_IDEN_CONTRAPARTE
            ,PRC_PER_TID_CODIGO_CONTRAPARTE
            ,NULL PRV_PRF_CONSECUTIVO
            ,NULL PRV_PRF_FON_CODIGO
            ,NULL PRV_CONSECUTIVO
            ,NULL PRV_PER_NUM_IDEN_CONTRAPARTE
            ,NULL PRV_PER_TID_CODIGO_CONTRAPARTE
            ,NPO_VALOR_NOMINAL
      FROM   NEGOCIOS_POSICION
            ,PREORDENES_COMPRA
      WHERE  NPO_CONSECUTIVO = VRP2.VRP_NPO_CONSECUTIVO
      AND    PRC_NPO_CONSECUTIVO = VRP2.VRP_NPO_CONSECUTIVO
      UNION
      SELECT NPO_PER_NUM_IDEN
            ,NPO_PER_TID_CODIGO
            ,NULL PRC_PRF_CONSECUTIVO
            ,NULL PRC_PRF_FON_CODIGO
            ,NULL PRC_CONSECUTIVO
            ,NULL PRC_PER_NUM_IDEN_CONTRAPARTE
            ,NULL PRC_PER_TID_CODIGO_CONTRAPARTE
            ,PRV_PRF_CONSECUTIVO
            ,PRV_PRF_FON_CODIGO
            ,PRV_CONSECUTIVO
            ,PRV_PER_NUM_IDEN_CONTRAPARTE
            ,PRV_PER_TID_CODIGO_CONTRAPARTE
            ,NPO_VALOR_NOMINAL
      FROM   NEGOCIOS_POSICION
            ,PREORDENES_VENTA
      WHERE  NPO_CONSECUTIVO = VRP2.VRP_NPO_CONSECUTIVO
      AND    PRV_NPO_CONSECUTIVO = VRP2.VRP_NPO_CONSECUTIVO;
   NPO1   C_NEGOCIOS_POSICION_INT%ROWTYPE;
   CONSECUTIVO_COMPRA         PREORDENES_FONDOS.PRF_CONSECUTIVO%TYPE;
   CONSECUTIVO_VENTA          PREORDENES_FONDOS.PRF_CONSECUTIVO%TYPE;
   CONSECUTIVO_PRC            PREORDENES_COMPRA.PRC_CONSECUTIVO%TYPE;
   CONSECUTIVO_PRV            PREORDENES_VENTA.PRV_CONSECUTIVO%TYPE;
   CONSECUTIVO_FUT            PREORDENES_FONDOS.PRF_CONSECUTIVO%TYPE;
   TOTAL_NOMINAL              NUMBER;
   FECHA                      DATE;
   FECHA_PRIMER_FLUJO         DATE;
   FECHA_CUMPLIMIENTO_INICIAL DATE;
   NUMERO_OPERACION           NUMBER;
   PORCENTAJE                 NUMBER;
   LONGITUD                   NUMBER;
   COMISION                   NUMBER;
   CLASE_OPERACION            VARCHAR2(5);
   RE_COMPRA_VENTA            VARCHAR2(1);
   DEPOSITO                   VARCHAR2(3);
   TOTAL_PESOS_COMPRA         NUMBER := 0;
   TOTAL_PESOS_VENTA          NUMBER := 0;
   TOTAL_NOMINAL_COMPRA       NUMBER := 0;
   TOTAL_FONDEOS              NUMBER := 0;
   TOTAL_COMERCIAL            NUMBER := 0;
   TOTAL_COMISION_INTRAMESAS  NUMBER := 0;
   VALOR_FONDEO               NUMBER;
   FECHA_FUTURA               DATE;
   VALOR_FUTURO               NUMBER;
   SIGUIENTE                  NUMBER;
BEGIN
   OPEN C_FACIALES;
   FETCH C_FACIALES INTO PPO1;
   IF C_FACIALES%NOTFOUND THEN
      RAISE_APPLICATION_ERROR(-20086,'No se pudo determinar los faciales de la especie ' || P_PPO_ENA_MNEMONICO);
   END IF;
   CLOSE C_FACIALES;
   SELECT SYSDATE INTO FECHA FROM DUAL;
   IF PPO1.PPO_TRE_MNEMONICO IS NULL THEN
      FECHA_PRIMER_FLUJO := NULL;
   ELSE
      IF PPO1.PPO_TIPO_PAGO_FLUJO = 'V' OR
         (PPO1.PPO_TIPO_PAGO_FLUJO = 'P' AND
          TRUNC(FECHA) = TRUNC(PPO1.PPO_FECHA_EMISION)) THEN
         SELECT TRUNC(SYSDATE) INTO FECHA_PRIMER_FLUJO FROM DUAL;
      ELSE
         CORRER_FLUJOS
            ('S'
            ,PPO1.PPO_ENA_MNEMONICO
            ,PPO1.PPO_FECHA_EMISION
            ,PPO1.PPO_FECHA_VENCIMIENTO
            ,PPO1.PPO_AMORTIZABLE
            ,PPO1.PPO_CAPITALIZABLE
            ,PPO1.PPO_TRE_MNEMONICO
            ,PPO1.PPO_PUNTOS_ADICIONALES
            ,PPO1.PPO_TASA_FACIAL
            ,PPO1.PPO_TIPO_PAGO_FLUJO
            ,PPO1.PPO_CODIGO_PERIODO
            ,PPO1.PPO_PERIODICIDAD_TASA
            ,PPO1.PPO_MODALIDAD_TASA
            ,PPO1.PPO_BASE_CALCULO
            ,FECHA
            ,1
            ,1);
         SELECT FECHA INTO FECHA_PRIMER_FLUJO
         FROM   GL_FLUJOS
         WHERE  TIPO = 'X';
      END IF;
   END IF;
   TOTAL_NOMINAL := NULL;
   OPEN C_TOTAL_NEGOCIO('C');
   FETCH C_TOTAL_NEGOCIO INTO TOTAL_NOMINAL;
   CLOSE C_TOTAL_NEGOCIO;
   TOTAL_NOMINAL := NVL(TOTAL_NOMINAL,0);
   IF TOTAL_NOMINAL != 0 THEN
      P_NEGOCIOS_POSICION.CREAR_PREORDEN_FONDOS
         (P_FONDO              => P_PRF_FON_CODIGO
         ,P_CONSECUTIVO        => CONSECUTIVO_COMPRA
         ,P_ENA_MNEMONICO      => PPO1.PPO_ENA_MNEMONICO
         ,P_FECHA_OPERACION    => TRUNC(PPO1.PPO_FECHA)
         ,P_EOF_CODIGO         => 'APR'
         ,P_TIPO_NEGOCIO       => 'C'
         ,P_TIPO               => 'RF'
         ,P_TITULO_EXTERIOR    => 'N'
         ,P_VALOR_NOMINAL      => TOTAL_NOMINAL
         ,P_CANTIDAD           => NULL
         ,P_NETEO              => NULL
         ,P_FECHA_EMISION      => PPO1.PPO_FECHA_EMISION
         ,P_FECHA_VENCIMIENTO  => PPO1.PPO_FECHA_VENCIMIENTO
         ,P_BMO_MNEMONICO      => PPO1.PPO_BMO_MNEMONICO
         ,P_PERIODICIDAD_TASA  => PPO1.PPO_PERIODICIDAD_TASA
         ,P_MODALIDAD_TASA     => PPO1.PPO_MODALIDAD_TASA
         ,P_BASE_CALCULO       => PPO1.PPO_BASE_CALCULO
         ,P_TASA_FACIAL        => PPO1.PPO_TASA_FACIAL
         ,P_AMORTIZABLE        => PPO1.PPO_AMORTIZABLE
         ,P_TRE_MNEMONICO      => PPO1.PPO_TRE_MNEMONICO
         ,P_CAPITALIZABLE      => PPO1.PPO_CAPITALIZABLE
         ,P_FECHA_PRIMER_FLUJO => FECHA_PRIMER_FLUJO
         ,P_TIPO_PAGO_FLUJO    => PPO1.PPO_TIPO_PAGO_FLUJO
         ,P_PUNTOS_ADICIONALES => PPO1.PPO_PUNTOS_ADICIONALES
         ,P_CODIGO_PERIODO     => PPO1.PPO_CODIGO_PERIODO
         ,P_PER_NUM_IDEN       => PPO1.PPO_PER_NUM_IDEN
         ,P_PER_TID_CODIGO     => PPO1.PPO_PER_TID_CODIGO);
      OPEN C_DETALLE_NEGOCIO('C');
      FETCH C_DETALLE_NEGOCIO INTO VRP1;
      WHILE C_DETALLE_NEGOCIO%FOUND LOOP
         IF VRP1.VRP_DEPOSITO = 'DCVAL' THEN
            DEPOSITO := 'DA';
         ELSIF VRP1.VRP_DEPOSITO = 'DCV' THEN
            DEPOSITO := 'DV';
         END IF;
         IF VRP1.VRP_TIPO_REGISTRO = 'OTRAS' THEN
            LIC1.LIC_BOL_MNEMONICO := 'MEC';
            IF LENGTH(VRP1.VRP_NUMERO_OPERACION) >= 1 AND
               LENGTH(VRP1.VRP_NUMERO_OPERACION) <= 9 THEN
               LONGITUD := 17 - LENGTH(VRP1.VRP_NUMERO_OPERACION);
               NUMERO_OPERACION := RPAD(TO_CHAR(FECHA,'YYYYMMDD'),LONGITUD,'0') || LTRIM(TO_CHAR(VRP1.VRP_NUMERO_OPERACION));
            ELSE
               NUMERO_OPERACION := VRP1.VRP_NUMERO_OPERACION;
            END IF;
--            NUMERO_OPERACION := NULL;
            LIC1.LIC_NUMERO_FRACCION := NULL;
            LIC1.LIC_TIPO_OPERACION := NULL;
            CCC1.CCC_PER_NUM_IDEN := VRP1.VRP_PPO_PER_NUM_IDEN;
            CCC1.CCC_PER_TID_CODIGO := VRP1.VRP_PPO_PER_TID_CODIGO;
         ELSIF VRP1.VRP_TIPO_NEGOCIO = 'INT' AND
            VRP1.VRP_TIPO_REGISTRO = 'INTME' THEN
            LIC1.LIC_BOL_MNEMONICO := 'MEC';
            NUMERO_OPERACION := NULL;
            LIC1.LIC_NUMERO_FRACCION := NULL;
            LIC1.LIC_TIPO_OPERACION := NULL;
            CCC1.CCC_PER_NUM_IDEN := VRP1.VRP_PPO_PER_NUM_IDEN;
            CCC1.CCC_PER_TID_CODIGO := VRP1.VRP_PPO_PER_TID_CODIGO;
         ELSE
            SELECT SYSDATE INTO FECHA FROM DUAL;
            IF VRP1.VRP_NUMERO_OPERACION = TO_CHAR(FECHA,'YYYYMMDD') || '000009999' THEN
               LIC1.LIC_BOL_MNEMONICO := 'MEC';
               NUMERO_OPERACION := VRP1.VRP_NUMERO_OPERACION;
               LIC1.LIC_NUMERO_FRACCION := NULL;
               LIC1.LIC_TIPO_OPERACION := NULL;
               CCC1.CCC_PER_NUM_IDEN := VRP1.VRP_PPO_PER_NUM_IDEN;
               CCC1.CCC_PER_TID_CODIGO := VRP1.VRP_PPO_PER_TID_CODIGO;
            ELSE
               IF LENGTH(VRP1.VRP_NUMERO_OPERACION) >= 1 AND
                  LENGTH(VRP1.VRP_NUMERO_OPERACION) <= 9 THEN
                  LONGITUD := 17 - LENGTH(VRP1.VRP_NUMERO_OPERACION);
                  NUMERO_OPERACION := RPAD(TO_CHAR(FECHA,'YYYYMMDD'),LONGITUD,'0') || LTRIM(TO_CHAR(VRP1.VRP_NUMERO_OPERACION));
               ELSE
                  NUMERO_OPERACION := VRP1.VRP_NUMERO_OPERACION;
               END IF;
               OPEN C_LIQUIDACION_CORREDORES(NUMERO_OPERACION
                                         ,'C');
               FETCH C_LIQUIDACION_CORREDORES INTO LIC1;
               IF C_LIQUIDACION_CORREDORES%NOTFOUND THEN
                  CLOSE C_LIQUIDACION_CORREDORES;
                  RAISE_APPLICATION_ERROR(-20088,'No se pudo determinar la operaciżn de compra de CORREDORES para el folio '
                     || TO_CHAR(NUMERO_OPERACION));
               END IF;
               CLOSE C_LIQUIDACION_CORREDORES;
               IF VRP1.VRP_NPO_CONSECUTIVO IS NOT NULL AND
                  VRP1.VRP_OFD_CONSECUTIVO IS NULL THEN
                  UPDATE NEGOCIOS_POSICION
                  SET    NPO_NUMERO_OPERACION = LIC1.LIC_NUMERO_OPERACION
                        ,NPO_NUMERO_FRACCION = LIC1.LIC_NUMERO_FRACCION
                  WHERE  NPO_CONSECUTIVO = VRP1.VRP_NPO_CONSECUTIVO;
               ELSIF VRP2.VRP_NPO_CONSECUTIVO IS NOT NULL AND
                  VRP2.VRP_OFD_CONSECUTIVO IS NOT NULL THEN
                  UPDATE OFERTAS_DEMANDAS_POSICION
                  SET    OFD_NUMERO_OPERACION = LIC1.LIC_NUMERO_OPERACION
                        ,OFD_NUMERO_FRACCION = LIC1.LIC_NUMERO_FRACCION
                  WHERE  OFD_CONSECUTIVO = VRP1.VRP_OFD_CONSECUTIVO;
               END IF;
               OPEN C_COMERCIAL_CUENTA('C');
               FETCH C_COMERCIAL_CUENTA INTO CCC1;
               IF C_COMERCIAL_CUENTA%NOTFOUND THEN
                  CLOSE C_COMERCIAL_CUENTA;
                  RAISE_APPLICATION_ERROR(-20089,'No se pudo determinar el comercial de la cuenta de CORREDORES para el folio '
                     || TO_CHAR(NUMERO_OPERACION));
               END IF;
               CLOSE C_COMERCIAL_CUENTA;
            END IF;
         END IF;
         PORCENTAJE := ROUND((VRP1.VRP_VALOR_NOMINAL * 100) / TOTAL_NOMINAL,2);
         FECHA_CUMPLIMIENTO_INICIAL := VRP1.VRP_FECHA;
         IF VRP1.VRP_CLASE_OPERACION = 'CON' THEN
            IF TRUNC(VRP1.VRP_FECHA) = TRUNC(VRP1.VRP_FECHA_FUTURA) THEN
               CLASE_OPERACION := 'CONT';
            ELSE
               CLASE_OPERACION := 'CON';
            END IF;
            RE_COMPRA_VENTA := 'N';
            FECHA_CUMPLIMIENTO_INICIAL := TRUNC(VRP1.VRP_FECHA_FUTURA);
            VRP1.VRP_FECHA_FUTURA := NULL; -- INSTRUCCION PARA QUE NO SE VAYA LA FECHA FUTURA COMO SI FUERA SIMULTANEA
         ELSIF VRP1.VRP_CLASE_OPERACION = 'PLA' THEN
            RE_COMPRA_VENTA := 'N';
            CLASE_OPERACION := 'PLZ';
            FECHA_CUMPLIMIENTO_INICIAL := VRP1.VRP_FECHA_FUTURA;
         ELSIF VRP1.VRP_CLASE_OPERACION = 'SIM' THEN
            RE_COMPRA_VENTA := 'S';
            CLASE_OPERACION := 'SIM';
         ELSIF VRP1.VRP_CLASE_OPERACION = 'REP' THEN
            RE_COMPRA_VENTA := 'N';
            CLASE_OPERACION := 'REPO';
         ELSIF VRP1.VRP_CLASE_OPERACION = 'FON' THEN
            RE_COMPRA_VENTA := 'S';
            CLASE_OPERACION := 'FON';
         END IF;
         IF VRP1.VRP_CCC_CLI_PER_NUM_IDEN = P_PRF_FON_CODIGO AND
            VRP1.VRP_CCC_CLI_PER_TID_CODIGO = 'NIT' THEN
            IF VRP1.VRP_TIPO_REGISTRO = 'OTRAS' THEN
               FIC1.PER_NUM_IDEN := VRP1.VRP_FIC_PER_NUM_IDEN;
               FIC1.PER_TID_CODIGO := VRP1.VRP_FIC_PER_TID_CODIGO;
            ELSIF VRP1.VRP_TIPO_NEGOCIO = 'INT' AND
               VRP1.VRP_TIPO_REGISTRO = 'INTME' THEN
               FIC1.PER_NUM_IDEN := '860079174';
               FIC1.PER_TID_CODIGO := 'NIT';
            ELSE
               IF VRP1.VRP_NUMERO_OPERACION = TO_CHAR(FECHA,'YYYYMMDD') || '000009999' THEN
                  /* regreso de garantia de la camara de riesgo */
                  FIC1.PER_NUM_IDEN := '900182389';
                  FIC1.PER_TID_CODIGO := 'NIT';
               ELSE
                  OPEN C_CONTRAPARTE(LIC1.LIC_COD_CMSNSTA_VNDDOR);
                  FETCH C_CONTRAPARTE INTO FIC1;
                  IF C_CONTRAPARTE%NOTFOUND THEN
                     CLOSE C_CONTRAPARTE;
                     RAISE_APPLICATION_ERROR(-20090,'No se pudo determinar contraparte para el negocio '
                        || TO_CHAR(NUMERO_OPERACION));
                  END IF;
                  CLOSE C_CONTRAPARTE;
               END IF;
            END IF;
         ELSE
            FIC1.PER_NUM_IDEN := VRP1.VRP_CCC_CLI_PER_NUM_IDEN;
            FIC1.PER_TID_CODIGO := VRP1.VRP_CCC_CLI_PER_TID_CODIGO;
         END IF;
         TOTAL_PESOS_COMPRA := TOTAL_PESOS_COMPRA + VRP1.VRP_VALOR_PESOS;
         P_NEGOCIOS_POSICION.CREAR_PREORDEN_COMPRA
            (P_FONDO                       => P_PRF_FON_CODIGO
            ,P_PRF_CONSECUTIVO             => CONSECUTIVO_COMPRA
            ,P_CLI_PER_NUM_IDEN            => P_PRF_FON_CODIGO
            ,P_CLI_PER_TID_CODIGO          => 'NIT'
            ,P_PER_NUM_IDEN                => CCC1.CCC_PER_NUM_IDEN
            ,P_PER_TID_CODIGO              => CCC1.CCC_PER_TID_CODIGO
            ,P_LTI_MNEMONICO               => DEPOSITO
            ,P_MONTO                       => VRP1.VRP_VALOR_PESOS
            ,P_VALOR_NOMINAL               => VRP1.VRP_VALOR_NOMINAL
            ,P_PORCENTAJE_CLIENTE          => PORCENTAJE
            ,P_COMPROMISO_VENTA_FUTURA     => RE_COMPRA_VENTA
            ,P_PER_NUM_IDEN_ES_MODIFICADA  => P_PER_NUM_IDEN
            ,P_PER_TID_CODIGO_ES_MODIFICA  => P_PER_TID_CODIGO
            ,P_FECHA_MODIFICACION          => FECHA
            ,P_FECHA_CUMPLIMIENTO          => FECHA_CUMPLIMIENTO_INICIAL
            ,P_NUMERO_OPERACION            => NUMERO_OPERACION
            ,P_CNE_MNEMONICO               => CLASE_OPERACION
            ,P_MERCADO                     => 'S'
            ,P_BOL_MNEMONICO               => LIC1.LIC_BOL_MNEMONICO
            ,P_PER_NUM_IDEN_CONTRAPARTE    => FIC1.PER_NUM_IDEN
            ,P_PER_TID_CODIGO_CONTRAPARTE  => FIC1.PER_TID_CODIGO
            ,P_CCO_MNEMONICO               => NULL
            ,P_MONTO_PESOS                 => NULL
            ,P_NPO_CONSECUTIVO             => VRP1.VRP_NPO_CONSECUTIVO
            ,P_OFD_CONSECUTIVO             => VRP1.VRP_OFD_CONSECUTIVO
            ,P_LIC_NUMERO_FRACCION         => LIC1.LIC_NUMERO_FRACCION
            ,P_LIC_TIPO_OPERACION          => LIC1.LIC_TIPO_OPERACION
            ,P_FECHA_VENTA_FUTURA          => VRP1.VRP_FECHA_FUTURA
            ,P_TASA_FUTURA                 => VRP1.VRP_TASA_SIMULTANEA
            ,P_BASE_CALCULO_FUTURA         => VRP1.VRP_BASE_CALCULO_FUT
            ,P_VALOR_FUTURO                => VRP1.VRP_VALOR_FUTURO

            ,P_PRC_CONSECUTIVO             => CONSECUTIVO_PRC);
         IF VRP1.VRP_CLASE_OPERACION IN ('SIM','FON') THEN
            /* Se crea el negocio futuro asociado */
            P_NEGOCIOS_POSICION.CREAR_PREORDEN_FONDOS
               (P_FONDO                       => P_PRF_FON_CODIGO
               ,P_CONSECUTIVO                 => CONSECUTIVO_FUT
               ,P_ENA_MNEMONICO               => PPO1.PPO_ENA_MNEMONICO
               ,P_FECHA_OPERACION             => TRUNC(PPO1.PPO_FECHA)
               ,P_EOF_CODIGO                  => 'APR'
               ,P_TIPO_NEGOCIO                => 'V'
               ,P_TIPO                        => 'RF'
               ,P_TITULO_EXTERIOR             => 'N'
               ,P_VALOR_NOMINAL               => VRP1.VRP_VALOR_NOMINAL
               ,P_CANTIDAD                    => NULL
               ,P_NETEO                       => NULL
               ,P_FECHA_EMISION               => PPO1.PPO_FECHA_EMISION
               ,P_FECHA_VENCIMIENTO           => PPO1.PPO_FECHA_VENCIMIENTO
               ,P_BMO_MNEMONICO               => PPO1.PPO_BMO_MNEMONICO
               ,P_PERIODICIDAD_TASA           => PPO1.PPO_PERIODICIDAD_TASA
               ,P_MODALIDAD_TASA              => PPO1.PPO_MODALIDAD_TASA
               ,P_BASE_CALCULO                => PPO1.PPO_BASE_CALCULO
               ,P_TASA_FACIAL                 => PPO1.PPO_TASA_FACIAL
               ,P_AMORTIZABLE                 => PPO1.PPO_AMORTIZABLE
               ,P_TRE_MNEMONICO               => PPO1.PPO_TRE_MNEMONICO
               ,P_CAPITALIZABLE               => PPO1.PPO_CAPITALIZABLE
               ,P_FECHA_PRIMER_FLUJO          => FECHA_PRIMER_FLUJO
               ,P_TIPO_PAGO_FLUJO             => PPO1.PPO_TIPO_PAGO_FLUJO
               ,P_PUNTOS_ADICIONALES          => PPO1.PPO_PUNTOS_ADICIONALES
               ,P_CODIGO_PERIODO              => PPO1.PPO_CODIGO_PERIODO
               ,P_PER_NUM_IDEN                => PPO1.PPO_PER_NUM_IDEN
               ,P_PER_TID_CODIGO              => PPO1.PPO_PER_TID_CODIGO);
            P_NEGOCIOS_POSICION.CREAR_PREORDEN_VENTA
               (P_FONDO                       => P_PRF_FON_CODIGO
               ,P_PRF_CONSECUTIVO             => CONSECUTIVO_FUT
               ,P_CLI_PER_NUM_IDEN            => P_PRF_FON_CODIGO
               ,P_CLI_PER_TID_CODIGO          => 'NIT'
               ,P_PER_NUM_IDEN                => CCC1.CCC_PER_NUM_IDEN
               ,P_PER_TID_CODIGO              => CCC1.CCC_PER_TID_CODIGO
               ,P_LTI_MNEMONICO               => DEPOSITO
               ,P_MONTO                       => VRP1.VRP_VALOR_FUTURO
               ,P_VALOR_NOMINAL               => VRP1.VRP_VALOR_NOMINAL
               ,P_PORCENTAJE_CLIENTE          => PORCENTAJE
               ,P_COMPROMISO_COMPRA_FUTURA    => 'N'
               ,P_PER_NUM_IDEN_ES_MODIFICADA  => P_PER_NUM_IDEN
               ,P_PER_TID_CODIGO_ES_MODIFICA  => P_PER_TID_CODIGO
               ,P_FECHA_MODIFICACION          => FECHA
               ,P_FECHA_CUMPLIMIENTO          => VRP1.VRP_FECHA_FUTURA
               ,P_NUMERO_OPERACION            => NUMERO_OPERACION + 1
               ,P_CNE_MNEMONICO               => VRP1.VRP_CLASE_OPERACION
               ,P_MERCADO                     => 'S'
               ,P_BOL_MNEMONICO               => LIC1.LIC_BOL_MNEMONICO
               ,P_PER_NUM_IDEN_CONTRAPARTE    => FIC1.PER_NUM_IDEN
               ,P_PER_TID_CODIGO_CONTRAPARTE  => FIC1.PER_TID_CODIGO
               ,P_CCO_MNEMONICO               => NULL
               ,P_MONTO_PESOS                 => NULL
               ,P_NPO_CONSECUTIVO             => VRP1.VRP_NPO_CONSECUTIVO
               ,P_OFD_CONSECUTIVO             => VRP1.VRP_OFD_CONSECUTIVO
               ,P_ARBITRAJE                   => 'N'
               ,P_LIC_NUMERO_FRACCION         => LIC1.LIC_NUMERO_FRACCION
               ,P_LIC_TIPO_OPERACION          => 'V' --LIC1.LIC_TIPO_OPERACION
               ,P_PRV_CONSECUTIVO             => CONSECUTIVO_PRV);
            INSERT INTO PARTICIPACIONES_PREORDENES
               (PAP_PRF_FON_CODIGO
               ,PAP_PRF_CONSECUTIVO
               ,PAP_PER_NUM_IDEN
               ,PAP_PER_TID_CODIGO
               ,PAP_PORCENTAJE)
            VALUES
               (P_PRF_FON_CODIGO
               ,CONSECUTIVO_FUT
               ,CCC1.CCC_PER_NUM_IDEN
               ,CCC1.CCC_PER_TID_CODIGO
               ,100);
            /* Actualizaciżn de la futura en la actual */
            UPDATE PREORDENES_COMPRA
            SET    PRC_PRV_PRF_CONSECUTIVO = CONSECUTIVO_FUT
                  ,PRC_PRV_CONSECUTIVO = CONSECUTIVO_PRV
            WHERE  PRC_PRF_CONSECUTIVO = CONSECUTIVO_COMPRA
            AND    PRC_CONSECUTIVO = CONSECUTIVO_PRC
            AND    PRC_PRF_FON_CODIGO = P_PRF_FON_CODIGO;
         END IF;
         FETCH C_DETALLE_NEGOCIO INTO VRP1;
      END LOOP;
      CLOSE C_DETALLE_NEGOCIO;
      CCC1.CCC_PER_NUM_IDEN := VRP1.VRP_PPO_PER_NUM_IDEN;
      CCC1.CCC_PER_TID_CODIGO := VRP1.VRP_PPO_PER_TID_CODIGO;
      INSERT INTO PARTICIPACIONES_PREORDENES
         (PAP_PRF_FON_CODIGO
         ,PAP_PRF_CONSECUTIVO
         ,PAP_PER_NUM_IDEN
         ,PAP_PER_TID_CODIGO
         ,PAP_PORCENTAJE)
      VALUES
         (P_PRF_FON_CODIGO
         ,CONSECUTIVO_COMPRA
         ,CCC1.CCC_PER_NUM_IDEN
         ,CCC1.CCC_PER_TID_CODIGO
         ,100);
      P_NEGOCIOS_POSICION.EJECUCION_PREORDENES_COMPRA /*Ejecuciżn de las compras del dia*/
         (P_PRF_FON_CODIGO
         ,CONSECUTIVO_COMPRA
         ,SYSDATE
         ,'POS');
   END IF;
   OPEN C_FUTURAS_COMPRA;
   FETCH C_FUTURAS_COMPRA INTO PRC1;
   WHILE C_FUTURAS_COMPRA%FOUND LOOP
      TOTAL_PESOS_COMPRA :=  TOTAL_PESOS_COMPRA + PRC1.VRP_VALOR_PESOS;
      P_NEGOCIOS_POSICION.EJECUCION_PREORDENES_COMPRA /*Ejecuciżn de las compras que vienen de dias anteriores*/
         (P_PRF_FON_CODIGO
         ,PRC1.PRC_PRF_CONSECUTIVO
         ,SYSDATE
         ,'POSF');
      FETCH C_FUTURAS_COMPRA INTO PRC1;
   END LOOP;
   CLOSE C_FUTURAS_COMPRA;
   TOTAL_NOMINAL := NULL;
   OPEN C_TOTAL_NEGOCIO('V');
   FETCH C_TOTAL_NEGOCIO INTO TOTAL_NOMINAL;
   CLOSE C_TOTAL_NEGOCIO;
   TOTAL_NOMINAL := NVL(TOTAL_NOMINAL,0);
   IF TOTAL_NOMINAL != 0 THEN
      P_NEGOCIOS_POSICION.CREAR_PREORDEN_FONDOS
         (P_FONDO              => P_PRF_FON_CODIGO
         ,P_CONSECUTIVO        => CONSECUTIVO_VENTA
         ,P_ENA_MNEMONICO      => PPO1.PPO_ENA_MNEMONICO
         ,P_FECHA_OPERACION    => TRUNC(PPO1.PPO_FECHA)
         ,P_EOF_CODIGO         => 'APR'
         ,P_TIPO_NEGOCIO       => 'V'
         ,P_TIPO               => 'RF'
         ,P_TITULO_EXTERIOR    => 'N'
         ,P_VALOR_NOMINAL      => TOTAL_NOMINAL
         ,P_CANTIDAD           => NULL
         ,P_NETEO              => NULL
         ,P_FECHA_EMISION      => PPO1.PPO_FECHA_EMISION
         ,P_FECHA_VENCIMIENTO  => PPO1.PPO_FECHA_VENCIMIENTO
         ,P_BMO_MNEMONICO      => PPO1.PPO_BMO_MNEMONICO
         ,P_PERIODICIDAD_TASA  => PPO1.PPO_PERIODICIDAD_TASA
         ,P_MODALIDAD_TASA     => PPO1.PPO_MODALIDAD_TASA
         ,P_BASE_CALCULO       => PPO1.PPO_BASE_CALCULO
         ,P_TASA_FACIAL        => PPO1.PPO_TASA_FACIAL
         ,P_AMORTIZABLE        => PPO1.PPO_AMORTIZABLE
         ,P_TRE_MNEMONICO      => PPO1.PPO_TRE_MNEMONICO
         ,P_CAPITALIZABLE      => PPO1.PPO_CAPITALIZABLE
         ,P_FECHA_PRIMER_FLUJO => FECHA_PRIMER_FLUJO
         ,P_TIPO_PAGO_FLUJO    => PPO1.PPO_TIPO_PAGO_FLUJO
         ,P_PUNTOS_ADICIONALES => PPO1.PPO_PUNTOS_ADICIONALES
         ,P_CODIGO_PERIODO     => PPO1.PPO_CODIGO_PERIODO
         ,P_PER_NUM_IDEN       => PPO1.PPO_PER_NUM_IDEN
         ,P_PER_TID_CODIGO     => PPO1.PPO_PER_TID_CODIGO);
      OPEN C_DETALLE_NEGOCIO('V');
      FETCH C_DETALLE_NEGOCIO INTO VRP1;
      WHILE C_DETALLE_NEGOCIO%FOUND LOOP
         IF VRP1.VRP_DEPOSITO = 'DCVAL' THEN
            DEPOSITO := 'DA';
         ELSIF VRP1.VRP_DEPOSITO = 'DCV' THEN
            DEPOSITO := 'DV';
         END IF;
         IF VRP1.VRP_TIPO_REGISTRO = 'OTRAS' THEN
            LIC1.LIC_BOL_MNEMONICO := 'MEC';
            IF LENGTH(VRP1.VRP_NUMERO_OPERACION) >= 1 AND
               LENGTH(VRP1.VRP_NUMERO_OPERACION) <= 9 THEN
               LONGITUD := 17 - LENGTH(VRP1.VRP_NUMERO_OPERACION);
               NUMERO_OPERACION := RPAD(TO_CHAR(FECHA,'YYYYMMDD'),LONGITUD,'0') || LTRIM(TO_CHAR(VRP1.VRP_NUMERO_OPERACION));
            ELSE
               NUMERO_OPERACION := VRP1.VRP_NUMERO_OPERACION;
            END IF;
--            NUMERO_OPERACION := NULL;
            LIC1.LIC_NUMERO_FRACCION := NULL;
            LIC1.LIC_TIPO_OPERACION := NULL;
            CCC1.CCC_PER_NUM_IDEN := VRP1.VRP_PPO_PER_NUM_IDEN;
            CCC1.CCC_PER_TID_CODIGO := VRP1.VRP_PPO_PER_TID_CODIGO;
         ELSIF VRP1.VRP_TIPO_NEGOCIO = 'INT' AND
            VRP1.VRP_TIPO_REGISTRO = 'INTME' THEN
            LIC1.LIC_BOL_MNEMONICO := 'MEC';
            NUMERO_OPERACION := NULL;
            LIC1.LIC_NUMERO_FRACCION := NULL;
            LIC1.LIC_TIPO_OPERACION := NULL;
            CCC1.CCC_PER_NUM_IDEN := VRP1.VRP_PPO_PER_NUM_IDEN;
            CCC1.CCC_PER_TID_CODIGO := VRP1.VRP_PPO_PER_TID_CODIGO;
         ELSE
            SELECT SYSDATE INTO FECHA FROM DUAL;
            IF VRP1.VRP_NUMERO_OPERACION = TO_CHAR(FECHA,'YYYYMMDD') || '000009999' THEN
               LIC1.LIC_BOL_MNEMONICO := 'MEC';
               NUMERO_OPERACION := VRP1.VRP_NUMERO_OPERACION;
               LIC1.LIC_NUMERO_FRACCION := NULL;
               LIC1.LIC_TIPO_OPERACION := NULL;
               CCC1.CCC_PER_NUM_IDEN := VRP1.VRP_PPO_PER_NUM_IDEN;
               CCC1.CCC_PER_TID_CODIGO := VRP1.VRP_PPO_PER_TID_CODIGO;
            ELSE
               IF LENGTH(VRP1.VRP_NUMERO_OPERACION) >= 1 AND
                  LENGTH(VRP1.VRP_NUMERO_OPERACION) <= 9 THEN
                  SELECT SYSDATE INTO FECHA FROM DUAL;
                  LONGITUD := 17 - LENGTH(VRP1.VRP_NUMERO_OPERACION);
                  NUMERO_OPERACION := RPAD(TO_CHAR(FECHA,'YYYYMMDD'),LONGITUD,'0') || LTRIM(TO_CHAR(VRP1.VRP_NUMERO_OPERACION));
               ELSE
                  NUMERO_OPERACION := VRP1.VRP_NUMERO_OPERACION;
               END IF;
               OPEN C_LIQUIDACION_CORREDORES(NUMERO_OPERACION
                                            ,'V');
               FETCH C_LIQUIDACION_CORREDORES INTO LIC1;
               IF C_LIQUIDACION_CORREDORES%NOTFOUND THEN
                  CLOSE C_LIQUIDACION_CORREDORES;
                  RAISE_APPLICATION_ERROR(-20093,'No se pudo determinar la operaciżn de compra de CORREDORES para el folio '
                     || TO_CHAR(NUMERO_OPERACION));
               END IF;
               CLOSE C_LIQUIDACION_CORREDORES;
               IF VRP1.VRP_NPO_CONSECUTIVO IS NOT NULL AND
                  VRP1.VRP_OFD_CONSECUTIVO IS NULL THEN
                  UPDATE NEGOCIOS_POSICION
                  SET    NPO_NUMERO_OPERACION = LIC1.LIC_NUMERO_OPERACION
                        ,NPO_NUMERO_FRACCION = LIC1.LIC_NUMERO_FRACCION
                  WHERE  NPO_CONSECUTIVO = VRP1.VRP_NPO_CONSECUTIVO;
               ELSIF VRP2.VRP_NPO_CONSECUTIVO IS NOT NULL AND
                  VRP2.VRP_OFD_CONSECUTIVO IS NOT NULL THEN
                  UPDATE OFERTAS_DEMANDAS_POSICION
                  SET    OFD_NUMERO_OPERACION = LIC1.LIC_NUMERO_OPERACION
                        ,OFD_NUMERO_FRACCION = LIC1.LIC_NUMERO_FRACCION
                  WHERE  OFD_CONSECUTIVO = VRP1.VRP_OFD_CONSECUTIVO;
               END IF;
               OPEN C_COMERCIAL_CUENTA('V');
               FETCH C_COMERCIAL_CUENTA INTO CCC1;
               IF C_COMERCIAL_CUENTA%NOTFOUND THEN
                  CLOSE C_COMERCIAL_CUENTA;
                  RAISE_APPLICATION_ERROR(-20094,'No se pudo determinar el comercial de la cuenta de CORREDORES para el folio '
                     || TO_CHAR(NUMERO_OPERACION));
               END IF;
               CLOSE C_COMERCIAL_CUENTA;
            END IF;
         END IF;
         PORCENTAJE := ROUND((VRP1.VRP_VALOR_NOMINAL * 100) / TOTAL_NOMINAL,2);
         FECHA_CUMPLIMIENTO_INICIAL := VRP1.VRP_FECHA;
         IF VRP1.VRP_CLASE_OPERACION = 'CON' THEN
            IF TRUNC(VRP1.VRP_FECHA) = TRUNC(VRP1.VRP_FECHA_FUTURA) THEN
               CLASE_OPERACION := 'CONT';
            ELSE
               CLASE_OPERACION := 'CON';
            END IF;
            RE_COMPRA_VENTA := 'N';
            FECHA_CUMPLIMIENTO_INICIAL := TRUNC(VRP1.VRP_FECHA_FUTURA);
            VRP1.VRP_FECHA_FUTURA := NULL; -- INSTRUCCION PARA QUE NO SE VAYA LA FECHA FUTURA COMO SI FUERA SIMULTANEA
         ELSIF VRP1.VRP_CLASE_OPERACION = 'PLA' THEN
            RE_COMPRA_VENTA := 'N';
            CLASE_OPERACION := 'PLZ';
            FECHA_CUMPLIMIENTO_INICIAL := VRP1.VRP_FECHA_FUTURA;
         ELSIF VRP1.VRP_CLASE_OPERACION = 'SIM' THEN
            RE_COMPRA_VENTA := 'S';
            CLASE_OPERACION := 'SIM';
         ELSIF VRP1.VRP_CLASE_OPERACION = 'REP' THEN
            RE_COMPRA_VENTA := 'N';
            CLASE_OPERACION := 'REPO';
         ELSIF VRP1.VRP_CLASE_OPERACION = 'FON' THEN
            RE_COMPRA_VENTA := 'S';
            CLASE_OPERACION := 'FON';
         END IF;
         IF VRP1.VRP_CCC_CLI_PER_NUM_IDEN = P_PRF_FON_CODIGO AND
            VRP1.VRP_CCC_CLI_PER_TID_CODIGO = 'NIT' THEN
            IF VRP1.VRP_TIPO_REGISTRO = 'OTRAS' THEN
               FIC1.PER_NUM_IDEN := VRP1.VRP_FIC_PER_NUM_IDEN;
               FIC1.PER_TID_CODIGO := VRP1.VRP_FIC_PER_TID_CODIGO;
            ELSIF VRP1.VRP_TIPO_NEGOCIO = 'INT' AND
               VRP1.VRP_TIPO_REGISTRO = 'INTME' THEN
               FIC1.PER_NUM_IDEN := '860079174';
               FIC1.PER_TID_CODIGO := 'NIT';
            ELSE
               IF VRP1.VRP_NUMERO_OPERACION = TO_CHAR(FECHA,'YYYYMMDD') || '000009999' THEN
                  /* regreso de garantia de la camara de riesgo */
                  FIC1.PER_NUM_IDEN := '900182389';
                  FIC1.PER_TID_CODIGO := 'NIT';
               ELSE
                  OPEN C_CONTRAPARTE(LIC1.LIC_COD_CMSNSTA_CMPRDOR);
                  FETCH C_CONTRAPARTE INTO FIC1;
                  IF C_CONTRAPARTE%NOTFOUND THEN
                     CLOSE C_CONTRAPARTE;
                     RAISE_APPLICATION_ERROR(-20095,'No se pudo determinar contraparte para el negocio '
                        || TO_CHAR(NUMERO_OPERACION));
                  END IF;
                  CLOSE C_CONTRAPARTE;
               END IF;
            END IF;
         ELSE
            FIC1.PER_NUM_IDEN := VRP1.VRP_CCC_CLI_PER_NUM_IDEN;
            FIC1.PER_TID_CODIGO := VRP1.VRP_CCC_CLI_PER_TID_CODIGO;
         END IF;
         TOTAL_PESOS_VENTA := TOTAL_PESOS_VENTA + VRP1.VRP_VALOR_PESOS;
         P_NEGOCIOS_POSICION.CREAR_PREORDEN_VENTA
            (P_FONDO                       => P_PRF_FON_CODIGO
            ,P_PRF_CONSECUTIVO             => CONSECUTIVO_VENTA
            ,P_CLI_PER_NUM_IDEN            => P_PRF_FON_CODIGO
            ,P_CLI_PER_TID_CODIGO          => 'NIT'
            ,P_PER_NUM_IDEN                => CCC1.CCC_PER_NUM_IDEN
            ,P_PER_TID_CODIGO              => CCC1.CCC_PER_TID_CODIGO
            ,P_LTI_MNEMONICO               => DEPOSITO
            ,P_MONTO                       => VRP1.VRP_VALOR_PESOS
            ,P_VALOR_NOMINAL               => VRP1.VRP_VALOR_NOMINAL
            ,P_PORCENTAJE_CLIENTE          => PORCENTAJE
            ,P_COMPROMISO_COMPRA_FUTURA    => RE_COMPRA_VENTA
            ,P_PER_NUM_IDEN_ES_MODIFICADA  => P_PER_NUM_IDEN
            ,P_PER_TID_CODIGO_ES_MODIFICA  => P_PER_TID_CODIGO
            ,P_FECHA_MODIFICACION          => FECHA
            ,P_FECHA_CUMPLIMIENTO          => FECHA_CUMPLIMIENTO_INICIAL
            ,P_NUMERO_OPERACION            => NUMERO_OPERACION
            ,P_CNE_MNEMONICO               => CLASE_OPERACION
            ,P_MERCADO                     => 'S'
            ,P_BOL_MNEMONICO               => LIC1.LIC_BOL_MNEMONICO
            ,P_PER_NUM_IDEN_CONTRAPARTE    => FIC1.PER_NUM_IDEN
            ,P_PER_TID_CODIGO_CONTRAPARTE  => FIC1.PER_TID_CODIGO
            ,P_CCO_MNEMONICO               => NULL
            ,P_MONTO_PESOS                 => NULL
            ,P_NPO_CONSECUTIVO             => VRP1.VRP_NPO_CONSECUTIVO
            ,P_OFD_CONSECUTIVO             => VRP1.VRP_OFD_CONSECUTIVO
            ,P_ARBITRAJE                   => 'N'
            ,P_LIC_NUMERO_FRACCION         => LIC1.LIC_NUMERO_FRACCION
            ,P_LIC_TIPO_OPERACION          => LIC1.LIC_TIPO_OPERACION
            ,P_FECHA_COMPRA_FUTURA         => VRP1.VRP_FECHA_FUTURA
            ,P_TASA_FUTURA                 => VRP1.VRP_TASA_SIMULTANEA
            ,P_BASE_CALCULO_FUTURA         => VRP1.VRP_BASE_CALCULO_FUT
            ,P_VALOR_FUTURO                => VRP1.VRP_VALOR_FUTURO
            ,P_PRV_CONSECUTIVO             => CONSECUTIVO_PRV);
         IF VRP1.VRP_CLASE_OPERACION IN ('SIM','FON') THEN
            /* Se crea el negocio futuro asociado */
            P_NEGOCIOS_POSICION.CREAR_PREORDEN_FONDOS
               (P_FONDO                       => P_PRF_FON_CODIGO
               ,P_CONSECUTIVO                 => CONSECUTIVO_FUT
               ,P_ENA_MNEMONICO               => PPO1.PPO_ENA_MNEMONICO
               ,P_FECHA_OPERACION             => TRUNC(PPO1.PPO_FECHA)
               ,P_EOF_CODIGO                  => 'APR'
               ,P_TIPO_NEGOCIO                => 'C'
               ,P_TIPO                        => 'RF'
               ,P_TITULO_EXTERIOR             => 'N'
               ,P_VALOR_NOMINAL               => VRP1.VRP_VALOR_NOMINAL
               ,P_CANTIDAD                    => NULL
               ,P_NETEO                       => NULL
               ,P_FECHA_EMISION               => PPO1.PPO_FECHA_EMISION
               ,P_FECHA_VENCIMIENTO           => PPO1.PPO_FECHA_VENCIMIENTO
               ,P_BMO_MNEMONICO               => PPO1.PPO_BMO_MNEMONICO
               ,P_PERIODICIDAD_TASA           => PPO1.PPO_PERIODICIDAD_TASA
               ,P_MODALIDAD_TASA              => PPO1.PPO_MODALIDAD_TASA
               ,P_BASE_CALCULO                => PPO1.PPO_BASE_CALCULO
               ,P_TASA_FACIAL                 => PPO1.PPO_TASA_FACIAL
               ,P_AMORTIZABLE                 => PPO1.PPO_AMORTIZABLE
               ,P_TRE_MNEMONICO               => PPO1.PPO_TRE_MNEMONICO
               ,P_CAPITALIZABLE               => PPO1.PPO_CAPITALIZABLE
               ,P_FECHA_PRIMER_FLUJO          => FECHA_PRIMER_FLUJO
               ,P_TIPO_PAGO_FLUJO             => PPO1.PPO_TIPO_PAGO_FLUJO
               ,P_PUNTOS_ADICIONALES          => PPO1.PPO_PUNTOS_ADICIONALES
               ,P_CODIGO_PERIODO              => PPO1.PPO_CODIGO_PERIODO
               ,P_PER_NUM_IDEN                => PPO1.PPO_PER_NUM_IDEN
               ,P_PER_TID_CODIGO              => PPO1.PPO_PER_TID_CODIGO);
            P_NEGOCIOS_POSICION.CREAR_PREORDEN_COMPRA
               (P_FONDO                       => P_PRF_FON_CODIGO
               ,P_PRF_CONSECUTIVO             => CONSECUTIVO_FUT
               ,P_CLI_PER_NUM_IDEN            => P_PRF_FON_CODIGO
               ,P_CLI_PER_TID_CODIGO          => 'NIT'
               ,P_PER_NUM_IDEN                => CCC1.CCC_PER_NUM_IDEN
               ,P_PER_TID_CODIGO              => CCC1.CCC_PER_TID_CODIGO
               ,P_LTI_MNEMONICO               => DEPOSITO
               ,P_MONTO                       => VRP1.VRP_VALOR_FUTURO
               ,P_VALOR_NOMINAL               => VRP1.VRP_VALOR_NOMINAL
               ,P_PORCENTAJE_CLIENTE          => PORCENTAJE
               ,P_COMPROMISO_VENTA_FUTURA     => 'N'
               ,P_PER_NUM_IDEN_ES_MODIFICADA  => P_PER_NUM_IDEN
               ,P_PER_TID_CODIGO_ES_MODIFICA  => P_PER_TID_CODIGO
               ,P_FECHA_MODIFICACION          => FECHA
               ,P_FECHA_CUMPLIMIENTO          => VRP1.VRP_FECHA_FUTURA
               ,P_NUMERO_OPERACION            => NUMERO_OPERACION + 1
               ,P_CNE_MNEMONICO               => CLASE_OPERACION
               ,P_MERCADO                     => 'S'
               ,P_BOL_MNEMONICO               => LIC1.LIC_BOL_MNEMONICO
               ,P_PER_NUM_IDEN_CONTRAPARTE    => FIC1.PER_NUM_IDEN
               ,P_PER_TID_CODIGO_CONTRAPARTE  => FIC1.PER_TID_CODIGO
               ,P_CCO_MNEMONICO               => NULL
               ,P_MONTO_PESOS                 => NULL
               ,P_NPO_CONSECUTIVO             => VRP1.VRP_NPO_CONSECUTIVO
               ,P_OFD_CONSECUTIVO             => VRP1.VRP_OFD_CONSECUTIVO
               ,P_LIC_NUMERO_FRACCION         => LIC1.LIC_NUMERO_FRACCION
               ,P_LIC_TIPO_OPERACION          => 'C'
               ,P_PRC_CONSECUTIVO             => CONSECUTIVO_PRC);
            INSERT INTO PARTICIPACIONES_PREORDENES
               (PAP_PRF_FON_CODIGO
               ,PAP_PRF_CONSECUTIVO
               ,PAP_PER_NUM_IDEN
               ,PAP_PER_TID_CODIGO
               ,PAP_PORCENTAJE)
            VALUES
               (P_PRF_FON_CODIGO
               ,CONSECUTIVO_FUT
               ,CCC1.CCC_PER_NUM_IDEN
               ,CCC1.CCC_PER_TID_CODIGO
               ,100);
            /* Actualizaciżn de la futura en la actual */
            UPDATE PREORDENES_VENTA
            SET    PRV_PRC_PRF_CONSECUTIVO = CONSECUTIVO_FUT
                  ,PRV_PRC_CONSECUTIVO = CONSECUTIVO_PRC
            WHERE  PRV_PRF_CONSECUTIVO = CONSECUTIVO_VENTA
            AND    PRV_CONSECUTIVO = CONSECUTIVO_PRV
            AND    PRV_PRF_FON_CODIGO = P_PRF_FON_CODIGO;
         END IF;
         FETCH C_DETALLE_NEGOCIO INTO VRP1;
      END LOOP;
      CLOSE C_DETALLE_NEGOCIO;
      CCC1.CCC_PER_NUM_IDEN := VRP1.VRP_PPO_PER_NUM_IDEN;
      CCC1.CCC_PER_TID_CODIGO := VRP1.VRP_PPO_PER_TID_CODIGO;
      INSERT INTO PARTICIPACIONES_PREORDENES
         (PAP_PRF_FON_CODIGO
         ,PAP_PRF_CONSECUTIVO
         ,PAP_PER_NUM_IDEN
         ,PAP_PER_TID_CODIGO
         ,PAP_PORCENTAJE)
      VALUES
         (P_PRF_FON_CODIGO
         ,CONSECUTIVO_VENTA
         ,CCC1.CCC_PER_NUM_IDEN
         ,CCC1.CCC_PER_TID_CODIGO
         ,100);
   END IF;
   P_NEGOCIOS_POSICION.VERIFICAR_FRACCIONAR_POSICION
      (P_PPO_CONSECUTIVO          => P_PPO_CONSECUTIVO
      ,P_PPO_ENA_MNEMONICO        => P_PPO_ENA_MNEMONICO
      ,P_PRF_FON_CODIGO           => P_PRF_FON_CODIGO
      ,P_FECHA                    => SYSDATE
      ,P_PRV_PRF_CONSECUTIVO      => CONSECUTIVO_VENTA);
   IF CONSECUTIVO_VENTA IS NOT NULL THEN
      P_NEGOCIOS_POSICION.EJECUTAR_PREORDENES_VENTA
         (P_PRF_FON_CODIGO           => P_PRF_FON_CODIGO
         ,P_PRF_CONSECUTIVO          => CONSECUTIVO_VENTA
         ,P_FECHA                    => SYSDATE
         ,P_COMISION                 => 0
         ,P_TIPO_OPERACION           => 'POS');
   END IF;
   OPEN C_FUTURAS_VENTA;
   FETCH C_FUTURAS_VENTA INTO PRV1;
   WHILE C_FUTURAS_VENTA%FOUND LOOP
      TOTAL_PESOS_VENTA := TOTAL_PESOS_VENTA + PRV1.VRP_VALOR_PESOS;
      P_NEGOCIOS_POSICION.EJECUTAR_PREORDENES_VENTA/*Ejecuciżn de las ventas que vienen de dias anteriores*/
         (P_PRF_FON_CODIGO
         ,PRV1.PRV_PRF_CONSECUTIVO
         ,SYSDATE
         ,0
         ,'POSF');
      FETCH C_FUTURAS_VENTA INTO PRV1;
   END LOOP;
   CLOSE C_FUTURAS_VENTA;
   TOTAL_PESOS_COMPRA := 0;
   TOTAL_PESOS_VENTA := 0;
   TOTAL_FONDEOS := 0;
   TOTAL_COMERCIAL := 0;
   TOTAL_COMISION_INTRAMESAS := 0;
   SELECT CEP_SEQ.NEXTVAL INTO SIGUIENTE FROM DUAL;
   INSERT INTO COMISIONES_MESAS_POSICION
      (CPO_CONSECUTIVO
      ,CPO_FECHA
      ,CPO_PPO_CONSECUTIVO
      ,CPO_PER_NUM_IDEN
      ,CPO_PER_TID_CODIGO
      ,CPO_TOTAL_COMPRAS
      ,CPO_TOTAL_VENTAS
      ,CPO_TOTAL_UTILIDAD
      ,CPO_TOTAL_UTILIDAD_MESA
      ,CPO_TOTAL_UTILIDAD_COMERCIAL
      ,CPO_TOTAL_FONDEOS_INTERNOS
      ,CPO_TOTAL_COMISION_INTRAMESAS)
   VALUES
      (SIGUIENTE
      ,SYSDATE
      ,P_PPO_CONSECUTIVO
      ,PPO1.PPO_PER_NUM_IDEN
      ,PPO1.PPO_PER_TID_CODIGO
      ,0
      ,0
      ,0
      ,0
      ,0
      ,0
      ,0);
   OPEN C_NEGOCIOS_POSICION;
   FETCH C_NEGOCIOS_POSICION INTO VRP2;
   WHILE C_NEGOCIOS_POSICION%FOUND LOOP
      IF VRP2.VRP_TIPO_OPERACION = 'C' THEN
         TOTAL_PESOS_COMPRA := TOTAL_PESOS_COMPRA + VRP2.VRP_VALOR_PESOS;
         TOTAL_NOMINAL_COMPRA := TOTAL_NOMINAL_COMPRA + VRP2.VRP_VALOR_NOMINAL;
      ELSIF VRP2.VRP_TIPO_OPERACION = 'V' THEN
         TOTAL_PESOS_VENTA := TOTAL_PESOS_VENTA + VRP2.VRP_VALOR_PESOS;
      END IF;
      /* Las dos condiciones que siguen no se validan contra la fecha futura debido que
         la vista para la simultaneas de regreso tiene el campo fecha futura en NULL */
      IF VRP2.VRP_CLASE_OPERACION = 'FON' AND
         VRP2.VRP_TIPO_REGISTRO = 'COASA' AND
         VRP2.VRP_ESTADO = 'ECO' THEN
         VRP1.VRP_PPO_PER_NUM_IDEN := VRP2.VRP_PPO_PER_NUM_IDEN;
         VRP1.VRP_PPO_PER_TID_CODIGO := VRP2.VRP_PPO_PER_TID_CODIGO;
         VALOR_FONDEO := NULL;

         SELECT NPO_VALOR_FUTURO - NPO_VALOR_PESOS
         INTO   VALOR_FONDEO
         FROM   NEGOCIOS_POSICION
         WHERE  NPO_CONSECUTIVO = VRP2.VRP_NPO_CONSECUTIVO;
         TOTAL_FONDEOS := TOTAL_FONDEOS + NVL(VALOR_FONDEO,0);

         INSERT INTO COMISIONES_POSICION_COMERCIAL
            (CPC_CONSECUTIVO
            ,CPC_CPO_CONSECUTIVO
            ,CPC_PER_NUM_IDEN
            ,CPC_PER_TID_CODIGO
            ,CPC_UTILIDAD
            ,CPC_VALOR_NOMINAL_FONDEO)
         VALUES
            (CPC_SEQ.NEXTVAL
            ,SIGUIENTE
            ,PPO1.PPO_PER_NUM_IDEN
            ,PPO1.PPO_PER_TID_CODIGO
            ,NVL(VALOR_FONDEO,0)
            ,VRP2.VRP_VALOR_NOMINAL);
      END IF;
      IF VRP2.VRP_TIPO_REGISTRO = 'INTME' AND
         VRP2.VRP_TIPO_NEGOCIO != 'INT' THEN
         TOTAL_COMISION_INTRAMESAS := TOTAL_COMISION_INTRAMESAS + NVL(VRP2.VRP_COMISION_INTRAMESA,0);
         OPEN C_NEGOCIOS_POSICION_INT;
         FETCH C_NEGOCIOS_POSICION_INT INTO NPO1;
         CLOSE C_NEGOCIOS_POSICION_INT;
         INSERT INTO COMISIONES_POSICION_COMERCIAL
            (CPC_CONSECUTIVO
            ,CPC_CPO_CONSECUTIVO
            ,CPC_PER_NUM_IDEN
            ,CPC_PER_TID_CODIGO
            ,CPC_UTILIDAD
            ,CPC_PRC_PRF_CONSECUTIVO
            ,CPC_PRC_PRF_FON_CODIGO
            ,CPC_PRC_CONSECUTIVO
            ,CPC_PRV_PRF_CONSECUTIVO
            ,CPC_PRV_PRF_FON_CODIGO
            ,CPC_PRV_CONSECUTIVO
            ,CPC_PER_NUM_IDEN_CONTRAPARTE
            ,CPC_PER_TID_CODIGO_CONTRAPARTE
            ,CPC_VALOR_NOMINAL)
         VALUES
            (CPC_SEQ.NEXTVAL
            ,SIGUIENTE
            ,NPO1.NPO_PER_NUM_IDEN
            ,NPO1.NPO_PER_TID_CODIGO
            ,NVL(VRP2.VRP_COMISION_INTRAMESA,0)
            ,NPO1.PRC_PRF_CONSECUTIVO
            ,NPO1.PRC_PRF_FON_CODIGO
            ,NPO1.PRC_CONSECUTIVO
            ,NPO1.PRV_PRF_CONSECUTIVO
            ,NPO1.PRV_PRF_FON_CODIGO
            ,NPO1.PRV_CONSECUTIVO
            ,NVL(NPO1.PRC_PER_NUM_IDEN_CONTRAPARTE,NPO1.PRV_PER_NUM_IDEN_CONTRAPARTE)
            ,NVL(NPO1.PRC_PER_TID_CODIGO_CONTRAPARTE,NPO1.PRV_PER_TID_CODIGO_CONTRAPARTE)
            ,NPO1.NPO_VALOR_NOMINAL);
      END IF;
      IF VRP2.VRP_CLASE_OPERACION = 'SIM' AND
         VRP2.VRP_ESTADO = 'ECO' AND
         VRP2.VRP_OFD_CONSECUTIVO IS NOT NULL THEN
         COMISION := NULL;
         FECHA_FUTURA := NULL;
         VALOR_FUTURO := NULL;
         OPEN C_OFERTAS_SIMULTANEAS;
         FETCH C_OFERTAS_SIMULTANEAS INTO OFD2;
         CLOSE C_OFERTAS_SIMULTANEAS;
         P_NEGOCIOS_POSICION.CALCULAR_COMISION_Y_FUTURO
            (P_OFD_TASA                  => OFD2.OFD_TASA
            ,P_OFD_PLAZO                 => OFD2.OFD_PLAZO
            ,P_OFD_VALOR_PESOS_ADQUIRIDO => OFD2.OFD_VALOR_PESOS_ADQUIRIDO
            ,P_OFD_FECHA                 => OFD2.OFD_FECHA
            ,P_NPO_CONSECUTIVO           => OFD2.OFD_NPO_CONSECUTIVO
            ,P_OFD_FECHA_FUTURA          => FECHA_FUTURA
            ,P_OFD_VALOR_FUTURO          => VALOR_FUTURO
            ,P_COMISION                  => COMISION);
         INSERT INTO COMISIONES_POSICION_COMERCIAL
            (CPC_CONSECUTIVO
            ,CPC_CPO_CONSECUTIVO
            ,CPC_PER_NUM_IDEN
            ,CPC_PER_TID_CODIGO
            ,CPC_CCC_CLI_PER_NUM_IDEN
            ,CPC_CCC_CLI_PER_TID_CODIGO
            ,CPC_CCC_NUMERO_CUENTA
            ,CPC_UTILIDAD
            ,CPC_PRC_PRF_CONSECUTIVO
            ,CPC_PRC_PRF_FON_CODIGO
            ,CPC_PRC_CONSECUTIVO
            ,CPC_PRV_PRF_CONSECUTIVO
            ,CPC_PRV_PRF_FON_CODIGO
            ,CPC_PRV_CONSECUTIVO
            ,CPC_VALOR_NOMINAL)
         VALUES
            (CPC_SEQ.NEXTVAL
            ,SIGUIENTE
            ,OFD2.CCC_PER_NUM_IDEN
            ,OFD2.CCC_PER_TID_CODIGO
            ,VRP2.VRP_CCC_CLI_PER_NUM_IDEN
            ,VRP2.VRP_CCC_CLI_PER_TID_CODIGO
            ,VRP2.VRP_CCC_NUMERO_CUENTA
            ,nvl(COMISION,0) /*----------------------*/
            ,OFD2.PRC_PRF_CONSECUTIVO
            ,OFD2.PRC_PRF_FON_CODIGO
            ,OFD2.PRC_CONSECUTIVO
            ,OFD2.PRV_PRF_CONSECUTIVO
            ,OFD2.PRV_PRF_FON_CODIGO
            ,OFD2.PRV_CONSECUTIVO
            ,OFD2.OFD_NOMINAL_ADQUIRIDO);
         TOTAL_COMERCIAL := TOTAL_COMERCIAL + nvl(COMISION,0); /*----------------------*/
      END IF;
      IF VRP2.VRP_NPO_CONSECUTIVO IS NOT NULL AND
         VRP2.VRP_OFD_CONSECUTIVO IS NULL THEN
         IF VRP2.VRP_ESTADO IN ('COM','REG') THEN
            P_NEGOCIOS_POSICION.INSERTAR_CAMBIO_ESTADO
               (P_CEP_PER_NUM_IDEN       => P_PER_NUM_IDEN
               ,P_CEP_PER_TID_CODIGO     => P_PER_TID_CODIGO
               ,P_CEP_VALOR_ANTERIOR     => NVL(VRP2.VRP_ESTADO_CUMPLIMIENTO,VRP2.VRP_ESTADO)
               ,P_CEP_VALOR_POSTERIOR    => 'ECO'
               ,P_CEP_DESCRIPCION        => NULL
               ,P_CEP_OFD_CONSECUTIVO    => NULL
               ,P_CEP_NPO_CONSECUTIVO    => VRP2.VRP_NPO_CONSECUTIVO);
            UPDATE NEGOCIOS_POSICION
            SET    NPO_ESTADO = 'ECO'
            WHERE  NPO_CONSECUTIVO = VRP2.VRP_NPO_CONSECUTIVO;
         ELSIF VRP2.VRP_ESTADO = 'ECO' THEN
            P_NEGOCIOS_POSICION.INSERTAR_CAMBIO_ESTADO
               (P_CEP_PER_NUM_IDEN       => P_PER_NUM_IDEN
               ,P_CEP_PER_TID_CODIGO     => P_PER_TID_CODIGO
               ,P_CEP_VALOR_ANTERIOR     => NVL(VRP2.VRP_ESTADO_CUMPLIMIENTO,VRP2.VRP_ESTADO)
               ,P_CEP_VALOR_POSTERIOR    => 'ESR'
               ,P_CEP_DESCRIPCION        => NULL
               ,P_CEP_OFD_CONSECUTIVO    => NULL
               ,P_CEP_NPO_CONSECUTIVO    => VRP2.VRP_NPO_CONSECUTIVO);
            UPDATE NEGOCIOS_POSICION
            SET    NPO_ESTADO = 'ESR'
            WHERE  NPO_CONSECUTIVO = VRP2.VRP_NPO_CONSECUTIVO;
         END IF;
      ELSIF VRP2.VRP_NPO_CONSECUTIVO IS NOT NULL AND
         VRP2.VRP_OFD_CONSECUTIVO IS NOT NULL THEN
         IF VRP2.VRP_ESTADO = 'COM' THEN
            P_NEGOCIOS_POSICION.INSERTAR_CAMBIO_ESTADO
               (P_CEP_PER_NUM_IDEN       => P_PER_NUM_IDEN
               ,P_CEP_PER_TID_CODIGO     => P_PER_TID_CODIGO
               ,P_CEP_VALOR_ANTERIOR     => NVL(VRP2.VRP_ESTADO_CUMPLIMIENTO,VRP2.VRP_ESTADO)
               ,P_CEP_VALOR_POSTERIOR    => 'ECO'
               ,P_CEP_DESCRIPCION        => NULL
               ,P_CEP_OFD_CONSECUTIVO    => VRP2.VRP_OFD_CONSECUTIVO
               ,P_CEP_NPO_CONSECUTIVO    => NULL);
            UPDATE OFERTAS_DEMANDAS_POSICION
            SET    OFD_ESTADO = 'ECO'
            WHERE  OFD_CONSECUTIVO = VRP2.VRP_OFD_CONSECUTIVO;
         ELSIF VRP2.VRP_ESTADO = 'ECO' THEN
            P_NEGOCIOS_POSICION.INSERTAR_CAMBIO_ESTADO
               (P_CEP_PER_NUM_IDEN       => P_PER_NUM_IDEN
               ,P_CEP_PER_TID_CODIGO     => P_PER_TID_CODIGO
               ,P_CEP_VALOR_ANTERIOR     => NVL(VRP2.VRP_ESTADO_CUMPLIMIENTO,VRP2.VRP_ESTADO)
               ,P_CEP_VALOR_POSTERIOR    => 'ESR'
               ,P_CEP_DESCRIPCION        => NULL
               ,P_CEP_OFD_CONSECUTIVO    => VRP2.VRP_OFD_CONSECUTIVO
               ,P_CEP_NPO_CONSECUTIVO    => NULL);
            UPDATE OFERTAS_DEMANDAS_POSICION
            SET    OFD_ESTADO = 'ESR'
            WHERE  OFD_CONSECUTIVO = VRP2.VRP_OFD_CONSECUTIVO;
         END IF;
      END IF;
      FETCH C_NEGOCIOS_POSICION INTO VRP2;
   END LOOP;
   TOTAL_PESOS_VENTA := TOTAL_PESOS_VENTA + NVL(PPO1.PPO_TOTAL_REDENCION,0);
   UPDATE COMISIONES_MESAS_POSICION
   SET    CPO_TOTAL_COMPRAS = TOTAL_PESOS_COMPRA
         ,CPO_TOTAL_VENTAS = TOTAL_PESOS_VENTA
         ,CPO_TOTAL_UTILIDAD = TOTAL_PESOS_VENTA - TOTAL_PESOS_COMPRA + TOTAL_FONDEOS
         ,CPO_TOTAL_UTILIDAD_MESA = TOTAL_PESOS_VENTA - TOTAL_PESOS_COMPRA
                                  - TOTAL_COMERCIAL - TOTAL_COMISION_INTRAMESAS + TOTAL_FONDEOS
         ,CPO_TOTAL_UTILIDAD_COMERCIAL = TOTAL_COMERCIAL
         ,CPO_TOTAL_FONDEOS_INTERNOS = TOTAL_FONDEOS
         ,CPO_TOTAL_COMISION_INTRAMESAS = TOTAL_COMISION_INTRAMESAS
         ,CPO_NOMINAL_COMPRAS = TOTAL_NOMINAL_COMPRA
   WHERE  CPO_CONSECUTIVO = SIGUIENTE;
   CLOSE C_NEGOCIOS_POSICION;
END EJECUTAR_NEGOCIO_POSICION;
/*************************************************/
PROCEDURE CREAR_TITULO_POSICION
   (P_PRF_FON_CODIGO           PREORDENES_FONDOS.PRF_FON_CODIGO%TYPE
   ,P_PRF_TIPO                 PREORDENES_FONDOS.PRF_TIPO%TYPE
   ,P_PRF_TIPO_NEGOCIO         PREORDENES_FONDOS.PRF_TIPO_NEGOCIO%TYPE
   ,P_PRF_ENA_MNEMONICO        PREORDENES_FONDOS.PRF_ENA_MNEMONICO%TYPE
   ,P_PRF_BMO_MNEMONICO        PREORDENES_FONDOS.PRF_BMO_MNEMONICO%TYPE
   ,P_PRF_TRE_MNEMONICO        PREORDENES_FONDOS.PRF_TRE_MNEMONICO%TYPE
   ,P_PRF_FECHA_EMISION        PREORDENES_FONDOS.PRF_FECHA_EMISION%TYPE
   ,P_PRF_FECHA_VENCIMIENTO    PREORDENES_FONDOS.PRF_FECHA_VENCIMIENTO%TYPE
   ,P_PRF_PERIODICIDAD_TASA    PREORDENES_FONDOS.PRF_PERIODICIDAD_TASA%TYPE
   ,P_PRF_BASE_CALCULO         PREORDENES_FONDOS.PRF_BASE_CALCULO%TYPE
   ,P_PRF_MODALIDAD_TASA       PREORDENES_FONDOS.PRF_MODALIDAD_TASA%TYPE
   ,P_PRF_PUNTOS_ADICIONALES   PREORDENES_FONDOS.PRF_PUNTOS_ADICIONALES%TYPE
   ,P_PRF_TASA_FACIAL          PREORDENES_FONDOS.PRF_TASA_FACIAL%TYPE
   ,P_PRF_AMORTIZABLE          PREORDENES_FONDOS.PRF_AMORTIZABLE%TYPE
   ,P_PRF_TIPO_PAGO_FLUJO      PREORDENES_FONDOS.PRF_TIPO_PAGO_FLUJO%TYPE
   ,P_PRF_FECHA_PRIMER_FLUJO   PREORDENES_FONDOS.PRF_FECHA_PRIMER_FLUJO%TYPE
   ,P_PRF_CAPITALIZABLE        PREORDENES_FONDOS.PRF_CAPITALIZABLE%TYPE
   ,P_PRF_CODIGO_PERIODO       PREORDENES_FONDOS.PRF_CODIGO_PERIODO%TYPE
   ,P_PRF_CONSECUTIVO          PREORDENES_FONDOS.PRF_CONSECUTIVO%TYPE
   ,P_PRF_PER_NUM_IDEN         PREORDENES_FONDOS.PRF_PER_NUM_IDEN%TYPE
   ,P_PRF_PER_TID_CODIGO       PREORDENES_FONDOS.PRF_PER_TID_CODIGO%TYPE
   ,P_PRC_LTI_MNEMONICO        PREORDENES_COMPRA.PRC_LTI_MNEMONICO%TYPE
   ,P_PRC_MONTO                PREORDENES_COMPRA.PRC_MONTO%TYPE
   ,P_PRC_VALOR_NOMINAL        PREORDENES_COMPRA.PRC_VALOR_NOMINAL%TYPE
   ,P_PRC_CNE_MNEMONICO        PREORDENES_COMPRA.PRC_CNE_MNEMONICO%TYPE
   ,P_PRC_MERCADO              PREORDENES_COMPRA.PRC_MERCADO%TYPE
   ,P_PRC_CONSECUTIVO          PREORDENES_COMPRA.PRC_CONSECUTIVO%TYPE
   ,P_PRC_BOL_MNEMONICO        PREORDENES_COMPRA.PRC_BOL_MNEMONICO%TYPE
   ,P_PRC_NUMERO_OPERACION     PREORDENES_COMPRA.PRC_NUMERO_OPERACION%TYPE
   ,P_PRC_LIC_TIPO_OPERACION   PREORDENES_COMPRA.PRC_LIC_TIPO_OPERACION%TYPE
   ,P_PRC_LIC_NUMERO_FRACCION  PREORDENES_COMPRA.PRC_LIC_NUMERO_FRACCION%TYPE
   ,P_PRC_PER_NUM_IDEN         PREORDENES_COMPRA.PRC_PER_NUM_IDEN%TYPE
   ,P_PRC_PER_TID_CODIGO       PREORDENES_COMPRA.PRC_PER_TID_CODIGO%TYPE
   ,P_PRV_CONSECUTIVO          PREORDENES_VENTA.PRV_CONSECUTIVO%TYPE
   ,P_FECHA                    DATE
   ,P_ETI_CODIGO               TITULOS_FONDOS.TFO_ETI_CODIGO%TYPE
   ,P_COTIZACION               IN OUT NUMBER
   ,P_MRF_TMT_MNEMONICO        MVTOS_RENTA_FIJA.MRF_TMT_MNEMONICO%TYPE
   ,P_INSERTA_CVS              VARCHAR2
   ,P_MVTO_CVS                 MVTOS_RENTA_FIJA.MRF_TMT_MNEMONICO%TYPE
   ,P_CVS_CONSECUTIVO          IN OUT COMPRAS_VENTAS_SIN_LIQ.CVS_CONSECUTIVO%TYPE
   ,P_TFO_CODIGO               IN OUT TITULOS_FONDOS.TFO_CODIGO%TYPE
   ,P_TOTAL_TC                 MVTOS_RENTA_FIJA.MRF_VALOR_TITULO_TC%TYPE
   ,P_FECHA_CUMPLIMIENTO       DATE
   ,P_VALOR_TM                 IN OUT NUMBER) IS
   CURSOR C_SIGUIENTE IS
      SELECT MAX(TFO_CODIGO)
      FROM   TITULOS_FONDOS
      WHERE  TFO_FON_CODIGO = P_PRF_FON_CODIGO;
   SIGUIENTE NUMBER;
   CURSOR C_SIGUIENTE1 IS
      SELECT MAX(CVS_CONSECUTIVO)
      FROM   COMPRAS_VENTAS_SIN_LIQ;
   SIGUIENTE1 NUMBER;
   CURSOR C_PENSIONAL (ENA VARCHAR2)  IS
      SELECT ENA_PENSIONAL
      FROM   ESPECIES_NACIONALES
      WHERE  ENA_MNEMONICO = ENA;
   ENA2   C_PENSIONAL%ROWTYPE;
   CURSOR C_TFO (FDO VARCHAR2, COD NUMBER) IS
      SELECT TFO_CODIGO
         , TFO_FON_CODIGO
       , TFO_TYPE
       , TFO_ENA_MNEMONICO
       , TFO_ETI_CODIGO
       , TFO_LTI_MNEMONICO
       , TFO_FECHA_OPERACION
       , TFO_VALOR_OPERACION
       , TFO_FECHA_CUMPLIMIENTO
       , TFO_DIA_SIGUIENTE
       , TFO_PRC_PRF_CONSECUTIVO
       , TFO_PRC_CONSECUTIVO
       , TFO_PRV_PRF_CONSECUTIVO
       , TFO_PRV_CONSECUTIVO
       , TFO_FUG_MNEMONICO
       , TFO_FUG_ISI_MNEMONICO
       , TFO_CVS_CONSECUTIVO
       , TFO_CVS_CONSECUTIVO_ES_VENDIDO
       , TFO_BOL_MNEMONICO, TFO_FONDEO
       , TFO_DERIVADO, TFO_CANTIDAD
       , TFO_MERCADO_COMPRA
       , TFO_VALOR_NOMINAL
       , TFO_BMO_MNEMONICO
       , TFO_FECHA_EMISION
       , TFO_FECHA_VENCIMIENTO
       , TFO_PERIODICIDAD_TASA
       , TFO_BASE_CALCULO
       , TFO_MODALIDAD_TASA
       , TFO_TASA_FACIAL
       , TFO_AMORTIZABLE
       , TFO_TRE_MNEMONICO
       , TFO_PUNTOS_ADICIONALES
       , TFO_FECHA_PRIMER_FLUJO
       , TFO_TIPO_PAGO_FLUJO
       , TFO_CAPITALIZABLE
       , TFO_TASA_MRC_CONGELADA
       , TFO_CRUZADA_CONVENIDA
       , TFO_AGE_CODIGO
       , TFO_COMISION_BOLSA
       , TFO_MERCADO
       , TFO_VALOR_UNITARIO
       , TFO_FECHA_CMPLMNTO_ESPECIAL
       , TFO_DISTRIBUCION_ACUMULADA
       , TFO_VALOR_TITULO_TM
       , TFO_FECHA_VALORIZACION
       , TFO_TASA_DESCUENTO
       , TFO_TFA_TIPO_INVERSION
       , TFO_TFA_CLT_MNEMONICO
       , TFO_DURACION
       , TFO_DURACION_MODIFICADA
       , TFO_VAR_TASA
       , TFO_VAR_MONEDA
       , TFO_CONVEXIDAD
       , TFO_NUMERO_EMISION_DCV
       , TFO_LIQ_NUMERO_OPERACION
       , TFO_LIQ_NUMERO_FRACCION
       , TFO_LIQ_TIPO_OPERACION
       , TFO_NUMERO_TITULO_FISICO
       , TFO_REFERENCIA_DECEVAL
       , TFO_LIQ_NUMERO_OPERACION_ES_VE
       , TFO_LIQ_NUMERO_FRACCION_ES_VEN
       , TFO_LIQ_TIPO_OPERACION_ES_VEND
       , TFO_FECHA_VENTA
       , TFO_VALOR_VENTA
       , TFO_PROSPECTO_VENTA
       , TFO_FECHA_PROSPECTO_VENTA
       , TFO_FECHA_VENTA_PLAZO
       , TFO_VALOR_VENTA_PLAZO
       , TFO_ENTE_VENTA_PLAZO
       , TFO_NUM_IDEN_VENTA_PLAZO
       , TFO_TELEFONO_VENTA_PLAZO
       , TFO_DIRECCION_VENTA_PLAZO
       , TFO_VENCIDO_ESPECIAL
       , TFO_LIC_NUMERO_OPERACION
       , TFO_LIC_NUMERO_FRACCION
       , TFO_LIC_TIPO_OPERACION
       , TFO_LIC_BOL_MNEMONICO
       , TFO_GARANTIA_ACTIVA
       , TFO_CODIGO_PERIODO
       , TFO_CALIFICADO
       , TFO_FECHA_CAMBIO_ESTADO
       , TFO_USUARIO_CAMBIO_ESTADO
       , TFO_TERMINAL_CAMBIO_ESTADO
       , TFO_PER_NUM_IDEN
       , TFO_PER_TID_CODIGO
       , TFO_TIPO_GARANTIA
       , TFO_CUENTA_CRCC
       , TFO_SEGMENTO
       , TFO_CCC_CLI_PER_NUM_IDEN
       , TFO_CCC_CLI_PER_TID_CODIGO
       , TFO_CCC_NUMERO_CUENTA
       , TFO_REPO
       , TFO_SALDO_GARANTIA_SIM
       , TFO_ESTADO_SIM
       , TFO_CLASIF_INVERSION
       ,TFO_FECHA_COMPRA_INICIAL
	     ,TFO_NPO_PROPORCION_CORTO
       ,TFO_NPO_NOMINAL_CORTO
       ,TFO_NPO_CORTO
       ,TFO_NPO_CUPON
       ,TFO_NUMERO_EMISION_DCV_HIST
       ,TFO_ORIGEN_TITULO -- OMORA F351
      FROM   TITULOS_FONDOS
      WHERE  TFO_FON_CODIGO = FDO
      AND    TFO_CODIGO = COD;
   TIT C_TFO%ROWTYPE;
   CURSOR C_TASA_REF(P_TASA   VARCHAR2
                    ,P_FECHA1 DATE) IS
      SELECT CTR_TASA_NOMINAL
      FROM   COTIZACIONES_TASA_REFERENCIA
      WHERE  CTR_TRE_MNEMONICO = P_TASA
      AND    TRUNC(CTR_FECHA) <= TRUNC(P_FECHA1)
      ORDER BY CTR_FECHA DESC;
   FECHA_HOY       DATE;
   COND_FECHA      DATE;
   TASA            NUMBER;
   DIAS_VTO        NUMBER;
   VALOR_TIT_TM    NUMBER;
   CURSOR C_CURVA IS
      SELECT CCV_RENTABILIDAD_ESTIMADA
      FROM   TMP_CERO_CUPON_VALORACION
      WHERE  TRUNC(CCV_FECHA_OPERACION) = TRUNC(COND_FECHA)
      AND    CCV_CURVA = 'CEC'
      AND    CCV_PLAZO_DIAS = DIAS_VTO;
   ISIN     VARCHAR2(12);
   FUNGIBLE NUMBER;
   EMISION  VARCHAR2(20);
   VALOR_TB NUMBER;
   MRF1     MVTOS_RENTA_FIJA%ROWTYPE;


   V_VC_PROP_CORTO           VARCHAR2(1)   := NULL;
   V_NM_NOMINAL_CORTO        NUMBER (22,2) := 0;
   V_VC_CORTO                VARCHAR2(1)   := NULL;
   V_MANSIM                  NUMBER        := 0;
   V_NM_NPO_CONSECUTIVO      NUMBER        := 0;
   V_NM_NPO_TASA_NEGOCIACION NUMBER        := 0;

BEGIN
   OPEN C_SIGUIENTE;
   FETCH C_SIGUIENTE INTO SIGUIENTE;
   CLOSE C_SIGUIENTE;
   SIGUIENTE := NVL(SIGUIENTE,0) + 1;
   P_TFO_CODIGO := SIGUIENTE;
   IF P_PRF_BMO_MNEMONICO = 'PESOS' THEN
      P_COTIZACION := 1;
   END IF;

   IF P_PRF_CONSECUTIVO IS NOT NULL AND P_PRF_TIPO_NEGOCIO = 'C' THEN
      BEGIN
        --SELECT PRC_NPO_CONSECUTIVO INTO V_MANSIM FROM PREORDENES_COMPRA
           --WHERE PRC_PRF_CONSECUTIVO = P_PRF_CONSECUTIVO;

        SELECT NPO_CORTO,  NPO_NOMINAL_CORTO,  NPO_PROPORCION_CORTO,NPO_TASA_NEGOCIACION, NPO_CONSECUTIVO
        INTO   V_VC_CORTO, V_NM_NOMINAL_CORTO, V_VC_PROP_CORTO, V_NM_NPO_TASA_NEGOCIACION, V_NM_NPO_CONSECUTIVO
         FROM    NEGOCIOS_POSICION
           WHERE TO_CHAR(NPO_NUMERO_OPERACION) = TO_CHAR(P_PRC_NUMERO_OPERACION)
           AND NPO_CLASE_OPERACION IN ('SIM','FON') AND NPO_TIPO_OPERACION = 'C'
           AND NPO_CORTO = 'S'
           AND NPO_ESTADO != 'ANU';

      EXCEPTION WHEN TOO_MANY_ROWS THEN

         V_VC_PROP_CORTO    := NULL;
         V_NM_NOMINAL_CORTO := 0;
         V_VC_CORTO         := NULL;
         P_SEGUIMIENTO.PR_SEGUIMIENTO('CORTO MANSIM-CTIMFO',SQLCODE||'-'||SQLERRM||' Se encontro mas de un negocio en MANSIM para la pre-orden de compra: '||P_PRF_CONSECUTIVO );

      WHEN NO_DATA_FOUND THEN

         V_VC_PROP_CORTO    := NULL;
         V_NM_NOMINAL_CORTO := 0;
         V_VC_CORTO         := NULL;
         P_SEGUIMIENTO.PR_SEGUIMIENTO('CORTO MANSIM-CTIMFO',SQLCODE||'-'||SQLERRM||' No se encontro negocio en MANSIM para la pre-orden de compra: '||P_PRF_CONSECUTIVO );

      WHEN OTHERS THEN

         V_VC_PROP_CORTO    := NULL;
         V_NM_NOMINAL_CORTO := 0;
         V_VC_CORTO         := NULL;
         P_SEGUIMIENTO.PR_SEGUIMIENTO('CORTO MANSIM-CTIMFO',SQLCODE||'-'||SQLERRM||' Error consultando la pre-orden de compra: '||P_PRF_CONSECUTIVO );
      END;

   END IF;

DBMS_OUTPUT.PUT_LINE('INSERT BASEMON: '||' - '||SIGUIENTE||' - '||P_PRF_CONSECUTIVO||' - '||TO_CHAR(P_PRC_NUMERO_OPERACION)||' - '||P_PRF_ENA_MNEMONICO||' - '||P_PRF_TIPO_NEGOCIO);

   INSERT INTO TITULOS_FONDOS
      (TFO_FON_CODIGO
      ,TFO_CODIGO
      ,TFO_TYPE
      ,TFO_ENA_MNEMONICO
      ,TFO_ETI_CODIGO
      ,TFO_LTI_MNEMONICO
      ,TFO_FECHA_OPERACION
      ,TFO_VALOR_OPERACION
      ,TFO_FECHA_CUMPLIMIENTO
      ,TFO_COMISION_BOLSA
      ,TFO_AGE_CODIGO
      ,TFO_BMO_MNEMONICO
      ,TFO_TRE_MNEMONICO
      ,TFO_FECHA_EMISION
      ,TFO_FECHA_VENCIMIENTO
      ,TFO_VALOR_NOMINAL
      ,TFO_PERIODICIDAD_TASA
      ,TFO_BASE_CALCULO
      ,TFO_MODALIDAD_TASA
      ,TFO_MERCADO_COMPRA
      ,TFO_VENCIDO_ESPECIAL
      ,TFO_VALOR_UNITARIO
      ,TFO_CANTIDAD
      ,TFO_PUNTOS_ADICIONALES
      ,TFO_TASA_FACIAL
      ,TFO_AMORTIZABLE
      ,TFO_TIPO_PAGO_FLUJO
      ,TFO_FECHA_PRIMER_FLUJO
      ,TFO_TASA_MRC_CONGELADA
      ,TFO_FECHA_CMPLMNTO_ESPECIAL
      ,TFO_DERIVADO
      ,TFO_DIA_SIGUIENTE
      ,TFO_CAPITALIZABLE
      ,TFO_FONDEO
      ,TFO_MERCADO
      ,TFO_NUMERO_EMISION_DCV
      ,TFO_CODIGO_PERIODO
      ,TFO_PRC_PRF_CONSECUTIVO
      ,TFO_PRC_CONSECUTIVO
      ,TFO_PRV_PRF_CONSECUTIVO
      ,TFO_PRV_CONSECUTIVO
      ,TFO_BOL_MNEMONICO
      ,TFO_PER_NUM_IDEN
      ,TFO_PER_TID_CODIGO
      ,TFO_GARANTIA_ACTIVA
      ,TFO_NPO_PROPORCION_CORTO
      ,TFO_NPO_NOMINAL_CORTO
      ,TFO_NPO_CORTO)
   VALUES
      (P_PRF_FON_CODIGO
      ,SIGUIENTE
      ,DECODE(P_PRF_TIPO,'RF','TRF'
                        ,'ACC','TAC')
      ,P_PRF_ENA_MNEMONICO
      ,P_ETI_CODIGO
      ,P_PRC_LTI_MNEMONICO
      ,P_FECHA
      ,P_PRC_MONTO
      ,P_FECHA
      ,0
      ,NULL
      ,P_PRF_BMO_MNEMONICO
      ,P_PRF_TRE_MNEMONICO
      ,P_PRF_FECHA_EMISION
      ,P_PRF_FECHA_VENCIMIENTO
      ,DECODE(P_PRF_TIPO,'RF',P_PRC_VALOR_NOMINAL,NULL)
      ,P_PRF_PERIODICIDAD_TASA
      ,P_PRF_BASE_CALCULO
      ,P_PRF_MODALIDAD_TASA
      ,'M'
      ,'N'
      ,DECODE(P_PRF_TIPO,'ACC',P_PRC_MONTO/P_PRC_VALOR_NOMINAL,NULL)
      ,DECODE(P_PRF_TIPO,'ACC',P_PRC_VALOR_NOMINAL,NULL)
      ,P_PRF_PUNTOS_ADICIONALES
      ,P_PRF_TASA_FACIAL/100
      ,P_PRF_AMORTIZABLE
      ,P_PRF_TIPO_PAGO_FLUJO
      ,DECODE(P_PRF_TIPO_PAGO_FLUJO,'V',TRUNC(P_FECHA)
                                       ,P_PRF_FECHA_PRIMER_FLUJO)
      ,NULL
      ,NULL
      ,DECODE(P_MRF_TMT_MNEMONICO,'DCO','S'
                                 ,'OCO','S'
                                 ,'DVE','S'
                                 ,'OVE','S'
                                 ,'N')
      ,NULL --DECODE(P_ETI_CODIGO,'VIG','S',NULL)
      ,P_PRF_CAPITALIZABLE
      ,DECODE(P_MRF_TMT_MNEMONICO,'FAC','S'
                                 ,'FAF','S'
                                 ,'FPF','S'
                                 ,'DVE','S'
                                 ,'OCO','S'
                                 ,'N')
      ,P_PRC_MERCADO
      ,NULL
      ,P_PRF_CODIGO_PERIODO
      ,DECODE(P_PRF_TIPO_NEGOCIO,'C',P_PRF_CONSECUTIVO,NULL)
      ,DECODE(P_PRF_TIPO_NEGOCIO,'C',P_PRC_CONSECUTIVO,NULL)
      ,DECODE(P_PRF_TIPO_NEGOCIO,'V',P_PRF_CONSECUTIVO,NULL)
      ,DECODE(P_PRF_TIPO_NEGOCIO,'V',P_PRV_CONSECUTIVO,NULL)
      ,P_PRC_BOL_MNEMONICO
      ,P_PRF_PER_NUM_IDEN
      ,P_PRF_PER_TID_CODIGO
      ,DECODE(P_ETI_CODIGO,'VGA','S',NULL)
      ,V_VC_PROP_CORTO
      ,V_NM_NOMINAL_CORTO
      ,V_VC_CORTO);

   IF P_PRF_TIPO = 'RF' THEN
      OPEN C_PENSIONAL(P_PRF_ENA_MNEMONICO);
      FETCH C_PENSIONAL INTO ENA2;
      IF NVL(ENA2.ENA_PENSIONAL,'N') = 'S' THEN
         OPEN C_TFO(P_PRF_FON_CODIGO, SIGUIENTE);
         FETCH C_TFO INTO TIT;
         CLOSE C_TFO;
         P_FLUJOS.GENERE_AMORT_PENSIONAL(TIT);
      ELSE
         IF NVL(P_PRF_AMORTIZABLE,'N') = 'N' THEN
            IF P_PRF_MODALIDAD_TASA != 'D' THEN
               P_FLUJOS_FRM.FLUJOS_RENDIMIENTOS(P_PRF_FON_CODIGO,SIGUIENTE);
            END IF;
            P_FLUJOS_FRM.FLUJOS_AMORTIZACIONES(P_PRF_FON_CODIGO,SIGUIENTE);
         ELSE
            P_FLUJOS_FRM.FLUJOS_AMORTIZACIONES(P_PRF_FON_CODIGO,SIGUIENTE);
            IF P_PRF_MODALIDAD_TASA != 'D' THEN
               P_FLUJOS_FRM.FLUJOS_RENDIMIENTOS(P_PRF_FON_CODIGO,SIGUIENTE);
            END IF;
         END IF;
      END IF;
      UPDATE FLUJOS_AMORTIZACION_TITULOS
      SET    FAT_ESTADO = 'C'
      WHERE  FAT_TFO_FON_CODIGO = P_PRF_FON_CODIGO
      AND    FAT_TFO_CODIGO = SIGUIENTE
      AND    TRUNC(FAT_FECHA) <= TRUNC(P_FECHA);
      UPDATE FLUJOS_RENDIMIENTOS_TITULOS
      SET    FRT_ESTADO = 'C'
      WHERE  FRT_TFO_FON_CODIGO = P_PRF_FON_CODIGO
      AND    FRT_TFO_CODIGO = SIGUIENTE
      AND    TRUNC(FRT_FECHA) <= TRUNC(P_FECHA);
      IF P_MRF_TMT_MNEMONICO IN ('DCO','OVE') THEN
         VALOR_TIT_TM := P_VALORIZA_RF.VALOR_MERCADO_TIR(SYSDATE
                                                        ,SYSDATE - 1
                                                        ,P_PRF_FON_CODIGO
                                                        ,SIGUIENTE);
         IF NVL(VALOR_TIT_TM,0) = 0 THEN
            /* Si no encuentra SISVAL se busca el valor del dinero hoy con la CEC */
            SELECT SYSDATE INTO FECHA_HOY FROM DUAL;
            SELECT SYSDATE - 1 INTO COND_FECHA FROM DUAL;
            DIAS_VTO := P_FINANCIERO.DIAS_365(FECHA_HOY
                                             ,P_FECHA_CUMPLIMIENTO);
            OPEN C_CURVA;
            FETCH C_CURVA INTO TASA;
            IF C_CURVA%NOTFOUND THEN
               CLOSE C_CURVA;
               RAISE_APPLICATION_ERROR(-20098,'No se encontro punto en la curva cero cupon para la fecha '
                   || TO_CHAR(COND_FECHA,'DD-MON-YYYY') || ' y dias al vencimiento '
                   || TO_CHAR(DIAS_VTO));
            END IF;
            VALOR_TIT_TM := P_PRC_MONTO / POWER(1 + TASA / 100,DIAS_VTO / 365);
            VALOR_TIT_TM := ROUND(VALOR_TIT_TM / P_COTIZACION,2);
         END IF;
         UPDATE TITULOS_FONDOS
         SET    TFO_VALOR_OPERACION = VALOR_TIT_TM * P_COTIZACION
         WHERE  TFO_FON_CODIGO = P_PRF_FON_CODIGO
         AND    TFO_CODIGO = SIGUIENTE;
         UPDATE FLUJOS_AMORTIZACION_TITULOS
         SET    FAT_AMORTIZACION_CAPITAL = - VALOR_TIT_TM
         WHERE  FAT_TFO_FON_CODIGO = P_PRF_FON_CODIGO
         AND    FAT_TFO_CODIGO = SIGUIENTE
         AND    TRUNC(FAT_FECHA) <= TRUNC(SYSDATE);
         P_VALOR_TM := VALOR_TIT_TM * P_COTIZACION;
      ELSE
         VALOR_TIT_TM := ROUND(P_PRC_MONTO / P_COTIZACION,2);
      END IF;
      IF P_MRF_TMT_MNEMONICO IN ('OCO','DVE') THEN
         MRF1.MRF_TIR360_C := 0;
         MRF1.MRF_TIR365_C := 0;
         MRF1.MRF_TIR360_M := 0;
         MRF1.MRF_TIR365_M := 0;
      ELSE
         IF P_PRF_TRE_MNEMONICO IS NOT NULL THEN
            OPEN C_TASA_REF(P_PRF_TRE_MNEMONICO
                           ,P_FECHA);
            FETCH C_TASA_REF INTO VALOR_TB;
            IF C_TASA_REF%NOTFOUND THEN
               CLOSE C_TASA_REF;
               RAISE_APPLICATION_ERROR(-20099,'No se encontro cotizaciżn de la tasa: ' || P_PRF_TRE_MNEMONICO
                  || ' para la fecha ' || TO_CHAR(P_FECHA,'DD-MON-YYYY'));
            END IF;
            CLOSE C_TASA_REF;
         ELSE
            VALOR_TB := P_PRF_TASA_FACIAL / 100;
         END IF;

DBMS_OUTPUT.PUT_LINE('P_PRC_CNE_MNEMONICO: '||P_PRC_CNE_MNEMONICO);
         IF P_PRF_FON_CODIGO = 860079174 AND P_PRC_CNE_MNEMONICO = 'SIM' AND TO_CHAR(P_PRC_NUMERO_OPERACION) != 0
         AND P_MRF_TMT_MNEMONICO IN ('FAF','FPF') THEN
            BEGIN
--DBMS_OUTPUT.PUT_LINE('P_PRF_CONSECUTIVO: '||P_PRF_CONSECUTIVO);
--               SELECT PRC_NPO_CONSECUTIVO INTO V_MANSIM FROM PREORDENES_COMPRA
--               WHERE PRC_PRF_CONSECUTIVO = P_PRF_CONSECUTIVO;
--DBMS_OUTPUT.PUT_LINE('MANSIM: '||V_MANSIM);
DBMS_OUTPUT.PUT_LINE('NUM OPERACI˙N: '||TO_CHAR(P_PRC_NUMERO_OPERACION));
               SELECT NPO_TASA_NEGOCIACION/100, NPO_CONSECUTIVO
               INTO   V_NM_NPO_TASA_NEGOCIACION, V_NM_NPO_CONSECUTIVO
               FROM    NEGOCIOS_POSICION
               WHERE TO_CHAR(NPO_NUMERO_OPERACION) = TO_CHAR(P_PRC_NUMERO_OPERACION)
               AND NPO_ESTADO != 'ANU';

               MRF1.MRF_TIR360_C := V_NM_NPO_TASA_NEGOCIACION;
               MRF1.MRF_TIR365_C := V_NM_NPO_TASA_NEGOCIACION;
               MRF1.MRF_TIR360_M := V_NM_NPO_TASA_NEGOCIACION;
               MRF1.MRF_TIR365_M := V_NM_NPO_TASA_NEGOCIACION;

DBMS_OUTPUT.PUT_LINE('CONSECUTIVO MANSIM: '||V_NM_NPO_CONSECUTIVO);
DBMS_OUTPUT.PUT_LINE('TASA MANSIM: '||MRF1.MRF_TIR360_C);

             EXCEPTION WHEN NO_DATA_FOUND THEN
               SELECT OFD_TASA/100, OFD_CONSECUTIVO
               INTO V_NM_NPO_TASA_NEGOCIACION, V_NM_NPO_CONSECUTIVO
               FROM OFERTAS_DEMANDAS_POSICION
               WHERE OFD_ESTADO != 'ANU'
               AND TO_CHAR(OFD_NUMERO_OPERACION) = TO_CHAR(P_PRC_NUMERO_OPERACION) ;

               MRF1.MRF_TIR360_C := V_NM_NPO_TASA_NEGOCIACION;
               MRF1.MRF_TIR365_C := V_NM_NPO_TASA_NEGOCIACION;
               MRF1.MRF_TIR360_M := V_NM_NPO_TASA_NEGOCIACION;
               MRF1.MRF_TIR365_M := V_NM_NPO_TASA_NEGOCIACION;

DBMS_OUTPUT.PUT_LINE('CONSECUTIVO MANSIM EXCEP: '||V_NM_NPO_CONSECUTIVO);
DBMS_OUTPUT.PUT_LINE('TASA MANSIM EXCEP: '||MRF1.MRF_TIR360_C);

--            EXCEPTION WHEN OTHERS THEN
--              V_NM_NPO_TASA_NEGOCIACION := 0;
--              V_NM_NPO_CONSECUTIVO      := 0;
            END;
         ELSE

         MRF1.MRF_TIR360_C := P_TITULOS.TIR_360_COMPRA_RF(P_PRF_FON_CODIGO
                                                         ,SIGUIENTE
                                                         ,P_FECHA
                                                         ,VALOR_TIT_TM
                                                         ,VALOR_TB);
         MRF1.MRF_TIR365_C := P_TITULOS.TIR_365_COMPRA_RF(P_PRF_FON_CODIGO
                                                         ,SIGUIENTE
                                                         ,P_FECHA
                                                         ,VALOR_TIT_TM
                                                         ,VALOR_TB);
         MRF1.MRF_TIR360_M := P_TITULOS.TIR_360_MERCADO_RF(P_PRF_FON_CODIGO
                                                          ,SIGUIENTE
                                                          ,P_FECHA
                                                          ,VALOR_TIT_TM
                                                          ,VALOR_TB);
         MRF1.MRF_TIR365_M := P_TITULOS.TIR_365_MERCADO_RF(P_PRF_FON_CODIGO
                                                          ,SIGUIENTE
                                                          ,P_FECHA
                                                          ,VALOR_TIT_TM
                                                          ,VALOR_TB);
         END IF;
      END IF;
      MRF1.MRF_VALOR_TITULO_TM := VALOR_TIT_TM;
      /* Estos indicadores se dejan en cero porque ya no se usan */
      MRF1.MRF_AAI := 0;
      MRF1.MRF_MPE := 0;
      MRF1.MRF_TAI := 0;
      /******************/
      IF SUBSTR(P_PRF_ENA_MNEMONICO,1,3) = 'TRD' THEN
         MRF1.MRF_AAI := 0;
         MRF1.MRF_TAI := 0;
         MRF1.MRF_MPE := 0;
         MRF1.MRF_TIR360_M := 0;
         MRF1.MRF_TIR360_C := 0;
         MRF1.MRF_TIR365_M := 0;
         MRF1.MRF_TIR365_C := 0;
      END IF;

      IF P_MRF_TMT_MNEMONICO = 'TGA' AND V_NM_NOMINAL_CORTO != 0 THEN
         MRF1.MRF_TFO_NPO_NOMINAL_CORTO      := V_NM_NOMINAL_CORTO;
         MRF1.MRF_VALOR_TITULO_TM_CORTO      := V_NM_NOMINAL_CORTO * VALOR_TIT_TM / P_PRC_VALOR_NOMINAL;
         MRF1.MRF_INTERES_CORTO              := 0;--V_NM_NOMINAL_CORTO * VALOR_TIT_TM/DECODE(P_PRF_TIPO,'RF',P_PRC_VALOR_NOMINAL,NULL);
         MRF1.MRF_VALOR_DISTRIBUIR_DIA_CORTO := 0;---MRF1.MRF_VALOR_TITULO_TM_CORTO+MRF1.MRF_INTERES_CORTO;
         MRF1.MRF_VALOR_DIST_DIA_CORTO_ACUM  := 0;--MRF1.MRF_VALOR_DISTRIBUIR_DIA_CORTO;
      ELSE
         MRF1.MRF_TFO_NPO_NOMINAL_CORTO      := NULL;
         MRF1.MRF_VALOR_TITULO_TM_CORTO      := NULL;
         MRF1.MRF_INTERES_CORTO              := NULL;
         MRF1.MRF_VALOR_DISTRIBUIR_DIA_CORTO := NULL;
         MRF1.MRF_VALOR_DIST_DIA_CORTO_ACUM  := NULL;
      END IF;


      INSERT INTO MVTOS_RENTA_FIJA
         (MRF_TFO_FON_CODIGO
         ,MRF_TFO_CODIGO
         ,MRF_TMT_MNEMONICO
         ,MRF_FECHA
         ,MRF_UTILIDAD
         ,MRF_PERDIDA
         ,MRF_CAPITAL
         ,MRF_INTERES
         ,MRF_VALOR_TITULO_TM
         ,MRF_VALOR_TITULO_TC
         ,MRF_VALORIZACION_TM
         ,MRF_VALORIZACION_TC
         ,MRF_VALOR_DISTRIBUIR_DIA
         ,MRF_VALOR_DIST_REND_FINANCIERO
         ,MRF_DIFERENCIA_CAMBIO
         ,MRF_MPE
         ,MRF_AAI
         ,MRF_TAI
         ,MRF_TIR360_M
         ,MRF_TIR360_C
         ,MRF_TIR365_M
         ,MRF_TIR365_C
         ,MRF_TFO_NPO_NOMINAL_CORTO
         ,MRF_VALOR_TITULO_TM_CORTO
         ,MRF_INTERES_CORTO
         ,MRF_VALOR_DISTRIBUIR_DIA_CORTO
         ,MRF_VALOR_DIST_DIA_CORTO_ACUM)
      VALUES
         (P_PRF_FON_CODIGO
         ,SIGUIENTE
         ,P_MRF_TMT_MNEMONICO
         ,P_FECHA
         ,0
         ,0
         ,0
         ,0
         ,VALOR_TIT_TM
         ,NVL(ROUND(P_TOTAL_TC / P_COTIZACION,2),VALOR_TIT_TM) -- Esto es para el fraccionamiento que se envia el acumulado
                                                               -- en caso que este nulo se imprime el valor de mercado
         ,0
         ,0
         ,0
         ,0
         ,0
         ,MRF1.MRF_MPE
         ,MRF1.MRF_AAI
         ,MRF1.MRF_TAI
         ,MRF1.MRF_TIR360_M
         ,MRF1.MRF_TIR360_C
         ,MRF1.MRF_TIR365_M
         ,MRF1.MRF_TIR365_C
         ,MRF1.MRF_TFO_NPO_NOMINAL_CORTO
         ,MRF1.MRF_VALOR_TITULO_TM_CORTO
         ,MRF1.MRF_INTERES_CORTO
         ,MRF1.MRF_VALOR_DISTRIBUIR_DIA_CORTO
         ,MRF1.MRF_VALOR_DIST_DIA_CORTO_ACUM
         );

      IF NVL(P_INSERTA_CVS,' ') = 'S' THEN
         OPEN C_SIGUIENTE1;
         FETCH C_SIGUIENTE1 INTO SIGUIENTE1;
         CLOSE C_SIGUIENTE1;
         SIGUIENTE1 := NVL(SIGUIENTE1,0) + 1;
         P_CVS_CONSECUTIVO := SIGUIENTE1;
         INSERT INTO COMPRAS_VENTAS_SIN_LIQ
            (CVS_CONSECUTIVO
            ,CVS_FON_CODIGO
            ,CVS_TMT_MNEMONICO
            ,CVS_VENDEDOR_COMPRADOR
            ,CVS_VALOR_OPERACION
            ,CVS_COMISION
            ,CVS_FECHA_CUMPLIMIENTO
            ,CVS_NUMERO_OPERACION
            ,CVS_TIPO_OPERACION
            ,CVS_NUMERO_FRACCION
            ,CVS_BOL_MNEMONICO
            ,CVS_PER_NUM_IDEN
            ,CVS_PER_TID_CODIGO
            ,CVS_FECHA_CUMPLIMIENTO_ESPECIA
            ,CVS_IDENT_OPERACION_SISTEMA)
         VALUES
            (SIGUIENTE1
            ,P_PRF_FON_CODIGO
            ,P_MVTO_CVS
            ,'CORREDORES ASOCIADOS'
            ,P_PRC_MONTO
            ,0
            ,P_FECHA
            ,P_PRC_NUMERO_OPERACION
            ,NVL(P_PRC_LIC_TIPO_OPERACION,'C')
            ,NVL(P_PRC_LIC_NUMERO_FRACCION,0)
            ,P_PRC_BOL_MNEMONICO
            ,P_PRC_PER_NUM_IDEN
            ,P_PRC_PER_TID_CODIGO
            ,NULL
            ,'R');
      ELSE
         UPDATE TITULOS_FONDOS
         SET    TFO_CVS_CONSECUTIVO = P_CVS_CONSECUTIVO
         WHERE  TFO_FON_CODIGO = P_PRF_FON_CODIGO
         AND    TFO_CODIGO = SIGUIENTE;
      END IF;
      IF P_MRF_TMT_MNEMONICO IN ('FAC','TGA','FPF','OCO','OVE') THEN
         UPDATE TITULOS_FONDOS
         SET    TFO_VALOR_OPERACION = - TFO_VALOR_OPERACION
               ,TFO_VALOR_NOMINAL = - TFO_VALOR_NOMINAL
         WHERE  TFO_FON_CODIGO = P_PRF_FON_CODIGO
         AND    TFO_CODIGO = SIGUIENTE;
         UPDATE FLUJOS_AMORTIZACION_TITULOS
         SET    FAT_AMORTIZACION_CAPITAL = - FAT_AMORTIZACION_CAPITAL
         WHERE  FAT_TFO_FON_CODIGO = P_PRF_FON_CODIGO
         AND    FAT_TFO_CODIGO = SIGUIENTE;
         UPDATE FLUJOS_RENDIMIENTOS_TITULOS
         SET    FRT_INTERES_COMPRA = - FRT_INTERES_COMPRA
               ,FRT_INTERES_MERCADO = - FRT_INTERES_MERCADO
               ,FRT_BASE_CAPITAL = - FRT_BASE_CAPITAL
         WHERE  FRT_TFO_FON_CODIGO = P_PRF_FON_CODIGO
         AND    FRT_TFO_CODIGO = SIGUIENTE;
         UPDATE MVTOS_RENTA_FIJA
         SET    MRF_VALOR_TITULO_TM = - MRF_VALOR_TITULO_TM
               ,MRF_VALOR_TITULO_TC = - MRF_VALOR_TITULO_TC
         WHERE  MRF_TFO_FON_CODIGO = P_PRF_FON_CODIGO
         AND    MRF_TFO_CODIGO = SIGUIENTE;
      END IF;
   ELSE
      P_FLUJOS_FRM.FLUJOS_DIVIDENDOS(P_PRF_FON_CODIGO
                                    ,SIGUIENTE);
      INSERT INTO MVTOS_ACCION
         (MAC_FECHA
         ,MAC_TFO_FON_CODIGO
         ,MAC_TFO_CODIGO
         ,MAC_TMT_MNEMONICO
         ,MAC_MONTO
         ,MAC_DIVIDENDOS_CAUSADOS
         ,MAC_DIVIDENDOS_PAGADOS
         ,MAC_UTILIDAD
         ,MAC_PERDIDA)
      VALUES
         (P_FECHA
         ,P_PRF_FON_CODIGO
         ,SIGUIENTE
         ,P_MRF_TMT_MNEMONICO
         ,P_PRC_MONTO
         ,0
         ,0
         ,0
         ,0);
      INSERT INTO COMPRAS_VENTAS_SIN_LIQ
         (CVS_CONSECUTIVO
         ,CVS_FON_CODIGO
         ,CVS_TMT_MNEMONICO
         ,CVS_VENDEDOR_COMPRADOR
         ,CVS_VALOR_OPERACION
         ,CVS_COMISION
         ,CVS_FECHA_CUMPLIMIENTO
         ,CVS_NUMERO_OPERACION
         ,CVS_TIPO_OPERACION
         ,CVS_NUMERO_FRACCION
         ,CVS_BOL_MNEMONICO
         ,CVS_PER_NUM_IDEN
         ,CVS_PER_TID_CODIGO
         ,CVS_FECHA_CUMPLIMIENTO_ESPECIA
         ,CVS_IDENT_OPERACION_SISTEMA)
      VALUES
         (SIGUIENTE1
         ,P_PRF_FON_CODIGO
         ,P_MVTO_CVS
         ,'CORREDORES ASOCIADOS'
         ,P_PRC_MONTO
         ,0
         ,P_FECHA
         ,P_PRC_NUMERO_OPERACION
         ,NVL(P_PRC_LIC_TIPO_OPERACION,'C')
         ,NVL(P_PRC_LIC_NUMERO_FRACCION,0)
         ,P_PRC_BOL_MNEMONICO
         ,P_PRC_PER_NUM_IDEN
         ,P_PRC_PER_TID_CODIGO
         ,NULL
         ,'R');
   END IF;
   P_TITULOS.P_ISIN_EMI_ANTERIOR(P_PRF_FON_CODIGO
                                ,SIGUIENTE
                                ,ISIN
                                ,FUNGIBLE
                                ,EMISION);
   UPDATE TITULOS_FONDOS
   SET    TFO_FUG_ISI_MNEMONICO = ISIN
         ,TFO_FUG_MNEMONICO= FUNGIBLE
         ,TFO_NUMERO_EMISION_DCV= EMISION
         ,TFO_CVS_CONSECUTIVO = SIGUIENTE1
   WHERE  TFO_FON_CODIGO = P_PRF_FON_CODIGO
   AND    TFO_CODIGO = SIGUIENTE;
END CREAR_TITULO_POSICION;
/*************************************************/
PROCEDURE VERIFICAR_FRACCIONAR_POSICION
   (P_PPO_CONSECUTIVO          PORTAFOLIOS_POSICION.PPO_CONSECUTIVO%TYPE
   ,P_PPO_ENA_MNEMONICO        PORTAFOLIOS_POSICION.PPO_ENA_MNEMONICO%TYPE
   ,P_PRF_FON_CODIGO           PREORDENES_FONDOS.PRF_FON_CODIGO%TYPE
   ,P_FECHA                    PORTAFOLIOS_POSICION.PPO_FECHA%TYPE
   ,P_PRV_PRF_CONSECUTIVO      PREORDENES_VENTA.PRV_PRF_CONSECUTIVO%TYPE) IS
   CURSOR C_TOTAL_TITULOS IS
      SELECT COUNT(*)
      FROM   TITULOS_FONDOS
            ,PORTAFOLIOS_POSICION
      WHERE  (TFO_ETI_CODIGO = 'GAF'
             OR
             (TFO_ETI_CODIGO = 'VIG' AND
              NVL(TFO_DERIVADO,'N') = 'N' AND
              NVL(TFO_FONDEO,'N') = 'N'))
      AND    TFO_PER_NUM_IDEN = PPO_PER_NUM_IDEN
      AND    TFO_PER_TID_CODIGO = PPO_PER_TID_CODIGO
      AND    TFO_FON_CODIGO = P_PRF_FON_CODIGO
      AND    TFO_ENA_MNEMONICO = P_PPO_ENA_MNEMONICO
      AND    TRUNC(TFO_FECHA_EMISION) = TRUNC(PPO_FECHA_EMISION)
      AND    TRUNC(TFO_FECHA_VENCIMIENTO) = TRUNC(PPO_FECHA_VENCIMIENTO)
      AND    NVL(TFO_TASA_FACIAL * 100,-.01) = NVL(PPO_TASA_FACIAL,-.01)
      AND    NVL(TFO_TRE_MNEMONICO,' ') = NVL(PPO_TRE_MNEMONICO,' ')
      AND    NVL(TFO_PUNTOS_ADICIONALES,-.000001) = NVL(PPO_PUNTOS_ADICIONALES,-.000001)
      AND    NVL(TFO_PERIODICIDAD_TASA,-1) = NVL(PPO_PERIODICIDAD_TASA,-1)
      AND    NVL(TFO_MODALIDAD_TASA,' ') = NVL(PPO_MODALIDAD_TASA,' ')
      AND    NVL(TFO_CODIGO_PERIODO,' ') = NVL(PPO_CODIGO_PERIODO,' ')
      AND    NVL(TFO_BASE_CALCULO,-1) = NVL(PPO_BASE_CALCULO,-1)
      AND    NVL(TFO_TIPO_PAGO_FLUJO,' ') = NVL(PPO_TIPO_PAGO_FLUJO,' ')
      AND    NVL(TFO_CAPITALIZABLE,'N') = NVL(PPO_CAPITALIZABLE,'N')
      AND    NVL(TFO_AMORTIZABLE,'N') = NVL(PPO_AMORTIZABLE,'N')
      AND    NVL(TFO_BMO_MNEMONICO,' ') = NVL(PPO_BMO_MNEMONICO,' ')
      AND    NOT EXISTS (SELECT 'X'
                         FROM   MVTOS_RENTA_FIJA
                         WHERE  MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                         AND    MRF_TFO_CODIGO = TFO_CODIGO
                         AND    MRF_TMT_MNEMONICO = 'FPA')
      AND    PPO_CONSECUTIVO = P_PPO_CONSECUTIVO;

      -- INICIO OMORA F351
   CURSOR C_VERIFICA_ESTADO_TITULOS IS
      SELECT TFO_ETI_CODIGO, COUNT(1) CONTADOR
      FROM   TITULOS_FONDOS
            ,PORTAFOLIOS_POSICION
      WHERE  (TFO_ETI_CODIGO = 'GAF'
             OR
             (TFO_ETI_CODIGO = 'VIG' AND
              NVL(TFO_DERIVADO,'N') = 'N' AND
              NVL(TFO_FONDEO,'N') = 'N'))
      AND    TFO_PER_NUM_IDEN = PPO_PER_NUM_IDEN
      AND    TFO_PER_TID_CODIGO = PPO_PER_TID_CODIGO
      AND    TFO_FON_CODIGO = P_PRF_FON_CODIGO
      AND    TFO_ENA_MNEMONICO = P_PPO_ENA_MNEMONICO
      AND    TRUNC(TFO_FECHA_EMISION) = TRUNC(PPO_FECHA_EMISION)
      AND    TRUNC(TFO_FECHA_VENCIMIENTO) = TRUNC(PPO_FECHA_VENCIMIENTO)
      AND    NVL(TFO_TASA_FACIAL * 100,-.01) = NVL(PPO_TASA_FACIAL,-.01)
      AND    NVL(TFO_TRE_MNEMONICO,' ') = NVL(PPO_TRE_MNEMONICO,' ')
      AND    NVL(TFO_PUNTOS_ADICIONALES,-.000001) = NVL(PPO_PUNTOS_ADICIONALES,-.000001)
      AND    NVL(TFO_PERIODICIDAD_TASA,-1) = NVL(PPO_PERIODICIDAD_TASA,-1)
      AND    NVL(TFO_MODALIDAD_TASA,' ') = NVL(PPO_MODALIDAD_TASA,' ')
      AND    NVL(TFO_CODIGO_PERIODO,' ') = NVL(PPO_CODIGO_PERIODO,' ')
      AND    NVL(TFO_BASE_CALCULO,-1) = NVL(PPO_BASE_CALCULO,-1)
      AND    NVL(TFO_TIPO_PAGO_FLUJO,' ') = NVL(PPO_TIPO_PAGO_FLUJO,' ')
      AND    NVL(TFO_CAPITALIZABLE,'N') = NVL(PPO_CAPITALIZABLE,'N')
      AND    NVL(TFO_AMORTIZABLE,'N') = NVL(PPO_AMORTIZABLE,'N')
      AND    NVL(TFO_BMO_MNEMONICO,' ') = NVL(PPO_BMO_MNEMONICO,' ')
      AND    NOT EXISTS (SELECT 'X'
                         FROM   MVTOS_RENTA_FIJA
                         WHERE  MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                         AND    MRF_TFO_CODIGO = TFO_CODIGO
                         AND    MRF_TMT_MNEMONICO = 'FPA')
      AND    PPO_CONSECUTIVO = P_PPO_CONSECUTIVO
      GROUP BY TFO_ETI_CODIGO;
      R_VERIFICA_ESTADO_TITULOS C_VERIFICA_ESTADO_TITULOS%ROWTYPE;

      P_CONTADOR_VIG  NUMBER;
      P_CONTADOR_GAF  NUMBER;
      P_ESTADO_TITULO VARCHAR2(8);
      -- FIN OMORA F351

   CURSOR C_TITULOS IS
      SELECT TFO.*
      FROM   TITULOS_FONDOS TFO
            ,PORTAFOLIOS_POSICION
      WHERE  (TFO_ETI_CODIGO = 'GAF'
             OR
             (TFO_ETI_CODIGO = 'VIG' AND
              NVL(TFO_DERIVADO,'N') = 'N' AND
              NVL(TFO_FONDEO,'N') = 'N'))
      AND    TFO_PER_NUM_IDEN = PPO_PER_NUM_IDEN
      AND    TFO_PER_TID_CODIGO = PPO_PER_TID_CODIGO
      AND    TFO_FON_CODIGO = P_PRF_FON_CODIGO
      AND    TFO_ENA_MNEMONICO = P_PPO_ENA_MNEMONICO
      AND    TRUNC(TFO_FECHA_EMISION) = TRUNC(PPO_FECHA_EMISION)
      AND    TRUNC(TFO_FECHA_VENCIMIENTO) = TRUNC(PPO_FECHA_VENCIMIENTO)
      AND    NVL(TFO_TASA_FACIAL * 100,-.01) = NVL(PPO_TASA_FACIAL,-.01)
      AND    NVL(TFO_TRE_MNEMONICO,' ') = NVL(PPO_TRE_MNEMONICO,' ')
      AND    NVL(TFO_PUNTOS_ADICIONALES,-.000001) = NVL(PPO_PUNTOS_ADICIONALES,-.000001)
      AND    NVL(TFO_PERIODICIDAD_TASA,-1) = NVL(PPO_PERIODICIDAD_TASA,-1)
      AND    NVL(TFO_MODALIDAD_TASA,' ') = NVL(PPO_MODALIDAD_TASA,' ')
      AND    NVL(TFO_CODIGO_PERIODO,' ') = NVL(PPO_CODIGO_PERIODO,' ')
      AND    NVL(TFO_BASE_CALCULO,-1) = NVL(PPO_BASE_CALCULO,-1)
      AND    NVL(TFO_TIPO_PAGO_FLUJO,' ') = NVL(PPO_TIPO_PAGO_FLUJO,' ')
      AND    NVL(TFO_CAPITALIZABLE,'N') = NVL(PPO_CAPITALIZABLE,'N')
      AND    NVL(TFO_AMORTIZABLE,'N') = NVL(PPO_AMORTIZABLE,'N')
      AND    NVL(TFO_BMO_MNEMONICO,' ') = NVL(PPO_BMO_MNEMONICO,' ')
      AND    NOT EXISTS (SELECT 'X'
                         FROM   MVTOS_RENTA_FIJA
                         WHERE  MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                         AND    MRF_TFO_CODIGO = TFO_CODIGO
                         AND    MRF_TMT_MNEMONICO = 'FPA')
      AND    PPO_CONSECUTIVO = P_PPO_CONSECUTIVO;
   TFO1   C_TITULOS%ROWTYPE;
   CURSOR C_ULTIMO_MVTO IS
      SELECT MRF_VALOR_TITULO_TM
            ,MRF_VALOR_TITULO_TC
            ,MRF_FECHA_VALORIZACION
            ,MRF_TASA_DESCUENTO
            ,MRF_INDICADOR
            ,MRF_VIGENCIA
      FROM   MVTOS_RENTA_FIJA
      WHERE  MRF_TFO_FON_CODIGO = TFO1.TFO_FON_CODIGO
      AND    MRF_TFO_CODIGO = TFO1.TFO_CODIGO
      ORDER BY MRF_FECHA DESC;
   MRF1   C_ULTIMO_MVTO%ROWTYPE;
   CURSOR C_TOTAL_PREORDENES IS
      SELECT COUNT(*)
            ,SUM(PRV_VALOR_NOMINAL)
      FROM   PREORDENES_VENTA
            ,PREORDENES_FONDOS
            ,PORTAFOLIOS_POSICION
      WHERE  PRV_FECHA_CUMPLIMIENTO >= TRUNC(P_FECHA)
      AND    PRV_FECHA_CUMPLIMIENTO < TRUNC(P_FECHA + 1)
      AND    PRV_PRF_FON_CODIGO = PRF_FON_CODIGO
      AND    PRV_PRF_CONSECUTIVO = PRF_CONSECUTIVO
      AND    PRF_EOF_CODIGO = 'APR'
      AND    PRF_PER_NUM_IDEN = PPO_PER_NUM_IDEN
      AND    PRF_PER_TID_CODIGO = PPO_PER_TID_CODIGO
      AND    PRF_FON_CODIGO = P_PRF_FON_CODIGO
      AND    PRF_ENA_MNEMONICO = P_PPO_ENA_MNEMONICO
      AND    TRUNC(PRF_FECHA_EMISION) = TRUNC(PPO_FECHA_EMISION)
      AND    TRUNC(PRF_FECHA_VENCIMIENTO) = TRUNC(PPO_FECHA_VENCIMIENTO)
      AND    NVL(PRF_TASA_FACIAL,-.01) = NVL(PPO_TASA_FACIAL,-.01)
      AND    NVL(PRF_TRE_MNEMONICO,' ') = NVL(PPO_TRE_MNEMONICO,' ')
      AND    NVL(PRF_PUNTOS_ADICIONALES,-.000001) = NVL(PPO_PUNTOS_ADICIONALES,-.000001)
      AND    NVL(PRF_PERIODICIDAD_TASA,-1) = NVL(PPO_PERIODICIDAD_TASA,-1)
      AND    NVL(PRF_MODALIDAD_TASA,' ') = NVL(PPO_MODALIDAD_TASA,' ')
      AND    NVL(PRF_CODIGO_PERIODO,' ') = NVL(PPO_CODIGO_PERIODO,' ')
      AND    NVL(PRF_BASE_CALCULO,-1) = NVL(PPO_BASE_CALCULO,-1)
      AND    NVL(PRF_TIPO_PAGO_FLUJO,' ') = NVL(PPO_TIPO_PAGO_FLUJO,' ')
      AND    NVL(PRF_CAPITALIZABLE,'N') = NVL(PPO_CAPITALIZABLE,'N')
      AND    NVL(PRF_AMORTIZABLE,'N') = NVL(PPO_AMORTIZABLE,'N')
      AND    NVL(PRF_BMO_MNEMONICO,' ') = NVL(PPO_BMO_MNEMONICO,' ')
      AND    PPO_CONSECUTIVO = P_PPO_CONSECUTIVO;
   CURSOR C_PREORDENES_VENTA IS
      SELECT PRV_PRF_FON_CODIGO
            ,PRV_PRF_CONSECUTIVO
            ,PRV_CONSECUTIVO
            ,PRV_VALOR_NOMINAL
      FROM   PREORDENES_VENTA
            ,PREORDENES_FONDOS
            ,PORTAFOLIOS_POSICION
      WHERE  PRV_FECHA_CUMPLIMIENTO >= TRUNC(P_FECHA)
      AND    PRV_FECHA_CUMPLIMIENTO < TRUNC(P_FECHA + 1)
      AND    PRV_PRF_FON_CODIGO = PRF_FON_CODIGO
      AND    PRV_PRF_CONSECUTIVO = PRF_CONSECUTIVO
      AND    PRF_EOF_CODIGO = 'APR'
      AND    PRF_PER_NUM_IDEN = PPO_PER_NUM_IDEN
      AND    PRF_PER_TID_CODIGO = PPO_PER_TID_CODIGO
      AND    PRF_FON_CODIGO = P_PRF_FON_CODIGO
      AND    PRF_ENA_MNEMONICO = P_PPO_ENA_MNEMONICO
      AND    TRUNC(PRF_FECHA_EMISION) = TRUNC(PPO_FECHA_EMISION)
      AND    TRUNC(PRF_FECHA_VENCIMIENTO) = TRUNC(PPO_FECHA_VENCIMIENTO)
      AND    NVL(PRF_TASA_FACIAL,-.01) = NVL(PPO_TASA_FACIAL,-.01)
      AND    NVL(PRF_TRE_MNEMONICO,' ') = NVL(PPO_TRE_MNEMONICO,' ')
      AND    NVL(PRF_PUNTOS_ADICIONALES,-.000001) = NVL(PPO_PUNTOS_ADICIONALES,-.000001)
      AND    NVL(PRF_PERIODICIDAD_TASA,-1) = NVL(PPO_PERIODICIDAD_TASA,-1)
      AND    NVL(PRF_MODALIDAD_TASA,' ') = NVL(PPO_MODALIDAD_TASA,' ')
      AND    NVL(PRF_CODIGO_PERIODO,' ') = NVL(PPO_CODIGO_PERIODO,' ')
      AND    NVL(PRF_BASE_CALCULO,-1) = NVL(PPO_BASE_CALCULO,-1)
      AND    NVL(PRF_TIPO_PAGO_FLUJO,' ') = NVL(PPO_TIPO_PAGO_FLUJO,' ')
      AND    NVL(PRF_CAPITALIZABLE,'N') = NVL(PPO_CAPITALIZABLE,'N')
      AND    NVL(PRF_AMORTIZABLE,'N') = NVL(PPO_AMORTIZABLE,'N')
      AND    NVL(PRF_BMO_MNEMONICO,' ') = NVL(PPO_BMO_MNEMONICO,' ')
      AND    PPO_CONSECUTIVO = P_PPO_CONSECUTIVO;
   PRV1   C_PREORDENES_VENTA%ROWTYPE;
   CURSOR C_COTIZACION_BASE(FECHA  DATE
                           ,BASE   VARCHAR2) IS
      SELECT CBM_VALOR
      FROM   COTIZACIONES_BASE_MONETARIAS
      WHERE  TRUNC(CBM_FECHA) = TRUNC(FECHA)
      AND    CBM_BMO_MNEMONICO = BASE;
   TOT_OPERACION    NUMBER;
   TOT_NOMINAL      NUMBER;
   TOT_OPERACION_TC NUMBER;
   TOT_COMISION     NUMBER;
   TOT_OPERACION_FR NUMBER;
   TOT_NOMINAL_FR   NUMBER;
   TOTAL_TITULOS    NUMBER;
   TOTAL_PREORDENES NUMBER;
   PORC             NUMBER;
   COTIZACION       NUMBER;
   P_TIPO           VARCHAR2(3);
   CONSECUTIVO_CVS  NUMBER;
   VALOR_TM         NUMBER;
   P_TFO_CODIGO     TITULOS_FONDOS.TFO_CODIGO%TYPE;
   P_TFO_CODIGO_FRA TITULOS_FONDOS.TFO_CODIGO%TYPE;
BEGIN

   -- INICIO OMORA F351
   P_CONTADOR_VIG  := 0;
   P_CONTADOR_GAF  := 0;
   P_ESTADO_TITULO := '';

   OPEN C_VERIFICA_ESTADO_TITULOS;
   FETCH C_VERIFICA_ESTADO_TITULOS INTO R_VERIFICA_ESTADO_TITULOS;
   WHILE C_VERIFICA_ESTADO_TITULOS%FOUND LOOP

     IF R_VERIFICA_ESTADO_TITULOS.TFO_ETI_CODIGO = 'VIG' THEN
       P_CONTADOR_VIG := R_VERIFICA_ESTADO_TITULOS.CONTADOR;
     ELSIF R_VERIFICA_ESTADO_TITULOS.TFO_ETI_CODIGO = 'GAF' THEN
       P_CONTADOR_GAF := R_VERIFICA_ESTADO_TITULOS.CONTADOR;
     END IF;

   FETCH C_VERIFICA_ESTADO_TITULOS INTO R_VERIFICA_ESTADO_TITULOS;
   END LOOP;
   CLOSE C_VERIFICA_ESTADO_TITULOS;

   IF P_CONTADOR_GAF > 0 AND P_CONTADOR_VIG = 0 THEN
     P_ESTADO_TITULO := 'GAF';
   ELSE
     P_ESTADO_TITULO := 'VIG';
   END IF;
   -- FIN OMORA F351

   OPEN C_TOTAL_TITULOS;
   FETCH C_TOTAL_TITULOS INTO TOTAL_TITULOS;
   CLOSE C_TOTAL_TITULOS;
   IF NVL(TOTAL_TITULOS,0) = 1 THEN
      OPEN C_TITULOS;
      FETCH C_TITULOS INTO TFO1;
      CLOSE C_TITULOS;
      P_TFO_CODIGO := TFO1.TFO_CODIGO;
      OPEN C_ULTIMO_MVTO;
      FETCH C_ULTIMO_MVTO INTO MRF1;
      CLOSE C_ULTIMO_MVTO;
      TOT_OPERACION := ABS(NVL(MRF1.MRF_VALOR_TITULO_TM,0));
      TOT_OPERACION_TC := ABS(NVL(MRF1.MRF_VALOR_TITULO_TC,0));
      TOT_COMISION := NVL(TFO1.TFO_COMISION_BOLSA,0);
      TOT_NOMINAL := ABS(NVL(TFO1.TFO_VALOR_NOMINAL,0));
      IF TFO1.TFO_BMO_MNEMONICO != 'PESOS' THEN
         OPEN C_COTIZACION_BASE(P_FECHA,TFO1.TFO_BMO_MNEMONICO);
         FETCH C_COTIZACION_BASE INTO COTIZACION;
         IF C_COTIZACION_BASE%NOTFOUND THEN
            RAISE_APPLICATION_ERROR(-20100,'Cotizacion Monetaria no encontrada');
         END IF;
         CLOSE C_COTIZACION_BASE;
      ELSE
         COTIZACION := 1;
      END IF;
      TOT_OPERACION := TOT_OPERACION * COTIZACION;
      TOT_OPERACION_TC := TOT_OPERACION_TC * COTIZACION;
      IF TFO1.TFO_TYPE = 'TRF' THEN
         P_TIPO := 'RF';
      ELSE
         P_TIPO := 'ACC';
      END IF;
   ELSIF NVL(TOTAL_TITULOS,0) = 0 THEN
      P_TFO_CODIGO := NULL;
   ELSE
      TOT_OPERACION := 0;
      TOT_OPERACION_TC := 0;
      TOT_COMISION := 0;
      TOT_NOMINAL := 0;
      OPEN C_TITULOS;
      FETCH C_TITULOS INTO TFO1;
      WHILE C_TITULOS%FOUND LOOP
         OPEN C_ULTIMO_MVTO;
         FETCH C_ULTIMO_MVTO INTO MRF1;
         CLOSE C_ULTIMO_MVTO;
         TOT_OPERACION := TOT_OPERACION + ABS(NVL(MRF1.MRF_VALOR_TITULO_TM,0));
         TOT_OPERACION_TC := TOT_OPERACION_TC + ABS(NVL(MRF1.MRF_VALOR_TITULO_TC,0));
         TOT_COMISION := TOT_COMISION + NVL(TFO1.TFO_COMISION_BOLSA,0);
         TOT_NOMINAL := TOT_NOMINAL + ABS(NVL(TFO1.TFO_VALOR_NOMINAL,0));
         FETCH C_TITULOS INTO TFO1;
      END LOOP;
      CLOSE C_TITULOS;
      IF TFO1.TFO_BMO_MNEMONICO != 'PESOS' THEN
         OPEN C_COTIZACION_BASE(P_FECHA,TFO1.TFO_BMO_MNEMONICO);
         FETCH C_COTIZACION_BASE INTO COTIZACION;
         IF C_COTIZACION_BASE%NOTFOUND THEN
            RAISE_APPLICATION_ERROR(-20101,'Cotizacion Monetaria no encontrada');
         END IF;
         CLOSE C_COTIZACION_BASE;
      ELSE
         COTIZACION := 1;
      END IF;
      TOT_OPERACION := TOT_OPERACION * COTIZACION;
      TOT_OPERACION_TC := TOT_OPERACION_TC * COTIZACION;
      IF TFO1.TFO_TYPE = 'TRF' THEN
         P_TIPO := 'RF';
      ELSE
         P_TIPO := 'ACC';
      END IF;
      P_NEGOCIOS_POSICION.CREAR_TITULO_POSICION
         (P_PRF_FON_CODIGO           => P_PRF_FON_CODIGO
         ,P_PRF_TIPO                 => P_TIPO
         ,P_PRF_TIPO_NEGOCIO         => NULL
         ,P_PRF_ENA_MNEMONICO        => P_PPO_ENA_MNEMONICO
         ,P_PRF_BMO_MNEMONICO        => TFO1.TFO_BMO_MNEMONICO
         ,P_PRF_TRE_MNEMONICO        => TFO1.TFO_TRE_MNEMONICO
         ,P_PRF_FECHA_EMISION        => TFO1.TFO_FECHA_EMISION
         ,P_PRF_FECHA_VENCIMIENTO    => TFO1.TFO_FECHA_VENCIMIENTO
         ,P_PRF_PERIODICIDAD_TASA    => TFO1.TFO_PERIODICIDAD_TASA
         ,P_PRF_BASE_CALCULO         => TFO1.TFO_BASE_CALCULO
         ,P_PRF_MODALIDAD_TASA       => TFO1.TFO_MODALIDAD_TASA
         ,P_PRF_PUNTOS_ADICIONALES   => TFO1.TFO_PUNTOS_ADICIONALES
         ,P_PRF_TASA_FACIAL          => TFO1.TFO_TASA_FACIAL * 100
         ,P_PRF_AMORTIZABLE          => TFO1.TFO_AMORTIZABLE
         ,P_PRF_TIPO_PAGO_FLUJO      => TFO1.TFO_TIPO_PAGO_FLUJO
         ,P_PRF_FECHA_PRIMER_FLUJO   => TFO1.TFO_FECHA_PRIMER_FLUJO
         ,P_PRF_CAPITALIZABLE        => TFO1.TFO_CAPITALIZABLE
         ,P_PRF_CODIGO_PERIODO       => TFO1.TFO_CODIGO_PERIODO
         ,P_PRF_CONSECUTIVO          => NULL
         ,P_PRF_PER_NUM_IDEN         => TFO1.TFO_PER_NUM_IDEN
         ,P_PRF_PER_TID_CODIGO       => TFO1.TFO_PER_TID_CODIGO
         ,P_PRC_LTI_MNEMONICO        => TFO1.TFO_LTI_MNEMONICO
         ,P_PRC_MONTO                => TOT_OPERACION
         ,P_PRC_VALOR_NOMINAL        => TOT_NOMINAL
         ,P_PRC_CNE_MNEMONICO        => NULL
         ,P_PRC_MERCADO              => TFO1.TFO_MERCADO
         ,P_PRC_CONSECUTIVO          => NULL
         ,P_PRC_BOL_MNEMONICO        => TFO1.TFO_BOL_MNEMONICO
         ,P_PRC_NUMERO_OPERACION     => NULL
         ,P_PRC_LIC_TIPO_OPERACION   => NULL
         ,P_PRC_LIC_NUMERO_FRACCION  => NULL
         ,P_PRC_PER_NUM_IDEN         => NULL
         ,P_PRC_PER_TID_CODIGO       => NULL
         ,P_PRV_CONSECUTIVO          => NULL
         ,P_FECHA                    => P_FECHA
         -- ,P_ETI_CODIGO               => 'VIG'        -- OMORA F351
         ,P_ETI_CODIGO               => P_ESTADO_TITULO -- OMORA F351
         ,P_COTIZACION               => COTIZACION
         ,P_MRF_TMT_MNEMONICO        => 'UNI'
         ,P_INSERTA_CVS              => 'N'
         ,P_MVTO_CVS                 => NULL
         ,P_CVS_CONSECUTIVO          => CONSECUTIVO_CVS
         ,P_TFO_CODIGO               => P_TFO_CODIGO
         ,P_TOTAL_TC                 => TOT_OPERACION_TC
         ,P_FECHA_CUMPLIMIENTO       => NULL
         ,P_VALOR_TM                 => VALOR_TM);
      OPEN C_TITULOS;
      FETCH C_TITULOS INTO TFO1;
      WHILE C_TITULOS%FOUND LOOP
         IF TFO1.TFO_CODIGO != P_TFO_CODIGO THEN
            P_FLUJOS_FRM.ANULE_FLUJOS(TFO1.TFO_FON_CODIGO
                                     ,TFO1.TFO_CODIGO);
            UPDATE TITULOS_FONDOS
            SET    TFO_ETI_CODIGO = 'UNI'
                  ,TFO_DIA_SIGUIENTE = NULL
            WHERE  TFO_FON_CODIGO = TFO1.TFO_FON_CODIGO
            AND    TFO_CODIGO = TFO1.TFO_CODIGO;
            INSERT INTO FRACCIONAMIENTOS_UNIFICACIONES
               (FUN_TFO_FON_CODIGO
               ,FUN_TFO_CODIGO
               ,FUN_TFO_FON_CODIGO_ES_PRODUCID
               ,FUN_TFO_CODIGO_ES_PRODUCIDA
               ,FUN_FECHA
               ,FUN_TIPO_OPERACION)
            VALUES
               (TFO1.TFO_FON_CODIGO
               ,TFO1.TFO_CODIGO
               ,TFO1.TFO_FON_CODIGO
               ,P_TFO_CODIGO
               ,P_FECHA
               ,'U');

			INSERT INTO SEGUIMIENTOS
				(FONDO,
				 TITULO,
				 TITULO_CREADO,
				 OPERACION,
				 FECHA,
				 OREIGEN)
			VALUES
				(TFO1.TFO_FON_CODIGO,
				 TFO1.TFO_CODIGO,
				 P_TFO_CODIGO,
				 'U',
				 SYSDATE,
				 'P_NEGOCIOS_POSICION 6919');
         END IF;
         FETCH C_TITULOS INTO TFO1;
      END LOOP;
      CLOSE C_TITULOS;
   END IF;
   OPEN C_TOTAL_PREORDENES;
   FETCH C_TOTAL_PREORDENES INTO TOTAL_PREORDENES, TOT_NOMINAL_FR;
   CLOSE C_TOTAL_PREORDENES;
   TOTAL_PREORDENES := NVL(TOTAL_PREORDENES,0);
   IF TOTAL_PREORDENES = 1 AND
      TOT_NOMINAL = TOT_NOMINAL_FR THEN
      IF P_PRV_PRF_CONSECUTIVO IS NOT NULL THEN
         UPDATE PREORDENES_VENTA
         SET    PRV_TFO_CODIGO = P_TFO_CODIGO
         WHERE  PRV_PRF_FON_CODIGO = P_PRF_FON_CODIGO
         AND    PRV_PRF_CONSECUTIVO = P_PRV_PRF_CONSECUTIVO;
      ELSE
         OPEN C_PREORDENES_VENTA;
         FETCH C_PREORDENES_VENTA INTO PRV1;
         CLOSE C_PREORDENES_VENTA;

         UPDATE PREORDENES_VENTA
         SET    PRV_TFO_CODIGO = P_TFO_CODIGO
         WHERE  PRV_PRF_FON_CODIGO = P_PRF_FON_CODIGO
         AND    PRV_PRF_CONSECUTIVO = PRV1.PRV_PRF_CONSECUTIVO;
      END IF;
   ELSIF TOTAL_PREORDENES = 0 THEN
      NULL;
   ELSE
      TOT_NOMINAL_FR := 0;
      TOT_OPERACION_FR := 0;
      OPEN C_PREORDENES_VENTA;
      FETCH C_PREORDENES_VENTA INTO PRV1;
      WHILE C_PREORDENES_VENTA%FOUND LOOP
         PORC := ((PRV1.PRV_VALOR_NOMINAL * 100) / TOT_NOMINAL) / 100;
         P_NEGOCIOS_POSICION.CREAR_TITULO_POSICION
            (P_PRF_FON_CODIGO           => P_PRF_FON_CODIGO
            ,P_PRF_TIPO                 => P_TIPO
            ,P_PRF_TIPO_NEGOCIO         => NULL
            ,P_PRF_ENA_MNEMONICO        => P_PPO_ENA_MNEMONICO
            ,P_PRF_BMO_MNEMONICO        => TFO1.TFO_BMO_MNEMONICO
            ,P_PRF_TRE_MNEMONICO        => TFO1.TFO_TRE_MNEMONICO
            ,P_PRF_FECHA_EMISION        => TFO1.TFO_FECHA_EMISION
            ,P_PRF_FECHA_VENCIMIENTO    => TFO1.TFO_FECHA_VENCIMIENTO
            ,P_PRF_PERIODICIDAD_TASA    => TFO1.TFO_PERIODICIDAD_TASA
            ,P_PRF_BASE_CALCULO         => TFO1.TFO_BASE_CALCULO
            ,P_PRF_MODALIDAD_TASA       => TFO1.TFO_MODALIDAD_TASA
            ,P_PRF_PUNTOS_ADICIONALES   => TFO1.TFO_PUNTOS_ADICIONALES
            ,P_PRF_TASA_FACIAL          => TFO1.TFO_TASA_FACIAL * 100
            ,P_PRF_AMORTIZABLE          => TFO1.TFO_AMORTIZABLE
            ,P_PRF_TIPO_PAGO_FLUJO      => TFO1.TFO_TIPO_PAGO_FLUJO
            ,P_PRF_FECHA_PRIMER_FLUJO   => TFO1.TFO_FECHA_PRIMER_FLUJO
            ,P_PRF_CAPITALIZABLE        => TFO1.TFO_CAPITALIZABLE
            ,P_PRF_CODIGO_PERIODO       => TFO1.TFO_CODIGO_PERIODO
            ,P_PRF_CONSECUTIVO          => NULL
            ,P_PRF_PER_NUM_IDEN         => TFO1.TFO_PER_NUM_IDEN
            ,P_PRF_PER_TID_CODIGO       => TFO1.TFO_PER_TID_CODIGO
            ,P_PRC_LTI_MNEMONICO        => TFO1.TFO_LTI_MNEMONICO
            ,P_PRC_MONTO                => ROUND(TOT_OPERACION * PORC,2)
            ,P_PRC_VALOR_NOMINAL        => PRV1.PRV_VALOR_NOMINAL
            ,P_PRC_CNE_MNEMONICO        => NULL
            ,P_PRC_MERCADO              => TFO1.TFO_MERCADO
            ,P_PRC_CONSECUTIVO          => NULL
            ,P_PRC_BOL_MNEMONICO        => TFO1.TFO_BOL_MNEMONICO
            ,P_PRC_NUMERO_OPERACION     => NULL
            ,P_PRC_LIC_TIPO_OPERACION   => NULL
            ,P_PRC_LIC_NUMERO_FRACCION  => NULL
            ,P_PRC_PER_NUM_IDEN         => NULL
            ,P_PRC_PER_TID_CODIGO       => NULL
            ,P_PRV_CONSECUTIVO          => NULL
            ,P_FECHA                    => P_FECHA
            -- ,P_ETI_CODIGO               => 'VIG'        -- OMORA F351
            ,P_ETI_CODIGO               => P_ESTADO_TITULO -- OMORA F351
            ,P_COTIZACION               => COTIZACION
            ,P_MRF_TMT_MNEMONICO        => 'FRA'
            ,P_INSERTA_CVS              => 'N'
            ,P_MVTO_CVS                 => NULL
            ,P_CVS_CONSECUTIVO          => CONSECUTIVO_CVS
            ,P_TFO_CODIGO               => P_TFO_CODIGO_FRA
            ,P_TOTAL_TC                 => NULL
            ,P_FECHA_CUMPLIMIENTO       => NULL
            ,P_VALOR_TM                 => VALOR_TM);
         UPDATE PREORDENES_VENTA
         SET    PRV_TFO_CODIGO = P_TFO_CODIGO_FRA
         WHERE  PRV_PRF_FON_CODIGO = PRV1.PRV_PRF_FON_CODIGO
         AND    PRV_PRF_CONSECUTIVO = PRV1.PRV_PRF_CONSECUTIVO
         AND    PRV_CONSECUTIVO = PRV1.PRV_CONSECUTIVO;
         INSERT INTO FRACCIONAMIENTOS_UNIFICACIONES
            (FUN_TFO_FON_CODIGO
            ,FUN_TFO_CODIGO
            ,FUN_TFO_FON_CODIGO_ES_PRODUCID
            ,FUN_TFO_CODIGO_ES_PRODUCIDA
            ,FUN_FECHA
            ,FUN_TIPO_OPERACION)
         VALUES
            (P_PRF_FON_CODIGO
            ,P_TFO_CODIGO
            ,P_PRF_FON_CODIGO
            ,P_TFO_CODIGO_FRA
            ,P_FECHA
            ,'F');

	    INSERT INTO SEGUIMIENTOS
				(FONDO,
				 TITULO,
				 TITULO_CREADO,
				 OPERACION,
				 FECHA,
				 OREIGEN)
		VALUES
				(P_PRF_FON_CODIGO,
				 P_TFO_CODIGO,
				 P_TFO_CODIGO_FRA,
				 'F',
				 SYSDATE,
				 'P_NEGOCIOS_POSICION 7034');

         TOT_NOMINAL_FR := TOT_NOMINAL_FR + PRV1.PRV_VALOR_NOMINAL;
         TOT_OPERACION_FR := TOT_OPERACION_FR  + ROUND(TOT_OPERACION * PORC,2);
         FETCH C_PREORDENES_VENTA INTO PRV1;
      END LOOP;
      CLOSE C_PREORDENES_VENTA;
      IF TOT_NOMINAL > TOT_NOMINAL_FR THEN
         PORC := (((TOT_NOMINAL - TOT_NOMINAL_FR) * 100) / TOT_NOMINAL) / 100;
         P_NEGOCIOS_POSICION.CREAR_TITULO_POSICION
            (P_PRF_FON_CODIGO           => P_PRF_FON_CODIGO
            ,P_PRF_TIPO                 => P_TIPO
            ,P_PRF_TIPO_NEGOCIO         => NULL
            ,P_PRF_ENA_MNEMONICO        => P_PPO_ENA_MNEMONICO
            ,P_PRF_BMO_MNEMONICO        => TFO1.TFO_BMO_MNEMONICO
            ,P_PRF_TRE_MNEMONICO        => TFO1.TFO_TRE_MNEMONICO
            ,P_PRF_FECHA_EMISION        => TFO1.TFO_FECHA_EMISION
            ,P_PRF_FECHA_VENCIMIENTO    => TFO1.TFO_FECHA_VENCIMIENTO
            ,P_PRF_PERIODICIDAD_TASA    => TFO1.TFO_PERIODICIDAD_TASA
            ,P_PRF_BASE_CALCULO         => TFO1.TFO_BASE_CALCULO
            ,P_PRF_MODALIDAD_TASA       => TFO1.TFO_MODALIDAD_TASA
            ,P_PRF_PUNTOS_ADICIONALES   => TFO1.TFO_PUNTOS_ADICIONALES
            ,P_PRF_TASA_FACIAL          => TFO1.TFO_TASA_FACIAL * 100
            ,P_PRF_AMORTIZABLE          => TFO1.TFO_AMORTIZABLE
            ,P_PRF_TIPO_PAGO_FLUJO      => TFO1.TFO_TIPO_PAGO_FLUJO
            ,P_PRF_FECHA_PRIMER_FLUJO   => TFO1.TFO_FECHA_PRIMER_FLUJO
            ,P_PRF_CAPITALIZABLE        => TFO1.TFO_CAPITALIZABLE
            ,P_PRF_CODIGO_PERIODO       => TFO1.TFO_CODIGO_PERIODO
            ,P_PRF_CONSECUTIVO          => NULL
            ,P_PRF_PER_NUM_IDEN         => TFO1.TFO_PER_NUM_IDEN
            ,P_PRF_PER_TID_CODIGO       => TFO1.TFO_PER_TID_CODIGO
            ,P_PRC_LTI_MNEMONICO        => TFO1.TFO_LTI_MNEMONICO
            ,P_PRC_MONTO                => ROUND(TOT_OPERACION * PORC,2)
            ,P_PRC_VALOR_NOMINAL        => TOT_NOMINAL - TOT_NOMINAL_FR
            ,P_PRC_CNE_MNEMONICO        => NULL
            ,P_PRC_MERCADO              => TFO1.TFO_MERCADO
            ,P_PRC_CONSECUTIVO          => NULL
            ,P_PRC_BOL_MNEMONICO        => TFO1.TFO_BOL_MNEMONICO
            ,P_PRC_NUMERO_OPERACION     => NULL
            ,P_PRC_LIC_TIPO_OPERACION   => NULL
            ,P_PRC_LIC_NUMERO_FRACCION  => NULL
            ,P_PRC_PER_NUM_IDEN         => NULL
            ,P_PRC_PER_TID_CODIGO       => NULL
            ,P_PRV_CONSECUTIVO          => NULL
            ,P_FECHA                    => P_FECHA
            -- ,P_ETI_CODIGO               => 'VIG'        -- OMORA F351
            ,P_ETI_CODIGO               => P_ESTADO_TITULO -- OMORA F351
            ,P_COTIZACION               => COTIZACION
            ,P_MRF_TMT_MNEMONICO        => 'FRA'
            ,P_INSERTA_CVS              => 'N'
            ,P_MVTO_CVS                 => NULL
            ,P_CVS_CONSECUTIVO          => CONSECUTIVO_CVS
            ,P_TFO_CODIGO               => P_TFO_CODIGO_FRA
            ,P_TOTAL_TC                 => NULL
            ,P_FECHA_CUMPLIMIENTO       => NULL
            ,P_VALOR_TM                 => VALOR_TM);
         INSERT INTO FRACCIONAMIENTOS_UNIFICACIONES
            (FUN_TFO_FON_CODIGO
            ,FUN_TFO_CODIGO
            ,FUN_TFO_FON_CODIGO_ES_PRODUCID
            ,FUN_TFO_CODIGO_ES_PRODUCIDA
            ,FUN_FECHA
            ,FUN_TIPO_OPERACION)
         VALUES
            (P_PRF_FON_CODIGO
            ,P_TFO_CODIGO
            ,P_PRF_FON_CODIGO
            ,P_TFO_CODIGO_FRA
            ,P_FECHA
            ,'F');

	    INSERT INTO SEGUIMIENTOS
				(FONDO,
				 TITULO,
				 TITULO_CREADO,
				 OPERACION,
				 FECHA,
				 OREIGEN)
		VALUES
				(P_PRF_FON_CODIGO,
				 P_TFO_CODIGO,
				 P_TFO_CODIGO_FRA,
				 'F',
				 SYSDATE,
				 'P_NEGOCIOS_POSICION 7117');

      END IF;
      UPDATE TITULOS_FONDOS
      SET    TFO_ETI_CODIGO = 'FRC'
            ,TFO_DIA_SIGUIENTE = NULL
      WHERE  TFO_FON_CODIGO = P_PRF_FON_CODIGO
      AND    TFO_CODIGO = P_TFO_CODIGO;
      P_FLUJOS_FRM.ANULE_FLUJOS(P_PRF_FON_CODIGO
                               ,P_TFO_CODIGO);
   END IF;
END VERIFICAR_FRACCIONAR_POSICION;
/*************************************************/
/*   PROCEDIMIENTO PARA INSERTAR EN EL MODULO DE OPERACIONES DIARIAS - PP
     LAS COMISIONES ASIGNADAS A LOS COMERCIALES Y LOS CLIENTES QUE INTERVINIERON
*/
PROCEDURE COMISIONES_SIMULTANEAS_PP (P_FECHA_DESDE IN DATE,
                                     P_FECHA_HASTA IN DATE) IS
      CURSOR C_CPO IS
      SELECT  CPO_CONSECUTIVO
         ,CPO_PPO_CONSECUTIVO
             ,CPO_PER_NUM_IDEN
             ,CPO_PER_TID_CODIGO
             ,CPO_FECHA
             ,CPO_TOTAL_UTILIDAD
             ,CPO_TOTAL_UTILIDAD_MESA
             ,CPO_TOTAL_UTILIDAD_COMERCIAL
             ,CPO_TOTAL_FONDEOS_INTERNOS
             ,CPO_TOTAL_COMISION_INTRAMESAS
             ,NVL(CPR_CUENTA_POSICION_PROPIA,0) CPR_CUENTA_POSICION_PROPIA
      FROM COMISIONES_MESAS_POSICION, PERSONAS_CENTROS_PRODUCCION, CENTROS_PRODUCCION
      WHERE CPO_FECHA >= TRUNC(P_FECHA_DESDE)
        AND CPO_FECHA < TRUNC(P_FECHA_HASTA) +1
        AND CPO_PER_NUM_IDEN = PCP_PER_NUM_IDEN
        AND CPO_PER_TID_CODIGO = PCP_PER_TID_CODIGO
        AND PCP_PRINCIPAL = 'S'
        AND PCP_CPR_MNEMONICO = CPR_MNEMONICO;
   R_CPO C_CPO%ROWTYPE;
   CONSECUTIVO_OPC OPERACIONES_DIARIAS.OPC_CONSECUTIVO%TYPE;
--   NID_MESA CENTROS_PRODUCCION.CPR_PER_NUM_IDEN%TYPE;
--   TID_MESA CENTROS_PRODUCCION.CPR_PER_TID_CODIGO%TYPE;
   CENTRO_P CENTROS_PRODUCCION.CPR_MNEMONICO%TYPE;
  --
   CURSOR C_CPC (P_CPO NUMBER,P_TIPO VARCHAR2) IS
      SELECT CPC_CONSECUTIVO
            ,CPC_CPO_CONSECUTIVO
            ,CPC_PER_NUM_IDEN
            ,CPC_PER_TID_CODIGO
            ,CPC_CCC_CLI_PER_NUM_IDEN
            ,CPC_CCC_CLI_PER_TID_CODIGO
            ,NVL(CPC_CCC_NUMERO_CUENTA,0) CPC_CCC_NUMERO_CUENTA
            ,CPC_PER_NUM_IDEN_CONTRAPARTE
            ,CPC_PER_TID_CODIGO_CONTRAPARTE
            ,CPC_UTILIDAD
      FROM COMISIONES_POSICION_COMERCIAL
      WHERE CPC_CPO_CONSECUTIVO = P_CPO
       AND ((P_TIPO = 'F' AND CPC_PRC_PRF_CONSECUTIVO IS NULL AND CPC_PRV_PRF_CONSECUTIVO IS NULL)
             OR
            ((P_TIPO = 'C' AND (CPC_PRC_PRF_CONSECUTIVO IS NOT NULL OR CPC_PRV_PRF_CONSECUTIVO IS NOT NULL) AND CPC_CCC_CLI_PER_NUM_IDEN IS NOT NULL))
             OR
            ((P_TIPO = 'I' AND (CPC_PRC_PRF_CONSECUTIVO IS NOT NULL OR CPC_PRV_PRF_CONSECUTIVO IS NOT NULL) AND CPC_CCC_CLI_PER_NUM_IDEN IS NULL)));

   R_CPC C_CPC%ROWTYPE;
   CONS_CPC NUMBER;

   NID_INTRAMESA CENTROS_PRODUCCION.CPR_PER_NUM_IDEN%TYPE;
   TID_INTRAMESA CENTROS_PRODUCCION.CPR_PER_TID_CODIGO%TYPE;

  CURSOR C_CPC_FIX (P_CPO NUMBER,P_TIPO VARCHAR2) IS
      SELECT CPC_CPO_CONSECUTIVO
            ,CPC_PER_NUM_IDEN
            ,CPC_PER_TID_CODIGO
            ,CPC_CCC_CLI_PER_NUM_IDEN
            ,CPC_CCC_CLI_PER_TID_CODIGO
            ,NVL(CPC_CCC_NUMERO_CUENTA,1) CPC_CCC_NUMERO_CUENTA
            ,CPC_PER_NUM_IDEN_CONTRAPARTE
            ,CPC_PER_TID_CODIGO_CONTRAPARTE
            ,SUM(CPC_UTILIDAD) CPC_UTILIDAD
      FROM COMISIONES_POSICION_COMERCIAL
      WHERE CPC_CPO_CONSECUTIVO = P_CPO
       AND ((P_TIPO = 'F' AND CPC_PRC_PRF_CONSECUTIVO IS NULL AND CPC_PRV_PRF_CONSECUTIVO IS NULL)
             OR
            ((P_TIPO = 'C' AND (CPC_PRC_PRF_CONSECUTIVO IS NOT NULL OR CPC_PRV_PRF_CONSECUTIVO IS NOT NULL) AND CPC_CCC_CLI_PER_NUM_IDEN IS NOT NULL))
             OR
            ((P_TIPO = 'I' AND (CPC_PRC_PRF_CONSECUTIVO IS NOT NULL OR CPC_PRV_PRF_CONSECUTIVO IS NOT NULL) AND CPC_CCC_CLI_PER_NUM_IDEN IS NULL)))
    GROUP BY CPC_CPO_CONSECUTIVO, CPC_PER_NUM_IDEN, CPC_PER_TID_CODIGO, CPC_CCC_CLI_PER_NUM_IDEN, CPC_CCC_CLI_PER_TID_CODIGO, NVL(CPC_CCC_NUMERO_CUENTA,1), CPC_PER_NUM_IDEN_CONTRAPARTE, CPC_PER_TID_CODIGO_CONTRAPARTE;
   R_CPC_FIX C_CPC_FIX%ROWTYPE;
  --
   CURSOR C_PCP (NID VARCHAR2, TID VARCHAR2) IS
      SELECT PCP_CPR_MNEMONICO
      FROM PERSONAS_CENTROS_PRODUCCION
      WHERE PCP_PER_NUM_IDEN = NID
        AND PCP_PER_TID_CODIGO = TID
        AND PCP_PRINCIPAL = 'S';
   CENTRO PERSONAS_CENTROS_PRODUCCION.PCP_CPR_MNEMONICO%TYPE;
  --
  CURSOR C_NEG (V_CPO_PPO_CONSECUTIVO NUMBER )IS
    SELECT  NPO_CONSECUTIVO  ,
        NPO_PPO_CONSECUTIVO    ,
        NPO_OCO_CONSECUTIVO    ,
        NPO_OVE_CONSECUTIVO    ,
        NPO_PORCENTAJE_COMISION,
        NPO_CLI_PER_NUM_IDEN   ,
        NPO_CLI_PER_TID_CODIGO ,
        NPO_COMISION_INTRAMESA,
        OCO_CONSECUTIVO   COSNECUTIVO     ,
        OCO_CANAL_ORIGEN ORIGEN
      FROM NEGOCIOS_POSICION,
        ORDENES_COMPRA
      WHERE NPO_OCO_CONSECUTIVO = OCO_CONSECUTIVO
      AND NPO_PPO_CONSECUTIVO  =  V_CPO_PPO_CONSECUTIVO --( 228969, 228970, 228971, 228972, 228973 )
      AND NPO_FECHA            >= TRUNC(P_FECHA_DESDE)
      AND NPO_FECHA            <  TRUNC(P_FECHA_DESDE) + 1
    UNION
    SELECT  NPO_CONSECUTIVO      ,
        NPO_PPO_CONSECUTIVO        ,
        NPO_OCO_CONSECUTIVO        ,
        NPO_OVE_CONSECUTIVO        ,
        NPO_PORCENTAJE_COMISION    ,
        NPO_CLI_PER_NUM_IDEN       ,
        NPO_CLI_PER_TID_CODIGO     ,
        NPO_COMISION_INTRAMESA     ,
        OVE_CONSECUTIVO CONSECUTIVO,
        OVE_CANAL_ORIGEN
      FROM NEGOCIOS_POSICION,
        ORDENES_VENTA
      WHERE NPO_OVE_CONSECUTIVO = OVE_CONSECUTIVO
      AND NPO_PPO_CONSECUTIVO  =  V_CPO_PPO_CONSECUTIVO-- IN( 228969, 228970, 228971, 228972, 228973 )
      AND NPO_FECHA            >= TRUNC(P_FECHA_DESDE)
      AND NPO_FECHA            <  TRUNC(P_FECHA_DESDE) + 1;
  R_NEG C_NEG%ROWTYPE;
  V_ORIGEN    VARCHAR2(20);
  V_PORCENTAJE  NUMBER;
  V_CUENTA    NUMBER;
  --
  --
  CURSOR C_NEG_C (V_CPO_PPO_CONSECUTIVO NUMBER )IS
    SELECT SUM( CUENTA ) CUENTA
      FROM
    ( SELECT COUNT(*) CUENTA
      FROM NEGOCIOS_POSICION,
        ORDENES_COMPRA
      WHERE NPO_OCO_CONSECUTIVO = OCO_CONSECUTIVO
      AND NPO_PPO_CONSECUTIVO  =  V_CPO_PPO_CONSECUTIVO --( 228969, 228970, 228971, 228972, 228973 )
      AND NPO_FECHA            >= TRUNC(P_FECHA_DESDE)
      AND NPO_FECHA            <  TRUNC(P_FECHA_DESDE) + 1
    UNION
    SELECT  COUNT(*) CUENTA
      FROM NEGOCIOS_POSICION,
        ORDENES_VENTA
      WHERE NPO_OVE_CONSECUTIVO = OVE_CONSECUTIVO
      AND NPO_PPO_CONSECUTIVO  =  V_CPO_PPO_CONSECUTIVO-- IN( 228969, 228970, 228971, 228972, 228973 )
      AND NPO_FECHA            >= TRUNC(P_FECHA_DESDE)
      AND NPO_FECHA            <  TRUNC(P_FECHA_DESDE) + 1);
  R_NEG_C C_NEG_C%ROWTYPE;
  --
   FUNCTION CONS_OPC RETURN NUMBER IS
      CURSOR NCONS IS
         SELECT MAX(OPC_CONSECUTIVO) N
         FROM OPERACIONES_DIARIAS;
     NSIGUIENTE NUMBER:= '';
   BEGIN
      OPEN NCONS;
      FETCH NCONS INTO NSIGUIENTE;
      IF NCONS%NOTFOUND OR NSIGUIENTE IS NULL THEN
         NSIGUIENTE := 1;
      ELSE
         NSIGUIENTE := NSIGUIENTE + 1;
      END IF;
      CLOSE NCONS;
      RETURN(NSIGUIENTE);
   END;

BEGIN

   -- POSICION PROPIA - SIMULTANEAS
   OPEN C_CPO;
   FETCH C_CPO INTO R_CPO;
   WHILE C_CPO%FOUND LOOP

    OPEN C_NEG(R_CPO.CPO_PPO_CONSECUTIVO);
    FETCH C_NEG INTO R_NEG;
    IF  C_NEG%FOUND THEN
      V_ORIGEN := R_NEG.ORIGEN;
    END IF;
    CLOSE C_NEG;

      IF R_CPO.CPO_TOTAL_UTILIDAD_MESA  != 0 THEN                    -- INSERTA UTILIDAD DE LA MESA
                 -- SE INSERTA UN REGISTRO POR LA UTILIDAD DE LA MESA EN OPERACIONES_DIARIAS
                 -- SE ASIGNA AL COMERCIAL DUEżO DEL PORTAFOLIO PARA EL CENTRO 21 SE ASIGNA EL COMERCIAL DEL CENTRO DE PRODUCCION
         -- EN CASO CONTRARIO SE ASIGNA EL COMERCIAL DUEżO DEL PORTAFOLIO
                 -- SE ASIGNA AL CLIENTE CORREDORES ASOCIADOS
         CONSECUTIVO_OPC := CONS_OPC;
         INSERT INTO OPERACIONES_DIARIAS
               (  OPC_CONSECUTIVO
                 ,OPC_FECHA
                 ,OPC_COMISION_ESTIMADA
                 ,OPC_PRO_MNEMONICO
                 ,OPC_CPO_CONSECUTIVO
               )
         VALUES ( CONSECUTIVO_OPC
                 ,TRUNC(R_CPO.CPO_FECHA)
                 ,R_CPO.CPO_TOTAL_UTILIDAD_MESA
                 ,'PP'
                 ,R_CPO.CPO_CONSECUTIVO);
         -- AANGEL: con el cambio de multiples portafolios el comercial que se asigna en comisiones
         -- es el dueżo del portafolio y no el comercial del centro de producciżn. Razżn  por la cual
         -- se quita la busqueda del comercial del centro de producciżn. Se busca el centro de producciżn principal
         -- para el comercial dueżo del portafolio
         CENTRO_P := NULL;
         OPEN C_PCP(R_CPO.CPO_PER_NUM_IDEN
                   ,R_CPO.CPO_PER_TID_CODIGO);
         FETCH C_PCP INTO CENTRO_P;
         CLOSE C_PCP;
         INSERT INTO DISTRIBUCION_OPERACIONES(
                  DOP_PER_NUM_IDEN
                 ,DOP_PER_TID_CODIGO
                 ,DOP_CPR_MNEMONICO
                 ,DOP_OPC_CONSECUTIVO
                 ,DOP_PARTICIPACION_ESTIMADA
                 ,DOP_CONFIRMADO)
         VALUES ( R_CPO.CPO_PER_NUM_IDEN
                 ,R_CPO.CPO_PER_TID_CODIGO
                 ,CENTRO_P
                 ,CONSECUTIVO_OPC
                 ,100
                 ,'N');
         --INSERTA DISTRIBUCION A CLIENTES
         INSERT INTO DISTRIBUCION_CLIENTES
                 ( DIC_OPC_CONSECUTIVO
                  ,DIC_PER_NUM_IDEN
                  ,DIC_PER_TID_CODIGO
                  ,DIC_PARTICIPACION_ESTIMADA
                  ,DIC_CCC_NUMERO_CUENTA)
         VALUES ( CONSECUTIVO_OPC
                 ,'860079174'    -- CORREDORES ASOCIADOS
                 ,'NIT'
                 ,100
                 ,R_CPO.CPR_CUENTA_POSICION_PROPIA);
      END IF;
      IF R_CPO.CPO_TOTAL_FONDEOS_INTERNOS  != 0 THEN
         -- INSERTA REGISTRO PARA FONDEO INTERNO
                 -- SE INSERTA UN REGISTRO POR EL FONDEO INTERNO EN OPERACIONES_DIARIAS
                 -- SE ASIGNA AL COMERCIAL DUEżO DEL PORTAFOLIO
                 -- SE ASIGNA AL CLIENTE CORREDORES ASOCIADOS
         -- SE ASOCIA LA FORANEA CON CPC
         -- SE INSERTA UNA CONTRAPARTIDA A RECURSOS PROPIOS 8600791749  Y AL CLIENTE CORREDORES ASOCIADOS-860079174

         OPEN C_CPC(R_CPO.CPO_CONSECUTIVO,'F');
         FETCH C_CPC INTO R_CPC;
         IF C_CPC%FOUND THEN
            CONS_CPC := R_CPC.CPC_CONSECUTIVO;
         END IF;
         CLOSE C_CPC;

         CONSECUTIVO_OPC := CONS_OPC;
         INSERT INTO OPERACIONES_DIARIAS
               (  OPC_CONSECUTIVO
                 ,OPC_FECHA
                 ,OPC_COMISION_ESTIMADA
                 ,OPC_PRO_MNEMONICO
                 ,OPC_CPO_CONSECUTIVO
                 ,OPC_CPC_CONSECUTIVO
               )
         VALUES ( CONSECUTIVO_OPC
                 ,TRUNC(R_CPO.CPO_FECHA)
                 ,-R_CPO.CPO_TOTAL_FONDEOS_INTERNOS
                 ,'PP'
                 ,R_CPO.CPO_CONSECUTIVO
                 ,CONS_CPC);
         -- TRAE CENTRO DE PRODUCCION DEL DUEżO DEL PORTAFOLIO
         CENTRO_P := NULL;
         OPEN C_PCP(R_CPO.CPO_PER_NUM_IDEN
                   ,R_CPO.CPO_PER_TID_CODIGO);
         FETCH C_PCP INTO CENTRO_P;
         CLOSE C_PCP;
         INSERT INTO DISTRIBUCION_OPERACIONES(
                  DOP_PER_NUM_IDEN
                 ,DOP_PER_TID_CODIGO
                 ,DOP_CPR_MNEMONICO
                 ,DOP_OPC_CONSECUTIVO
                 ,DOP_PARTICIPACION_ESTIMADA
                 ,DOP_CONFIRMADO)
         VALUES ( R_CPO.CPO_PER_NUM_IDEN
                 ,R_CPO.CPO_PER_TID_CODIGO
                 ,CENTRO_P
                 ,CONSECUTIVO_OPC
                 ,100
                 ,'N');
         --INSERTA DISTRIBUCION A CLIENTES
         INSERT INTO DISTRIBUCION_CLIENTES
                 ( DIC_OPC_CONSECUTIVO
                  ,DIC_PER_NUM_IDEN
                  ,DIC_PER_TID_CODIGO
                  ,DIC_PARTICIPACION_ESTIMADA
                  ,DIC_CCC_NUMERO_CUENTA)
         VALUES ( CONSECUTIVO_OPC
                 ,'860079174'    -- CORREDORES ASOCIADOS
                 ,'NIT'
                 ,100
                 ,R_CPO.CPR_CUENTA_POSICION_PROPIA);

         --CONTRAPARTIDA A ALFONSO DURAN-- cambiada a recursos propios VAGTUS096528
         CONSECUTIVO_OPC := CONS_OPC;
         INSERT INTO OPERACIONES_DIARIAS
               (  OPC_CONSECUTIVO
                 ,OPC_FECHA
                 ,OPC_COMISION_ESTIMADA
                 ,OPC_PRO_MNEMONICO
                 ,OPC_CPO_CONSECUTIVO
                 ,OPC_CPC_CONSECUTIVO
               )
         VALUES ( CONSECUTIVO_OPC
                 ,TRUNC(R_CPO.CPO_FECHA)
                 ,R_CPO.CPO_TOTAL_FONDEOS_INTERNOS
                 ,'PP'
                 ,R_CPO.CPO_CONSECUTIVO
                 ,CONS_CPC);

         OPEN C_PCP('8600791749','CC');
         FETCH C_PCP INTO CENTRO;
         IF C_PCP%NOTFOUND THEN
            CENTRO := CENTRO_P;
         END IF;
         CLOSE C_PCP;

         INSERT INTO DISTRIBUCION_OPERACIONES(
                  DOP_PER_NUM_IDEN
                 ,DOP_PER_TID_CODIGO
                 ,DOP_CPR_MNEMONICO
                 ,DOP_OPC_CONSECUTIVO
                 ,DOP_PARTICIPACION_ESTIMADA
                 ,DOP_CONFIRMADO)
         VALUES ( '8600791749'
                 ,'CC'
                 ,CENTRO
                 ,CONSECUTIVO_OPC
                 ,100
                 ,'N');
         --INSERTA DISTRIBUCION A CLIENTES
         INSERT INTO DISTRIBUCION_CLIENTES
                 ( DIC_OPC_CONSECUTIVO
                  ,DIC_PER_NUM_IDEN
                  ,DIC_PER_TID_CODIGO
                  ,DIC_PARTICIPACION_ESTIMADA
                  ,DIC_CCC_NUMERO_CUENTA)
         VALUES ( CONSECUTIVO_OPC
                 ,'860079174'    -- CORREDORES ASOCIADOS
                 ,'NIT'
                 ,100
                 ,R_CPO.CPR_CUENTA_POSICION_PROPIA);
      END IF;
      IF R_CPO.CPO_TOTAL_COMISION_INTRAMESAS != 0 THEN
         -- INSERTA DETALLE PARA UTILIDAD INTRAMESA
         -- SE REGISTRA UNA OPERACION POR CADA NEGOCIO INTRAMESA
         -- EL COMERCIAL ASIGNADO ES EL DUEżO DEL PORTAFOLIO
         -- EL CLIENTE ASIGNADO ES EL DE LA LIQUIDACION, SI NO EXISTE VA AL DE LA CONTRAPARTE

        IF V_ORIGEN = 'FIXRF' THEN
          --se mantiene el indicador para Cliente(s) Vende - PP compra

          OPEN C_NEG_C(R_CPO.CPO_PPO_CONSECUTIVO);
          FETCH C_NEG_C INTO R_NEG_C;
          IF C_NEG_C%FOUND THEN
           V_CUENTA := R_NEG_C.CUENTA;
          END IF;
          CLOSE C_NEG_C;

          IF V_CUENTA >1 THEN

            OPEN C_CPC_FIX(R_CPO.CPO_CONSECUTIVO,'I');
            FETCH C_CPC_FIX INTO R_CPC_FIX;
            WHILE C_CPC_FIX%FOUND LOOP

              CONSECUTIVO_OPC := CONS_OPC;

              INSERT INTO OPERACIONES_DIARIAS
              (  OPC_CONSECUTIVO
              ,OPC_FECHA
              ,OPC_COMISION_ESTIMADA
              ,OPC_PRO_MNEMONICO
              ,OPC_CPO_CONSECUTIVO
              --,OPC_CPC_CONSECUTIVO
              )
              VALUES ( CONSECUTIVO_OPC
              ,TRUNC(R_CPO.CPO_FECHA)
              ,R_CPC_FIX.CPC_UTILIDAD
              ,'PP'
              ,R_CPO.CPO_CONSECUTIVO
              --,R_CPC_FIX.CPC_CONSECUTIVO
                  );
              INSERT INTO DISTRIBUCION_OPERACIONES(
               DOP_PER_NUM_IDEN
              ,DOP_PER_TID_CODIGO
              ,DOP_CPR_MNEMONICO
              ,DOP_OPC_CONSECUTIVO
              ,DOP_PARTICIPACION_ESTIMADA
              ,DOP_CONFIRMADO)
              VALUES ( R_CPC_FIX.CPC_PER_NUM_IDEN
              ,R_CPC_FIX.CPC_PER_TID_CODIGO
              ,CENTRO_P
              ,CONSECUTIVO_OPC
              ,100
              ,'N');

              OPEN C_NEG(R_CPO.CPO_PPO_CONSECUTIVO);
              FETCH C_NEG INTO R_NEG;
              WHILE C_NEG%FOUND LOOP

                OPEN C_NEG_C(R_CPO.CPO_PPO_CONSECUTIVO);
                FETCH C_NEG_C INTO R_NEG_C;
                IF C_NEG_C%FOUND THEN
                 V_CUENTA := R_NEG_C.CUENTA;
                END IF;
                CLOSE C_NEG_C;

                IF V_CUENTA >1 THEN

                  V_PORCENTAJE :=( R_NEG.NPO_COMISION_INTRAMESA  *  100)/R_CPC_FIX.CPC_UTILIDAD;

                ELSIF V_CUENTA = 1 THEN
                  V_PORCENTAJE := 100;
                END IF;

                --INSERTA DISTRIBUCION A CLIENTES
                INSERT INTO DISTRIBUCION_CLIENTES
                      ( DIC_OPC_CONSECUTIVO
                        ,DIC_PER_NUM_IDEN
                        ,DIC_PER_TID_CODIGO
                        ,DIC_PARTICIPACION_ESTIMADA
                        ,DIC_CCC_NUMERO_CUENTA)
                VALUES ( CONSECUTIVO_OPC
                        ,R_NEG.NPO_CLI_PER_NUM_IDEN --Se asocia al cliente
                        ,R_NEG.NPO_CLI_PER_TID_CODIGO
                        ,V_PORCENTAJE
                        ,R_CPC_FIX.CPC_CCC_NUMERO_CUENTA);

              FETCH C_NEG INTO R_NEG;
              END LOOP;
              CLOSE C_NEG;

            FETCH C_CPC_FIX INTO R_CPC_FIX;
            END LOOP;
            CLOSE C_CPC_FIX;

          ELSIF V_CUENTA <= 1  THEN

            OPEN C_CPC(R_CPO.CPO_CONSECUTIVO,'I');
            FETCH C_CPC INTO R_CPC;
            WHILE C_CPC%FOUND LOOP

            CONSECUTIVO_OPC := CONS_OPC;

              INSERT INTO OPERACIONES_DIARIAS
                (  OPC_CONSECUTIVO
                  ,OPC_FECHA
                  ,OPC_COMISION_ESTIMADA
                  ,OPC_PRO_MNEMONICO
                  ,OPC_CPO_CONSECUTIVO
                  ,OPC_CPC_CONSECUTIVO
                )
              VALUES ( CONSECUTIVO_OPC
                  ,TRUNC(R_CPO.CPO_FECHA)
                  ,R_CPC.CPC_UTILIDAD
                  ,'PP'
                  ,R_CPO.CPO_CONSECUTIVO
                  ,R_CPC.CPC_CONSECUTIVO
                  );
              INSERT INTO DISTRIBUCION_OPERACIONES(
                  DOP_PER_NUM_IDEN
                  ,DOP_PER_TID_CODIGO
                  ,DOP_CPR_MNEMONICO
                  ,DOP_OPC_CONSECUTIVO
                  ,DOP_PARTICIPACION_ESTIMADA
                  ,DOP_CONFIRMADO)
              VALUES ( R_CPC.CPC_PER_NUM_IDEN
                  ,R_CPC.CPC_PER_TID_CODIGO
                  ,CENTRO_P
                  ,CONSECUTIVO_OPC
                  ,100
                  ,'N');

              OPEN C_NEG(R_CPO.CPO_PPO_CONSECUTIVO);
              FETCH C_NEG INTO R_NEG;
              WHILE C_NEG%FOUND LOOP

                OPEN C_NEG_C(R_CPO.CPO_PPO_CONSECUTIVO);
                FETCH C_NEG_C INTO R_NEG_C;
                IF C_NEG_C%FOUND THEN
                 V_CUENTA := R_NEG_C.CUENTA;
                END IF;
                CLOSE C_NEG_C;

                IF V_CUENTA >1 THEN

                  V_PORCENTAJE :=( R_NEG.NPO_COMISION_INTRAMESA  *  100)/R_CPC.CPC_UTILIDAD;

                ELSIF V_CUENTA = 1 THEN
                  V_PORCENTAJE := 100;
                END IF;

                --INSERTA DISTRIBUCION A CLIENTES
                INSERT INTO DISTRIBUCION_CLIENTES
                      ( DIC_OPC_CONSECUTIVO
                      ,DIC_PER_NUM_IDEN
                      ,DIC_PER_TID_CODIGO
                      ,DIC_PARTICIPACION_ESTIMADA
                      ,DIC_CCC_NUMERO_CUENTA)
                VALUES ( CONSECUTIVO_OPC
                      ,R_NEG.NPO_CLI_PER_NUM_IDEN--'860079174'    -- CORREDORES ASOCIADOS
                      ,R_NEG.NPO_CLI_PER_TID_CODIGO
                      ,V_PORCENTAJE --R_NEG.NPO_PORCENTAJE_COMISION
                      ,DECODE(R_CPC.CPC_CCC_NUMERO_CUENTA, 0, 1, R_CPC.CPC_CCC_NUMERO_CUENTA ));

              FETCH C_NEG INTO R_NEG;
              END LOOP;
              CLOSE C_NEG;

            FETCH C_CPC INTO R_CPC;
            END LOOP;
            CLOSE C_CPC;
          END IF;

        ELSE

           OPEN C_CPC(R_CPO.CPO_CONSECUTIVO,'I');
           FETCH C_CPC INTO R_CPC;
           WHILE C_CPC%FOUND LOOP
              CONSECUTIVO_OPC := CONS_OPC;
              INSERT INTO OPERACIONES_DIARIAS
                    (  OPC_CONSECUTIVO
                      ,OPC_FECHA
                      ,OPC_COMISION_ESTIMADA
                      ,OPC_PRO_MNEMONICO
                      ,OPC_CPO_CONSECUTIVO
                      ,OPC_CPC_CONSECUTIVO
                    )
              VALUES ( CONSECUTIVO_OPC
                      ,TRUNC(R_CPO.CPO_FECHA)
                      ,R_CPC.CPC_UTILIDAD
                      ,'PP'
                      ,R_CPO.CPO_CONSECUTIVO
                      ,R_CPC.CPC_CONSECUTIVO);
              INSERT INTO DISTRIBUCION_OPERACIONES(
                       DOP_PER_NUM_IDEN
                      ,DOP_PER_TID_CODIGO
                      ,DOP_CPR_MNEMONICO
                      ,DOP_OPC_CONSECUTIVO
                      ,DOP_PARTICIPACION_ESTIMADA
                      ,DOP_CONFIRMADO)
              VALUES ( R_CPC.CPC_PER_NUM_IDEN
                      ,R_CPC.CPC_PER_TID_CODIGO
                      ,CENTRO_P
                      ,CONSECUTIVO_OPC
                      ,100
                      ,'N');

              IF R_CPC.CPC_CCC_CLI_PER_NUM_IDEN IS NOT NULL THEN
                 NID_INTRAMESA := R_CPC.CPC_CCC_CLI_PER_NUM_IDEN;
                 TID_INTRAMESA := R_CPC.CPC_CCC_CLI_PER_TID_CODIGO;
              ELSE
                 NID_INTRAMESA := R_CPC.CPC_PER_NUM_IDEN_CONTRAPARTE;
                 TID_INTRAMESA := R_CPC.CPC_PER_TID_CODIGO_CONTRAPARTE;
              END IF;
              --INSERTA DISTRIBUCION A CLIENTES
              INSERT INTO DISTRIBUCION_CLIENTES
                      ( DIC_OPC_CONSECUTIVO
                       ,DIC_PER_NUM_IDEN
                       ,DIC_PER_TID_CODIGO
                       ,DIC_PARTICIPACION_ESTIMADA
                       ,DIC_CCC_NUMERO_CUENTA)
              VALUES ( CONSECUTIVO_OPC
                      ,NID_INTRAMESA
                      ,TID_INTRAMESA
                      ,100
                      ,R_CPC.CPC_CCC_NUMERO_CUENTA);
              FETCH C_CPC INTO R_CPC;
           END LOOP;
           CLOSE C_CPC;
        END IF;
      END IF;
      IF R_CPO.CPO_TOTAL_UTILIDAD_COMERCIAL != 0 THEN
         -- INSERTA DETALLE PARA UTILIDAD COMERCIAL
         -- SE REGISTRA UNA OPERACION POR CADA OFERTA
         -- EL COMERCIAL ASIGNADO ES AL ASIGNADO EN EL NEGOCIO
         -- EL CLIENTE ASIGNADO ES EL DEL NEGOCIO
         -- INSERTA DETALLE DE LAS OFERTAS DE CLIENTES
         OPEN C_CPC(R_CPO.CPO_CONSECUTIVO,'C');
         FETCH C_CPC INTO R_CPC;
         WHILE C_CPC%FOUND LOOP
            CONSECUTIVO_OPC := CONS_OPC;
            INSERT INTO OPERACIONES_DIARIAS
                  (  OPC_CONSECUTIVO
                    ,OPC_FECHA
                    ,OPC_COMISION_ESTIMADA
                    ,OPC_PRO_MNEMONICO
                    ,OPC_CPO_CONSECUTIVO
                    ,OPC_CPC_CONSECUTIVO
                  )
            VALUES ( CONSECUTIVO_OPC
                    ,TRUNC(R_CPO.CPO_FECHA)
                    ,R_CPC.CPC_UTILIDAD
                    ,'PP'
                    ,R_CPO.CPO_CONSECUTIVO
                    ,R_CPC.CPC_CONSECUTIVO);
            OPEN C_PCP(R_CPC.CPC_PER_NUM_IDEN,R_CPC.CPC_PER_TID_CODIGO);
            FETCH C_PCP INTO CENTRO;
            IF C_PCP%NOTFOUND THEN
               /* SI NO ENCUENTRA CENTRO DE PRODUCCION PARA EL COMERCIAL SE COLOCA EL CENTRO DEL DUEżO DEL PORTAFOLIO */
               CENTRO := CENTRO_P;
            END IF;
            CLOSE C_PCP;
            INSERT INTO DISTRIBUCION_OPERACIONES(
                     DOP_PER_NUM_IDEN
                    ,DOP_PER_TID_CODIGO
                    ,DOP_CPR_MNEMONICO
                    ,DOP_OPC_CONSECUTIVO
                    ,DOP_PARTICIPACION_ESTIMADA
                    ,DOP_CONFIRMADO)
            VALUES ( R_CPC.CPC_PER_NUM_IDEN
                    ,R_CPC.CPC_PER_TID_CODIGO
                    ,CENTRO
                    ,CONSECUTIVO_OPC
                    ,100
                    ,'N');
            --INSERTA DISTRIBUCION A CLIENTES
            INSERT INTO DISTRIBUCION_CLIENTES
                    ( DIC_OPC_CONSECUTIVO
                     ,DIC_PER_NUM_IDEN
                     ,DIC_PER_TID_CODIGO
                     ,DIC_PARTICIPACION_ESTIMADA
                     ,DIC_CCC_NUMERO_CUENTA)
            VALUES ( CONSECUTIVO_OPC
                    ,R_CPC.CPC_CCC_CLI_PER_NUM_IDEN
                    ,R_CPC.CPC_CCC_CLI_PER_TID_CODIGO
                    ,100
                    ,R_CPC.CPC_CCC_NUMERO_CUENTA);
            FETCH C_CPC INTO R_CPC;
         END LOOP;
         CLOSE C_CPC;
      END IF;
      COMMIT;
      FETCH C_CPO INTO R_CPO;
   END LOOP;
   CLOSE C_CPO;
   COMMIT;

EXCEPTION
   WHEN OTHERS THEN
     P_MAIL.envio_mail_error('Proceso COMISIONES_SIMULTANEAS_PP','Error en procedimiento P_NEGOCIOS_POSICION.COMISIONES_SIMULTANEAS_PP: '||substr(sqlerrm,1,80));

END COMISIONES_SIMULTANEAS_PP;
/*************************************************/
PROCEDURE ANULACION_OFERTAS_SIN_ORDEN IS
   CURSOR C_OFERTAS IS
      SELECT OFD_CONSECUTIVO
            ,OFD_FECHA
      FROM   OFERTAS_DEMANDAS_POSICION
            ,NEGOCIOS_POSICION
      WHERE  OFD_FECHA >= TRUNC(SYSDATE)
      AND    OFD_ESTADO = 'COL'
      AND    OFD_NPO_CONSECUTIVO = NPO_CONSECUTIVO
      AND    OFD_OCO_CONSECUTIVO IS NULL;
   OFD1   C_OFERTAS%ROWTYPE;
   CURSOR C_CONSTANTES IS
      SELECT CON_VALOR
      FROM   CONSTANTES
      WHERE  CON_MNEMONICO = 'TRS';
   CON1   C_CONSTANTES%ROWTYPE;
   FECHA  DATE;
BEGIN
   OPEN C_OFERTAS;
   FETCH C_OFERTAS INTO OFD1;
   WHILE C_OFERTAS%FOUND LOOP
      OPEN C_CONSTANTES;
      FETCH C_CONSTANTES INTO CON1;
      CLOSE C_CONSTANTES;
      CON1.CON_VALOR := NVL(CON1.CON_VALOR,0);
      SELECT SYSDATE INTO FECHA FROM DUAL;
      IF FECHA - OFD1.OFD_FECHA >  CON1.CON_VALOR / 1440 THEN
         P_NEGOCIOS_POSICION.INSERTAR_CAMBIO_ESTADO
            (P_CEP_PER_NUM_IDEN       => '0'
            ,P_CEP_PER_TID_CODIGO     => 'CC'
            ,P_CEP_VALOR_ANTERIOR     => 'COL'
            ,P_CEP_VALOR_POSTERIOR    => 'ANU'
            ,P_CEP_DESCRIPCION        => 'AUT. NO COLOCO ORDEN DE COMPRA'
            ,P_CEP_OFD_CONSECUTIVO    => OFD1.OFD_CONSECUTIVO
            ,P_CEP_NPO_CONSECUTIVO    => NULL);
         UPDATE OFERTAS_DEMANDAS_POSICION
         SET    OFD_ESTADO = 'ANU'
         WHERE  OFD_CONSECUTIVO = OFD1.OFD_CONSECUTIVO;
         COMMIT;
      END IF;
      FETCH C_OFERTAS INTO OFD1;
   END LOOP;
   CLOSE C_OFERTAS;
END ANULACION_OFERTAS_SIN_ORDEN;

-- SORTIZ TRANSMISIONES
PROCEDURE PR_NUEVA_PREORDEN_FONDOS_YK
   (P_FONDO                       VARCHAR2
   ,P_OLD_PRF_CONSECUTIVO         NUMBER
   ,P_OLD_PRC_PRV_CONSECUTIVO     NUMBER
   ,P_TIPO                        VARCHAR2
   ,P_VALOR_NOMINAL               NUMBER
   ,P_VALOR_GIRO                  NUMBER
   ,P_VALOR_DOLARES               NUMBER
   ,P_PRF_CONSECUTIVO             IN OUT NUMBER)
   IS

   CURSOR C_CONSECUTIVO IS
      SELECT MAX(PRF_CONSECUTIVO) SIGUIENTE
      FROM   PREORDENES_FONDOS
      WHERE  PRF_FON_CODIGO = P_FONDO;
   CONSECUTIVO   NUMBER;

   -- DATOS DE LA PREORDEN ORIGINAL
   CURSOR C_PRF IS
      SELECT PRF_CONSECUTIVO
            ,PRF_FON_CODIGO
            ,PRF_EOF_CODIGO
            ,PRF_ENA_MNEMONICO
            ,PRF_FECHA_OPERACION
            ,PRF_TIPO_NEGOCIO
            ,PRF_TIPO
            ,PRF_TITULO_EXTERIOR
            ,PRF_VALOR_NOMINAL
            ,PRF_CANTIDAD
            ,PRF_NETEO
            ,PRF_FECHA_EMISION
            ,PRF_FECHA_VENCIMIENTO
            ,PRF_BMO_MNEMONICO
            ,PRF_PERIODICIDAD_TASA
            ,PRF_MODALIDAD_TASA
            ,PRF_BASE_CALCULO
            ,PRF_TASA_FACIAL
            ,PRF_AMORTIZABLE
            ,PRF_TRE_MNEMONICO
            ,PRF_CAPITALIZABLE
            ,PRF_FECHA_PRIMER_FLUJO
            ,PRF_TIPO_PAGO_FLUJO
            ,PRF_PUNTOS_ADICIONALES
            ,PRF_TFO_CODIGO
            ,PRF_FECHA_NEGOCIACION_YANKEE
            ,PRF_CBE_NUMERO_CUENTA
            ,PRF_CBE_BEX_MNEMONICO
            ,PRF_CODIGO_PERIODO
            ,PRF_PER_NUM_IDEN
            ,PRF_PER_TID_CODIGO
            ,PRF_VALOR_COMISION
            ,PRF_RETENCION_FUENTE
            ,PRF_VALOR_IVA_COMISION
            ,PRF_VALOR_EXTEMPO
      FROM   PREORDENES_FONDOS
      WHERE  PRF_FON_CODIGO = P_FONDO
      AND    PRF_CONSECUTIVO = P_OLD_PRF_CONSECUTIVO;
   PRF1 C_PRF%ROWTYPE;

BEGIN
   P_PRF_CONSECUTIVO := NULL;
   OPEN C_PRF;
   FETCH C_PRF INTO PRF1;
   IF C_PRF%FOUND THEN
      OPEN C_CONSECUTIVO;
      FETCH C_CONSECUTIVO INTO CONSECUTIVO;
      CLOSE C_CONSECUTIVO;

      CONSECUTIVO := NVL(CONSECUTIVO,0) + 1;

      INSERT INTO PREORDENES_FONDOS (
             PRF_CONSECUTIVO
            ,PRF_FON_CODIGO
            ,PRF_EOF_CODIGO
            ,PRF_ENA_MNEMONICO
            ,PRF_FECHA_OPERACION
            ,PRF_TIPO_NEGOCIO
            ,PRF_TIPO
            ,PRF_TITULO_EXTERIOR
            ,PRF_VALOR_NOMINAL
            ,PRF_CANTIDAD
            ,PRF_NETEO
            ,PRF_FECHA_EMISION
            ,PRF_FECHA_VENCIMIENTO
            ,PRF_BMO_MNEMONICO
            ,PRF_PERIODICIDAD_TASA
            ,PRF_MODALIDAD_TASA
            ,PRF_BASE_CALCULO
            ,PRF_TASA_FACIAL
            ,PRF_AMORTIZABLE
            ,PRF_TRE_MNEMONICO
            ,PRF_CAPITALIZABLE
            ,PRF_FECHA_PRIMER_FLUJO
            ,PRF_TIPO_PAGO_FLUJO
            ,PRF_PUNTOS_ADICIONALES
            ,PRF_TFO_CODIGO
            ,PRF_FECHA_NEGOCIACION_YANKEE
            ,PRF_CBE_NUMERO_CUENTA
            ,PRF_CBE_BEX_MNEMONICO
            ,PRF_CODIGO_PERIODO
            ,PRF_PER_NUM_IDEN
            ,PRF_PER_TID_CODIGO
            ,PRF_VALOR_COMISION
            ,PRF_RETENCION_FUENTE
            ,PRF_VALOR_IVA_COMISION
            ,PRF_VALOR_EXTEMPO
            )
      VALUES (
             CONSECUTIVO                      -- PRF_CONSECUTIVO
            ,PRF1.PRF_FON_CODIGO
            ,PRF1.PRF_EOF_CODIGO
            ,PRF1.PRF_ENA_MNEMONICO
            ,TRUNC(SYSDATE)                   -- PRF_FECHA_OPERACION
            ,P_TIPO                           -- PRF_TIPO_NEGOCIO
            ,PRF1.PRF_TIPO
            ,PRF1.PRF_TITULO_EXTERIOR
            ,P_VALOR_NOMINAL                  -- PRF1.PRF_VALOR_NOMINAL
            ,PRF1.PRF_CANTIDAD
            ,PRF1.PRF_NETEO
            ,PRF1.PRF_FECHA_EMISION
            ,PRF1.PRF_FECHA_VENCIMIENTO
            ,PRF1.PRF_BMO_MNEMONICO
            ,PRF1.PRF_PERIODICIDAD_TASA
            ,PRF1.PRF_MODALIDAD_TASA
            ,PRF1.PRF_BASE_CALCULO
            ,PRF1.PRF_TASA_FACIAL
            ,PRF1.PRF_AMORTIZABLE
            ,PRF1.PRF_TRE_MNEMONICO
            ,PRF1.PRF_CAPITALIZABLE
            ,PRF1.PRF_FECHA_PRIMER_FLUJO
            ,PRF1.PRF_TIPO_PAGO_FLUJO
            ,PRF1.PRF_PUNTOS_ADICIONALES
            ,PRF1.PRF_TFO_CODIGO
            ,PRF1.PRF_FECHA_NEGOCIACION_YANKEE
            ,PRF1.PRF_CBE_NUMERO_CUENTA
            ,PRF1.PRF_CBE_BEX_MNEMONICO
            ,PRF1.PRF_CODIGO_PERIODO
            ,PRF1.PRF_PER_NUM_IDEN
            ,PRF1.PRF_PER_TID_CODIGO
            ,PRF1.PRF_VALOR_COMISION
            ,PRF1.PRF_RETENCION_FUENTE
            ,PRF1.PRF_VALOR_IVA_COMISION
            ,PRF1.PRF_VALOR_EXTEMPO
            );
   END IF;
   CLOSE C_PRF;
   IF P_TIPO = 'C' THEN
      P_NEGOCIOS_POSICION.PR_NUEVA_PREORDEN_COMPRA_YK
                         (P_FONDO               => P_FONDO
                         ,P_OLD_PRF_CONSECUTIVO => P_OLD_PRF_CONSECUTIVO
                         ,P_OLD_PRC_CONSECUTIVO => P_OLD_PRC_PRV_CONSECUTIVO
                         ,P_VALOR_NOMINAL       => P_VALOR_NOMINAL
                         ,P_VALOR_GIRO          => P_VALOR_GIRO
                         ,P_VALOR_DOLARES       => P_VALOR_DOLARES
                         ,P_PRF_CONSECUTIVO     => CONSECUTIVO            -- CONSECUTIVO DE LA NUEVA PREORDEN CREADA
                         );

   ELSIF P_TIPO = 'V' THEN
      P_NEGOCIOS_POSICION.PR_NUEVA_PREORDEN_VENTA_YK
                         (P_FONDO               => P_FONDO
                         ,P_OLD_PRF_CONSECUTIVO => P_OLD_PRF_CONSECUTIVO
                         ,P_OLD_PRV_CONSECUTIVO => P_OLD_PRC_PRV_CONSECUTIVO
                         ,P_VALOR_NOMINAL       => P_VALOR_NOMINAL
                         ,P_VALOR_GIRO          => P_VALOR_GIRO
                         ,P_VALOR_DOLARES       => P_VALOR_DOLARES
                         ,P_PRF_CONSECUTIVO     => CONSECUTIVO            -- CONSECUTIVO DE LA NUEVA PREORDEN CREADA
                         );
   END IF;
END PR_NUEVA_PREORDEN_FONDOS_YK;

PROCEDURE PR_NUEVA_PREORDEN_COMPRA_YK
   (P_FONDO                       VARCHAR2
   ,P_OLD_PRF_CONSECUTIVO         NUMBER
   ,P_OLD_PRC_CONSECUTIVO         NUMBER
   ,P_VALOR_NOMINAL               NUMBER
   ,P_VALOR_GIRO                  NUMBER
   ,P_VALOR_DOLARES               NUMBER
   ,P_PRF_CONSECUTIVO             NUMBER)
   IS

   CURSOR C_SIGUIENTE_C IS
      SELECT MAX(PRC_CONSECUTIVO)
      FROM   PREORDENES_COMPRA
      WHERE  PRC_PRF_FON_CODIGO = P_FONDO
      AND    PRC_PRF_CONSECUTIVO = P_PRF_CONSECUTIVO;
   SIGUIENTE_C   NUMBER;

   -- TRAE LOS DATOS DE LA PRC ORIGINAL
   CURSOR C_PRC IS
      SELECT PRC_PRF_CONSECUTIVO
            ,PRC_PRF_FON_CODIGO
            ,PRC_CONSECUTIVO
            ,PRC_CLI_PER_NUM_IDEN
            ,PRC_CLI_PER_TID_CODIGO
            ,PRC_CONTACTO_VENDEDOR
            ,PRC_TELEFONO
            ,PRC_PER_NUM_IDEN
            ,PRC_PER_TID_CODIGO
            ,PRC_LTI_MNEMONICO
            ,PRC_COP_MNEMONICO
            ,PRC_MONTO
            ,PRC_VALOR_NOMINAL
            ,PRC_PORCENTAJE_CLIENTE
            ,PRC_REPO_ACTIVO
            ,PRC_COMPROMISO_VENTA_FUTURA
            ,PRC_PER_NUM_IDEN_ES_MODIFICADA
            ,PRC_PER_TID_CODIGO_ES_MODIFICA
            ,PRC_FECHA_MODIFICACION
            ,PRC_REGISTRA_CLIENTE
            ,PRC_AUTORIZACION
            ,PRC_FECHA_CUMPLIMIENTO
            ,PRC_NUMERO_OPERACION
            ,PRC_CNE_MNEMONICO
            ,PRC_MERCADO
            ,PRC_BOL_MNEMONICO
            ,PRC_BRO_MNEMONICO
            ,PRC_POSICION_ABIERTA
            ,PRC_POR_CORREDORES
            ,PRC_PER_NUM_IDEN_CONTRAPARTE
            ,PRC_PER_TID_CODIGO_CONTRAPARTE
            ,PRC_CCO_MNEMONICO
            ,PRC_DIRECCION_TITULOS
            ,PRC_PREGUNTAR_POR_TITULOS
            ,PRC_AGE_CODIGO
            ,PRC_TASA_NOMINAL_REPO
            ,PRC_FECHA_VENCIMIENTO_REPO
            ,PRC_FECHA_VENTA_FUTURA
            ,PRC_PRV_PRF_CONSECUTIVO
            ,PRC_PRV_CONSECUTIVO
            ,PRC_FPO_CONSECUTIVO
            ,PRC_MONTO_DOLARES
            ,PRC_MONTO_PESOS
            ,PRC_AUTORIZADO_POR
            ,PRC_FECHA_AUTORIZACION
            ,PRC_MOTIVO_AUTORIZACION
            ,PRC_TASA_FUTURA
            ,PRC_BASE_CALCULO_FUTURA
            ,PRC_VALOR_FUTURO
            ,PRC_OVE_CONSECUTIVO
            ,PRC_OVE_COC_CTO_MNEMONICO
            ,PRC_NUMERO_ACCIONES_REPO
            ,PRC_NPO_CONSECUTIVO
            ,PRC_OFD_CONSECUTIVO
            ,PRC_LIC_NUMERO_FRACCION
            ,PRC_LIC_TIPO_OPERACION
            ,PRC_VALOR_COMISION
            ,PRC_RETENCION_FUENTE
            ,PRC_VALOR_IVA_COMISION
            ,PRC_VALOR_EXTEMPO
            ,PRC_FECHA_CUM_CON
            ,PRC_VOLUMEN_FRACCION
            ,PRC_FRACCIONADA_UNIFICADA
            ,PRC_CRUZADA_CONVENIDA
      FROM   PREORDENES_COMPRA
      WHERE  PRC_PRF_CONSECUTIVO = P_OLD_PRF_CONSECUTIVO
      AND    PRC_PRF_FON_CODIGO = P_FONDO
      AND    PRC_CONSECUTIVO = P_OLD_PRC_CONSECUTIVO;
   PRC1 C_PRC%ROWTYPE;

   P_PRC_CONSECUTIVO NUMBER;

BEGIN
   P_PRC_CONSECUTIVO := NULL;
   OPEN C_PRC;
   FETCH C_PRC INTO PRC1;
   IF C_PRC%FOUND THEN
      OPEN C_SIGUIENTE_C;
      FETCH C_SIGUIENTE_C INTO SIGUIENTE_C;
      CLOSE C_SIGUIENTE_C;
      SIGUIENTE_C := NVL(SIGUIENTE_C,0) + 1;
      P_PRC_CONSECUTIVO := SIGUIENTE_C;

      INSERT INTO PREORDENES_COMPRA
            (PRC_PRF_CONSECUTIVO
            ,PRC_PRF_FON_CODIGO
            ,PRC_CONSECUTIVO
            ,PRC_CLI_PER_NUM_IDEN
            ,PRC_CLI_PER_TID_CODIGO
            ,PRC_CONTACTO_VENDEDOR
            ,PRC_TELEFONO
            ,PRC_PER_NUM_IDEN
            ,PRC_PER_TID_CODIGO
            ,PRC_LTI_MNEMONICO
            ,PRC_COP_MNEMONICO
            ,PRC_MONTO
            ,PRC_VALOR_NOMINAL
            ,PRC_PORCENTAJE_CLIENTE
            ,PRC_REPO_ACTIVO
            ,PRC_COMPROMISO_VENTA_FUTURA
            ,PRC_PER_NUM_IDEN_ES_MODIFICADA
            ,PRC_PER_TID_CODIGO_ES_MODIFICA
            ,PRC_FECHA_MODIFICACION
            ,PRC_REGISTRA_CLIENTE
            ,PRC_AUTORIZACION
            ,PRC_FECHA_CUMPLIMIENTO
            ,PRC_NUMERO_OPERACION
            ,PRC_CNE_MNEMONICO
            ,PRC_MERCADO
            ,PRC_BOL_MNEMONICO
            ,PRC_BRO_MNEMONICO
            ,PRC_POSICION_ABIERTA
            ,PRC_POR_CORREDORES
            ,PRC_PER_NUM_IDEN_CONTRAPARTE
            ,PRC_PER_TID_CODIGO_CONTRAPARTE
            ,PRC_CCO_MNEMONICO
            ,PRC_DIRECCION_TITULOS
            ,PRC_PREGUNTAR_POR_TITULOS
            ,PRC_AGE_CODIGO
            ,PRC_TASA_NOMINAL_REPO
            ,PRC_FECHA_VENCIMIENTO_REPO
            ,PRC_FECHA_VENTA_FUTURA
            ,PRC_PRV_PRF_CONSECUTIVO
            ,PRC_PRV_CONSECUTIVO
            ,PRC_FPO_CONSECUTIVO
            ,PRC_MONTO_DOLARES
            ,PRC_MONTO_PESOS
            ,PRC_AUTORIZADO_POR
            ,PRC_FECHA_AUTORIZACION
            ,PRC_MOTIVO_AUTORIZACION
            ,PRC_TASA_FUTURA
            ,PRC_BASE_CALCULO_FUTURA
            ,PRC_VALOR_FUTURO
            ,PRC_OVE_CONSECUTIVO
            ,PRC_OVE_COC_CTO_MNEMONICO
            ,PRC_NUMERO_ACCIONES_REPO
            ,PRC_NPO_CONSECUTIVO
            ,PRC_OFD_CONSECUTIVO
            ,PRC_LIC_NUMERO_FRACCION
            ,PRC_LIC_TIPO_OPERACION
            ,PRC_VALOR_COMISION
            ,PRC_RETENCION_FUENTE
            ,PRC_VALOR_IVA_COMISION
            ,PRC_VALOR_EXTEMPO
            ,PRC_FECHA_CUM_CON
            ,PRC_VOLUMEN_FRACCION
            ,PRC_FRACCIONADA_UNIFICADA
            ,PRC_CRUZADA_CONVENIDA)
      VALUES (
             P_PRF_CONSECUTIVO        -- PRC_PRF_CONSECUTIVO
            ,PRC1.PRC_PRF_FON_CODIGO
            ,SIGUIENTE_C          -- PRC_CONSECUTIVO
            ,PRC1.PRC_CLI_PER_NUM_IDEN
            ,PRC1.PRC_CLI_PER_TID_CODIGO
            ,PRC1.PRC_CONTACTO_VENDEDOR
            ,PRC1.PRC_TELEFONO
            ,PRC1.PRC_PER_NUM_IDEN
            ,PRC1.PRC_PER_TID_CODIGO
            ,PRC1.PRC_LTI_MNEMONICO
            ,PRC1.PRC_COP_MNEMONICO
            ,P_VALOR_GIRO                     -- PRC_MONTO
            ,P_VALOR_NOMINAL                  -- PRC_VALOR_NOMINAL
            ,PRC1.PRC_PORCENTAJE_CLIENTE
            ,PRC1.PRC_REPO_ACTIVO
            ,PRC1.PRC_COMPROMISO_VENTA_FUTURA
            ,PRC1.PRC_PER_NUM_IDEN_ES_MODIFICADA
            ,PRC1.PRC_PER_TID_CODIGO_ES_MODIFICA
            ,PRC1.PRC_FECHA_MODIFICACION
            ,PRC1.PRC_REGISTRA_CLIENTE
            ,PRC1.PRC_AUTORIZACION
            ,PRC1.PRC_FECHA_CUMPLIMIENTO
            ,PRC1.PRC_NUMERO_OPERACION
            ,PRC1.PRC_CNE_MNEMONICO
            ,PRC1.PRC_MERCADO
            ,PRC1.PRC_BOL_MNEMONICO
            ,PRC1.PRC_BRO_MNEMONICO
            ,PRC1.PRC_POSICION_ABIERTA
            ,PRC1.PRC_POR_CORREDORES
            ,PRC1.PRC_PER_NUM_IDEN_CONTRAPARTE
            ,PRC1.PRC_PER_TID_CODIGO_CONTRAPARTE
            ,PRC1.PRC_CCO_MNEMONICO
            ,PRC1.PRC_DIRECCION_TITULOS
            ,PRC1.PRC_PREGUNTAR_POR_TITULOS
            ,PRC1.PRC_AGE_CODIGO
            ,PRC1.PRC_TASA_NOMINAL_REPO
            ,PRC1.PRC_FECHA_VENCIMIENTO_REPO
            ,PRC1.PRC_FECHA_VENTA_FUTURA
            ,PRC1.PRC_PRV_PRF_CONSECUTIVO
            ,PRC1.PRC_PRV_CONSECUTIVO
            ,PRC1.PRC_FPO_CONSECUTIVO
            ,P_VALOR_DOLARES                    -- PRC_MONTO_DOLARES
            ,PRC1.PRC_MONTO_PESOS
            ,PRC1.PRC_AUTORIZADO_POR
            ,PRC1.PRC_FECHA_AUTORIZACION
            ,PRC1.PRC_MOTIVO_AUTORIZACION
            ,PRC1.PRC_TASA_FUTURA
            ,PRC1.PRC_BASE_CALCULO_FUTURA
            ,PRC1.PRC_VALOR_FUTURO
            ,PRC1.PRC_OVE_CONSECUTIVO
            ,PRC1.PRC_OVE_COC_CTO_MNEMONICO
            ,PRC1.PRC_NUMERO_ACCIONES_REPO
            ,PRC1.PRC_NPO_CONSECUTIVO
            ,PRC1.PRC_OFD_CONSECUTIVO
            ,PRC1.PRC_LIC_NUMERO_FRACCION
            ,PRC1.PRC_LIC_TIPO_OPERACION
            ,PRC1.PRC_VALOR_COMISION
            ,PRC1.PRC_RETENCION_FUENTE
            ,PRC1.PRC_VALOR_IVA_COMISION
            ,PRC1.PRC_VALOR_EXTEMPO
            ,PRC1.PRC_FECHA_CUM_CON
            ,P_VALOR_GIRO                     -- PRC_VOLUMEN_FRACCION
            ,NULL
            ,PRC1.PRC_CRUZADA_CONVENIDA);

      -- REVISAR QUE VALORES DEBE PASARLE PARA LA CREACION  DE LOS TITULOS
      P_NEGOCIOS_POSICION.PR_CREAR_DERECHO_COMPRA_YK
                         (P_FONDO               => P_FONDO
                         ,P_OLD_PRF_CONSECUTIVO => P_OLD_PRF_CONSECUTIVO
                         ,P_OLD_PRC_CONSECUTIVO => P_OLD_PRC_CONSECUTIVO
                         ,P_FECHA_CUMPLIMIENTO  => PRC1.PRC_FECHA_CUMPLIMIENTO
                         ,P_MONTO               => P_VALOR_GIRO
                         ,P_BOLSA               => PRC1.PRC_BOL_MNEMONICO
                         ,P_PRC_PRF_CONSECUTIVO => P_PRF_CONSECUTIVO
                         ,P_PRC_CONSECUTIVO     => SIGUIENTE_C
                         ,P_VALOR_NOMINAL       => P_VALOR_NOMINAL
                         ,P_LTI_MNEMONICO       => PRC1.PRC_LTI_MNEMONICO);


      P_NEGOCIOS_POSICION.PR_CREAR_OBLIGACION_COMPRA_YK
                         (P_FONDO               => P_FONDO
                         ,P_OLD_PRF_CONSECUTIVO => P_OLD_PRF_CONSECUTIVO
                         ,P_OLD_PRC_CONSECUTIVO => P_OLD_PRC_CONSECUTIVO
                         ,P_FECHA_CUMPLIMIENTO  => PRC1.PRC_FECHA_CUMPLIMIENTO
                         ,P_MONTO               => P_VALOR_GIRO
                         ,P_BOLSA               => PRC1.PRC_BOL_MNEMONICO
                         ,P_PRC_PRF_CONSECUTIVO => P_PRF_CONSECUTIVO
                         ,P_PRC_CONSECUTIVO     => SIGUIENTE_C
                         ,P_LTI_MNEMONICO       => PRC1.PRC_LTI_MNEMONICO);

   END IF;
   CLOSE C_PRC;
END PR_NUEVA_PREORDEN_COMPRA_YK;

PROCEDURE PR_NUEVA_PREORDEN_VENTA_YK
   (P_FONDO                       VARCHAR2
   ,P_OLD_PRF_CONSECUTIVO         NUMBER
   ,P_OLD_PRV_CONSECUTIVO         NUMBER
   ,P_VALOR_NOMINAL               NUMBER
   ,P_VALOR_GIRO                  NUMBER
   ,P_VALOR_DOLARES               NUMBER
   ,P_PRF_CONSECUTIVO             NUMBER)
   IS

   CURSOR C_SIGUIENTE_V IS
      SELECT MAX(PRV_CONSECUTIVO)
      FROM   PREORDENES_VENTA
      WHERE  PRV_PRF_FON_CODIGO = P_FONDO
      AND    PRV_PRF_CONSECUTIVO = P_PRF_CONSECUTIVO;
   SIGUIENTE_V   NUMBER;

   CURSOR C_PRV IS
      SELECT PRV_PRF_CONSECUTIVO
            ,PRV_PRF_FON_CODIGO
            ,PRV_CONSECUTIVO
            ,PRV_CLI_PER_NUM_IDEN
            ,PRV_CLI_PER_TID_CODIGO
            ,PRV_CONTACTO_COMPRADOR
            ,PRV_TELEFONO_CONTACTO
            ,PRV_PER_NUM_IDEN
            ,PRV_PER_TID_CODIGO
            ,PRV_MONTO
            ,PRV_VALOR_NOMINAL
            ,PRV_LTI_MNEMONICO
            ,PRV_COP_MNEMONICO
            ,PRV_PORCENTAJE_CLIENTE
            ,PRV_ENVIA_RECOGE_DOCUMENTOS
            ,PRV_ENVIA_FAX
            ,PRV_REPO_PASIVO
            ,PRV_COMPROMISO_COMPRA_FUTURA
            ,PRV_FECHA_MODIFICACION
            ,PRV_PER_NUM_IDEN_ES_MODIFICADA
            ,PRV_PER_TID_CODIGO_ES_MODIFICA
            ,PRV_REGISTRA_CLIENTE
            ,PRV_AUTORIZACION
            ,PRV_FECHA_CUMPLIMIENTO
            ,PRV_BOL_MNEMONICO
            ,PRV_BRO_MNEMONICO
            ,PRV_NUMERO_OPERACION
            ,PRV_MERCADO
            ,PRV_POSICION_ABIERTA
            ,PRV_POR_CORREDORES
            ,PRV_PER_NUM_IDEN_CONTRAPARTE
            ,PRV_PER_TID_CODIGO_CONTRAPARTE
            ,PRV_PRC_PRF_CONSECUTIVO
            ,PRV_PRC_CONSECUTIVO
            ,PRV_CCO_MNEMONICO
            ,PRV_TFO_CODIGO
            ,PRV_TASA_NOMINAL_REPO
            ,PRV_FECHA_VENCIMIENTO_REPO
            ,PRV_DIRECCION_ENVIO_TITULOS
            ,PRV_PREGUNTAR_POR_TITULOS
            ,PRV_AGE_CODIGO
            ,PRV_DIRECCION_ENVIO_DOCUMENTOS
            ,PRV_PREGUNTAR_POR_DOCUMENTOS
            ,PRV_AGE_CODIGO_DOCUMENTOS
            ,PRV_FAX
            ,PRV_OTRAS_INSTRUCCIONES
            ,PRV_FECHA_COMPRA_FUTURA
            ,PRV_FPO_CONSECUTIVO
            ,PRV_MONTO_DOLARES
            ,PRV_MONTO_PESOS
            ,PRV_AUTORIZADO_POR
            ,PRV_FECHA_AUTORIZACION
            ,PRV_MOTIVO_AUTORIZACION
            ,PRV_TASA_FUTURA
            ,PRV_BASE_CALCULO_FUTURA
            ,PRV_VALOR_FUTURO
            ,PRV_CNE_MNEMONICO
            ,PRV_OCO_CONSECUTIVO
            ,PRV_OCO_COC_CTO_MNEMONICO
            ,PRV_ARBITRAJE
            ,PRV_NUMERO_ACCIONES_REPO
            ,PRV_NPO_CONSECUTIVO
            ,PRV_OFD_CONSECUTIVO
            ,PRV_LIC_NUMERO_FRACCION
            ,PRV_LIC_TIPO_OPERACION
            ,PRV_VALOR_COMISION
            ,PRV_RETENCION_FUENTE
            ,PRV_VALOR_IVA_COMISION
            ,PRV_VALOR_EXTEMPO
            ,PRV_FECHA_CUM_CON
            ,PRV_VOLUMEN_FRACCION
            ,PRV_DESCUENTO_TRIBUTARIO
            ,PRV_FRACCIONADA_UNIFICADA
            ,PRV_CRUZADA_CONVENIDA
      FROM   PREORDENES_VENTA
      WHERE  PRV_PRF_FON_CODIGO = P_FONDO
      AND    PRV_PRF_CONSECUTIVO = P_OLD_PRF_CONSECUTIVO
      AND    PRV_CONSECUTIVO = P_OLD_PRV_CONSECUTIVO;
   PRV1 C_PRV%ROWTYPE;

   P_PRV_CONSECUTIVO NUMBER;

BEGIN
   P_PRV_CONSECUTIVO := NULL;
   OPEN C_PRV;
   FETCH C_PRV INTO PRV1;
   IF C_PRV%FOUND THEN
      OPEN C_SIGUIENTE_V;
      FETCH C_SIGUIENTE_V INTO SIGUIENTE_V;
      CLOSE C_SIGUIENTE_V;
      SIGUIENTE_V := NVL(SIGUIENTE_V,0) + 1;
      P_PRV_CONSECUTIVO := SIGUIENTE_V;

      INSERT INTO PREORDENES_VENTA
            (PRV_PRF_CONSECUTIVO
            ,PRV_PRF_FON_CODIGO
            ,PRV_CONSECUTIVO
            ,PRV_CLI_PER_NUM_IDEN
            ,PRV_CLI_PER_TID_CODIGO
            ,PRV_CONTACTO_COMPRADOR
            ,PRV_TELEFONO_CONTACTO
            ,PRV_PER_NUM_IDEN
            ,PRV_PER_TID_CODIGO
            ,PRV_MONTO
            ,PRV_VALOR_NOMINAL
            ,PRV_LTI_MNEMONICO
            ,PRV_COP_MNEMONICO
            ,PRV_PORCENTAJE_CLIENTE
            ,PRV_ENVIA_RECOGE_DOCUMENTOS
            ,PRV_ENVIA_FAX
            ,PRV_REPO_PASIVO
            ,PRV_COMPROMISO_COMPRA_FUTURA
            ,PRV_FECHA_MODIFICACION
            ,PRV_PER_NUM_IDEN_ES_MODIFICADA
            ,PRV_PER_TID_CODIGO_ES_MODIFICA
            ,PRV_REGISTRA_CLIENTE
            ,PRV_AUTORIZACION
            ,PRV_FECHA_CUMPLIMIENTO
            ,PRV_BOL_MNEMONICO
            ,PRV_BRO_MNEMONICO
            ,PRV_NUMERO_OPERACION
            ,PRV_MERCADO
            ,PRV_POSICION_ABIERTA
            ,PRV_POR_CORREDORES
            ,PRV_PER_NUM_IDEN_CONTRAPARTE
            ,PRV_PER_TID_CODIGO_CONTRAPARTE
            ,PRV_PRC_PRF_CONSECUTIVO
            ,PRV_PRC_CONSECUTIVO
            ,PRV_CCO_MNEMONICO
            ,PRV_TFO_CODIGO
            ,PRV_TASA_NOMINAL_REPO
            ,PRV_FECHA_VENCIMIENTO_REPO
            ,PRV_DIRECCION_ENVIO_TITULOS
            ,PRV_PREGUNTAR_POR_TITULOS
            ,PRV_AGE_CODIGO
            ,PRV_DIRECCION_ENVIO_DOCUMENTOS
            ,PRV_PREGUNTAR_POR_DOCUMENTOS
            ,PRV_AGE_CODIGO_DOCUMENTOS
            ,PRV_FAX
            ,PRV_OTRAS_INSTRUCCIONES
            ,PRV_FECHA_COMPRA_FUTURA
            ,PRV_FPO_CONSECUTIVO
            ,PRV_MONTO_DOLARES
            ,PRV_MONTO_PESOS
            ,PRV_AUTORIZADO_POR
            ,PRV_FECHA_AUTORIZACION
            ,PRV_MOTIVO_AUTORIZACION
            ,PRV_TASA_FUTURA
            ,PRV_BASE_CALCULO_FUTURA
            ,PRV_VALOR_FUTURO
            ,PRV_CNE_MNEMONICO
            ,PRV_OCO_CONSECUTIVO
            ,PRV_OCO_COC_CTO_MNEMONICO
            ,PRV_ARBITRAJE
            ,PRV_NUMERO_ACCIONES_REPO
            ,PRV_NPO_CONSECUTIVO
            ,PRV_OFD_CONSECUTIVO
            ,PRV_LIC_NUMERO_FRACCION
            ,PRV_LIC_TIPO_OPERACION
            ,PRV_VALOR_COMISION
            ,PRV_RETENCION_FUENTE
            ,PRV_VALOR_IVA_COMISION
            ,PRV_VALOR_EXTEMPO
            ,PRV_FECHA_CUM_CON
            ,PRV_VOLUMEN_FRACCION
            ,PRV_DESCUENTO_TRIBUTARIO
            ,PRV_FRACCIONADA_UNIFICADA
            ,PRV_CRUZADA_CONVENIDA)
      VALUES   (
             P_PRF_CONSECUTIVO          -- PRV_PRF_CONSECUTIVO
            ,PRV1.PRV_PRF_FON_CODIGO
            ,SIGUIENTE_V                        -- PRV_CONSECUTIVO
            ,PRV1.PRV_CLI_PER_NUM_IDEN
            ,PRV1.PRV_CLI_PER_TID_CODIGO
            ,PRV1.PRV_CONTACTO_COMPRADOR
            ,PRV1.PRV_TELEFONO_CONTACTO
            ,PRV1.PRV_PER_NUM_IDEN
            ,PRV1.PRV_PER_TID_CODIGO
            ,P_VALOR_GIRO                       -- PRV_MONTO
            ,P_VALOR_NOMINAL                    -- PRV_VALOR_NOMINAL
            ,PRV1.PRV_LTI_MNEMONICO
            ,PRV1.PRV_COP_MNEMONICO
            ,PRV1.PRV_PORCENTAJE_CLIENTE
            ,PRV1.PRV_ENVIA_RECOGE_DOCUMENTOS
            ,PRV1.PRV_ENVIA_FAX
            ,PRV1.PRV_REPO_PASIVO
            ,PRV1.PRV_COMPROMISO_COMPRA_FUTURA
            ,PRV1.PRV_FECHA_MODIFICACION
            ,PRV1.PRV_PER_NUM_IDEN_ES_MODIFICADA
            ,PRV1.PRV_PER_TID_CODIGO_ES_MODIFICA
            ,PRV1.PRV_REGISTRA_CLIENTE
            ,PRV1.PRV_AUTORIZACION
            ,PRV1.PRV_FECHA_CUMPLIMIENTO
            ,PRV1.PRV_BOL_MNEMONICO
            ,PRV1.PRV_BRO_MNEMONICO
            ,PRV1.PRV_NUMERO_OPERACION
            ,PRV1.PRV_MERCADO
            ,PRV1.PRV_POSICION_ABIERTA
            ,PRV1.PRV_POR_CORREDORES
            ,PRV1.PRV_PER_NUM_IDEN_CONTRAPARTE
            ,PRV1.PRV_PER_TID_CODIGO_CONTRAPARTE
            ,PRV1.PRV_PRC_PRF_CONSECUTIVO
            ,PRV1.PRV_PRC_CONSECUTIVO
            ,PRV1.PRV_CCO_MNEMONICO
            ,PRV1.PRV_TFO_CODIGO
            ,PRV1.PRV_TASA_NOMINAL_REPO
            ,PRV1.PRV_FECHA_VENCIMIENTO_REPO
            ,PRV1.PRV_DIRECCION_ENVIO_TITULOS
            ,PRV1.PRV_PREGUNTAR_POR_TITULOS
            ,PRV1.PRV_AGE_CODIGO
            ,PRV1.PRV_DIRECCION_ENVIO_DOCUMENTOS
            ,PRV1.PRV_PREGUNTAR_POR_DOCUMENTOS
            ,PRV1.PRV_AGE_CODIGO_DOCUMENTOS
            ,PRV1.PRV_FAX
            ,PRV1.PRV_OTRAS_INSTRUCCIONES
            ,PRV1.PRV_FECHA_COMPRA_FUTURA
            ,PRV1.PRV_FPO_CONSECUTIVO
            ,P_VALOR_DOLARES                  -- PRV_MONTO_DOLARES
            ,PRV1.PRV_MONTO_PESOS
            ,PRV1.PRV_AUTORIZADO_POR
            ,PRV1.PRV_FECHA_AUTORIZACION
            ,PRV1.PRV_MOTIVO_AUTORIZACION
            ,PRV1.PRV_TASA_FUTURA
            ,PRV1.PRV_BASE_CALCULO_FUTURA
            ,PRV1.PRV_VALOR_FUTURO
            ,PRV1.PRV_CNE_MNEMONICO
            ,PRV1.PRV_OCO_CONSECUTIVO
            ,PRV1.PRV_OCO_COC_CTO_MNEMONICO
            ,PRV1.PRV_ARBITRAJE
            ,PRV1.PRV_NUMERO_ACCIONES_REPO
            ,PRV1.PRV_NPO_CONSECUTIVO
            ,PRV1.PRV_OFD_CONSECUTIVO
            ,PRV1.PRV_LIC_NUMERO_FRACCION
            ,PRV1.PRV_LIC_TIPO_OPERACION
            ,PRV1.PRV_VALOR_COMISION
            ,PRV1.PRV_RETENCION_FUENTE
            ,PRV1.PRV_VALOR_IVA_COMISION
            ,PRV1.PRV_VALOR_EXTEMPO
            ,PRV1.PRV_FECHA_CUM_CON
            ,P_VALOR_GIRO                       -- PRV_VOLUMEN_FRACCION
            ,PRV1.PRV_DESCUENTO_TRIBUTARIO
            ,NULL
            ,PRV1.PRV_CRUZADA_CONVENIDA);

      -- REVISAR QUE VALORES DEBE PASARLE PARA LA CREACION  DE LOS TITULOS
      P_NEGOCIOS_POSICION.PR_CREAR_OBLIGACION_VENTA_YK
                         (P_FONDO               => P_FONDO
                         ,P_OLD_PRF_CONSECUTIVO => P_OLD_PRF_CONSECUTIVO
                         ,P_OLD_PRV_CONSECUTIVO => P_OLD_PRV_CONSECUTIVO
                         ,P_FECHA_CUMPLIMIENTO  => PRV1.PRV_FECHA_CUMPLIMIENTO
                         ,P_MONTO               => P_VALOR_GIRO
                         ,P_BOLSA               => PRV1.PRV_BOL_MNEMONICO
                         ,P_PRV_PRF_CONSECUTIVO => P_PRF_CONSECUTIVO
                         ,P_PRV_CONSECUTIVO     => SIGUIENTE_V
                         ,P_VALOR_NOMINAL       => P_VALOR_NOMINAL
                         ,P_LTI_MNEMONICO       => PRV1.PRV_LTI_MNEMONICO);

      P_NEGOCIOS_POSICION.PR_CREAR_DERECHO_VENTA_YK
                         (P_FONDO               => P_FONDO
                         ,P_OLD_PRF_CONSECUTIVO => P_OLD_PRF_CONSECUTIVO
                         ,P_OLD_PRV_CONSECUTIVO => P_OLD_PRV_CONSECUTIVO
                         ,P_FECHA_CUMPLIMIENTO  => PRV1.PRV_FECHA_CUMPLIMIENTO
                         ,P_MONTO               => P_VALOR_GIRO
                         ,P_BOLSA               => PRV1.PRV_BOL_MNEMONICO
                         ,P_PRV_PRF_CONSECUTIVO => P_PRF_CONSECUTIVO
                         ,P_PRV_CONSECUTIVO     => SIGUIENTE_V
                         ,P_PRV_LTI_MNEMONICO   => PRV1.PRV_LTI_MNEMONICO);

   END IF;
   CLOSE C_PRV;
END PR_NUEVA_PREORDEN_VENTA_YK;

PROCEDURE PR_CREAR_DERECHO_COMPRA_YK
   (P_FONDO               VARCHAR2
   ,P_OLD_PRF_CONSECUTIVO NUMBER
   ,P_OLD_PRC_CONSECUTIVO NUMBER
   ,P_FECHA_CUMPLIMIENTO  DATE
   ,P_MONTO               NUMBER
   ,P_BOLSA               VARCHAR2
   ,P_PRC_PRF_CONSECUTIVO NUMBER
   ,P_PRC_CONSECUTIVO     NUMBER
   ,P_VALOR_NOMINAL       NUMBER
   ,P_LTI_MNEMONICO       VARCHAR2) IS

   -- PROCESO PARA CREAR EL DERECHO DE COMPRA DESPUES DE FRACCIONAR UN NEGOCIO YANKEE
   CURSOR C_FONDO IS
      SELECT FON_TIPO
            ,FON_BMO_MNEMONICO
      FROM   FONDOS
      WHERE  FON_CODIGO = P_FONDO;
   FON1   C_FONDO%ROWTYPE;

   CURSOR C_CODIGO IS
      SELECT NVL(MAX(TFO_CODIGO) + 1,1)
      FROM   TITULOS_FONDOS
      WHERE  TFO_FON_CODIGO = P_FONDO;
   SIGUIENTE     NUMBER;

   -- DATOS DEL NUEVO NEGOCIO CREADO
   CURSOR C_PRF IS
      SELECT PRF_FON_CODIGO
            ,PRF_ENA_MNEMONICO
            ,PRF_BMO_MNEMONICO
            ,PRF_TRE_MNEMONICO
            ,PRF_FECHA_EMISION
            ,PRF_FECHA_VENCIMIENTO
            ,PRF_PERIODICIDAD_TASA
            ,PRF_BASE_CALCULO
            ,PRF_MODALIDAD_TASA
            ,PRF_PUNTOS_ADICIONALES
            ,PRF_TASA_FACIAL
            ,PRF_AMORTIZABLE
            ,PRF_TIPO_PAGO_FLUJO
            ,PRF_FECHA_PRIMER_FLUJO
            ,PRF_CAPITALIZABLE
            ,PRF_CODIGO_PERIODO
      FROM   PREORDENES_FONDOS
      WHERE  PRF_FON_CODIGO = P_FONDO
      AND    PRF_CONSECUTIVO = P_PRC_PRF_CONSECUTIVO;
   PRF1 C_PRF%ROWTYPE;

   -- BUSCA EL TFO DERECHO DE COMPRA DE LA PREORDEN DE COMPRA ANTERIOR
   CURSOR C_DCO_OLD IS
      SELECT TFO_CODIGO, TFO_FUG_ISI_MNEMONICO, TFO_FUG_MNEMONICO, TFO_NUMERO_EMISION_DCV,
             TFO_VALOR_NOMINAL, TFO_VALOR_OPERACION
      FROM   TITULOS_FONDOS
      WHERE  TFO_FON_CODIGO = P_FONDO
      AND    TFO_PRC_PRF_CONSECUTIVO = P_OLD_PRF_CONSECUTIVO
      AND    TFO_PRC_CONSECUTIVO = P_OLD_PRC_CONSECUTIVO
      AND    TFO_BMO_MNEMONICO = 'DOLAR'
      AND    NVL(TFO_DERIVADO,'N') = 'S';
   TFODCO C_DCO_OLD%ROWTYPE;

   CURSOR C_MRF_OLD IS
      SELECT MRF_FECHA, MRF_TFO_FON_CODIGO, MRF_TFO_CODIGO,
             MRF_TMT_MNEMONICO, MRF_VALOR_TITULO_TM,
             MRF_VALOR_TITULO_TC,MRF_VALORIZACION_TM,
             MRF_VALORIZACION_TC, MRF_MPE, MRF_AAI, MRF_TAI,
             MRF_TIR360_M, MRF_TIR360_C, MRF_TIR365_M,
             MRF_TIR365_C, MRF_FECHA_VALORIZACION, MRF_TASA_DESCUENTO
             MRF_PRECIO, MRF_TASA, MRF_MARGEN, MRF_INDICE,
             MRF_INDICADOR, MRF_VIGENCIA
      FROM   MVTOS_RENTA_FIJA
      WHERE  MRF_TFO_FON_CODIGO = P_FONDO
      AND    MRF_TFO_CODIGO = TFODCO.TFO_CODIGO
      ORDER BY MRF_FECHA DESC;
   MRF_OLD C_MRF_OLD%ROWTYPE;

   MRF1   MVTOS_RENTA_FIJA%ROWTYPE;
   TASA_BASICA   VARCHAR2(10);
   VALOR_TB      NUMBER;
   VALOR_TR      NUMBER;
   FECSYS        DATE;
   COTIZACION    NUMBER;
   VALIDA        BOOLEAN;
   VALOR_TIT_TM  NUMBER;
   ISIN          VARCHAR2(12);
   FUNGIBLE      NUMBER(10);
   EMISION       VARCHAR2(20);

BEGIN
   SELECT SYSDATE INTO FECSYS FROM SYS.DUAL;

   OPEN C_FONDO;
   FETCH C_FONDO INTO FON1;
   CLOSE C_FONDO;

   OPEN C_CODIGO;
   FETCH C_CODIGO INTO SIGUIENTE;
   CLOSE C_CODIGO;

   OPEN C_PRF;
   FETCH C_PRF INTO PRF1;
   CLOSE C_PRF;

   INSERT INTO TITULOS_FONDOS
      (TFO_FON_CODIGO
      ,TFO_CODIGO
      ,TFO_TYPE
      ,TFO_ENA_MNEMONICO
      ,TFO_ETI_CODIGO
      ,TFO_LTI_MNEMONICO
      ,TFO_FECHA_OPERACION
      ,TFO_VALOR_OPERACION
      ,TFO_FECHA_CUMPLIMIENTO
      ,TFO_COMISION_BOLSA
      ,TFO_BMO_MNEMONICO
      ,TFO_TRE_MNEMONICO
      ,TFO_FECHA_EMISION
      ,TFO_FECHA_VENCIMIENTO
      ,TFO_VALOR_NOMINAL
      ,TFO_PERIODICIDAD_TASA
      ,TFO_BASE_CALCULO
      ,TFO_MODALIDAD_TASA
      ,TFO_MERCADO_COMPRA
      ,TFO_VENCIDO_ESPECIAL
      ,TFO_VALOR_UNITARIO
      ,TFO_CANTIDAD
      ,TFO_PUNTOS_ADICIONALES
      ,TFO_TASA_FACIAL
      ,TFO_AMORTIZABLE
      ,TFO_TIPO_PAGO_FLUJO
      ,TFO_FECHA_PRIMER_FLUJO
      ,TFO_TASA_MRC_CONGELADA
      ,TFO_FECHA_CMPLMNTO_ESPECIAL
      ,TFO_CAPITALIZABLE
      ,TFO_FONDEO
      ,TFO_FECHA_VENTA_PLAZO
      ,TFO_CRUZADA_CONVENIDA
      ,TFO_BOL_MNEMONICO
      ,TFO_PRC_PRF_CONSECUTIVO
      ,TFO_PRC_CONSECUTIVO
      ,TFO_VALOR_TITULO_TM
      ,TFO_FECHA_VALORIZACION
      ,TFO_TASA_DESCUENTO
      ,TFO_LIQ_NUMERO_OPERACION_ES_VE
      ,TFO_LIQ_NUMERO_FRACCION_ES_VEN
      ,TFO_LIQ_TIPO_OPERACION_ES_VEND
      ,TFO_CVS_CONSECUTIVO_ES_VENDIDO
      ,TFO_DERIVADO
      ,TFO_CODIGO_PERIODO)
   VALUES
      (P_FONDO                -- TFO_FON_CODIGO
      ,SIGUIENTE              -- TFO_CODIGO
      ,'TRF'                -- TFO_TYPE
      ,PRF1.PRF_ENA_MNEMONICO       -- TFO_ENA_MNEMONICO
      ,'VIG'                -- TFO_ETI_CODIGO
      ,P_LTI_MNEMONICO            -- TFO_LTI_MNEMONICO
      ,SYSDATE                -- TFO_FECHA_OPERACION
      ,P_MONTO                -- TFO_VALOR_OPERACION
      ,P_FECHA_CUMPLIMIENTO         -- TFO_FECHA_CUMPLIMIENTO
      ,0                  -- TFO_COMISION_BOLSA
      ,PRF1.PRF_BMO_MNEMONICO       -- TFO_BMO_MNEMONICO
      ,PRF1.PRF_TRE_MNEMONICO       -- TFO_TRE_MNEMONICO
      ,PRF1.PRF_FECHA_EMISION       -- TFO_FECHA_EMISION
      ,PRF1.PRF_FECHA_VENCIMIENTO     -- TFO_FECHA_VENCIMIENTO
      ,P_VALOR_NOMINAL            -- TFO_VALOR_NOMINAL
      ,PRF1.PRF_PERIODICIDAD_TASA     -- TFO_PERIODICIDAD_TASA
      ,PRF1.PRF_BASE_CALCULO        -- TFO_BASE_CALCULO
      ,PRF1.PRF_MODALIDAD_TASA        -- TFO_MODALIDAD_TASA
      ,'M'                  -- TFO_MERCADO_COMPRA
      ,'N'                  -- TFO_VENCIDO_ESPECIAL
      ,NULL                 -- TFO_VALOR_UNITARIO
      ,NULL                 -- TFO_CANTIDAD
      ,PRF1.PRF_PUNTOS_ADICIONALES      -- TFO_PUNTOS_ADICIONALES
      ,PRF1.PRF_TASA_FACIAL / 100     -- TFO_TASA_FACIAL
      ,PRF1.PRF_AMORTIZABLE         -- TFO_AMORTIZABLE
      ,PRF1.PRF_TIPO_PAGO_FLUJO       -- TFO_TIPO_PAGO_FLUJO
      ,PRF1.PRF_FECHA_PRIMER_FLUJO      -- TFO_FECHA_PRIMER_FLUJO
      ,NULL                 -- TFO_TASA_MRC_CONGELADA
      ,NULL                 -- TFO_FECHA_CMPLMNTO_ESPECIAL
      ,PRF1.PRF_CAPITALIZABLE       -- TFO_CAPITALIZABLE
      ,'N'                  -- TFO_FONDEO
      ,NULL                 -- TFO_FECHA_VENTA_PLAZO
      ,NULL                 -- TFO_CRUZADA_CONVENIDA
      ,P_BOLSA                -- TFO_BOL_MNEMONICO
      ,P_PRC_PRF_CONSECUTIVO        -- TFO_PRC_PRF_CONSECUTIVO
      ,P_PRC_CONSECUTIVO          -- TFO_PRC_CONSECUTIVO
      ,NULL                 -- TFO_VALOR_TITULO_TM
      ,NULL                 -- TFO_FECHA_VALORIZACION
      ,NULL                 -- TFO_TASA_DESCUENTO
      ,NULL                 -- TFO_LIQ_NUMERO_OPERACION_ES_VE
      ,NULL                 -- TFO_LIQ_NUMERO_FRACCION_ES_VEN
      ,NULL                 -- TFO_LIQ_TIPO_OPERACION_ES_VEND
      ,NULL                 -- TFO_CVS_CONSECUTIVO_ES_VENDIDO
      ,'S'                  -- TFO_DERIVADO
      ,PRF1.PRF_CODIGO_PERIODO        -- TFO_CODIGO_PERIODO
    );

   OPEN C_DCO_OLD;
   FETCH C_DCO_OLD INTO TFODCO;
   IF C_DCO_OLD%FOUND THEN
      UPDATE TITULOS_FONDOS
      SET    TFO_FUG_ISI_MNEMONICO = TFODCO.TFO_FUG_ISI_MNEMONICO,
             TFO_FUG_MNEMONICO = TFODCO.TFO_FUG_MNEMONICO,
             TFO_NUMERO_EMISION_DCV = TFODCO.TFO_NUMERO_EMISION_DCV
             --,TFO_VALOR_OPERACION = TFODCO.TFO_VALOR_OPERACION * (P_VALOR_NOMINAL/TFODCO.TFO_VALOR_NOMINAL)
      WHERE  TFO_FON_CODIGO = PRF1.PRF_FON_CODIGO
      AND    TFO_CODIGO = SIGUIENTE;
   END IF;
   CLOSE C_DCO_OLD;

   /* Se calculan los flujos del titulo deshabilitando los que ya esten causados */

   IF NVL(PRF1.PRF_AMORTIZABLE,'N') = 'S' THEN
      P_FLUJOS_FRM.FLUJOS_AMORTIZACIONES(PRF1.PRF_FON_CODIGO,SIGUIENTE);

      IF PRF1.PRF_MODALIDAD_TASA != 'D' THEN
         P_FLUJOS_FRM.FLUJOS_RENDIMIENTOS(PRF1.PRF_FON_CODIGO,SIGUIENTE);
      END IF;
   ELSE
      IF PRF1.PRF_MODALIDAD_TASA != 'D' THEN
         P_FLUJOS_FRM.FLUJOS_RENDIMIENTOS(PRF1.PRF_FON_CODIGO,SIGUIENTE);
      END IF;
      P_FLUJOS_FRM.FLUJOS_AMORTIZACIONES(PRF1.PRF_FON_CODIGO,SIGUIENTE);
   END IF;

   UPDATE FLUJOS_AMORTIZACION_TITULOS
   SET    FAT_ESTADO = 'C'
   WHERE  FAT_TFO_FON_CODIGO = PRF1.PRF_FON_CODIGO
   AND    FAT_TFO_CODIGO = SIGUIENTE
   AND    TRUNC(FAT_FECHA) <= TRUNC(SYSDATE);

   UPDATE FLUJOS_RENDIMIENTOS_TITULOS
   SET    FRT_ESTADO = 'C'
   WHERE  FRT_TFO_FON_CODIGO = PRF1.PRF_FON_CODIGO
   AND    FRT_TFO_CODIGO = SIGUIENTE
   AND    TRUNC(FRT_FECHA) <= TRUNC(SYSDATE);

   MRF1.MRF_TIR360_C := 0;
   MRF1.MRF_TIR365_C := 0;
   MRF1.MRF_TIR360_M := 0;
   MRF1.MRF_TIR365_M := 0 ;
   MRF1.MRF_AAI := 0;
   MRF1.MRF_TAI := 0;
   MRF1.MRF_MPE := 0;

   OPEN C_MRF_OLD;
   FETCH C_MRF_OLD INTO MRF_OLD;
   CLOSE C_MRF_OLD;

   MRF1.MRF_TIR360_C := MRF_OLD.MRF_TIR360_C;
   MRF1.MRF_TIR365_C := MRF_OLD.MRF_TIR365_C;
   MRF1.MRF_TIR360_M := MRF_OLD.MRF_TIR360_M;
   MRF1.MRF_TIR365_M := MRF_OLD.MRF_TIR365_M;
   MRF1.MRF_AAI := MRF_OLD.MRF_AAI;
   MRF1.MRF_TAI := MRF_OLD.MRF_TAI;
   MRF1.MRF_MPE := MRF_OLD.MRF_MPE;
   MRF1.MRF_VALOR_TITULO_TM := MRF_OLD.MRF_VALOR_TITULO_TM * (P_VALOR_NOMINAL/TFODCO.TFO_VALOR_NOMINAL);
   MRF1.MRF_VALOR_TITULO_TC := MRF_OLD.MRF_VALOR_TITULO_TC * (P_VALOR_NOMINAL/TFODCO.TFO_VALOR_NOMINAL);
   MRF1.MRF_VALORIZACION_TM := MRF_OLD.MRF_VALORIZACION_TM * (P_VALOR_NOMINAL/TFODCO.TFO_VALOR_NOMINAL);
   MRF1.MRF_VALORIZACION_TC := MRF_OLD.MRF_VALORIZACION_TC * (P_VALOR_NOMINAL/TFODCO.TFO_VALOR_NOMINAL);

   -- ACTUALIZACION DEL FLUJO DE AMORTIZACION DE LA FECHA CON EL VALOR DEL TITULO TM
   UPDATE FLUJOS_AMORTIZACION_TITULOS
   SET    FAT_AMORTIZACION_CAPITAL = - MRF1.MRF_VALOR_TITULO_TM
   WHERE  FAT_TFO_FON_CODIGO = PRF1.PRF_FON_CODIGO
   AND    FAT_TFO_CODIGO = SIGUIENTE
   AND    TRUNC(FAT_FECHA) <= TRUNC(SYSDATE);

   /* Se crea el mvto en MVTOS_RENTA_FIJA de fondeo pasivo */
   INSERT INTO MVTOS_RENTA_FIJA
      (MRF_TFO_FON_CODIGO
      ,MRF_TFO_CODIGO
      ,MRF_TMT_MNEMONICO
      ,MRF_FECHA
      ,MRF_UTILIDAD
      ,MRF_PERDIDA
      ,MRF_CAPITAL
      ,MRF_INTERES
      ,MRF_VALOR_TITULO_TM
      ,MRF_VALOR_TITULO_TC
      ,MRF_VALORIZACION_TM
      ,MRF_VALORIZACION_TC
      ,MRF_VALOR_DISTRIBUIR_DIA
      ,MRF_VALOR_DIST_REND_FINANCIERO
      ,MRF_DIFERENCIA_CAMBIO
      ,MRF_MPE
      ,MRF_AAI
      ,MRF_TAI
      ,MRF_TIR360_M
      ,MRF_TIR360_C
      ,MRF_TIR365_M
      ,MRF_TIR365_C)
   VALUES
      (PRF1.PRF_FON_CODIGO
      ,SIGUIENTE
      ,'DCO'
      ,SYSDATE
      ,0
      ,0
      ,0
      ,0
      ,MRF1.MRF_VALOR_TITULO_TM
      ,MRF1.MRF_VALOR_TITULO_TC
      ,MRF1.MRF_VALORIZACION_TM
      ,MRF1.MRF_VALORIZACION_TC
      ,0
      ,0
      ,0
      ,MRF1.MRF_MPE
      ,MRF1.MRF_AAI
      ,MRF1.MRF_TAI
      ,MRF1.MRF_TIR360_M
      ,MRF1.MRF_TIR360_C
      ,MRF1.MRF_TIR365_M
      ,MRF1.MRF_TIR365_C);

END PR_CREAR_DERECHO_COMPRA_YK;

PROCEDURE PR_CREAR_OBLIGACION_COMPRA_YK
   (P_FONDO               VARCHAR2
   ,P_OLD_PRF_CONSECUTIVO NUMBER
   ,P_OLD_PRC_CONSECUTIVO NUMBER
   ,P_FECHA_CUMPLIMIENTO  DATE
   ,P_MONTO               NUMBER
   ,P_BOLSA               VARCHAR2
   ,P_PRC_PRF_CONSECUTIVO NUMBER
   ,P_PRC_CONSECUTIVO     NUMBER
   ,P_LTI_MNEMONICO       VARCHAR2) IS

   -- PROCESO PARA CREAR LA OBLIGACION DE COMPRA DESPUES DE FRACCIONAR UN NEGOCIO YANKEE
   CURSOR C_FONDO IS
      SELECT FON_TIPO
            ,FON_BMO_MNEMONICO
      FROM   FONDOS
      WHERE  FON_CODIGO = P_FONDO;
   FON1   C_FONDO%ROWTYPE;

   CURSOR C_CODIGO IS
      SELECT NVL(MAX(TFO_CODIGO) + 1,1)
      FROM   TITULOS_FONDOS
      WHERE  TFO_FON_CODIGO = P_FONDO;
   SIGUIENTE     NUMBER;

      -- DATOS DEL NUEVO NEGOCIO CREADO
   CURSOR C_PRF IS
      SELECT PRF_FON_CODIGO
            ,PRF_ENA_MNEMONICO
            ,PRF_BMO_MNEMONICO
            ,PRF_TRE_MNEMONICO
            ,PRF_FECHA_EMISION
            ,PRF_FECHA_VENCIMIENTO
            ,PRF_PERIODICIDAD_TASA
            ,PRF_BASE_CALCULO
            ,PRF_MODALIDAD_TASA
            ,PRF_PUNTOS_ADICIONALES
            ,PRF_TASA_FACIAL
            ,PRF_AMORTIZABLE
            ,PRF_TIPO_PAGO_FLUJO
            ,PRF_FECHA_PRIMER_FLUJO
            ,PRF_CAPITALIZABLE
            ,PRF_CODIGO_PERIODO
      FROM   PREORDENES_FONDOS
    WHERE  PRF_FON_CODIGO = P_FONDO
    AND    PRF_CONSECUTIVO = P_PRC_PRF_CONSECUTIVO;
   PRF1 C_PRF%ROWTYPE;


   -- BUSCA EL TFO OBLIGACION DE COMPRA DE LA PREORDEN DE COMPRA ANTERIOR
   CURSOR C_OCO_OLD IS
    SELECT TFO_CODIGO, TFO_FUG_ISI_MNEMONICO, TFO_FUG_MNEMONICO, TFO_NUMERO_EMISION_DCV,
           TFO_VALOR_NOMINAL, TFO_VALOR_OPERACION
    FROM   TITULOS_FONDOS
    WHERE  TFO_FON_CODIGO = P_FONDO
    AND    TFO_PRC_PRF_CONSECUTIVO = P_OLD_PRF_CONSECUTIVO
    AND    TFO_PRC_CONSECUTIVO = P_OLD_PRC_CONSECUTIVO
    AND    TFO_BMO_MNEMONICO = 'PESOS'
    AND    NVL(TFO_DERIVADO,'N') = 'S';
   TFOOCO C_OCO_OLD%ROWTYPE;

   CURSOR C_MRF_OLD IS
      SELECT MRF_FECHA, MRF_TFO_FON_CODIGO, MRF_TFO_CODIGO,
             MRF_TMT_MNEMONICO, MRF_VALOR_TITULO_TM,
             MRF_VALOR_TITULO_TC,MRF_VALORIZACION_TM,
             MRF_VALORIZACION_TC, MRF_MPE, MRF_AAI, MRF_TAI,
             MRF_TIR360_M, MRF_TIR360_C, MRF_TIR365_M,
             MRF_TIR365_C, MRF_FECHA_VALORIZACION, MRF_TASA_DESCUENTO
             MRF_PRECIO, MRF_TASA, MRF_MARGEN, MRF_INDICE,
             MRF_INDICADOR, MRF_VIGENCIA
      FROM   MVTOS_RENTA_FIJA
      WHERE  MRF_TFO_FON_CODIGO = P_FONDO
      AND    MRF_TFO_CODIGO = TFOOCO.TFO_CODIGO
      ORDER BY MRF_FECHA DESC;
   MRF_OLD C_MRF_OLD%ROWTYPE;

   MRF1   MVTOS_RENTA_FIJA%ROWTYPE;
   TASA_BASICA VARCHAR2(10);
   VALOR_TB    NUMBER;
   V_VALOR_OP NUMBER;

BEGIN
   /* Se verfica el tipo de fondo y la base monetaria */
   OPEN C_FONDO;
   FETCH C_FONDO INTO FON1;
   CLOSE C_FONDO;

   /* Se crea el titulo de la parte financiera el fondeo */
   OPEN C_CODIGO;
   FETCH C_CODIGO INTO SIGUIENTE;
   CLOSE C_CODIGO;

   OPEN C_PRF;
   FETCH C_PRF INTO PRF1;
   CLOSE C_PRF;

   INSERT INTO TITULOS_FONDOS
      (TFO_FON_CODIGO
      ,TFO_CODIGO
      ,TFO_TYPE
      ,TFO_ENA_MNEMONICO
      ,TFO_ETI_CODIGO
      ,TFO_LTI_MNEMONICO
      ,TFO_FECHA_OPERACION
      ,TFO_VALOR_OPERACION
      ,TFO_FECHA_CUMPLIMIENTO
      ,TFO_COMISION_BOLSA
      ,TFO_BMO_MNEMONICO
      ,TFO_TRE_MNEMONICO
      ,TFO_FECHA_EMISION
      ,TFO_FECHA_VENCIMIENTO
      ,TFO_VALOR_NOMINAL
      ,TFO_PERIODICIDAD_TASA
      ,TFO_BASE_CALCULO
      ,TFO_MODALIDAD_TASA
      ,TFO_MERCADO_COMPRA
      ,TFO_VENCIDO_ESPECIAL
      ,TFO_VALOR_UNITARIO
      ,TFO_CANTIDAD
      ,TFO_PUNTOS_ADICIONALES
      ,TFO_TASA_FACIAL
      ,TFO_TIPO_PAGO_FLUJO
      ,TFO_FECHA_PRIMER_FLUJO
      ,TFO_TASA_MRC_CONGELADA
      ,TFO_FECHA_CMPLMNTO_ESPECIAL
      ,TFO_CAPITALIZABLE
      ,TFO_FONDEO
      ,TFO_FECHA_VENTA_PLAZO
      ,TFO_CRUZADA_CONVENIDA
      ,TFO_BOL_MNEMONICO
      ,TFO_PRC_PRF_CONSECUTIVO
      ,TFO_PRC_CONSECUTIVO
      ,TFO_VALOR_TITULO_TM
      ,TFO_FECHA_VALORIZACION
      ,TFO_TASA_DESCUENTO
      ,TFO_LIQ_NUMERO_OPERACION_ES_VE
      ,TFO_LIQ_NUMERO_FRACCION_ES_VEN
      ,TFO_LIQ_TIPO_OPERACION_ES_VEND
      ,TFO_CVS_CONSECUTIVO_ES_VENDIDO
      ,TFO_DERIVADO)
   VALUES
      (P_FONDO                -- TFO_FON_CODIGO
      ,SIGUIENTE              -- TFO_CODIGO
      ,'TRF'                -- TFO_TYPE
      ,PRF1.PRF_ENA_MNEMONICO       -- TFO_ENA_MNEMONICO
      ,'VIG'                -- TFO_ETI_CODIGO
      ,P_LTI_MNEMONICO            -- TFO_LTI_MNEMONICO
      ,SYSDATE                -- TFO_FECHA_OPERACION
      ,P_MONTO                -- TFO_VALOR_OPERACION
      ,P_FECHA_CUMPLIMIENTO         -- TFO_FECHA_CUMPLIMIENTO
      ,0                  -- TFO_COMISION_BOLSA
      ,DECODE(FON1.FON_TIPO,'A',DECODE(FON1.FON_TIPO,'PESOS','PESOS'
                                                    ,FON1.FON_BMO_MNEMONICO)
                               ,'PESOS')        -- TFO_BMO_MNEMONICO
      ,NULL                 -- TFO_TRE_MNEMONICO
      ,PRF1.PRF_FECHA_EMISION               -- TFO_FECHA_EMISION
      ,PRF1.PRF_FECHA_VENCIMIENTO         -- TFO_FECHA_VENCIMIENTO
      ,P_MONTO                -- TFO_VALOR_NOMINAL
      ,0                  -- TFO_PERIODICIDAD_TASA
      ,365                  -- TFO_BASE_CALCULO
      ,'D'                  -- TFO_MODALIDAD_TASA
      ,'M'                  -- TFO_MERCADO_COMPRA
      ,'N'                  -- TFO_VENCIDO_ESPECIAL
      ,NULL                 -- TFO_VALOR_UNITARIO
      ,NULL                 -- TFO_CANTIDAD
      ,NULL                 -- TFO_PUNTOS_ADICIONALES
      ,0                  -- TFO_TASA_FACIAL
      ,NULL                 -- TFO_TIPO_PAGO_FLUJO
      ,NULL                 -- TFO_FECHA_PRIMER_FLUJO
      ,NULL                 -- TFO_TASA_MRC_CONGELADA
      ,NULL                 -- TFO_FECHA_CMPLMNTO_ESPECIAL
      ,NULL                 -- TFO_CAPITALIZABLE
      ,'S'                  -- TFO_FONDEO
      ,NULL                 -- TFO_FECHA_VENTA_PLAZO
      ,NULL                 -- TFO_CRUZADA_CONVENIDA
      ,P_BOLSA                -- TFO_BOL_MNEMONICO
      ,P_PRC_PRF_CONSECUTIVO        -- TFO_PRC_PRF_CONSECUTIVO
      ,P_PRC_CONSECUTIVO          -- TFO_PRC_CONSECUTIVO
      ,NULL                 -- TFO_VALOR_TITULO_TM
      ,NULL                 -- TFO_FECHA_VALORIZACION
      ,NULL                 -- TFO_TASA_DESCUENTO
      ,NULL                 -- TFO_LIQ_NUMERO_OPERACION_ES_VE
      ,NULL                 -- TFO_LIQ_NUMERO_FRACCION_ES_VEN
      ,NULL                 -- TFO_LIQ_TIPO_OPERACION_ES_VEND
      ,NULL                 -- TFO_CVS_CONSECUTIVO_ES_VENDIDO
      ,'S'                  -- TFO_DERIVADO
    );

   OPEN C_OCO_OLD;
   FETCH C_OCO_OLD INTO TFOOCO;
   IF C_OCO_OLD%FOUND THEN
      V_VALOR_OP := TFOOCO.TFO_VALOR_OPERACION * (P_MONTO/TFOOCO.TFO_VALOR_NOMINAL);
      UPDATE TITULOS_FONDOS
      SET    TFO_FUG_ISI_MNEMONICO = TFOOCO.TFO_FUG_ISI_MNEMONICO,
             TFO_FUG_MNEMONICO = TFOOCO.TFO_FUG_MNEMONICO,
             TFO_NUMERO_EMISION_DCV = TFOOCO.TFO_NUMERO_EMISION_DCV,
             TFO_VALOR_OPERACION = V_VALOR_OP
      WHERE  TFO_FON_CODIGO = PRF1.PRF_FON_CODIGO
      AND    TFO_CODIGO = SIGUIENTE;
   END IF;
   CLOSE C_OCO_OLD;

   /* Se crea el flujo de amortizaciżn del fondeo */
  /*
   INSERT INTO FLUJOS_AMORTIZACION_TITULOS
      (FAT_TFO_FON_CODIGO
      ,FAT_TFO_CODIGO
      ,FAT_FECHA
      ,FAT_ESTADO
      ,FAT_DESPLAZADO
      ,FAT_AMORTIZACION_CAPITAL)
   VALUES
      (PRF1.PRF_FON_CODIGO
      ,SIGUIENTE
      ,SYSDATE
      ,'C'
      ,'N'
      ,-V_VALOR_OP);
*/
   INSERT INTO FLUJOS_AMORTIZACION_TITULOS
      (FAT_TFO_FON_CODIGO
      ,FAT_TFO_CODIGO
      ,FAT_FECHA
      ,FAT_ESTADO
      ,FAT_DESPLAZADO
      ,FAT_AMORTIZACION_CAPITAL)
   VALUES
      (PRF1.PRF_FON_CODIGO
      ,SIGUIENTE
      ,P_FECHA_CUMPLIMIENTO
      ,'V'
      ,'N'
      ,P_MONTO); --   -p_monto

   MRF1.MRF_TIR360_C := 0;
   MRF1.MRF_TIR365_C := 0;
   MRF1.MRF_TIR360_M := 0;
   MRF1.MRF_TIR365_M := 0;


   MRF1.MRF_FECHA := SYSDATE;
   MRF1.MRF_AAI := 0;
   MRF1.MRF_MPE := 0;
   MRF1.MRF_TAI := 0;

   OPEN C_MRF_OLD;
   FETCH C_MRF_OLD INTO MRF_OLD;
   CLOSE C_MRF_OLD;

   MRF1.MRF_VALOR_TITULO_TM := MRF_OLD.MRF_VALOR_TITULO_TM * (P_MONTO/TFOOCO.TFO_VALOR_NOMINAL);
   MRF1.MRF_VALOR_TITULO_TC := MRF_OLD.MRF_VALOR_TITULO_TC * (P_MONTO/TFOOCO.TFO_VALOR_NOMINAL);

   INSERT INTO MVTOS_RENTA_FIJA
      (MRF_TFO_FON_CODIGO
      ,MRF_TFO_CODIGO
      ,MRF_TMT_MNEMONICO
      ,MRF_FECHA
      ,MRF_UTILIDAD
      ,MRF_PERDIDA
      ,MRF_CAPITAL
      ,MRF_INTERES
      ,MRF_VALOR_TITULO_TM
      ,MRF_VALOR_TITULO_TC
      ,MRF_VALORIZACION_TM
      ,MRF_VALORIZACION_TC
      ,MRF_VALOR_DISTRIBUIR_DIA
      ,MRF_VALOR_DIST_REND_FINANCIERO
      ,MRF_DIFERENCIA_CAMBIO
      ,MRF_MPE
      ,MRF_AAI
      ,MRF_TAI
      ,MRF_TIR360_M
      ,MRF_TIR360_C
      ,MRF_TIR365_M
      ,MRF_TIR365_C)
   VALUES
      (PRF1.PRF_FON_CODIGO
      ,SIGUIENTE
      ,'OCO'
      ,SYSDATE
      ,0
      ,0
      ,0
      ,0
      ,-MRF1.MRF_VALOR_TITULO_TM
      ,-MRF1.MRF_VALOR_TITULO_TC
      ,0
      ,0
      ,0
      ,0
      ,0
      ,MRF1.MRF_MPE
      ,MRF1.MRF_AAI
      ,MRF1.MRF_TAI
      ,MRF1.MRF_TIR360_M
      ,MRF1.MRF_TIR360_C
      ,MRF1.MRF_TIR365_M
      ,MRF1.MRF_TIR365_C);

   /* Se cambian los signos de los flujos de amortizaciżn del derivado */
   UPDATE TITULOS_FONDOS
   SET    TFO_VALOR_OPERACION = - TFO_VALOR_OPERACION
         ,TFO_VALOR_NOMINAL = - TFO_VALOR_NOMINAL
   WHERE  TFO_FON_CODIGO = PRF1.PRF_FON_CODIGO
   AND    TFO_CODIGO = SIGUIENTE;

   UPDATE FLUJOS_AMORTIZACION_TITULOS
   SET    FAT_AMORTIZACION_CAPITAL = - FAT_AMORTIZACION_CAPITAL
   WHERE  FAT_TFO_FON_CODIGO = PRF1.PRF_FON_CODIGO
   AND    FAT_TFO_CODIGO = SIGUIENTE;

   UPDATE FLUJOS_RENDIMIENTOS_TITULOS
   SET    FRT_INTERES_COMPRA = - FRT_INTERES_COMPRA
         ,FRT_INTERES_MERCADO = - FRT_INTERES_MERCADO
         ,FRT_BASE_CAPITAL = - FRT_BASE_CAPITAL
   WHERE  FRT_TFO_FON_CODIGO = PRF1.PRF_FON_CODIGO
   AND    FRT_TFO_CODIGO = SIGUIENTE;

END PR_CREAR_OBLIGACION_COMPRA_YK;

PROCEDURE PR_CREAR_OBLIGACION_VENTA_YK
   (P_FONDO               VARCHAR2
   ,P_OLD_PRF_CONSECUTIVO NUMBER
   ,P_OLD_PRV_CONSECUTIVO NUMBER
   ,P_FECHA_CUMPLIMIENTO  DATE
   ,P_MONTO               NUMBER
   ,P_BOLSA               VARCHAR2
   ,P_PRV_PRF_CONSECUTIVO NUMBER
   ,P_PRV_CONSECUTIVO     NUMBER
   ,P_VALOR_NOMINAL       NUMBER
   ,P_LTI_MNEMONICO       VARCHAR2) IS

   CURSOR C_FONDO IS
      SELECT FON_TIPO
            ,FON_BMO_MNEMONICO
      FROM   FONDOS
      WHERE  FON_CODIGO = P_FONDO;
   FON1   C_FONDO%ROWTYPE;

   CURSOR C_CODIGO IS
      SELECT NVL(MAX(TFO_CODIGO) + 1,1)
      FROM   TITULOS_FONDOS
      WHERE  TFO_FON_CODIGO = P_FONDO;
   SIGUIENTE     NUMBER;

   CURSOR C_TFO (FDO VARCHAR2, COD NUMBER) IS
      SELECT TFO_CODIGO
         , TFO_FON_CODIGO
       , TFO_TYPE
       , TFO_ENA_MNEMONICO
       , TFO_ETI_CODIGO
       , TFO_LTI_MNEMONICO
       , TFO_FECHA_OPERACION
       , TFO_VALOR_OPERACION
       , TFO_FECHA_CUMPLIMIENTO
       , TFO_DIA_SIGUIENTE
       , TFO_PRC_PRF_CONSECUTIVO
       , TFO_PRC_CONSECUTIVO
       , TFO_PRV_PRF_CONSECUTIVO
       , TFO_PRV_CONSECUTIVO
       , TFO_FUG_MNEMONICO
       , TFO_FUG_ISI_MNEMONICO
       , TFO_CVS_CONSECUTIVO
       , TFO_CVS_CONSECUTIVO_ES_VENDIDO
       , TFO_BOL_MNEMONICO, TFO_FONDEO
       , TFO_DERIVADO, TFO_CANTIDAD
       , TFO_MERCADO_COMPRA
       , TFO_VALOR_NOMINAL
       , TFO_BMO_MNEMONICO
       , TFO_FECHA_EMISION
       , TFO_FECHA_VENCIMIENTO
       , TFO_PERIODICIDAD_TASA
       , TFO_BASE_CALCULO
       , TFO_MODALIDAD_TASA
       , TFO_TASA_FACIAL
       , TFO_AMORTIZABLE
       , TFO_TRE_MNEMONICO
       , TFO_PUNTOS_ADICIONALES
       , TFO_FECHA_PRIMER_FLUJO
       , TFO_TIPO_PAGO_FLUJO
       , TFO_CAPITALIZABLE
       , TFO_TASA_MRC_CONGELADA
       , TFO_CRUZADA_CONVENIDA
       , TFO_AGE_CODIGO
       , TFO_COMISION_BOLSA
       , TFO_MERCADO
       , TFO_VALOR_UNITARIO
       , TFO_FECHA_CMPLMNTO_ESPECIAL
       , TFO_DISTRIBUCION_ACUMULADA
       , TFO_VALOR_TITULO_TM
       , TFO_FECHA_VALORIZACION
       , TFO_TASA_DESCUENTO
       , TFO_TFA_TIPO_INVERSION
       , TFO_TFA_CLT_MNEMONICO
       , TFO_DURACION
       , TFO_DURACION_MODIFICADA
       , TFO_VAR_TASA
       , TFO_VAR_MONEDA
       , TFO_CONVEXIDAD
       , TFO_NUMERO_EMISION_DCV
       , TFO_LIQ_NUMERO_OPERACION
       , TFO_LIQ_NUMERO_FRACCION
       , TFO_LIQ_TIPO_OPERACION
       , TFO_NUMERO_TITULO_FISICO
       , TFO_REFERENCIA_DECEVAL
       , TFO_LIQ_NUMERO_OPERACION_ES_VE
       , TFO_LIQ_NUMERO_FRACCION_ES_VEN
       , TFO_LIQ_TIPO_OPERACION_ES_VEND
       , TFO_FECHA_VENTA
       , TFO_VALOR_VENTA
       , TFO_PROSPECTO_VENTA
       , TFO_FECHA_PROSPECTO_VENTA
       , TFO_FECHA_VENTA_PLAZO
       , TFO_VALOR_VENTA_PLAZO
       , TFO_ENTE_VENTA_PLAZO
       , TFO_NUM_IDEN_VENTA_PLAZO
       , TFO_TELEFONO_VENTA_PLAZO
       , TFO_DIRECCION_VENTA_PLAZO
       , TFO_VENCIDO_ESPECIAL
       , TFO_LIC_NUMERO_OPERACION
       , TFO_LIC_NUMERO_FRACCION
       , TFO_LIC_TIPO_OPERACION
       , TFO_LIC_BOL_MNEMONICO
       , TFO_GARANTIA_ACTIVA
       , TFO_CODIGO_PERIODO
       , TFO_CALIFICADO
       , TFO_FECHA_CAMBIO_ESTADO
       , TFO_USUARIO_CAMBIO_ESTADO
       , TFO_TERMINAL_CAMBIO_ESTADO
       , TFO_PER_NUM_IDEN
       , TFO_PER_TID_CODIGO
       , TFO_TIPO_GARANTIA
       , TFO_CUENTA_CRCC
       , TFO_SEGMENTO
       , TFO_CCC_CLI_PER_NUM_IDEN
       , TFO_CCC_CLI_PER_TID_CODIGO
       , TFO_CCC_NUMERO_CUENTA
       , TFO_REPO
       , TFO_SALDO_GARANTIA_SIM
       , TFO_ESTADO_SIM
       ,TFO_NUMERO_EMISION_DCV_HIST
      FROM TITULOS_FONDOS
      WHERE TFO_FON_CODIGO = FDO
        AND TFO_CODIGO = COD;
   TIT C_TFO%ROWTYPE;

   -- DATOS DEL NUEVO NEGOCIO CREADO
   CURSOR C_PRF IS
      SELECT PRF_FON_CODIGO
            ,PRF_ENA_MNEMONICO
            ,PRF_BMO_MNEMONICO
            ,PRF_TRE_MNEMONICO
            ,PRF_FECHA_EMISION
            ,PRF_FECHA_VENCIMIENTO
            ,PRF_PERIODICIDAD_TASA
            ,PRF_BASE_CALCULO
            ,PRF_MODALIDAD_TASA
            ,PRF_PUNTOS_ADICIONALES
            ,PRF_TASA_FACIAL
            ,PRF_AMORTIZABLE
            ,PRF_TIPO_PAGO_FLUJO
            ,PRF_FECHA_PRIMER_FLUJO
            ,PRF_CAPITALIZABLE
            ,PRF_CODIGO_PERIODO
      FROM   PREORDENES_FONDOS
      WHERE  PRF_FON_CODIGO = P_FONDO
      AND    PRF_CONSECUTIVO = P_PRV_PRF_CONSECUTIVO;
    PRF1 C_PRF%ROWTYPE;

   -- BUSCA EL TFO OBLIGACION DE VENTA DE LA PREORDEN DE VENTA ANTERIOR
   CURSOR C_OVE_OLD IS
    SELECT TFO_CODIGO, TFO_FUG_ISI_MNEMONICO, TFO_FUG_MNEMONICO, TFO_NUMERO_EMISION_DCV,
           TFO_VALOR_NOMINAL, TFO_VALOR_OPERACION
    FROM   TITULOS_FONDOS
    WHERE  TFO_FON_CODIGO = P_FONDO
    AND    TFO_PRV_PRF_CONSECUTIVO = P_OLD_PRF_CONSECUTIVO
    AND    TFO_PRV_CONSECUTIVO = P_OLD_PRV_CONSECUTIVO
    AND    TFO_BMO_MNEMONICO = 'DOLAR'
    AND    NVL(TFO_DERIVADO,'N') = 'S';
   TFOOVE C_OVE_OLD%ROWTYPE;

   CURSOR C_MRF_OLD IS
      SELECT MRF_FECHA, MRF_TFO_FON_CODIGO, MRF_TFO_CODIGO,
             MRF_TMT_MNEMONICO, MRF_VALOR_TITULO_TM,
             MRF_VALOR_TITULO_TC,MRF_VALORIZACION_TM,
             MRF_VALORIZACION_TC, MRF_MPE, MRF_AAI, MRF_TAI,
             MRF_TIR360_M, MRF_TIR360_C, MRF_TIR365_M,
             MRF_TIR365_C, MRF_FECHA_VALORIZACION, MRF_TASA_DESCUENTO
             MRF_PRECIO, MRF_TASA, MRF_MARGEN, MRF_INDICE,
             MRF_INDICADOR, MRF_VIGENCIA
      FROM   MVTOS_RENTA_FIJA
      WHERE  MRF_TFO_FON_CODIGO = P_FONDO
      AND    MRF_TFO_CODIGO = TFOOVE.TFO_CODIGO
      ORDER BY MRF_FECHA DESC;
   MRF_OLD C_MRF_OLD%ROWTYPE;

   MRF1   MVTOS_RENTA_FIJA%ROWTYPE;
   TASA_BASICA  VARCHAR2(10);
   VALOR_TB     NUMBER;
   VALOR_TR     NUMBER;
   FECSYS       DATE;
   COTIZACION   NUMBER;
   VALIDA       BOOLEAN;
   VALOR_TIT_TM NUMBER;

BEGIN
   SELECT SYSDATE INTO FECSYS FROM SYS.DUAL;

   OPEN C_FONDO;
   FETCH C_FONDO INTO FON1;
   CLOSE C_FONDO;

   OPEN C_CODIGO;
   FETCH C_CODIGO INTO SIGUIENTE;
   CLOSE C_CODIGO;

   OPEN C_PRF;
   FETCH C_PRF INTO PRF1;
   CLOSE C_PRF;

   /* Se crea el titulo */
   INSERT INTO TITULOS_FONDOS
      (TFO_FON_CODIGO
      ,TFO_CODIGO
      ,TFO_TYPE
      ,TFO_ENA_MNEMONICO
      ,TFO_ETI_CODIGO
      ,TFO_LTI_MNEMONICO
      ,TFO_FECHA_OPERACION
      ,TFO_VALOR_OPERACION
      ,TFO_FECHA_CUMPLIMIENTO
      ,TFO_COMISION_BOLSA
      ,TFO_BMO_MNEMONICO
      ,TFO_TRE_MNEMONICO
      ,TFO_FECHA_EMISION
      ,TFO_FECHA_VENCIMIENTO
      ,TFO_VALOR_NOMINAL
      ,TFO_PERIODICIDAD_TASA
      ,TFO_BASE_CALCULO
      ,TFO_MODALIDAD_TASA
      ,TFO_MERCADO_COMPRA
      ,TFO_VENCIDO_ESPECIAL
      ,TFO_VALOR_UNITARIO
      ,TFO_CANTIDAD
      ,TFO_PUNTOS_ADICIONALES
      ,TFO_TASA_FACIAL
      ,TFO_AMORTIZABLE
      ,TFO_TIPO_PAGO_FLUJO
      ,TFO_FECHA_PRIMER_FLUJO
      ,TFO_TASA_MRC_CONGELADA
      ,TFO_FECHA_CMPLMNTO_ESPECIAL
      ,TFO_CAPITALIZABLE
      ,TFO_FONDEO
      ,TFO_FECHA_VENTA_PLAZO
      ,TFO_CRUZADA_CONVENIDA
      ,TFO_BOL_MNEMONICO
      ,TFO_PRV_PRF_CONSECUTIVO
      ,TFO_PRV_CONSECUTIVO
      ,TFO_VALOR_TITULO_TM
      ,TFO_FECHA_VALORIZACION
      ,TFO_TASA_DESCUENTO
      ,TFO_LIQ_NUMERO_OPERACION_ES_VE
      ,TFO_LIQ_NUMERO_FRACCION_ES_VEN
      ,TFO_LIQ_TIPO_OPERACION_ES_VEND
      ,TFO_CVS_CONSECUTIVO_ES_VENDIDO
      ,TFO_DERIVADO
      ,TFO_CODIGO_PERIODO
      )
   VALUES
      (P_FONDO
      ,SIGUIENTE
      ,'TRF'
      ,PRF1.PRF_ENA_MNEMONICO
      ,'VIG'
      ,P_LTI_MNEMONICO --'CR'
      ,SYSDATE
      ,P_MONTO
      ,P_FECHA_CUMPLIMIENTO
      ,0
      ,PRF1.PRF_BMO_MNEMONICO       -- TFO_BMO_MNEMONICO
      ,PRF1.PRF_TRE_MNEMONICO
      ,PRF1.PRF_FECHA_EMISION
      ,PRF1.PRF_FECHA_VENCIMIENTO
      ,P_VALOR_NOMINAL
      ,PRF1.PRF_PERIODICIDAD_TASA
      ,PRF1.PRF_BASE_CALCULO
      ,PRF1.PRF_MODALIDAD_TASA
      ,'M'
      ,'N'
      ,NULL
      ,NULL
      ,PRF1.PRF_PUNTOS_ADICIONALES
      ,PRF1.PRF_TASA_FACIAL / 100
      ,PRF1.PRF_AMORTIZABLE
      ,PRF1.PRF_TIPO_PAGO_FLUJO
      ,PRF1.PRF_FECHA_PRIMER_FLUJO
      ,NULL
      ,NULL
      ,PRF1.PRF_CAPITALIZABLE
      ,'N'
      ,NULL
      ,NULL
      ,P_BOLSA
      ,P_PRV_PRF_CONSECUTIVO
      ,P_PRV_CONSECUTIVO
      ,NULL
      ,NULL
      ,NULL
      ,NULL
      ,NULL
      ,NULL
      ,NULL
      ,'S'
      ,PRF1.PRF_CODIGO_PERIODO);

   OPEN C_OVE_OLD;
   FETCH C_OVE_OLD INTO TFOOVE;
   IF C_OVE_OLD%FOUND THEN
      UPDATE TITULOS_FONDOS
      SET    TFO_FUG_ISI_MNEMONICO = TFOOVE.TFO_FUG_ISI_MNEMONICO,
             TFO_FUG_MNEMONICO = TFOOVE.TFO_FUG_MNEMONICO,
             TFO_NUMERO_EMISION_DCV = TFOOVE.TFO_NUMERO_EMISION_DCV
             --,TFO_VALOR_OPERACION = TFODCO.TFO_VALOR_OPERACION * (P_VALOR_NOMINAL/TFODCO.TFO_VALOR_NOMINAL)
      WHERE  TFO_FON_CODIGO = PRF1.PRF_FON_CODIGO
      AND    TFO_CODIGO = SIGUIENTE;
   END IF;
   CLOSE C_OVE_OLD;

   /* Se calculan los flujos del titulo deshabilitando los que ya esten causados */
   IF NVL(PRF1.PRF_AMORTIZABLE,'N') = 'S' THEN
      P_FLUJOS_FRM.FLUJOS_AMORTIZACIONES(PRF1.PRF_FON_CODIGO,SIGUIENTE);
      IF PRF1.PRF_MODALIDAD_TASA != 'D' THEN
         P_FLUJOS_FRM.FLUJOS_RENDIMIENTOS(PRF1.PRF_FON_CODIGO,SIGUIENTE);
      END IF;
   ELSE
      IF PRF1.PRF_MODALIDAD_TASA != 'D' THEN
         P_FLUJOS_FRM.FLUJOS_RENDIMIENTOS(PRF1.PRF_FON_CODIGO,SIGUIENTE);
      END IF;
      P_FLUJOS_FRM.FLUJOS_AMORTIZACIONES(PRF1.PRF_FON_CODIGO,SIGUIENTE);
   END IF;

   UPDATE FLUJOS_AMORTIZACION_TITULOS
   SET    FAT_ESTADO = 'C'
   WHERE  FAT_TFO_FON_CODIGO = PRF1.PRF_FON_CODIGO
   AND    FAT_TFO_CODIGO = SIGUIENTE
   AND    TRUNC(FAT_FECHA) <= TRUNC(SYSDATE);

   UPDATE FLUJOS_RENDIMIENTOS_TITULOS
   SET    FRT_ESTADO = 'C'
   WHERE  FRT_TFO_FON_CODIGO = PRF1.PRF_FON_CODIGO
   AND    FRT_TFO_CODIGO = SIGUIENTE
   AND    TRUNC(FRT_FECHA) <= TRUNC(SYSDATE);

   MRF1.MRF_TIR360_C := 0;
   MRF1.MRF_TIR365_C := 0;
   MRF1.MRF_TIR360_M := 0;
   MRF1.MRF_TIR365_M := 0 ;
   MRF1.MRF_AAI := 0;
   MRF1.MRF_TAI := 0;
   MRF1.MRF_MPE := 0;

   OPEN C_MRF_OLD;
   FETCH C_MRF_OLD INTO MRF_OLD;
   CLOSE C_MRF_OLD;

   MRF1.MRF_TIR360_C := MRF_OLD.MRF_TIR360_C;
   MRF1.MRF_TIR365_C := MRF_OLD.MRF_TIR365_C;
   MRF1.MRF_TIR360_M := MRF_OLD.MRF_TIR360_M;
   MRF1.MRF_TIR365_M := MRF_OLD.MRF_TIR365_M;
   MRF1.MRF_AAI := MRF_OLD.MRF_AAI;
   MRF1.MRF_TAI := MRF_OLD.MRF_TAI;
   MRF1.MRF_MPE := MRF_OLD.MRF_MPE;
   MRF1.MRF_VALOR_TITULO_TM := MRF_OLD.MRF_VALOR_TITULO_TM * (P_VALOR_NOMINAL/TFOOVE.TFO_VALOR_NOMINAL);
   MRF1.MRF_VALOR_TITULO_TC := MRF_OLD.MRF_VALOR_TITULO_TC * (P_VALOR_NOMINAL/TFOOVE.TFO_VALOR_NOMINAL);
   MRF1.MRF_VALORIZACION_TM := MRF_OLD.MRF_VALORIZACION_TM * (P_VALOR_NOMINAL/TFOOVE.TFO_VALOR_NOMINAL);
   MRF1.MRF_VALORIZACION_TC := MRF_OLD.MRF_VALORIZACION_TC * (P_VALOR_NOMINAL/TFOOVE.TFO_VALOR_NOMINAL);

   UPDATE FLUJOS_AMORTIZACION_TITULOS
   SET    FAT_AMORTIZACION_CAPITAL = - MRF1.MRF_VALOR_TITULO_TM
   WHERE  FAT_TFO_FON_CODIGO = PRF1.PRF_FON_CODIGO
   AND    FAT_TFO_CODIGO = SIGUIENTE
   AND    TRUNC(FAT_FECHA) <= TRUNC(SYSDATE);

   /* Se crea el mvto en MVTOS_RENTA_FIJA de fondeo pasivo */
   INSERT INTO MVTOS_RENTA_FIJA
      (MRF_TFO_FON_CODIGO
      ,MRF_TFO_CODIGO
      ,MRF_TMT_MNEMONICO
      ,MRF_FECHA
      ,MRF_UTILIDAD
      ,MRF_PERDIDA
      ,MRF_CAPITAL
      ,MRF_INTERES
      ,MRF_VALOR_TITULO_TM
      ,MRF_VALOR_TITULO_TC
      ,MRF_VALORIZACION_TM
      ,MRF_VALORIZACION_TC
      ,MRF_VALOR_DISTRIBUIR_DIA
      ,MRF_VALOR_DIST_REND_FINANCIERO
      ,MRF_DIFERENCIA_CAMBIO
      ,MRF_MPE
      ,MRF_AAI
      ,MRF_TAI
      ,MRF_TIR360_M
      ,MRF_TIR360_C
      ,MRF_TIR365_M
      ,MRF_TIR365_C)
   VALUES
      (PRF1.PRF_FON_CODIGO
      ,SIGUIENTE
      ,'OVE'
      ,SYSDATE
      ,0
      ,0
      ,0
      ,0
      ,-MRF1.MRF_VALOR_TITULO_TM
      ,-MRF1.MRF_VALOR_TITULO_TC
      ,0
      ,0
      ,0
      ,0
      ,0
      ,MRF1.MRF_MPE
      ,MRF1.MRF_AAI
      ,MRF1.MRF_TAI
      ,MRF1.MRF_TIR360_M
      ,MRF1.MRF_TIR360_C
      ,MRF1.MRF_TIR365_M
      ,MRF1.MRF_TIR365_C);

   /* Se cambian los signos de los flujos de amortizaciżn del derivado */
   UPDATE TITULOS_FONDOS
   SET    TFO_VALOR_OPERACION = - TFO_VALOR_OPERACION
         ,TFO_VALOR_NOMINAL = - TFO_VALOR_NOMINAL
   WHERE  TFO_FON_CODIGO = PRF1.PRF_FON_CODIGO
   AND    TFO_CODIGO = SIGUIENTE;

   UPDATE FLUJOS_AMORTIZACION_TITULOS
   SET    FAT_AMORTIZACION_CAPITAL = - FAT_AMORTIZACION_CAPITAL
   WHERE  FAT_TFO_FON_CODIGO = PRF1.PRF_FON_CODIGO
   AND    FAT_TFO_CODIGO = SIGUIENTE;

   UPDATE FLUJOS_RENDIMIENTOS_TITULOS
   SET    FRT_INTERES_COMPRA = - FRT_INTERES_COMPRA
         ,FRT_INTERES_MERCADO = - FRT_INTERES_MERCADO
         ,FRT_BASE_CAPITAL = - FRT_BASE_CAPITAL
   WHERE  FRT_TFO_FON_CODIGO = PRF1.PRF_FON_CODIGO
   AND    FRT_TFO_CODIGO = SIGUIENTE;


END PR_CREAR_OBLIGACION_VENTA_YK;

PROCEDURE PR_CREAR_DERECHO_VENTA_YK
   (P_FONDO               VARCHAR2
   ,P_OLD_PRF_CONSECUTIVO NUMBER
   ,P_OLD_PRV_CONSECUTIVO NUMBER
   ,P_FECHA_CUMPLIMIENTO  DATE
   ,P_MONTO               NUMBER
   ,P_BOLSA               VARCHAR2
   ,P_PRV_PRF_CONSECUTIVO NUMBER
   ,P_PRV_CONSECUTIVO     NUMBER
   ,P_PRV_LTI_MNEMONICO   VARCHAR2) IS

   CURSOR C_FONDO IS
      SELECT FON_TIPO
            ,FON_BMO_MNEMONICO
      FROM   FONDOS
      WHERE  FON_CODIGO = P_FONDO;
   FON1   C_FONDO%ROWTYPE;

   CURSOR C_CODIGO IS
      SELECT NVL(MAX(TFO_CODIGO) + 1,1)
      FROM   TITULOS_FONDOS
      WHERE  TFO_FON_CODIGO = P_FONDO;
   SIGUIENTE     NUMBER;

   -- DATOS DEL NUEVO NEGOCIO CREADO
   CURSOR C_PRF IS
      SELECT PRF_FON_CODIGO
            ,PRF_ENA_MNEMONICO
            ,PRF_BMO_MNEMONICO
            ,PRF_TRE_MNEMONICO
            ,PRF_FECHA_EMISION
            ,PRF_FECHA_VENCIMIENTO
            ,PRF_PERIODICIDAD_TASA
            ,PRF_BASE_CALCULO
            ,PRF_MODALIDAD_TASA
            ,PRF_PUNTOS_ADICIONALES
            ,PRF_TASA_FACIAL
            ,PRF_AMORTIZABLE
            ,PRF_TIPO_PAGO_FLUJO
            ,PRF_FECHA_PRIMER_FLUJO
            ,PRF_CAPITALIZABLE
            ,PRF_CODIGO_PERIODO
      FROM   PREORDENES_FONDOS
      WHERE  PRF_FON_CODIGO = P_FONDO
      AND    PRF_CONSECUTIVO = P_PRV_PRF_CONSECUTIVO;
    PRF1 C_PRF%ROWTYPE;

   -- BUSCA EL TFO DERECHO DE VENTA DE LA PREORDEN DE VENTA ANTERIOR
   CURSOR C_DVE_OLD IS
      SELECT TFO_CODIGO, TFO_FUG_ISI_MNEMONICO, TFO_FUG_MNEMONICO, TFO_NUMERO_EMISION_DCV,
             TFO_VALOR_NOMINAL, TFO_VALOR_OPERACION
      FROM   TITULOS_FONDOS
      WHERE  TFO_FON_CODIGO = P_FONDO
      AND    TFO_PRC_PRF_CONSECUTIVO = P_OLD_PRF_CONSECUTIVO
      AND    TFO_PRC_CONSECUTIVO = P_OLD_PRV_CONSECUTIVO
      AND    TFO_BMO_MNEMONICO = 'PESOS'
      AND    NVL(TFO_DERIVADO,'N') = 'S';
   TFODVE C_DVE_OLD%ROWTYPE;

   CURSOR C_MRF_OLD IS
      SELECT MRF_FECHA, MRF_TFO_FON_CODIGO, MRF_TFO_CODIGO,
             MRF_TMT_MNEMONICO, MRF_VALOR_TITULO_TM,
             MRF_VALOR_TITULO_TC,MRF_VALORIZACION_TM,
             MRF_VALORIZACION_TC, MRF_MPE, MRF_AAI, MRF_TAI,
             MRF_TIR360_M, MRF_TIR360_C, MRF_TIR365_M,
             MRF_TIR365_C, MRF_FECHA_VALORIZACION, MRF_TASA_DESCUENTO
             MRF_PRECIO, MRF_TASA, MRF_MARGEN, MRF_INDICE,
             MRF_INDICADOR, MRF_VIGENCIA
      FROM   MVTOS_RENTA_FIJA
      WHERE  MRF_TFO_FON_CODIGO = P_FONDO
      AND    MRF_TFO_CODIGO = TFODVE.TFO_CODIGO
      ORDER BY MRF_FECHA DESC;
   MRF_OLD C_MRF_OLD%ROWTYPE;

   MRF1   MVTOS_RENTA_FIJA%ROWTYPE;
   TASA_BASICA VARCHAR2(10);
   VALOR_TB    NUMBER;
   V_VALOR_OP  NUMBER;

BEGIN
   /* Se verfica el tipo de fondo y la base monetaria */
   OPEN C_FONDO;
   FETCH C_FONDO INTO FON1;
   CLOSE C_FONDO;

   /* Se crea el titulo de la parte financiera el fondeo */
   OPEN C_CODIGO;
   FETCH C_CODIGO INTO SIGUIENTE;
   CLOSE C_CODIGO;

   OPEN C_PRF;
   FETCH C_PRF INTO PRF1;
   CLOSE C_PRF;

   INSERT INTO TITULOS_FONDOS
      (TFO_FON_CODIGO
      ,TFO_CODIGO
      ,TFO_TYPE
      ,TFO_ENA_MNEMONICO
      ,TFO_ETI_CODIGO
      ,TFO_LTI_MNEMONICO
      ,TFO_FECHA_OPERACION
      ,TFO_VALOR_OPERACION
      ,TFO_FECHA_CUMPLIMIENTO
      ,TFO_COMISION_BOLSA
      ,TFO_BMO_MNEMONICO
      ,TFO_TRE_MNEMONICO
      ,TFO_FECHA_EMISION
      ,TFO_FECHA_VENCIMIENTO
      ,TFO_VALOR_NOMINAL
      ,TFO_PERIODICIDAD_TASA
      ,TFO_BASE_CALCULO
      ,TFO_MODALIDAD_TASA
      ,TFO_MERCADO_COMPRA
      ,TFO_VENCIDO_ESPECIAL
      ,TFO_VALOR_UNITARIO
      ,TFO_CANTIDAD
      ,TFO_PUNTOS_ADICIONALES
      ,TFO_TASA_FACIAL
      ,TFO_TIPO_PAGO_FLUJO
      ,TFO_FECHA_PRIMER_FLUJO
      ,TFO_TASA_MRC_CONGELADA
      ,TFO_FECHA_CMPLMNTO_ESPECIAL
      ,TFO_CAPITALIZABLE
      ,TFO_FONDEO
      ,TFO_FECHA_VENTA_PLAZO
      ,TFO_CRUZADA_CONVENIDA
      ,TFO_BOL_MNEMONICO
      ,TFO_PRV_PRF_CONSECUTIVO
      ,TFO_PRV_CONSECUTIVO
      ,TFO_VALOR_TITULO_TM
      ,TFO_FECHA_VALORIZACION
      ,TFO_TASA_DESCUENTO
      ,TFO_LIQ_NUMERO_OPERACION_ES_VE
      ,TFO_LIQ_NUMERO_FRACCION_ES_VEN
      ,TFO_LIQ_TIPO_OPERACION_ES_VEND
      ,TFO_CVS_CONSECUTIVO_ES_VENDIDO
      ,TFO_DERIVADO)
   VALUES
      (P_FONDO
      ,SIGUIENTE
      ,'TRF'
      ,PRF1.PRF_ENA_MNEMONICO
      ,'VIG'
      ,P_PRV_LTI_MNEMONICO --'CR'
      ,SYSDATE
      ,P_MONTO
      ,P_FECHA_CUMPLIMIENTO
      ,0
      ,DECODE(FON1.FON_TIPO,'A',DECODE(FON1.FON_TIPO,'PESOS','PESOS',FON1.FON_BMO_MNEMONICO),'PESOS')
      ,NULL
      ,PRF1.PRF_FECHA_EMISION
      ,PRF1.PRF_FECHA_VENCIMIENTO
      ,P_MONTO
      ,0
      ,365
      ,'D'
      ,'M'
      ,'N'
      ,NULL
      ,NULL
      ,NULL
      ,0
      ,NULL
      ,NULL
      ,NULL
      ,NULL
      ,NULL
      ,'S'
      ,NULL
      ,NULL
      ,P_BOLSA
      ,P_PRV_PRF_CONSECUTIVO
      ,P_PRV_CONSECUTIVO
      ,NULL
      ,NULL
      ,NULL
      ,NULL
      ,NULL
      ,NULL
      ,NULL
      ,'S');

   OPEN C_DVE_OLD;
   FETCH C_DVE_OLD INTO TFODVE;
   IF C_DVE_OLD%FOUND THEN
      V_VALOR_OP := TFODVE.TFO_VALOR_OPERACION * (P_MONTO/TFODVE.TFO_VALOR_NOMINAL);
      UPDATE TITULOS_FONDOS
      SET    TFO_FUG_ISI_MNEMONICO = TFODVE.TFO_FUG_ISI_MNEMONICO,
             TFO_FUG_MNEMONICO = TFODVE.TFO_FUG_MNEMONICO,
             TFO_NUMERO_EMISION_DCV = TFODVE.TFO_NUMERO_EMISION_DCV,
             TFO_VALOR_OPERACION = V_VALOR_OP
      WHERE  TFO_FON_CODIGO = PRF1.PRF_FON_CODIGO
      AND    TFO_CODIGO = SIGUIENTE;
   END IF;
   CLOSE C_DVE_OLD;

   /* Se crea el flujo de amortizaciżn del fondeo */
/*
   INSERT INTO FLUJOS_AMORTIZACION_TITULOS
      (FAT_TFO_FON_CODIGO
      ,FAT_TFO_CODIGO
      ,FAT_FECHA
      ,FAT_ESTADO
      ,FAT_DESPLAZADO
      ,FAT_AMORTIZACION_CAPITAL)
   VALUES
      (PRF1.PRF_FON_CODIGO
      ,SIGUIENTE
      ,SYSDATE
      ,'C'
      ,'N'
      ,- V_VALOR_OP);
*/
   INSERT INTO FLUJOS_AMORTIZACION_TITULOS
      (FAT_TFO_FON_CODIGO
      ,FAT_TFO_CODIGO
      ,FAT_FECHA
      ,FAT_ESTADO
      ,FAT_DESPLAZADO
      ,FAT_AMORTIZACION_CAPITAL)
   VALUES
      (PRF1.PRF_FON_CODIGO
      ,SIGUIENTE
      ,P_FECHA_CUMPLIMIENTO
      ,'V'
      ,'N'
      ,P_MONTO); -- -P_MONTO

   MRF1.MRF_TIR360_C := 0;
   MRF1.MRF_TIR365_C := 0;
   MRF1.MRF_TIR360_M := 0;
   MRF1.MRF_TIR365_M := 0;

   OPEN C_MRF_OLD;
   FETCH C_MRF_OLD INTO MRF_OLD;
   CLOSE C_MRF_OLD;

   MRF1.MRF_VALOR_TITULO_TM := MRF_OLD.MRF_VALOR_TITULO_TM * (P_MONTO/TFODVE.TFO_VALOR_NOMINAL);
   MRF1.MRF_VALOR_TITULO_TC := MRF_OLD.MRF_VALOR_TITULO_TC * (P_MONTO/TFODVE.TFO_VALOR_NOMINAL);


   MRF1.MRF_FECHA := SYSDATE;

   MRF1.MRF_AAI := 0;
   MRF1.MRF_MPE := 0;
   MRF1.MRF_TAI := 0;

   INSERT INTO MVTOS_RENTA_FIJA
      (MRF_TFO_FON_CODIGO
      ,MRF_TFO_CODIGO
      ,MRF_TMT_MNEMONICO
      ,MRF_FECHA
      ,MRF_UTILIDAD
      ,MRF_PERDIDA
      ,MRF_CAPITAL
      ,MRF_INTERES
      ,MRF_VALOR_TITULO_TM
      ,MRF_VALOR_TITULO_TC
      ,MRF_VALORIZACION_TM
      ,MRF_VALORIZACION_TC
      ,MRF_VALOR_DISTRIBUIR_DIA
      ,MRF_VALOR_DIST_REND_FINANCIERO
      ,MRF_DIFERENCIA_CAMBIO
      ,MRF_MPE
      ,MRF_AAI
      ,MRF_TAI
      ,MRF_TIR360_M
      ,MRF_TIR360_C
      ,MRF_TIR365_M
      ,MRF_TIR365_C)
   VALUES
      (PRF1.PRF_FON_CODIGO
      ,SIGUIENTE
      ,'DVE'
      ,SYSDATE
      ,0
      ,0
      ,0
      ,0
      ,MRF1.MRF_VALOR_TITULO_TM
      ,MRF1.MRF_VALOR_TITULO_TC
      ,0
      ,0
      ,0
      ,0
      ,0
      ,MRF1.MRF_MPE
      ,MRF1.MRF_AAI
      ,MRF1.MRF_TAI
      ,MRF1.MRF_TIR360_M
      ,MRF1.MRF_TIR360_C
      ,MRF1.MRF_TIR365_M
      ,MRF1.MRF_TIR365_C);

END PR_CREAR_DERECHO_VENTA_YK;

PROCEDURE PR_VALIDA_IAP IS
   CURSOR C_TFO IS
      SELECT TFO_FON_CODIGO, TFO_CODIGO, TFO_PRC_PRF_CONSECUTIVO
      FROM   TITULOS_FONDOS
      WHERE  TFO_FON_CODIGO = '860079174'
      AND    TRUNC(TFO_FECHA_OPERACION) = TRUNC(SYSDATE)
      AND    TFO_PRC_PRF_CONSECUTIVO IS NOT NULL
      AND    NVL(TFO_DERIVADO,'N') = 'N'
      AND    NVL(TFO_FONDEO,'N') = 'N'
      AND    TFO_ETI_CODIGO = 'VIG';
   TFO1 C_TFO%ROWTYPE;

   CURSOR C_IAP IS
      SELECT 'S'
      FROM   PREORDENES_FONDOS
            ,ESPECIES_NACIONALES
      WHERE  PRF_FON_CODIGO = '860079174'
      AND    PRF_CONSECUTIVO = TFO1.TFO_PRC_PRF_CONSECUTIVO
      AND    PRF_ENA_MNEMONICO = ENA_MNEMONICO
      AND    NVL(ENA_YANKEE,'N') = 'S'
      AND    EXISTS (SELECT 'S'
                     FROM   PREORDENES_VENTA
                     WHERE  PRV_PRF_FON_CODIGO = PRF_FON_CODIGO
                     AND    PRV_PRF_CONSECUTIVO = PRF_CONSECUTIVO
                     AND    PRV_PRF_FON_CODIGO = '860079174'
                     AND    PRV_PRF_CONSECUTIVO = TFO1.TFO_PRC_PRF_CONSECUTIVO
                     AND    NVL(PRV_FRACCIONADA_UNIFICADA,' ') NOT IN ('FRC','UNI')
                     AND    PRV_FECHA_CUMPLIMIENTO > TRUNC(SYSDATE)
                     AND    NOT EXISTS (SELECT 'S'
                            FROM TITULOS_FONDOS
                            WHERE TFO_FON_CODIGO = PRV_PRF_FON_CODIGO
                            AND   TFO_PRV_PRF_CONSECUTIVO = PRV_PRF_CONSECUTIVO
                            AND   TFO_PRV_CONSECUTIVO = PRV_CONSECUTIVO
                            AND   NVL(TFO_DERIVADO,'N') = 'N'));
   V_IAP VARCHAR2(1);

BEGIN
   OPEN C_TFO;
   FETCH C_TFO INTO TFO1;
   WHILE C_TFO%FOUND LOOP
      OPEN C_IAP;
      FETCH C_IAP INTO V_IAP;
      CLOSE C_IAP;
      IF NVL(V_IAP,'N') = 'S' THEN
         UPDATE TITULOS_FONDOS
         SET    TFO_ETI_CODIGO = 'IAP'    -- INVERSION APLAZADA
         WHERE  TFO_FON_CODIGO = TFO1.TFO_FON_CODIGO
         AND    TFO_CODIGO = TFO1.TFO_CODIGO;
      END IF;
      FETCH C_TFO INTO TFO1;
   END LOOP;
   CLOSE C_TFO;
   COMMIT;

END PR_VALIDA_IAP;
-- FIN SORTIZ TRANSMISIONES

FUNCTION FN_TASA_FACIAL(P_TASA_EFECTIVA NUMBER,
                        P_PERIODICIDAD  VARCHAR2,
                        P_BASE          NUMBER,
                        P_FECHA         DATE)
   RETURN NUMBER IS
/*DECLARE
P_TASA_EFECTIVA NUMBER        := 0.1730;
P_PERIODICIDAD  VARCHAR2(2)   := 'TV';
P_BASE          NUMBER        := 365;
P_FECHA         DATE          := '23-JUN-2023';*/

P_DIAS          NUMBER;
TASA_FACIAL     NUMBER;
P_FECHA_FIN     DATE;
BEGIN
  DBMS_OUTPUT.PUT_LINE('P_NEGOCIOS_POSICION.FN_TASA_FACIAL  ');
  IF P_BASE = 360 THEN
    DBMS_OUTPUT.PUT_LINE('360  ');
    IF P_PERIODICIDAD = 'MV' THEN--MES
      P_DIAS := 30;
    ELSIF P_PERIODICIDAD = 'BV' THEN--BIMESTRE
      P_DIAS := 60;
    ELSIF P_PERIODICIDAD = 'TV' THEN--TRIMESTRE
      P_DIAS := 90;
    ELSIF P_PERIODICIDAD = 'CV' THEN--CUATRIMESTRE
      P_DIAS := 120;
    ELSIF P_PERIODICIDAD = 'SV' THEN--SEMESTRE
      P_DIAS := 180;
    END IF;
  ELSIF P_BASE = 365 THEN
    DBMS_OUTPUT.PUT_LINE('365  ');
    IF P_PERIODICIDAD = 'MV' THEN--MES
      P_FECHA_FIN := ADD_MONTHS(P_FECHA,1);
    ELSIF P_PERIODICIDAD = 'BV' THEN--BIMESTRE
      P_FECHA_FIN := ADD_MONTHS(P_FECHA,2);
    ELSIF P_PERIODICIDAD = 'TV' THEN--TRIMESTRE
      P_FECHA_FIN := ADD_MONTHS(P_FECHA,3);
    ELSIF P_PERIODICIDAD = 'CV' THEN--CUATRIMESTRE
      P_FECHA_FIN := ADD_MONTHS(P_FECHA,4);
    ELSIF P_PERIODICIDAD = 'SV' THEN--SEMESTRE
      P_FECHA_FIN := ADD_MONTHS(P_FECHA,6);
    END IF;
    P_DIAS := P_FINANCIERO.DIAS_365(P_FECHA,P_FECHA_FIN);
    DBMS_OUTPUT.PUT_LINE('P_DIAS  '||P_DIAS);
  END IF;
  TASA_FACIAL := ((POWER((1+P_TASA_EFECTIVA),(P_DIAS/P_BASE))-1)*(P_BASE/P_DIAS))*100;
  DBMS_OUTPUT.PUT_LINE('TASA_FACIAL  '||TASA_FACIAL);
  DBMS_OUTPUT.PUT_LINE('SALIO DE P_NEGOCIOS_POSICION.FN_TASA_FACIAL  ');
  RETURN TASA_FACIAL;
END FN_TASA_FACIAL;
END P_NEGOCIOS_POSICION;

/

  GRANT EXECUTE ON "PROD"."P_NEGOCIOS_POSICION" TO "M_OP_SOPORTE_JEFE";
  GRANT EXECUTE ON "PROD"."P_NEGOCIOS_POSICION" TO "M_OP_SOPORTE_PROFESIONAL";
  GRANT EXECUTE ON "PROD"."P_NEGOCIOS_POSICION" TO "COE_RECURSOS";
  GRANT EXECUTE ON "PROD"."P_NEGOCIOS_POSICION" TO "NOCTURNO";
