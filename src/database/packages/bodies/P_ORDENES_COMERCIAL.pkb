        , OCO_CANAL_ORIGEN
        , OCO_FECHA_RECEPCION
        ,OCO_ESTADO_BOLSA
        ,OCO_TASA_REGISTRO
        --,OCO_COBRAR_RETIRO_PARCIAL
       -- ,OCO_NO_REGISTRA_INSTRUCCION  ---desarrollo miguel pando para quitar
       --App Complementacion Rf Rv 19/11/2020
      ,OCO_COBRAR_RETIRO_PARCIAL -- fdm compra desde fondo
        ,OCO_CFO_FON_CODIGO
        ,OCO_CFO_CODIGO
        ,OCO_NO_REGISTRA_INSTRUCCION -- fdm compra desde fondo
        ,OCO_CDC_CUENTA_DCV  --VAGTUD885-3 Complementacion RF RV
    ,OCO_RECPROF_CONSECUTIVO
  ,OCO_PRECIO_PROMEDIO --MB PRECIO PROMEDIO
       )
       VALUES
       (  P_ID_ORDEN                                                          --OCO_CONSECUTIVO
        , 'MEC'                                                               --OCO_BOL_MNEMONICO
        , 'RF'                                                               --OCO_COC_CTO_MNEMONICO
        , 'ORD'                                                               --OCO_COC_CCO_MNEMONICO
        , 'NA'                                                                --OCO_COC_CTE_MNEMONICO
        , 'MER'                                                               --OCO_TOC_MNEMONICO
        , 'CON'                                                               --OCO_CNE_MNEMONICO
        , DECODE(V_CANAL_ORIGEN,'PLV','PCO',
                  DECODE(V_LEO,5,'COL',
                       'COL'))                                                 --OCO_EOC_MNEMONICO
        , P_VIG_TIPO_VIGENCIA                                                 --OCO_VIO_MNEMONICO
        , P_CLI_NUM_IDEN                                                      --OCO_CCC_CLI_PER_NUM_IDEN
        , P_CLI_TID_CODIGO                                                    --OCO_CCC_CLI_PER_TID_CODIGO
        , P_CUENTA_CORREDORES                                                 --OCO_CCC_NUMERO_CUENTA
        , P_COLOCA_NUM_IDEN                                                   --OCO_PER_NUM_IDEN
        , P_COLOCA_TID_CODIGO                                                 --OCO_PER_TID_CODIGO
        , C_ORDENANTE.RLC_PER_NUM_IDEN                                        --OCO_RLC_PER_NUM_IDEN
        , C_ORDENANTE.RLC_PER_TID_CODIGO                                      --OCO_RLC_PER_TID_CODIGO
        , C_ORDENANTE.RLC_ROL_CODIGO                                          --OCO_RLC_ROL_CODIGO
        ,  DECODE(V_ORDEN_DCV ,'S','DV','DA')                                 --OCO_LTI_MNEMONICO
        , V_GNA_MNEMONICO                                                     --OCO_GNA_MNEMONICO
        , SYSDATE --TO_DATE(P_FECHA_HORA,'DD-MM-YYYY HH24:MI:SS')                       --OCO_FECHA_Y_HORA
        , SYSDATE --TO_DATE(P_FECHA_HORA,'DD-MM-YYYY HH24:MI:SS')                       --OCO_FECHA_CRONOLOGICA
        , P_CANTIDAD                                                          --OCO_NOMINAL_O_PESOS
        , 'N'                                                                 --OCO_TIPO_NOMINAL_O_PESOS
        , 'N'                                                                 -- OCO_OPERACION_TOTAL
        , C_INICIALES.PER_EJECUTA_ORDEN_MESA                                  --OCO_EJECUTA_ORDEN_MESA
        , 'N'                                                                 --OCO_DINERO_CONTRA_TITULOS
        , V_INS_ENV_FAX                                                       --OCO_ENVIAR_FAX_FACTURA
        , V_INS_ENV_DIRECCION                                                 --OCO_ENVIAR_FACTURA
        , 'N'                                                                 --OCO_ENVIAR_CARTA_COMPROMISO
        , 'N'                                                                 --OCO_ENVIAR_CARTA_CARRU_PLAZO
        , 'N'                                                                 --OCO_ENVIAR_RECIBO_CUSTODIA
        , 'N'                                                                  --OCO_COBRAR_CHEQUE
        , 'N'                                                                 --OCO_COBRAR_CHEQUE_GERENCIA
        , 'N'                                                                 --OCO_RECOGER_CHEQUE
        , 'S'                                                                 --OCO_COBRAR_SALDO_CUENTA
        , 'N'                                                                 --OCO_COBRAR_TRANSFERENCIA_BANCA
        , 'N'                                                                 --OCO_COBRAR_SEBRA
        , 'N'                                                                 --OCO_COBRAR_CONSIGNA
        , 'N'                                                                 --OCO_COBRAR_REDENCION
        , 'N'                                                                 --OCO_COBRAR_FONDOS_VALORES
        , P_ESPECIE                                                           --OCO_ENA_MNEMONICO
        , V_EMI_MNEMONICO                                                     --OCO_EMI_MNEMONICO
        , SYSDATE--TO_DATE(P_FECHA_HORA,'DD-MM-YYYY HH24:MI:SS')                       --OCO_FECHA_MODIFICACION
        , P_COND_PRECIO_LIMITIE                                               --OCO_PRECIO_LIMITE_O_MARGEN
        , P_PORCENTAJE_COMISION                                               --OCO_COMISION
        , DECODE(P_INS_ENV_NUM_FAX,NULL, NULL,P_INS_ENV_NUM_FAX)                                                   --OCO_NUMERO_FAX
        , DECODE(P_INS_ENV_NUM_DIRECCION,NULL,NULL,P_INS_ENV_NUM_DIRECCION)                                             --OCO_DIRECCION_DOCUMENTOS
        , DECODE(P_INS_ENV_CONTACTO,NULL,NULL,P_INS_ENV_NUM_DIRECCION)                                                  --OCO_PREGUNTAR_POR_DOCUMENTOS
        , 'S'                                                                 --OCO_VERIFICADO_COMERCIAL
        , DECODE(C_INICIALES.PER_TIPO_COMERCIAL,'C',substr(P_COLOCA_TERMINAL,1,40),
                                                'P',substr(P_COLOCA_TERMINAL,1,40),
                                                 NULL)                                    --OCO_TERMINAL_VERIFICA
        , P_DUENO_NUM_IDEN                                                     --OCO_PER_NUM_IDEN_ES_DUENO
        , P_DUENO_TID_CODIGO                                                   --OCO_PER_TID_CODIGO_ES_DUENO
        , DECODE(C_INICIALES.PER_TIPO_COMERCIAL,'C',SYSDATE,
                                                'P',SYSDATE,
                                                 NULL)                                    --OCO_FECHA_VERIFICA
        , 'N'                                                                  --OCO_COBRAR_EFECTIVO
        , P_INS_REC_MEDIO                                                      --OCO_MEDIO_RECEPCION
        , P_INS_REC_DETALLE                                                    --OCO_DETALLE_MEDIO_RECEPCION
        , to_char(sysdate, 'HH24:MI')  --P_INS_REC_HORA                                                      --OCO_HORA_RECEPCION
        , 'MR'                                                                  --OCO_TIPO_MEC
        , DECODE(P_CLI_PROFESIONAL,'1','S','N')                                 --OCO_PROFESIONAL
        , V_LEO                                                                 --OCO_LEO_CONSECUTIVO
        , 'N'   --OTC                                                                --OCO_ORDEN_NEGOCIO
        , NULL /*P_COND_PRECIO*/                                                         --OCO_CONDICION_PRECIO
        , NULL /*DECODE(P_COND_CRITERIOS_ADICI,NULL,NULL,P_COND_CRITERIOS_ADICI)*/                                               --OCO_CRITERIOS_ADICIONALES
        , NULL /* P_COND_CANTIDAD_MINIMA */                                                --OCO_CANTIDAD_MINIMA
        , NULL /* DECODE(V_VIS_VISIBLE,NULL,NULL,V_VIS_VISIBLE)*/                                                         --OCO_VISIBLE
        , NULL /*DECODE(P_VIS_PORCENTAJE,NULL,NULL,P_VIS_PORCENTAJE)*/                                                      --OCO_PORCENTAJE_VISIBLE
        , NULL /*DECODE(V_STOP_STOP,NULL,NULL,V_STOP_STOP)*/                                                           --OCO_STOP
        , NULL /*DECODE(P_STOP_PRECIO_STOP,NULL,NULL,P_STOP_PRECIO_STOP)*/                                                    --OCO_PRECIO_STOP
        , NULL /*DECODE(P_CONSOLIDAR,1,'S','N')*/                                        --OCO_PERMITE_AGRUPAMIENTO
        , NVL(TO_DATE(P_VIG_FECHA_PERMANENCI,'DD-MM-YYYY HH24:MI:SS'),NULL)               --OCO_FECHA_PERMANENCIA
        , NULL /*NVL(P_VIG_HORA_PERMANENCIA,NULL)*/                                                --OCO_HORA_DURACION
        , V_CUENTA_DECEVAL                                                      --OCO_CUD_CUENTA_DECEVAL
        , DECODE(P_INS_ENV_COD_CIUDAD,NULL,NULL,P_INS_ENV_COD_CIUDAD)                                                  --OCO_AGE_CODIGO_ENVIA_DOCUMENTO
        , NVL(P_CANTIDAD_INTENCION,0)                                           --OCO_CANTIDAD_ACC
        , NVL(P_PRECIO_INTENCION,0)                                             --OCO_PRECIO_ACC
        , NVL(P_COMISION_INTENCION,0)                                           --OCO_COMISION_ACC
        , NVL(P_IVA_ITENCION,0)                                                 --OCO_IVA_ACC
        , NVL(P_TOTAL_OPERACION_INT,0)                                          --OCO_TOTAL_OPERACION_ACC
        , NVL(P_NETO_OPERACION_INT,0)                                           --OCO_NETO_OPERACION_ACC
        , DECODE(V_PER_TID_ENRUTA,NULL,NULL,V_PER_TID_ENRUTA)                                                      --OCO_PER_TID_ENRUTA
        , DECODE(V_PER_NUM_ENRUTA,NULL,NULL,V_PER_NUM_ENRUTA)                                                      --OCO_PER_NUM_ENRUTA
        , V_CANAL_ORIGEN                                                        --OCO_CANAL_ORIGEN
        , TO_DATE(V_FECHA_RECEPCION,'dd/mm/yyyy')                               --OCO_FECHA_RECEPCION
        , DECODE(V_CANAL_ORIGEN,'Fix-I','REG',NULL)                             --OCO_ESTADO_BOLSA
        , NVL(P_TASA_REGISTRO,null)                                               --OCO_TASA_REGISTRO--0.3
       -- ,'N'                                                                     --OCO_COBRAR_RETIRO_PARCIAL
      --  , V_NO_REGIS_INST                                                        --OCO_NO_REGISTRA_INSTRUCCION
    --App Complementaciones Rf Rv 19/11/2020
      , V_OCO_COBRAR_RETIRO_PARCIAL                                              --OCO_COBRAR_RETIRO_PARCIAL  fdm compra desde fondo
        , V_OCO_CFO_FON_CODIGO                                                               --OCO_CFO_FON_CODIGO
        , V_OCO_CFO_CODIGO                                                              --OCO_CFO_CODIGO
        , V_OCO_NO_REGISTRA_INSTRUCCION                                            --OCO_OPERACION_SIN_INSTRUCCION -- fdm compra desde fondo
        , DECODE(V_ORDEN_DCV ,'S',P_TITULO_CTA_DCV,NULL)                        --OCO_CDC_CUENTA_DCV   -weis VAGTUS
        ,P_RECPROF_CONSECUTIVO   --OCO_RECPROF_CONSECUTIVO
       --MB PRECIO PROMEDIO 
       ,P_CALCULO_PRECIO_PROMEDIO.PRECIO_PROMEDIO_LINEA( P_CLI_NUM_IDEN                                                      --OCO_CCC_CLI_PER_NUM_IDEN
                                                       , P_CLI_TID_CODIGO
                                                       ,P_ESPECIE
                                                       ,SYSDATE
                                                       ,NULL)
       --MB
    );

        IF SQL%ROWCOUNT = 0 THEN
          P_ID_ORDEN := NULL;
        END IF;
      END IF;

      IF P_ID_ORDEN IS NOT NULL THEN
         IF V_CANAL_ORIGEN = 'Fix-I' THEN


            P_TOOLS.CONSULTARCONSTANTE(P_CONSTANTE  => 'CS4',
                                       P_VALOR      => V_VALOR_CONS_INT,
                                       P_VALOR_DATE => V_VALOR_DATE_CONS,
                                       P_VALOR_CHAR => V_VALOR_SAE_S4);


            IF  V_TIPO_PERSONA = 'PJU' THEN
               V_NOC_CLI_PER_NUM_IDE := P_CLI_NUM_IDEN||'-'||P_CLIENTES.RT_DIGITO_CONTROL(P_CLI_NUM_IDEN);
            ELSE
                V_NOC_CLI_PER_NUM_IDE := P_CLI_NUM_IDEN;
            END IF;

            V_CUENTAS_DECEVAL := NULL;
            IO_CURSOR_CUD     := NULL;
            V_QUERY_CUD := 'SELECT CUD_CUENTA_DECEVAL,CUD_ESPECIAL_FIDUCIARIO FROM CUENTAS_DECEVAL'||
                               ' WHERE CUD_CLI_PER_NUM_IDEN = '||CHR(39)||P_CLI_NUM_IDEN||CHR(39)||
                               ' AND CUD_CLI_PER_TID_CODIGO = '||CHR(39)||P_CLI_TID_CODIGO||CHR(39)||
                               ' AND CUD_ESTADO = ''A'' '||
                               ' AND CUD_CUENTA_DECEVAL = '||V_CUENTA_DECEVAL;

            OPEN IO_CURSOR_CUD FOR V_QUERY_CUD;
            LOOP
               FETCH IO_CURSOR_CUD INTO  V_CUENTAS_DECEVAL.CUD_CUENTA_DECEVAL,
                                         V_CUENTAS_DECEVAL.CUD_ESPECIAL_FIDUCIARIO;
               EXIT WHEN IO_CURSOR_CUD%NOTFOUND;
            END LOOP;
            CLOSE IO_CURSOR_CUD;

            INSERT INTO NOTIFICACIONES_ORDENES_CMA(
                             NOC_CONSECUTIVO
                            ,NOC_FOLIO_BOLSA
                            ,NOC_CLI_PER_NUM_IDEN
                            ,NOC_CLI_PER_TID_CODIGO
                            ,NOC_CUENTA_DECEVAL
                            ,NOC_ID_COEASY
                            ,NOC_TIPO_NEGOCIO
                            ,NOC_PORCENTAJE_COMISION
                            ,NOC_USUARIO_SAE
                            ,NOC_ESPECIAL_FIDUCIARIO
                            ,NOC_CANTIDAD
                            ,NOC_PRECIO
                            ,NOC_ESTADO
                            ,NOC_FECHA_INGRESO
                            ,NOC_FECHA_ENTREGA
                            ,NOC_ENA_MNEMONICO
                            ,NOC_CANAL_ORIGEN
                            ,NOC_PER_NOMBRE_USUARIO
                            ,NOC_PER_NOMBRE
                            ,NOC_PER_APELLIDOS
                            ,NOC_COMISION_ESPECIAL_ETRADE)
            VALUES(
                             NOC_SEQ.NEXTVAL                                 --NOC_CONSECUTIVO
                            ,P_ID_BOLSA                                       --NOC_FOLIO_BOLSA
                            ,V_NOC_CLI_PER_NUM_IDE                           --V_CUENTA_CCC.CCC_CLI_PER_NUM_IDEN               --NOC_CLI_PER_NUM_IDEN
                            ,P_CLI_TID_CODIGO                                --NOC_CLI_PER_TID_CODIGO
                            ,V_CUENTA_DECEVAL                                --NOC_CUENTA_DECEVAL
                            ,P_ID_ORDEN                                      --NOC_ID_COEASY
                            ,'C'                                             --NOC_TIPO_NEGOCIO
                            ,TRUNC(P_PORCENTAJE_COMISION,3)                  --NOC_PORCENTAJE_COMISION
                            ,V_VALOR_SAE_S4                                  --NOC_USUARIO_SAE
                            ,V_CUENTAS_DECEVAL.CUD_ESPECIAL_FIDUCIARIO       --NOC_ESPECIAL_FIDUCIARIO
                            ,P_CANTIDAD                                      --NOC_CANTIDAD
                            ,P_PRECIO_INTENCION                                        --NOC_PRECIO
                            ,'POR_PROCESAR'                                  --NOC_ESTADO
                            ,SYSDATE                                         --NOC_FECHA_INGRESO
                            ,NULL                                            --NOC_FECHA_ENTREGA
                            ,P_ESPECIE                                          --NOC_ENA_MNEMONICO
                            ,'3'--'S4'                                        --NOC_CANAL_ORIGEN
                            ,P_USUARIO                                     --NOC_PER_NOMBRE_USUARIO
                            ,V_PER_NOMBRE_PER                             --NOC_PER_NOMBRE
                            ,DECODE(V_TIPO_PERSONA,'PJU',' ',
                                    V_PER_APELLIDOS)   --NOC_PER_APELLIDOS)
                            ,'N');

         END IF;
      END IF;
   END IF;

   IF P_TIPO_ORDEN = 'V' THEN
     /* VALIDACIONES DE SALDOS CON CUENTA DECEVAL*/

     /* Asignacion de LEO segun origen
      @cciones comisionista = 3
      @Etrade clientes = 5
      PLV = 8  se reasigna al leo 3 VAGTUS030559
      UDF = 9
     */
       IF V_CLI_PERFIL_RIESGO IS NULL THEN
          V_ERRORES := V_ERRORES + 1;
          P_CAB.CrearError('Cliente sin perfil de riesgo Definido. No se puede registrar la operacion');
       END IF;

       IF P_VIG_TIPO_VIGENCIA = 'HFE' THEN

       SELECT SYSDATE INTO FECHA_T FROM DUAL;
       IF TRUNC(TO_DATE(P_VIG_FECHA_PERMANENCI,'DD-MM-YYYY HH24:MI:SS')) <= TRUNC(FECHA_T) THEN
          V_ERRORES := V_ERRORES + 1;
          P_CAB.CrearError('Para una orden con vigencia HASTA FECHA la FECHA DE VIGENCIA debe ser mayor a hoy');
       END IF;
       OPEN C_CONSTANTES('DMP');
       FETCH C_CONSTANTES INTO DIAS;
       IF C_CONSTANTES%NOTFOUND THEN
          CLOSE C_CONSTANTES;
          V_ERRORES := V_ERRORES + 1;
          P_CAB.CrearError('No se pudo determinar la constante de dias mżximos de permanencia de la orden');
       END IF;
       CLOSE C_CONSTANTES;
       IF TRUNC(FECHA_T) + DIAS < TRUNC(TO_DATE(P_VIG_FECHA_PERMANENCI,'DD-MM-YYYY HH24:MI:SS')) THEN
             V_ERRORES := V_ERRORES + 1;
             P_CAB.CREARERROR('En ordenes HASTA FECHA la FECHA DE VIGENCIA debe ser menor o igual a ' || DIAS || ' dias');
      END IF;
  END IF;


  OPEN C_CLIENTE;
      FETCH C_CLIENTE INTO CLIENTE;
      CLOSE C_CLIENTE;

      IF CLIENTE.PER_TIPO = 'PNA' AND
         P_CLI_TID_CODIGO IN ('TI','NIUP') THEN
         CLIENTE.CLI_FECHA_NACIMIENTO := NVL(CLIENTE.CLI_FECHA_NACIMIENTO,SYSDATE);
         IF ADD_MONTHS(CLIENTE.CLI_FECHA_NACIMIENTO,222) < TRUNC(SYSDATE) THEN
            V_ERRORES := V_ERRORES + 1;
            P_CAB.CrearError('Cliente con identificaciżn de menor de edad y ya es mayor de edad. No puede operar con este documento');
         END IF;
      END IF;

      V_PER_TID_ENRUTA  := NULL;
      V_PER_NUM_ENRUTA  := NULL;

     IF P_CODIGO_INFORMADOR IS NOT NULL AND NVL(C_PRODUCTO.CCC_PANTALLA_LIVIANA,'N') != 'S'  THEN
        V_ERRORES := V_ERRORES+1;
        P_CAB.CrearError('Cliente no habilitado para operar por pantalla liviana ');
     END IF;

     IF C_INICIALES.PER_TIP_COMERCIAL_UDF IN ( 'PRO','ASE','ASP') AND C_INICIALES.PER_SUC_CODIGO= 11 AND V_CANAL_ORIGEN NOT IN ('ACC-E') THEN
         IF P_ABONO_CUENTA = 'S' AND
           P_PAGAR_A_PAGO IS NOT NULL THEN
           IF P_PAGAR_A_PAGO NOT IN ('C') THEN
             V_ERRORES := V_ERRORES+1;
             P_CAB.CrearError('Tipos de pagos inconsistentes.. Se debe seleccionar uno Reinversion o Transferencia');
           END IF;
         END IF;

         V_ABONO_CUENTA := P_ABONO_CUENTA;


         V_OVE_GIRAR  := 'N';
         IF P_ABONO_CUENTA = 'N' AND
            P_PAGAR_A_PAGO IN ('C','B','T') THEN
           V_OVE_GIRAR := 'S';
           V_OVE_TIPO_ABONO := NULL;
         END IF;

         IF P_ABONO_CUENTA = 'S' THEN
           V_OVE_TIPO_ABONO := 'S';
         ELSE
           V_OVE_TIPO_ABONO := NULL;
         END IF;

         IF C_INICIALES.PER_TIP_COMERCIAL_UDF = 'PRO' THEN
           V_PER_TID_ENRUTA    := P_COLOCA_TID_CODIGO;
           V_PER_NUM_ENRUTA    := P_COLOCA_NUM_IDEN;
         END IF;
     ELSE
        V_OVE_GIRAR      := 'N';
        V_ABONO_CUENTA   := 'S';
        V_OVE_TIPO_ABONO := 'S';
     END IF;

     /*IF P_ABONO_CUENTA = 'S' THEN
           V_OVE_TIPO_ABONO := 'S';
     ELSE
           V_OVE_TIPO_ABONO := NULL;
           V_ABONO_CUENTA := 'N';
     END IF;*/

     V_DUENO_NUM_IDEN := P_DUENO_NUM_IDEN;
     IF V_CANAL_ORIGEN = 'PLV' THEN
        IF P_DUENO_NUM_IDEN = P_CLI_NUM_IDEN THEN
           V_DUENO_NUM_IDEN := P_COLOCA_NUM_IDEN;
        END IF;
     END IF;


     IF V_ERRORES = 0 THEN
       IO_CURSOR := NULL;

       -- VALIDAR SI EXISTE CLIENTE PARA OPERACIONES SP=EXCEDE SALDO

       IF NVL(P_TITULO_ORIGEN,' ') = 'SP' THEN
          V_ISIN            := NULL;
          V_CREA_SALDO      := NULL;
          V_MENSAJE_SALDO   := NULL;
          P_ORDENES_COMERCIAL.PR_ISIN_VENTA_CORTO_ACC(P_ENA_MNEMONICO  => P_ESPECIE,
                                                      P_PER_NUM_IDEN   => P_CLI_NUM_IDEN,
                                                      P_PER_TID_CODIGO => P_CLI_TID_CODIGO,
                                                      P_ISIN           => V_ISIN,
                                                      P_CREA_SALDO     => V_CREA_SALDO,
                                                      P_MENSAJE        => V_MENSAJE_SALDO
                                                      );
          IF NVL(V_CREA_SALDO,' ') = 'S' THEN
             P_ORDENES_COMERCIAL.PR_CREAR_SALDO_CFC(P_CUENTA_DECEVAL     => V_TITULO_CTA_DVAL,
                                                    P_ISIN               => V_ISIN,
                                                    P_FUNGIBLE           => 0,
                                                    P_CLI_PER_NUM_IDEN   => P_CLI_NUM_IDEN,
                                                    P_CLI_PER_TID_CODIGO => P_CLI_TID_CODIGO,
                                                    P_CUENTA_CCC         => P_CUENTA_CORREDORES
                                                    );
          END IF;
       END IF;

       P_WEB_CLIENTE.OBTENERCUENTASDECEVAL(P_TID_CODIGO     => P_CLI_TID_CODIGO,
                                           P_NUM_IDEN       => P_CLI_NUM_IDEN,
                                           P_ENA_MNEMONICO  => P_ESPECIE,
                                           P_FECHA          => SYSDATE,
                                           P_CUENTA_DECEVAL => V_TITULO_CTA_DVAL,
                                           IO_CURSOR        => IO_CURSOR);
       OPEN PORTAFOLIO(P_ENA_MNEMONICO => P_ESPECIE,
                       P_CUENTA_DECEVAL=> V_TITULO_CTA_DVAL);
       FETCH PORTAFOLIO INTO C_PORTAFOLIO;
       CLOSE PORTAFOLIO;

       C_PORTAFOLIO.SALDO_DISPONIBLE := NVL(C_PORTAFOLIO.SALDO_DISPONIBLE ,0)-P_CANTIDAD;

       IF NVL(P_TITULO_ORIGEN,' ')  = 'DA' THEN
         IF C_PORTAFOLIO.SALDO_DISPONIBLE < 0 THEN
           V_ERRORES := V_ERRORES+1;
           P_CAB.CrearError('El numero de acciones de '||P_ESPECIE||' no puede ser superior a:'||TRIM(TO_CHAR(C_PORTAFOLIO.SALDO_DISPONIBLE,'999999999999999999.99')));
         END IF;
       ELSIF NVL(P_TITULO_ORIGEN,' ') = 'SP' THEN
         IF C_PORTAFOLIO.SALDO_DISPONIBLE > 0 THEN
           V_ERRORES := V_ERRORES+1;
           P_CAB.CrearError('El monto de '||P_ESPECIE||' debe superar el neto: '||TRIM(TO_CHAR(C_PORTAFOLIO.SALDO_DISPONIBLE,'999999999999999999.99'))||' cuando vende con Excede Saldo');
         END IF;
       END IF;

       IF V_CANAL_ORIGEN IN ('S2','S4') THEN -- bloquear ingreso de este canal
       --IF V_CANAL_ORIGEN IN ('S2','S4','ACC-E') THEN -- bloquear ingreso de este canal
         V_ERRORES := V_ERRORES + 1;
         P_CAB.CrearError('Ordenes por este canal no autorizadas');
       END IF;


     IF NVL(P_TIPO_INSTRUCCION,'0') NOT IN ('0') AND V_CANAL_ORIGEN IN ('ACC-E','UDF-A','ACC') THEN /* fdm cuando viene de @cciones, y es fondo */


      IF P_INS_ENV_DIRECCION = 1 THEN
      V_INS_ENV_DIRECCION := 'S';--'E';
      ELSE
      V_INS_ENV_DIRECCION := 'N';--'R';
      END IF;

      IF P_TIPO_INSTRUCCION IN ('AC') THEN
       V_ABONO_CUENTA := 'S';
      ELSE
       V_ABONO_CUENTA := 'N'/*NVL(P_ABONO_CUENTA, 'N')*/;
       V_OVE_TIPO_ABONO := null;
      END IF;

      SELECT DECODE(P_TIPO_INSTRUCCION,'PG','S','N') INTO V_OVE_GIRAR FROM DUAL;

      END IF;

     --INSERT_CLOB('fdm error V_ABONO_CUENTA - '|| V_ABONO_CUENTA || '  V_OVE_TIPO_ABONO- ' || V_OVE_TIPO_ABONO|| ' - ');

      IF V_ERRORES = 0  AND V_RENTA_FIJA IS NULL THEN
         /* CREACION DE LA ORDEN DE VENTA*/
--begin
         SELECT COR_SEQ.NEXTVAL INTO P_ID_ORDEN FROM DUAL;
         INSERT INTO CONSECUTIVO_ORDENES
           (COR_CONSECUTIVO
           ,COR_CLASE
           ,COR_BOLSA)
         VALUES
           (P_ID_ORDEN
           ,'ACC'
           ,'COL');
         INSERT INTO ORDENES_VENTA
         ( OVE_CONSECUTIVO
          ,OVE_BOL_MNEMONICO
          ,OVE_COC_CTO_MNEMONICO
          ,OVE_COC_CCO_MNEMONICO
          ,OVE_COC_CTE_MNEMONICO
          ,OVE_PER_NUM_IDEN
          ,OVE_PER_TID_CODIGO
          ,OVE_CCC_CLI_PER_TID_CODIGO
          ,OVE_CCC_CLI_PER_NUM_IDEN
          ,OVE_CCC_NUMERO_CUENTA
          ,OVE_RLC_PER_NUM_IDEN
          ,OVE_RLC_PER_TID_CODIGO
          ,OVE_RLC_ROL_CODIGO
          ,OVE_VIO_MNEMONICO
          ,OVE_CNE_MNEMONICO
          ,OVE_TOC_MNEMONICO
          ,OVE_EOC_MNEMONICO
          ,OVE_ENA_MNEMONICO
          ,OVE_LTI_MNEMONICO
          ,OVE_FECHA_Y_HORA
          ,OVE_FECHA_CRONOLOGICA
          ,OVE_NOMINAL_O_PESOS
          ,OVE_TIPO_NOMINAL_O_PESOS
          ,OVE_OPERACION_TOTAL
          ,OVE_EJECUTA_ORDEN_MESA
          ,OVE_GIRAR
          ,OVE_ABONO_CUENTA
          ,OVE_ENVIAR_FAX_FACTURA
          ,OVE_ENVIAR_FACTURA
          ,OVE_DINERO_CONTRA_TITULOS
          ,OVE_RECOGER_CARTA
          ,OVE_RECOGER_CERT_CAMARA
          ,OVE_ORIGEN_FUNGIBLE
          ,OVE_FECHA_MODIFICACION
          ,OVE_PRECIO_LIMITE_O_MARGEN
          ,OVE_COMISION
          ,OVE_TIPO_PAGO_ABONO_CUENTA
          ,OVE_NUMERO_FAX
          ,OVE_AGE_CODIGO_ENVIA_DOCUMENTO
          ,OVE_DIRECCION_DOCUMENTOS
          ,OVE_PREGUNTAR_POR_DOCUMENTOS
          ,OVE_CFC_CUENTA_DECEVAL
          ,OVE_CFC_FUG_ISI_MNEMONICO
          ,OVE_CFC_FUG_MNEMONICO
          ,OVE_FECHA_VERIFICA
          ,OVE_TERMINAL_VERIFICA
          ,OVE_PER_NUM_IDEN_ES_DUENO
          ,OVE_PER_TID_CODIGO_ES_DUENO
          ,OVE_VERIFICADO_COMERCIAL
          ,OVE_FECHA_PERMANENCIA
          ,OVE_MEDIO_RECEPCION
          ,OVE_DETALLE_MEDIO_RECEPCION
          ,OVE_HORA_RECEPCION
          ,OVE_TIPO_MEC
          ,OVE_PROFESIONAL
          ,OVE_PER_NUM_IDEN_CTA
          ,OVE_PER_TID_CODIGO_CTA
          ,OVE_LEO_CONSECUTIVO
          ,OVE_ORDEN_NEGOCIO
          ,OVE_CONDICION_PRECIO
          ,OVE_CRITERIOS_ADICIONALES
          ,OVE_CANTIDAD_MINIMA
          ,OVE_VISIBLE
          ,OVE_PORCENTAJE_VISIBLE
          ,OVE_STOP
          ,OVE_PRECIO_STOP
          ,OVE_HORA_DURACION
          ,OVE_PERMITE_AGRUPAMIENTO
          ,OVE_CANTIDAD_ACC
          ,OVE_PRECIO_ACC
          ,OVE_COMISION_ACC
          ,OVE_IVA_ACC
          ,OVE_TOTAL_OPERACION_ACC
          ,OVE_NETO_OPERACION_ACC
          ,OVE_FECHA_RECEPCION
          ,OVE_CODIGO_INFORMADOR
          ,OVE_TID_CODIGO_INFORMADOR
          ,OVE_IDENTIFICACION_INFORMADOR
          ,OVE_NOMBRE_INFORMADOR
          ,OVE_CODIGO_OFICINA_INFORMADOR
          ,OVE_FECHA_PRE_ORDEN
          ,OVE_HORA_PRE_ORDEN
          ,OVE_PER_TID_ENRUTA
          ,OVE_PER_NUM_ENRUTA
          ,OVE_CANAL_ORIGEN
          ,OVE_TODO_NADA_OPA
          ,OVE_ESTADO_BOLSA
          ,OVE_INCREMENTO_FONDO -- fdm fondos inversiżn
          ,OVE_CFO_FON_CODIGO
          ,OVE_CFO_CODIGO
          ,OVE_MAS_INSTRUC_COBRO_PAGO
          ,OVE_NO_REGISTRA_INSTRUCCION -- fdm sin instrucciżn desde @cciones
      ,OVE_RECPROF_CONSECUTIVO
         ) VALUES
         (   P_ID_ORDEN                                                 --OVE_CONSECUTIVO
            ,'COL'                                                      --OVE_BOL_MNEMONICO
            ,'ACC'                                                      --OVE_COC_CTO_MNEMONICO
            ,DECODE(NVL(P_OPA,'N'),'S','EXT','ORD')                     --OVE_COC_CCO_MNEMONICO
            ,DECODE(NVL(P_OPA,'N'),'S','OPA','NA')                      --OVE_COC_CTE_MNEMONICO
            ,P_COLOCA_NUM_IDEN                                          --OVE_PER_NUM_IDEN
            ,P_COLOCA_TID_CODIGO                                        --OVE_PER_TID_CODIGO
            ,P_CLI_TID_CODIGO                                           --OVE_CCC_CLI_PER_TID_CODIGO
            ,P_CLI_NUM_IDEN                                             --OVE_CCC_CLI_PER_NUM_IDEN
            ,P_CUENTA_CORREDORES                                        --OVE_CCC_NUMERO_CUENTA
            ,C_ORDENANTE.RLC_PER_NUM_IDEN                               --OVE_RLC_PER_NUM_IDEN
            ,C_ORDENANTE.RLC_PER_TID_CODIGO                              --OVE_RLC_PER_TID_CODIGO
            ,C_ORDENANTE.RLC_ROL_CODIGO                                 --OVE_RLC_ROL_CODIGO
            ,DECODE(NVL(P_OPA,'N'),'S','HCA',P_VIG_TIPO_VIGENCIA)       --OVE_VIO_MNEMONICO
            ,DECODE(NVL(P_VENTA_CORTO,'N'),'S','VCO','CON')             --OVE_CNE_MNEMONICO
            ,'MER'                                                      --OVE_TOC_MNEMONICO
            ,DECODE(V_CANAL_ORIGEN,'PLV','PCO',
                       DECODE(NVL(P_OPA,'N'),'S','COL',
                        DECODE(V_LEO,5,'COL',
                               'COL')))                                 --OVE_EOC_MNEMONICO
            ,P_ESPECIE                                                  --OVE_ENA_MNEMONICO
            ,'DA'                                                       --OVE_LTI_MNEMONICO
            ,SYSDATE--TO_DATE(P_FECHA_HORA,'DD-MM-YYYY HH24:MI:SS')              --OVE_FECHA_Y_HORA
            ,SYSDATE--TO_DATE(P_FECHA_HORA,'DD-MM-YYYY HH24:MI:SS')              --OVE_FECHA_CRONOLOGICA
            ,P_CANTIDAD                                                 --OVE_NOMINAL_O_PESOS
            ,'N'                                                        --OVE_TIPO_NOMINAL_O_PESOS
            ,'N'                                                        --OVE_OPERACION_TOTAL
            ,C_INICIALES.PER_EJECUTA_ORDEN_MESA                         --OVE_EJECUTA_ORDEN_MESA
            ,V_OVE_GIRAR                                                --OVE_GIRAR
            ,V_ABONO_CUENTA                                             --OVE_ABONO_CUENTA
            ,V_INS_ENV_FAX                                              --OVE_ENVIAR_FAX_FACTURA
            ,V_INS_ENV_DIRECCION                                        --OVE_ENVIAR_FACTURA
            ,'N'                                                        --OVE_DINERO_CONTRA_TITULOS
            ,'N'                                                        --OVE_RECOGER_CARTA
            ,'N'                                                        --OVE_RECOGER_CERT_CAMARA
            ,P_TITULO_ORIGEN                                            --OVE_ORIGEN_FUNGIBLE
            ,SYSDATE--TO_DATE(P_FECHA_HORA,'DD-MM-YYYY HH24:MI:SS')              --OVE_FECHA_MODIFICACION
            ,P_COND_PRECIO_LIMITIE                                      --OVE_PRECIO_LIMITE_O_MARGEN
            ,P_PORCENTAJE_COMISION                                      --OVE_COMISION
            ,V_OVE_TIPO_ABONO                                           --OVE_TIPO_PAGO_ABONO_CUENTA
            ,P_INS_ENV_NUM_FAX                                          --OVE_NUMERO_FAX
            ,P_INS_ENV_COD_CIUDAD                                       --OVE_AGE_CODIGO_ENVIA_DOCUMENTOS
            ,P_INS_ENV_NUM_DIRECCION                                    --OVE_DIRECCION_DOCUMENTOS
            ,P_INS_ENV_CONTACTO                                         --OVE_PREGUNTAR_POR_DOCUMENTOS
            ,V_TITULO_CTA_DVAL                                          --OVE_CFC_CUENTA_DECEVAL
            ,P_TITULO_COD_ISIN                                          --OVE_CFC_FUG_ISI_MNEMONICO
            ,P_TITULO_COD_FUNGIBLE                                      --OVE_CFC_FUG_MNEMONICO
            ,DECODE(C_INICIALES.PER_TIPO_COMERCIAL,'C',SYSDATE,
                                                  'P',SYSDATE,
                                                   NULL)                --OVE_FECHA_VERIFICA
            ,DECODE(C_INICIALES.PER_TIPO_COMERCIAL,'C',substr(P_COLOCA_TERMINAL,1,20),
                                                   'P',substr(P_COLOCA_TERMINAL,1,20),
                                                   NULL)                --OVE_TERMINAL_VERIFICA
            ,V_DUENO_NUM_IDEN                                           --OVE_PER_NUM_IDEN_ES_DUENO
            ,P_DUENO_TID_CODIGO                                         --OVE_PER_TID_CODIGO_ES_DUENO
            ,'S'                                                        --OVE_VERIFICADO_COMERCIAL
            ,DECODE(NVL(P_OPA,'N'),'S',NULL,TO_DATE(P_VIG_FECHA_PERMANENCI,'DD-MM-YYYY HH24:MI:SS'))    --OVE_FECHA_PERMANENCIA
            ,P_INS_REC_MEDIO                                            --OVE_MEDIO_RECEPCION
            ,P_INS_REC_DETALLE                                          --OVE_DETALLE_MEDIO_RECEPCION
            ,P_INS_REC_HORA                                             --OVE_HORA_RECEPCION
            ,'MT'                                                       --OVE_TIPO_MEC
            ,DECODE(P_CLI_PROFESIONAL,'1','S','N')                      --OVE_PROFESIONAL
            ,DECODE(P_CLI_NUM_IDEN,'860079174',NULL,V_DUENO_NUM_IDEN)   --OVE_PER_NUM_IDEN_CTA
            ,DECODE(P_CLI_NUM_IDEN,'860079174',NULL,P_DUENO_TID_CODIGO) --OVE_PER_TID_CODIGO_CTA
            ,V_LEO                                                      --OVE_LEO_CONSECUTIVO
            ,'O'                                                        --OVE_ORDEN_NEGOCIO
            ,P_COND_PRECIO                                              --OVE_CONDICION_PRECIO
            ,P_COND_CRITERIOS_ADICI                                     --OVE_CRITERIOS_ADICIONALES
            ,P_COND_CANTIDAD_MINIMA                                     --OVE_CANTIDAD_MINIMA
            ,V_VIS_VISIBLE                                              --OVE_VISIBLE
            ,P_VIS_PORCENTAJE                                           --OVE_PORCENTAJE_VISIBLE
            ,V_STOP_STOP                                                --OVE_STOP
            ,P_STOP_PRECIO_STOP                                         --OVE_PRECIO_STOP
            ,P_VIG_HORA_PERMANENCIA                                     --OVE_HORA_DURACION
            ,DECODE(P_CONSOLIDAR,1,'S','N')                             --OVE_PERMITE_AGRUPAMIENTO
            ,NVL(P_CANTIDAD_INTENCION,0)                                --OVE_CANTIDAD_ACC
            ,NVL(P_PRECIO_INTENCION,0)                                  --OVE_PRECIO_ACC
            ,NVL(P_COMISION_INTENCION,0)                                --OVE_COMISION_ACC
            ,NVL(P_IVA_ITENCION,0)                                      --OVE_IVA_ACC
            ,NVL(P_TOTAL_OPERACION_INT,0)                               --OVE_TOTAL_OPERACION_ACC
            ,NVL(P_NETO_OPERACION_INT,0)                                --OVE_NETO_OPERACION_ACC
            ,TO_DATE(V_FECHA_RECEPCION,'dd/mm/yyyy')                    --OVE_FECHA_RECEPCION dd/MM/yyyy
            ,P_CODIGO_INFORMADOR                                        --OVE_CODIGO_INFORMADOR
            ,P_TID_CODIGO_INFORMADOR                                    --OVE_TID_CODIGO_INFORMADOR
            ,P_NUM_IDEN_INFORMADOR                                      --OVE_IDENTIFICACION_INFORMADOR
            ,P_NOMBRE_INFORMADOR                                        --OVE_NOMBRE_INFORMADOR
            ,P_CODIGO_OFICINA_INFOR                                     --OVE_CODIGO_OFICINA_INFORMADOR
            ,TO_DATE(P_FECHA_PRE_ORDEN_INFOR,'dd/mm/yyyy')              --OVE_FECHA_PRE_ORDEN
            ,P_HORA_PRE_ORDEN_INFOR                                     --OVE_HORA_PRE_ORDEN
            ,V_PER_TID_ENRUTA                                           --OVE_PER_TID_ENRUTA
            ,V_PER_NUM_ENRUTA                                           --OVE_PER_NUM_ENRUTA
            ,V_CANAL_ORIGEN                                             --OVE_CANAL_ORIGEN
            ,DECODE(NVL(P_OPA,'N'),'S',NVL(P_TODO_NADA_OPA,'N'),NULL)   --OVE_TODO_NADA_OPA IN ('S', 'N')
            ,DECODE(V_CANAL_ORIGEN,'Fix-I','REG',NULL)                  --OVE_ESTADO_BOLSA
      ,DECODE(P_TIPO_INSTRUCCION,'INC','S','N')                   --OVE_INCREMENTO_FONDO -- fdm fondos inversiżn
            ,P_FONDO                                                    --OVE_CFO_FON_CODIGO
            ,P_APORTE                                                   --OVE_CFO_CODIGO
            ,P_MAS_INSTRUCCIONES_PAGO                                   --OVE_MAS_INSTRUC_COBRO_PAGO
            ,DECODE(P_TIPO_INSTRUCCION,'NR','S','','S','N')             --OVE_NO_REGISTRA_INSTRUCCION -- fdm sin instrucciżn desde @cciones
            ,P_RECPROF_CONSECUTIVO                    -- OVE_RECPROF_CONSECUTIVO
      );
 /*EXCEPTION
             WHEN OTHERS THEN

             vtest :=  sqlerrm;

             INSERT_CLOB('fdm error '|| vtest);


             RAISE_APPLICATION_ERROR(-20001,'Error en procedimientoP_COLOCAR_ORDEN: '||sqlerrm);

        END;*/

          IF SQL%ROWCOUNT = 0 THEN
            P_ID_ORDEN := NULL;
            V_ERRORES := V_ERRORES+1;
          ELSE
            IO_CURSOR := NULL;

            P_WEB_CLIENTE.OBTENERCUENTASDECEVAL(P_TID_CODIGO     => P_CLI_TID_CODIGO,
                                                P_NUM_IDEN       => P_CLI_NUM_IDEN,
                                                P_ENA_MNEMONICO  => P_ESPECIE,
                                                P_FECHA          => SYSDATE,
                                                P_CUENTA_DECEVAL => V_TITULO_CTA_DVAL,
                                                IO_CURSOR        => IO_CURSOR);
            OPEN PORTAFOLIO(P_ENA_MNEMONICO => P_ESPECIE,
                            P_CUENTA_DECEVAL=> V_TITULO_CTA_DVAL);
            FETCH PORTAFOLIO INTO C_PORTAFOLIO;
            CLOSE PORTAFOLIO;

            C_PORTAFOLIO.SALDO_DISPONIBLE := NVL(C_PORTAFOLIO.SALDO_DISPONIBLE ,0);

            IF NVL(P_TITULO_ORIGEN,' ')  = 'DA' THEN
              IF C_PORTAFOLIO.SALDO_DISPONIBLE < 0 THEN
                V_ERRORES := V_ERRORES+1;
                P_CAB.CrearError('El monto de '||P_ESPECIE||' no puede superar el neto en'||TO_CHAR(C_PORTAFOLIO.SALDO_DISPONIBLE,'999999999999999999.99'));
              END IF;
            ELSIF NVL(P_TITULO_ORIGEN,' ') = 'SP' THEN
              IF C_PORTAFOLIO.SALDO_DISPONIBLE > 0 THEN
                 V_ERRORES := V_ERRORES+1;
                P_CAB.CrearError('El monto de '||P_ESPECIE||' debe superar el neto '||TO_CHAR(C_PORTAFOLIO.SALDO_DISPONIBLE,'999999999999999999.99')||' cuando vende con Excede Saldo');
              END IF;
            END IF;

            /* CREACION DE ORDEN DE PAGO ORIGEN PLV O UDF*/
      --Se agrega origen  Complementaciones RF RV 18/11/2020
      --
            IF (V_ABONO_CUENTA = 'N' AND P_CODIGO_BANCO_PAGO IS NOT NULL)
              OR (V_CANAL_ORIGEN IN ('ACC-E','UDF-A','ACC',V_VALOR_COMRV) ) AND P_TIPO_INSTRUCCION = 'PG' /*AND P_TIPO_INSTRUCCION NOT IN ('NR')*/ THEN -- fdm pone esta parte al if para tener en cuenta @ccciones
              IF V_LEO IN (9,3,2) THEN--pendiente leo
                V_ERRORES_ODP := 0;
                V_ODP_CONSECUTIVO := NULL;
                SELECT DECODE(P_PAGAR_A_PAGO,'C',V_PER_NOMBRE,'B',P_NOMBRE_CUENTA_PAGO,'T',P_NOMBRE_CUENTA_PAGO) INTO V_ODP_A_NOMBRE_DE FROM DUAL;
                SELECT DECODE(P_PAGAR_A_PAGO,'C','C','B','T','T','T') INTO V_ODP_PAGAR_A FROM DUAL;

                SELECT DECODE(P_PAGAR_A_PAGO,'T',P_NUM_IDEN_PAGO,'B',P_NUM_IDEN_PAGO,NULL),DECODE(P_PAGAR_A_PAGO,'T',P_TIPO_IDEN_PAGO,'B',P_TIPO_IDEN_PAGO,NULL) INTO V_ODP_NUM_IDEN,V_ODP_TID_CODIGO FROM DUAL;

                IF P_CODIGO_BANCO_PAGO  <> 51 THEN
                   V_TPA_MNEMONICO := 'ACH';
                   V_ODP_CONSIGNAR := 'N';
                   V_DETALLE_ACH := 'S';
                ELSE
                   V_TPA_MNEMONICO := 'TRB';
                   V_ODP_CONSIGNAR := 'S';
                   V_DETALLE_ACH := 'N';
                END IF;

            V_ODP_ES_CLIENTE := 'N';


        IF (P_TIPO_PAGO IS NOT NULL OR LENGTH(P_TIPO_PAGO) > 0) AND V_CANAL_ORIGEN IN ('ACC-E','UDF-A','ACC') THEN /* fdm cuando viene de @cciones, y trae tipo de pago */


          V_TPA_MNEMONICO := P_TIPO_PAGO;
          V_DETALLE_ACH := 'N'; --DUDA ACż!!!
          V_ODP_A_NOMBRE_DE := P_PAGAR_A;

          IF P_ABONO_CUENTA <> 'S' OR P_ABONO_CUENTA IS NULL THEN
            --V_ODP_PAGAR_A := P_PAGAR_A;
            SELECT DECODE(P_PAGAR_A,'C','C','B','O','T','T') INTO V_ODP_PAGAR_A FROM DUAL;
          END IF;
          IF P_INS_ENV_DIRECCION = 1 THEN
            V_INS_ENV_DIRECCION := 'E';
          ELSE
            V_INS_ENV_DIRECCION := 'R';
          END IF;
          IF P_CONSIGNAR = 'S' THEN
            V_ODP_CONSIGNAR := P_CONSIGNAR;
          ELSE
            V_ODP_CONSIGNAR := 'N';
          END IF;
          IF P_PAGAR_A = 'C' THEN
            V_ODP_ES_CLIENTE := 'S';
          ELSE
            V_ODP_ES_CLIENTE := 'N';
          END IF;
          IF P_PAGAR_A = 'T' THEN
            V_ODP_A_NOMBRE_DE := P_TERCERO_NOMBRE;
            V_ODP_TID_CODIGO := P_TERCERO_TIPO_ID;
            V_ODP_NUM_IDEN := P_TERCERO_NUMERO_ID;
          END IF;
          IF P_PAGAR_A = 'O' THEN
            V_ODP_A_NOMBRE_DE := P_ORDENANTE;
            V_ODP_TID_CODIGO := P_ORDENANTE_TID_CODIGO;
            V_ODP_NUM_IDEN := P_ORDENANTE_NUM_IDEN;
          END IF;

          IF P_TIPO_PAGO IN ('CHE','CHG') THEN
            V_ODP_BAN_CODIGO := P_CONSIGNAR_BANCO;
            V_ODP_NUM_CUENTA_CONSIGNAR := P_CONSIGNAR_CUENTA;
            V_ODP_TCB_MNEMONICO := P_CONSIGNAR_TIPO_CUENTA;
          END IF;

          IF P_TIPO_PAGO = 'PSE' THEN
            V_ODP_BAN_CODIGO := P_SEBRA_ID_BANCO;
            V_ODP_NUM_CUENTA_CONSIGNAR := P_SEBRA_NUMERO_CUENTA;
            V_ODP_TCB_MNEMONICO := P_SEBRA_TIPO_CUENTA;
            BEGIN
              SELECT FIC_CODIGO_BOLSA, FIC_PER_TID_CODIGO
              INTO V_ODP_FIC_CODIGO_BOLSA , V_ODP_FIC_PER_TID_CODIGO
              FROM FIRMAS_COMISIONISTAS
              WHERE FIC_ESTADO = 'A' AND FIC_PER_NUM_IDEN = P_SEBRA_ID_CONTRAPARTE AND ROWNUM=1;
            EXCEPTION
              WHEN NO_DATA_FOUND THEN
                V_ODP_FIC_CODIGO_BOLSA := NULL;
                V_ODP_FIC_PER_TID_CODIGO:= NULL;
            END;
          END IF;

          IF P_TIPO_PAGO = 'TRB' THEN
            V_ODP_BAN_CODIGO := P_TR_BANC_ID_BANCO;
            V_ODP_NUM_CUENTA_CONSIGNAR := P_TR_BANC_CUENTA;
            V_ODP_TCB_MNEMONICO := P_TR_BANC_TIPO_CUENTA;


          END IF;

          IF P_TIPO_PAGO = 'ACH' THEN
            V_ODP_BAN_CODIGO := P_ACH_ID_BANCO;
            V_ODP_NUM_CUENTA_CONSIGNAR := P_ACH_CUENTA;
            V_ODP_TCB_MNEMONICO := P_ACH_TIPO_CUENTA;
            V_DETALLE_ACH := 'S';
          END IF;

        ELSE
          V_ODP_BAN_CODIGO := P_CODIGO_BANCO_PAGO;
          V_ODP_NUM_CUENTA_CONSIGNAR:= P_NUMERO_CUENTA_PAGO;
          V_ODP_TCB_MNEMONICO:= P_TIPO_CUENTA_PAGO;
          V_INS_ENV_DIRECCION := 'R';
        END IF;

                P_ORDEN_PAGO.PR_INSERTA_ORDEN_DE_PAGO(
                  P_ODP_SUC_CODIGO                  =>  1,
                  P_ODP_NEG_CONSECUTIVO             =>  2,
                  P_ODP_FECHA                       =>  SYSDATE,
                  P_ODP_COLOCADA_POR                =>  P_USUARIO,
                  P_ODP_TPA_MNEMONICO               =>  V_TPA_MNEMONICO,
                  P_ODP_ESTADO                      =>  'COL',
                  P_ODP_ES_CLIENTE                  =>  'S',--V_ODP_ES_CLIENTE, -- por solicitud de Miguel siempre va S
                  P_ODP_COT_MNEMONICO               =>  'PVT',
                  P_ODP_A_NOMBRE_DE                 =>  V_ODP_A_NOMBRE_DE,
                  P_ODP_FECHA_EJECUCION             =>  SYSDATE,
                  P_ODP_CONSIGNAR                   =>  V_ODP_CONSIGNAR,
                  P_ODP_ENTREGAR_RECOGE             =>  V_INS_ENV_DIRECCION,
                  P_ODP_ENVIA_FAX                   =>  V_INS_ENV_FAX,
                  P_ODP_SOBREGIRO                   =>  'N',
                  P_ODP_CRUCE_CHEQUE                =>  NVL(P_CRUCE, 'RP'),
                  P_ODP_MONTO_ORDEN                 =>  P_NETO_OPERACION_INT,--NULL,
                  P_ODP_MONTO_IMGF                  =>  NULL,
                  P_ODP_APROBADA_POR                =>  NULL,
                  P_ODP_FECHA_APROBACION            =>  NULL,
                  P_ODP_FORMA_DE_PAGO               =>  'S',
                  P_ODP_CCC_CLI_PER_NUM_IDEN        =>  P_CLI_NUM_IDEN,
                  P_ODP_CCC_CLI_PER_TID_CODIGO      =>  P_CLI_TID_CODIGO,
                  P_ODP_CCC_NUMERO_CUENTA           =>  P_CUENTA_CORREDORES,
                  P_ODP_PAGAR_A                     =>  V_ODP_PAGAR_A,
                  P_ODP_PER_NUM_IDEN                =>  NULL,
                  P_ODP_PER_TID_CODIGO              =>  NULL,
                  P_ODP_BAN_CODIGO                  =>  V_ODP_BAN_CODIGO,--P_CODIGO_BANCO_PAGO,
                  P_ODP_NUM_CUENTA_CONSIGNAR        =>  V_ODP_NUM_CUENTA_CONSIGNAR,--P_NUMERO_CUENTA_PAGO,
                  P_ODP_TCB_MNEMONICO               =>  V_ODP_TCB_MNEMONICO,--P_TIPO_CUENTA_PAGO,
                  P_ODP_OCL_CLI_PER_NUM_IDEN_R      =>  NULL,
                  P_ODP_OCL_CLI_PER_TID_CODIGO_R    =>  NULL,
                  P_ODP_CCC_CLI_PER_NUM_IDEN_T      =>  NULL,
                  P_ODP_CCC_CLI_PER_TID_CODIGO_T    =>  NULL,
                  P_ODP_CCC_NUMERO_CUENTA_T         =>  NULL,
                  P_ODP_CBA_BAN_CODIGO              =>  NULL,
                  P_ODP_CBA_NUMERO_CUENTA           =>  NULL,
                  P_ODP_MAS_INSTRUCCIONES           =>  P_MAS_INSTRUCCIONES_PAGO,
                  P_ODP_NUM_IDEN                    =>  V_ODP_NUM_IDEN,
                  P_ODP_TID_CODIGO                  =>  V_ODP_TID_CODIGO,
                  P_ODP_NPR_PRO_MNEMONICO           =>  'OB',
                  P_ODP_MEDIO_RECEPCION             =>  NULL,
                  P_ODP_DETALLE_MEDIO_RECEPCION     =>  NULL,
                  P_ODP_HORA_RECEPCION              =>  NULL,
                  P_ODP_PER_NUM_IDEN_ES_DUENO       =>  V_DUENO_NUM_IDEN,
                  P_ODP_PER_TID_CODIGO_ES_DUENO     =>  P_DUENO_TID_CODIGO,
                  P_ODP_FECHA_VERIFICA              =>  NULL,
                  P_ODP_TERMINAL_VERIFICA           =>  FN_TERMINAL,
                  P_ODP_VERIFICADO_COMERCIAL        =>  NULL,
                  P_ODP_DILIGENCIADA_POR            =>  NULL,
                  P_DETALLE_ACH                     =>  V_DETALLE_ACH,
                  P_ODP_OFO_CONSECUTIVO             =>  NULL,
                  P_ODP_OFO_SUC_CODIGO              =>  NULL,
                  P_ODP_TAC_MNEMONICO               =>  NULL,
                  P_ODP_FORMA_CARGUE_ACH            =>  'M',
                  P_ODP_CDD_CUENTA_CRCC             =>  NULL,
                  P_ODP_OVE_CONSECUTIVO             =>  P_ID_ORDEN,
                  P_ODP_OVE_BOL_MNEMONICO           =>  'COL' ,
                  P_ODP_OVE_COC_CTO_MNEMONICO       =>  'ACC' ,
                  P_ODP_CONSECUTIVO                 =>  V_ODP_CONSECUTIVO,
                  P_ODP_FIC_CODIGO_BOLSA            =>  V_ODP_FIC_CODIGO_BOLSA,
                  P_ODP_FIC_PER_TID_CODIGO          =>  V_ODP_FIC_PER_TID_CODIGO,
                  P_CUENTA_INSCRITA                 =>  P_CUENTA_INSCRITA,
                  P_SOPORTE_FISICO                  =>  P_SOPORTE_FISICO,
--MIGUEL PANDO 06/01/2021 VAGTUS060072 CAMBIAR EL VALOR DEL CAMPO ODP_ORDEN_MANUAL A N CUANDO LA ORDEN DE PAGO SE CREE DESDE @CCIONES
                  P_ODP_ORDEN_MANUAL                =>  'N',
                  P_ODP_FIC_PER_NUM_IDEN            =>  P_SEBRA_ID_CONTRAPARTE,
                  P_ERRORES                         =>  V_ERRORES_ODP
                );
                IF V_ERRORES_ODP > 0 THEN
                  V_ERRORES := V_ERRORES+V_ERRORES_ODP;
                  P_ID_ORDEN := NULL;
                  V_ODP_CONSECUTIVO := NULL;
                END IF;
              END IF;
            END IF;

            IF P_ID_ORDEN IS NOT NULL THEN
              IF V_CANAL_ORIGEN = 'Fix-I' THEN

                 P_TOOLS.CONSULTARCONSTANTE(P_CONSTANTE  => 'CS4',
                                            P_VALOR      => V_VALOR_CONS_INT,
                                            P_VALOR_DATE => V_VALOR_DATE_CONS,
                                            P_VALOR_CHAR => V_VALOR_SAE_S4);


                 IF  V_TIPO_PERSONA = 'PJU' THEN
                    V_NOC_CLI_PER_NUM_IDE := P_CLI_NUM_IDEN||'-'||P_CLIENTES.RT_DIGITO_CONTROL(P_CLI_NUM_IDEN);
                 ELSE
                    V_NOC_CLI_PER_NUM_IDE := P_CLI_NUM_IDEN;
                 END IF;
                 V_CUENTAS_DECEVAL := NULL;
                 IO_CURSOR_CUD     := NULL;
                 V_QUERY_CUD := 'SELECT CUD_CUENTA_DECEVAL,CUD_ESPECIAL_FIDUCIARIO FROM CUENTAS_DECEVAL'||
                                 ' WHERE CUD_CLI_PER_NUM_IDEN = '||CHR(39)||P_CLI_NUM_IDEN||CHR(39)||
                                 ' AND CUD_CLI_PER_TID_CODIGO = '||CHR(39)||P_CLI_TID_CODIGO||CHR(39)||
                                 ' AND CUD_ESTADO = ''A'' '||
                                 ' AND CUD_CUENTA_DECEVAL = '||V_TITULO_CTA_DVAL;

                 OPEN IO_CURSOR_CUD FOR V_QUERY_CUD;
                 LOOP
                    FETCH IO_CURSOR_CUD INTO  V_CUENTAS_DECEVAL.CUD_CUENTA_DECEVAL,
                                             V_CUENTAS_DECEVAL.CUD_ESPECIAL_FIDUCIARIO;
                    EXIT WHEN IO_CURSOR_CUD%NOTFOUND;
                 END LOOP;
                 CLOSE IO_CURSOR_CUD;

                 INSERT INTO NOTIFICACIONES_ORDENES_CMA(
                               NOC_CONSECUTIVO
                              ,NOC_FOLIO_BOLSA
                              ,NOC_CLI_PER_NUM_IDEN
                              ,NOC_CLI_PER_TID_CODIGO
                              ,NOC_CUENTA_DECEVAL
                              ,NOC_ID_COEASY
                              ,NOC_TIPO_NEGOCIO
                              ,NOC_PORCENTAJE_COMISION
                              ,NOC_USUARIO_SAE
                              ,NOC_ESPECIAL_FIDUCIARIO
                              ,NOC_CANTIDAD
                              ,NOC_PRECIO
                              ,NOC_ESTADO
                              ,NOC_FECHA_INGRESO
                              ,NOC_FECHA_ENTREGA
                              ,NOC_ENA_MNEMONICO
                              ,NOC_CANAL_ORIGEN
                              ,NOC_PER_NOMBRE_USUARIO
                              ,NOC_PER_NOMBRE
                              ,NOC_PER_APELLIDOS
                              ,NOC_COMISION_ESPECIAL_ETRADE)
                 VALUES(
                               NOC_SEQ.NEXTVAL                                 --NOC_CONSECUTIVO
                              ,P_ID_BOLSA                                       --NOC_FOLIO_BOLSA
                              ,V_NOC_CLI_PER_NUM_IDE                           --V_CUENTA_CCC.CCC_CLI_PER_NUM_IDEN               --NOC_CLI_PER_NUM_IDEN
                              ,P_CLI_TID_CODIGO                                --NOC_CLI_PER_TID_CODIGO
                              ,V_CUENTA_DECEVAL                                --NOC_CUENTA_DECEVAL
                              ,P_ID_ORDEN                                      --NOC_ID_COEASY
                              ,'V'                                             --NOC_TIPO_NEGOCIO
                              ,TRUNC(P_PORCENTAJE_COMISION,3)                  --NOC_PORCENTAJE_COMISION
                              ,V_VALOR_SAE_S4                                  --NOC_USUARIO_SAE
                              ,V_CUENTAS_DECEVAL.CUD_ESPECIAL_FIDUCIARIO       --NOC_ESPECIAL_FIDUCIARIO
                              ,P_CANTIDAD                                      --NOC_CANTIDAD
                              ,P_PRECIO_INTENCION                                        --NOC_PRECIO
                              ,'POR_PROCESAR'                                  --NOC_ESTADO
                              ,SYSDATE                                         --NOC_FECHA_INGRESO
                              ,NULL                                            --NOC_FECHA_ENTREGA
                              ,P_ESPECIE                                          --NOC_ENA_MNEMONICO
                              ,'3'--'S4'                                        --NOC_CANAL_ORIGEN
                              ,P_USUARIO                                     --NOC_PER_NOMBRE_USUARIO
                              ,V_PER_NOMBRE_PER                             --NOC_PER_NOMBRE
                              ,DECODE(V_TIPO_PERSONA,'PJU',' ',
                                      V_PER_APELLIDOS)   --NOC_PER_APELLIDOS)
                              ,'N');

              END IF;
           END IF;
         END IF;
         /**********************Renta Fija Venta********************************/
         ELSIF V_CANAL_ORIGEN IN( 'FIXRF','COMRF') AND V_RENTA_FIJA IS NOT NULL AND V_ERRORES=0 THEN
         /* CREACION DE LA ORDEN DE VENTA*/
         SELECT COR_SEQ.NEXTVAL INTO P_ID_ORDEN FROM DUAL;

            INSERT INTO CONSECUTIVO_ORDENES
           (COR_CONSECUTIVO
           ,COR_CLASE
           ,COR_BOLSA)
         VALUES
           (P_ID_ORDEN
           ,'RF'
           ,'COL');
       ----NULIFICAR CUANDO ES COMRF COMRV
         CASE
            WHEN V_CANAL_ORIGEN IN (V_VALOR_COMRV,V_VALOR_COMRF) THEN
               V_OVE_INCREMENTO_FONDO        := NULL;
               V_OVE_CFO_FON_CODIGO          := NULL;
               V_OVE_CFO_CODIGO              := NULL;
               V_OVE_MAS_INSTRUC_COBRO_PAGO  := NULL;
               V_OVE_NO_REGISTRA_INSTRUCCION := NULL;
               IF P_TITULO_CTA_DCV IS NOT NULL THEN  --VAGTUD885-3 Complementacion RF RV
                  V_ORDEN_DCV := 'S';
               ELSE
                 V_ORDEN_DCV := 'N';
               END IF;
            ELSE
               CASE
                  WHEN P_TIPO_INSTRUCCION = 'INC' THEN
                     V_OVE_INCREMENTO_FONDO := 'S';
                  ELSE
                     V_OVE_INCREMENTO_FONDO := 'N';
               END CASE;
               V_OVE_CFO_FON_CODIGO         := P_FONDO;
               V_OVE_CFO_CODIGO             := P_APORTE;
               V_OVE_MAS_INSTRUC_COBRO_PAGO := P_MAS_INSTRUCCIONES_PAGO;
               CASE
                  WHEN P_TIPO_INSTRUCCION IN ('NR', '') THEN
                     V_OVE_NO_REGISTRA_INSTRUCCION := 'S';
                  ELSE
                     V_OVE_NO_REGISTRA_INSTRUCCION := 'N';
               END CASE;
           END CASE;

/*
          INSERT INTO CONSECUTIVO_ORDENES --VAGTUD885-3 Complementacion RF RV
           (COR_CONSECUTIVO
           ,COR_CLASE
           ,COR_BOLSA)
         VALUES
           (P_ID_ORDEN
           ,'RF'
           ,DECODE(V_ORDEN_DCV,'S','MEC','COL'));
*/

            INSERT INTO ORDENES_VENTA
                   ( OVE_CONSECUTIVO
                    ,OVE_BOL_MNEMONICO
                    ,OVE_COC_CTO_MNEMONICO
                    ,OVE_COC_CCO_MNEMONICO
                    ,OVE_COC_CTE_MNEMONICO
                    ,OVE_PER_NUM_IDEN
                    ,OVE_PER_TID_CODIGO
                    ,OVE_CCC_CLI_PER_TID_CODIGO
                    ,OVE_CCC_CLI_PER_NUM_IDEN
                    ,OVE_CCC_NUMERO_CUENTA
                    ,OVE_RLC_PER_NUM_IDEN
                    ,OVE_RLC_PER_TID_CODIGO
                    ,OVE_RLC_ROL_CODIGO
                    ,OVE_VIO_MNEMONICO
                    ,OVE_CNE_MNEMONICO
                    ,OVE_TOC_MNEMONICO
                    ,OVE_EOC_MNEMONICO
                    ,OVE_ENA_MNEMONICO
                    ,OVE_LTI_MNEMONICO
                    ,OVE_FECHA_Y_HORA
                    ,OVE_FECHA_CRONOLOGICA
                    ,OVE_NOMINAL_O_PESOS
                    ,OVE_TIPO_NOMINAL_O_PESOS
                    ,OVE_OPERACION_TOTAL
                    ,OVE_EJECUTA_ORDEN_MESA
                    ,OVE_GIRAR
                    ,OVE_ABONO_CUENTA
                    ,OVE_ENVIAR_FAX_FACTURA
                    ,OVE_ENVIAR_FACTURA
                    ,OVE_DINERO_CONTRA_TITULOS
                    ,OVE_RECOGER_CARTA
                    ,OVE_RECOGER_CERT_CAMARA
                    ,OVE_ORIGEN_FUNGIBLE
                    ,OVE_FECHA_MODIFICACION
                    ,OVE_PRECIO_LIMITE_O_MARGEN
                    ,OVE_COMISION
                    ,OVE_TIPO_PAGO_ABONO_CUENTA
                    ,OVE_NUMERO_FAX
                    ,OVE_AGE_CODIGO_ENVIA_DOCUMENTO
                    ,OVE_DIRECCION_DOCUMENTOS
                    ,OVE_PREGUNTAR_POR_DOCUMENTOS
                    ,OVE_CFC_CUENTA_DECEVAL
                    ,OVE_CFC_FUG_ISI_MNEMONICO
                    ,OVE_CFC_FUG_MNEMONICO
                    ,OVE_FECHA_VERIFICA
                    ,OVE_TERMINAL_VERIFICA
                    ,OVE_PER_NUM_IDEN_ES_DUENO
                    ,OVE_PER_TID_CODIGO_ES_DUENO
                    ,OVE_VERIFICADO_COMERCIAL
                    ,OVE_FECHA_PERMANENCIA
                    ,OVE_MEDIO_RECEPCION
                    ,OVE_DETALLE_MEDIO_RECEPCION
                    ,OVE_HORA_RECEPCION
                    ,OVE_TIPO_MEC
                    ,OVE_PROFESIONAL
                    ,OVE_PER_NUM_IDEN_CTA
                    ,OVE_PER_TID_CODIGO_CTA
                    ,OVE_LEO_CONSECUTIVO
                    ,OVE_ORDEN_NEGOCIO
                    ,OVE_CONDICION_PRECIO
                    ,OVE_CRITERIOS_ADICIONALES
                    ,OVE_CANTIDAD_MINIMA
                    ,OVE_VISIBLE
                    ,OVE_PORCENTAJE_VISIBLE
                    ,OVE_STOP
                    ,OVE_PRECIO_STOP
                    ,OVE_HORA_DURACION
                    ,OVE_PERMITE_AGRUPAMIENTO
                    ,OVE_CANTIDAD_ACC
                    ,OVE_PRECIO_ACC
                    ,OVE_COMISION_ACC
                    ,OVE_IVA_ACC
                    ,OVE_TOTAL_OPERACION_ACC
                    ,OVE_NETO_OPERACION_ACC
                    ,OVE_FECHA_RECEPCION
                    ,OVE_CODIGO_INFORMADOR
                    ,OVE_TID_CODIGO_INFORMADOR
                    ,OVE_IDENTIFICACION_INFORMADOR
                    ,OVE_NOMBRE_INFORMADOR
                    ,OVE_CODIGO_OFICINA_INFORMADOR
                    ,OVE_FECHA_PRE_ORDEN
                    ,OVE_HORA_PRE_ORDEN
                    ,OVE_PER_TID_ENRUTA
                    ,OVE_PER_NUM_ENRUTA
                    ,OVE_CANAL_ORIGEN
                    ,OVE_TODO_NADA_OPA
                    ,OVE_ESTADO_BOLSA
                    ,OVE_TASA_REGISTRO
                     --App Complementacion RF RV
                    ,OVE_INCREMENTO_FONDO
                    ,OVE_CFO_FON_CODIGO
                    ,OVE_CFO_CODIGO
                    ,OVE_MAS_INSTRUC_COBRO_PAGO
                    ,OVE_NO_REGISTRA_INSTRUCCION
                    ,OVE_CDC_CUENTA_DCV  --VAGTUD885-3 Complementacion RF RV
          ,OVE_RECPROF_CONSECUTIVO 
                   ) VALUES

            ( P_ID_ORDEN
                  ,'MEC'
                  ,'RF'
                  ,DECODE(NVL(P_OPA,'N'),'S','EXT','ORD')
                  ,DECODE(NVL(P_OPA,'N'),'S','OPA','NA')
                  ,P_COLOCA_NUM_IDEN
                  ,P_COLOCA_TID_CODIGO
                  ,P_CLI_TID_CODIGO
                  ,P_CLI_NUM_IDEN
                  ,P_CUENTA_CORREDORES
                  ,C_ORDENANTE.RLC_PER_NUM_IDEN
                  ,C_ORDENANTE.RLC_PER_TID_CODIGO
                  ,C_ORDENANTE.RLC_ROL_CODIGO
                  ,DECODE(NVL(P_OPA,'N'),'S','HCA',P_VIG_TIPO_VIGENCIA)
                  ,DECODE(NVL(P_VENTA_CORTO,'N'),'S','VCO','CON')
                  ,'MER'
                  ,DECODE(V_CANAL_ORIGEN,'PLV','PCO',
                                       DECODE(NVL(P_OPA,'N'),'S','COL',
                                        DECODE(V_LEO,5,'COL',
                                               'COL')))                                 --OVE_EOC_MNEMONICO
                  ,P_ESPECIE
                  ,DECODE(V_ORDEN_DCV ,'S','DV','DA')                                   --OVE_LTI_MNENICO
                  ,SYSDATE
                  ,SYSDATE
                  ,P_CANTIDAD
                  ,'N'
                  ,'N'
                  ,C_INICIALES.PER_EJECUTA_ORDEN_MESA
                  ,V_OVE_GIRAR
                  ,V_ABONO_CUENTA
                  ,V_INS_ENV_FAX
                  ,V_INS_ENV_DIRECCION
                  ,'N'
                  ,'N'
                  ,'N'
                  ,P_TITULO_ORIGEN
                  ,SYSDATE
                  ,P_COND_PRECIO_LIMITIE
                  ,P_PORCENTAJE_COMISION
                  ,V_OVE_TIPO_ABONO
                  ,P_INS_ENV_NUM_FAX
                  ,P_INS_ENV_COD_CIUDAD
                  ,P_INS_ENV_NUM_DIRECCION
                  ,P_INS_ENV_CONTACTO
                  ,V_TITULO_CTA_DVAL
                  ,P_TITULO_COD_ISIN
                  ,P_TITULO_COD_FUNGIBLE
                  , DECODE(C_INICIALES.PER_TIPO_COMERCIAL,'C',SYSDATE,   --cambio de datos
                                                          'P',SYSDATE,
                                                                  NULL)
                  ,DECODE(C_INICIALES.PER_TIPO_COMERCIAL,'C',substr(P_COLOCA_TERMINAL,1,20),
                                                         'P',substr(P_COLOCA_TERMINAL,1,20),
                                                         NULL)                --OVE_TERMINAL_VERIFICA
                  ,V_DUENO_NUM_IDEN
                  ,P_DUENO_TID_CODIGO
                  ,'S'
                  ,DECODE(NVL(P_OPA,'N'),'S',NULL,TO_DATE(P_VIG_FECHA_PERMANENCI,'DD-MM-YYYY HH24:MI:SS'))    --OVE_FECHA_PERMANENCIA
                  ,P_INS_REC_MEDIO
                  ,P_INS_REC_DETALLE
                  ,P_INS_REC_HORA
                  ,'MT'
                  ,DECODE(P_CLI_PROFESIONAL,'1','S','N')
                  ,DECODE(P_CLI_NUM_IDEN,'860079174',NULL,V_DUENO_NUM_IDEN)
                  ,DECODE(P_CLI_NUM_IDEN,'860079174',NULL,P_DUENO_TID_CODIGO)
                  ,V_LEO
                  ,'N' --OTC
                  ,null
                  ,null
                  ,null
                  ,null
                  ,null
                  ,null
                  ,null
                  ,P_VIG_HORA_PERMANENCIA
                  ,null
                  ,NVL(P_CANTIDAD_INTENCION,0)                                --OVE_CANTIDAD_ACC
                  ,NVL(P_PRECIO_INTENCION,0)                                  --OVE_PRECIO_ACC
                  ,NVL(P_COMISION_INTENCION,0)                                --OVE_COMISION_ACC
                  ,NVL(P_IVA_ITENCION,0)                                      --OVE_IVA_ACC
                  ,NVL(P_TOTAL_OPERACION_INT,0)                               --OVE_TOTAL_OPERACION_ACC
                  ,NVL(P_NETO_OPERACION_INT,0)
                  ,TO_DATE(V_FECHA_RECEPCION,'dd/mm/yyyy')
                  ,P_CODIGO_INFORMADOR
                  ,P_TID_CODIGO_INFORMADOR
                  ,P_NUM_IDEN_INFORMADOR
                  ,P_NOMBRE_INFORMADOR
                  ,P_CODIGO_OFICINA_INFOR
                  ,TO_DATE(P_FECHA_PRE_ORDEN_INFOR,'dd/mm/yyyy')
                  ,P_HORA_PRE_ORDEN_INFOR
                  ,V_PER_TID_ENRUTA
                  ,V_PER_NUM_ENRUTA
                  ,V_CANAL_ORIGEN
                  ,DECODE(NVL(P_OPA,'N'),'S',NVL(P_TODO_NADA_OPA,'N'),NULL)   --OVE_TODO_NADA_OPA IN ('S', 'N')
                  ,DECODE(V_CANAL_ORIGEN,'Fix-I','REG',NULL)                  --OVE_ESTADO_BOLSA
                  ,3
                  --App Complementacion RF Rv 19/11/2020
                  ,V_OVE_INCREMENTO_FONDO                                     --OVE_INCREMENTO_FONDO -- fdm fondos inversion
                  ,V_OVE_CFO_FON_CODIGO                                       --OVE_CFO_FON_CODIGO
                  ,V_OVE_CFO_CODIGO                                           --OVE_CFO_CODIGO
                  ,V_OVE_MAS_INSTRUC_COBRO_PAGO                               --OVE_MAS_INSTRUC_COBRO_PAGO
                  ,V_OVE_NO_REGISTRA_INSTRUCCION                              --OVE_NO_REGISTRA_INSTRUCCION -- fdm sin instruccion desde @cciones
                  ,DECODE(V_ORDEN_DCV ,'S',P_TITULO_CTA_DCV,NULL)             -- OVE_CDC_CUENTA_DCV -weis VAGTUS
                  ,P_RECPROF_CONSECUTIVO                                      --OVE_RECPROF_CONSECUTIVO
            );

          IF SQL%ROWCOUNT = 0 THEN
            P_ID_ORDEN := NULL;
            V_ERRORES := V_ERRORES+1;
      else
      --Asociar la orden de venta a una orden pago CUANDO ES COMRV Y COMRF.
      BEGIN
         CASE
          WHEN V_CANAL_ORIGEN IN (V_VALOR_COMRF, V_VALOR_COMRV) THEN
           IF (V_ABONO_CUENTA = 'N' AND P_CODIGO_BANCO_PAGO IS NOT NULL)
           --OR
            --(V_CANAL_ORIGEN IN ('ACC-E', 'UDF-A', 'ACC', V_VALOR_COMRV)
            --)
            AND P_TIPO_INSTRUCCION = 'PG' /*AND P_TIPO_INSTRUCCION NOT IN ('NR')*/
            THEN
            -- fdm pone esta parte al if para tener en cuenta @ccciones
            IF V_LEO IN (9, 3, 2) THEN
               --pendiente leo
               V_ERRORES_ODP     := 0;
               V_ODP_CONSECUTIVO := NULL;
               SELECT DECODE(P_PAGAR_A_PAGO, 'C', V_PER_NOMBRE, 'B', P_NOMBRE_CUENTA_PAGO, 'T', P_NOMBRE_CUENTA_PAGO)
                 ,DECODE(P_PAGAR_A_PAGO, 'C', 'C', 'B', 'T', 'T', 'T')
                 ,DECODE(P_PAGAR_A_PAGO, 'T', P_NUM_IDEN_PAGO, 'B', P_NUM_IDEN_PAGO, NULL)
                 ,DECODE(P_PAGAR_A_PAGO, 'T', P_TIPO_IDEN_PAGO, 'B', P_TIPO_IDEN_PAGO, NULL)
               INTO V_ODP_A_NOMBRE_DE
                 ,V_ODP_PAGAR_A
                 ,V_ODP_NUM_IDEN
                 ,V_ODP_TID_CODIGO
               FROM DUAL;

               IF P_CODIGO_BANCO_PAGO <> 51 THEN
                V_TPA_MNEMONICO := 'ACH';
                V_ODP_CONSIGNAR := 'N';
                V_DETALLE_ACH   := 'S';
               ELSE
                V_TPA_MNEMONICO := 'TRB';
                V_ODP_CONSIGNAR := 'S';
                V_DETALLE_ACH   := 'N';
               END IF;

               V_ODP_ES_CLIENTE := 'N';

               IF (P_TIPO_PAGO IS NOT NULL OR LENGTH(P_TIPO_PAGO) > 0) AND V_CANAL_ORIGEN IN ('ACC-E', 'UDF-A', 'ACC') THEN
                /* fdm cuando viene de @cciones, y trae tipo de pago */

                V_TPA_MNEMONICO   := P_TIPO_PAGO;
                V_DETALLE_ACH     := 'N'; --DUDA ACA!!!
                V_ODP_A_NOMBRE_DE := P_PAGAR_A;

                IF P_ABONO_CUENTA <> 'S' OR P_ABONO_CUENTA IS NULL THEN
                 --V_ODP_PAGAR_A := P_PAGAR_A;
                 SELECT DECODE(P_PAGAR_A, 'C', 'C', 'B', 'O', 'T', 'T') INTO V_ODP_PAGAR_A FROM DUAL;
                END IF;
                IF P_INS_ENV_DIRECCION = 1 THEN
                 V_INS_ENV_DIRECCION := 'E';
                ELSE
                 V_INS_ENV_DIRECCION := 'R';
                END IF;
                IF P_CONSIGNAR = 'S' THEN
                 V_ODP_CONSIGNAR := P_CONSIGNAR;
                ELSE
                 V_ODP_CONSIGNAR := 'N';
                END IF;
                IF P_PAGAR_A = 'C' THEN
                 V_ODP_ES_CLIENTE := 'S';
                ELSE
                 V_ODP_ES_CLIENTE := 'N';
                END IF;
                IF P_PAGAR_A = 'T' THEN
                 V_ODP_A_NOMBRE_DE := P_TERCERO_NOMBRE;
                 V_ODP_TID_CODIGO  := P_TERCERO_TIPO_ID;
                 V_ODP_NUM_IDEN    := P_TERCERO_NUMERO_ID;
                END IF;
                IF P_PAGAR_A = 'O' THEN
                 V_ODP_A_NOMBRE_DE := P_ORDENANTE;
                 V_ODP_TID_CODIGO  := P_ORDENANTE_TID_CODIGO;
                 V_ODP_NUM_IDEN    := P_ORDENANTE_NUM_IDEN;
                END IF;

                IF P_TIPO_PAGO IN ('CHE', 'CHG') THEN
                 V_ODP_BAN_CODIGO           := P_CONSIGNAR_BANCO;
                 V_ODP_NUM_CUENTA_CONSIGNAR := P_CONSIGNAR_CUENTA;
                 V_ODP_TCB_MNEMONICO        := P_CONSIGNAR_TIPO_CUENTA;
                END IF;

                IF P_TIPO_PAGO = 'PSE' THEN
                 V_ODP_BAN_CODIGO           := P_SEBRA_ID_BANCO;
                 V_ODP_NUM_CUENTA_CONSIGNAR := P_SEBRA_NUMERO_CUENTA;
                 V_ODP_TCB_MNEMONICO        := P_SEBRA_TIPO_CUENTA;
                 BEGIN
                  SELECT FIC_CODIGO_BOLSA
                      ,FIC_PER_TID_CODIGO
                    INTO V_ODP_FIC_CODIGO_BOLSA
                      ,V_ODP_FIC_PER_TID_CODIGO
                    FROM FIRMAS_COMISIONISTAS
                   WHERE FIC_ESTADO = 'A'
                     AND FIC_PER_NUM_IDEN = P_SEBRA_ID_CONTRAPARTE
                     AND ROWNUM = 1;
                 EXCEPTION
                  WHEN NO_DATA_FOUND THEN
                     V_ODP_FIC_CODIGO_BOLSA   := NULL;
                     V_ODP_FIC_PER_TID_CODIGO := NULL;
                 END;
                END IF;

                IF P_TIPO_PAGO = 'TRB' THEN
                 V_ODP_BAN_CODIGO           := P_TR_BANC_ID_BANCO;
                 V_ODP_NUM_CUENTA_CONSIGNAR := P_TR_BANC_CUENTA;
                 V_ODP_TCB_MNEMONICO        := P_TR_BANC_TIPO_CUENTA;

                END IF;

                IF P_TIPO_PAGO = 'ACH' THEN
                 V_ODP_BAN_CODIGO           := P_ACH_ID_BANCO;
                 V_ODP_NUM_CUENTA_CONSIGNAR := P_ACH_CUENTA;
                 V_ODP_TCB_MNEMONICO        := P_ACH_TIPO_CUENTA;
                 V_DETALLE_ACH              := 'S';
                END IF;

               ELSE
                V_ODP_BAN_CODIGO           := P_CODIGO_BANCO_PAGO;
                V_ODP_NUM_CUENTA_CONSIGNAR := P_NUMERO_CUENTA_PAGO;
                V_ODP_TCB_MNEMONICO        := P_TIPO_CUENTA_PAGO;
                V_INS_ENV_DIRECCION        := 'R';
               END IF;

               P_ORDEN_PAGO.PR_INSERTA_ORDEN_DE_PAGO(P_ODP_SUC_CODIGO               => 1,
                                 P_ODP_NEG_CONSECUTIVO          => 2,
                                 P_ODP_FECHA                    => SYSDATE,
                                 P_ODP_COLOCADA_POR             => P_USUARIO,
                                 P_ODP_TPA_MNEMONICO            => V_TPA_MNEMONICO,
                                 P_ODP_ESTADO                   => 'COL',
                                 P_ODP_ES_CLIENTE               => 'S', --V_ODP_ES_CLIENTE, -- por solicitud de Miguel siempre va S
                                 P_ODP_COT_MNEMONICO            => 'PVT',
                                 P_ODP_A_NOMBRE_DE              => V_ODP_A_NOMBRE_DE,
                                 P_ODP_FECHA_EJECUCION          => SYSDATE,
                                 P_ODP_CONSIGNAR                => V_ODP_CONSIGNAR,
                                 P_ODP_ENTREGAR_RECOGE          => V_INS_ENV_DIRECCION,
                                 P_ODP_ENVIA_FAX                => V_INS_ENV_FAX,
                                 P_ODP_SOBREGIRO                => 'N',
                                 P_ODP_CRUCE_CHEQUE             => NVL(P_CRUCE, 'RP'),
                                 P_ODP_MONTO_ORDEN              => P_NETO_OPERACION_INT, --NULL,
                                 P_ODP_MONTO_IMGF               => NULL,
                                 P_ODP_APROBADA_POR             => NULL,
                                 P_ODP_FECHA_APROBACION         => NULL,
                                 P_ODP_FORMA_DE_PAGO            => 'S',
                                 P_ODP_CCC_CLI_PER_NUM_IDEN     => P_CLI_NUM_IDEN,
                                 P_ODP_CCC_CLI_PER_TID_CODIGO   => P_CLI_TID_CODIGO,
                                 P_ODP_CCC_NUMERO_CUENTA        => P_CUENTA_CORREDORES,
                                 P_ODP_PAGAR_A                  => V_ODP_PAGAR_A,
                                 P_ODP_PER_NUM_IDEN             => NULL,
                                 P_ODP_PER_TID_CODIGO           => NULL,
                                 P_ODP_BAN_CODIGO               => V_ODP_BAN_CODIGO, --P_CODIGO_BANCO_PAGO,
                                 P_ODP_NUM_CUENTA_CONSIGNAR     => V_ODP_NUM_CUENTA_CONSIGNAR, --P_NUMERO_CUENTA_PAGO,
                                 P_ODP_TCB_MNEMONICO            => V_ODP_TCB_MNEMONICO, --P_TIPO_CUENTA_PAGO,
                                 P_ODP_OCL_CLI_PER_NUM_IDEN_R   => NULL,
                                 P_ODP_OCL_CLI_PER_TID_CODIGO_R => NULL,
                                 P_ODP_CCC_CLI_PER_NUM_IDEN_T   => NULL,
                                 P_ODP_CCC_CLI_PER_TID_CODIGO_T => NULL,
                                 P_ODP_CCC_NUMERO_CUENTA_T      => NULL,
                                 P_ODP_CBA_BAN_CODIGO           => NULL,
                                 P_ODP_CBA_NUMERO_CUENTA        => NULL,
                                 P_ODP_MAS_INSTRUCCIONES        => P_MAS_INSTRUCCIONES_PAGO,
                                 P_ODP_NUM_IDEN                 => V_ODP_NUM_IDEN,
                                 P_ODP_TID_CODIGO               => V_ODP_TID_CODIGO,
                                 P_ODP_NPR_PRO_MNEMONICO        => 'OB',
                                 P_ODP_MEDIO_RECEPCION          => NULL,
                                 P_ODP_DETALLE_MEDIO_RECEPCION  => NULL,
                                 P_ODP_HORA_RECEPCION           => NULL,
                                 P_ODP_PER_NUM_IDEN_ES_DUENO    => V_DUENO_NUM_IDEN,
                                 P_ODP_PER_TID_CODIGO_ES_DUENO  => P_DUENO_TID_CODIGO,
                                 P_ODP_FECHA_VERIFICA           => NULL,
                                 P_ODP_TERMINAL_VERIFICA        => FN_TERMINAL,
                                 P_ODP_VERIFICADO_COMERCIAL     => NULL,
                                 P_ODP_DILIGENCIADA_POR         => NULL,
                                 P_DETALLE_ACH                  => V_DETALLE_ACH,
                                 P_ODP_OFO_CONSECUTIVO          => NULL,
                                 P_ODP_OFO_SUC_CODIGO           => NULL,
                                 P_ODP_TAC_MNEMONICO            => NULL,
                                 P_ODP_FORMA_CARGUE_ACH         => 'M',
                                 P_ODP_CDD_CUENTA_CRCC          => NULL,
                                 P_ODP_OVE_CONSECUTIVO          => P_ID_ORDEN,
                                 P_ODP_OVE_BOL_MNEMONICO        => 'COL',
                                 P_ODP_OVE_COC_CTO_MNEMONICO    => 'ACC',
                                 P_ODP_CONSECUTIVO              => V_ODP_CONSECUTIVO,
                                 P_ODP_FIC_CODIGO_BOLSA         => V_ODP_FIC_CODIGO_BOLSA,
                                 P_ODP_FIC_PER_TID_CODIGO       => V_ODP_FIC_PER_TID_CODIGO,
                                 P_CUENTA_INSCRITA              => P_CUENTA_INSCRITA,
                                 P_SOPORTE_FISICO               => P_SOPORTE_FISICO,
--22/01/2021                                 P_ODP_ORDEN_MANUAL             => 'S',
                                 P_ODP_ORDEN_MANUAL             => 'N',
                                 P_ODP_FIC_PER_NUM_IDEN         => P_SEBRA_ID_CONTRAPARTE,
                                 P_ERRORES                      => V_ERRORES_ODP);
               IF V_ERRORES_ODP > 0 THEN
                V_ERRORES         := V_ERRORES + V_ERRORES_ODP;
                P_ID_ORDEN        := NULL;
                V_ODP_CONSECUTIVO := NULL;
               END IF;
            END IF;
           END IF;
          ELSE
           V_ODP_CONSECUTIVO := NULL;
         END CASE;
      END;

      END IF;

       ELSE
         P_ID_ORDEN := NULL;
         V_ERRORES := V_ERRORES+1;
       END IF;
     END IF;
   END IF;
   IF V_ERRORES = 0 THEN
     IF  P_INS_REC_DETALLE = 'Internet S2 Saldo' THEN
        -- ELIMINAR ORDENES DE COMPRA O VENTA EN ESTADP PCO
        IF P_TIPO_ORDEN = 'C' THEN
           DELETE ORDENES_COMPRA
           WHERE OCO_CONSECUTIVO       = P_ID_ORDEN
             AND OCO_BOL_MNEMONICO     = 'COL'
             AND OCO_COC_CTO_MNEMONICO = 'ACC';
        END IF;

        IF P_TIPO_ORDEN = 'V' THEN
           DELETE ORDENES_VENTA
           WHERE OVE_CONSECUTIVO       = P_ID_ORDEN
             AND OVE_BOL_MNEMONICO     = 'COL'
             AND OVE_COC_CTO_MNEMONICO = 'ACC';
        END IF;
     END IF;


   --WILLIAM CAMPOS 03/04/2020 VAGTUS052320 Analizar tiempos de ejecucion hasta el 8/04/2020
       --P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_ORDENES_COMERCIAL.P_COLOCAR_ORDEN','FIN:' || P_CANAL_ORIGEN);
      -- WILLIAM CAMPOS 03/04/2020 SE COMPARAN EL TIEMPO DE EJECUCION DE LA ORDEN , SI ES MAYOR A 15 SEGUNDOS , VA A HACER ROLLBACK.
      P_FIN_ORDEN:= SYSDATE;
          select (( P_INI_ORDEN - P_FIN_ORDEN ) * 86400 ) * -1 INTO P_DIF_MIN_ORDEN from DUAL ;
           IF P_DIF_MIN_ORDEN >= 15 THEN
            ROLLBACK;            -- Guarda los datos en la tabla EJECUCION_PROCESOS_NOCTURNOS
            P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('ROLLBACK COLOCAR_ORDEN T: '|| P_DIF_MIN_ORDEN ,'OTR');
            RAISE_APPLICATION_ERROR(-20002,'VUELVE A INTENTAR EN UN MINUTO.');
           ELSE
            COMMIT;
           END IF;
      -- FIN WILLIAM CAMPOS
   ELSE
     P_CLOB := P_CAB.ObtenerCLOB_ERROR('ColocarOrden') ;
   END IF;
END IF;
EXCEPTION
   WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20001,'Error en procedimientoP_COLOCAR_ORDEN: '||sqlerrm);
END P_COLOCAR_ORDEN;




PROCEDURE P_ORDENACTUALIZARESTADO (P_TIPO_ORDEN   IN VARCHAR2,
                                   P_ID_ORDEN     IN NUMBER,
                                   P_ESTADO       IN VARCHAR2,
                                   P_USUARIO      IN VARCHAR2,
                                   P_TID_CODIGO   IN VARCHAR2,
                                   P_NUM_IDEN     IN VARCHAR2,
                                   P_TERMINAL     IN VARCHAR2) IS
BEGIN
  IF P_ESTADO IN ('REG') THEN
    IF P_TIPO_ORDEN = 'C' THEN
      UPDATE ORDENES_COMPRA
        SET OCO_ESTADO_BOLSA = P_ESTADO
           ,OCO_PER_NUM_IDEN_ES_MODIFICADA =P_NUM_IDEN
           ,OCO_PER_TID_CODIGO_ES_MODIFICA = P_TID_CODIGO
        WHERE OCO_CONSECUTIVO = P_ID_ORDEN
          AND OCO_BOL_MNEMONICO = 'COL'
          AND OCO_COC_CTO_MNEMONICO = 'ACC';
      IF SQL%ROWCOUNT = 0 THEN
        RAISE_APPLICATION_ERROR(-20001,'Error actualizando estado orden:'||P_TIPO_ORDEN||'-'||P_ID_ORDEN ) ;
      END IF;
      COMMIT;
    ELSIF P_TIPO_ORDEN = 'V' THEN
        UPDATE ORDENES_VENTA
        SET OVE_ESTADO_BOLSA = P_ESTADO
           ,OVE_PER_NUM_IDEN_ES_MODIFICADA =P_NUM_IDEN
           ,OVE_PER_TID_CODIGO_ES_MODIFICA = P_TID_CODIGO
        WHERE OVE_CONSECUTIVO = P_ID_ORDEN
          AND OVE_BOL_MNEMONICO = 'COL'
          AND OVE_COC_CTO_MNEMONICO = 'ACC';
      IF SQL%ROWCOUNT = 0 THEN
        RAISE_APPLICATION_ERROR(-20002,'Error actualizando estado orden:'||P_TIPO_ORDEN||'-'||P_ID_ORDEN ) ;
      END IF;
      COMMIT;
    END IF;
  ELSE
    RAISE_APPLICATION_ERROR(-20003,'Tipo de estado invalido:'||P_TIPO_ORDEN||'-'||P_ID_ORDEN ) ;
  END IF;
END P_ORDENACTUALIZARESTADO ;

PROCEDURE P_ORDEN_CANCELAR(P_TIPO_ORDEN    IN VARCHAR2,
                           P_ID_ORDEN      IN NUMBER,
                           P_FECHA         IN DATE,
                           P_MOTIVO        IN VARCHAR2,
                           P_USUARIO       IN VARCHAR2,
                           P_TID_CODIGO    IN VARCHAR2,
                           P_NUM_IDEN      IN VARCHAR2,
                           P_TERMINAL      IN VARCHAR2,
                           P_ERRORES       IN OUT NUMBER,
                           /**WGONZALEZ**/
                           P_INS_REC_HORA    IN VARCHAR2 DEFAULT NULL,
                           P_INS_REC_MEDIO   IN VARCHAR2 DEFAULT NULL,
                           P_INS_REC_DETALLE IN VARCHAR2 DEFAULT NULL,
                           P_CANAL_ORIGEN    IN VARCHAR2 DEFAULT NULL,
                           P_USUARIO_RECEPCION IN VARCHAR2 DEFAULT NULL) IS
   CURSOR C_ANULADO IS
      SELECT OCO_EOC_MNEMONICO, OCO_ESTADO_BOLSA
      FROM   ORDENES_COMPRA
      WHERE  OCO_BOL_MNEMONICO = 'COL'
      AND    OCO_COC_CTO_MNEMONICO = 'ACC'
      AND    OCO_CONSECUTIVO = P_ID_ORDEN;
   ANULADO   C_ANULADO%ROWTYPE;
   CURSOR C_OFERTA IS
      SELECT 'X'
      FROM   OFERTAS_DEMANDAS_POSICION
      WHERE  OFD_OCO_CONSECUTIVO = P_ID_ORDEN
      AND    OFD_OCO_BOL_MNEMONICO = 'COL'
      AND    OFD_OCO_COC_CTO_MNEMONICO = 'ACC'
      AND    OFD_ESTADO != 'ANU';
   COND   VARCHAR2(1);
  CURSOR C_ANULADO_V IS
      SELECT OVE_EOC_MNEMONICO, OVE_ESTADO_BOLSA
      FROM   ORDENES_VENTA
      WHERE  OVE_BOL_MNEMONICO = 'COL'
      AND    OVE_COC_CTO_MNEMONICO = 'ACC'
      AND    OVE_CONSECUTIVO = P_ID_ORDEN;
   ANULADO_OVE1   C_ANULADO_V%ROWTYPE;
   CURSOR C_NEGOCIOS IS
      SELECT 'X'
      FROM   NEGOCIOS_POSICION
      WHERE  NPO_OVE_CONSECUTIVO = P_ID_ORDEN
      AND    NPO_OVE_BOL_MNEMONICO = 'COL'
      AND    NPO_OVE_COC_CTO_MNEMONICO = 'ACC'
      AND    NPO_ESTADO != 'ANU';
   COND_V  VARCHAR2(1);

   /******WGONZALEZ*******/

   CURSOR ORDE_ANU IS
      SELECT ORDE_CONSECUTIVO
            ,ORDE_EOC_MNEMONICO
      FROM   ORDENES_DERIVADOS
      WHERE  ORDE_BOL_MNEMONICO = 'BOG'
        AND  ORDE_CONSECUTIVO = P_ID_ORDEN
        AND  ORDE_CANAL_ORIGEN = 'FIXBR';

   R_ANULADO   ORDE_ANU%ROWTYPE;
   V_SQL VARCHAR2(4000);
BEGIN
   P_ERRORES := 0;

IF P_CANAL_ORIGEN IN ('FIXBR') THEN

   OPEN ORDE_ANU;
   FETCH ORDE_ANU INTO R_ANULADO;
      IF ORDE_ANU%NOTFOUND THEN
         P_CAB.CREARERROR('La orden de derivados ' || TO_CHAR(R_ANULADO.ORDE_CONSECUTIVO) ||  ' no existe '
              || '. No puede hacer la cancelacion de la Orden');
         P_ERRORES := P_ERRORES+1;
      ELSIF R_ANULADO.ORDE_EOC_MNEMONICO = 'ANU' THEN
         P_CAB.CREARERROR('La orden de derivados ' || TO_CHAR(R_ANULADO.ORDE_CONSECUTIVO) ||  ' ya fue cancelada por otro usuario '
              || '. No puede hacer la cancelacion de la Orden');
         P_ERRORES := P_ERRORES+1;
      ELSIF R_ANULADO.ORDE_EOC_MNEMONICO IN ('APL','PAP') THEN
         P_CAB.CREARERROR('La orden de derivados ' || TO_CHAR(R_ANULADO.ORDE_CONSECUTIVO) ||  ' se encuentra en estado invalido'
              || '. No puede hacer la cancelacion de la Orden');
         P_ERRORES := P_ERRORES+1;
      END IF;
   CLOSE ORDE_ANU;

   IF P_ERRORES = 0 THEN
         IF P_TERMINAL = 'SOLCLI' THEN
            UPDATE ORDENES_DERIVADOS
               SET ORDE_EOC_MNEMONICO           = 'ANU'
                  ,ORDE_ANU_CAN_POR             = P_USUARIO
                  ,ORDE_RAZON_ANU_CAN           = P_MOTIVO
                  ,ORDE_FECHA_ANU_CAN           = SYSDATE--TO_DATE(SYSDATE,'DD/MM/YYYY HH24:MI:SS')
                  ,ORDE_HORA_RECEPCION          = P_INS_REC_HORA
                  ,ORDE_MEDIO_RECEPCION         = DECODE(P_INS_REC_MEDIO,'INT','OTR',P_INS_REC_MEDIO)
                  ,ORDE_DETALLE_MEDIO_RECEPCION = P_INS_REC_DETALLE
                  ,ORDE_USUARIO_RECEPCION       = P_USUARIO_RECEPCION
                  ,ORDE_ULTIMA_ACTUALIZACION    = 'ANU'
             WHERE ORDE_CONSECUTIVO = P_ID_ORDEN;--R_ANULADO.ORDE_CONSECUTIVO;
         ELSIF P_TERMINAL = 'REGERR' THEN
            UPDATE ORDENES_DERIVADOS
               SET ORDE_EOC_MNEMONICO           = 'ANU'
                  ,ORDE_ANU_CAN_POR             = P_USUARIO
                  ,ORDE_RAZON_ANU_CAN           = P_MOTIVO
                  ,ORDE_FECHA_ANU_CAN           = SYSDATE--TO_DATE(SYSDATE,'DD/MM/YYYY HH24:MI:SS')
                  ,ORDE_ULTIMA_ACTUALIZACION    = 'ANU'
             WHERE ORDE_CONSECUTIVO = P_ID_ORDEN;--R_ANULADO.ORDE_CONSECUTIVO;
         END IF;

       IF SQL%ROWCOUNT = 0 THEN
          V_SQL := SQLERRM;
          RAISE_APPLICATION_ERROR(-20002,'Orden:'||P_TIPO_ORDEN||'-'||R_ANULADO.ORDE_CONSECUTIVO ||' no existe .. no es posible cancelarla '||V_SQL) ;
       END IF;
       COMMIT;
   END IF;
ELSE
   IF P_TIPO_ORDEN = 'C' THEN
      OPEN C_ANULADO;
      FETCH C_ANULADO INTO ANULADO;
      IF C_ANULADO%NOTFOUND THEN
        P_CAB.CrearError('La orden de compra ' || TO_CHAR(P_ID_ORDEN) ||  ' no existe '
              || '. No puede hacer la cancelaciżn de la compra');
          P_ERRORES := P_ERRORES+1;
      ELSE
        IF ANULADO.OCO_ESTADO_BOLSA = 'CPC' THEN
          --P_CAB.CrearError('La orden ya fue cancelada por otro usuario');
          P_ERRORES := 0;
        END IF;
        --IF ANULADO.OCO_EOC_MNEMONICO NOT IN ('PAP','COL') THEN
         -- P_CAB.CrearError('La orden de compra ' || TO_CHAR(P_ID_ORDEN) ||  ' se encuentra en estado invalido'
          --    || '. No puede hacer la cancelaciżn de la compra');
          --P_ERRORES := P_ERRORES+1;
        --END IF;
      END IF;
      CLOSE C_ANULADO;
      OPEN C_OFERTA;
      FETCH C_OFERTA INTO COND;
      CLOSE C_OFERTA;
      IF NVL(COND,' ') = 'X' THEN
        P_CAB.CrearError('La orden esta asociada a una oferta de posiciżn (primario, simultanea, etc). No se puede cancelar');
        P_ERRORES := P_ERRORES+1;
      END IF;
      IF P_ERRORES = 0 AND NVL(ANULADO.OCO_ESTADO_BOLSA,' ') != 'CPC' AND ANULADO.OCO_EOC_MNEMONICO IN ('PAP','COL')  THEN
         UPDATE ORDENES_COMPRA
         SET    OCO_ESTADO_BOLSA        = 'CPC'
              ,OCO_FECHA_MODIFICACION  = SYSDATE
              /*osjtorres para que quede la traza*/
              ,OCO_ANU_CAN_POR          = P_USUARIO
              ,OCO_FECHA_ANU_CAN        = P_FECHA
              ,OCO_TERMINAL_ANU_CAN     = P_TERMINAL
              /*Fin Osjtorres*/
              ,OCO_PER_NUM_IDEN_ES_MODIFICADA = P_NUM_IDEN
              ,OCO_PER_TID_CODIGO_ES_MODIFICA = P_TID_CODIGO
        WHERE OCO_CONSECUTIVO = P_ID_ORDEN
          AND OCO_BOL_MNEMONICO = 'COL'
          AND OCO_COC_CTO_MNEMONICO = 'ACC';
        IF SQL%ROWCOUNT = 0 THEN
          RAISE_APPLICATION_ERROR(-20001,'Orden:'||P_TIPO_ORDEN||'-'||P_ID_ORDEN ||' no existe .. no es posible cancelarla') ;
        END IF;
        COMMIT;
      END IF;
   ELSIF P_TIPO_ORDEN = 'V' THEN
      OPEN C_ANULADO_V;
      FETCH C_ANULADO_V INTO ANULADO_OVE1;
      IF C_ANULADO_V%NOTFOUND THEN
        P_CAB.CrearError('La orden de venta ' || TO_CHAR(P_ID_ORDEN) || ' no existe '
              || '. No puede hacer la cancelaciżn de la venta');
          P_ERRORES := P_ERRORES+1;
      ELSE
        IF ANULADO_OVE1.OVE_ESTADO_BOLSA = 'CPC' THEN
          --P_CAB.CrearError('La orden ya fue cancelada por otro usuario');
          P_ERRORES := 0;
        END IF;
        /* verficcar si la orden esta en estado valida de cancelacion PAP */
        --IF ANULADO_OVE1.OVE_EOC_MNEMONICO NOT IN ('PAP','COL') THEN
        --  P_CAB.CrearError('La orden de venta ' || TO_CHAR(P_ID_ORDEN) || ' se encuentra en estado invalido'
        --      || '. No puede hacer la cancelaciżn de la venta');
         -- P_ERRORES := P_ERRORES+1;
        --END IF;
      END IF;
      CLOSE C_ANULADO_V ;
      OPEN C_NEGOCIOS;
      FETCH C_NEGOCIOS INTO COND_V;
      CLOSE C_NEGOCIOS;
      IF NVL(COND,' ') = 'X' THEN
        P_CAB.CrearError('La orden esta asociada a un neogicio de posiciżn (primario, simultanea, etc).'
            || ' No se puede cancelar');
        P_ERRORES := P_ERRORES+1;
      END IF;
      IF P_ERRORES = 0 AND NVL(ANULADO_OVE1.OVE_ESTADO_BOLSA,' ') != 'CPC' AND ANULADO_OVE1.OVE_EOC_MNEMONICO IN ('PAP','COL')  THEN
        BEGIN
          UPDATE ORDENES_VENTA
          SET    OVE_ESTADO_BOLSA         = 'CPC'
                ,OVE_FECHA_MODIFICACION  = SYSDATE
                /*osjtorres para que quede la traza*/
                ,OVE_FECHA_ANU_CAN        = P_FECHA
                ,OVE_ANU_CAN_POR          = P_USUARIO
                ,OVE_TERMINAL_ANU_CAN     = P_TERMINAL
                /*Fin Osjtorres*/
                ,OVE_PER_NUM_IDEN_ES_MODIFICADA = P_NUM_IDEN
                ,OVE_PER_TID_CODIGO_ES_MODIFICA = P_TID_CODIGO
           WHERE OVE_CONSECUTIVO = P_ID_ORDEN
             AND OVE_BOL_MNEMONICO = 'COL'
             AND OVE_COC_CTO_MNEMONICO = 'ACC';
          IF SQL%ROWCOUNT = 0 THEN
            RAISE_APPLICATION_ERROR(-20001,'Orden:'||P_TIPO_ORDEN||'-'||P_ID_ORDEN ||' no existe .. no es posible cancelarla') ;
          END IF;
        END;
        BEGIN
           UPDATE ORDENES_DE_PAGO
               SET   ODP_ESTADO = 'ANU'
                    ,ODP_ANULADA_POR = USER
                    ,ODP_FECHA_ANULACION = SYSDATE
                    ,ODP_RAZON_ANULACION = 'ANULACION ORDEN VENTA CANAL'
               WHERE  ODP_OVE_BOL_MNEMONICO = 'COL'
               AND    ODP_OVE_COC_CTO_MNEMONICO = 'ACC'
               AND    ODP_OVE_CONSECUTIVO = P_ID_ORDEN
               AND    ODP_CGE_CONSECUTIVO IS NULL
               AND    ODP_CEG_CONSECUTIVO IS NULL
               AND    ODP_TCC_CONSECUTIVO IS NULL
               AND    ODP_TBC_CONSECUTIVO IS NULL
               AND    ODP_ESTADO = 'COL';
        END;
        COMMIT;
      END IF;
   END IF;
END IF;
   EXCEPTION
     WHEN OTHERS THEN
       RAISE_APPLICATION_ERROR(-20001,'Error en procedimientoP_ORDEN_CANCELAR: '||sqlerrm);
END P_ORDEN_CANCELAR;


PROCEDURE P_ORDEN_ANULAR (P_TIPO_ORDEN   IN VARCHAR2,
                           P_ID_ORDEN     IN NUMBER,
                           P_FECHA        IN DATE,
                           P_MOTIVO       IN VARCHAR2,
                           P_USUARIO      IN VARCHAR2,
                           P_TID_CODIGO   IN VARCHAR2,
                           P_NUM_IDEN     IN VARCHAR2,
                           P_TERMINAL     IN VARCHAR2,
                           P_ERRORES      IN OUT NUMBER,
                           P_CANAL_ORIGEN IN VARCHAR2 DEFAULT NULL) IS
   CURSOR C_ANULADO IS
      SELECT OCO_EOC_MNEMONICO
      FROM   ORDENES_COMPRA
      WHERE  OCO_BOL_MNEMONICO = 'COL'
      AND    OCO_COC_CTO_MNEMONICO = 'ACC'
      AND    OCO_CONSECUTIVO = P_ID_ORDEN;
   ANULADO   C_ANULADO%ROWTYPE;
   CURSOR C_OFERTA IS
      SELECT 'X'
      FROM   OFERTAS_DEMANDAS_POSICION
      WHERE  OFD_OCO_CONSECUTIVO = P_ID_ORDEN
      AND    OFD_OCO_BOL_MNEMONICO = 'COL'
      AND    OFD_OCO_COC_CTO_MNEMONICO = 'ACC'
      AND    OFD_ESTADO != 'ANU';
   COND   VARCHAR2(1);
  CURSOR C_ANULADO_V IS
      SELECT OVE_EOC_MNEMONICO
      FROM   ORDENES_VENTA
      WHERE  OVE_BOL_MNEMONICO = 'COL'
      AND    OVE_COC_CTO_MNEMONICO = 'ACC'
      AND    OVE_CONSECUTIVO = P_ID_ORDEN;
  ANULADO_OVE1   C_ANULADO_V%ROWTYPE;
   CURSOR C_NEGOCIOS IS
      SELECT 'X'
      FROM   NEGOCIOS_POSICION
      WHERE  NPO_OVE_CONSECUTIVO = P_ID_ORDEN
      AND    NPO_OVE_BOL_MNEMONICO = 'COL'
      AND    NPO_OVE_COC_CTO_MNEMONICO = 'ACC'
      AND    NPO_ESTADO != 'ANU';
   COND_V  VARCHAR2(1);

   /******WGONZALEZ*******/

   CURSOR ORDE_ANU IS
      SELECT ORDE_EOC_MNEMONICO
      FROM   ORDENES_DERIVADOS
      WHERE  ORDE_BOL_MNEMONICO = 'BOG'
      AND  ORDE_CONSECUTIVO = P_ID_ORDEN
      AND  ORDE_CANAL_ORIGEN = 'FIXBR';
   R_ANULADO   ORDE_ANU%ROWTYPE;
   /*CURSOR RENTA FIJA COMPRA*/
  CURSOR C_ANULADO_RF IS
    SELECT OCO_EOC_MNEMONICO,OCO_COC_CTO_MNEMONICO
    FROM   ORDENES_COMPRA
    WHERE  OCO_BOL_MNEMONICO ='MEC'
    AND    OCO_COC_CTO_MNEMONICO = 'RF'
    AND    OCO_CONSECUTIVO = P_ID_ORDEN;
  /*VARIABLE ANULADO RENTA FIJA*/
  ANULADO_RF   C_ANULADO_RF%ROWTYPE;

  /*CURSOR ORDEN_VENTA,RENTA FIJA*/
  CURSOR C_ANULADO_V_RF IS
    SELECT OVE_EOC_MNEMONICO,OVE_COC_CTO_MNEMONICO
    FROM   ORDENES_VENTA
    WHERE  OVE_BOL_MNEMONICO = 'MEC'
    AND    OVE_COC_CTO_MNEMONICO = 'RF'
    AND    OVE_CONSECUTIVO = P_ID_ORDEN;
    /*VARIABLE VENTA RENTA FIJA*/
  ANULADO_OVE_RF   C_ANULADO_V_RF%ROWTYPE;

  CURSOR C_COMERCIAL IS
  SELECT PER_ES_CORREDOR
  FROM PERSONAS
  WHERE PER_NOMBRE_USUARIO = P_USUARIO
    AND PER_ES_CORREDOR    = 'S'
    AND PER_SUC_CODIGO     IS NOT NULL;
   COMERCIAL        C_COMERCIAL%ROWTYPE;

  V_CRENTAFIJA    ORDENES_COMPRA.OCO_COC_CTO_MNEMONICO%TYPE;
  V_VRENTAFIJA    ORDENES_VENTA.OVE_COC_CTO_MNEMONICO%TYPE;
BEGIN
   P_ERRORES := 0;
IF P_CANAL_ORIGEN IN ('FIXBR') THEN

   OPEN ORDE_ANU;
   FETCH ORDE_ANU INTO R_ANULADO;
      IF ORDE_ANU%NOTFOUND THEN
         P_CAB.CREARERROR('La orden de derivados ' || TO_CHAR(P_ID_ORDEN) ||  ' no existe '
              || '. No puede hacer la Anulaciżn de la Orden');
         P_ERRORES := P_ERRORES+1;
      ELSIF R_ANULADO.ORDE_EOC_MNEMONICO = 'ANU' THEN
         P_CAB.CREARERROR('La orden de derivados ' || TO_CHAR(P_ID_ORDEN) ||  ' ya fue Anulada por otro usuario '
              || '. No puede hacer la Anulaciżn de la Orden'); COMMIT;
         P_ERRORES := P_ERRORES+1;
      ELSIF R_ANULADO.ORDE_EOC_MNEMONICO = 'APL' THEN
         P_CAB.CREARERROR('La orden de derivados ' || TO_CHAR(P_ID_ORDEN) ||  ' se encuentra en estado invalido'
              || '. No puede hacer la Anulaciżn de la Orden');
         P_ERRORES := P_ERRORES+1;
      END IF;
   CLOSE ORDE_ANU;

   IF P_ERRORES = 0 AND (V_CRENTAFIJA IS NULL AND V_VRENTAFIJA IS NULL) THEN

      UPDATE ORDENES_DERIVADOS
         SET ORDE_EOC_MNEMONICO           = 'ANU'
            ,ORDE_ANU_CAN_POR             = P_USUARIO
            ,ORDE_RAZON_ANU_CAN           = P_MOTIVO
            ,ORDE_FECHA_ANU_CAN           = SYSDATE
            ,ORDE_ULTIMA_ACTUALIZACION    = 'VEN'
       WHERE ORDE_CONSECUTIVO = P_ID_ORDEN;
       IF SQL%ROWCOUNT = 0 THEN
          RAISE_APPLICATION_ERROR(-20002,'Orden:'||P_TIPO_ORDEN||'-'||P_ID_ORDEN ||' no existe .. no es posible cancelarla') ;
       END IF;
       COMMIT;
   END IF;
ELSE

  IF P_CANAL_ORIGEN IN ('FIXBRRF') THEN

  OPEN C_ANULADO_RF;
    FETCH C_ANULADO_RF INTO ANULADO_RF;
    ---INICIO VALIDACION RF COMPRA
    IF C_ANULADO_RF%NOTFOUND THEN


        OPEN C_ANULADO_V_RF;
        FETCH C_ANULADO_V_RF INTO ANULADO_OVE_RF;
      IF C_ANULADO_V_RF%NOTFOUND THEN

          P_CAB.CREARERROR('La orden de compra ' || TO_CHAR(P_ID_ORDEN) ||  ' no existe '
             || '. No puede hacer la anulacion de la compra');
             P_ERRORES := P_ERRORES+1;
          CLOSE C_ANULADO_RF;
      ELSE

         OPEN C_COMERCIAL;
           FETCH C_COMERCIAL INTO COMERCIAL;
                V_CRENTAFIJA := ANULADO_RF.OCO_COC_CTO_MNEMONICO;
                IF C_COMERCIAL%NOTFOUND THEN
                    P_ERRORES := P_ERRORES+1;
                    P_CAB.CREARERROR('Comercial no existe en Coeasy :'||P_USUARIO);
                    CLOSE C_COMERCIAL;
                ELSE
                CLOSE C_COMERCIAL;
                  V_VRENTAFIJA := ANULADO_OVE_RF.OVE_COC_CTO_MNEMONICO;
                        UPDATE ORDENES_VENTA
                          SET  OVE_EOC_MNEMONICO        = 'ANU'
                            ,OVE_FECHA_ANU_CAN        = SYSDATE --P_FECHA
                            ,OVE_ANU_CAN_POR          = P_USUARIO
                            ,OVE_TERMINAL_ANU_CAN     = P_TERMINAL
                             ,OVE_RAZON_ANU_CAN        = SUBSTR(P_MOTIVO,1,40)
                            /*osjtorres 06/12/2018 vagtud793  Administrador @ Acciones */
                            ,OVE_PER_NUM_IDEN_ES_MODIFICADA = P_NUM_IDEN
                            ,OVE_PER_TID_CODIGO_ES_MODIFICA = P_TID_CODIGO
                          WHERE OVE_CONSECUTIVO = P_ID_ORDEN
                          AND OVE_BOL_MNEMONICO = 'MEC'
                          AND OVE_COC_CTO_MNEMONICO = 'RF';
                    IF SQL%ROWCOUNT = 0 THEN
                     P_CAB.CREARERROR(-20003||'Orden:'||P_TIPO_ORDEN||'-'||P_ID_ORDEN ||' no existe .. no es posible anularla') ;
                    END IF;
                    COMMIT;
                    --Validacion del comercial
                END IF;
    END IF;
    ELSE
      --Validacion del comercial
      OPEN C_COMERCIAL;
      FETCH C_COMERCIAL INTO COMERCIAL;
      IF C_COMERCIAL%NOTFOUND THEN
          P_ERRORES := P_ERRORES+1;
          P_CAB.CREARERROR('Comercial no existe en Coeasy :'||P_USUARIO);
          CLOSE C_COMERCIAL;
      ELSE

      CLOSE C_ANULADO_RF;

       OPEN C_ANULADO_RF;
         FETCH C_ANULADO_RF INTO ANULADO_RF;
            IF C_ANULADO_RF%NOTFOUND THEN
               P_CAB.CREARERROR('La orden de Renta Fija ' || TO_CHAR(P_ID_ORDEN) || ' no existe '
                    || '. No puede hacer la Anulaciżn de la Orden');
               P_ERRORES := P_ERRORES+1;
            ELSIF ANULADO_RF.OCO_EOC_MNEMONICO = 'ANU' THEN
               P_CAB.CREARERROR('La orden de Renta Fija ' || TO_CHAR(P_ID_ORDEN) || ' ya fue Anulada'
                    || '. No puede hacer la Anulaciżn de la Orden');
               P_ERRORES := P_ERRORES+1;
            ELSIF ANULADO_RF.OCO_EOC_MNEMONICO = 'APL' THEN
               P_CAB.CREARERROR('La orden de Renta Fija ' || TO_CHAR(P_ID_ORDEN) || ' se encuentra en estado APL'
                    || '. No puede hacer la Anulaciżn de la Orden');
               P_ERRORES := P_ERRORES+1;
          END IF;
       CLOSE C_ANULADO_RF;


      V_VRENTAFIJA := ANULADO_OVE_RF.OVE_COC_CTO_MNEMONICO;

      IF P_ERRORES = 0 THEN
        UPDATE ORDENES_COMPRA
        SET  OCO_EOC_MNEMONICO    = 'ANU'
          ,OCO_FECHA_ANU_CAN        = SYSDATE
          ,OCO_ANU_CAN_POR          = P_USUARIO
          ,OCO_TERMINAL_ANU_CAN     = P_TERMINAL
          ,OCO_RAZON_ANU_CAN        = SUBSTR(P_MOTIVO,1,40)
          ,OCO_PER_NUM_IDEN_ES_MODIFICADA = P_NUM_IDEN
          ,OCO_PER_TID_CODIGO_ES_MODIFICA =  P_TID_CODIGO
        WHERE OCO_CONSECUTIVO = P_ID_ORDEN
        AND OCO_BOL_MNEMONICO = 'MEC'
        AND OCO_COC_CTO_MNEMONICO = 'RF' ;
        IF SQL%ROWCOUNT = 0 THEN
          RAISE_APPLICATION_ERROR(-20005, 'Orden:'||P_TIPO_ORDEN||'-'||P_ID_ORDEN ||' no existe .. no es posible anularla') ;
        END IF;
        COMMIT;
      END IF;
    END IF;
END IF;
   ELSIF P_TIPO_ORDEN = 'C' AND (V_CRENTAFIJA IS NULL OR V_VRENTAFIJA IS NULL) THEN
      OPEN C_ANULADO;
      FETCH C_ANULADO INTO ANULADO;
      IF C_ANULADO%NOTFOUND THEN
        P_CAB.CrearError('La orden de compra ' || TO_CHAR(P_ID_ORDEN) ||  ' no existe '
             || '. No puede hacer la anulacion de la compra');
         P_ERRORES := P_ERRORES+1;
      ELSE
        IF ANULADO.OCO_EOC_MNEMONICO IN ('ANU','APL') THEN
          --P_CAB.CrearError('La orden ya fue anulada por otro usuario');
          P_ERRORES := 0;
        END IF;
        --IF ANULADO.OCO_EOC_MNEMONICO NOT IN ('COL','PCO') THEN
         -- P_CAB.CrearError('La orden de compra ' || TO_CHAR(P_ID_ORDEN) ||  ' se encuentra en estado invalido'
          --    || '. No puede hacer la anulacion de la compra');
          --P_ERRORES := P_ERRORES+1;
        --END IF;
      END IF;
      CLOSE C_ANULADO;
      OPEN C_OFERTA;
      FETCH C_OFERTA INTO COND;
      CLOSE C_OFERTA;
      IF NVL(COND,' ') = 'X' THEN
        P_CAB.CrearError('La orden esta asociada a una oferta de posiciżn (primario, simultanea, etc). No se puede anular');
        P_ERRORES := P_ERRORES+1;
      END IF;
      IF P_ERRORES = 0 AND ANULADO.OCO_EOC_MNEMONICO IN ('COL','PCO') THEN
        UPDATE ORDENES_COMPRA
        SET  OCO_EOC_MNEMONICO        = 'ANU'
            ,OCO_FECHA_ANU_CAN        = SYSDATE --P_FECHA
            ,OCO_ANU_CAN_POR          = P_USUARIO
            ,OCO_TERMINAL_ANU_CAN     = P_TERMINAL
            ,OCO_RAZON_ANU_CAN        = SUBSTR(P_MOTIVO,1,40)
            /*osjtorres 06/12/2018 vagtud793  Administrador @ Acciones */
            ,OCO_PER_NUM_IDEN_ES_MODIFICADA = P_NUM_IDEN
            ,OCO_PER_TID_CODIGO_ES_MODIFICA =  P_TID_CODIGO
        WHERE OCO_CONSECUTIVO = P_ID_ORDEN
          AND OCO_BOL_MNEMONICO = 'COL'
          AND OCO_COC_CTO_MNEMONICO = 'ACC';
        IF SQL%ROWCOUNT = 0 THEN
          RAISE_APPLICATION_ERROR(-20001,'Orden:'||P_TIPO_ORDEN||'-'||P_ID_ORDEN ||' no existe .. no es posible anularla') ;
        END IF;
        COMMIT;
      END IF;
   ELSIF P_TIPO_ORDEN = 'V'  AND (V_CRENTAFIJA IS NULL OR V_VRENTAFIJA IS NULL)  THEN

      OPEN C_ANULADO_V;
      FETCH C_ANULADO_V INTO ANULADO_OVE1;
      IF C_ANULADO_V%NOTFOUND THEN
        P_CAB.CrearError('La orden de venta ' || TO_CHAR(P_ID_ORDEN) || ' no existe '
             || '. No puede hacer la anulacion de la venta');
         P_ERRORES := P_ERRORES+1;
      ELSE
        IF ANULADO_OVE1.OVE_EOC_MNEMONICO = 'ANU' THEN
          --P_CAB.CrearError('La orden ya fue anulada por otro usuario');
          P_ERRORES := 0;
        END IF;
        --IF ANULADO_OVE1.OVE_EOC_MNEMONICO NOT IN ('COL','PCO') THEN
        --  P_CAB.CrearError('La orden de venta ' || TO_CHAR(P_ID_ORDEN) || ' se encuentra en estado invalido'
          --    || '. No puede hacer la anulacion de la venta');
         -- P_ERRORES := P_ERRORES+1;
        --END IF;
      END IF;
      CLOSE  C_ANULADO_V;
      OPEN C_NEGOCIOS;
      FETCH C_NEGOCIOS INTO COND_V;
      CLOSE C_NEGOCIOS;
      IF NVL(COND,' ') = 'X' THEN
        P_CAB.CrearError('La orden esta asociada a un negocio de posiciżn (primario, simultanea, etc).'
            || ' No se puede anular');
        P_ERRORES := P_ERRORES+1;
      END IF;
      IF P_ERRORES = 0 AND ANULADO_OVE1.OVE_EOC_MNEMONICO IN ('COL','PCO') THEN
        BEGIN
          UPDATE ORDENES_VENTA
          SET  OVE_EOC_MNEMONICO        = 'ANU'
              ,OVE_FECHA_ANU_CAN        = SYSDATE --P_FECHA
              ,OVE_ANU_CAN_POR          = P_USUARIO
              ,OVE_TERMINAL_ANU_CAN     = P_TERMINAL
              ,OVE_RAZON_ANU_CAN        = SUBSTR(P_MOTIVO,1,40)
        /*osjtorres 06/12/2018 vagtud793  Administrador @ Acciones */
              ,OVE_PER_NUM_IDEN_ES_MODIFICADA = P_NUM_IDEN
              ,OVE_PER_TID_CODIGO_ES_MODIFICA = P_TID_CODIGO
          WHERE OVE_CONSECUTIVO = P_ID_ORDEN
            AND OVE_BOL_MNEMONICO = 'COL'
            AND OVE_COC_CTO_MNEMONICO = 'ACC';
          IF SQL%ROWCOUNT = 0 THEN
            RAISE_APPLICATION_ERROR(-20001,'Orden:'||P_TIPO_ORDEN||'-'||P_ID_ORDEN ||' no existe .. no es posible anularla') ;
          END IF;
        END;

        BEGIN
          UPDATE ORDENES_DE_PAGO
          SET  ODP_ESTADO = 'ANU'
              ,ODP_ANULADA_POR = USER
              ,ODP_FECHA_ANULACION = SYSDATE
              ,ODP_RAZON_ANULACION = 'ANULACION ORDEN VENTA CANAL'
          WHERE ODP_OVE_BOL_MNEMONICO = 'COL'
            AND ODP_OVE_COC_CTO_MNEMONICO = 'ACC'
            AND ODP_OVE_CONSECUTIVO = P_ID_ORDEN
            AND ODP_CGE_CONSECUTIVO IS NULL
            AND ODP_CEG_CONSECUTIVO IS NULL
            AND ODP_TCC_CONSECUTIVO IS NULL
            AND ODP_TBC_CONSECUTIVO IS NULL
            AND ODP_ESTADO IN ('COL','APR');
        END;
        COMMIT;
      END IF;
   END IF;
END IF;
   EXCEPTION
     WHEN OTHERS THEN
       RAISE_APPLICATION_ERROR(-20001,'Error en procedimiento P_ORDEN_ANULAR : '||sqlerrm);
END P_ORDEN_ANULAR;
PROCEDURE P_COMPLEMENTACION (P_NUMERO_OPERACION  IN VARCHAR2,
                             P_NUMERO_FRACCION   IN NUMBER,
                             P_TIPO_ORDEN        IN VARCHAR2,
                             P_BOL_MNEMONICO     IN VARCHAR2,
                             P_ID_ORDEN          IN NUMBER,
                             P_USUARIO           IN VARCHAR2,
                             P_TID_CODIGO        IN VARCHAR2,
                             P_NUM_IDEN          IN VARCHAR2,
                             P_TERMINAL          IN VARCHAR2,
                             P_FECHA_PROCESO     IN VARCHAR2,
                             P_ERRORES           IN OUT NUMBER) IS
  V_NUMERO_OPERACION NUMBER;
BEGIN
  P_ERRORES := 0;
  /* Obtener numero de liquidacion para coeasy a partir del id de folio enviado por bolsa*/
  BEGIN
    V_NUMERO_OPERACION := TO_NUMBER(SUBSTR(TRIM(P_NUMERO_OPERACION),4,8)||SUBSTR(TRIM(P_NUMERO_OPERACION),length(TRIM(P_NUMERO_OPERACION))-8,9));
    EXCEPTION WHEN OTHERS  THEN
    P_CAB.CrearError('Error al obtener id de folio para coeasy:'||P_TIPO_ORDEN||'-'||P_ID_ORDEN||'-'||P_NUMERO_OPERACION);
    P_ERRORES := P_ERRORES+1;
  END;
  IF P_TIPO_ORDEN = 'C' THEN
    /* cambiar estado de la orden */
    BEGIN
      UPDATE ORDENES_COMPRA
        SET OCO_ESTADO_BOLSA = DECODE(OCO_ESTADO_BOLSA,'CPC',OCO_ESTADO_BOLSA,'COM')
           ,OCO_PER_NUM_IDEN_ES_MODIFICADA =P_NUM_IDEN
           ,OCO_PER_TID_CODIGO_ES_MODIFICA = P_TID_CODIGO
        WHERE OCO_CONSECUTIVO = P_ID_ORDEN
          AND OCO_BOL_MNEMONICO = 'COL'
          AND OCO_COC_CTO_MNEMONICO = 'ACC';
      IF SQL%ROWCOUNT = 0 THEN
        P_CAB.CrearError('Error orden no existe en coeasy:'||P_TIPO_ORDEN||'-'||P_ID_ORDEN  );
        P_ERRORES := P_ERRORES+1;
      END IF;
    END;
    IF  P_ERRORES = 0 THEN
      BEGIN
        INSERT INTO LIQUIDACIONES_SAE
          (LIS_NUMERO_OPERACION
          ,LIS_NUMERO_FRACCION
          ,LIS_TIPO_OPERACION
          ,LIS_BOL_MNEMONICO
          ,LIS_FECHA_INGRESO
          ,LIS_TERMINAL_INGRESO
          ,LIS_USUARIO
          ,LIS_NUMERO_OPERACION_SAE
          ,LIS_OCO_BOL_MNEMONICO
          ,LIS_OCO_COC_CTO_MNEMONICO
          ,LIS_OCO_CONSECUTIVO)
         VALUES(
           V_NUMERO_OPERACION
          ,NVL(P_NUMERO_FRACCION,0)
          ,P_TIPO_ORDEN
          ,NVL(P_BOL_MNEMONICO,'COL')
          ,SYSDATE--TO_DATE(P_FECHA_PROCESO,'DD-MM-YYYY HH24:MI:SS')
          ,P_TERMINAL
          ,P_USUARIO
          ,P_NUMERO_OPERACION
          ,NVL(P_BOL_MNEMONICO,'COL')
          ,'ACC'
          ,P_ID_ORDEN);
         IF SQL%ROWCOUNT = 0 THEN
           P_CAB.CrearError('Orden:'||P_TIPO_ORDEN||'-'||P_ID_ORDEN ||' no existe .. no es posible crear liquidacion de complementacion') ;
           P_ERRORES := P_ERRORES+1;
         END IF;
         EXCEPTION
            WHEN DUP_VAL_ON_INDEX THEN
              P_ERRORES := 0;
      END;
    END IF;
    IF P_ERRORES = 0 THEN
      COMMIT;
    END IF;
  ELSIF P_TIPO_ORDEN = 'V' THEN
    BEGIN
      UPDATE ORDENES_VENTA
        SET OVE_ESTADO_BOLSA = DECODE(OVE_ESTADO_BOLSA,'CPC',OVE_ESTADO_BOLSA,'COM')
           ,OVE_PER_NUM_IDEN_ES_MODIFICADA =P_NUM_IDEN
           ,OVE_PER_TID_CODIGO_ES_MODIFICA = P_TID_CODIGO
        WHERE OVE_CONSECUTIVO = P_ID_ORDEN
          AND OVE_BOL_MNEMONICO = 'COL'
          AND OVE_COC_CTO_MNEMONICO = 'ACC';
      IF SQL%ROWCOUNT = 0 THEN
        P_CAB.CrearError('Error orden no existe en coeasy:'||P_TIPO_ORDEN||'-'||P_ID_ORDEN );
        P_ERRORES := P_ERRORES+1;
      END IF;
    END;
    IF P_ERRORES = 0 THEN
      BEGIN
        INSERT INTO LIQUIDACIONES_SAE
          (LIS_NUMERO_OPERACION
          ,LIS_NUMERO_FRACCION
          ,LIS_TIPO_OPERACION
          ,LIS_BOL_MNEMONICO
          ,LIS_FECHA_INGRESO
          ,LIS_TERMINAL_INGRESO
          ,LIS_USUARIO
          ,LIS_NUMERO_OPERACION_SAE
          ,LIS_OVE_BOL_MNEMONICO
          ,LIS_OVE_COC_CTO_MNEMONICO
          ,LIS_OVE_CONSECUTIVO)
         VALUES(
           V_NUMERO_OPERACION
          ,NVL(P_NUMERO_FRACCION,0)
          ,P_TIPO_ORDEN
          ,NVL(P_BOL_MNEMONICO,'COL')
          ,SYSDATE--TO_DATE(P_FECHA_PROCESO,'DD-MM-YYYY HH24:MI:SS')
          ,P_TERMINAL
          ,P_USUARIO
          ,P_NUMERO_OPERACION
          ,NVL(P_BOL_MNEMONICO,'COL')
          ,'ACC'
          ,P_ID_ORDEN);
         IF SQL%ROWCOUNT = 0 THEN
           P_CAB.CrearError('Orden:'||P_TIPO_ORDEN||'-'||P_ID_ORDEN ||' no existe .. no es posible crear liquidacion de complementacion') ;
           P_ERRORES := P_ERRORES+1;
         END IF;
         EXCEPTION
            WHEN DUP_VAL_ON_INDEX THEN
              P_ERRORES := 0;

      END;
    END IF;
    IF P_ERRORES = 0 THEN
      COMMIT;
    END IF;
  END IF;
END P_COMPLEMENTACION;
PROCEDURE P_NUMERACION_SUPER IS
   CURSOR C_ORDENES IS
      SELECT OCO_CONSECUTIVO       CONSECUTIVO
            ,OCO_BOL_MNEMONICO     BOL_MNEMONICO
            ,OCO_COC_CTO_MNEMONICO COC_CTO_MNEMONICO
            ,OCO_FECHA_Y_HORA      FECHA_Y_HORA
            ,'C'                   TIPO
      FROM   ORDENES_COMPRA
      WHERE  OCO_FECHA_Y_HORA >= TRUNC(SYSDATE-1)
      AND    OCO_CONSECUTIVO_SUPER IS NULL
      UNION
      SELECT OVE_CONSECUTIVO
            ,OVE_BOL_MNEMONICO
            ,OVE_COC_CTO_MNEMONICO
            ,OVE_FECHA_Y_HORA
            ,'V'
      FROM   ORDENES_VENTA
      WHERE  OVE_FECHA_Y_HORA >= TRUNC(SYSDATE-1)
      AND    OVE_CONSECUTIVO_SUPER IS NULL
      ORDER BY 4,1;
   ORD1   C_ORDENES%ROWTYPE;

   CURSOR C_SIGUIENTE IS
      SELECT MAX(COR_CONSECUTIVO_SUPER)
      FROM   CONSECUTIVO_ORDENES
      WHERE  COR_BOLSA = ORD1.BOL_MNEMONICO
      AND    COR_CLASE = ORD1.COC_CTO_MNEMONICO;
   SIGUIENTE NUMBER;
BEGIN
   OPEN C_ORDENES;
   FETCH C_ORDENES INTO ORD1;
   WHILE C_ORDENES%FOUND LOOP
      SIGUIENTE := NULL;
      OPEN C_SIGUIENTE;
      FETCH C_SIGUIENTE INTO SIGUIENTE;
      CLOSE C_SIGUIENTE;
      SIGUIENTE := NVL(SIGUIENTE,0) + 1;

      UPDATE CONSECUTIVO_ORDENES
      SET    COR_CONSECUTIVO_SUPER = SIGUIENTE
      WHERE  COR_CONSECUTIVO = ORD1.CONSECUTIVO
      AND    COR_BOLSA = ORD1.BOL_MNEMONICO
      AND    COR_CLASE = ORD1.COC_CTO_MNEMONICO;

      IF ORD1.TIPO = 'C' THEN
         UPDATE ORDENES_COMPRA
         SET    OCO_CONSECUTIVO_SUPER = SIGUIENTE
         WHERE  OCO_CONSECUTIVO = ORD1.CONSECUTIVO
         AND    OCO_BOL_MNEMONICO = ORD1.BOL_MNEMONICO
         AND    OCO_COC_CTO_MNEMONICO = ORD1.COC_CTO_MNEMONICO;
      ELSIF ORD1.TIPO = 'V' THEN
         UPDATE ORDENES_VENTA
         SET    OVE_CONSECUTIVO_SUPER = SIGUIENTE
         WHERE  OVE_CONSECUTIVO = ORD1.CONSECUTIVO
         AND    OVE_BOL_MNEMONICO = ORD1.BOL_MNEMONICO
         AND    OVE_COC_CTO_MNEMONICO = ORD1.COC_CTO_MNEMONICO;
      END IF;
      FETCH C_ORDENES INTO ORD1;
   END LOOP;
   CLOSE C_ORDENES;
   COMMIT;
EXCEPTION
   WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento P_NUMERACION_SUPERL',substr(sqlerrm,1,80));
END P_NUMERACION_SUPER;
PROCEDURE P_NOTIFICAR_OPERACION( P_ID_ORDEN              IN NUMBER,
                                 P_BOL_MNEMONICO         IN VARCHAR2,
                                 P_COC_CTO_MNEMONICO     IN VARCHAR2,
                                 P_TIPO_OPERACION        IN VARCHAR2,
                                 P_CANTIDAD_TOTAL        IN NUMBER,
                                 P_PRECIO                IN NUMBER,
                                 P_COMISION              IN NUMBER,
                                 P_VALOR_TOTAL           IN NUMBER,
                                 P_IVA                   IN NUMBER,
                                 P_VALOR_NETO            IN NUMBER,
                                 P_FOLIO                 IN VARCHAR2,
                                 P_FRACCION              IN NUMBER,
                                 P_CODIGO_XSTREAM        IN VARCHAR2,
                                 P_ENA_MNENMONICO        IN VARCHAR2,
                                 P_ERRORES               IN OUT NUMBER) IS

  CURSOR C1(P_CODIGO_XSTREAM VARCHAR2) IS
    SELECT PER_NUM_IDEN
       , PER_TID_CODIGO
     , PER_TIPO
     , PER_RAZON_SOCIAL
     , PER_DIGITO_CONTROL
     , PER_PRIMER_APELLIDO
     , PER_SEGUNDO_APELLIDO
     , PER_NOMBRE
     , PER_SEXO
     , PER_ES_CORREDOR
     , PER_NOMBRE_USUARIO
     , PER_INICIALES_USUARIO
     , PER_SUC_CODIGO
     , PER_CPR_MNEMONICO
     , PER_MAIL_CORREDOR
     , PER_TIPO_COMERCIAL
     , PER_EJECUTA_ORDEN_MESA
     , PER_PER_NUM_IDEN
     , PER_PER_TID_CODIGO
     , PER_CCT_MNEMONICO
     , PER_ESTADO
     , PER_CLF_SECUENCIAL
     , PER_TELEFONO_DIRECTO
     , PER_CODIGO_BOLSA
     , PER_COMERCIAL_ACC_DIRECTO
     , PER_CODIGO_SAE_ACC
     , PER_COMPLEMENTACION
     , PER_COMERCIAL_OPX
     , PER_USUARIO_DECEVAL
     , PER_ID_USUARIO_DECEVAL
     , PER_CODIGO_SIOPEL
     , PER_CODIGO_XSTREAM
     , PER_NOTIFICA_CENLINEA
     , PER_TIP_COMERCIAL_UDF
     , PER_ORIGEN
     , PER_REPRESENTANTE_LEGAL
     , PER_CODIGO_SAE_DER
     , PER_ES_PAGADOR
     , PER_ESTADO_FACTORING
     , PER_CODIGO_CONTABLE
     , PER_GOBIERNO
     , PER_SUPERBANCARIA
     , PER_ENTIDAD_CARTA
     , PER_PERSONA_CARTA
     , PER_DIRECCION_CARTA
     , PER_AGE_CODIGO
     , PER_CNU_MNEMONICO
     , PER_NATURALEZA_JURIDICA
     , PER_CORPORATIVO
     , PER_CTSE_MNEMONICO
     , PER_MERCADO
     , PER_FACTORING
     , PER_MODULO
     , PER_SECTOR_PIP
     , PER_BROKER
     , PER_PREPAGO
    FROM PERSONAS
    WHERE PER_NOTIFICA_CENLINEA = 'S'
      AND PER_CODIGO_XSTREAM = SUBSTR(P_CODIGO_XSTREAM, LENGTH(P_CODIGO_XSTREAM)-3,LENGTH(P_CODIGO_XSTREAM));

  C_C1 C1%ROWTYPE;
  V_FOLIO_COEASY NUMBER;
  P_VALOR        NUMBER;
  P_VALOR_DATE   DATE;
  P_VALOR_CHAR   VARCHAR2(200);


BEGIN
  P_ERRORES := 0;
  BEGIN
      IF SUBSTR(P_FOLIO, 1, 3) = '002' THEN
            V_FOLIO_COEASY := TO_NUMBER(SUBSTR(P_FOLIO, 4, 8) || SUBSTR(P_FOLIO, 13));
      ELSE
            V_FOLIO_COEASY := TO_NUMBER(SUBSTR(P_FOLIO,1,8)||SUBSTR(P_FOLIO,10) );
      END IF;
  EXCEPTION 
    WHEN OTHERS  THEN
        P_CAB.CrearError('Error al obtener id de folio para coeasy:'||P_TIPO_OPERACION||'-'||P_ID_ORDEN||'-'||P_FOLIO);
        P_ERRORES := P_ERRORES+1;
  END;

  IF P_ID_ORDEN IS NOT NULL AND P_ID_ORDEN != -1 THEN
    BEGIN
      INSERT INTO NOTIFICACIONES_OPERACIONES
        (NOO_CONSECUTIVO
        ,NOO_CANTIDAD
        ,NOO_PRECIO
        ,NOO_COMISION
        ,NOO_VALOR_TOTAL
        ,NOO_IVA
        ,NOO_VALOR_NETO
        ,NOO_NUMERO_OPERACION_SAE
        ,NOO_NUMERO_OPERACION
        ,NOO_FRACCION
        ,NOO_FECHA_INGRESO
        ,NOO_OVE_CONSECUTIVO
        ,NOO_OVE_COC_CTO_MNEMONICO
        ,NOO_OVE_BOL_MNEMONICO
        ,NOO_OCO_CONSECUTIVO
        ,NOO_OCO_COC_CTO_MNEMONICO
        ,NOO_OCO_BOL_MNEMONICO)
      VALUES
        (NOO_SEQ.NEXTVAL   --NOO_CONSECUTIVO
        ,P_CANTIDAD_TOTAL  --NOO_CANTIDAD
        ,P_PRECIO          --NOO_PRECIO
        ,P_COMISION        --NOO_COMISION
        ,P_VALOR_TOTAL     --NOO_VALOR_TOTAL
        ,P_IVA             --NOO_IVA
        ,P_VALOR_NETO      --NOO_VALOR_NETO
        ,P_FOLIO           --NOO_NUMERO_OPERACION_SAE
        ,V_FOLIO_COEASY    --NOO_NUMERO_OPERACION
        ,P_FRACCION        --NOO_FRACCION
        ,SYSDATE           --NOO_FECHA_INGRESO
        ,DECODE(P_TIPO_OPERACION,'V',P_ID_ORDEN,NULL)           --NOO_OVE_CONSECUTIVO
        ,DECODE(P_TIPO_OPERACION,'V',P_COC_CTO_MNEMONICO,NULL)  --NOO_OVE_COC_CTO_MNEMONICO
        ,DECODE(P_TIPO_OPERACION,'V',P_BOL_MNEMONICO,NULL)      --NOO_OVE_BOL_MNEMONICO
        ,DECODE(P_TIPO_OPERACION,'C',P_ID_ORDEN,NULL)           --NOO_OCO_CONSECUTIVO
        ,DECODE(P_TIPO_OPERACION,'C',P_COC_CTO_MNEMONICO,NULL)  --NOO_OCO_COC_CTO_MNEMONICO
        ,DECODE(P_TIPO_OPERACION,'C',P_BOL_MNEMONICO,NULL)      --NOO_OCO_BOL_MNEMONICO
        );
      IF SQL%ROWCOUNT = 0 THEN
        P_CAB.CrearError('Orden:'||P_TIPO_OPERACION||'-'||P_ID_ORDEN ||' no existe .. no es posible crear notificacion de la operacion') ;
        P_ERRORES := P_ERRORES+1;
      END IF;
    END;
  END IF;

  /* VALIDA QUE INDIDICADOR DE ENRURAMIENTO ESTE ACTIVO */
  P_TOOLS.CONSULTARCONSTANTE(
    P_CONSTANTE => 'ENA',
    P_VALOR => P_VALOR,
    P_VALOR_DATE => P_VALOR_DATE,
    P_VALOR_CHAR => P_VALOR_CHAR
    );

  IF NVL(P_VALOR_CHAR,'N') = 'S' THEN
    IF P_ID_ORDEN IS NULL OR NVL(P_ID_ORDEN,0) = 0 THEN
      /* SE REPORTAN LAS OPERACIONES DE SOLO LA POSICION PERSONAS MARCADAS PER_NOTIFICA_CENLINEA = 'S'*/
      OPEN C1(P_CODIGO_XSTREAM);
      FETCH C1 INTO C_C1;
      IF C1%FOUND  THEN
        BEGIN
          INSERT INTO CENLINEA_NOTIFICA_RV
            (CNRV_CONSECUTIVO
            ,CNRV_ESTADO
            ,CNRV_CANTIDAD
            ,CNRV_PRECIO
            ,CNRV_COMISION
            ,CNRV_VALOR_TOTAL
            ,CNRV_IVA
            ,CNRV_VALOR_NETO
            ,CNRV_NUMERO_OPERACION
            ,CNRV_FRACCION
            ,CNRV_FECHA_INGRESO
            ,CNRV_FECHA_ENTREGA
            ,CNRV_OVE_CONSECUTIVO
            ,CNRV_OVE_COC_CTO_MNEMONICO
            ,CNRV_OVE_BOL_MNEMONICO
            ,CNRV_OCO_CONSECUTIVO
            ,CNRV_OCO_COC_CTO_MNEMONICO
            ,CNRV_OCO_BOL_MNEMONICO
            ,CNRV_CODIGO_XSTREAM
            ,CNRV_EOC_MNENMONICO
            ,CNRV_ENA_MNENMONICO
            ,CNRV_TIPO_ORDEN
            ,CNRV_CODIGO_OPERACION)
          VALUES
            (CNRV_SEQ.NEXTVAL   --CNRV_CONSECUTIVO
            ,'POR_PROCESAR'    --CNRV_ESTADO
            ,P_CANTIDAD_TOTAL  --CNRV_CANTIDAD
            ,P_PRECIO          --CNRV_PRECIO
            ,P_COMISION        --CNRV_COMISION
            ,P_VALOR_TOTAL     --CNRV_VALOR_TOTAL
            ,P_IVA             --CNRV_IVA
            ,P_VALOR_NETO      --CNRV_VALOR_NETO
            ,V_FOLIO_COEASY    --CNRV_NUMERO_OPERACION
            ,P_FRACCION        --CNRV_FRACCION
            ,SYSDATE           --CNRV_FECHA_INGRESO
            ,NULL
            ,DECODE(P_ID_ORDEN,NULL,NULL,DECODE(P_TIPO_OPERACION,'V',P_ID_ORDEN,NULL))           --CNRV_OVE_CONSECUTIVO
            ,DECODE(P_ID_ORDEN,NULL,NULL,DECODE(P_TIPO_OPERACION,'V',P_COC_CTO_MNEMONICO,NULL))  --CNRV_OVE_COC_CTO_MNEMONICO
            ,DECODE(P_ID_ORDEN,NULL,NULL,DECODE(P_TIPO_OPERACION,'V',P_BOL_MNEMONICO,NULL))      --CNRV_OVE_BOL_MNEMONICO
            ,DECODE(P_ID_ORDEN,NULL,NULL,DECODE(P_TIPO_OPERACION,'C',P_ID_ORDEN,NULL))           --CNRV_OCO_CONSECUTIVO
            ,DECODE(P_ID_ORDEN,NULL,NULL,DECODE(P_TIPO_OPERACION,'C',P_COC_CTO_MNEMONICO,NULL))  --CNRV_OCO_COC_CTO_MNEMONICO
            ,DECODE(P_ID_ORDEN,NULL,NULL,DECODE(P_TIPO_OPERACION,'C',P_BOL_MNEMONICO,NULL))      --CNRV_OCO_BOL_MNEMONICO
            ,P_CODIGO_XSTREAM
            ,'COL'
            ,P_ENA_MNENMONICO
            ,P_TIPO_OPERACION
            ,'N');
          IF SQL%ROWCOUNT = 0 THEN
            P_CAB.CrearError('Error en notificacion operacion rv'||SQLERRM) ;
            P_ERRORES := P_ERRORES+1;
          END IF;
        END;
      END IF;
      CLOSE C1;
    ELSE
      /* CREACION DE TODAS LAS ORDENES DEL MERCADO POR PLTAFORMA*/
      BEGIN
        INSERT INTO CENLINEA_NOTIFICA_RV
          (CNRV_CONSECUTIVO
          ,CNRV_ESTADO
          ,CNRV_CANTIDAD
          ,CNRV_PRECIO
          ,CNRV_COMISION
          ,CNRV_VALOR_TOTAL
          ,CNRV_IVA
          ,CNRV_VALOR_NETO
          ,CNRV_NUMERO_OPERACION
          ,CNRV_FRACCION
          ,CNRV_FECHA_INGRESO
          ,CNRV_FECHA_ENTREGA
          ,CNRV_OVE_CONSECUTIVO
          ,CNRV_OVE_COC_CTO_MNEMONICO
          ,CNRV_OVE_BOL_MNEMONICO
          ,CNRV_OCO_CONSECUTIVO
          ,CNRV_OCO_COC_CTO_MNEMONICO
          ,CNRV_OCO_BOL_MNEMONICO
          ,CNRV_CODIGO_XSTREAM
          ,CNRV_EOC_MNENMONICO
          ,CNRV_ENA_MNENMONICO
          ,CNRV_TIPO_ORDEN
          ,CNRV_CODIGO_OPERACION)
        VALUES
          (CNRV_SEQ.NEXTVAL   --CNRV_CONSECUTIVO
          ,'POR_PROCESAR'    --CNRV_ESTADO
          ,P_CANTIDAD_TOTAL  --CNRV_CANTIDAD
          ,P_PRECIO          --CNRV_PRECIO
          ,P_COMISION        --CNRV_COMISION
          ,P_VALOR_TOTAL     --CNRV_VALOR_TOTAL
          ,P_IVA             --CNRV_IVA
          ,P_VALOR_NETO      --CNRV_VALOR_NETO
          ,V_FOLIO_COEASY    --CNRV_NUMERO_OPERACION
          ,P_FRACCION        --CNRV_FRACCION
          ,SYSDATE           --CNRV_FECHA_INGRESO
          ,NULL
          ,DECODE(P_ID_ORDEN,NULL,NULL,DECODE(P_TIPO_OPERACION,'V',P_ID_ORDEN,NULL))           --CNRV_OVE_CONSECUTIVO
          ,DECODE(P_ID_ORDEN,NULL,NULL,DECODE(P_TIPO_OPERACION,'V',P_COC_CTO_MNEMONICO,NULL))  --CNRV_OVE_COC_CTO_MNEMONICO
          ,DECODE(P_ID_ORDEN,NULL,NULL,DECODE(P_TIPO_OPERACION,'V',P_BOL_MNEMONICO,NULL))      --CNRV_OVE_BOL_MNEMONICO
          ,DECODE(P_ID_ORDEN,NULL,NULL,DECODE(P_TIPO_OPERACION,'C',P_ID_ORDEN,NULL))           --CNRV_OCO_CONSECUTIVO
          ,DECODE(P_ID_ORDEN,NULL,NULL,DECODE(P_TIPO_OPERACION,'C',P_COC_CTO_MNEMONICO,NULL))  --CNRV_OCO_COC_CTO_MNEMONICO
          ,DECODE(P_ID_ORDEN,NULL,NULL,DECODE(P_TIPO_OPERACION,'C',P_BOL_MNEMONICO,NULL))      --CNRV_OCO_BOL_MNEMONICO
          ,P_CODIGO_XSTREAM
          ,'COL'
          ,P_ENA_MNENMONICO
          ,P_TIPO_OPERACION
          ,'N');
        IF SQL%ROWCOUNT = 0 THEN
          P_CAB.CrearError('Error en notificacion operacion rv'||SQLERRM) ;
          P_ERRORES := P_ERRORES+1;
        END IF;
      END;
    END IF;
  END IF;
END P_NOTIFICAR_OPERACION;


/**************************************************
************** SEBRA CONTINGENCIA *****************
***************************************************/

/*Ordenes de Pago Sebra Registradas*/
PROCEDURE ORDENES_PAGO_SEBRA_REGISTRADAS
(P_ODP_CONSECUTIVO IN ORDENES_DE_PAGO.ODP_CONSECUTIVO%TYPE
,P_ODP_SUC_CODIGO IN ORDENES_DE_PAGO.ODP_SUC_CODIGO%TYPE
,P_ODP_NEG_CONSECUTIVO IN ORDENES_DE_PAGO.ODP_NEG_CONSECUTIVO%TYPE
,P_ODP_OCU_CODIGO IN ORDENES_DE_PAGO.ODP_OCU_CODIGO%TYPE
,io_cursor IN OUT O_CURSOR) IS

  C_ODP O_CURSOR;


  TYPE T_ODP IS RECORD (NUMERO_OP VARCHAR2(12), CODIGO_OP_CUD NUMBER(5), CANTIDAD NUMBER(22,2),
                          FECHA_APLICACION DATE, ID_TERCERO_DEB VARCHAR2(20),
                          NOMBRE_TERCERO_DEB VARCHAR2(62), ID_TERCERO_CRE VARCHAR2(25), NOMBRE_TERCERO_CRE VARCHAR2(62),
                          NIT_CTA_CREDITO VARCHAR2(15), CTA_DEPOSITO_BR_CRE NUMBER(8,0), ES_CLIENTE VARCHAR2(1),PAGAR_A VARCHAR2(1));


  R_ODP T_ODP;

  V_SELECT VARCHAR2(4000);
  V_FROM VARCHAR2(4000);
  V_WHERE VARCHAR2(4000);

CURSOR C_PAGAR_A IS
      SELECT ODP_ES_CLIENTE, ODP_PAGAR_A
      FROM ORDENES_DE_PAGO
      WHERE ODP_CONSECUTIVO = P_ODP_CONSECUTIVO
        AND ODP_SUC_CODIGO = P_ODP_SUC_CODIGO
        AND ODP_NEG_CONSECUTIVO = P_ODP_NEG_CONSECUTIVO;

R_PAGAR_A C_PAGAR_A%ROWTYPE;
V_BAN_NIT VARCHAR(15);

BEGIN
  OPEN C_PAGAR_A;
  FETCH C_PAGAR_A INTO R_PAGAR_A;
  CLOSE C_PAGAR_A;

   IF R_PAGAR_A.ODP_ES_CLIENTE = 'N' THEN

              V_SELECT := 'SELECT odp.odp_consecutivo NUMERO_OP, (SELECT OCU_CODIGO FROM OPERACIONES_CUD_SEBRA WHERE OCU_CODIGO = '||P_ODP_OCU_CODIGO||') CODIGO_OP_CUD, odp.odp_monto_orden CANTIDAD, ';
              V_SELECT := V_SELECT || 'odp.odp_fecha_ejecucion FECHA_APLICACION, odp.odp_per_num_iden ID_TERCERO_DEB, ';
              V_SELECT := V_SELECT || 'fp.per_nombre NOMBRE_TERCERO_DEB, odp.odp_per_num_iden ID_TERCERO_CRE, fp.per_nombre NOMBRE_TERCERO_CRE, ';
              V_SELECT := V_SELECT || 'odp.odp_FIC_PER_NUM_IDEN NIT_CTA_CREDITO, NVL(fic.fic_cuenta_br,0) CTA_DEPOSITO_BR_CRE, ODP_ES_CLIENTE ES_CLIENTE,odp.odp_pagar_a PAGAR_A ';

              V_FROM := 'FROM ORDENES_DE_PAGO odp, FIRMAS_COMISIONISTAS fic, CONCEPTOS_TESORERIA cot, FILTRO_PERSONAS fp ';

              V_WHERE := 'WHERE odp.odp_suc_codigo =' || P_ODP_SUC_CODIGO ||' AND odp.odp_neg_consecutivo = ' || P_ODP_NEG_CONSECUTIVO;
              V_WHERE := V_WHERE || ' AND odp.odp_consecutivo =' || P_ODP_CONSECUTIVO || ' ';
              V_WHERE := V_WHERE || ' AND odp.odp_per_num_iden = fic.FIC_PER_NUM_IDEN(+) AND odp.odp_per_tid_codigo = fic.FIC_PER_TID_CODIGO(+) ';
              V_WHERE := V_WHERE || ' AND odp.odp_cot_mnemonico = cot.cot_mnemonico AND fp.per_num_iden = odp.odp_per_num_iden AND fp.per_tid_codigo = odp.odp_per_tid_codigo ';

    ELSIF R_PAGAR_A.ODP_ES_CLIENTE = 'S' THEN
          IF R_PAGAR_A.ODP_PAGAR_A = 'C' THEN

              V_SELECT := 'SELECT odp.odp_consecutivo NUMERO_OP, (SELECT OCU_CODIGO FROM OPERACIONES_CUD_SEBRA WHERE OCU_CODIGO = '||P_ODP_OCU_CODIGO||') CODIGO_OP_CUD, odp.odp_monto_orden CANTIDAD, ';
              V_SELECT := V_SELECT || 'odp.odp_fecha_ejecucion FECHA_APLICACION, odp.odp_ccc_cli_per_num_iden ID_TERCERO_DEB, ';
              V_SELECT := V_SELECT || 'fp_deb.per_nombre NOMBRE_TERCERO_DEB, odp.odp_ccc_cli_per_num_iden ID_TERCERO_CRE, fp_ter_cre.per_nombre NOMBRE_TERCERO_CRE, ';
              V_SELECT := V_SELECT || 'odp.odp_FIC_PER_NUM_IDEN NIT_CTA_CREDITO, NVL(fic.fic_cuenta_br,0) CTA_DEPOSITO_BR_CRE, ODP_ES_CLIENTE ES_CLIENTE,odp.odp_pagar_a PAGAR_A ';

              V_FROM := 'FROM ORDENES_DE_PAGO odp, FIRMAS_COMISIONISTAS fic, CONCEPTOS_TESORERIA cot, FILTRO_PERSONAS fp_deb, FILTRO_PERSONAS fp_ter_cre ';

              V_WHERE := 'WHERE odp.odp_suc_codigo =' || P_ODP_SUC_CODIGO ||' AND odp.odp_neg_consecutivo = ' || P_ODP_NEG_CONSECUTIVO;
              V_WHERE := V_WHERE || ' AND odp.odp_consecutivo =' || P_ODP_CONSECUTIVO || ' ';
              V_WHERE := V_WHERE || ' AND odp.ODP_FIC_PER_NUM_IDEN = fic.FIC_PER_NUM_IDEN AND odp.ODP_FIC_PER_TID_CODIGO = fic.FIC_PER_TID_CODIGO';
              V_WHERE := V_WHERE || ' AND odp.odp_cot_mnemonico = cot.cot_mnemonico AND fp_deb.per_num_iden = odp.odp_ccc_cli_per_num_iden AND fp_deb.per_tid_codigo = odp.odp_ccc_cli_per_tid_codigo ';
              V_WHERE := V_WHERE || ' AND fp_ter_cre.per_num_iden = odp.odp_ccc_cli_per_num_iden AND fp_ter_cre.per_tid_codigo = odp.odp_ccc_cli_per_tid_codigo ';

          ELSIF R_PAGAR_A.ODP_PAGAR_A = 'O' THEN

              V_SELECT := 'SELECT odp.odp_consecutivo NUMERO_OP, (SELECT OCU_CODIGO FROM OPERACIONES_CUD_SEBRA WHERE OCU_CODIGO = '||P_ODP_OCU_CODIGO||') CODIGO_OP_CUD, odp.odp_monto_orden CANTIDAD, ';
              V_SELECT := V_SELECT || 'odp.odp_fecha_ejecucion FECHA_APLICACION, odp.odp_ccc_cli_per_num_iden ID_TERCERO_DEB, ';
              V_SELECT := V_SELECT || 'fp_deb.per_nombre NOMBRE_TERCERO_DEB, odp.odp_ocl_cli_per_num_iden_relac ID_TERCERO_CRE, fp_ter_cre.per_nombre NOMBRE_TERCERO_CRE, ';
              V_SELECT := V_SELECT || 'odp.odp_FIC_PER_NUM_IDEN NIT_CTA_CREDITO, NVL(fic.fic_cuenta_br,0) CTA_DEPOSITO_BR_CRE, ODP_ES_CLIENTE ES_CLIENTE,odp.odp_pagar_a PAGAR_A ';

              V_FROM := 'FROM ORDENES_DE_PAGO odp, FIRMAS_COMISIONISTAS fic, CONCEPTOS_TESORERIA cot, FILTRO_PERSONAS fp_deb, FILTRO_PERSONAS fp_ter_cre ';

              V_WHERE := 'WHERE odp.odp_suc_codigo =' || P_ODP_SUC_CODIGO ||' AND odp.odp_neg_consecutivo = ' || P_ODP_NEG_CONSECUTIVO;
              V_WHERE := V_WHERE || ' AND odp.odp_consecutivo =' || P_ODP_CONSECUTIVO || ' ';
              V_WHERE := V_WHERE || ' AND odp.odp_ocl_cli_per_num_iden_relac = fic.FIC_PER_NUM_IDEN(+) AND odp.odp_ocl_cli_per_tid_codigo_rel = fic.FIC_PER_TID_CODIGO(+) ';
              V_WHERE := V_WHERE || ' AND odp.odp_cot_mnemonico = cot.cot_mnemonico AND fp_deb.per_num_iden = odp.odp_ccc_cli_per_num_iden AND fp_deb.per_tid_codigo = odp.odp_ccc_cli_per_tid_codigo ';
              V_WHERE := V_WHERE || ' AND fp_ter_cre.per_num_iden = odp.odp_ocl_cli_per_num_iden_relac AND fp_ter_cre.per_tid_codigo = odp.odp_ocl_cli_per_tid_codigo_rel ';

          ELSIF R_PAGAR_A.ODP_PAGAR_A = 'T' THEN

              V_SELECT := 'SELECT odp.odp_consecutivo NUMERO_OP, (SELECT OCU_CODIGO FROM OPERACIONES_CUD_SEBRA WHERE OCU_CODIGO = '||P_ODP_OCU_CODIGO||') CODIGO_OP_CUD, odp.odp_monto_orden CANTIDAD, ';
              V_SELECT := V_SELECT || 'odp.odp_fecha_ejecucion FECHA_APLICACION, odp.odp_ccc_cli_per_num_iden ID_TERCERO_DEB, ';
              V_SELECT := V_SELECT || 'fp_deb.per_nombre NOMBRE_TERCERO_DEB, odp.odp_num_iden ID_TERCERO_CRE, odp.odp_a_nombre_de NOMBRE_TERCERO_CRE, ';
              V_SELECT := V_SELECT || 'odp.odp_FIC_PER_NUM_IDEN NIT_CTA_CREDITO, NVL(fic.fic_cuenta_br,0) CTA_DEPOSITO_BR_CRE, ODP_ES_CLIENTE ES_CLIENTE,odp.odp_pagar_a PAGAR_A ';

              V_FROM := 'FROM ORDENES_DE_PAGO odp, FIRMAS_COMISIONISTAS fic, CONCEPTOS_TESORERIA cot, FILTRO_PERSONAS fp_deb ';

              V_WHERE := 'WHERE odp.odp_suc_codigo =' || P_ODP_SUC_CODIGO ||' AND odp.odp_neg_consecutivo = ' || P_ODP_NEG_CONSECUTIVO;
              V_WHERE := V_WHERE || ' AND odp.odp_consecutivo =' || P_ODP_CONSECUTIVO || ' ';
              V_WHERE := V_WHERE || ' AND odp.odp_ccc_cli_per_num_iden = fic.FIC_PER_NUM_IDEN(+) AND odp.odp_ccc_cli_per_tid_codigo = fic.FIC_PER_TID_CODIGO(+) ';
              V_WHERE := V_WHERE || ' AND odp.odp_cot_mnemonico = cot.cot_mnemonico AND fp_deb.per_num_iden = odp.odp_ccc_cli_per_num_iden AND fp_deb.per_tid_codigo = odp.odp_ccc_cli_per_tid_codigo ';
          END IF;
    END IF;

  OPEN C_ODP FOR (V_SELECT || V_FROM || V_WHERE);
  FETCH C_ODP INTO R_ODP;

  OPEN io_cursor FOR

      SELECT R_ODP.NUMERO_OP NUMERO_OP, R_ODP.CODIGO_OP_CUD CODIGO_OP_CUD, R_ODP.CANTIDAD CANTIDAD, R_ODP.FECHA_APLICACION FECHA_APLICACION,
             R_ODP.ID_TERCERO_DEB ID_TERCERO_DEB, R_ODP.NOMBRE_TERCERO_DEB NOMBRE_TERCERO_DEB,
             R_ODP.ID_TERCERO_CRE ID_TERCERO_CRE, R_ODP.NOMBRE_TERCERO_CRE NOMBRE_TERCERO_CRE, R_ODP.NIT_CTA_CREDITO NIT_CTA_CREDITO,
             R_ODP.CTA_DEPOSITO_BR_CRE CTA_DEPOSITO_BR_CRE, R_ODP.ES_CLIENTE ES_CLIENTE, R_ODP.PAGAR_A PAGAR_A
      FROM DUAL;


END ORDENES_PAGO_SEBRA_REGISTRADAS;

/*Nżmero de archivos contingencia Sebra*/
PROCEDURE NUM_ARCHIVO_CONTINGENCIA_SEBRA(io_cursor IN OUT O_CURSOR) IS

BEGIN
   OPEN io_cursor FOR

        SELECT  CON_VALOR
        FROM    CONSTANTES
        WHERE   CON_MNEMONICO = 'NAS';

END NUM_ARCHIVO_CONTINGENCIA_SEBRA;

/*Actualizaciżn nżmero de archivos sebra*/
PROCEDURE ACT_NUM_ARCHIVO_CONTI_PSE IS

BEGIN
   UPDATE CONSTANTES
   SET    CON_VALOR = CON_VALOR + 1
   WHERE   CON_MNEMONICO = 'NAS';

END ACT_NUM_ARCHIVO_CONTI_PSE;

PROCEDURE LEER_DATOS_SALIDA_BANREP (P_TSE_NUM_TRANSACCION IN NUMBER, P_TSE_TOTAL_TRANSACCIONES IN NUMBER,
  P_TSE_NUMERO_ORIGINADOR IN VARCHAR2, P_TSE_OPERACION_BANREP IN NUMBER, P_TSE_ESTADO IN VARCHAR2, P_TSE_CODIGO_ERROR IN VARCHAR2,
  P_TSE_DESCRIPCION_ERROR IN VARCHAR2, P_TSE_MONEDA IN VARCHAR2, P_TSE_CANTIDAD IN NUMBER, P_TSE_CODIGO_TRANSACCION IN NUMBER,
  P_TSE_TIPO IN NUMBER, P_TSE_OBSERVACIONES IN VARCHAR2, P_TSE_NIT_CTA_DEBITO IN VARCHAR2, P_TSE_SUCURSAL_CTA_DEBITO IN NUMBER,
  P_TSE_CTA_DEPOSITO_BR_DEB IN NUMBER, P_TSE_PORTAFOLIO_CTA_DEB IN NUMBER, P_TSE_CODIGO_MON_CTA_DEB IN VARCHAR2,
  P_TSE_ID_TERCERO_DEB IN VARCHAR2, P_TSE_NOMBRE_TERCERO_DEB IN VARCHAR2, P_TSE_ID_TERCERO_CRE IN VARCHAR2,
  P_TSE_NOMBRE_TERCERO_CRE IN VARCHAR2, P_TSE_NIT_CTA_CREDITO IN VARCHAR2, P_TSE_SUCURSAL_CTA_CREDITO IN NUMBER,
  P_TSE_CTA_DEPOSITO_BR_CRE IN NUMBER, P_TSE_PORTAFOLIO_CTA_CRE IN NUMBER, P_TSE_CODIGO_MON_CTA_CRE IN VARCHAR2) AS

  BEGIN
    INSERT INTO TMP_CONTINGENCIA_SEBRA
    (TSE_NUM_TRANSACCION, TSE_TOTAL_TRANSACCIONES, TSE_NUMERO_ORIGINADOR, TSE_OPERACION_BANREP, TSE_ESTADO, TSE_CODIGO_ERROR,
      TSE_DESCRIPCION_ERROR, TSE_MONEDA, TSE_CANTIDAD, TSE_CODIGO_TRANSACCION, TSE_TIPO, TSE_OBSERVACIONES, TSE_NIT_CTA_DEBITO,
      TSE_SUCURSAL_CTA_DEBITO, TSE_CTA_DEPOSITO_BR_DEB, TSE_PORTAFOLIO_CTA_DEB, TSE_CODIGO_MON_CTA_DEB, TSE_ID_TERCERO_DEB,
      TSE_NOMBRE_TERCERO_DEB, TSE_ID_TERCERO_CRE, TSE_NOMBRE_TERCERO_CRE, TSE_NIT_CTA_CREDITO, TSE_SUCURSAL_CTA_CREDITO,
      TSE_CTA_DEPOSITO_BR_CRE, TSE_PORTAFOLIO_CTA_CRE, TSE_CODIGO_MON_CTA_CRE)
  VALUES
    (P_TSE_NUM_TRANSACCION, P_TSE_TOTAL_TRANSACCIONES, P_TSE_NUMERO_ORIGINADOR, P_TSE_OPERACION_BANREP,
    P_TSE_ESTADO, P_TSE_CODIGO_ERROR, P_TSE_DESCRIPCION_ERROR, P_TSE_MONEDA, P_TSE_CANTIDAD, P_TSE_CODIGO_TRANSACCION,
    P_TSE_TIPO, P_TSE_OBSERVACIONES, P_TSE_NIT_CTA_DEBITO, P_TSE_SUCURSAL_CTA_DEBITO,
    P_TSE_CTA_DEPOSITO_BR_DEB, P_TSE_PORTAFOLIO_CTA_DEB, P_TSE_CODIGO_MON_CTA_DEB,
    P_TSE_ID_TERCERO_DEB, P_TSE_NOMBRE_TERCERO_DEB, P_TSE_ID_TERCERO_CRE,
    P_TSE_NOMBRE_TERCERO_CRE, P_TSE_NIT_CTA_CREDITO, P_TSE_SUCURSAL_CTA_CREDITO,
    P_TSE_CTA_DEPOSITO_BR_CRE, P_TSE_PORTAFOLIO_CTA_CRE, P_TSE_CODIGO_MON_CTA_CRE);

END LEER_DATOS_SALIDA_BANREP;

PROCEDURE P_NOTIFICAR_OPERACION_RF( P_ID_ORDEN           IN NUMBER,
                                    P_BOL_MNEMONICO      IN VARCHAR2,
                                    P_COC_CTO_MNEMONICO  IN VARCHAR2,
                                    P_FOLIO              IN VARCHAR2,
                                    P_TIPO               IN VARCHAR2,
                                    P_CANTIDAD           IN NUMBER,
                                    P_FECHA_HORA_REGIS   IN VARCHAR2,
                                    P_FECHA_CUMP_TITULO  IN VARCHAR2,
                                    P_PRECIO             IN NUMBER,
                                    P_DIAS_CUMPLIMIENTO  IN NUMBER,
                                    P_TASA               IN NUMBER,
                                    P_NEMOTECNICO        IN VARCHAR2,
                                    P_FECHA_EMISION      IN VARCHAR2,
                                    P_MERCADO            IN VARCHAR2,
                                    P_ISIN               IN VARCHAR2,
                                    P_NEMO_SERIALIZADO   IN VARCHAR2,
                                    P_TRADER             IN VARCHAR2,
                                    P_CODIGO_COM_VEN     IN VARCHAR2,
                                    P_UBICACION_TITULO   IN VARCHAR2,
                                    P_RUEDA              IN VARCHAR2,
                                    P_COD_FIRMA_CONTRA   IN VARCHAR2,
                                    P_TIPO_MER_PRI_SEC   IN VARCHAR2,
                                    P_PLAZO_REPO         IN VARCHAR2,
                                    P_MONEDA             IN VARCHAR2,
                                    P_VALOR_TOTAL        IN NUMBER,
                                    P_PRECIO_LIMPIO      IN NUMBER,
                                    P_FIJA_PRECIO        IN VARCHAR2,
                                    P_DVL_FISICO         IN VARCHAR2,
                                    P_ORIGEN_PUNTA       IN VARCHAR2,
                                    P_TIPO_OPERACION     IN VARCHAR2,
                                    P_TIPO_OPERACION_SER IN VARCHAR2,
                                    P_TIPO_OPERACION_CON IN VARCHAR2,
                                    P_PLAZO_LIQUIDACION  IN VARCHAR2,
                                    P_ESTADO_OPERACION   IN VARCHAR2,
                                    P_FUNGIBLE           IN NUMBER,
                                    P_TASA_REFERENCIA    IN VARCHAR2,
                                    P_PUNTOS_TASA        IN NUMBER,
                                    P_BASE_CALCULO       IN VARCHAR2,
                                    P_PER_PAGO_INTERESE  IN VARCHAR2,
                                    P_MODALIDAD          IN VARCHAR2,
                                    P_DURACION           IN VARCHAR2,
                                    P_NUM_DIAS_VENCI     IN NUMBER,
                                    P_FECHA_VENCIMI_TIT  IN VARCHAR2,
                                    P_PLAZO_EMI_DIAS     IN NUMBER,
                                    P_TASA_EMISION       IN NUMBER,
                                    P_FECHA_MONEDA       IN VARCHAR2,
                                    P_TASA_REPO          IN NUMBER,
                                    P_MONTO_RECOMPRA     IN NUMBER,
                                    P_CANTIDAD_RECOMPRA  IN NUMBER,
                                    P_ESTADO_TITULO      IN VARCHAR2,
                                    P_TASA_TTV           IN NUMBER,
                                    P_HORA_REGISTRO      IN VARCHAR2,
                                    P_ERRORES            IN OUT NUMBER) IS

  CURSOR C1(P_CODIGO_SIOPEL VARCHAR2) IS
    SELECT PER_NUM_IDEN
       , PER_TID_CODIGO
     , PER_TIPO
     , PER_RAZON_SOCIAL
     , PER_DIGITO_CONTROL
     , PER_PRIMER_APELLIDO
     , PER_SEGUNDO_APELLIDO
     , PER_NOMBRE
     , PER_SEXO
     , PER_ES_CORREDOR
     , PER_NOMBRE_USUARIO
     , PER_INICIALES_USUARIO
     , PER_SUC_CODIGO
     , PER_CPR_MNEMONICO
     , PER_MAIL_CORREDOR
     , PER_TIPO_COMERCIAL
     , PER_EJECUTA_ORDEN_MESA
     , PER_PER_NUM_IDEN
     , PER_PER_TID_CODIGO
     , PER_CCT_MNEMONICO
     , PER_ESTADO
     , PER_CLF_SECUENCIAL
     , PER_TELEFONO_DIRECTO
     , PER_CODIGO_BOLSA
     , PER_COMERCIAL_ACC_DIRECTO
     , PER_CODIGO_SAE_ACC
     , PER_COMPLEMENTACION
     , PER_COMERCIAL_OPX
     , PER_USUARIO_DECEVAL
     , PER_ID_USUARIO_DECEVAL
     , PER_CODIGO_SIOPEL
     , PER_CODIGO_XSTREAM
     , PER_NOTIFICA_CENLINEA
     , PER_TIP_COMERCIAL_UDF
     , PER_ORIGEN
     , PER_REPRESENTANTE_LEGAL
     , PER_CODIGO_SAE_DER
     , PER_ES_PAGADOR
     , PER_ESTADO_FACTORING
     , PER_CODIGO_CONTABLE
     , PER_GOBIERNO
     , PER_SUPERBANCARIA
     , PER_ENTIDAD_CARTA
     , PER_PERSONA_CARTA
     , PER_DIRECCION_CARTA
     , PER_AGE_CODIGO
     , PER_CNU_MNEMONICO
     , PER_NATURALEZA_JURIDICA
     , PER_CORPORATIVO
     , PER_CTSE_MNEMONICO
     , PER_MERCADO
     , PER_FACTORING
     , PER_MODULO
     , PER_SECTOR_PIP
     , PER_BROKER
     , PER_PREPAGO
    FROM PERSONAS
    WHERE PER_NOTIFICA_CENLINEA = 'S'
      AND PER_CODIGO_SIOPEL = SUBSTR(P_CODIGO_SIOPEL, LENGTH(P_CODIGO_SIOPEL)-1,LENGTH(P_CODIGO_SIOPEL));
  C_C1 C1%ROWTYPE;


  P_VALOR            NUMBER;
  P_VALOR_DATE       DATE;
  P_VALOR_CHAR       VARCHAR2(200);
  V_FOLIO_COEASY     NUMBER;
  V_FECHA_HORA_REGIS VARCHAR2(30);


BEGIN
  /* VALIDA QUE INDIDICADOR DE ENRURAMIENTO ESTE ACTIVO */
  P_TOOLS.CONSULTARCONSTANTE(
    P_CONSTANTE => 'ENA',
    P_VALOR => P_VALOR,
    P_VALOR_DATE => P_VALOR_DATE,
    P_VALOR_CHAR => P_VALOR_CHAR
    );
  V_FOLIO_COEASY := TO_CHAR(SYSDATE,'YYYYMMDD')||TRIM(TO_CHAR(TO_NUMBER(P_FOLIO),'000000000'));
  IF NVL(P_VALOR_CHAR,'N') = 'S' THEN
    IF P_ID_ORDEN IS NULL AND P_TRADER IS NOT NULL THEN
      /* SE REPORTAN LAS OPERACIONES DE SOLO LA POSICION PERSONAS MARCADAS PER_NOTIFICA_CENLINEA = 'S'*/

      IF P_FECHA_HORA_REGIS IS NOT NULL THEN
        V_FECHA_HORA_REGIS := TO_CHAR(TO_DATE(SUBSTR(P_FECHA_HORA_REGIS,1,10),'DD/MM/YYYY'),'YYYY-MM-DD')||SUBSTR(P_FECHA_HORA_REGIS,11,LENGTH(P_FECHA_HORA_REGIS));
      ELSE
         V_FECHA_HORA_REGIS := NULL;
      END IF;

      OPEN C1(P_TRADER);
      FETCH C1 INTO C_C1;
      IF C1%FOUND  THEN
        INSERT INTO CENLINEA_NOTIFICA_RF
          (CNRF_CONSECUTIVO,
           CNRF_ESTADO,
           CNRF_FECHA_INGRESO,
           CNRF_FECHA_ENTREGA,
           CNRF_ID_ORDEN,
           CNRF_BOL_MNEMONICO,
           CNRF_COC_LICTO_MNEMONICO,
           CNRF_FOLIO_SAE,
           CNRF_NUMERO_OPERACION,
           CNRF_TIPO,
           CNRF_CANTIDAD,
           CNRF_FECHA_HORA_REGIS,
           CNRF_FECHA_CUMP_TITULO,
           CNRF_PRECIO,
           CNRF_DIAS_CUMPLIMIENTO,
           CNRF_TASA,
           CNRF_NEMOTECNICO,
           CNRF_FECHA_EMISION,
           CNRF_MERCADO,
           CNRF_ISIN,
           CNRF_NEMO_SERIALIZADO,
           CNRF_TRADER,
           CNRF_CODIGO_COM_VEN,
           CNRF_UBICACION_TITULO,
           CNRF_RUEDA,
           CNRF_COD_FIRMA_CONTRA,
           CNRF_TIPO_MER_PRI_SEC,
           CNRF_PLAZO_REPO,
           CNRF_MONEDA,
           CNRF_VALOR_TOTAL,
           CNRF_PRECIO_LIMPIO,
           CNRF_FIJA_PRECIO ,
           CNRF_DVL_FISICO,
           CNRF_ORIGEN_PUNTA,
           CNRF_TIPO_OPERACION,
           CNRF_TIPO_OPERACION_SER,
           CNRF_TIPO_OPERACION_CON,
           CNRF_PLAZO_LIQUIDACION,
           CNRF_ESTADO_OPERACION,
           CNRF_FUNGIBLE,
           CNRF_TASA_REFERENCIA,
           CNRF_PUNTOS_TASA,
           CNRF_BASE_CALCULO,
           CNRF_PER_PAGO_TERESE,
           CNRF_MODALIDAD,
           CNRF_DURACION,
           CNRF_NUM_DIAS_VENCI,
           CNRF_FECHA_VENCIMI_TIT,
           CNRF_PLAZO_EMI_DIAS,
           CNRF_TASA_EMISION,
           CNRF_FECHA_MONEDA,
           CNRF_TASA_REPO,
           CNRF_MONTO_RECOMPRA,
           CNRF_CANTIDAD_RECOMPRA,
           CNRF_ESTADO_TITULO,
           CNRF_TASA_TTV,
           CNRF_HORA_REGISTRO,
           CNRF_EOC_MNENMONICO
           )
         VALUES
         (
            CNRF_SEQ.NEXTVAL,                                                                     --CNRF_CONSECUTIVO
            'POR_PROCESAR',                                                                       --CNRF_ESTADO
            SYSDATE,                                                                              --CNRF_FECHA_INGRESO,
            NULL,                                                                                 --CNRF_FECHA_ENTREGA,
            NULL,                                                                                 --CNRF_ID_ORDEN,
            'MEC',                                                                                --CNRF_BOL_MNEMONICO,
            'RF',                                                                                --CNRF_COC_LICTO_MNEMONICO,
            P_FOLIO,                                                                              --CNRF_FOLIO_SAE,
            V_FOLIO_COEASY,                                                                       --CNRF_NUMERO_OPERACION,
            P_TIPO,                                                                               --CNRF_TIPO,
            P_CANTIDAD,                                                                           --CNRF_CANTIDAD,
            V_FECHA_HORA_REGIS,                                                                   --CNRF_FECHA_HORA_REGIS,
            SUBSTR(P_FECHA_CUMP_TITULO,1,10),                                                     --CNRF_FECHA_CUMP_TITULO,
            P_PRECIO,                                                                             --CNRF_PRECIO,
            P_DIAS_CUMPLIMIENTO,                                                                  --CNRF_DIAS_CUMPLIMIENTO,
            P_TASA,                                                                               --CNRF_TASA,
            P_NEMOTECNICO,                                                                        --CNRF_NEMOTECNICO,
            SUBSTR(P_FECHA_EMISION,1,10),                                                         --CNRF_FECHA_EMISION,
            P_MERCADO,                                                                            --CNRF_MERCADO,
            P_ISIN,                                                                               --CNRF_ISIN,
            P_NEMO_SERIALIZADO,                                                                   --CNRF_NEMO_SERIALIZADO,
            P_TRADER,                                                                             --CNRF_TRADER,
            P_CODIGO_COM_VEN,                                                                     --CNRF_CODIGO_COM_VEN,
            P_UBICACION_TITULO,                                                                   --CNRF_UBICACION_TITULO,
            P_RUEDA,                                                                                --CNRF_RUEDA,
            P_COD_FIRMA_CONTRA,                                                                     --CNRF_COD_FIRMA_CONTRA,
            P_TIPO_MER_PRI_SEC,                                                                     --CNRF_TIPO_MER_PRI_SEC,
            P_PLAZO_REPO,                                                                           --CNRF_PLAZO_REPO,
            P_MONEDA,                                                                               --CNRF_MONEDA,
            P_VALOR_TOTAL,                                                                          --CNRF_VALOR_TOTAL,
            P_PRECIO_LIMPIO,                                                                        --CNRF_PRECIO_LIMPIO,
            P_FIJA_PRECIO,                                                                          --CNRF_FIJA_PRECIO,
            P_DVL_FISICO,                                                                           --CNRF_DVL_FISICO,
            P_ORIGEN_PUNTA,                                                                         --CNRF_ORIGEN_PUNTA,
            P_TIPO_OPERACION,                                                                       --CNRF_TIPO_OPERACION,
            P_TIPO_OPERACION_SER,                                                                   --CNRF_TIPO_OPERACION_SER,
            P_TIPO_OPERACION_CON,                                                                   --CNRF_TIPO_OPERACION_CON,
            P_PLAZO_LIQUIDACION,                                                                    --CNRF_PLAZO_LIQUIDACION,
            P_ESTADO_OPERACION,                                                                     --CNRF_ESTADO_OPERACION,
            P_FUNGIBLE,                                                                           --CNRF_FUNGIBLE,
            P_TASA_REFERENCIA,                                                                      --CNRF_TASA_REFERENCIA,
            P_PUNTOS_TASA,                                                                          --CNRF_PUNTOS_TASA,
            P_BASE_CALCULO,                                                                         --CNRF_BASE_CALCULO,
            P_PER_PAGO_INTERESE,                                                                    --CNRF_PER_PAGO_TERESE,
            P_MODALIDAD,                                                                            --CNRF_MODALIDAD,
            P_DURACION,                                                                             --CNRF_DURACION,
            P_NUM_DIAS_VENCI,                                                                       --CNRF_NUM_DIAS_VENCI,
            SUBSTR(P_FECHA_VENCIMI_TIT,1,10),                                                       --CNRF_FECHA_VENCIMI_TIT,
            P_PLAZO_EMI_DIAS,                                                                       --CNRF_PLAZO_EMI_DIAS,
            P_TASA_EMISION,                                                                         --CNRF_TASA_EMISION,
            P_FECHA_MONEDA,                                                                         --CNRF_FECHA_MONEDA,
            P_TASA_REPO,                                                                            --CNRF_TASA_REPO,
            P_MONTO_RECOMPRA,                                                                       --CNRF_MONTO_RECOMPRA,
            P_CANTIDAD_RECOMPRA,                                                                    --CNRF_CANTIDAD_RECOMPRA,
            P_ESTADO_TITULO,                                                                        --CNRF_ESTADO_TITULO,
            P_TASA_TTV,                                                                             --CNRF_TASA_TTV,
            P_HORA_REGISTRO,                                                                        --CNRF_HORA_REGISTRO
            'COL'                                                                                   --CNRF_EOC_MNENMONICO
            );

      END IF;
    END IF;
  END IF;
END P_NOTIFICAR_OPERACION_RF;

PROCEDURE P_ACTUALIZAR_ENRUTAMIENTO (P_ID_ORDEN     IN NUMBER,
                                     P_TIPO_ORDEN   IN VARCHAR2,
                                     P_TID_CODIGO   IN VARCHAR2,
                                     P_NUM_IDEN     IN VARCHAR2,
                                     P_ERRORES      IN OUT NUMBER) IS
  CURSOR ORDEN_C IS
    SELECT OCO_EOC_MNEMONICO,OCO_LEO_CONSECUTIVO
    FROM ORDENES_COMPRA
    WHERE OCO_CONSECUTIVO = P_ID_ORDEN
      AND OCO_BOL_MNEMONICO = 'COL'
      AND OCO_COC_CTO_MNEMONICO = 'ACC';

  CURSOR ORDEN_V IS
    SELECT OVE_EOC_MNEMONICO,OVE_LEO_CONSECUTIVO,OVE_CODIGO_INFORMADOR
    FROM ORDENES_VENTA
    WHERE OVE_CONSECUTIVO = P_ID_ORDEN
      AND OVE_BOL_MNEMONICO = 'COL'
      AND OVE_COC_CTO_MNEMONICO = 'ACC';

  V_EOC_MNEMONICO     ORDENES_COMPRA.OCO_EOC_MNEMONICO%TYPE;
  V_LEO_CONSECUTIVO   ORDENES_COMPRA.OCO_LEO_CONSECUTIVO%TYPE;
  V_CODIGO_INFORMADOR ORDENES_VENTA.OVE_CODIGO_INFORMADOR%TYPE;
  V_MENSAJE           VARCHAR2(100);
BEGIN
   V_EOC_MNEMONICO     := NULL;
   V_LEO_CONSECUTIVO   := NULL;
   V_CODIGO_INFORMADOR := NULL;
   IF P_TIPO_ORDEN = 'C' THEN
      OPEN ORDEN_C;
      FETCH ORDEN_C INTO V_EOC_MNEMONICO,V_LEO_CONSECUTIVO;
      CLOSE ORDEN_C;
      V_MENSAJE := 'La orden de compra '||TO_CHAR(P_ID_ORDEN);
   ELSIF P_TIPO_ORDEN = 'V' THEN
      OPEN ORDEN_V;
      FETCH ORDEN_V INTO V_EOC_MNEMONICO,V_LEO_CONSECUTIVO,V_CODIGO_INFORMADOR;
      CLOSE ORDEN_V;
      V_MENSAJE := 'La orden de venta '||TO_CHAR(P_ID_ORDEN);
   END IF;

   V_EOC_MNEMONICO := NVL(V_EOC_MNEMONICO,' ');
   V_LEO_CONSECUTIVO := NVL(V_LEO_CONSECUTIVO,0);

   IF V_LEO_CONSECUTIVO IN (8,9,3) AND V_CODIGO_INFORMADOR IS NOT NULL THEN -- ORDENES DE ORIGEN PLV
      IF V_EOC_MNEMONICO != 'PCO' THEN
         P_CAB.CrearError(V_MENSAJE||' en estado invalido. No es posible actualizar su estado');
      ELSE
         IF P_TIPO_ORDEN = 'C' THEN
            UPDATE ORDENES_COMPRA
            SET  OCO_EOC_MNEMONICO     = 'COL'
                ,OCO_FECHA_Y_HORA      = SYSDATE --P_FECHA
                ,OCO_HORA_RECEPCION    = TO_CHAR(SYSDATE,'HH24:MI')
                ,OCO_FECHA_RECEPCION   = SYSDATE
                ,OCO_FECHA_PERMANENCIA = DECODE(OCO_VIO_MNEMONICO,'HFE',SYSDATE+30,NULL)
                ,OCO_PER_TID_ENRUTA    = P_TID_CODIGO
                ,OCO_PER_NUM_ENRUTA    = P_NUM_IDEN
            WHERE OCO_CONSECUTIVO = P_ID_ORDEN
              AND OCO_BOL_MNEMONICO = 'COL'
              AND OCO_COC_CTO_MNEMONICO = 'ACC';
            IF SQL%ROWCOUNT = 0 THEN
               RAISE_APPLICATION_ERROR(-20001,'Orden:'||P_TIPO_ORDEN||'-'||P_ID_ORDEN ||' no existe .. no es posible actualizar estado') ;
             END IF;
         END IF;

         IF P_TIPO_ORDEN = 'V' THEN
            UPDATE ORDENES_VENTA
            SET  OVE_EOC_MNEMONICO     = 'COL'
                ,OVE_FECHA_Y_HORA      = SYSDATE --P_FECHA
                ,OVE_HORA_RECEPCION    = TO_CHAR(SYSDATE,'HH24:MI')
                ,OVE_FECHA_RECEPCION   = SYSDATE
                ,OVE_FECHA_PERMANENCIA = DECODE(OVE_VIO_MNEMONICO,'HFE',SYSDATE+30,NULL)
                ,OVE_PER_TID_ENRUTA    = P_TID_CODIGO
                ,OVE_PER_NUM_ENRUTA    = P_NUM_IDEN
            WHERE OVE_CONSECUTIVO = P_ID_ORDEN
              AND OVE_BOL_MNEMONICO = 'COL'
              AND OVE_COC_CTO_MNEMONICO = 'ACC';
            IF SQL%ROWCOUNT = 0 THEN
               RAISE_APPLICATION_ERROR(-20002,'Orden:'||P_TIPO_ORDEN||'-'||P_ID_ORDEN ||' no existe .. no es posible actualizar estado') ;
             END IF;
         END IF;
         COMMIT;
      END IF;
   ELSIF V_LEO_CONSECUTIVO = 9 THEN -- ORDENES DE ORIGEN UDF
      IF V_EOC_MNEMONICO != 'COL' THEN
         P_CAB.CrearError(V_MENSAJE||' en estado invalido. No es posible actualizar su estado');
      ELSE
         IF P_TIPO_ORDEN = 'C' THEN
            UPDATE ORDENES_COMPRA
            SET  OCO_PER_TID_ENRUTA    = P_TID_CODIGO
                ,OCO_PER_NUM_ENRUTA    = P_NUM_IDEN
            WHERE OCO_CONSECUTIVO = P_ID_ORDEN
              AND OCO_BOL_MNEMONICO = 'COL'
              AND OCO_COC_CTO_MNEMONICO = 'ACC';
            IF SQL%ROWCOUNT = 0 THEN
              RAISE_APPLICATION_ERROR(-20003,'Orden:'||P_TIPO_ORDEN||'-'||P_ID_ORDEN ||' no existe .. no es posible actualizar usuario de enrutamiento') ;
            END IF;
         END IF;
         IF P_TIPO_ORDEN = 'V' THEN
            UPDATE ORDENES_VENTA
            SET  OVE_PER_TID_ENRUTA    = P_TID_CODIGO
                ,OVE_PER_NUM_ENRUTA    = P_NUM_IDEN
            WHERE OVE_CONSECUTIVO = P_ID_ORDEN
              AND OVE_BOL_MNEMONICO = 'COL'
              AND OVE_COC_CTO_MNEMONICO = 'ACC';
            IF SQL%ROWCOUNT = 0 THEN
               RAISE_APPLICATION_ERROR(-20004,'Orden:'||P_TIPO_ORDEN||'-'||P_ID_ORDEN ||' no existe .. no es posible actualizar usuario de enrutamiento') ;
            END IF;
         END IF;
         COMMIT;
      END IF;
   ELSE
      IF P_TIPO_ORDEN = 'C' THEN
         P_CAB.CrearError(V_MENSAJE||'. No puede actualizar su estado ');
      ELSIF P_TIPO_ORDEN = 'V' THEN
         P_CAB.CrearError(V_MENSAJE ||'. No puede actualizar su estado ');
      END IF;
      P_ERRORES := P_ERRORES+1;
   END IF;
END P_ACTUALIZAR_ENRUTAMIENTO;


PROCEDURE P_VALIDAR_SALDO_ETRADE(P_CODIGO_USUARIO        IN VARCHAR2,
                                 P_CUENTAS_CORREDORES    IN NUMBER,
                                 P_CLI_PER_NUM_IDEN      IN VARCHAR2,
                                 P_CLI_PER_TID_CODIGO    IN VARCHAR2,
                                 P_PER_NUM_IDEN          IN VARCHAR2,
                                 P_PER_TID_CODIGO        IN VARCHAR2,
                                 P_CLASE_ORDEN           IN VARCHAR2,
                                 P_TIPO_ORDEN            IN VARCHAR2,
                                 P_ESPECIE               IN VARCHAR2,
                                 P_CANTIDAD              IN NUMBER,
                                 P_PRECIO_ORDEN          IN NUMBER,
                                 P_FECHA_HORA            IN VARCHAR2,
                                 P_CUENTA_DECEVAL        IN NUMBER,
                                 P_NUMERO_ORDEN          IN NUMBER,
                                 P_FECHA_VIGENCIA        IN VARCHAR2 DEFAULT NULL,
                                 P_TID_CODIGO_COMERCIAL  IN VARCHAR2 DEFAULT NULL,
                                 P_NUM_IDEN_COMERCIAL    IN VARCHAR2 DEFAULT NULL,
                                 P_ID_ORDEN              OUT NUMBER,
                                 P_CLOB                  OUT CLOB,
                                 /**WGONZALEZ**/
                                 P_VIG_TIPO_VIGENCIA       IN VARCHAR2 DEFAULT NULL,
                                 P_INS_REC_HORA            IN VARCHAR2 DEFAULT NULL,
                                 P_USUARIO                 IN VARCHAR2 DEFAULT NULL,
                                 P_COND_CANTIDAD_MINIMA    IN NUMBER DEFAULT NULL,
                                 P_COND_PRECIO_LIMITIE     IN NUMBER DEFAULT NULL,
                                 P_INS_REC_MEDIO           IN VARCHAR2 DEFAULT NULL,
                                 P_INS_REC_DETALLE         IN VARCHAR2 DEFAULT NULL,
                                 P_OBSERVACION             IN VARCHAR2 DEFAULT NULL,
                                 P_CANAL_ORIGEN            IN VARCHAR2 DEFAULT NULL,
                                 P_OBSERVACION_CORRECION   IN VARCHAR2 DEFAULT NULL,
                                 P_TIPO_COMISION           IN VARCHAR2 DEFAULT NULL,
                                 P_TIPO_ACTUALIZACION      IN VARCHAR2 DEFAULT NULL,
                                 P_ORDENANTE_TID_CODIGO    IN VARCHAR2 DEFAULT NULL,
                                 P_ORDENANTE_NUM_IDEN      IN VARCHAR2 DEFAULT NULL,
                                 P_ORDENANTE               IN VARCHAR2 DEFAULT NULL,
                                 P_USUARIO_RECEPCION       IN VARCHAR2 DEFAULT NULL,
                                 P_VALOR_COMISION          IN NUMBER DEFAULT NULL) IS


   CURSOR PORTAFOLIO(P_ENA_MNEMONICO VARCHAR2,
                    P_CUENTA_DECEVAL NUMBER) IS
    SELECT SUM(SALDO_DISPONIBLE) SALDO_DISPONIBLE
    FROM GL_PORTAFOLIO_CLIENTE
    WHERE ENA_MNEMONICO = P_ENA_MNEMONICO
    AND  CUENTA_DECEVAL = P_CUENTA_DECEVAL ;

   /*****CURSOR QUE RETORNA DATOS DEL USUARIO QUE MODIFICA LA ORDEN******/
    CURSOR INICIALES_D IS
        SELECT PER_TID_CODIGO
              ,PER_NUM_IDEN
              ,PER_INICIALES_USUARIO
              ,PER_SUC_CODIGO
              ,PER_EJECUTA_ORDEN_MESA
              ,SUC_NOMBRE
              ,PER_TIPO_COMERCIAL
              ,CPR_CONSULTA_GRUPO_INDIVIDUAL
              ,PER_CODIGO_SAE_ACC
              ,PER_TIP_COMERCIAL_UDF
        FROM   CENTROS_PRODUCCION
              ,PERSONAS_CENTROS_PRODUCCION
              ,PERSONAS
              ,SUCURSALES
        WHERE  CPR_ESTADO         = 'A'
        AND    CPR_MNEMONICO      = PCP_CPR_MNEMONICO
        AND    PCP_PER_NUM_IDEN   = PER_NUM_IDEN
        AND    PCP_PER_TID_CODIGO = PER_TID_CODIGO
        AND    PER_NOMBRE_USUARIO = UPPER(P_USUARIO)
        AND    PER_ES_CORREDOR    = 'S' /*CORREDOR*/
        AND    PER_ESTADO         = 'A'
        AND    PER_SUC_CODIGO     = SUC_CODIGO;
    R_INICIALES    INICIALES_D%ROWTYPE;

   IO_CURSOR             P_WEB_CLIENTE.O_CURSOR;
   IO_CURSOR_COMER       P_WEB_CLIENTE.O_CURSOR;
   IO_CURSOR_PORTAFOLIO  P_WEB_CLIENTE.O_CURSOR;
   IO_CURSOR_NOTIFICA    P_WEB_CLIENTE.O_CURSOR;
   V_CUENTAS_CORREDORES  CUENTAS_CLIENTE_CORREDORES%ROWTYPE;
   V_PERSONAS            PERSONAS%ROWTYPE;
   V_SUCURSALES          SUCURSALES%ROWTYPE;
   V_PER_RELACIONADA     PERSONAS_RELACIONADAS%ROWTYPE;
   V_PER_CODIGO_SAE_ACC  PERSONAS.PER_CODIGO_SAE_ACC%TYPE;
   V_CCP_PRO_MNEMONICO   VARCHAR2(50);
   V_PER_BACKUP          PERSONAS.PER_NOMBRE_USUARIO%TYPE;
   V_PCP_CPR_MNEMONICO   PERSONAS_CENTROS_PRODUCCION.PCP_CPR_MNEMONICO%TYPE;
   V_CUENTA_CORREDORES   CUENTAS_CLIENTE_CORREDORES.CCC_NUMERO_CUENTA%TYPE;
   V_PER_NUM_IDEN_ORD    CLIENTES.CLI_PER_NUM_IDEN%TYPE;
   V_PER_TID_CODIGO_ORD  CLIENTES.CLI_PER_TID_CODIGO%TYPE;
   V_PER_TIPO            PERSONAS.PER_TIPO%TYPE;
   V_PRECIO_LIMITIE      ORDENES_COMPRA.OCO_PRECIO_LIMITE_O_MARGEN%TYPE;
   V_CUENTA_DECEVAL      ORDENES_COMPRA.OCO_CUD_CUENTA_DECEVAL%TYPE;
   V_TITULO_CTA_DVAL     ORDENES_VENTA.OVE_CFC_CUENTA_DECEVAL%TYPE;
   V_INS_REC_HORA        ORDENES_VENTA.OVE_HORA_RECEPCION%TYPE;
   V_CONSECUTIVO         ORDENES_VENTA.OVE_CONSECUTIVO%TYPE;
   V_BOL_MNEMONICO       ORDENES_VENTA.OVE_BOL_MNEMONICO%TYPE;
   V_COC_CTO_MNEMONICO   ORDENES_VENTA.OVE_COC_CTO_MNEMONICO%TYPE;
   V_NOMINAL_O_PESOS     ORDENES_VENTA.OVE_NOMINAL_O_PESOS%TYPE;
   V_ID_CMA              ORDENES_VENTA.OVE_ID_CMA%TYPE;
   V_EOC_MNEMONICO       ORDENES_VENTA.OVE_EOC_MNEMONICO%TYPE;
   V_ENA_MNEMONICO       ORDENES_VENTA.OVE_ENA_MNEMONICO%TYPE;
   C_PORTAFOLIO          PORTAFOLIO%ROWTYPE;
   V_VALOR_CONS          CONSTANTES.CON_VALOR%TYPE;
   V_VALOR_DATE_CONS     CONSTANTES.CON_VALOR_DATE%TYPE;
   V_VALOR_CHAR_CONS     CONSTANTES.CON_VALOR_CHAR%TYPE;
   V_VALOR_COMI          CONSTANTES.CON_VALOR%TYPE;
   V_VALOR_DATE_COMI     CONSTANTES.CON_VALOR_DATE%TYPE;
   V_VALOR_CHAR_COMI     CONSTANTES.CON_VALOR_CHAR%TYPE;
   V_PRE_LIMITE_O_MARGEN ORDENES_VENTA.OVE_PRECIO_LIMITE_O_MARGEN%TYPE;
   V_COMISION_ACC        ORDENES_VENTA.OVE_COMISION_ACC%TYPE;
   V_IVA_ACC             ORDENES_VENTA.OVE_IVA_ACC%TYPE;
   V_TOTAL_OPERACION_ACC ORDENES_VENTA.OVE_TOTAL_OPERACION_ACC%TYPE;
   V_NETO_OPERACION_ACC  ORDENES_VENTA.OVE_NETO_OPERACION_ACC%TYPE;
   V_TOTAL_OPERACION     ORDENES_VENTA.OVE_TOTAL_OPERACION_ACC%TYPE;
   V_NETO_OPERACION      ORDENES_VENTA.OVE_NETO_OPERACION_ACC%TYPE;
   V_CANTIDAD_ACC        ORDENES_VENTA.OVE_CANTIDAD_ACC%TYPE;
   V_PRECIO_ACC          ORDENES_VENTA.OVE_PRECIO_ACC%TYPE;
   V_PORCENTAJE_COMISION ORDENES_VENTA.OVE_COMISION%TYPE;
   V_TOTAL_PARCIAL_NOM   ORDENES_VENTA.OVE_NOMINAL_O_PESOS%TYPE;
   V_CANTIDAD_ORDEN      ORDENES_VENTA.OVE_NOMINAL_O_PESOS%TYPE;
   V_TOTAL_PAR_VALOR_NOM ORDENES_VENTA.OVE_TOTAL_OPERACION_ACC%TYPE;
   V_VIO_MNEMMONICO      ORDENES_COMPRA.OCO_VIO_MNEMONICO%TYPE;
   V_COMISION_ESPECIAL   NUMBER;
   V_IND_COMISION_ESPE   VARCHAR2(2);
   V_FONDO_VALORES       VARCHAR(2);
   V_TITULO_ORIGEN       VARCHAR2(2);
   V_CCC_SALDO_CAPITAL   VARCHAR2(30);
   V_PER_ESTADO          NUMBER(1);
   V_PER_COMPLEMENTA     NUMBER(1);
   V_SELECT              VARCHAR2(1000);
   V_QUERY               VARCHAR2(4000);
   V_QUERY_NOTIFICACION  VARCHAR2(4000);
   V_ERRORES             NUMBER;
   V_SALDO               NUMBER;
   V_NOTIFICACI0NES      NUMBER(5);
   V_CANAL_ORIGEN        VARCHAR2(5);
   V_FECHA_PERMANENCIA   DATE;

   -- AJUSTES POR SALDOS NEGATIVOS
   V_CLI_PER_NUM_IDEN    ORDENES_COMPRA.OCO_CCC_CLI_PER_NUM_IDEN%TYPE;
   V_CLI_PER_TID_CODIGO  ORDENES_COMPRA.OCO_CCC_CLI_PER_TID_CODIGO%TYPE;
   V_CCC_NUMERO_CUENTA   ORDENES_COMPRA.OCO_CCC_NUMERO_CUENTA%TYPE;
   v_sql varchar2(4000);--wgonzalez
    --WILLIAM CAMPOS 03/04/2020 VARIABLES PARA CONTROL DE TIMEOUT PARA ORDENES DESDE HOMEBROKER
P_NUM_INI NUMBER;
P_NUM_FIN NUMBER;
P_INI_ORDEN DATE;
P_FIN_ORDEN DATE;
P_DIF_MIN_ORDEN NUMBER;

--FIN WILLIAM CAMPOS
   v_xml     XMLTYPE;
   v_error   VARCHAR2(8);
   v_mensaje VARCHAR2(2048);

BEGIN
   --VAGTUS900009.LogValidarSaldoEtrade
   BEGIN
    SELECT XMLELEMENT("P_VALIDAR_SALDO_ETRADE",
                      XMLAGG(XMLELEMENT("Cliente", XMLFOREST(P_CLI_PER_NUM_IDEN AS "CLI_PER_NUM_IDEN", P_CLI_PER_TID_CODIGO AS "CLI_PER_TID_CODIGO", P_CUENTAS_CORREDORES AS "CUENTAS_CORREDORES"))),
                      XMLAGG(XMLELEMENT("ParamIn", XMLFOREST(P_CODIGO_USUARIO as "P_CODIGO_USUARIO", P_CUENTAS_CORREDORES as "P_CUENTAS_CORREDORES", P_CLI_PER_NUM_IDEN as "P_CLI_PER_NUM_IDEN", P_CLI_PER_TID_CODIGO as "P_CLI_PER_TID_CODIGO", P_PER_NUM_IDEN as "P_PER_NUM_IDEN", P_PER_TID_CODIGO as "P_PER_TID_CODIGO", P_CLASE_ORDEN as "P_CLASE_ORDEN", P_TIPO_ORDEN as "P_TIPO_ORDEN", P_ESPECIE as "P_ESPECIE", P_CANTIDAD as "P_CANTIDAD", P_PRECIO_ORDEN as "P_PRECIO_ORDEN", P_FECHA_HORA as "P_FECHA_HORA", P_CUENTA_DECEVAL as "P_CUENTA_DECEVAL", P_NUMERO_ORDEN as "P_NUMERO_ORDEN", P_FECHA_VIGENCIA as "P_FECHA_VIGENCIA", P_TID_CODIGO_COMERCIAL as "P_TID_CODIGO_COMERCIAL", P_NUM_IDEN_COMERCIAL as "P_NUM_IDEN_COMERCIAL", P_VIG_TIPO_VIGENCIA as "P_VIG_TIPO_VIGENCIA", P_INS_REC_HORA as "P_INS_REC_HORA", P_USUARIO as "P_USUARIO", P_COND_CANTIDAD_MINIMA as "P_COND_CANTIDAD_MINIMA", P_COND_PRECIO_LIMITIE as "P_COND_PRECIO_LIMITIE", P_INS_REC_MEDIO as "P_INS_REC_MEDIO", P_INS_REC_DETALLE as "P_INS_REC_DETALLE", P_OBSERVACION as "P_OBSERVACION", P_CANAL_ORIGEN as "P_CANAL_ORIGEN", P_OBSERVACION_CORRECION as "P_OBSERVACION_CORRECION", P_TIPO_COMISION as "P_TIPO_COMISION", P_TIPO_ACTUALIZACION as "P_TIPO_ACTUALIZACION", P_ORDENANTE_TID_CODIGO as "P_ORDENANTE_TID_CODIGO", P_ORDENANTE_NUM_IDEN as "P_ORDENANTE_NUM_IDEN", P_ORDENANTE as "P_ORDENANTE", P_USUARIO_RECEPCION as "P_USUARIO_RECEPCION", P_VALOR_COMISION as "P_VALOR_COMISION"))),
                      XMLAGG(XMLELEMENT("ParamOut", XMLFOREST(NULL AS "Param"))),
                      XMLAGG(XMLELEMENT("Message", XMLFOREST('1.Entra al SP P_ORDENES_COMERCIAL.P_VALIDAR_SALDO_ETRADE con los parametros' AS "MESSAGE")))
                     ) xmlreg
    INTO   v_xml
    FROM   dual;

    prod.p_log_traza.InsertarLog(P_Procedure => 'ValidarSaldoEtrade',
                                 P_Xml       => v_xml,
                                 P_Error     => v_error,
                                 P_Msg       => v_mensaje);
  EXCEPTION
    WHEN OTHERS THEN
      NULL;
  END;

    --WILLIAM CAMPOS , PARA CALCULO DE TIMEOUT EN ORDENES HOMBEBROKER POR SERVICIO
    P_INI_ORDEN := SYSDATE;

   --1. Obtener informacion de cuentas corredores del cliente.
   IO_CURSOR            := NULL;
   IO_CURSOR_NOTIFICA   := NULL;
   IO_CURSOR_COMER      := NULL;
   IO_CURSOR_PORTAFOLIO := NULL;
   V_CUENTAS_CORREDORES := NULL;
   V_PER_CODIGO_SAE_ACC := NULL;
   V_CCP_PRO_MNEMONICO  := NULL;
   V_PERSONAS           := NULL;
   V_SUCURSALES         := NULL;
   V_PER_BACKUP         := NULL;
   V_PCP_CPR_MNEMONICO  := NULL;
   V_FONDO_VALORES      := NULL;
   V_PER_ESTADO         := NULL;
   V_PER_COMPLEMENTA    := NULL;
   V_PER_TIPO           := NULL;
   V_SELECT             := NULL;
   V_PER_RELACIONADA    := NULL;
   V_PER_NUM_IDEN_ORD   := NULL;
   V_PER_TID_CODIGO_ORD := NULL;
   V_PRECIO_LIMITIE     := NULL;
   V_CUENTA_DECEVAL     := NULL;
   V_TITULO_ORIGEN      := NULL;
   V_TITULO_CTA_DVAL    := NULL;
   V_INS_REC_HORA       := NULL;
   V_CUENTA_CORREDORES  := 0;
   V_CCC_SALDO_CAPITAL  := NULL;
   V_QUERY              := NULL;
   V_CONSECUTIVO        := NULL;
   V_BOL_MNEMONICO      := NULL;
   V_COC_CTO_MNEMONICO  := NULL;
   V_NOMINAL_O_PESOS    := NULL;
   V_ID_CMA             := NULL;
   V_EOC_MNEMONICO      := NULL;
   V_ERRORES            := 0;
   V_ENA_MNEMONICO      := NULL;
   C_PORTAFOLIO         := NULL;
   V_PRE_LIMITE_O_MARGEN := NULL;
   V_COMISION_ACC        := 0;
   V_IVA_ACC             := 0;
   V_TOTAL_OPERACION_ACC := 0;
   V_NETO_OPERACION_ACC  := 0;
   V_TOTAL_OPERACION     := 0;
   V_NETO_OPERACION      := 0;
   V_SALDO               := 0;
   V_CANTIDAD_ACC        := NULL;
   V_PRECIO_ACC          := NULL;
   V_PORCENTAJE_COMISION := 0;
   V_CANAL_ORIGEN        := NULL;
   V_QUERY_NOTIFICACION  := NULL;
   V_TOTAL_PARCIAL_NOM   := 0;
   V_TOTAL_PAR_VALOR_NOM := 0;
   V_CANTIDAD_ORDEN      := 0;

   --AJUSTE POR SALDO NEGATIVO
   V_CLI_PER_NUM_IDEN    := NULL;
   V_CLI_PER_TID_CODIGO  := NULL;
   V_CCC_NUMERO_CUENTA   := NULL;

IF P_CANAL_ORIGEN IN ('FIXBR') THEN /*****INGRESAN ORDENENES DESDE FIXBROKER *****/
   V_ERRORES := 0;

      V_QUERY := 'SELECT ORDE_CONSECUTIVO             '||
                      ' ,ORDE_EOC_MNEMONICO           '||
                      ' ,ORDE_CANAL_ORIGEN            '||
                      '  FROM ORDENES_DERIVADOS       '||
                      ' WHERE ORDE_CONSECUTIVO              = '||P_NUMERO_ORDEN||
                      '   AND ORDE_CCC_CLI_PER_NUM_IDEN     = '||CHR(39)||P_CLI_PER_NUM_IDEN||CHR(39)||
                      '   AND ORDE_CCC_CLI_PER_TID_CODIGO   = '||CHR(39)||P_CLI_PER_TID_CODIGO||CHR(39)||
                      '   AND ORDE_CCC_NUMERO_CUENTA        = '||P_CUENTAS_CORREDORES||
                      '   AND ORDE_CANAL_ORIGEN             = '||CHR(39)||P_CANAL_ORIGEN||CHR(39);

   OPEN IO_CURSOR FOR V_QUERY;
     LOOP
        FETCH IO_CURSOR INTO V_CONSECUTIVO,
                             V_EOC_MNEMONICO,
                             V_CANAL_ORIGEN;
        EXIT WHEN IO_CURSOR%NOTFOUND;
      IF NVL(V_CONSECUTIVO,0) = 0   THEN
         V_ERRORES := V_ERRORES+1;
         P_CAB.CREARERROR('Orden no existe. No es posible modificar la orden');
      END IF;

      IF NVL(V_CONSECUTIVO,0) > 0 THEN --VALIDACIONES DE ORDENES AL ACTUALIZAR VALOR --0
         IF V_EOC_MNEMONICO IN ('APL','ANU') THEN
            V_ERRORES := V_ERRORES+1;
            P_CAB.CREARERROR('Ordenes en estado '||V_EOC_MNEMONICO||', no pueden ser modificadas');
         END IF;
      END IF;
     END LOOP;
   CLOSE IO_CURSOR;

    OPEN INICIALES_D;
   FETCH INICIALES_D INTO R_INICIALES;
      IF INICIALES_D%NOTFOUND THEN
         V_ERRORES := V_ERRORES + 1;
         P_CAB.CREARERROR('Comercial no existe en COEASY');
      END IF;
   CLOSE INICIALES_D;

   IF V_ERRORES = 0 THEN

      UPDATE ORDENES_DERIVADOS
         SET ORDE_VIO_MNEMONICO           = P_VIG_TIPO_VIGENCIA
            ,ORDE_TOC_MNEMONICO           = DECODE(P_CLASE_ORDEN,'LIM','CLI')
            ,ORDE_HORA_RECEPCION          = P_INS_REC_HORA
            ,ORDE_FECHA_MODIFICACION      = SYSDATE --TO_DATE(SYSDATE,'DD/MM/YYYY HH24:MI:SS')
            ,ORDE_MODIFICADA_POR          = P_USUARIO
            ,ORDE_CANTIDAD_CONTRATOS      = P_CANTIDAD
            ,ORDE_CANTIDAD_MINIMA         = P_COND_CANTIDAD_MINIMA
            ,ORDE_PRECIO_LIMITE           = P_COND_PRECIO_LIMITIE
            ,ORDE_MEDIO_RECEPCION         = DECODE(P_INS_REC_MEDIO,'INT','OTR',P_INS_REC_MEDIO)
            ,ORDE_DETALLE_MEDIO_RECEPCION = P_INS_REC_DETALLE
            ,ORDE_OBSERVACION             = P_OBSERVACION
            ,ORDE_OBSERVACION_CORRECCION  = P_OBSERVACION_CORRECION
            ,ORDE_PER_NUM_IDEN_MODIFICA   = R_INICIALES.PER_NUM_IDEN
            ,ORDE_PER_TID_CODIGO_MODIFICA = R_INICIALES.PER_TID_CODIGO
            ,ORDE_ULTIMA_ACTUALIZACION    = P_TIPO_ACTUALIZACION
            ,ORDE_ORDENANTE               = P_ORDENANTE
            ,ORDE_RLC_PER_NUM_IDEN        = P_ORDENANTE_NUM_IDEN
            ,ORDE_RLC_PER_TID_CODIGO      = P_ORDENANTE_TID_CODIGO
            ,ORDE_USUARIO_RECEPCION       = P_USUARIO_RECEPCION
            ,ORDE_TIPO_COMISION           = P_TIPO_COMISION
            ,ORDE_COMISION                = DECODE(P_TIPO_COMISION,'P',P_VALOR_COMISION,ORDE_COMISION)
            ,ORDE_VALOR_COMISION          = DECODE(P_TIPO_COMISION,'V',P_VALOR_COMISION,ORDE_VALOR_COMISION)
      WHERE ORDE_CONSECUTIVO              = P_NUMERO_ORDEN
        AND ORDE_CCC_CLI_PER_NUM_IDEN     = P_CLI_PER_NUM_IDEN
        AND ORDE_CCC_CLI_PER_TID_CODIGO   = P_CLI_PER_TID_CODIGO
        AND ORDE_CCC_NUMERO_CUENTA        = P_CUENTAS_CORREDORES
        AND ORDE_CANAL_ORIGEN             = P_CANAL_ORIGEN;
        COMMIT; /*ESTE COMMIT ES EL DE TODO EL PROCESO*/
   ELSE
      P_CLOB := P_CAB.OBTENERCLOB_ERROR('ColocarOrdenDerivados') ;
   END IF;
ELSE /*****ENTRA CUANDO SON ORDENES DE RV******/
   P_TOOLS.CONSULTARCONSTANTE(P_CONSTANTE  => 'IVC',
                              P_VALOR      => V_VALOR_CONS,
                              P_VALOR_DATE => V_VALOR_DATE_CONS,
                              P_VALOR_CHAR => V_VALOR_CHAR_CONS);


   V_TOTAL_OPERACION_ACC :=  P_CANTIDAD*P_PRECIO_ORDEN;

   /*IF P_CODIGO_USUARIO = 'CMA' THEN
     V_ERRORES := V_ERRORES + 1;
     P_CAB.CrearError('Ordenes por este canal no autorizadas');
   END IF;
   */


   IF P_CODIGO_USUARIO = 'CMA' THEN

     V_PORCENTAJE_COMISION   := 0;
     V_COMISION_ESPECIAL     := 0;
     V_IND_COMISION_ESPE     := 'N';

     V_COMISION_ESPECIAL := P_COMERCIAL.CALCULAR_COMISION_BURSATIL(
                               P_NUM_IDEN           => P_CLI_PER_NUM_IDEN,
                               P_TID_CODIGO         => P_CLI_PER_TID_CODIGO,
                               P_NRO_CUENTA         => P_CUENTAS_CORREDORES,
                               P_TIPO_PAPEL         => 'ACC',
                               P_TIPO_NOMINAL_PESOS => NULL,
                               P_ESPECIE            => NULL,
                               P_MONTO              => NULL,
                               P_LLAMADO            => 'EXT');

      IF NVL(V_COMISION_ESPECIAL,0) != 0 THEN
        V_PORCENTAJE_COMISION   := V_COMISION_ESPECIAL/100;
        V_IND_COMISION_ESPE     := 'S';
      ELSE
        V_IND_COMISION_ESPE     := 'N';
      END IF;

      IF V_IND_COMISION_ESPE = 'N' THEN
        IF V_TOTAL_OPERACION_ACC <=  50000000 THEN
           V_PORCENTAJE_COMISION := 0.003;
        ELSE
          V_PORCENTAJE_COMISION := 0.002;
        END IF;
      END IF;

      V_COMISION_ACC := V_TOTAL_OPERACION_ACC*V_PORCENTAJE_COMISION;

      IF V_IND_COMISION_ESPE = 'N' THEN
     P_TOOLS.CONSULTARCONSTANTE(P_CONSTANTE  => 'CMH',
                  P_VALOR      => V_VALOR_COMI,
                  P_VALOR_DATE => V_VALOR_DATE_COMI,
                  P_VALOR_CHAR => V_VALOR_CHAR_COMI); 

     IF V_COMISION_ACC < V_VALOR_COMI THEN
            V_COMISION_ACC := V_VALOR_COMI;
            V_PORCENTAJE_COMISION   := TRUNC(V_COMISION_ACC/(V_TOTAL_OPERACION_ACC),5)*100;
         ELSE
            V_PORCENTAJE_COMISION  := V_PORCENTAJE_COMISION*100;
         END IF;
      ELSE
         V_PORCENTAJE_COMISION   := V_COMISION_ESPECIAL;
      END IF;

   END IF;

   V_IVA_ACC := V_COMISION_ACC*V_VALOR_CONS;

   IF P_TIPO_ORDEN = 'C' THEN
     V_NETO_OPERACION_ACC := V_TOTAL_OPERACION_ACC+V_COMISION_ACC+V_IVA_ACC;
   ELSIF P_TIPO_ORDEN = 'V' THEN
     V_NETO_OPERACION_ACC := V_TOTAL_OPERACION_ACC-V_COMISION_ACC-V_IVA_ACC;
   END IF;

   IF P_CODIGO_USUARIO IN ( 'ACC','FIX-INS') THEN
      IF P_NUMERO_ORDEN IS NULL THEN
         V_ERRORES := V_ERRORES+1;
         P_CAB.CREARERROR('Numero de Orden invalido');
      END IF;
   END IF;



   IF V_ERRORES = 0 THEN
       IF NVL(P_NUMERO_ORDEN,0) > 0 THEN -- VALIDACIONES DE ORDENES  AL ACTUALIAR VALOR --0
          IF P_TIPO_ORDEN = 'C' THEN
             V_QUERY := 'SELECT OCO_CONSECUTIVO '||
                        ' ,OCO_BOL_MNEMONICO '||
                        ' ,OCO_COC_CTO_MNEMONICO '||
                        ' ,OCO_NOMINAL_O_PESOS '||
                        ' ,OCO_ID_CMA '||
                        ' ,OCO_EOC_MNEMONICO '||
                        ' ,OCO_ENA_MNEMONICO '||
                        ' ,OCO_PRECIO_LIMITE_O_MARGEN '||
                        ' ,OCO_CANTIDAD_ACC '||
                        ' ,OCO_PRECIO_ACC '||
                        ' ,OCO_TOTAL_OPERACION_ACC '||
                        ' ,OCO_NETO_OPERACION_ACC  '||
                        ' ,OCO_CANAL_ORIGEN  '||
                        ' ,''NA'' OCO_ORIGEN '||
                        ' ,OCO_COMISION '||
                        ' ,OCO_CCC_CLI_PER_NUM_IDEN  '||
                        ' ,OCO_CCC_CLI_PER_TID_CODIGO '||
                        ' ,OCO_CCC_NUMERO_CUENTA '||
                        ' FROM ORDENES_COMPRA ';
            IF P_CODIGO_USUARIO = 'CMA' THEN
               V_QUERY :=  V_QUERY||' WHERE OCO_ID_CMA ='|| P_NUMERO_ORDEN ||
                        ' AND OCO_BOL_MNEMONICO = ''COL'' '||
                        ' AND OCO_COC_CTO_MNEMONICO = ''ACC'' '||
                        ' AND OCO_EOC_MNEMONICO IN (''COL'',''PAP'')' ||
                        ' AND NVL(OCO_ESTADO_BOLSA,'' '') NOT IN (''CPC'')';

               -- SE BUSCA EN EL RANGO
            END IF;

            IF P_CODIGO_USUARIO IN ( 'ACC','FIX-INS') THEN
               V_QUERY :=  V_QUERY||' WHERE OCO_CONSECUTIVO ='|| P_NUMERO_ORDEN ||
                        ' AND OCO_BOL_MNEMONICO = ''COL'' '||
                        ' AND OCO_COC_CTO_MNEMONICO = ''ACC'' '||
                        ' AND OCO_EOC_MNEMONICO IN (''COL'',''PAP'')' ||
                        ' AND NVL(OCO_ESTADO_BOLSA,'' '') NOT IN (''CPC'')';

               -- LA COMISION SE CALCULA CON OCO_COMISION
            END IF;
          END IF;

          IF P_TIPO_ORDEN = 'V' THEN
             V_QUERY := 'SELECT OVE_CONSECUTIVO '||
                        ' ,OVE_BOL_MNEMONICO '||
                        ' ,OVE_COC_CTO_MNEMONICO '||
                        ' ,OVE_NOMINAL_O_PESOS '||
                        ' ,OVE_ID_CMA '||
                        ' ,OVE_EOC_MNEMONICO '||
                        ' ,OVE_ENA_MNEMONICO '||
                        ' ,OVE_PRECIO_LIMITE_O_MARGEN '||
                        ' ,OVE_CANTIDAD_ACC '||
                        ' ,OVE_PRECIO_ACC '||
                        ' ,OVE_TOTAL_OPERACION_ACC '||
                        ' ,OVE_NETO_OPERACION_ACC  '||
                        ' ,OVE_CANAL_ORIGEN  '||
                        ' ,OVE_ORIGEN_FUNGIBLE '||
                        ' ,OVE_COMISION '||
                        ' ,OVE_CCC_CLI_PER_NUM_IDEN '||
                        ' ,OVE_CCC_CLI_PER_TID_CODIGO '||
                        ' ,OVE_CCC_NUMERO_CUENTA '||
                        ' FROM ORDENES_VENTA ';

             IF  P_CODIGO_USUARIO = 'CMA' THEN
                 V_QUERY :=  V_QUERY||' WHERE OVE_ID_CMA ='|| P_NUMERO_ORDEN ||
                        ' AND OVE_BOL_MNEMONICO = ''COL'' '||
                        ' AND OVE_COC_CTO_MNEMONICO = ''ACC'' '||
                        ' AND OVE_EOC_MNEMONICO IN (''COL'',''PAP'')' ||
                        ' AND NVL(OVE_ESTADO_BOLSA,'' '') NOT IN (''CPC'')';
             END IF;


             IF  P_CODIGO_USUARIO IN ('ACC','FIX-INS')  THEN
                 V_QUERY :=  V_QUERY||' WHERE OVE_CONSECUTIVO ='|| P_NUMERO_ORDEN ||
                        ' AND OVE_BOL_MNEMONICO = ''COL'' '||
                        ' AND OVE_COC_CTO_MNEMONICO = ''ACC'' '||
                        ' AND OVE_EOC_MNEMONICO IN (''COL'',''PAP'')' ||
                        ' AND NVL(OVE_ESTADO_BOLSA,'' '') NOT IN (''CPC'')';

             END IF;

          END IF;


          OPEN IO_CURSOR FOR V_QUERY;
          LOOP
             FETCH IO_CURSOR INTO V_CONSECUTIVO,
                                  V_BOL_MNEMONICO,
                                  V_COC_CTO_MNEMONICO,
                                  V_NOMINAL_O_PESOS,
                                  V_ID_CMA,
                                  V_EOC_MNEMONICO,
                                  V_ENA_MNEMONICO,
                                  V_PRE_LIMITE_O_MARGEN,
                                  V_CANTIDAD_ACC,
                                  V_PRECIO_ACC,
                                  V_TOTAL_OPERACION,
                                  V_NETO_OPERACION,
                                  V_CANAL_ORIGEN,
                                  V_TITULO_ORIGEN,
                                  V_PORCENTAJE_COMISION,
                                  V_CLI_PER_NUM_IDEN,
                                  V_CLI_PER_TID_CODIGO,
                                  V_CCC_NUMERO_CUENTA ;
             EXIT WHEN IO_CURSOR%NOTFOUND;
          END LOOP;
          CLOSE IO_CURSOR;


          IF NVL(V_CONSECUTIVO,0) = 0   THEN
             V_ERRORES := V_ERRORES+1;
             P_CAB.CrearError('Orden no existe. No es posible modificar la orden');
          END IF;

          IF NVL(V_CONSECUTIVO,0) > 0 THEN
             /* OBTENER NOTIFICACIONES DE CALCE DE LAS ORDENES*/
             V_QUERY_NOTIFICACION := 'SELECT SUM(NOO_CANTIDAD) NOO_CANTIDAD, '||
                                     ' SUM(NOO_CANTIDAD*NOO_PRECIO) NOO_TOTAL_NOMINAL '||
                                     ' FROM NOTIFICACIONES_OPERACIONES ';

             IF   P_TIPO_ORDEN = 'C' THEN
                V_QUERY_NOTIFICACION := V_QUERY_NOTIFICACION||' WHERE NOO_OCO_CONSECUTIVO ='|| V_CONSECUTIVO ||
                                    ' AND NOO_OCO_BOL_MNEMONICO ='||CHR(39)||V_BOL_MNEMONICO||CHR(39)||
                                    ' AND NOO_OCO_COC_CTO_MNEMONICO ='||CHR(39)||V_COC_CTO_MNEMONICO||CHR(39);
             END IF;

             IF   P_TIPO_ORDEN = 'V' THEN
                V_QUERY_NOTIFICACION := V_QUERY_NOTIFICACION||' WHERE NOO_OVE_CONSECUTIVO ='|| V_CONSECUTIVO ||
                                    ' AND NOO_OVE_BOL_MNEMONICO ='||CHR(39)||V_BOL_MNEMONICO||CHR(39)||
                                    ' AND NOO_OVE_COC_CTO_MNEMONICO ='||CHR(39)||V_COC_CTO_MNEMONICO||CHR(39);

             END IF;

             OPEN IO_CURSOR_NOTIFICA FOR V_QUERY_NOTIFICACION;
             LOOP
                FETCH IO_CURSOR_NOTIFICA INTO V_TOTAL_PARCIAL_NOM,V_TOTAL_PAR_VALOR_NOM;
                EXIT WHEN IO_CURSOR_NOTIFICA%NOTFOUND;
             END LOOP;
             CLOSE IO_CURSOR_NOTIFICA;


             V_TOTAL_PARCIAL_NOM   := NVL(V_TOTAL_PARCIAL_NOM,0);
             V_TOTAL_PAR_VALOR_NOM := NVL(V_TOTAL_PAR_VALOR_NOM,0);
          END IF;

          --RAISE_APPLICATION_ERROR(-20900, 'error cantidad:'||V_CONSECUTIVO||'-'||V_TOTAL_PARCIAL_NOM);
          V_CANTIDAD_ORDEN    := 0;
          V_TOTAL_PARCIAL_NOM := NVL(V_TOTAL_PARCIAL_NOM,0);

          IF P_CODIGO_USUARIO = 'CMA' THEN
            V_CANTIDAD_ORDEN := P_CANTIDAD+V_TOTAL_PARCIAL_NOM;
          END IF;

          IF P_CODIGO_USUARIO IN ( 'ACC','FIX-INS') THEN
            V_CANTIDAD_ORDEN := P_CANTIDAD;
          END IF;

          IF V_TOTAL_PARCIAL_NOM > 0 THEN
             V_TOTAL_OPERACION_ACC := V_TOTAL_PAR_VALOR_NOM+((V_CANTIDAD_ORDEN-V_TOTAL_PARCIAL_NOM)*P_PRECIO_ORDEN);
          ELSE
             V_TOTAL_OPERACION_ACC :=  V_CANTIDAD_ORDEN*P_PRECIO_ORDEN;
          END IF;

          IF V_TOTAL_PARCIAL_NOM > 0 THEN   -- LA ORDEN NO SE PUEDE DISMINUIR
             IF V_CANTIDAD_ORDEN < V_TOTAL_PARCIAL_NOM THEN
                 V_ERRORES := V_ERRORES+1;
                 P_CAB.CREARERROR('La cantidad no se puede disminuir a la cantidad ya calzada :'||V_TOTAL_PARCIAL_NOM);
             END IF;
          END IF;

          IF P_CODIGO_USUARIO = 'CMA' THEN
             IF V_TOTAL_OPERACION_ACC <=  50000000 THEN
                V_PORCENTAJE_COMISION := 0.003;
             ELSE
                V_PORCENTAJE_COMISION := 0.002;
             END IF;

             V_COMISION_ACC := V_TOTAL_OPERACION_ACC*V_PORCENTAJE_COMISION;

       P_TOOLS.CONSULTARCONSTANTE(P_CONSTANTE  => 'CMH',
                    P_VALOR      => V_VALOR_COMI,
                    P_VALOR_DATE => V_VALOR_DATE_COMI,
                    P_VALOR_CHAR => V_VALOR_CHAR_COMI); 

       IF V_COMISION_ACC < V_VALOR_COMI THEN
        V_COMISION_ACC := V_VALOR_COMI;
             END IF;
             V_PORCENTAJE_COMISION   := TRUNC(V_COMISION_ACC/(V_TOTAL_OPERACION_ACC),5)*100; -- REVISAR
          ELSIF P_CODIGO_USUARIO IN ( 'ACC','FIX-INS') THEN
             IF V_CANAL_ORIGEN IN ( 'ACC-E') THEN

                V_PORCENTAJE_COMISION   := 0;
                V_COMISION_ESPECIAL     := 0;
                V_IND_COMISION_ESPE     := 'N';

                V_COMISION_ESPECIAL := P_COMERCIAL.CALCULAR_COMISION_BURSATIL(
                                        P_NUM_IDEN           => V_CLI_PER_NUM_IDEN,
                                        P_TID_CODIGO         => V_CLI_PER_TID_CODIGO,
                                        P_NRO_CUENTA         => V_CCC_NUMERO_CUENTA,
                                        P_TIPO_PAPEL         => 'ACC',
                                        P_TIPO_NOMINAL_PESOS => NULL,
                                        P_ESPECIE            => NULL,
                                        P_MONTO              => NULL,
                                        P_LLAMADO            => 'EXT');

                IF NVL(V_COMISION_ESPECIAL,0) != 0 THEN
                   V_PORCENTAJE_COMISION   := V_COMISION_ESPECIAL/100;
                   V_IND_COMISION_ESPE     := 'S';
                ELSE
                   V_IND_COMISION_ESPE     := 'N';
                END IF;

                IF V_IND_COMISION_ESPE = 'N' THEN
                   IF V_TOTAL_OPERACION_ACC <=  50000000 THEN
                       V_PORCENTAJE_COMISION := 0.003;
                   ELSE
                       V_PORCENTAJE_COMISION := 0.002;
                   END IF;
                END IF;

                V_COMISION_ACC := V_TOTAL_OPERACION_ACC*V_PORCENTAJE_COMISION;

                IF V_IND_COMISION_ESPE = 'N' THEN
          P_TOOLS.CONSULTARCONSTANTE(P_CONSTANTE  => 'CMH',
                         P_VALOR      => V_VALOR_COMI,
                         P_VALOR_DATE => V_VALOR_DATE_COMI,
                         P_VALOR_CHAR => V_VALOR_CHAR_COMI); 

          IF V_COMISION_ACC < V_VALOR_COMI THEN
            V_COMISION_ACC := V_VALOR_COMI;       
            V_PORCENTAJE_COMISION   := TRUNC(V_COMISION_ACC/(V_TOTAL_OPERACION_ACC),5)*100;
          ELSE
            V_PORCENTAJE_COMISION  := V_PORCENTAJE_COMISION*100;
          END IF;
                ELSE
                  V_PORCENTAJE_COMISION   := V_COMISION_ESPECIAL;
                END IF;
             ELSE
                V_COMISION_ACC := V_TOTAL_OPERACION_ACC*V_PORCENTAJE_COMISION/100;
             END IF;
          ELSIF P_CODIGO_USUARIO = 'UDF-A' THEN

             SELECT P_OPERACIONES.FN_COMISION_UDF_CAMBIO_ORDEN(P_PRECIO_ORDEN,V_CANTIDAD_ORDEN)
             INTO V_PORCENTAJE_COMISION   FROM DUAL;


             V_PORCENTAJE_COMISION := V_PORCENTAJE_COMISION/100;
             V_COMISION_ACC := V_TOTAL_OPERACION_ACC*V_PORCENTAJE_COMISION;
          END IF;

          V_IVA_ACC := V_COMISION_ACC*V_VALOR_CONS;

          IF P_TIPO_ORDEN = 'C' THEN
             V_NETO_OPERACION_ACC := V_TOTAL_OPERACION_ACC+V_COMISION_ACC+V_IVA_ACC;
          ELSIF P_TIPO_ORDEN = 'V' THEN
             V_NETO_OPERACION_ACC := V_TOTAL_OPERACION_ACC-V_COMISION_ACC-V_IVA_ACC;
          END IF;

    -- VAGTUD702-2 AJUSTE COEASY RV - SMORALES
--insert_clob('incio valida fechas.');
          IF NVL(V_CANTIDAD_ORDEN,0) > 0 THEN  -- Modificacion Orden

             IF P_FECHA_VIGENCIA IS NOT NULL THEN
                V_FECHA_PERMANENCIA := TO_DATE(P_FECHA_VIGENCIA,'DD-MM-YYYY');

                IF TRUNC(V_FECHA_PERMANENCIA) > TRUNC(SYSDATE) THEN
                   V_VIO_MNEMMONICO := 'HFE';
                ELSE
                   V_FECHA_PERMANENCIA :=  NULL;
                   V_VIO_MNEMMONICO := 'DIA';
                END IF;
             ELSE
                V_FECHA_PERMANENCIA :=  NULL;
                V_VIO_MNEMMONICO := 'DIA';
             END IF;

             IF  P_TIPO_ORDEN = 'C' AND  V_ERRORES = 0 THEN
                IF V_CANAL_ORIGEN IN ( 'S2','ACC-E') THEN -- Validacion solo para ETRADE - HOMEBROKER
                   --VAGTUS065416.AjustesConsultasSaldosEnLineaHB
                   SAVEPOINT OCO_UPDATE_PRE;

                   UPDATE ORDENES_COMPRA
                   SET OCO_NOMINAL_O_PESOS = V_CANTIDAD_ORDEN
                      ,OCO_CANTIDAD_ACC   = V_CANTIDAD_ORDEN
                      ,OCO_COMISION_ACC  = V_COMISION_ACC
                      ,OCO_PRECIO_ACC = P_PRECIO_ORDEN
                      ,OCO_PRECIO_LIMITE_O_MARGEN = DECODE(P_CLASE_ORDEN,'LIM',P_PRECIO_ORDEN,NULL)
                      ,OCO_TOTAL_OPERACION_ACC = V_TOTAL_OPERACION_ACC
                      ,OCO_NETO_OPERACION_ACC = V_NETO_OPERACION_ACC
                      ,OCO_COMISION = V_PORCENTAJE_COMISION
                      ,OCO_FECHA_PERMANENCIA = DECODE(V_CANAL_ORIGEN,'S2',OCO_FECHA_PERMANENCIA,V_FECHA_PERMANENCIA)
                      ,OCO_VIO_MNEMONICO = DECODE(V_CANAL_ORIGEN,'S2',OCO_VIO_MNEMONICO,V_VIO_MNEMMONICO)
                      ,OCO_IVA_ACC  =  V_COMISION_ACC*NVL(V_VALOR_CONS,0)
                      /*osjtorres 07/12/2018 Proyecto PMO vagtud793  Administrador @ Acciones   */
                      ,OCO_PER_NUM_IDEN_ES_MODIFICADA = P_NUM_IDEN_COMERCIAL
                      ,OCO_PER_TID_CODIGO_ES_MODIFICA = P_TID_CODIGO_COMERCIAL
                   WHERE OCO_CONSECUTIVO = V_CONSECUTIVO
                   AND OCO_BOL_MNEMONICO = V_BOL_MNEMONICO
                   AND OCO_COC_CTO_MNEMONICO = V_COC_CTO_MNEMONICO;


                   V_SALDO := 0;
                   P_WEB_CLIENTE.OBTENERSALDOSPESOS(P_TID_CODIGO => V_CLI_PER_TID_CODIGO,--P_CLI_PER_TID_CODIGO,
                                                    P_NUM_IDEN   => V_CLI_PER_NUM_IDEN,--P_CLI_PER_NUM_IDEN,
                                                    P_CUENTA     => V_CCC_NUMERO_CUENTA,--P_CUENTAS_CORREDORES,
                                                    P_SALDO      => V_SALDO);
                   V_SALDO := NVL(V_SALDO,0);

                   --VAGTUS900009.LogValidarSaldoEtrade
                   BEGIN
                     SELECT XMLELEMENT("P_VALIDAR_SALDO_ETRADE",
                                       XMLAGG(XMLELEMENT("Cliente", XMLFOREST(P_CLI_PER_NUM_IDEN AS "CLI_PER_NUM_IDEN", P_CLI_PER_TID_CODIGO AS "CLI_PER_TID_CODIGO", P_CUENTAS_CORREDORES AS "CUENTAS_CORREDORES"))),
                                       XMLAGG(XMLELEMENT("ParamIn", XMLFOREST(V_CLI_PER_TID_CODIGO AS "P_TID_CODIGO", V_CLI_PER_NUM_IDEN AS "P_NUM_IDEN", V_CCC_NUMERO_CUENTA AS "P_CUENTA"))),
                                       XMLAGG(XMLELEMENT("ParamOut", XMLFOREST(V_SALDO AS "V_SALDO"))),
                                       XMLAGG(XMLELEMENT("Message", XMLFOREST('2.OCO_UPDATE_PRE: Sale de P_WEB_CLIENTE.OBTENERSALDOSPESOS' AS "MESSAGE")))
                                      ) xmlreg
                     INTO   v_xml
                     FROM   dual;

                     prod.p_log_traza.InsertarLog(P_Procedure => 'ValidarSaldoEtrade',
                                                 P_Xml       => v_xml,
                                                 P_Error     => v_error,
                                                 P_Msg       => v_mensaje);
                   EXCEPTION
                     WHEN OTHERS THEN
                       NULL;
                   END;

                   IF NVL(V_SALDO,0) < 0 THEN
                      ROLLBACK TO SAVEPOINT OCO_UPDATE_PRE;
                      V_ERRORES := V_ERRORES+1;
                      P_CAB.CREARERROR('Cuenta en corredores sin saldo disponible para operacion Etrade de compra');
                   END IF;


                   IF (NVL(P_PRECIO_ORDEN,0)*NVL(V_CANTIDAD_ORDEN,0)) = 0 THEN
                       ROLLBACK TO SAVEPOINT OCO_UPDATE_PRE;
                       V_ERRORES := V_ERRORES+1;
                       P_CAB.CREARERROR('Para operaciones Etrade se debe especificar Total y Neto Operacion');
                   END IF;
                END IF;

                IF V_ERRORES = 0 THEN
                     UPDATE ORDENES_COMPRA
                     SET OCO_NOMINAL_O_PESOS = V_CANTIDAD_ORDEN
                        ,OCO_CANTIDAD_ACC   = V_CANTIDAD_ORDEN
                        ,OCO_COMISION_ACC  = V_COMISION_ACC
                        ,OCO_PRECIO_ACC = P_PRECIO_ORDEN
                        ,OCO_PRECIO_LIMITE_O_MARGEN = DECODE(P_CLASE_ORDEN,'LIM',P_PRECIO_ORDEN,NULL)
                        ,OCO_TOTAL_OPERACION_ACC = V_TOTAL_OPERACION_ACC
                        ,OCO_NETO_OPERACION_ACC = V_NETO_OPERACION_ACC
                        ,OCO_COMISION = V_PORCENTAJE_COMISION
                        ,OCO_FECHA_PERMANENCIA = DECODE(V_CANAL_ORIGEN,'S2',OCO_FECHA_PERMANENCIA,
                                                                       V_FECHA_PERMANENCIA)
                        ,OCO_VIO_MNEMONICO =  DECODE(V_CANAL_ORIGEN,'S2',OCO_VIO_MNEMONICO,
                                                                     V_VIO_MNEMMONICO)
                        ,OCO_IVA_ACC  =  V_COMISION_ACC*NVL(V_VALOR_CONS,0)
            /*osjtorres 07/12/2018 Proyecto PMO vagtud793  Administrador @ Acciones   */
                       ,OCO_PER_NUM_IDEN_ES_MODIFICADA = P_NUM_IDEN_COMERCIAL
                       ,OCO_PER_TID_CODIGO_ES_MODIFICA = P_TID_CODIGO_COMERCIAL
                     WHERE OCO_CONSECUTIVO = V_CONSECUTIVO
                     AND OCO_BOL_MNEMONICO = V_BOL_MNEMONICO
                     AND OCO_COC_CTO_MNEMONICO = V_COC_CTO_MNEMONICO;

          -- WILLIAM CAMPOS 03/04/2020 SE COMPARAN EL TIEMPO DE EJECUCION DE LA ORDEN , SI ES MAYOR A 15 SEGUNDOS , VA A HACER ROLLBACK.
                   P_FIN_ORDEN:= SYSDATE;
            select (( P_INI_ORDEN - P_FIN_ORDEN ) * 86400 ) * -1 INTO P_DIF_MIN_ORDEN from DUAL ;
                     IF P_DIF_MIN_ORDEN >= 15 THEN
                      ROLLBACK;
             P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('ROLLBACK MODIFICAR_ORDEN T:' || P_DIF_MIN_ORDEN ,'OTR' );
                      RAISE_APPLICATION_ERROR(-20002,'VUELVE A INTENTAR EN UN MINUTO.');
                     ELSE
                      COMMIT;
                     END IF;
                      -- FIN WILLIAM CAMPOS
                END IF;

             ELSIF P_TIPO_ORDEN = 'V' AND  V_ERRORES = 0 THEN

                IF V_CANAL_ORIGEN IN ('S2','ACC','UDF-A','ACC-E')  THEN -- Validacion solo para ETRADE - HOMEBROKER  y @acciones
                   --VAGTUS065416.AjustesConsultasSaldosEnLineaHB
                   SAVEPOINT OVE_UPDATE_PRE;
--insert_clob('incio updte venta.');
--begin  -- SOLO PARA PREUBAS NO PASAR A PRODUCION
                   UPDATE ORDENES_VENTA
                   SET OVE_NOMINAL_O_PESOS = V_CANTIDAD_ORDEN
                      ,OVE_CANTIDAD_ACC   = V_CANTIDAD_ORDEN
                      ,OVE_COMISION_ACC  = V_COMISION_ACC
                      ,OVE_PRECIO_ACC = P_PRECIO_ORDEN
                      ,OVE_PRECIO_LIMITE_O_MARGEN = DECODE(P_CLASE_ORDEN,'LIM',P_PRECIO_ORDEN,NULL)
                      ,OVE_TOTAL_OPERACION_ACC = V_TOTAL_OPERACION_ACC
                      ,OVE_NETO_OPERACION_ACC = V_NETO_OPERACION_ACC
                      ,OVE_COMISION = V_PORCENTAJE_COMISION
                      ,OVE_FECHA_PERMANENCIA = DECODE(V_CANAL_ORIGEN,'S2',OVE_FECHA_PERMANENCIA,
                                                                       V_FECHA_PERMANENCIA)
                      ,OVE_VIO_MNEMONICO =  DECODE(V_CANAL_ORIGEN,'S2',OVE_VIO_MNEMONICO,
                                                                     V_VIO_MNEMMONICO)
                      ,OVE_IVA_ACC  =  V_COMISION_ACC*NVL(V_VALOR_CONS,0)
                       /*osjtorres 07/12/2018 Proyecto PMO vagtud793  Administrador @ Acciones   */
                      ,OVE_PER_NUM_IDEN_ES_MODIFICADA = P_NUM_IDEN_COMERCIAL
                      ,OVE_PER_TID_CODIGO_ES_MODIFICA = P_TID_CODIGO_COMERCIAL
                   WHERE OVE_CONSECUTIVO = V_CONSECUTIVO
                   AND OVE_BOL_MNEMONICO = V_BOL_MNEMONICO
                   AND OVE_COC_CTO_MNEMONICO = V_COC_CTO_MNEMONICO;

  --exception WHEN others THEN -- SOLO PARA PREUBAS NO PASAR A PRODUCION
     --insert_clob('updte venta.'||sqlerrm); -- SOLO PARA PREUBAS NO PASAR A PRODUCION
--end;-- SOLO PARA PREUBAS NO PASAR A PRODUCION
                   IO_CURSOR := NULL;

                   P_WEB_CLIENTE.OBTENERCUENTASDECEVAL(P_TID_CODIGO     => V_CLI_PER_TID_CODIGO,
                                                       P_NUM_IDEN       => V_CLI_PER_NUM_IDEN,
                                                       P_ENA_MNEMONICO  => P_ESPECIE,
                                                       P_FECHA          => SYSDATE,
                                                       P_CUENTA_DECEVAL => V_TITULO_CTA_DVAL,
                                                       IO_CURSOR        => IO_CURSOR);

                     OPEN PORTAFOLIO(P_ENA_MNEMONICO => V_ENA_MNEMONICO,
                          P_CUENTA_DECEVAL=> P_CUENTA_DECEVAL);
                     FETCH PORTAFOLIO INTO C_PORTAFOLIO;
                     CLOSE PORTAFOLIO;

                     C_PORTAFOLIO.SALDO_DISPONIBLE := NVL(C_PORTAFOLIO.SALDO_DISPONIBLE ,0);

                     --VAGTUS900009.LogValidarSaldoEtrade
                     BEGIN
                       SELECT XMLELEMENT("P_VALIDAR_SALDO_ETRADE",
                                         XMLAGG(XMLELEMENT("Cliente", XMLFOREST(P_CLI_PER_NUM_IDEN AS "CLI_PER_NUM_IDEN", P_CLI_PER_TID_CODIGO AS "CLI_PER_TID_CODIGO", P_CUENTAS_CORREDORES AS "CUENTAS_CORREDORES"))),
                                         XMLAGG(XMLELEMENT("ParamIn", XMLFOREST(V_CLI_PER_TID_CODIGO AS "P_TID_CODIGO", V_CLI_PER_NUM_IDEN AS "P_NUM_IDEN", P_ESPECIE AS "P_ENA_MNEMONICO", SYSDATE AS "P_FECHA", V_TITULO_CTA_DVAL AS "P_CUENTA_DECEVAL"))),
                                         XMLAGG(XMLELEMENT("ParamOut", XMLFOREST(C_PORTAFOLIO.SALDO_DISPONIBLE AS "SALDO_DISPONIBLE"))),
                                         XMLAGG(XMLELEMENT("Message", XMLFOREST('2.OVE_UPDATE_PRE: Sale de P_WEB_CLIENTE.OBTENERCUENTASDECEVAL' AS "MESSAGE")))
                                        ) xmlreg
                       INTO   v_xml
                       FROM   dual;

                       prod.p_log_traza.InsertarLog(P_Procedure => 'ValidarSaldoEtrade',
                                                   P_Xml       => v_xml,
                                                   P_Error     => v_error,
                                                   P_Msg       => v_mensaje);
                     EXCEPTION
                       WHEN OTHERS THEN
                         NULL;
                     END;

                     IF NVL(V_TITULO_ORIGEN,' ')  = 'DA' THEN
                        IF C_PORTAFOLIO.SALDO_DISPONIBLE < 0 THEN
                           ROLLBACK TO SAVEPOINT OVE_UPDATE_PRE;
                           V_ERRORES := V_ERRORES+1;
                           P_CAB.CREARERROR('El numero de acciones de '||P_ESPECIE||' no puede ser superior a:'||TRIM(TO_CHAR(C_PORTAFOLIO.SALDO_DISPONIBLE,'999999999999999999.99')));
                        END IF;
                     ELSIF NVL(V_TITULO_ORIGEN,' ') = 'SP' THEN
                        IF C_PORTAFOLIO.SALDO_DISPONIBLE > 0 THEN
                           ROLLBACK TO SAVEPOINT OVE_UPDATE_PRE;
                           V_ERRORES := V_ERRORES+1;
                           P_CAB.CREARERROR('El monto de '||P_ESPECIE||' debe superar el neto: '||TRIM(TO_CHAR(C_PORTAFOLIO.SALDO_DISPONIBLE,'999999999999999999.99'))||' cuando vende con Excede Saldo');
                        END IF;
                     END IF;
                END IF;

                IF V_ERRORES = 0 THEN
                   UPDATE ORDENES_VENTA
                   SET OVE_NOMINAL_O_PESOS = V_CANTIDAD_ORDEN
                      ,OVE_CANTIDAD_ACC   = V_CANTIDAD_ORDEN
                      ,OVE_COMISION_ACC  = V_COMISION_ACC
                      ,OVE_PRECIO_ACC = P_PRECIO_ORDEN
                      ,OVE_PRECIO_LIMITE_O_MARGEN = DECODE(P_CLASE_ORDEN,'LIM',P_PRECIO_ORDEN,NULL)
                      ,OVE_TOTAL_OPERACION_ACC = V_TOTAL_OPERACION_ACC
                      ,OVE_NETO_OPERACION_ACC = V_NETO_OPERACION_ACC
                      ,OVE_COMISION = V_PORCENTAJE_COMISION
                      ,OVE_FECHA_PERMANENCIA = DECODE(V_CANAL_ORIGEN,'S2',OVE_FECHA_PERMANENCIA,
                                                                     V_FECHA_PERMANENCIA)
                      ,OVE_VIO_MNEMONICO =  DECODE(V_CANAL_ORIGEN,'S2',OVE_VIO_MNEMONICO,
                                                                  V_VIO_MNEMMONICO)
                      ,OVE_IVA_ACC  =  V_COMISION_ACC*NVL(V_VALOR_CONS,0)
            /*osjtorres 07/12/2018 Proyecto PMO vagtud793  Administrador @ Acciones   */
                      ,OVE_PER_NUM_IDEN_ES_MODIFICADA = P_NUM_IDEN_COMERCIAL
                      ,OVE_PER_TID_CODIGO_ES_MODIFICA = P_TID_CODIGO_COMERCIAL
                   WHERE OVE_CONSECUTIVO = V_CONSECUTIVO
                   AND OVE_BOL_MNEMONICO = V_BOL_MNEMONICO
                   AND OVE_COC_CTO_MNEMONICO = V_COC_CTO_MNEMONICO;
                   -- WILLIAM CAMPOS 03/04/2020 SE COMPARAN EL TIEMPO DE EJECUCION DE LA ORDEN , SI ES MAYOR A 15 SEGUNDOS , VA A HACER ROLLBACK.
                   P_FIN_ORDEN:= SYSDATE;
            select (( P_INI_ORDEN - P_FIN_ORDEN ) * 86400 ) * -1 INTO P_DIF_MIN_ORDEN from DUAL ;
                     IF P_DIF_MIN_ORDEN >= 15 AND (V_CANAL_ORIGEN = 'ACC-E') THEN
                      ROLLBACK;
             P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('ROLLBACK MODIFICAR_ORDEN_ T:' || P_DIF_MIN_ORDEN ,'OTR' );
                      RAISE_APPLICATION_ERROR(-20002,'VUELVE A INTENTAR EN UN MINUTO.');
                     ELSE
                      COMMIT;
                     END IF;
                      -- FIN WILLIAM CAMPOS
                END IF;
             END IF;
          ELSE
             V_ERRORES := V_ERRORES+1;
             P_CAB.CREARERROR('Cantidad invalida para modifcar la orden');
          END IF;

          IF V_ERRORES = 0 THEN
             P_ID_ORDEN := V_CONSECUTIVO;
             --VAGTUS900009.LogValidarSaldoEtrade
             BEGIN
               SELECT XMLELEMENT("P_VALIDAR_SALDO_ETRADE",
                                 XMLAGG(XMLELEMENT("Cliente", XMLFOREST(P_CLI_PER_NUM_IDEN AS "CLI_PER_NUM_IDEN", P_CLI_PER_TID_CODIGO AS "CLI_PER_TID_CODIGO", P_CUENTAS_CORREDORES AS "CUENTAS_CORREDORES"))),
                                 XMLAGG(XMLELEMENT("ParamIn", XMLFOREST(NULL AS "Param"))),
                                 XMLAGG(XMLELEMENT("ParamOut", XMLFOREST(V_ERRORES AS "V_ERRORES", V_CONSECUTIVO AS "P_ID_ORDEN"))),
                                 XMLAGG(XMLELEMENT("Message", XMLFOREST('3.Finaliza validacion de saldos etrade con resultado OK' AS "MESSAGE")))
                                ) xmlreg
               INTO   v_xml
               FROM   dual;

               prod.p_log_traza.InsertarLog(P_Procedure => 'ValidarSaldoEtrade',
                                           P_Xml       => v_xml,
                                           P_Error     => v_error,
                                           P_Msg       => v_mensaje);
             EXCEPTION
               WHEN OTHERS THEN
                 NULL;
             END;
          ELSE
             P_CLOB := P_CAB.OBTENERCLOB_ERROR('ColocarOrden') ;
             V_ERRORES := V_ERRORES+1;
             --VAGTUS900009.LogValidarSaldoEtrade
             BEGIN
               SELECT XMLELEMENT("P_VALIDAR_SALDO_ETRADE",
                                 XMLAGG(XMLELEMENT("Cliente", XMLFOREST(P_CLI_PER_NUM_IDEN AS "CLI_PER_NUM_IDEN", P_CLI_PER_TID_CODIGO AS "CLI_PER_TID_CODIGO", P_CUENTAS_CORREDORES AS "CUENTAS_CORREDORES"))),
                                 XMLAGG(XMLELEMENT("ParamIn", XMLFOREST(NULL AS "Param"))),
                                 XMLAGG(XMLELEMENT("ParamOut", XMLFOREST(V_ERRORES AS "V_ERRORES", P_CLOB AS "P_CLOB"))),
                                 XMLAGG(XMLELEMENT("Message", XMLFOREST('3.Finaliza validacion de saldos etrade con resultado ERROR' AS "MESSAGE")))
                                ) xmlreg
               INTO   v_xml
               FROM   dual;

               prod.p_log_traza.InsertarLog(P_Procedure => 'ValidarSaldoEtrade',
                                           P_Xml       => v_xml,
                                           P_Error     => v_error,
                                           P_Msg       => v_mensaje);
             EXCEPTION
               WHEN OTHERS THEN
                 NULL;
             END;
          END IF;

       ELSE

          P_WEB_CLIENTE.OBTENERCUENTASCORREDORES(P_TID_CODIGO => V_CLI_PER_TID_CODIGO,--P_CLI_PER_TID_CODIGO,
                                                 P_NUM_IDEN   => V_CLI_PER_NUM_IDEN,--P_CLI_PER_NUM_IDEN,
                                                 P_ACTIVA     => 'S',
                                                 IO_CURSOR    => IO_CURSOR);

          LOOP
             FETCH IO_CURSOR INTO V_CUENTAS_CORREDORES.CCC_CLI_PER_NUM_IDEN,
                                  V_CUENTAS_CORREDORES.CCC_CLI_PER_TID_CODIGO,
                                  V_CUENTAS_CORREDORES.CCC_NUMERO_CUENTA,
                                  V_CUENTAS_CORREDORES.CCC_NOMBRE_CUENTA,
                                  V_CUENTAS_CORREDORES.CCC_FECHA_APERTURA,
                                  V_CUENTAS_CORREDORES.CCC_SALDO_CAPITAL,
                                  V_CUENTAS_CORREDORES.CCC_SALDO_A_PLAZO,
                                  V_CUENTAS_CORREDORES.CCC_SALDO_A_CONTADO,
                                  V_CUENTAS_CORREDORES.CCC_SALDO_ADMON_VALORES,
                                  V_CUENTAS_CORREDORES.CCC_CUENTA_ACTIVA,
                                  V_CUENTAS_CORREDORES.CCC_CUENTA_CRCC,
                                  V_CUENTAS_CORREDORES.CCC_PER_NUM_IDEN,
                                  V_CUENTAS_CORREDORES.CCC_PER_TID_CODIGO,
                                  V_PER_CODIGO_SAE_ACC,
                                  V_CCC_SALDO_CAPITAL,
                                  V_CCP_PRO_MNEMONICO,
                                  V_CUENTAS_CORREDORES.CCC_ETRADE,
                                  V_CUENTAS_CORREDORES.CCC_CUENTA_APT ,
                                  V_CUENTAS_CORREDORES.CCC_LINEAS_PROFUNDIDAD,
                                  V_CUENTAS_CORREDORES.CCC_PANTALLA_LIVIANA;



             EXIT WHEN IO_CURSOR%NOTFOUND;
             IF V_CUENTAS_CORREDORES.CCC_NUMERO_CUENTA = P_CUENTAS_CORREDORES THEN
                V_CUENTA_CORREDORES := V_CUENTAS_CORREDORES.CCC_NUMERO_CUENTA;
                EXIT;
             END IF;
          END LOOP;
          CLOSE IO_CURSOR;


          /* Obtener informacion del comercial de la cuenta*/
          P_WEB_COMERCIAL.OBTENERCOMERCIAL(P_USUARIO          => NULL,
                                           P_TID_CODIGO       => V_CUENTAS_CORREDORES.CCC_PER_TID_CODIGO,
                                           P_NUM_IDEN         => V_CUENTAS_CORREDORES.CCC_PER_NUM_IDEN,
                                           P_INICIALES        => NULL,
                                           P_NOMBRE           => NULL,
                                           P_PRIMER_APELLIDO  => NULL,
                                           P_SEGUNDO_APELLIDO => NULL,
                                           IO_CURSOR          => IO_CURSOR_COMER );

          LOOP
             FETCH IO_CURSOR_COMER INTO  V_PERSONAS.PER_NUM_IDEN,
                                         V_PERSONAS.PER_TID_CODIGO,
                                         V_PERSONAS.PER_NOMBRE_USUARIO,
                                         V_PERSONAS.PER_INICIALES_USUARIO,
                                         V_PERSONAS.PER_SUC_CODIGO,
                                         V_PERSONAS.PER_MAIL_CORREDOR,
                                         V_PERSONAS.PER_TIPO_COMERCIAL,
                                         V_PERSONAS.PER_PER_NUM_IDEN,
                                         V_PERSONAS.PER_PER_TID_CODIGO,
                                         V_PERSONAS.PER_NOMBRE,
                                         V_PERSONAS.PER_PRIMER_APELLIDO,
                                         V_PERSONAS.PER_SEGUNDO_APELLIDO,
                                         V_PER_ESTADO,
                                         V_SUCURSALES.SUC_CODIGO,
                                         V_SUCURSALES.SUC_NOMBRE,
                                         V_PERSONAS.PER_CODIGO_SAE_ACC,
                                         V_PER_COMPLEMENTA,
                                         V_PER_BACKUP,
                                         V_PCP_CPR_MNEMONICO,
                                         V_FONDO_VALORES,
                                         V_PERSONAS.PER_TIP_COMERCIAL_UDF,
                                         V_PERSONAS.PER_TELEFONO_DIRECTO;
             EXIT WHEN IO_CURSOR_COMER%NOTFOUND;
          END LOOP;
          CLOSE IO_CURSOR_COMER;

          /* DETERMINAR EL CLIENTE DEL ORDENANTE PARA JURIDICOS*/
          SELECT P_CLIENTES.F_TIPO_PERSONA(V_CLI_PER_NUM_IDEN,V_CLI_PER_TID_CODIGO) INTO V_PER_TIPO FROM DUAL;  --SALDOS NEGATIVOS

          IF NVL(V_PER_TIPO,' ') = 'PJU' THEN
             V_PER_NUM_IDEN_ORD    := V_CLI_PER_NUM_IDEN;
             V_PER_TID_CODIGO_ORD  := V_CLI_PER_TID_CODIGO;
          ELSE
             V_PER_NUM_IDEN_ORD    := P_PER_NUM_IDEN;
             V_PER_TID_CODIGO_ORD  := P_PER_TID_CODIGO;
          END IF;



          IF P_CLASE_ORDEN = 'MER' THEN
             V_PRECIO_LIMITIE := NULL;
          ELSIF P_CLASE_ORDEN = 'LIM' THEN
             V_PRECIO_LIMITIE := P_PRECIO_ORDEN;
          END IF;



          IF P_TIPO_ORDEN = 'C' THEN
             V_CUENTA_DECEVAL  := P_CUENTA_DECEVAL;
             V_TITULO_ORIGEN   := NULL;
             V_TITULO_CTA_DVAL := NULL;
          END IF;

          IF P_TIPO_ORDEN = 'V' THEN
             V_CUENTA_DECEVAL  := NULL;
             V_TITULO_ORIGEN   := 'DA';
             V_TITULO_CTA_DVAL := P_CUENTA_DECEVAL;
          END IF;

          SELECT TO_CHAR(SYSDATE,'HH24:MI') INTO V_INS_REC_HORA FROM DUAL;


          DBMS_OUTPUT.PUT_LINE(' CLIENTE :'||V_CUENTAS_CORREDORES.CCC_CLI_PER_NUM_IDEN||'-'||
                                             V_CUENTAS_CORREDORES.CCC_CLI_PER_TID_CODIGO||'-'||
                                           V_CUENTA_CORREDORES);
          DBMS_OUTPUT.PUT_LINE(' COMERCIAL:'||V_PERSONAS.PER_INICIALES_USUARIO||'-'||V_PERSONAS.PER_NOMBRE_USUARIO);

          DBMS_OUTPUT.PUT_LINE(' CLIENTE DEL ORDENANTE:'||V_PER_RELACIONADA.RLC_CLI_PER_NUM_IDEN||'-'||V_PER_RELACIONADA.RLC_CLI_PER_TID_CODIGO);



          P_ORDENES_COMERCIAL.P_COLOCAR_ORDEN( P_CLI_TID_CODIGO                       => V_CLI_PER_TID_CODIGO,--P_CLI_PER_TID_CODIGO,
                                               P_CLI_NUM_IDEN                         => V_CLI_PER_NUM_IDEN,--P_CLI_PER_NUM_IDEN,
                                               P_USUARIO                              => V_PERSONAS.PER_NOMBRE_USUARIO,
                                               P_CUENTA_CORREDORES                    => V_CUENTA_CORREDORES,
                                               P_COLOCA_USUARIO                       => V_PERSONAS.PER_NOMBRE_USUARIO,
                                               P_COLOCA_TID_CODIGO                    => V_PERSONAS.PER_TID_CODIGO,
                                               P_COLOCA_NUM_IDEN                      => V_PERSONAS.PER_NUM_IDEN,
                                               P_COLOCA_TERMINAL                      => FN_TERMINAL,
                                               P_DUENO_TID_CODIGO                     => V_PERSONAS.PER_TID_CODIGO,
                                               P_DUENO_NUM_IDEN                       => V_PERSONAS.PER_NUM_IDEN,
                                               P_ORDENANTE_TID_CODIGO                 => V_PER_TID_CODIGO_ORD,
                                               P_ORDENANTE_NUM_IDEN                   => V_PER_NUM_IDEN_ORD,
                                               P_TIPO_ORDEN                           => P_TIPO_ORDEN,
                                               P_ESPECIE                              => P_ESPECIE,
                                               P_CANTIDAD                             => P_CANTIDAD,
                                               P_FECHA_HORA                           => P_FECHA_HORA,
                                               P_PORCENTAJE_COMISION                  => V_PORCENTAJE_COMISION,
                                               P_VIG_TIPO_VIGENCIA                    => 'DIA',
                                               P_VIG_FECHA_PERMANENCI                 => NULL,
                                               P_VIG_HORA_PERMANENCIA                 => NULL,
                                               P_COND_PRECIO                          => P_CLASE_ORDEN,
                                               P_COND_PRECIO_LIMITIE                  => V_PRECIO_LIMITIE,
                                               P_COND_CRITERIOS_ADICI                 => NULL,
                                               P_COND_CANTIDAD_MINIMA                 => NULL,
                                               P_VIS_VISIBLE                          => NULL,
                                               P_VIS_PORCENTAJE                       => NULL,
                                               P_STOP_STOP                            => NULL,
                                               P_STOP_PRECIO_STOP                     => NULL,
                                               P_CONSOLIDAR                           => 0,
                                               P_CUENTA_DECEVAL                       => V_CUENTA_DECEVAL,
                                               P_TITULO_ORIGEN                        => V_TITULO_ORIGEN,
                                               P_TITULO_CTA_DVAL                      => V_TITULO_CTA_DVAL,
                                               P_TITULO_COD_FUNGIBLE                  => NULL,
                                               P_TITULO_COD_ISIN                      => 0,
                                               P_INS_REC_MEDIO                        => 'INT',
                                               P_INS_REC_HORA                         => V_INS_REC_HORA,
                                               P_INS_REC_DETALLE                      => 'Internet S2 Saldo',
                                               P_INS_ENV_FAX                          => 0,
                                               P_INS_ENV_NUM_FAX                      => NULL,
                                               P_INS_ENV_DIRECCION                    => 0,
                                               P_INS_ENV_NUM_DIRECCION                => NULL,
                                               P_INS_ENV_COD_CIUDAD                   => NULL,
                                               P_INS_ENV_CONTACTO                     => NULL,
                                               P_CLI_PROFESIONAL                      => 'N',
                                               P_OPX                                  => 'N',
                                               P_CANTIDAD_INTENCION                   => P_CANTIDAD,
                                               P_PRECIO_INTENCION                     => P_PRECIO_ORDEN,
                                               P_COMISION_INTENCION                   => 0,
                                               P_IVA_ITENCION                         => 0,
                                               P_TOTAL_OPERACION_INT                  => V_TOTAL_OPERACION_ACC,
                                               P_NETO_OPERACION_INT                   => V_NETO_OPERACION_ACC,
                                               P_FECHA_RECEPCION                      => TO_CHAR(SYSDATE,'DD/MM/YYYY'),
                                               P_ABONO_CUENTA                         => 'S',
                                               P_VALOR_ABONO_CUENTA                   => NULL,
                                               P_PAGAR_A_PAGO                         => NULL,
                                               P_TIPO_IDEN_PAGO                       => NULL,
                                               P_NUM_IDEN_PAGO                        => NULL,
                                               P_TIPO_CUENTA_PAGO                     => NULL,
                                               P_CODIGO_BANCO_PAGO                    => NULL,
                                               P_NUMERO_CUENTA_PAGO                   => NULL,
                                               P_NOMBRE_CUENTA_PAGO                   => NULL,
                                               P_VALOR_PAGO                           => NULL,
                                               P_CODIGO_INFORMADOR                    => NULL,
                                               P_TID_CODIGO_INFORMADOR                => NULL,
                                               P_NUM_IDEN_INFORMADOR                  => NULL,
                                               P_NOMBRE_INFORMADOR                    => NULL,
                                               P_CODIGO_OFICINA_INFOR                 => NULL,
                                               P_FECHA_PRE_ORDEN_INFOR                => NULL,
                                               P_HORA_PRE_ORDEN_INFOR                 => NULL,
                                               P_ID_ORDEN                             => P_ID_ORDEN,
                                               P_CLOB                                 => P_CLOB);
       END IF;   -- FIN VALIDAR PARA MODIFICAR --0
   ELSE
      P_CLOB := P_CAB.OBTENERCLOB_ERROR('ColocarOrden') ;
      V_ERRORES := V_ERRORES+1;
   END IF;
END IF;
END P_VALIDAR_SALDO_ETRADE;


PROCEDURE P_ACTUALIZA_INTERFAZ_CMA (P_EJECUTA VARCHAR2,P_ERRORES OUT NUMBER) IS
   V_QUERY_INTERFAZ      VARCHAR2(4000);
   V_QUERY_CCC           VARCHAR2(4000);
   V_QUERY_C             VARCHAR2(4000);
   V_QUERY_V             VARCHAR2(4000);
   V_QUERY_CUD           VARCHAR2(4000);
   V_QUERY_ORDENANTE     VARCHAR2(4000);
   V_QUERY_ENA           VARCHAR2(4000);
   V_IND_COMISION_ESPE   VARCHAR2(2);
   V_FECHA_PERMANENCIA   DATE;
   V_ERRORES             NUMBER;
   V_PORCENTAJE_COMISION NUMBER;
   V_COMISION_ESPECIAL   NUMBER;
   V_INTERFAZ_CMA        INTERFAZ_ORDENES_CMA%ROWTYPE;
   V_CUENTA_CCC          CUENTAS_CLIENTE_CORREDORES%ROWTYPE;
   V_ORDENES_COMPRA      ORDENES_COMPRA%ROWTYPE;
   V_ORDENES_VENTA       ORDENES_VENTA%ROWTYPE;
   V_PERSONAS            PERSONAS%ROWTYPE;
   V_CUENTAS_DECEVAL     CUENTAS_DECEVAL%ROWTYPE;
   V_ORDENANTES_INST     PERSONAS_RELACIONADAS%ROWTYPE;
   V_ESPECIES            ESPECIES_NACIONALES%ROWTYPE;
   V_CUENTA_DECEVAL      ORDENES_COMPRA.OCO_CUD_CUENTA_DECEVAL%TYPE;
   V_CUENTA_DECEVAL_COM  ORDENES_COMPRA.OCO_CUD_CUENTA_DECEVAL%TYPE;
   V_COND_PRECIO         ORDENES_COMPRA.OCO_CONDICION_PRECIO%TYPE;
   V_CANTIDAD            ORDENES_COMPRA.OCO_NOMINAL_O_PESOS%TYPE;
   V_EOC_MNEMONICO       ORDENES_COMPRA.OCO_EOC_MNEMONICO%TYPE;
   V_VIO_MNEMMONICO      ORDENES_COMPRA.OCO_VIO_MNEMONICO%TYPE;
   V_PRECIO              ORDENES_COMPRA.OCO_NOMINAL_O_PESOS%TYPE;
   V_COMISION            ORDENES_COMPRA.OCO_COMISION_OMS%TYPE;
   V_PRECIO_LIMITE       ORDENES_COMPRA.OCO_PRECIO_LIMITE_O_MARGEN%TYPE;
   V_TITULO_ORIGEN       ORDENES_VENTA.OVE_ORIGEN_FUNGIBLE%TYPE;
   V_TITULO_CTA_DVAL     ORDENES_VENTA.OVE_CFC_CUENTA_DECEVAL%TYPE;
   V_IVA_ITENCION        ORDENES_VENTA.OVE_IVA_ACC%TYPE;
   V_TOTAL_OPERACION_INT ORDENES_VENTA.OVE_TOTAL_OPERACION_ACC%TYPE;
   V_NETO_OPERACION_INT  ORDENES_VENTA.OVE_NETO_OPERACION_ACC%TYPE;
   V_ID_ORDEN            ORDENES_VENTA.OVE_CONSECUTIVO%TYPE;
   V_CLOB                CLOB;
   V_VALOR_CONS          CONSTANTES.CON_VALOR%TYPE;
   V_VALOR_CONS_INT      CONSTANTES.CON_VALOR%TYPE;
   V_VALOR_DATE_CONS     CONSTANTES.CON_VALOR_DATE%TYPE;
   V_VALOR_CHAR_CONS     CONSTANTES.CON_VALOR_CHAR%TYPE;
   V_VALOR_SAE_S2        CONSTANTES.CON_VALOR_CHAR%TYPE;
   V_VALOR_SAE_S4        CONSTANTES.CON_VALOR_CHAR%TYPE;
   V_NOC_CLI_PER_NUM_IDE CUENTAS_CLIENTE_CORREDORES.CCC_cLI_PER_NUM_IDEN%TYPE;
   IO_CURSOR             P_WEB_CLIENTE.O_CURSOR;
   IO_CURSOR_CCC         P_WEB_CLIENTE.O_CURSOR;
   IO_CURSOR_C_V         P_WEB_CLIENTE.O_CURSOR;
   IO_CURSOR_CUD         P_WEB_CLIENTE.O_CURSOR;
   IO_CURSOR_ORDENANTE   P_WEB_CLIENTE.O_CURSOR;
   IO_CURSOR_ENA         P_WEB_CLIENTE.O_CURSOR;

BEGIN
   IF P_EJECUTA = 'S' THEN
     --RAISE_APPLICATION_ERROR(-20001,'Error en P_ACTUALIZA_INTERFAZ_CMA: '||sqlerrm);

     V_INTERFAZ_CMA := NULL;
     IO_CURSOR      := NULL;



     P_TOOLS.CONSULTARCONSTANTE(P_CONSTANTE  => 'IVC',
                                P_VALOR      => V_VALOR_CONS,
                                P_VALOR_DATE => V_VALOR_DATE_CONS,
                                P_VALOR_CHAR => V_VALOR_CHAR_CONS);

     P_TOOLS.CONSULTARCONSTANTE(P_CONSTANTE  => 'CS2',
                                P_VALOR      => V_VALOR_CONS_INT,
                                P_VALOR_DATE => V_VALOR_DATE_CONS,
                                P_VALOR_CHAR => V_VALOR_SAE_S2);

     P_TOOLS.CONSULTARCONSTANTE(P_CONSTANTE  => 'CS4',
                                P_VALOR      => V_VALOR_CONS_INT,
                                P_VALOR_DATE => V_VALOR_DATE_CONS,
                                P_VALOR_CHAR => V_VALOR_SAE_S4);



     V_QUERY_INTERFAZ := 'SELECT IOC_CONSECUTIVO '||
                        ',IOC_NRO_INT_ORDEN '||
                        ',IOC_NRO_ORDEN '||
                        ',IOC_FEC_ORDEN '||
                        ',IOC_CLASE_ORDEN '||
                        ',IOC_TIPO_ORDEN '||
                        ',IOC_FEC_CUMPLIMIENTO '||
                        ',IOC_TIP_USUARIO '||
                        ',IOC_TIPO_DOCTO '||
                        ',IOC_NUM_DOCTO '||
                        ',IOC_NUM_CTA '||
                        ',IOC_MNEMOTECNICO '||
                        ',IOC_MERCADO '||
                        ',IOC_CANTIDAD '||
                        ',IOC_CANTIDAD_CALZADA '||
                        ',IOC_CANTIDAD_PENDIENTE '||
                        ',IOC_PREC_REGISTRO '||
                        ',IOC_PREC_PROMEDIO '||
                        ',IOC_PRECIO_STOP '||
                        ',IOC_VALOR '||
                        ',IOC_COMISION '||
                        ',IOC_IVA_COMISION '||
                        ',IOC_VALOR_GIRO '||
                        ',IOC_ESTADO '||
                        ',IOC_CTA_DCV '||
                        ',IOC_CTA_DECEVAL '||
                        ',IOC_ID_EVENTO '||
                        ',IOC_MENSAJE '||
                        ',IOC_FECHA_INGRESO '||
                        ',IOC_FECHA_ENTREGA '||
                        ',IOC_ESTADO_REGISTRO '||
                        ',IOC_OBSERVACIONES '||
                        'FROM INTERFAZ_ORDENES_CMA '||
                        'WHERE  IOC_ESTADO_REGISTRO = '||CHR(39)||'POR_PROCESAR'||CHR(39)||
                        '  AND  TRUNC(IOC_FECHA_INGRESO)  >= TRUNC(SYSDATE)'||
                        ' ORDER BY IOC_CONSECUTIVO';
     OPEN IO_CURSOR FOR V_QUERY_INTERFAZ;
     LOOP
        V_ERRORES      := 0;
        V_QUERY_CCC    := NULL;

        DELETE GL_CAB_ERROR;
        V_CLOB     := NULL;
        V_ID_ORDEN := NULL;


        FETCH IO_CURSOR INTO V_INTERFAZ_CMA.IOC_CONSECUTIVO ,
                             V_INTERFAZ_CMA.IOC_NRO_INT_ORDEN,
                             V_INTERFAZ_CMA.IOC_NRO_ORDEN,
                             V_INTERFAZ_CMA.IOC_FEC_ORDEN,
                             V_INTERFAZ_CMA.IOC_CLASE_ORDEN,
                             V_INTERFAZ_CMA.IOC_TIPO_ORDEN,
                             V_INTERFAZ_CMA.IOC_FEC_CUMPLIMIENTO,
                             V_INTERFAZ_CMA.IOC_TIP_USUARIO,
                             V_INTERFAZ_CMA.IOC_TIPO_DOCTO,
                             V_INTERFAZ_CMA.IOC_NUM_DOCTO,
                             V_INTERFAZ_CMA.IOC_NUM_CTA,
                             V_INTERFAZ_CMA.IOC_MNEMOTECNICO,
                             V_INTERFAZ_CMA.IOC_MERCADO,
                             V_INTERFAZ_CMA.IOC_CANTIDAD,
                             V_INTERFAZ_CMA.IOC_CANTIDAD_CALZADA,
                             V_INTERFAZ_CMA.IOC_CANTIDAD_PENDIENTE,
                             V_INTERFAZ_CMA.IOC_PREC_REGISTRO,
                             V_INTERFAZ_CMA.IOC_PREC_PROMEDIO,
                             V_INTERFAZ_CMA.IOC_PRECIO_STOP,
                             V_INTERFAZ_CMA.IOC_VALOR ,
                             V_INTERFAZ_CMA.IOC_COMISION ,
                             V_INTERFAZ_CMA.IOC_IVA_COMISION ,
                             V_INTERFAZ_CMA.IOC_VALOR_GIRO ,
                             V_INTERFAZ_CMA.IOC_ESTADO ,
                             V_INTERFAZ_CMA.IOC_CTA_DCV ,
                             V_INTERFAZ_CMA.IOC_CTA_DECEVAL ,
                             V_INTERFAZ_CMA.IOC_ID_EVENTO ,
                             V_INTERFAZ_CMA.IOC_MENSAJE ,
                             V_INTERFAZ_CMA.IOC_FECHA_INGRESO ,
                             V_INTERFAZ_CMA.IOC_FECHA_ENTREGA ,
                             V_INTERFAZ_CMA.IOC_ESTADO_REGISTRO ,
                             V_INTERFAZ_CMA.IOC_OBSERVACIONES;
        EXIT WHEN IO_CURSOR%NOTFOUND;

        -- Determinar cuenta corredores tipo S2 o s4
        IO_CURSOR_CCC := NULL;
        V_CUENTA_CCC  := NULL;
        V_NOC_CLI_PER_NUM_IDE := NULL;
        BEGIN
           V_CUENTA_CCC.CCC_NUMERO_CUENTA := TO_NUMBER(NVL(TRIM(V_INTERFAZ_CMA.IOC_CTA_DCV),'0'),'99');
           EXCEPTION WHEN OTHERS THEN
             UPDATE INTERFAZ_ORDENES_CMA
                SET IOC_OBSERVACIONES = 'CCC ERROR '
                   ,IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                   ,IOC_FECHA_ENTREGA = SYSDATE
             WHERE  IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
             V_ERRORES  := V_ERRORES+1;
        END;

        BEGIN
           V_CUENTA_DECEVAL := TO_NUMBER(NVL(TRIM(V_INTERFAZ_CMA.IOC_CTA_DECEVAL),'0'),'99999999');
           EXCEPTION WHEN OTHERS THEN
             UPDATE INTERFAZ_ORDENES_CMA
                SET IOC_OBSERVACIONES = IOC_OBSERVACIONES ||' DCVAL ERROR'
                   ,IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                   ,IOC_FECHA_ENTREGA = SYSDATE
             WHERE  IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
             V_ERRORES := V_ERRORES+1;
        END;

        BEGIN
           V_CANTIDAD := TO_NUMBER(NVL(TRIM(REPLACE(V_INTERFAZ_CMA.IOC_CANTIDAD,',','.')),'0'),'999999999.00');
           EXCEPTION WHEN OTHERS THEN
             UPDATE INTERFAZ_ORDENES_CMA
                SET IOC_OBSERVACIONES = IOC_OBSERVACIONES ||' CANTIDAD ERROR'
                   ,IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                   ,IOC_FECHA_ENTREGA = SYSDATE
             WHERE  IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
             V_ERRORES := V_ERRORES+1;
        END;

        BEGIN
           V_PRECIO := TO_NUMBER(NVL(TRIM(REPLACE(V_INTERFAZ_CMA.IOC_PREC_REGISTRO,',','.')),'0'),'999999999999.9999');
           EXCEPTION WHEN OTHERS THEN
             UPDATE INTERFAZ_ORDENES_CMA
                SET IOC_OBSERVACIONES = IOC_OBSERVACIONES ||' PRECIO ERROR'
                   ,IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                   ,IOC_FECHA_ENTREGA = SYSDATE
             WHERE  IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
             V_ERRORES := V_ERRORES+1;
        END;

        BEGIN
          V_COMISION := TO_NUMBER(NVL(TRIM(REPLACE(V_INTERFAZ_CMA.IOC_COMISION,',','.')),'0'),'9999999999.9999999999');
          IF NVL(V_COMISION,0) = 0 THEN
             UPDATE INTERFAZ_ORDENES_CMA
                SET IOC_OBSERVACIONES = IOC_OBSERVACIONES ||' COMISION CERO'
                   ,IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                   ,IOC_FECHA_ENTREGA = SYSDATE
             WHERE  IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
             V_ERRORES := V_ERRORES+1;
          END IF;
           EXCEPTION WHEN OTHERS THEN
             UPDATE INTERFAZ_ORDENES_CMA
                SET IOC_OBSERVACIONES = IOC_OBSERVACIONES ||' COMISION ERROR'
                   ,IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                   ,IOC_FECHA_ENTREGA = SYSDATE
             WHERE  IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
             V_ERRORES := V_ERRORES+1;
        END;


        IF V_CUENTA_CCC.CCC_NUMERO_CUENTA > 0 AND V_CUENTA_DECEVAL > 0 AND V_CANTIDAD > 0 AND
           V_PRECIO >= 0 AND V_COMISION > 0  AND V_ERRORES = 0 THEN

           V_PERSONAS       := NULL;

           V_QUERY_CCC := 'SELECT CCC_ETRADE,CCC_ETRADE_INSTITUCIONAL,CCC_CLI_PER_NUM_IDEN '||
                                 ' ,CCC_CLI_PER_TID_CODIGO '||
                                 ' ,CCC_NUMERO_CUENTA'||
                                 ' ,PER.PER_NUM_IDEN '||
                                 ' ,PER.PER_TID_CODIGO '||
                                 ' ,PER.PER_NOMBRE_USUARIO '||
                                 ' ,PER.PER_CODIGO_SAE_ACC '||
                                 ' ,PER.PER_EJECUTA_ORDEN_MESA '||
                                 ' ,PER.PER_TIPO_COMERCIAL '||
                                 ' ,FIL.PER_TIPO '||
                                 ' ,FIL.PER_RAZON_SOCIAL '||
                                 ' ,FIL.PER_PRIMER_APELLIDO  '||
                                 ' ,FIL.PER_SEGUNDO_APELLIDO '||
                                 ' ,FIL.PER_NOMBRE '||
                          ' FROM PERSONAS FIL,PERSONAS PER,CUENTAS_CLIENTE_CORREDORES '||
                          ' WHERE FIL.PER_NUM_IDEN = CCC_CLI_PER_NUM_IDEN '||
                          ' AND FIL.PER_TID_CODIGO = CCC_CLI_PER_TID_CODIGO '||
                          ' AND PER.PER_NUM_IDEN = CCC_PER_NUM_IDEN '||
                          ' AND PER.PER_TID_CODIGO = CCC_PER_TID_CODIGO '||
                          ' AND PER.PER_ESTADO = ''A'' '||
                          ' AND CCC_CLI_PER_NUM_IDEN = '||CHR(39)||V_INTERFAZ_CMA.IOC_NUM_DOCTO||CHR(39)||
                          ' AND CCC_CLI_PER_TID_CODIGO = '||CHR(39)||V_INTERFAZ_CMA.IOC_TIPO_DOCTO||CHR(39)||
                          ' AND CCC_NUMERO_CUENTA = '||V_CUENTA_CCC.CCC_NUMERO_CUENTA;

           OPEN IO_CURSOR_CCC FOR V_QUERY_CCC;
           LOOP
              FETCH IO_CURSOR_CCC INTO  V_CUENTA_CCC.CCC_ETRADE,
                                        V_CUENTA_CCC.CCC_ETRADE_INSTITUCIONAL,
                                        V_CUENTA_CCC.CCC_CLI_PER_NUM_IDEN,
                                        V_CUENTA_CCC.CCC_CLI_PER_TID_CODIGO,
                                        V_CUENTA_CCC.CCC_NUMERO_CUENTA,
                                        V_PERSONAS.PER_NUM_IDEN,
                                        V_PERSONAS.PER_TID_CODIGO,
                                        V_PERSONAS.PER_NOMBRE_USUARIO,
                                        V_PERSONAS.PER_CODIGO_SAE_ACC,
                                        V_PERSONAS.PER_EJECUTA_ORDEN_MESA,
                                        V_PERSONAS.PER_TIPO_COMERCIAL,
                                        V_PERSONAS.PER_TIPO,
                                        V_PERSONAS.PER_RAZON_SOCIAL,
                                        V_PERSONAS.PER_PRIMER_APELLIDO,
                                        V_PERSONAS.PER_SEGUNDO_APELLIDO,
                                        V_PERSONAS.PER_NOMBRE ;
              EXIT WHEN IO_CURSOR_CCC%NOTFOUND;
           END LOOP;
           CLOSE IO_CURSOR_CCC ;

           IF V_CUENTA_CCC.CCC_NUMERO_CUENTA IS NULL THEN
               UPDATE INTERFAZ_ORDENES_CMA
                SET IOC_OBSERVACIONES = IOC_OBSERVACIONES ||' CCC NO EXSITE'
                   ,IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                   ,IOC_FECHA_ENTREGA = SYSDATE
             WHERE  IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
             V_ERRORES := V_ERRORES+1;
           END IF;

           IF V_ERRORES = 0 THEN
             IO_CURSOR_C_V    := NULL;
             V_QUERY_C        := NULL;
             V_QUERY_V        := NULL;
             V_ORDENES_COMPRA := NULL;
             V_ORDENES_VENTA  := NULL;
             SELECT DECODE(V_INTERFAZ_CMA.IOC_TIPO_ORDEN,'LIM','LIM','MKT','MER') INTO V_COND_PRECIO  FROM DUAL;

             IF V_COND_PRECIO = 'LIM' THEN
                V_PRECIO_LIMITE := V_PRECIO;
             ELSE
                V_PRECIO_LIMITE := NULL;
             END IF;

             IF V_CUENTA_CCC.CCC_ETRADE = 'S' THEN -- ORDENES DE S2
                -- BUSCAR ORDENES SEGUN CORRESPONDA Y ACTUALIZAR VALORES
                IF V_INTERFAZ_CMA.IOC_CLASE_ORDEN = 'C' THEN
                   -- BUSCAR ORDENE DE COMPRA  POR ID CMA

                   V_QUERY_C := 'SELECT OCO_CONSECUTIVO,OCO_BOL_MNEMONICO,OCO_COC_CTO_MNEMONICO '||
                                        ' ,OCO_EOC_MNEMONICO '||
                                ' FROM ORDENES_COMPRA '||
                                --' WHERE OCO_FECHA_Y_HORA >= TRUNC(SYSDATE) '||
                                --'   AND OCO_FECHA_Y_HORA < TRUNC(SYSDATE+1) '||
                                 ' WHERE  OCO_CCC_CLI_PER_NUM_IDEN = '||CHR(39)||V_CUENTA_CCC.CCC_CLI_PER_NUM_IDEN||CHR(39)||
                                '   AND OCO_CCC_CLI_PER_TID_CODIGO = '||CHR(39)||V_CUENTA_CCC.CCC_CLI_PER_TID_CODIGO||CHR(39)||
                                '   AND OCO_CCC_NUMERO_CUENTA = '||V_CUENTA_CCC.CCC_NUMERO_CUENTA||
                                '   AND OCO_CANAL_ORIGEN = '||CHR(39)||'S2'||CHR(39)||
                                --'   AND OCO_EOC_MNEMONICO IN( '||CHR(39)||'PCO'||CHR(39)||','||CHR(39)||'COL'||CHR(39)||')'||
                                '   AND OCO_ENA_MNEMONICO = '||CHR(39)||V_INTERFAZ_CMA.IOC_MNEMOTECNICO||CHR(39)||
                                '   AND OCO_CUD_CUENTA_DECEVAL = '||V_CUENTA_DECEVAL||
                                --'   AND OCO_ID_BOLSA_CMA = '||CHR(39)||V_INTERFAZ_CMA.IOC_NRO_ORDEN||CHR(39)||
                                '   AND OCO_ID_CMA = '||TO_NUMBER(NVL(TRIM(V_INTERFAZ_CMA.IOC_NRO_INT_ORDEN),'0'),'9999999999');

                   OPEN IO_CURSOR_C_V FOR V_QUERY_C;
                   LOOP
                      FETCH IO_CURSOR_C_V INTO  V_ORDENES_COMPRA.OCO_CONSECUTIVO,
                                                V_ORDENES_COMPRA.OCO_BOL_MNEMONICO,
                                                V_ORDENES_COMPRA.OCO_COC_CTO_MNEMONICO,
                                                V_ORDENES_COMPRA.OCO_EOC_MNEMONICO;
                      EXIT WHEN IO_CURSOR_C_V%NOTFOUND;
                   END LOOP;
                   CLOSE IO_CURSOR_C_V;

                   V_EOC_MNEMONICO := NULL;
                   BEGIN
                      IF V_INTERFAZ_CMA.IOC_FEC_CUMPLIMIENTO IS NOT NULL THEN
                         V_FECHA_PERMANENCIA := TO_DATE(REPLACE(TRIM(V_INTERFAZ_CMA.IOC_FEC_CUMPLIMIENTO),'.'),'DD/MM/YYYY HH:MI:SS am');

                         IF TRUNC(V_FECHA_PERMANENCIA) > TRUNC(SYSDATE) THEN
                            V_VIO_MNEMMONICO := 'HFE';
                         ELSE
                            V_FECHA_PERMANENCIA :=  NULL;
                            V_VIO_MNEMMONICO := 'DIA';
                         END IF;
                      ELSE
                        V_FECHA_PERMANENCIA :=  NULL;
                        V_VIO_MNEMMONICO := 'DIA';
                      END IF;
                   END;

                   --RAISE_APPLICATION_ERROR(-20001,'ERROR V_FECHA_PERMANENCIA: '||V_FECHA_PERMANENCIA||'-'||V_VIO_MNEMMONICO);

                   SELECT DECODE(V_INTERFAZ_CMA.IOC_ESTADO,'P','COL',
                                                           'T','COL',
                                                           'E','COL',
                                                           'C','COL',
                                                           'EC','COL',
                                                           'ANU','ANU',
                                                           'V','ANU',
                                                           'CV','CAN',
                                                           'CX','CAN') INTO V_EOC_MNEMONICO FROM DUAL;

                   IF V_ORDENES_COMPRA.OCO_CONSECUTIVO IS NULL AND V_EOC_MNEMONICO = 'COL' THEN
                      --  CREACION ORDEN DE COMPRA INFORMADA POR LA INTERFAZ
                      V_CLOB                  := NULL;
                      V_ID_ORDEN              := NULL;
                      V_IVA_ITENCION          := V_COMISION*V_VALOR_CONS;
                      V_TOTAL_OPERACION_INT   := V_CANTIDAD*V_PRECIO;
                      V_NETO_OPERACION_INT    := V_TOTAL_OPERACION_INT+V_COMISION+V_IVA_ITENCION;

                      V_PORCENTAJE_COMISION   := 0;
                      V_COMISION_ESPECIAL     := 0;
                      V_IND_COMISION_ESPE     := 'N';

                      -- VALIDAR SI EL CLIENTE TIENE COMISION ESPECIAL
                      V_COMISION_ESPECIAL := P_COMERCIAL.CALCULAR_COMISION_BURSATIL(
                                             P_NUM_IDEN           => V_CUENTA_CCC.CCC_CLI_PER_NUM_IDEN,
                                             P_TID_CODIGO         => V_CUENTA_CCC.CCC_CLI_PER_TID_CODIGO,
                                             P_NRO_CUENTA         => V_CUENTA_CCC.CCC_NUMERO_CUENTA,
                                             P_TIPO_PAPEL         => 'ACC',
                                             P_TIPO_NOMINAL_PESOS => NULL,
                                             P_ESPECIE            => NULL,
                                             P_MONTO              => NULL,
                                             P_LLAMADO            => 'EXT');
                      IF NVL(V_COMISION_ESPECIAL,0) != 0 THEN
                         V_PORCENTAJE_COMISION   := V_COMISION_ESPECIAL;
                         V_IND_COMISION_ESPE     := 'S';
                      ELSE
                         V_PORCENTAJE_COMISION   := TRUNC(V_COMISION/(V_CANTIDAD*V_PRECIO),5)*100;
                         V_IND_COMISION_ESPE     := 'N';
                      END IF;
                   --RAISE_APPLICATION_ERROR(-20001,'NETOS: '||V_COMISION||'-'||V_VALOR_CONS||'-'||V_TOTAL_OPERACION_INT||'-'||V_NETO_OPERACION_INT);
                      BEGIN
                        P_ORDENES_COMERCIAL.P_COLOCAR_ORDEN( P_CLI_TID_CODIGO        => V_CUENTA_CCC.CCC_CLI_PER_TID_CODIGO,
                                                           P_CLI_NUM_IDEN          => V_CUENTA_CCC.CCC_CLI_PER_NUM_IDEN,
                                                           P_USUARIO               => V_PERSONAS.PER_NOMBRE_USUARIO,
                                                           P_CUENTA_CORREDORES     => V_CUENTA_CCC.CCC_NUMERO_CUENTA,
                                                           P_COLOCA_USUARIO        => V_PERSONAS.PER_NOMBRE_USUARIO,
                                                           P_COLOCA_TID_CODIGO     => V_PERSONAS.PER_TID_CODIGO,
                                                           P_COLOCA_NUM_IDEN       => V_PERSONAS.PER_NUM_IDEN,
                                                           P_COLOCA_TERMINAL       => FN_TERMINAL      ,
                                                           P_DUENO_TID_CODIGO      => V_PERSONAS.PER_TID_CODIGO,
                                                           P_DUENO_NUM_IDEN        => V_PERSONAS.PER_NUM_IDEN,
                                                           P_ORDENANTE_TID_CODIGO  => V_CUENTA_CCC.CCC_CLI_PER_TID_CODIGO,
                                                           P_ORDENANTE_NUM_IDEN    => V_CUENTA_CCC.CCC_CLI_PER_NUM_IDEN,
                                                           P_TIPO_ORDEN            => V_INTERFAZ_CMA.IOC_CLASE_ORDEN,
                                                           P_ESPECIE               => V_INTERFAZ_CMA.IOC_MNEMOTECNICO,
                                                           P_CANTIDAD              => V_CANTIDAD,
                                                           P_FECHA_HORA            => TO_CHAR(SYSDATE,'DD-MM-YYYY'),
                                                           P_PORCENTAJE_COMISION   => V_PORCENTAJE_COMISION  ,
                                                           P_VIG_TIPO_VIGENCIA     => V_VIO_MNEMMONICO,
                                                           P_VIG_FECHA_PERMANENCI  => TO_CHAR(V_FECHA_PERMANENCIA,'DD-MM-YYYY'),
                                                           P_VIG_HORA_PERMANENCIA  => NULL,
                                                           P_COND_PRECIO           => V_COND_PRECIO,
                                                           P_COND_PRECIO_LIMITIE   => V_PRECIO_LIMITE,
                                                           P_COND_CRITERIOS_ADICI  => NULL,
                                                           P_COND_CANTIDAD_MINIMA  => NULL,
                                                           P_VIS_VISIBLE           => NULL,
                                                           P_VIS_PORCENTAJE        => NULL,
                                                           P_STOP_STOP             => NULL,
                                                           P_STOP_PRECIO_STOP      => NULL,
                                                           P_CONSOLIDAR            => 0,
                                                           P_CUENTA_DECEVAL        => V_CUENTA_DECEVAL,
                                                           P_TITULO_ORIGEN         => NULL,
                                                           P_TITULO_CTA_DVAL       => NULL,
                                                           P_TITULO_COD_FUNGIBLE   => NULL,
                                                           P_TITULO_COD_ISIN       => 0,
                                                           P_INS_REC_MEDIO         => 'INT',
                                                           P_INS_REC_HORA          => TO_CHAR(SYSDATE,'HH24:MI'),
                                                           P_INS_REC_DETALLE       => 'Internet S2',
                                                           P_INS_ENV_FAX           => 0,
                                                           P_INS_ENV_NUM_FAX       => NULL,
                                                           P_INS_ENV_DIRECCION     => 0,
                                                           P_INS_ENV_NUM_DIRECCION => NULL,
                                                           P_INS_ENV_COD_CIUDAD    => NULL,
                                                           P_INS_ENV_CONTACTO      => NULL,
                                                           P_CLI_PROFESIONAL       => 'N',
                                                           P_OPX                   => 'N',
                                                           P_CANTIDAD_INTENCION    => V_CANTIDAD,
                                                           P_PRECIO_INTENCION      => V_PRECIO,
                                                           P_COMISION_INTENCION    => V_COMISION,
                                                           P_IVA_ITENCION          => V_IVA_ITENCION,
                                                           P_TOTAL_OPERACION_INT   => V_TOTAL_OPERACION_INT,
                                                           P_NETO_OPERACION_INT    => V_NETO_OPERACION_INT,
                                                           P_FECHA_RECEPCION       => TO_CHAR(SYSDATE,'DD/MM/YYYY'),
                                                           P_ABONO_CUENTA          => 'S',
                                                           P_VALOR_ABONO_CUENTA    => NULL,
                                                           P_PAGAR_A_PAGO          => NULL,
                                                           P_TIPO_IDEN_PAGO        => NULL,
                                                           P_NUM_IDEN_PAGO         => NULL,
                                                           P_TIPO_CUENTA_PAGO      => NULL,
                                                           P_CODIGO_BANCO_PAGO     => NULL,
                                                           P_NUMERO_CUENTA_PAGO    => NULL,
                                                           P_NOMBRE_CUENTA_PAGO    => NULL,
                                                           P_VALOR_PAGO            => NULL,
                                                           P_CODIGO_INFORMADOR     => NULL,
                                                           P_TID_CODIGO_INFORMADOR => NULL,
                                                           P_NUM_IDEN_INFORMADOR   => NULL,
                                                           P_NOMBRE_INFORMADOR     => NULL,
                                                           P_CODIGO_OFICINA_INFOR  => NULL,
                                                           P_FECHA_PRE_ORDEN_INFOR => NULL,
                                                           P_HORA_PRE_ORDEN_INFOR  => NULL,
                                                           P_ID_ORDEN              => V_ID_ORDEN,
                                                           P_CLOB                  => V_CLOB);

                        EXCEPTION WHEN OTHERS THEN
                          V_ID_ORDEN := NULL;
                          IF V_CLOB IS NULL THEN
                            V_CLOB := substr(sqlerrm,1,3500);
                          END IF;
                          UPDATE INTERFAZ_ORDENES_CMA
                           SET IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                             ,IOC_FECHA_ENTREGA = SYSDATE
                             ,IOC_OBSERVACIONES = ' ORDEN S2:'||V_CLOB
                         WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                      END;
                      DBMS_OUTPUT.PUT_LINE('ID ORDEN :'||V_ID_ORDEN);
                      DBMS_OUTPUT.PUT_LINE('CLOB :'||V_CLOB);
                      IF V_ID_ORDEN IS NOT NULL THEN
                         UPDATE INTERFAZ_ORDENES_CMA
                           SET IOC_ESTADO_REGISTRO = 'PROCESADO'
                             ,IOC_FECHA_ENTREGA = SYSDATE
                         WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;

                         UPDATE ORDENES_COMPRA
                           SET OCO_ID_BOLSA_CMA =   V_INTERFAZ_CMA.IOC_NRO_ORDEN
                              ,OCO_ID_CMA = TO_NUMBER(NVL(TRIM(V_INTERFAZ_CMA.IOC_NRO_INT_ORDEN),'0'),'9999999999')
                              ,OCO_COMISION_OMS = V_COMISION
                              ,OCO_ESTADO_BOLSA = DECODE(V_INTERFAZ_CMA.IOC_ESTADO,'E','REG','C','REG','EC','REG',NULL)
                         WHERE  OCO_CONSECUTIVO = V_ID_ORDEN
                           AND OCO_BOL_MNEMONICO = 'COL'
                           AND OCO_COC_CTO_MNEMONICO = 'ACC';


                         -- NOTIFICAR OPERACION S2
                         -- NOTIFICAR ORDENES A DATAIFX
                         IF V_PERSONAS.PER_TIPO = 'PJU' THEN
                            V_NOC_CLI_PER_NUM_IDE := V_CUENTA_CCC.CCC_CLI_PER_NUM_IDEN||'-'||P_CLIENTES.RT_DIGITO_CONTROL(V_CUENTA_CCC.CCC_CLI_PER_NUM_IDEN);
                         ELSE
                            V_NOC_CLI_PER_NUM_IDE := V_CUENTA_CCC.CCC_CLI_PER_NUM_IDEN;
                         END IF;

                         INSERT INTO NOTIFICACIONES_ORDENES_CMA(
                             NOC_CONSECUTIVO
                            ,NOC_FOLIO_BOLSA
                            ,NOC_CLI_PER_NUM_IDEN
                            ,NOC_CLI_PER_TID_CODIGO
                            ,NOC_CUENTA_DECEVAL
                            ,NOC_ID_COEASY
                            ,NOC_TIPO_NEGOCIO
                            ,NOC_PORCENTAJE_COMISION
                            ,NOC_USUARIO_SAE
                            ,NOC_ESPECIAL_FIDUCIARIO
                            ,NOC_CANTIDAD
                            ,NOC_PRECIO
                            ,NOC_ESTADO
                            ,NOC_FECHA_INGRESO
                            ,NOC_FECHA_ENTREGA
                            ,NOC_ENA_MNEMONICO
                            ,NOC_CANAL_ORIGEN
                            ,NOC_PER_NOMBRE_USUARIO
                            ,NOC_PER_NOMBRE
                            ,NOC_PER_APELLIDOS
                            ,NOC_COMISION_ESPECIAL_ETRADE)
                         VALUES(
                             NOC_SEQ.NEXTVAL                                 --NOC_CONSECUTIVO
                            ,V_INTERFAZ_CMA.IOC_NRO_ORDEN                    --NOC_FOLIO_BOLSA
                            ,V_NOC_CLI_PER_NUM_IDE                           --V_CUENTA_CCC.CCC_CLI_PER_NUM_IDEN               --NOC_CLI_PER_NUM_IDEN
                            ,V_CUENTA_CCC.CCC_CLI_PER_TID_CODIGO             --NOC_CLI_PER_TID_CODIGO
                            ,V_CUENTA_DECEVAL                                --NOC_CUENTA_DECEVAL
                            ,V_ID_ORDEN                                      --NOC_ID_COEASY
                            ,'C'                                             --NOC_TIPO_NEGOCIO
                            ,TRUNC(V_PORCENTAJE_COMISION,3)                  --NOC_PORCENTAJE_COMISION
                            ,V_VALOR_SAE_S2                                  --NOC_USUARIO_SAE
                            ,V_CUENTAS_DECEVAL.CUD_ESPECIAL_FIDUCIARIO       --NOC_ESPECIAL_FIDUCIARIO
                            ,V_CANTIDAD                                      --NOC_CANTIDAD
                            ,V_PRECIO                                        --NOC_PRECIO
                            ,'POR_PROCESAR'                                  --NOC_ESTADO
                            ,SYSDATE                                         --NOC_FECHA_INGRESO
                            ,NULL                                            --NOC_FECHA_ENTREGA
                            ,V_INTERFAZ_CMA.IOC_MNEMOTECNICO                 --NOC_ENA_MNEMONICO
                            ,'1'--'S2'                                       --NOC_CANAL_ORIGEN
                            ,V_PERSONAS.PER_NOMBRE_USUARIO                   --NOC_PER_NOMBRE_USUARIO
                            ,DECODE(V_PERSONAS.PER_TIPO,'PJU',
                                    V_PERSONAS.PER_RAZON_SOCIAL,
                                    V_PERSONAS.PER_NOMBRE)                   --NOC_PER_NOMBRE
                            ,DECODE(V_PERSONAS.PER_TIPO,'PJU',' ',
                                    TRIM(V_PERSONAS.PER_PRIMER_APELLIDO)||' '||
                                    TRIM(V_PERSONAS.PER_SEGUNDO_APELLIDO))   --NOC_PER_APELLIDOS)
                            ,V_IND_COMISION_ESPE);
                      END IF;

                      IF V_CLOB IS NOT NULL THEN
                        UPDATE INTERFAZ_ORDENES_CMA
                        SET IOC_OBSERVACIONES = ' ORDEN S2:'||V_CLOB
                           ,IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                           ,IOC_FECHA_ENTREGA = SYSDATE
                        WHERE  IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                        V_ERRORES := V_ERRORES+1;
                      END IF;
                   END IF;

                   IF V_ORDENES_COMPRA.OCO_CONSECUTIVO IS NOT NULL THEN
                      IF V_EOC_MNEMONICO = 'COL' THEN
                         BEGIN
                           UPDATE ORDENES_COMPRA
                              SET OCO_ID_BOLSA_CMA  = V_INTERFAZ_CMA.IOC_NRO_ORDEN
                                 ,OCO_ID_CMA = TO_NUMBER(NVL(TRIM(V_INTERFAZ_CMA.IOC_NRO_INT_ORDEN),'0'),'9999999999')
                                 ,OCO_VIO_MNEMONICO = V_VIO_MNEMMONICO
                                 ,OCO_FECHA_PERMANENCIA = V_FECHA_PERMANENCIA
                                 ,OCO_NOMINAL_O_PESOS = V_CANTIDAD
                                 ,OCO_PRECIO_LIMITE_O_MARGEN = DECODE(V_COND_PRECIO,'LIM',V_PRECIO,NULL)
                                 ,OCO_ESTADO_BOLSA = DECODE(V_INTERFAZ_CMA.IOC_ESTADO,'E','REG','C','REG','EC','REG',NULL)
                                 --,OCO_COMISION = TRUNC(V_COMISION/(V_CANTIDAD*V_PRECIO),5)
                                 --,OCO_COMISION_OMS = V_COMISION
                                 --,OCO_CANTIDAD_ACC   = V_CANTIDAD
                                 ,OCO_PRECIO_ACC = V_PRECIO
                                 ,OCO_COMISION_ACC = V_COMISION
                                 ,OCO_IVA_ACC  =  V_COMISION*NVL(V_VALOR_CONS,0)
                                 --,OCO_TOTAL_OPERACION_ACC = V_CANTIDAD*V_PRECIO
                                 --,OCO_NETO_OPERACION_ACC = (V_CANTIDAD*V_PRECIO)+V_COMISION+(V_COMISION*NVL(V_VALOR_CONS,0))
                           WHERE OCO_CONSECUTIVO = V_ORDENES_COMPRA.OCO_CONSECUTIVO
                             AND OCO_BOL_MNEMONICO = V_ORDENES_COMPRA.OCO_BOL_MNEMONICO
                             AND OCO_COC_CTO_MNEMONICO = V_ORDENES_COMPRA.OCO_COC_CTO_MNEMONICO;
                           IF SQL%ROWCOUNT = 0 THEN
                              V_ERRORES := V_ERRORES+1;
                              V_CLOB := P_CAB.ObtenerCLOB_ERROR ('UpdateOrden');
                              UPDATE INTERFAZ_ORDENES_CMA
                              SET IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                                 ,IOC_FECHA_ENTREGA = SYSDATE
                                 ,IOC_OBSERVACIONES = ' ORDEN S2:'||V_CLOB
                              WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                           ELSE
                              UPDATE NOTIFICACIONES_ORDENES_CMA
                                SET NOC_FOLIO_BOLSA = V_INTERFAZ_CMA.IOC_NRO_ORDEN
                              WHERE NOC_ID_COEASY =   V_ORDENES_COMPRA.OCO_CONSECUTIVO
                                AND NOC_TIPO_NEGOCIO  = 'C'
                                AND NOC_ESTADO = 'POR_PROCESAR';

                              UPDATE INTERFAZ_ORDENES_CMA
                                 SET IOC_ESTADO_REGISTRO = 'PROCESADO'
                                    ,IOC_FECHA_ENTREGA = SYSDATE
                              WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                           END IF;

                           EXCEPTION WHEN OTHERS THEN
                             V_ID_ORDEN := NULL;
                             V_ERRORES := V_ERRORES+1;
                             V_CLOB := P_CAB.ObtenerCLOB_ERROR ('UpdateOrden');
                             IF V_CLOB IS NULL THEN
                               V_CLOB := substr(sqlerrm,1,3500);
                             END IF;

                             UPDATE INTERFAZ_ORDENES_CMA
                             SET IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                                 ,IOC_FECHA_ENTREGA = SYSDATE
                                 ,IOC_OBSERVACIONES = ' ORDEN S2:'||V_CLOB
                             WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                         END;
                      END IF;



                      IF V_EOC_MNEMONICO = 'ANU' THEN
                         P_ERRORES := 0;
                         P_ORDENES_COMERCIAL.P_ORDEN_ANULAR(P_TIPO_ORDEN => 'C',
                                                            P_ID_ORDEN   => V_ORDENES_COMPRA.OCO_CONSECUTIVO,
                                                            P_FECHA      => SYSDATE,
                                                            P_MOTIVO     => 'ANULADA DESDE S2',
                                                            P_USUARIO    => V_PERSONAS.PER_NOMBRE_USUARIO,
                                                            P_TID_CODIGO => V_PERSONAS.PER_TID_CODIGO,
                                                            P_NUM_IDEN   => V_PERSONAS.PER_NUM_IDEN,
                                                            P_TERMINAL   => 'INTERNET',
                                                            P_ERRORES    => P_ERRORES);
                         IF P_ERRORES = 0 THEN
                            UPDATE INTERFAZ_ORDENES_CMA
                              SET IOC_ESTADO_REGISTRO = 'PROCESADO'
                                 ,IOC_FECHA_ENTREGA = SYSDATE
                            WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                         ELSE
                            V_CLOB := P_CAB.ObtenerCLOB_ERROR ('AnularOrden');
                            UPDATE INTERFAZ_ORDENES_CMA
                              SET IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                                 ,IOC_OBSERVACIONES = ' ANULAR S2:'||V_CLOB
                                 ,IOC_FECHA_ENTREGA = SYSDATE
                            WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                            V_ERRORES := V_ERRORES+1;
                         END IF;
                      END IF;

                      IF V_EOC_MNEMONICO = 'CAN' THEN
                         P_ERRORES := 0;
                         P_ORDENES_COMERCIAL.P_ORDEN_CANCELAR(P_TIPO_ORDEN => 'C',
                                                              P_ID_ORDEN   => V_ORDENES_COMPRA.OCO_CONSECUTIVO,
                                                              P_FECHA      => SYSDATE,
                                                              P_MOTIVO     => 'ANULADA DESDE S2',
                                                              P_USUARIO    => V_PERSONAS.PER_NOMBRE_USUARIO,
                                                              P_TID_CODIGO => V_PERSONAS.PER_TID_CODIGO,
                                                              P_NUM_IDEN   => V_PERSONAS.PER_NUM_IDEN,
                                                              P_TERMINAL   => 'INTERNET',
                                                              P_ERRORES    => P_ERRORES);
                         IF P_ERRORES = 0 THEN
                            UPDATE INTERFAZ_ORDENES_CMA
                              SET IOC_ESTADO_REGISTRO = 'PROCESADO'
                                 ,IOC_FECHA_ENTREGA = SYSDATE
                            WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                         ELSE
                            V_CLOB := P_CAB.ObtenerCLOB_ERROR ('CancelarOrden');
                            UPDATE INTERFAZ_ORDENES_CMA
                              SET IOC_OBSERVACIONES = ' CANCELAR S2:'||V_CLOB
                                 ,IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                                 ,IOC_FECHA_ENTREGA = SYSDATE
                            WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                            V_ERRORES := V_ERRORES+1;
                         END IF;
                      END IF;
                   END IF;

                   IF V_ORDENES_COMPRA.OCO_CONSECUTIVO IS  NULL AND
                       V_EOC_MNEMONICO IN ( 'CAN','ANU') THEN
                      UPDATE INTERFAZ_ORDENES_CMA
                      SET IOC_OBSERVACIONES = ' ORDEN S2 NO CREADA EN COEASY'
                         ,IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                         ,IOC_FECHA_ENTREGA = SYSDATE
                      WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                      V_ERRORES := V_ERRORES+1;
                   END IF;

                END IF;

                IF V_INTERFAZ_CMA.IOC_CLASE_ORDEN = 'V' THEN
                   -- BUSCAR ORDENE DE VENTA POR ID CM,A Y FOLIO CMA
                   V_QUERY_V := 'SELECT OVE_CONSECUTIVO,OVE_BOL_MNEMONICO,OVE_COC_CTO_MNEMONICO '||
                                        ' ,OVE_EOC_MNEMONICO '||
                                ' FROM ORDENES_VENTA '||
                                --' WHERE OVE_FECHA_Y_HORA >= TRUNC(SYSDATE) '||
                                --'   AND OVE_FECHA_Y_HORA < TRUNC(SYSDATE+1) '||
                                '   WHERE OVE_CCC_CLI_PER_NUM_IDEN = '||CHR(39)||V_CUENTA_CCC.CCC_CLI_PER_NUM_IDEN||CHR(39)||
                                '   AND OVE_CCC_CLI_PER_TID_CODIGO = '||CHR(39)||V_CUENTA_CCC.CCC_CLI_PER_TID_CODIGO||CHR(39)||
                                '   AND OVE_CCC_NUMERO_CUENTA = '||V_CUENTA_CCC.CCC_NUMERO_CUENTA||
                                '   AND OVE_CANAL_ORIGEN = '||CHR(39)||'S2'||CHR(39)||
                                --'   AND OVE_EOC_MNEMONICO IN( '||CHR(39)||'PCO'||CHR(39)||','||CHR(39)||'COL'||CHR(39)||')'||
                                '   AND OVE_ENA_MNEMONICO = '||CHR(39)||V_INTERFAZ_CMA.IOC_MNEMOTECNICO||CHR(39)||
                                '   AND OVE_CFC_CUENTA_DECEVAL = '||V_CUENTA_DECEVAL||
                                --'   AND OVE_ID_BOLSA_CMA  = '||CHR(39)||V_INTERFAZ_CMA.IOC_NRO_ORDEN||CHR(39)||
                                '   AND OVE_ID_CMA = '||TO_NUMBER(NVL(TRIM(V_INTERFAZ_CMA.IOC_NRO_INT_ORDEN),'0'),'9999999999');
                   OPEN IO_CURSOR_C_V FOR V_QUERY_V;
                   LOOP
                      FETCH IO_CURSOR_C_V INTO  V_ORDENES_VENTA.OVE_CONSECUTIVO,
                                                V_ORDENES_VENTA.OVE_BOL_MNEMONICO,
                                                V_ORDENES_VENTA.OVE_COC_CTO_MNEMONICO,
                                                V_ORDENES_VENTA.OVE_EOC_MNEMONICO;
                      EXIT WHEN IO_CURSOR_C_V%NOTFOUND;
                   END LOOP;
                   CLOSE IO_CURSOR_C_V;


                   V_EOC_MNEMONICO := NULL;
                   BEGIN
                      IF V_INTERFAZ_CMA.IOC_FEC_CUMPLIMIENTO IS NOT NULL THEN
                         V_FECHA_PERMANENCIA := TO_DATE(REPLACE(TRIM(V_INTERFAZ_CMA.IOC_FEC_CUMPLIMIENTO),'.'),'DD/MM/YYYY HH:MI:SS am');

                         IF TRUNC(V_FECHA_PERMANENCIA) > TRUNC(SYSDATE) THEN
                            V_VIO_MNEMMONICO := 'HFE';
                         ELSE
                            V_FECHA_PERMANENCIA :=  NULL;
                            V_VIO_MNEMMONICO := 'DIA';
                         END IF;
                      ELSE
                        V_FECHA_PERMANENCIA :=  NULL;
                        V_VIO_MNEMMONICO := 'DIA';
                      END IF;
                   END;


                   SELECT DECODE(V_INTERFAZ_CMA.IOC_ESTADO,'P','COL',
                                                           'T','COL',
                                                           'E','COL',
                                                           'C','COL',
                                                           'EC','COL',
                                                           'ANU','ANU',
                                                           'V','ANU',
                                                           'CV','CAN',
                                                           'CX','CAN') INTO V_EOC_MNEMONICO FROM DUAL;


                   IF V_ORDENES_VENTA.OVE_CONSECUTIVO IS NULL AND V_EOC_MNEMONICO ='COL' THEN
                      V_CLOB                  := NULL;
                      V_ID_ORDEN              := NULL;
                      V_IVA_ITENCION          := V_COMISION*V_VALOR_CONS;
                      V_TOTAL_OPERACION_INT   := V_CANTIDAD*V_PRECIO;
                      V_NETO_OPERACION_INT    := V_TOTAL_OPERACION_INT-V_COMISION-V_IVA_ITENCION;

                      V_PORCENTAJE_COMISION   := 0;
                      V_COMISION_ESPECIAL     := 0;
                      V_IND_COMISION_ESPE     := 'N';

                      -- VALIDAR SI EL CLIENTE TIENE COMISION ESPECIAL
                      V_COMISION_ESPECIAL := P_COMERCIAL.CALCULAR_COMISION_BURSATIL(
                                             P_NUM_IDEN           => V_CUENTA_CCC.CCC_CLI_PER_NUM_IDEN,
                                             P_TID_CODIGO         => V_CUENTA_CCC.CCC_CLI_PER_TID_CODIGO,
                                             P_NRO_CUENTA         => V_CUENTA_CCC.CCC_NUMERO_CUENTA,
                                             P_TIPO_PAPEL         => 'ACC',
                                             P_TIPO_NOMINAL_PESOS => NULL,
                                             P_ESPECIE            => NULL,
                                             P_MONTO              => NULL,
                                             P_LLAMADO            => 'EXT');
                      IF NVL(V_COMISION_ESPECIAL,0) != 0 THEN
                         V_PORCENTAJE_COMISION   := V_COMISION_ESPECIAL;
                         V_IND_COMISION_ESPE     := 'S';
                      ELSE
                         V_PORCENTAJE_COMISION   := TRUNC(V_COMISION/(V_CANTIDAD*V_PRECIO),5)*100;
                         V_IND_COMISION_ESPE     := 'N';
                      END IF;


                      BEGIN
                        P_ORDENES_COMERCIAL.P_COLOCAR_ORDEN( P_CLI_TID_CODIGO        => V_CUENTA_CCC.CCC_CLI_PER_TID_CODIGO,
                                                           P_CLI_NUM_IDEN          => V_CUENTA_CCC.CCC_CLI_PER_NUM_IDEN,
                                                           P_USUARIO               => V_PERSONAS.PER_NOMBRE_USUARIO,
                                                           P_CUENTA_CORREDORES     => V_CUENTA_CCC.CCC_NUMERO_CUENTA,
                                                           P_COLOCA_USUARIO        => V_PERSONAS.PER_NOMBRE_USUARIO,
                                                           P_COLOCA_TID_CODIGO     => V_PERSONAS.PER_TID_CODIGO,
                                                           P_COLOCA_NUM_IDEN       => V_PERSONAS.PER_NUM_IDEN,
                                                           P_COLOCA_TERMINAL       => FN_TERMINAL      ,
                                                           P_DUENO_TID_CODIGO      => V_PERSONAS.PER_TID_CODIGO,
                                                           P_DUENO_NUM_IDEN        => V_PERSONAS.PER_NUM_IDEN,
                                                           P_ORDENANTE_TID_CODIGO  => V_CUENTA_CCC.CCC_CLI_PER_TID_CODIGO,
                                                           P_ORDENANTE_NUM_IDEN    => V_CUENTA_CCC.CCC_CLI_PER_NUM_IDEN,
                                                           P_TIPO_ORDEN            => V_INTERFAZ_CMA.IOC_CLASE_ORDEN,
                                                           P_ESPECIE               => V_INTERFAZ_CMA.IOC_MNEMOTECNICO,
                                                           P_CANTIDAD              => V_CANTIDAD,
                                                           P_FECHA_HORA            => TO_CHAR(SYSDATE,'DD-MM-YYYY'),
                                                           P_PORCENTAJE_COMISION   => V_PORCENTAJE_COMISION,
                                                           P_VIG_TIPO_VIGENCIA     => V_VIO_MNEMMONICO,
                                                           P_VIG_FECHA_PERMANENCI  => TO_CHAR(V_FECHA_PERMANENCIA,'DD-MM-YYYY'),
                                                           P_VIG_HORA_PERMANENCIA  => NULL,
                                                           P_COND_PRECIO           => V_COND_PRECIO,
                                                           P_COND_PRECIO_LIMITIE   => V_PRECIO_LIMITE,
                                                           P_COND_CRITERIOS_ADICI  => NULL,
                                                           P_COND_CANTIDAD_MINIMA  => NULL,
                                                           P_VIS_VISIBLE           => NULL,
                                                           P_VIS_PORCENTAJE        => NULL,
                                                           P_STOP_STOP             => NULL,
                                                           P_STOP_PRECIO_STOP      => NULL,
                                                           P_CONSOLIDAR            => 0,
                                                           P_CUENTA_DECEVAL        => NULL,
                                                           P_TITULO_ORIGEN         => 'DA',
                                                           P_TITULO_CTA_DVAL       => V_CUENTA_DECEVAL,
                                                           P_TITULO_COD_FUNGIBLE   => NULL,
                                                           P_TITULO_COD_ISIN       => 0,
                                                           P_INS_REC_MEDIO         => 'INT',
                                                           P_INS_REC_HORA          => TO_CHAR(SYSDATE,'HH24:MI'),
                                                           P_INS_REC_DETALLE       => 'Internet S2',
                                                           P_INS_ENV_FAX           => 0,
                                                           P_INS_ENV_NUM_FAX       => NULL,
                                                           P_INS_ENV_DIRECCION     => 0,
                                                           P_INS_ENV_NUM_DIRECCION => NULL,
                                                           P_INS_ENV_COD_CIUDAD    => NULL,
                                                           P_INS_ENV_CONTACTO      => NULL,
                                                           P_CLI_PROFESIONAL       => 'N',
                                                           P_OPX                   => 'N',
                                                           P_CANTIDAD_INTENCION    => V_CANTIDAD,
                                                           P_PRECIO_INTENCION      => V_PRECIO,
                                                           P_COMISION_INTENCION    => V_COMISION,
                                                           P_IVA_ITENCION          => V_IVA_ITENCION,
                                                           P_TOTAL_OPERACION_INT   => V_TOTAL_OPERACION_INT,
                                                           P_NETO_OPERACION_INT    => V_NETO_OPERACION_INT,
                                                           P_FECHA_RECEPCION       => TO_CHAR(SYSDATE,'DD/MM/YYYY'),
                                                           P_ABONO_CUENTA          => 'S',
                                                           P_VALOR_ABONO_CUENTA    => NULL,
                                                           P_PAGAR_A_PAGO          => NULL,
                                                           P_TIPO_IDEN_PAGO        => NULL,
                                                           P_NUM_IDEN_PAGO         => NULL,
                                                           P_TIPO_CUENTA_PAGO      => NULL,
                                                           P_CODIGO_BANCO_PAGO     => NULL,
                                                           P_NUMERO_CUENTA_PAGO    => NULL,
                                                           P_NOMBRE_CUENTA_PAGO    => NULL,
                                                           P_VALOR_PAGO            => NULL,
                                                           P_CODIGO_INFORMADOR     => NULL,
                                                           P_TID_CODIGO_INFORMADOR => NULL,
                                                           P_NUM_IDEN_INFORMADOR   => NULL,
                                                           P_NOMBRE_INFORMADOR     => NULL,
                                                           P_CODIGO_OFICINA_INFOR  => NULL,
                                                           P_FECHA_PRE_ORDEN_INFOR => NULL,
                                                           P_HORA_PRE_ORDEN_INFOR  => NULL,
                                                           P_ID_ORDEN              => V_ID_ORDEN,
                                                           P_CLOB                  => V_CLOB);


                        EXCEPTION WHEN OTHERS THEN
                          V_ID_ORDEN := NULL;
                          IF V_CLOB IS NULL THEN
                            V_CLOB := substr(sqlerrm,1,3500);
                          END IF;
                          UPDATE INTERFAZ_ORDENES_CMA
                          SET IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                             ,IOC_FECHA_ENTREGA = SYSDATE
                             ,IOC_OBSERVACIONES = ' ORDEN S2:'||V_CLOB
                          WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                      END;
                      IF V_ID_ORDEN IS NOT NULL THEN
                         UPDATE INTERFAZ_ORDENES_CMA
                           SET IOC_ESTADO_REGISTRO = 'PROCESADO'
                             ,IOC_FECHA_ENTREGA = SYSDATE
                         WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;

                         UPDATE ORDENES_VENTA
                           SET OVE_ID_BOLSA_CMA =   V_INTERFAZ_CMA.IOC_NRO_ORDEN
                              ,OVE_ID_CMA = TO_NUMBER(NVL(TRIM(V_INTERFAZ_CMA.IOC_NRO_INT_ORDEN),'0'),'9999999999')
                              ,OVE_COMISION_OMS = V_COMISION
                              ,OVE_ESTADO_BOLSA = DECODE(V_INTERFAZ_CMA.IOC_ESTADO,'E','REG','C','REG','EC','REG',NULL)
                         WHERE  OVE_CONSECUTIVO = V_ID_ORDEN
                           AND OVE_BOL_MNEMONICO = 'COL'
                           AND OVE_COC_CTO_MNEMONICO = 'ACC';


                         -- NOTIFICAR OPERACION S2
                         -- NOTIFICAR ORDENES A DATAIFX
                         IF V_PERSONAS.PER_TIPO = 'PJU' THEN
                            V_NOC_CLI_PER_NUM_IDE := V_CUENTA_CCC.CCC_CLI_PER_NUM_IDEN||'-'||P_CLIENTES.RT_DIGITO_CONTROL(V_CUENTA_CCC.CCC_CLI_PER_NUM_IDEN);
                         ELSE
                            V_NOC_CLI_PER_NUM_IDE := V_CUENTA_CCC.CCC_CLI_PER_NUM_IDEN;
                         END IF;

                         INSERT INTO NOTIFICACIONES_ORDENES_CMA(
                             NOC_CONSECUTIVO
                            ,NOC_FOLIO_BOLSA
                            ,NOC_CLI_PER_NUM_IDEN
                            ,NOC_CLI_PER_TID_CODIGO
                            ,NOC_CUENTA_DECEVAL
                            ,NOC_ID_COEASY
                            ,NOC_TIPO_NEGOCIO
                            ,NOC_PORCENTAJE_COMISION
                            ,NOC_USUARIO_SAE
                            ,NOC_ESPECIAL_FIDUCIARIO
                            ,NOC_CANTIDAD
                            ,NOC_PRECIO
                            ,NOC_ESTADO
                            ,NOC_FECHA_INGRESO
                            ,NOC_FECHA_ENTREGA
                            ,NOC_ENA_MNEMONICO
                            ,NOC_CANAL_ORIGEN
                            ,NOC_PER_NOMBRE_USUARIO
                            ,NOC_PER_NOMBRE
                            ,NOC_PER_APELLIDOS
                            ,NOC_COMISION_ESPECIAL_ETRADE)
                         VALUES(
                             NOC_SEQ.NEXTVAL                                 --NOC_CONSECUTIVO
                            ,V_INTERFAZ_CMA.IOC_NRO_ORDEN                    --NOC_FOLIO_BOLSA
                            ,V_NOC_CLI_PER_NUM_IDE                           --NOC_CLI_PER_NUM_IDEN
                            ,V_CUENTA_CCC.CCC_CLI_PER_TID_CODIGO             --NOC_CLI_PER_TID_CODIGO
                            ,V_CUENTA_DECEVAL                                --NOC_CUENTA_DECEVAL
                            ,V_ID_ORDEN                                      --NOC_ID_COEASY
                            ,'V'                                             --NOC_TIPO_NEGOCIO
                            ,TRUNC(V_PORCENTAJE_COMISION,3)                  --NOC_PORCENTAJE_COMISION
                            ,V_VALOR_SAE_S2                                  --NOC_USUARIO_SAE
                            ,V_CUENTAS_DECEVAL.CUD_ESPECIAL_FIDUCIARIO       --NOC_ESPECIAL_FIDUCIARIO
                            ,V_CANTIDAD                                      --NOC_CANTIDAD
                            ,V_PRECIO                                        --NOC_PRECIO
                            ,'POR_PROCESAR'                                  --NOC_ESTADO
                            ,SYSDATE                                         --NOC_FECHA_INGRESO
                            ,NULL                                            --NOC_FECHA_ENTREGA
                            ,V_INTERFAZ_CMA.IOC_MNEMOTECNICO                 --NOC_ENA_MNEMONICO
                            ,'1'--'S2'                                       --NOC_CANAL_ORIGEN
                            ,V_PERSONAS.PER_NOMBRE_USUARIO                   --NOC_PER_NOMBRE_USUARIO
                            ,DECODE(V_PERSONAS.PER_TIPO,'PJU',
                                    V_PERSONAS.PER_RAZON_SOCIAL,
                                    V_PERSONAS.PER_NOMBRE)                   --NOC_PER_NOMBRE
                            ,DECODE(V_PERSONAS.PER_TIPO,'PJU',' ',
                                    TRIM(V_PERSONAS.PER_PRIMER_APELLIDO)||' '||
                                    TRIM(V_PERSONAS.PER_SEGUNDO_APELLIDO))   --NOC_PER_APELLIDOS)
                            ,V_IND_COMISION_ESPE);
                      END IF;

                      IF V_CLOB IS NOT NULL THEN
                        UPDATE INTERFAZ_ORDENES_CMA
                        SET IOC_OBSERVACIONES = ' ORDEN S2:'||V_CLOB
                            ,IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                            ,IOC_FECHA_ENTREGA = SYSDATE
                        WHERE  IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                        V_ERRORES := V_ERRORES+1;
                      END IF;
                   END IF;

                   IF V_ORDENES_VENTA.OVE_CONSECUTIVO IS NOT NULL THEN
                      IF V_EOC_MNEMONICO = 'COL' THEN
                         BEGIN
                         UPDATE ORDENES_VENTA
                            SET OVE_ID_BOLSA_CMA  = V_INTERFAZ_CMA.IOC_NRO_ORDEN
                               ,OVE_ID_CMA = TO_NUMBER(NVL(TRIM(V_INTERFAZ_CMA.IOC_NRO_INT_ORDEN),'0'),'9999999999')
                               ,OVE_VIO_MNEMONICO = V_VIO_MNEMMONICO
                               ,OVE_FECHA_PERMANENCIA = V_FECHA_PERMANENCIA
                               ,OVE_NOMINAL_O_PESOS = V_CANTIDAD
                               ,OVE_PRECIO_LIMITE_O_MARGEN = DECODE(V_COND_PRECIO,'LIM',V_PRECIO,NULL)
                               ,OVE_ESTADO_BOLSA = DECODE(V_INTERFAZ_CMA.IOC_ESTADO,'E','REG','C','REG','EC','REG',NULL)
                               --,OVE_COMISION = TRUNC(V_COMISION/(V_CANTIDAD*V_PRECIO),5)
                               --,OVE_COMISION_OMS = V_COMISION
                               --,OVE_CANTIDAD_ACC   = V_CANTIDAD
                               ,OVE_PRECIO_ACC = V_PRECIO
                               ,OVE_COMISION_ACC = V_COMISION
                               ,OVE_IVA_ACC  =  V_COMISION*NVL(V_VALOR_CONS,0)
                               --,OVE_TOTAL_OPERACION_ACC = V_CANTIDAD*V_PRECIO
                               --,OVE_NETO_OPERACION_ACC = (V_CANTIDAD*V_PRECIO)-V_COMISION-(V_COMISION*NVL(V_VALOR_CONS,0))
                         WHERE OVE_CONSECUTIVO = V_ORDENES_VENTA.OVE_CONSECUTIVO
                           AND OVE_BOL_MNEMONICO = V_ORDENES_VENTA.OVE_BOL_MNEMONICO
                           AND OVE_COC_CTO_MNEMONICO = V_ORDENES_VENTA.OVE_COC_CTO_MNEMONICO;
                         IF SQL%ROWCOUNT = 0 THEN
                            V_ERRORES := V_ERRORES+1;
                            V_CLOB := P_CAB.ObtenerCLOB_ERROR ('UpdateOrden');
                            UPDATE INTERFAZ_ORDENES_CMA
                            SET IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                               ,IOC_FECHA_ENTREGA = SYSDATE
                               ,IOC_OBSERVACIONES = ' ORDEN S2:'||V_CLOB
                            WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                         ELSE
                            UPDATE NOTIFICACIONES_ORDENES_CMA
                                SET NOC_FOLIO_BOLSA = V_INTERFAZ_CMA.IOC_NRO_ORDEN
                              WHERE NOC_ID_COEASY =   V_ORDENES_VENTA.OVE_CONSECUTIVO
                                AND NOC_TIPO_NEGOCIO  = 'V'
                                AND NOC_ESTADO = 'POR_PROCESAR';

                            UPDATE INTERFAZ_ORDENES_CMA
                               SET IOC_ESTADO_REGISTRO = 'PROCESADO'
                                  ,IOC_FECHA_ENTREGA = SYSDATE
                            WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                         END IF;

                         EXCEPTION WHEN OTHERS THEN
                             V_ID_ORDEN := NULL;
                             V_ERRORES := V_ERRORES+1;
                             V_CLOB := P_CAB.ObtenerCLOB_ERROR ('UpdateOrden');
                             IF V_CLOB IS NULL THEN
                               V_CLOB := substr(sqlerrm,1,3500);
                             END IF;

                             UPDATE INTERFAZ_ORDENES_CMA
                             SET IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                                 ,IOC_FECHA_ENTREGA = SYSDATE
                                 ,IOC_OBSERVACIONES = ' ORDEN S2:'||V_CLOB
                             WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                         END;
                      END IF;

                      IF V_EOC_MNEMONICO = 'ANU' THEN
                         P_ERRORES := 0;
                         P_ORDENES_COMERCIAL.P_ORDEN_ANULAR(P_TIPO_ORDEN => 'V',
                                                            P_ID_ORDEN   => V_ORDENES_VENTA.OVE_CONSECUTIVO,
                                                            P_FECHA      => SYSDATE,
                                                            P_MOTIVO     => 'ANULADA DESDE S2',
                                                            P_USUARIO    => V_PERSONAS.PER_NOMBRE_USUARIO,
                                                            P_TID_CODIGO => V_PERSONAS.PER_TID_CODIGO,
                                                            P_NUM_IDEN   => V_PERSONAS.PER_NUM_IDEN,
                                                            P_TERMINAL   => 'INTERNET',
                                                            P_ERRORES    => P_ERRORES);
                         IF P_ERRORES = 0 THEN
                            UPDATE INTERFAZ_ORDENES_CMA
                              SET IOC_ESTADO_REGISTRO = 'PROCESADO'
                                 ,IOC_FECHA_ENTREGA = SYSDATE
                            WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                         ELSE
                            V_CLOB := P_CAB.ObtenerCLOB_ERROR ('AnularOrden');
                            UPDATE INTERFAZ_ORDENES_CMA
                              SET IOC_OBSERVACIONES = ' ANULAR S2:'||V_CLOB
                                 ,IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                                 ,IOC_FECHA_ENTREGA = SYSDATE
                            WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;

                           V_ERRORES := V_ERRORES+1;
                         END IF;
                      END IF;

                      IF V_EOC_MNEMONICO = 'CAN' THEN
                         P_ERRORES := 0;
                         P_ORDENES_COMERCIAL.P_ORDEN_CANCELAR(P_TIPO_ORDEN => 'V',
                                                              P_ID_ORDEN   => V_ORDENES_VENTA.OVE_CONSECUTIVO,
                                                              P_FECHA      => SYSDATE,
                                                              P_MOTIVO     => 'ANULADA DESDE S2',
                                                              P_USUARIO    => V_PERSONAS.PER_NOMBRE_USUARIO,
                                                              P_TID_CODIGO => V_PERSONAS.PER_TID_CODIGO,
                                                              P_NUM_IDEN   => V_PERSONAS.PER_NUM_IDEN,
                                                              P_TERMINAL   => 'INTERNET',
                                                              P_ERRORES    => P_ERRORES);
                         IF P_ERRORES = 0 THEN
                            UPDATE INTERFAZ_ORDENES_CMA
                              SET IOC_ESTADO_REGISTRO = 'PROCESADO'
                                 ,IOC_FECHA_ENTREGA = SYSDATE
                            WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                         ELSE
                            V_CLOB := P_CAB.ObtenerCLOB_ERROR ('CancelarOrden');
                            UPDATE INTERFAZ_ORDENES_CMA
                              SET IOC_OBSERVACIONES = ' ANULAR S2:'||V_CLOB
                                 ,IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                                 ,IOC_FECHA_ENTREGA = SYSDATE
                            WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;

                            V_ERRORES := V_ERRORES+1;
                         END IF;
                      END IF;
                   END IF;

                   IF V_ORDENES_VENTA.OVE_CONSECUTIVO  IS  NULL AND
                       V_EOC_MNEMONICO IN ( 'CAN','ANU') THEN
                      UPDATE INTERFAZ_ORDENES_CMA
                      SET IOC_OBSERVACIONES = ' ORDEN S2 NO CREADA EN COEASY'
                         ,IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                         ,IOC_FECHA_ENTREGA = SYSDATE
                      WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                      V_ERRORES := V_ERRORES+1;
                   END IF;
                END IF;
             END IF;


             IF V_CUENTA_CCC.CCC_ETRADE_INSTITUCIONAL = 'S' THEN -- ORDENES DE S4

                V_QUERY_CUD         := NULL;
                V_QUERY_ORDENANTE   := NULL;
                V_QUERY_ENA         := NULL;
                IO_CURSOR_CUD       := NULL;
                IO_CURSOR_ORDENANTE := NULL;
                IO_CURSOR_ENA       := NULL;
                V_CUENTAS_DECEVAL   := NULL;
                V_EOC_MNEMONICO     := NULL;
                V_ORDENANTES_INST   := NULL;
                V_ESPECIES          := NULL;




                /* ORDENANTES ETRADE INSTITUCIONAL*/
                V_QUERY_ORDENANTE := 'SELECT RLC1.RLC_PER_NUM_IDEN '||
                                    ' ,RLC1.RLC_PER_TID_CODIGO '||
                                    ' ,RLC1.RLC_ROL_CODIGO '||
                                    ' FROM  PERSONAS_RELACIONADAS RLC1 '||
                                    ' WHERE  RLC1.RLC_CLI_PER_NUM_IDEN ='||CHR(39)||V_CUENTA_CCC.CCC_CLI_PER_NUM_IDEN||CHR(39)||
                                    ' AND    RLC1.RLC_CLI_PER_TID_CODIGO = '||CHR(39)||V_CUENTA_CCC.CCC_CLI_PER_TID_CODIGO||CHR(39)||
                                    ' AND    NVL(RLC1.RLC_ETRADE_INSTITUCIONAL,''N'') = ''S'' '||
                                    ' AND    RLC1.RLC_ROL_CODIGO IN (1,6,7) '||
                                    ' AND    RLC1.RLC_ESTADO = ''A''';

                OPEN IO_CURSOR_ORDENANTE FOR V_QUERY_ORDENANTE;
                LOOP
                   FETCH IO_CURSOR_ORDENANTE INTO  V_ORDENANTES_INST.RLC_PER_NUM_IDEN,
                                                   V_ORDENANTES_INST.RLC_PER_TID_CODIGO,
                                                   V_ORDENANTES_INST.RLC_ROL_CODIGO;
                   EXIT WHEN IO_CURSOR_ORDENANTE%NOTFOUND;
                END LOOP;
                CLOSE IO_CURSOR_ORDENANTE;

                IF V_ORDENANTES_INST.RLC_PER_NUM_IDEN IS NULL THEN
                   UPDATE INTERFAZ_ORDENES_CMA
                   SET IOC_OBSERVACIONES = IOC_OBSERVACIONES ||' ORDENANTE NO EXISTE'
                      ,IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                      ,IOC_FECHA_ENTREGA = SYSDATE
                   WHERE  IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                   V_ERRORES := V_ERRORES+1;
                END IF;

                V_QUERY_ENA := 'SELECT ENA_GNA_MNEMONICO '||
                              ' ,ENA_EMI_MNEMONICO '||
                              ' FROM   ESPECIES_NACIONALES '||
                              ' WHERE  ENA_MNEMONICO = '||CHR(39)||V_INTERFAZ_CMA.IOC_MNEMOTECNICO||CHR(39);


                OPEN IO_CURSOR_ENA FOR V_QUERY_ENA;
                LOOP
                   FETCH IO_CURSOR_ENA INTO  V_ESPECIES.ENA_GNA_MNEMONICO
                                            ,V_ESPECIES.ENA_EMI_MNEMONICO;
                   EXIT WHEN IO_CURSOR_ENA%NOTFOUND;
                END LOOP;
                CLOSE IO_CURSOR_ENA;

                IF V_ESPECIES.ENA_EMI_MNEMONICO IS NULL THEN
                   UPDATE INTERFAZ_ORDENES_CMA
                   SET IOC_OBSERVACIONES = IOC_OBSERVACIONES ||' EMISOR NO EXISTE'
                      ,IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                      ,IOC_FECHA_ENTREGA = SYSDATE
                   WHERE  IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                   V_ERRORES := V_ERRORES+1;
                END IF;

                SELECT DECODE(V_INTERFAZ_CMA.IOC_ESTADO,'P','COL',
                                                        'T','COL',
                                                        'E','COL',
                                                        'C','COL',
                                                        'EC','COL',
                                                        'ANU','ANU',
                                                        'V','ANU',
                                                        'CV','CAN',
                                                        'CX','CAN') INTO V_EOC_MNEMONICO FROM DUAL;



                BEGIN
                   V_CANTIDAD := TO_NUMBER(NVL(TRIM(REPLACE(V_INTERFAZ_CMA.IOC_CANTIDAD,',','.')),'0'),'999999999.00');
                   EXCEPTION WHEN OTHERS THEN
                   UPDATE INTERFAZ_ORDENES_CMA
                     SET IOC_OBSERVACIONES = 'CANTIDAD ERROR'
                        ,IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                        ,IOC_FECHA_ENTREGA = SYSDATE
                    WHERE  IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                    V_ERRORES := V_ERRORES+1;
                END;


                BEGIN
                   V_COMISION := TO_NUMBER(NVL(TRIM(REPLACE(V_INTERFAZ_CMA.IOC_COMISION,',','.')),'0'),'9999999999.9999999999');
                   EXCEPTION WHEN OTHERS THEN
                     UPDATE INTERFAZ_ORDENES_CMA
                        SET IOC_OBSERVACIONES = IOC_OBSERVACIONES ||' COMISION ERROR'
                           ,IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                           ,IOC_FECHA_ENTREGA = SYSDATE
                     WHERE  IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                     V_ERRORES := V_ERRORES+1;
                END;



                BEGIN
                   V_PRECIO := TO_NUMBER(NVL(TRIM(REPLACE(V_INTERFAZ_CMA.IOC_PREC_REGISTRO,',','.')),'0'),'999999999999.9999');
                   EXCEPTION WHEN OTHERS THEN
                     UPDATE INTERFAZ_ORDENES_CMA
                        SET IOC_OBSERVACIONES = IOC_OBSERVACIONES ||' PRECIO ERROR'
                           ,IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                           ,IOC_FECHA_ENTREGA = SYSDATE
                     WHERE  IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                     V_ERRORES := V_ERRORES+1;
                END;

                BEGIN
                   IF V_INTERFAZ_CMA.IOC_FEC_CUMPLIMIENTO IS NOT NULL THEN
                     V_FECHA_PERMANENCIA := TO_DATE(REPLACE(TRIM(V_INTERFAZ_CMA.IOC_FEC_CUMPLIMIENTO),'.'),'DD/MM/YYYY HH:MI:SS am');

                     IF TRUNC(V_FECHA_PERMANENCIA) > TRUNC(SYSDATE) THEN
                        V_VIO_MNEMMONICO := 'HFE';
                     ELSE
                        V_FECHA_PERMANENCIA :=  NULL;
                        V_VIO_MNEMMONICO := 'DIA';
                     END IF;
                   ELSE
                     V_FECHA_PERMANENCIA :=  NULL;
                     V_VIO_MNEMMONICO := 'DIA';
                   END IF;
                END;


                SELECT DECODE(V_INTERFAZ_CMA.IOC_TIPO_ORDEN,'LIM','LIM','MKT','MER') INTO V_COND_PRECIO  FROM DUAL;

                IF V_COND_PRECIO = 'LIM' THEN
                   V_PRECIO_LIMITE := V_PRECIO;
                ELSE
                   V_PRECIO_LIMITE := NULL;
                END IF;

                BEGIN
                  V_CUENTA_DECEVAL := TO_NUMBER(NVL(TRIM(V_INTERFAZ_CMA.IOC_CTA_DECEVAL),'0'),'99999999');
                  EXCEPTION WHEN OTHERS THEN
                  UPDATE INTERFAZ_ORDENES_CMA
                     SET IOC_OBSERVACIONES = IOC_OBSERVACIONES ||' DCVAL ERROR'
                        ,IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                        ,IOC_FECHA_ENTREGA = SYSDATE
                  WHERE  IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                  V_ERRORES := V_ERRORES+1;
                END;


                IF V_INTERFAZ_CMA.IOC_CLASE_ORDEN = 'C' THEN
                   V_TITULO_ORIGEN    := NULL;
                   V_TITULO_CTA_DVAL  := NULL;

                   V_IVA_ITENCION          := V_COMISION*V_VALOR_CONS;
                   V_TOTAL_OPERACION_INT   := V_CANTIDAD*V_PRECIO;
                   V_NETO_OPERACION_INT    := V_TOTAL_OPERACION_INT+V_COMISION+V_IVA_ITENCION;
                   V_CUENTA_DECEVAL_COM    := V_CUENTA_DECEVAL;

                ELSE
                   V_TITULO_ORIGEN       := 'NP';
                   V_TITULO_CTA_DVAL     := V_CUENTA_DECEVAL;
                   V_CUENTA_DECEVAL_COM  := NULL;

                   V_IVA_ITENCION          := V_COMISION*V_VALOR_CONS;
                   V_TOTAL_OPERACION_INT   := V_CANTIDAD*V_PRECIO;
                   V_NETO_OPERACION_INT    := V_TOTAL_OPERACION_INT-V_COMISION-V_IVA_ITENCION;
                END IF;


                -- OBTENER ESPECIAL FIDUCIARIO
                V_QUERY_CUD := 'SELECT CUD_CUENTA_DECEVAL,CUD_ESPECIAL_FIDUCIARIO FROM CUENTAS_DECEVAL'||
                               ' WHERE CUD_CLI_PER_NUM_IDEN = '||CHR(39)||V_CUENTA_CCC.CCC_CLI_PER_NUM_IDEN||CHR(39)||
                               ' AND CUD_CLI_PER_TID_CODIGO = '||CHR(39)||V_CUENTA_CCC.CCC_CLI_PER_TID_CODIGO||CHR(39)||
                               ' AND CUD_ESTADO = ''A'' '||
                               ' AND CUD_CUENTA_DECEVAL = '||V_CUENTA_DECEVAL;

                OPEN IO_CURSOR_CUD FOR V_QUERY_CUD;
                LOOP
                   FETCH IO_CURSOR_CUD INTO  V_CUENTAS_DECEVAL.CUD_CUENTA_DECEVAL,
                                             V_CUENTAS_DECEVAL.CUD_ESPECIAL_FIDUCIARIO;
                   EXIT WHEN IO_CURSOR_CUD%NOTFOUND;
                END LOOP;
                CLOSE IO_CURSOR_CUD;

                IF V_CUENTAS_DECEVAL.CUD_CUENTA_DECEVAL IS NULL THEN
                   UPDATE INTERFAZ_ORDENES_CMA
                   SET IOC_OBSERVACIONES = IOC_OBSERVACIONES ||' DCVAL NO EXISTE'
                      ,IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                      ,IOC_FECHA_ENTREGA = SYSDATE
                   WHERE  IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                   V_ERRORES := V_ERRORES+1;
                END IF;


                IF V_CANTIDAD > 0  AND
                   V_COMISION > 0 AND
                   V_PRECIO > 0 AND
                   V_CUENTA_DECEVAL > 0 AND
                   V_ORDENANTES_INST.RLC_PER_NUM_IDEN IS NOT NULL
                   AND V_ERRORES = 0 THEN

                  -- DETERMINAR ORDENDE COMRPA O VENTA
                  IF V_INTERFAZ_CMA.IOC_CLASE_ORDEN = 'C' THEN
                     V_QUERY_C := 'SELECT OCO_CONSECUTIVO,OCO_BOL_MNEMONICO,OCO_COC_CTO_MNEMONICO '||
                                          ' ,OCO_EOC_MNEMONICO '||
                                  ' FROM ORDENES_COMPRA '||
                                  --' WHERE OCO_FECHA_Y_HORA >= TRUNC(SYSDATE) '||
                                  --'   AND OCO_FECHA_Y_HORA < TRUNC(SYSDATE+1) '||
                                  '   WHERE OCO_CCC_CLI_PER_NUM_IDEN = '||CHR(39)||V_CUENTA_CCC.CCC_CLI_PER_NUM_IDEN||CHR(39)||
                                  '   AND OCO_CCC_CLI_PER_TID_CODIGO = '||CHR(39)||V_CUENTA_CCC.CCC_CLI_PER_TID_CODIGO||CHR(39)||
                                  '   AND OCO_CCC_NUMERO_CUENTA = '||V_CUENTA_CCC.CCC_NUMERO_CUENTA||
                                  '   AND OCO_CANAL_ORIGEN = '||CHR(39)||'S4'||CHR(39)||
                                  --'   AND OCO_EOC_MNEMONICO IN( '||CHR(39)||'COL'||CHR(39)||')'||
                                  '   AND OCO_ENA_MNEMONICO = '||CHR(39)||V_INTERFAZ_CMA.IOC_MNEMOTECNICO||CHR(39)||
                                  '   AND OCO_CUD_CUENTA_DECEVAL = '||V_CUENTA_DECEVAL||
                                  --'   AND OCO_CONDICION_PRECIO = '||CHR(39)||V_COND_PRECIO||CHR(39)||
                                  --'   AND OCO_NOMINAL_O_PESOS <= '||V_CANTIDAD||
                                  --'   AND OCO_ID_BOLSA_CMA = '||CHR(39)||V_INTERFAZ_CMA.IOC_NRO_ORDEN||CHR(39)||
                                  '   AND OCO_ID_CMA = '||TO_NUMBER(NVL(TRIM(V_INTERFAZ_CMA.IOC_NRO_INT_ORDEN),'0'),'9999999999')||
                                  '   ORDER BY OCO_CONSECUTIVO ASC';
                     OPEN IO_CURSOR_C_V FOR V_QUERY_C;
                     LOOP
                        FETCH IO_CURSOR_C_V INTO  V_ORDENES_COMPRA.OCO_CONSECUTIVO,
                                                  V_ORDENES_COMPRA.OCO_BOL_MNEMONICO,
                                                  V_ORDENES_COMPRA.OCO_COC_CTO_MNEMONICO,
                                                  V_ORDENES_COMPRA.OCO_EOC_MNEMONICO;
                        EXIT WHEN IO_CURSOR_C_V%NOTFOUND;
                     END LOOP;
                     CLOSE IO_CURSOR_C_V;
                  END IF;


                  IF V_INTERFAZ_CMA.IOC_CLASE_ORDEN = 'V' THEN
                     V_QUERY_V := 'SELECT OVE_CONSECUTIVO,OVE_BOL_MNEMONICO,OVE_COC_CTO_MNEMONICO '||
                                        ' ,OVE_EOC_MNEMONICO '||
                                ' FROM ORDENES_VENTA '||
                                --' WHERE OVE_FECHA_Y_HORA >= TRUNC(SYSDATE) '||
                                --'   AND OVE_FECHA_Y_HORA < TRUNC(SYSDATE+1) '||
                                '   WHERE OVE_CCC_CLI_PER_NUM_IDEN = '||CHR(39)||V_CUENTA_CCC.CCC_CLI_PER_NUM_IDEN||CHR(39)||
                                '   AND OVE_CCC_CLI_PER_TID_CODIGO = '||CHR(39)||V_CUENTA_CCC.CCC_CLI_PER_TID_CODIGO||CHR(39)||
                                '   AND OVE_CCC_NUMERO_CUENTA = '||V_CUENTA_CCC.CCC_NUMERO_CUENTA||
                                '   AND OVE_CANAL_ORIGEN = '||CHR(39)||'S4'||CHR(39)||
                                --'   AND OVE_EOC_MNEMONICO IN( '||CHR(39)||'COL'||CHR(39)||')'||
                                '   AND OVE_ENA_MNEMONICO = '||CHR(39)||V_INTERFAZ_CMA.IOC_MNEMOTECNICO||CHR(39)||
                                '   AND OVE_CFC_CUENTA_DECEVAL = '||V_CUENTA_DECEVAL||
                                --'   AND OVE_CONDICION_PRECIO = '||CHR(39)||V_COND_PRECIO||CHR(39)||
                                --'   AND OVE_NOMINAL_O_PESOS <= '||V_CANTIDAD||
                               -- '   AND OVE_ID_BOLSA_CMA = '||CHR(39)||V_INTERFAZ_CMA.IOC_NRO_ORDEN||CHR(39)||
                                '   AND OVE_ID_CMA = '||TO_NUMBER(NVL(TRIM(V_INTERFAZ_CMA.IOC_NRO_INT_ORDEN),'0'),'9999999999')||
                                '   ORDER BY OVE_CONSECUTIVO ASC';
                     OPEN IO_CURSOR_C_V FOR V_QUERY_V;
                     LOOP
                        FETCH IO_CURSOR_C_V INTO  V_ORDENES_VENTA.OVE_CONSECUTIVO,
                                                V_ORDENES_VENTA.OVE_BOL_MNEMONICO,
                                                V_ORDENES_VENTA.OVE_COC_CTO_MNEMONICO,
                                                V_ORDENES_VENTA.OVE_EOC_MNEMONICO;
                        EXIT WHEN IO_CURSOR_C_V%NOTFOUND;
                     END LOOP;
                     CLOSE IO_CURSOR_C_V;
                  END IF;

                  IF V_EOC_MNEMONICO = 'COL' THEN
                    IF ((V_INTERFAZ_CMA.IOC_CLASE_ORDEN = 'C' AND NVL(V_ORDENES_COMPRA.OCO_CONSECUTIVO,0) = 0) OR
                       (V_INTERFAZ_CMA.IOC_CLASE_ORDEN = 'V' AND NVL(V_ORDENES_VENTA.OVE_CONSECUTIVO,0) = 0)) THEN
                        V_CLOB := NULL;
                        V_ID_ORDEN := NULL;


                        IF V_INTERFAZ_CMA.IOC_CLASE_ORDEN = 'C' THEN
                           SELECT COR_SEQ.NEXTVAL INTO V_ID_ORDEN FROM DUAL;
                           INSERT INTO CONSECUTIVO_ORDENES
                              (COR_CONSECUTIVO
                              ,COR_CLASE
                              ,COR_BOLSA)
                           VALUES
                             (V_ID_ORDEN
                             ,'ACC'
                             ,'COL');
                           BEGIN
                           INSERT INTO ORDENES_COMPRA
                             (  OCO_CONSECUTIVO
                              , OCO_BOL_MNEMONICO
                              , OCO_COC_CTO_MNEMONICO
                              , OCO_COC_CCO_MNEMONICO
                              , OCO_COC_CTE_MNEMONICO
                              , OCO_TOC_MNEMONICO
                              , OCO_CNE_MNEMONICO
                              , OCO_EOC_MNEMONICO
                              , OCO_VIO_MNEMONICO
                              , OCO_CCC_CLI_PER_NUM_IDEN
                              , OCO_CCC_CLI_PER_TID_CODIGO
                              , OCO_CCC_NUMERO_CUENTA
                              , OCO_PER_NUM_IDEN
                              , OCO_PER_TID_CODIGO
                              , OCO_RLC_PER_NUM_IDEN
                              , OCO_RLC_PER_TID_CODIGO
                              , OCO_RLC_ROL_CODIGO
                              , OCO_LTI_MNEMONICO
                              , OCO_GNA_MNEMONICO
                              , OCO_FECHA_Y_HORA
                              , OCO_FECHA_CRONOLOGICA
                              , OCO_NOMINAL_O_PESOS
                              , OCO_TIPO_NOMINAL_O_PESOS
                              , OCO_OPERACION_TOTAL
                              , OCO_EJECUTA_ORDEN_MESA
                              , OCO_DINERO_CONTRA_TITULOS
                              , OCO_ENVIAR_FAX_FACTURA
                              , OCO_ENVIAR_FACTURA
                              , OCO_ENVIAR_CARTA_COMPROMISO
                              , OCO_ENVIAR_CARTA_CARRU_PLAZO
                              , OCO_ENVIAR_RECIBO_CUSTODIA
                              , OCO_COBRAR_CHEQUE
                              , OCO_COBRAR_CHEQUE_GERENCIA
                              , OCO_RECOGER_CHEQUE
                              , OCO_COBRAR_SALDO_CUENTA
                              , OCO_COBRAR_TRANSFERENCIA_BANCA
                              , OCO_COBRAR_SEBRA
                              , OCO_COBRAR_CONSIGNA
                              , OCO_COBRAR_REDENCION
                              , OCO_COBRAR_FONDOS_VALORES
                              , OCO_ENA_MNEMONICO
                              , OCO_EMI_MNEMONICO
                              , OCO_FECHA_MODIFICACION
                              , OCO_PRECIO_LIMITE_O_MARGEN
                              , OCO_COMISION
                              , OCO_NUMERO_FAX
                              , OCO_DIRECCION_DOCUMENTOS
                              , OCO_PREGUNTAR_POR_DOCUMENTOS
                              , OCO_VERIFICADO_COMERCIAL
                              , OCO_TERMINAL_VERIFICA
                              , OCO_PER_NUM_IDEN_ES_DUENO
                              , OCO_PER_TID_CODIGO_ES_DUENO
                              , OCO_FECHA_VERIFICA
                              , OCO_COBRAR_EFECTIVO
                              , OCO_MEDIO_RECEPCION
                              , OCO_DETALLE_MEDIO_RECEPCION
                              , OCO_HORA_RECEPCION
                              , OCO_TIPO_MEC
                              , OCO_PROFESIONAL
                              , OCO_LEO_CONSECUTIVO
                              , OCO_ORDEN_NEGOCIO
                              , OCO_CONDICION_PRECIO
                              , OCO_CRITERIOS_ADICIONALES
                              , OCO_CANTIDAD_MINIMA
                              , OCO_VISIBLE
                              , OCO_PORCENTAJE_VISIBLE
                              , OCO_STOP
                              , OCO_PRECIO_STOP
                              , OCO_PERMITE_AGRUPAMIENTO
                              , OCO_FECHA_PERMANENCIA
                              , OCO_HORA_DURACION
                              , OCO_CUD_CUENTA_DECEVAL
                              , OCO_AGE_CODIGO_ENVIA_DOCUMENTO
                              , OCO_CANTIDAD_ACC
                              , OCO_PRECIO_ACC
                              , OCO_COMISION_ACC
                              , OCO_IVA_ACC
                              , OCO_TOTAL_OPERACION_ACC
                              , OCO_NETO_OPERACION_ACC
                              , OCO_PER_TID_ENRUTA
                              , OCO_PER_NUM_ENRUTA
                              , OCO_CANAL_ORIGEN
                              , OCO_FECHA_RECEPCION
                           ) VALUES
                             (  V_ID_ORDEN                                                          --OCO_CONSECUTIVO
                              , 'COL'                                                               --OCO_BOL_MNEMONICO
                              , 'ACC'                                                               --OCO_COC_CTO_MNEMONICO
                              , 'ORD'                                                               --OCO_COC_CCO_MNEMONICO
                              , 'NA'                                                                --OCO_COC_CTE_MNEMONICO
                              , 'MER'                                                               --OCO_TOC_MNEMONICO
                              , 'CON'                                                               --OCO_CNE_MNEMONICO
                              , 'COL'                                                               --OCO_EOC_MNEMONICO
                              , V_VIO_MNEMMONICO                                                    --OCO_VIO_MNEMONICO
                              , V_CUENTA_CCC.CCC_CLI_PER_NUM_IDEN                                   --OCO_CCC_CLI_PER_NUM_IDEN
                              , V_CUENTA_CCC.CCC_CLI_PER_TID_CODIGO                                 --OCO_CCC_CLI_PER_TID_CODIGO
                              , V_CUENTA_CCC.CCC_NUMERO_CUENTA                                      --OCO_CCC_NUMERO_CUENTA
                              , V_PERSONAS.PER_NUM_IDEN                                             --OCO_PER_NUM_IDEN
                              , V_PERSONAS.PER_TID_CODIGO                                           --OCO_PER_TID_CODIGO
                              , V_ORDENANTES_INST.RLC_PER_NUM_IDEN                                  --OCO_RLC_PER_NUM_IDEN
                              , V_ORDENANTES_INST.RLC_PER_TID_CODIGO                                --OCO_RLC_PER_TID_CODIGO
                              , V_ORDENANTES_INST.RLC_ROL_CODIGO                                    --OCO_RLC_ROL_CODIGO
                              , 'DA'                                                                --OCO_LTI_MNEMONICO
                              , V_ESPECIES.ENA_GNA_MNEMONICO                                        --OCO_GNA_MNEMONICO,
                              , SYSDATE                                                             --OCO_FECHA_Y_HORA
                              , SYSDATE                                                             --OCO_FECHA_CRONOLOGICA
                              , V_CANTIDAD                                                          --OCO_NOMINAL_O_PESOS
                              , 'N'                                                                 --OCO_TIPO_NOMINAL_O_PESOS
                              , 'N'                                                                 -- OCO_OPERACION_TOTAL
                              , V_PERSONAS.PER_EJECUTA_ORDEN_MESA                                   --OCO_EJECUTA_ORDEN_MESA
                              , 'N'                                                                 --OCO_DINERO_CONTRA_TITULOS
                              , 'N'                                                                 --OCO_ENVIAR_FAX_FACTURA
                              , 'N'                                                                 --OCO_ENVIAR_FACTURA
                              , 'N'                                                                 --OCO_ENVIAR_CARTA_COMPROMISO
                              , 'N'                                                                 --OCO_ENVIAR_CARTA_CARRU_PLAZO
                              , 'N'                                                                 --OCO_ENVIAR_RECIBO_CUSTODIA
                              , 'N'                                                                  --OCO_COBRAR_CHEQUE
                              , 'N'                                                                 --OCO_COBRAR_CHEQUE_GERENCIA
                              , 'N'                                                                 --OCO_RECOGER_CHEQUE
                              , 'S'                                                                 --OCO_COBRAR_SALDO_CUENTA
                              , 'N'                                                                 --OCO_COBRAR_TRANSFERENCIA_BANCA
                              , 'N'                                                                 --OCO_COBRAR_SEBRA
                              , 'N'                                                                 --OCO_COBRAR_CONSIGNA
                              , 'N'                                                                 --OCO_COBRAR_REDENCION
                              , 'N'                                                                 --OCO_COBRAR_FONDOS_VALORES
                              , V_INTERFAZ_CMA.IOC_MNEMOTECNICO                                     --OCO_ENA_MNEMONICO
                              , V_ESPECIES.ENA_EMI_MNEMONICO                                        --OCO_EMI_MNEMONICO
                              , SYSDATE--TO_DATE(P_FECHA_HORA,'DD-MM-YYYY HH24:MI:SS')              --OCO_FECHA_MODIFICACION
                              , V_PRECIO_LIMITE                                                     --OCO_PRECIO_LIMITE_O_MARGEN
                              , TRUNC(V_COMISION/(V_CANTIDAD*V_PRECIO),5)*100                       --OCO_COMISION
                              , NULL                                                                --OCO_NUMERO_FAX
                              , NULL                                                                --OCO_DIRECCION_DOCUMENTOS
                              , NULL                                                                --OCO_PREGUNTAR_POR_DOCUMENTOS
                              , 'S'                                                                 --OCO_VERIFICADO_COMERCIAL
                              , DECODE(V_PERSONAS.PER_TIPO_COMERCIAL,'C',FN_TERMINAL,
                                                                      'P',FN_TERMINAL,
                                                                       NULL)                         --OCO_TERMINAL_VERIFICA
                              , V_PERSONAS.PER_NUM_IDEN                                              --OCO_PER_NUM_IDEN_ES_DUENO
                              , V_PERSONAS.PER_TID_CODIGO                                            --OCO_PER_TID_CODIGO_ES_DUENO
                              , DECODE(V_PERSONAS.PER_TIPO_COMERCIAL,'C',TO_DATE(SYSDATE,'DD-MM-YYYY HH24:MI:SS'),
                                                                      'P',TO_DATE(SYSDATE,'DD-MM-YYYY HH24:MI:SS'),
                                                                       NULL)                         --OCO_FECHA_VERIFICA
                              , 'N'                                                                  --OCO_COBRAR_EFECTIVO
                              , 'INT'                                                                 --OCO_MEDIO_RECEPCION
                              , 'Internet S4'                                                         --OCO_DETALLE_MEDIO_RECEPCION
                              , TO_CHAR(SYSDATE,'HH24:MI')                                            --OCO_HORA_RECEPCION
                              , 'MT'                                                                  --OCO_TIPO_MEC
                              , 'S'                                                                   --OCO_PROFESIONAL
                              , 5                                                                     --OCO_LEO_CONSECUTIVO
                              , 'O'                                                                   --OCO_ORDEN_NEGOCIO
                              , V_COND_PRECIO                                                         --OCO_CONDICION_PRECIO
                              , NULL                                                                  --OCO_CRITERIOS_ADICIONALES
                              , NULL                                                                  --OCO_CANTIDAD_MINIMA
                              , NULL                                                                  --OCO_VISIBLE
                              , NULL                                                                  --OCO_PORCENTAJE_VISIBLE
                              , NULL                                                                  --OCO_STOP
                              , NULL                                                                  --OCO_PRECIO_STOP
                              , 'N'                                                                   --OCO_PERMITE_AGRUPAMIENTO
                              , V_FECHA_PERMANENCIA                                                   --OCO_FECHA_PERMANENCIA
                              , NULL                                                                  --OCO_HORA_DURACION
                              , V_CUENTA_DECEVAL                                                      --OCO_CUD_CUENTA_DECEVAL
                              , NULL                                                                  --OCO_AGE_CODIGO_ENVIA_DOCUMENTO
                              , NVL(V_CANTIDAD,0)                                                     --OCO_CANTIDAD_ACC
                              , NVL(V_PRECIO,0)                                                       --OCO_PRECIO_ACC
                              , NVL(V_COMISION,0)                                                     --OCO_COMISION_ACC
                              , NVL(V_IVA_ITENCION,0)                                                 --OCO_IVA_ACC
                              , NVL(V_TOTAL_OPERACION_INT,0)                                          --OCO_TOTAL_OPERACION_ACC
                              , NVL(V_NETO_OPERACION_INT,0)                                           --OCO_NETO_OPERACION_ACC
                              , NULL                                                                  --OCO_PER_TID_ENRUTA
                              , NULL                                                                  --OCO_PER_NUM_ENRUTA
                              , 'S4'                                                                  --OCO_CANAL_ORIGEN
                              , SYSDATE                                                               --OCO_FECHA_RECEPCION
                              );
                           IF SQL%ROWCOUNT = 0 THEN
                             V_ID_ORDEN := NULL;
                             V_CLOB := P_CAB.ObtenerCLOB_ERROR('ColocarOrden') ;
                             IF V_CLOB IS NULL THEN
                               V_CLOB := substr(sqlerrm,1,3500);
                             END IF;
                             UPDATE INTERFAZ_ORDENES_CMA
                               SET IOC_OBSERVACIONES = ' ORDEN S4:'||V_CLOB
                                  ,IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                                  ,IOC_FECHA_ENTREGA = SYSDATE
                               WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                           END IF;
                            EXCEPTION WHEN OTHERS THEN
                               V_ID_ORDEN := NULL;
                               V_CLOB := P_CAB.ObtenerCLOB_ERROR('ColocarOrden') ;
                               IF V_CLOB IS NULL THEN
                                 V_CLOB := substr(sqlerrm,1,3500);
                               END IF;
                               UPDATE INTERFAZ_ORDENES_CMA
                               SET IOC_OBSERVACIONES = ' ORDEN S4:'||V_CLOB
                                  ,IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                                  ,IOC_FECHA_ENTREGA = SYSDATE
                               WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                           END;
                        END IF;


                        IF V_INTERFAZ_CMA.IOC_CLASE_ORDEN = 'V' THEN
                           /* CREACION DE LA ORDEN DE VENTA*/
                           SELECT COR_SEQ.NEXTVAL INTO V_ID_ORDEN FROM DUAL;
                           INSERT INTO CONSECUTIVO_ORDENES
                             (COR_CONSECUTIVO
                             ,COR_CLASE
                             ,COR_BOLSA)
                           VALUES
                             (V_ID_ORDEN
                             ,'ACC'
                             ,'COL');
                           BEGIN
                           INSERT INTO ORDENES_VENTA
                             ( OVE_CONSECUTIVO
                              ,OVE_BOL_MNEMONICO
                              ,OVE_COC_CTO_MNEMONICO
                              ,OVE_COC_CCO_MNEMONICO
                              ,OVE_COC_CTE_MNEMONICO
                              ,OVE_PER_NUM_IDEN
                              ,OVE_PER_TID_CODIGO
                              ,OVE_CCC_CLI_PER_TID_CODIGO
                              ,OVE_CCC_CLI_PER_NUM_IDEN
                              ,OVE_CCC_NUMERO_CUENTA
                              ,OVE_RLC_PER_NUM_IDEN
                              ,OVE_RLC_PER_TID_CODIGO
                              ,OVE_RLC_ROL_CODIGO
                              ,OVE_VIO_MNEMONICO
                              ,OVE_CNE_MNEMONICO
                              ,OVE_TOC_MNEMONICO
                              ,OVE_EOC_MNEMONICO
                              ,OVE_ENA_MNEMONICO
                              ,OVE_LTI_MNEMONICO
                              ,OVE_FECHA_Y_HORA
                              ,OVE_FECHA_CRONOLOGICA
                              ,OVE_NOMINAL_O_PESOS
                              ,OVE_TIPO_NOMINAL_O_PESOS
                              ,OVE_OPERACION_TOTAL
                              ,OVE_EJECUTA_ORDEN_MESA
                              ,OVE_GIRAR
                              ,OVE_ABONO_CUENTA
                              ,OVE_ENVIAR_FAX_FACTURA
                              ,OVE_ENVIAR_FACTURA
                              ,OVE_DINERO_CONTRA_TITULOS
                              ,OVE_RECOGER_CARTA
                              ,OVE_RECOGER_CERT_CAMARA
                              ,OVE_ORIGEN_FUNGIBLE
                              ,OVE_FECHA_MODIFICACION
                              ,OVE_PRECIO_LIMITE_O_MARGEN
                              ,OVE_COMISION
                              ,OVE_TIPO_PAGO_ABONO_CUENTA
                              ,OVE_NUMERO_FAX
                              ,OVE_AGE_CODIGO_ENVIA_DOCUMENTO
                              ,OVE_DIRECCION_DOCUMENTOS
                              ,OVE_PREGUNTAR_POR_DOCUMENTOS
                              ,OVE_CFC_CUENTA_DECEVAL
                              ,OVE_CFC_FUG_ISI_MNEMONICO
                              ,OVE_CFC_FUG_MNEMONICO
                              ,OVE_FECHA_VERIFICA
                              ,OVE_TERMINAL_VERIFICA
                              ,OVE_PER_NUM_IDEN_ES_DUENO
                              ,OVE_PER_TID_CODIGO_ES_DUENO
                              ,OVE_VERIFICADO_COMERCIAL
                              ,OVE_FECHA_PERMANENCIA
                              ,OVE_MEDIO_RECEPCION
                              ,OVE_DETALLE_MEDIO_RECEPCION
                              ,OVE_HORA_RECEPCION
                              ,OVE_TIPO_MEC
                              ,OVE_PROFESIONAL
                              ,OVE_PER_NUM_IDEN_CTA
                              ,OVE_PER_TID_CODIGO_CTA
                              ,OVE_LEO_CONSECUTIVO
                              ,OVE_ORDEN_NEGOCIO
                              ,OVE_CONDICION_PRECIO
                              ,OVE_CRITERIOS_ADICIONALES
                              ,OVE_CANTIDAD_MINIMA
                              ,OVE_VISIBLE
                              ,OVE_PORCENTAJE_VISIBLE
                              ,OVE_STOP
                              ,OVE_PRECIO_STOP
                              ,OVE_HORA_DURACION
                              ,OVE_PERMITE_AGRUPAMIENTO
                              ,OVE_CANTIDAD_ACC
                              ,OVE_PRECIO_ACC
                              ,OVE_COMISION_ACC
                              ,OVE_IVA_ACC
                              ,OVE_TOTAL_OPERACION_ACC
                              ,OVE_NETO_OPERACION_ACC
                              ,OVE_FECHA_RECEPCION
                              ,OVE_CODIGO_INFORMADOR
                              ,OVE_TID_CODIGO_INFORMADOR
                              ,OVE_IDENTIFICACION_INFORMADOR
                              ,OVE_NOMBRE_INFORMADOR
                              ,OVE_CODIGO_OFICINA_INFORMADOR
                              ,OVE_FECHA_PRE_ORDEN
                              ,OVE_HORA_PRE_ORDEN
                              ,OVE_PER_TID_ENRUTA
                              ,OVE_PER_NUM_ENRUTA
                              ,OVE_CANAL_ORIGEN
                           ) VALUES
                             ( V_ID_ORDEN                                                 --OVE_CONSECUTIVO
                              ,'COL'                                                      --OVE_BOL_MNEMONICO
                              ,'ACC'                                                      --OVE_COC_CTO_MNEMONICO
                              ,'ORD'                                                      --OVE_COC_CCO_MNEMONICO
                              ,'NA'                                                       --OVE_COC_CTE_MNEMONICO
                              ,V_PERSONAS.PER_NUM_IDEN                                    --OVE_PER_NUM_IDEN
                              ,V_PERSONAS.PER_TID_CODIGO                                  --OVE_PER_TID_CODIGO
                              ,V_CUENTA_CCC.CCC_CLI_PER_TID_CODIGO                        --OVE_CCC_CLI_PER_TID_CODIGO
                              ,V_CUENTA_CCC.CCC_CLI_PER_NUM_IDEN                          --OVE_CCC_CLI_PER_NUM_IDEN
                              ,V_CUENTA_CCC.CCC_NUMERO_CUENTA                             --OVE_CCC_NUMERO_CUENTA
                              ,V_ORDENANTES_INST.RLC_PER_NUM_IDEN                         --OVE_RLC_PER_NUM_IDEN
                              ,V_ORDENANTES_INST.RLC_PER_TID_CODIGO                       --OVE_RLC_PER_TID_CODIGO
                              ,V_ORDENANTES_INST.RLC_ROL_CODIGO                           --OVE_RLC_ROL_CODIGO
                              ,V_VIO_MNEMMONICO                                           --OVE_VIO_MNEMONICO
                              ,'CON'                                                      --OVE_CNE_MNEMONICO
                              ,'MER'                                                      --OVE_TOC_MNEMONICO
                              ,'COL'                                                      --OVE_EOC_MNEMONICO
                              ,V_INTERFAZ_CMA.IOC_MNEMOTECNICO                            --OVE_ENA_MNEMONICO
                              ,'DA'                                                       --OVE_LTI_MNEMONICO
                              ,SYSDATE--TO_DATE(P_FECHA_HORA,'DD-MM-YYYY HH24:MI:SS')     --OVE_FECHA_Y_HORA
                              ,SYSDATE--TO_DATE(P_FECHA_HORA,'DD-MM-YYYY HH24:MI:SS')     --OVE_FECHA_CRONOLOGICA
                              ,V_CANTIDAD                                                 --OVE_NOMINAL_O_PESOS
                              ,'N'                                                        --OVE_TIPO_NOMINAL_O_PESOS
                              ,'N'                                                        --OVE_OPERACION_TOTAL
                              ,V_PERSONAS.PER_EJECUTA_ORDEN_MESA                          --OVE_EJECUTA_ORDEN_MESA
                              ,'N'                                                        --OVE_GIRAR
                              ,'S'                                                        --OVE_ABONO_CUENTA
                              ,'N'                                                        --OVE_ENVIAR_FAX_FACTURA
                              ,'N'                                                        --OVE_ENVIAR_FACTURA
                              ,'N'                                                        --OVE_DINERO_CONTRA_TITULOS
                              ,'N'                                                        --OVE_RECOGER_CARTA
                              ,'N'                                                        --OVE_RECOGER_CERT_CAMARA
                              ,V_TITULO_ORIGEN                                            --OVE_ORIGEN_FUNGIBLE
                              ,SYSDATE--TO_DATE(P_FECHA_HORA,'DD-MM-YYYY HH24:MI:SS')     --OVE_FECHA_MODIFICACION
                              ,V_PRECIO_LIMITE                                            --OVE_PRECIO_LIMITE_O_MARGEN
                              ,TRUNC(V_COMISION/(V_CANTIDAD*V_PRECIO),5)*100              --OVE_COMISION
                              ,'S'                                                        --OVE_TIPO_PAGO_ABONO_CUENTA
                              ,NULL                                                       --OVE_NUMERO_FAX
                              ,NULL                                                       --OVE_AGE_CODIGO_ENVIA_DOCUMENTOS
                              ,NULL                                                       --OVE_DIRECCION_DOCUMENTOS
                              ,NULL                                                       --OVE_PREGUNTAR_POR_DOCUMENTOS
                              ,V_TITULO_CTA_DVAL                                          --OVE_CFC_CUENTA_DECEVAL
                              ,NULL                                                       --OVE_CFC_FUG_ISI_MNEMONICO
                              ,NULL                                                       --OVE_CFC_FUG_MNEMONICO
                              ,DECODE(V_PERSONAS.PER_TIPO_COMERCIAL,'C',TO_DATE(SYSDATE,'DD-MM-YYYY HH24:MI:SS'),
                                                                    'P',TO_DATE(SYSDATE,'DD-MM-YYYY HH24:MI:SS'),
                                                                     NULL)                --OVE_FECHA_VERIFICA
                              ,DECODE(V_PERSONAS.PER_TIPO_COMERCIAL,'C',FN_TERMINAL,
                                                                    'P',FN_TERMINAL,
                                                                     NULL)                --OVE_TERMINAL_VERIFICA
                              ,V_PERSONAS.PER_NUM_IDEN                                    --OVE_PER_NUM_IDEN_ES_DUENO
                              ,V_PERSONAS.PER_TID_CODIGO                                  --OVE_PER_TID_CODIGO_ES_DUENO
                              ,'S'                                                        --OVE_VERIFICADO_COMERCIAL
                              ,V_FECHA_PERMANENCIA                                        --OVE_FECHA_PERMANENCIA
                              ,'INT'                                                      --OVE_MEDIO_RECEPCION
                              ,'Internet S4'                                              --OVE_DETALLE_MEDIO_RECEPCION
                              ,TO_CHAR(SYSDATE,'HH24:MI')                                 --OVE_HORA_RECEPCION
                              ,'MT'                                                       --OVE_TIPO_MEC
                              ,'S'                                                       --OVE_PROFESIONAL
                              ,DECODE(V_CUENTA_CCC.CCC_CLI_PER_NUM_IDEN,'860079174',NULL,V_PERSONAS.PER_NUM_IDEN)   --OVE_PER_NUM_IDEN_CTA
                              ,DECODE(V_CUENTA_CCC.CCC_CLI_PER_NUM_IDEN,'860079174',NULL,V_PERSONAS.PER_TID_CODIGO) --OVE_PER_TID_CODIGO_CTA
                              ,5                                                          --OVE_LEO_CONSECUTIVO
                              ,'O'                                                        --OVE_ORDEN_NEGOCIO
                              ,V_COND_PRECIO                                              --OVE_CONDICION_PRECIO
                              ,NULL                                                       --OVE_CRITERIOS_ADICIONALES
                              ,NULL                                                       --OVE_CANTIDAD_MINIMA
                              ,NULL                                                       --OVE_VISIBLE
                              ,NULL                                                      --OVE_PORCENTAJE_VISIBLE
                              ,NULL                                                      --OVE_STOP
                              ,NULL                                                       --OVE_PRECIO_STOP
                              ,NULL                                                       --OVE_HORA_DURACION
                              ,'N'                                                        --OVE_PERMITE_AGRUPAMIENTO
                              ,NVL(V_CANTIDAD,0)                                          --OVE_CANTIDAD_ACC
                              ,NVL(V_PRECIO,0)                                            --OVE_PRECIO_ACC
                              ,NVL(V_COMISION,0)                                          --OVE_COMISION_ACC
                              ,NVL(V_IVA_ITENCION,0)                                      --OVE_IVA_ACC
                              ,NVL(V_TOTAL_OPERACION_INT,0)                               --OVE_TOTAL_OPERACION_ACC
                              ,NVL(V_NETO_OPERACION_INT,0)                                --OVE_NETO_OPERACION_ACC
                              ,SYSDATE                                                    --OVE_FECHA_RECEPCION dd/MM/yyyy
                              ,NULL                                                       --OVE_CODIGO_INFORMADOR
                              ,NULL                                                       --OVE_TID_CODIGO_INFORMADOR
                              ,NULL                                                       --OVE_IDENTIFICACION_INFORMADOR
                              ,NULL                                                       --OVE_NOMBRE_INFORMADOR
                              ,NULL                                                       --OVE_CODIGO_OFICINA_INFORMADOR
                              ,NULL                                                       --OVE_FECHA_PRE_ORDEN
                              ,NULL                                                       --OVE_HORA_PRE_ORDEN
                              ,NULL                                                       --OVE_PER_TID_ENRUTA
                              ,NULL                                                       --OVE_PER_NUM_ENRUTA
                              ,'S4'                                                       --OVE_CANAL_ORIGEN
                             );
                          IF SQL%ROWCOUNT = 0 THEN
                            V_ID_ORDEN := NULL;
                            V_CLOB := P_CAB.ObtenerCLOB_ERROR('ColocarOrden') ;
                            IF V_CLOB IS NULL THEN
                               V_CLOB := substr(sqlerrm,1,3500);
                            END IF;
                            UPDATE INTERFAZ_ORDENES_CMA
                               SET IOC_OBSERVACIONES = ' ORDEN S4:'||V_CLOB
                                  ,IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                                  ,IOC_FECHA_ENTREGA = SYSDATE
                               WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                          END IF;
                          EXCEPTION WHEN OTHERS THEN
                               V_ID_ORDEN := NULL;
                               V_CLOB := P_CAB.ObtenerCLOB_ERROR('ColocarOrden') ;
                               IF V_CLOB IS NULL THEN
                                 V_CLOB := substr(sqlerrm,1,3500);
                               END IF;
                               UPDATE INTERFAZ_ORDENES_CMA
                               SET IOC_OBSERVACIONES = ' ORDEN S4:'||V_CLOB
                                  ,IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                                  ,IOC_FECHA_ENTREGA = SYSDATE
                               WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                           END;
                        END IF;


                        IF V_ID_ORDEN IS NOT NULL THEN
                            UPDATE INTERFAZ_ORDENES_CMA
                            SET IOC_ESTADO_REGISTRO = 'PROCESADO'
                               ,IOC_FECHA_ENTREGA = SYSDATE
                            WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;

                            IF V_INTERFAZ_CMA.IOC_CLASE_ORDEN = 'C' THEN
                               UPDATE ORDENES_COMPRA
                                 SET OCO_ID_BOLSA_CMA =   V_INTERFAZ_CMA.IOC_NRO_ORDEN
                                    ,OCO_ID_CMA = TO_NUMBER(NVL(TRIM(V_INTERFAZ_CMA.IOC_NRO_INT_ORDEN),'0'),'9999999999')
                                    ,OCO_COMISION_OMS = V_COMISION
                                    ,OCO_ESTADO_BOLSA = DECODE(V_INTERFAZ_CMA.IOC_ESTADO,'E','REG','C','REG','EC','REG',NULL)
                               WHERE  OCO_CONSECUTIVO = V_ID_ORDEN
                                 AND OCO_BOL_MNEMONICO = 'COL'
                                 AND OCO_COC_CTO_MNEMONICO = 'ACC';


                               -- NOTIFICAR OPERACION S4
                               -- NOTIFICAR ORDENES A DATAIFX
                               IF V_PERSONAS.PER_TIPO = 'PJU' THEN
                                 V_NOC_CLI_PER_NUM_IDE := V_CUENTA_CCC.CCC_CLI_PER_NUM_IDEN||'-'||P_CLIENTES.RT_DIGITO_CONTROL(V_CUENTA_CCC.CCC_CLI_PER_NUM_IDEN);
                               ELSE
                                 V_NOC_CLI_PER_NUM_IDE := V_CUENTA_CCC.CCC_CLI_PER_NUM_IDEN;
                               END IF;

                               INSERT INTO NOTIFICACIONES_ORDENES_CMA(
                                   NOC_CONSECUTIVO
                                  ,NOC_FOLIO_BOLSA
                                  ,NOC_CLI_PER_NUM_IDEN
                                  ,NOC_CLI_PER_TID_CODIGO
                                  ,NOC_CUENTA_DECEVAL
                                  ,NOC_ID_COEASY
                                  ,NOC_TIPO_NEGOCIO
                                  ,NOC_PORCENTAJE_COMISION
                                  ,NOC_USUARIO_SAE
                                  ,NOC_ESPECIAL_FIDUCIARIO
                                  ,NOC_CANTIDAD
                                  ,NOC_PRECIO
                                  ,NOC_ESTADO
                                  ,NOC_FECHA_INGRESO
                                  ,NOC_FECHA_ENTREGA
                                  ,NOC_ENA_MNEMONICO
                                  ,NOC_CANAL_ORIGEN
                                  ,NOC_PER_NOMBRE_USUARIO
                                  ,NOC_PER_NOMBRE
                                  ,NOC_PER_APELLIDOS
                                  ,NOC_COMISION_ESPECIAL_ETRADE)
                               VALUES
                                (
                                   NOC_SEQ.NEXTVAL                                 --NOC_CONSECUTIVO
                                  ,V_INTERFAZ_CMA.IOC_NRO_ORDEN                    --NOC_FOLIO_BOLSA
                                  ,V_NOC_CLI_PER_NUM_IDE                           --NOC_CLI_PER_NUM_IDEN
                                  ,V_CUENTA_CCC.CCC_CLI_PER_TID_CODIGO             --NOC_CLI_PER_TID_CODIGO
                                  ,V_CUENTA_DECEVAL                                --NOC_CUENTA_DECEVAL
                                  ,V_ID_ORDEN                                      --NOC_ID_COEASY
                                  ,'C'                                             --NOC_TIPO_NEGOCIO
                                  ,TRUNC((V_COMISION/(V_CANTIDAD*V_PRECIO)*100),3) --NOC_PORCENTAJE_COMISION
                                  ,V_VALOR_SAE_S4                                  --NOC_USUARIO_SAE
                                  ,V_CUENTAS_DECEVAL.CUD_ESPECIAL_FIDUCIARIO       --NOC_ESPECIAL_FIDUCIARIO
                                  ,V_CANTIDAD                                      --NOC_CANTIDAD
                                  ,V_PRECIO                                        --NOC_PRECIO
                                  ,'POR_PROCESAR'                                  --NOC_ESTADO
                                  ,SYSDATE                                         --NOC_FECHA_INGRESO
                                  ,NULL                                            --NOC_FECHA_ENTREGA
                                  ,V_INTERFAZ_CMA.IOC_MNEMOTECNICO                 --NOC_ENA_MNEMONICO
                                  ,'3'--'S4'                                       --NOC_CANAL_ORIGEN
                                  ,V_PERSONAS.PER_NOMBRE_USUARIO                   --NOC_PER_NOMBRE_USUARIO
                                  ,DECODE(V_PERSONAS.PER_TIPO,'PJU',
                                    V_PERSONAS.PER_RAZON_SOCIAL,
                                    V_PERSONAS.PER_NOMBRE)                         --NOC_PER_NOMBRE
                                  ,DECODE(V_PERSONAS.PER_TIPO,'PJU',' ',
                                    TRIM(V_PERSONAS.PER_PRIMER_APELLIDO)||' '||
                                    TRIM(V_PERSONAS.PER_SEGUNDO_APELLIDO))         --NOC_PER_APELLIDOS
                                  ,'N'                                             --NOC_COMISION_ESPECIAL_ETRADE
                                );
                            END IF;

                            IF V_INTERFAZ_CMA.IOC_CLASE_ORDEN = 'V' THEN
                               UPDATE ORDENES_VENTA
                                 SET OVE_ID_BOLSA_CMA =   V_INTERFAZ_CMA.IOC_NRO_ORDEN
                                    ,OVE_ID_CMA = TO_NUMBER(NVL(TRIM(V_INTERFAZ_CMA.IOC_NRO_INT_ORDEN),'0'),'9999999999')
                                    ,OVE_COMISION_OMS = V_COMISION
                                    ,OVE_ESTADO_BOLSA = DECODE(V_INTERFAZ_CMA.IOC_ESTADO,'E','REG','C','REG','EC','REG',NULL)
                               WHERE  OVE_CONSECUTIVO = V_ID_ORDEN
                                 AND OVE_BOL_MNEMONICO = 'COL'
                                 AND OVE_COC_CTO_MNEMONICO = 'ACC';

                               -- NOTIFICAR OPERACION S4
                               -- NOTIFICAR ORDENES A DATAIFX
                               IF V_PERSONAS.PER_TIPO = 'PJU' THEN
                                 V_NOC_CLI_PER_NUM_IDE := V_CUENTA_CCC.CCC_CLI_PER_NUM_IDEN||'-'||P_CLIENTES.RT_DIGITO_CONTROL(V_CUENTA_CCC.CCC_CLI_PER_NUM_IDEN);
                               ELSE
                                 V_NOC_CLI_PER_NUM_IDE := V_CUENTA_CCC.CCC_CLI_PER_NUM_IDEN;
                               END IF;

                               INSERT INTO NOTIFICACIONES_ORDENES_CMA(
                                   NOC_CONSECUTIVO
                                  ,NOC_FOLIO_BOLSA
                                  ,NOC_CLI_PER_NUM_IDEN
                                  ,NOC_CLI_PER_TID_CODIGO
                                  ,NOC_CUENTA_DECEVAL
                                  ,NOC_ID_COEASY
                                  ,NOC_TIPO_NEGOCIO
                                  ,NOC_PORCENTAJE_COMISION
                                  ,NOC_USUARIO_SAE
                                  ,NOC_ESPECIAL_FIDUCIARIO
                                  ,NOC_CANTIDAD
                                  ,NOC_PRECIO
                                  ,NOC_ESTADO
                                  ,NOC_FECHA_INGRESO
                                  ,NOC_FECHA_ENTREGA
                                  ,NOC_ENA_MNEMONICO
                                  ,NOC_CANAL_ORIGEN
                                  ,NOC_PER_NOMBRE_USUARIO
                                  ,NOC_PER_NOMBRE
                                  ,NOC_PER_APELLIDOS
                                  ,NOC_COMISION_ESPECIAL_ETRADE)
                               VALUES
                                (
                                   NOC_SEQ.NEXTVAL                                 --NOC_CONSECUTIVO
                                  ,V_INTERFAZ_CMA.IOC_NRO_ORDEN                    --NOC_FOLIO_BOLSA
                                  ,V_NOC_CLI_PER_NUM_IDE                           --NOC_CLI_PER_NUM_IDEN
                                  ,V_CUENTA_CCC.CCC_CLI_PER_TID_CODIGO             --NOC_CLI_PER_TID_CODIGO
                                  ,V_CUENTA_DECEVAL                                --NOC_CUENTA_DECEVAL
                                  ,V_ID_ORDEN                                      --NOC_ID_COEASY
                                  ,'V'                                             --NOC_TIPO_NEGOCIO
                                  ,TRUNC((V_COMISION/(V_CANTIDAD*V_PRECIO))*100,3) --NOC_PORCENTAJE_COMISION
                                  ,V_VALOR_SAE_S4                                  --NOC_USUARIO_SAE
                                  ,V_CUENTAS_DECEVAL.CUD_ESPECIAL_FIDUCIARIO       --NOC_ESPECIAL_FIDUCIARIO
                                  ,V_CANTIDAD                                      --NOC_CANTIDAD
                                  ,V_PRECIO                                        --NOC_PRECIO
                                  ,'POR_PROCESAR'                                  --NOC_ESTADO
                                  ,SYSDATE                                         --NOC_FECHA_INGRESO
                                  ,NULL                                            --NOC_FECHA_ENTREGA
                                  ,V_INTERFAZ_CMA.IOC_MNEMOTECNICO                 --NOC_ENA_MNEMONICO
                                  ,'3'--'S4'                                       --NOC_CANAL_ORIGEN
                                  ,V_PERSONAS.PER_NOMBRE_USUARIO                   --NOC_PER_NOMBRE_USUARIO
                                  ,DECODE(V_PERSONAS.PER_TIPO,'PJU',
                                    V_PERSONAS.PER_RAZON_SOCIAL,
                                    V_PERSONAS.PER_NOMBRE)                         --NOC_PER_NOMBRE
                                  ,DECODE(V_PERSONAS.PER_TIPO,'PJU',' ',
                                    TRIM(V_PERSONAS.PER_PRIMER_APELLIDO)||' '||
                                    TRIM(V_PERSONAS.PER_SEGUNDO_APELLIDO))         --NOC_PER_APELLIDOS)
                                  ,'N'                                             --NOC_COMISION_ESPECIAL_ETRADE
                               );
                            END IF;

                            UPDATE INTERFAZ_ORDENES_CMA
                               SET IOC_ESTADO_REGISTRO = 'PROCESADO'
                                  ,IOC_FECHA_ENTREGA = SYSDATE
                            WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                         ELSE
                            V_ERRORES := V_ERRORES+1;
                         END IF;

                         IF V_CLOB IS NOT NULL THEN
                           UPDATE INTERFAZ_ORDENES_CMA
                           SET IOC_OBSERVACIONES = ' ORDEN S4:'||V_CLOB
                              ,IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                              ,IOC_FECHA_ENTREGA = SYSDATE
                           WHERE  IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                           V_ERRORES := V_ERRORES+1;
                         END IF;
                    ELSE
                      IF  V_INTERFAZ_CMA.IOC_CLASE_ORDEN = 'C' THEN
                         BEGIN
                         UPDATE ORDENES_COMPRA
                            SET  OCO_ID_BOLSA_CMA  = V_INTERFAZ_CMA.IOC_NRO_ORDEN
                                ,OCO_ID_CMA = TO_NUMBER(NVL(TRIM(V_INTERFAZ_CMA.IOC_NRO_INT_ORDEN),'0'),'9999999999')
                                ,OCO_VIO_MNEMONICO = V_VIO_MNEMMONICO
                                ,OCO_FECHA_PERMANENCIA = V_FECHA_PERMANENCIA
                                ,OCO_NOMINAL_O_PESOS = V_CANTIDAD
                                ,OCO_PRECIO_LIMITE_O_MARGEN = DECODE(V_COND_PRECIO,'LIM',V_PRECIO,NULL)
                                ,OCO_ESTADO_BOLSA = DECODE(V_INTERFAZ_CMA.IOC_ESTADO,'E','REG','C','REG','EC','REG',NULL)
                         WHERE OCO_CONSECUTIVO = V_ORDENES_COMPRA.OCO_CONSECUTIVO
                           AND OCO_BOL_MNEMONICO = V_ORDENES_COMPRA.OCO_BOL_MNEMONICO
                           AND OCO_COC_CTO_MNEMONICO = V_ORDENES_COMPRA.OCO_COC_CTO_MNEMONICO;
                         IF   SQL%ROWCOUNT = 0 THEN
                            V_ERRORES := V_ERRORES+1;
                            V_CLOB := P_CAB.ObtenerCLOB_ERROR ('AnularOrden');
                            UPDATE INTERFAZ_ORDENES_CMA
                              SET IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                                 ,IOC_FECHA_ENTREGA = SYSDATE
                                 ,IOC_OBSERVACIONES = ' ORDEN S4:'||V_CLOB
                              WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                         ELSE
                           UPDATE NOTIFICACIONES_ORDENES_CMA
                                SET NOC_FOLIO_BOLSA = V_INTERFAZ_CMA.IOC_NRO_ORDEN
                              WHERE NOC_ID_COEASY =   V_ORDENES_COMPRA.OCO_CONSECUTIVO
                                AND NOC_TIPO_NEGOCIO  = 'C'
                                AND NOC_ESTADO = 'POR_PROCESAR';

                           UPDATE INTERFAZ_ORDENES_CMA
                               SET IOC_ESTADO_REGISTRO = 'PROCESADO'
                                  ,IOC_FECHA_ENTREGA = SYSDATE
                           WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                         END IF;
                         EXCEPTION WHEN OTHERS THEN
                             V_ID_ORDEN := NULL;
                             V_ERRORES := V_ERRORES+1;
                             V_CLOB := P_CAB.ObtenerCLOB_ERROR ('UpdateOrden');
                             IF V_CLOB IS NULL THEN
                               V_CLOB := substr(sqlerrm,1,3500);
                             END IF;

                             UPDATE INTERFAZ_ORDENES_CMA
                             SET IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                                 ,IOC_FECHA_ENTREGA = SYSDATE
                                 ,IOC_OBSERVACIONES = ' ORDEN S4:'||V_CLOB
                             WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                         END;
                      END IF;

                      IF  V_INTERFAZ_CMA.IOC_CLASE_ORDEN = 'V' THEN
                         BEGIN
                         UPDATE ORDENES_VENTA
                            SET  OVE_ID_BOLSA_CMA  = V_INTERFAZ_CMA.IOC_NRO_ORDEN
                                ,OVE_ID_CMA = TO_NUMBER(NVL(TRIM(V_INTERFAZ_CMA.IOC_NRO_INT_ORDEN),'0'),'9999999999')
                                ,OVE_VIO_MNEMONICO = V_VIO_MNEMMONICO
                                ,OVE_FECHA_PERMANENCIA = V_FECHA_PERMANENCIA
                                ,OVE_NOMINAL_O_PESOS = V_CANTIDAD
                                ,OVE_PRECIO_LIMITE_O_MARGEN = DECODE(V_COND_PRECIO,'LIM',V_PRECIO,NULL)
                                ,OVE_ESTADO_BOLSA = DECODE(V_INTERFAZ_CMA.IOC_ESTADO,'E','REG','C','REG','EC','REG',NULL)
                         WHERE OVE_CONSECUTIVO = V_ORDENES_VENTA.OVE_CONSECUTIVO
                           AND OVE_BOL_MNEMONICO = V_ORDENES_VENTA.OVE_BOL_MNEMONICO
                           AND OVE_COC_CTO_MNEMONICO = V_ORDENES_VENTA.OVE_COC_CTO_MNEMONICO;
                         IF SQL%ROWCOUNT = 0 THEN
                            V_ERRORES := V_ERRORES+1;
                            V_CLOB := P_CAB.ObtenerCLOB_ERROR ('AnularOrden');
                            UPDATE INTERFAZ_ORDENES_CMA
                              SET IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                                 ,IOC_FECHA_ENTREGA = SYSDATE
                                 ,IOC_OBSERVACIONES = ' ORDEN S4:'||V_CLOB
                              WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                         ELSE
                            UPDATE NOTIFICACIONES_ORDENES_CMA
                                SET NOC_FOLIO_BOLSA = V_INTERFAZ_CMA.IOC_NRO_ORDEN
                            WHERE NOC_ID_COEASY =   V_ORDENES_VENTA.OVE_CONSECUTIVO
                              AND NOC_TIPO_NEGOCIO  = 'V'
                              AND NOC_ESTADO = 'POR_PROCESAR';

                            UPDATE INTERFAZ_ORDENES_CMA
                               SET IOC_ESTADO_REGISTRO = 'PROCESADO'
                                  ,IOC_FECHA_ENTREGA = SYSDATE
                            WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                         END IF;
                         EXCEPTION WHEN OTHERS THEN
                             V_ID_ORDEN := NULL;
                             V_ERRORES := V_ERRORES+1;
                             V_CLOB := P_CAB.ObtenerCLOB_ERROR ('UpdateOrden');
                             IF V_CLOB IS NULL THEN
                               V_CLOB := substr(sqlerrm,1,3500);
                             END IF;

                             UPDATE INTERFAZ_ORDENES_CMA
                             SET IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                                 ,IOC_FECHA_ENTREGA = SYSDATE
                                 ,IOC_OBSERVACIONES = ' ORDEN S4:'||V_CLOB
                             WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                         END;
                      END IF;
                    END IF;
                  END IF;

                  IF V_EOC_MNEMONICO = 'ANU' THEN
                     IF V_INTERFAZ_CMA.IOC_CLASE_ORDEN  = 'C' THEN
                         P_ERRORES := 0;
                         P_ORDENES_COMERCIAL.P_ORDEN_ANULAR(P_TIPO_ORDEN => 'C',
                                                            P_ID_ORDEN   => V_ORDENES_COMPRA.OCO_CONSECUTIVO,
                                                            P_FECHA      => SYSDATE,
                                                            P_MOTIVO     => 'ANULADA DESDE S4',
                                                            P_USUARIO    => V_PERSONAS.PER_NOMBRE_USUARIO,
                                                            P_TID_CODIGO => V_PERSONAS.PER_TID_CODIGO,
                                                            P_NUM_IDEN   => V_PERSONAS.PER_NUM_IDEN,
                                                            P_TERMINAL   => 'INTERNET',
                                                            P_ERRORES    => P_ERRORES);
                         IF P_ERRORES = 0 THEN
                            UPDATE INTERFAZ_ORDENES_CMA
                              SET IOC_ESTADO_REGISTRO = 'PROCESADO'
                                 ,IOC_FECHA_ENTREGA = SYSDATE
                            WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                         ELSE
                            V_CLOB := P_CAB.ObtenerCLOB_ERROR ('AnularOrden');
                            UPDATE INTERFAZ_ORDENES_CMA
                              SET IOC_OBSERVACIONES = ' ANULAR S4:'||V_CLOB
                                 ,IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                                 ,IOC_FECHA_ENTREGA = SYSDATE
                            WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;

                             V_ERRORES := V_ERRORES+1;
                         END IF;
                     END IF;





                     IF V_INTERFAZ_CMA.IOC_CLASE_ORDEN  = 'V' THEN
                         P_ERRORES := 0;
                         P_ORDENES_COMERCIAL.P_ORDEN_ANULAR(P_TIPO_ORDEN => 'V',
                                                            P_ID_ORDEN   => V_ORDENES_VENTA.OVE_CONSECUTIVO,
                                                            P_FECHA      => SYSDATE,
                                                            P_MOTIVO     => 'ANULADA DESDE S4',
                                                            P_USUARIO    => V_PERSONAS.PER_NOMBRE_USUARIO,
                                                            P_TID_CODIGO => V_PERSONAS.PER_TID_CODIGO,
                                                            P_NUM_IDEN   => V_PERSONAS.PER_NUM_IDEN,
                                                            P_TERMINAL   => 'INTERNET',
                                                            P_ERRORES    => P_ERRORES);
                         IF P_ERRORES = 0 THEN
                            UPDATE INTERFAZ_ORDENES_CMA
                              SET IOC_ESTADO_REGISTRO = 'PROCESADO'
                                 ,IOC_FECHA_ENTREGA = SYSDATE
                            WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                         ELSE
                            V_CLOB := P_CAB.ObtenerCLOB_ERROR ('AnularOrden');
                            UPDATE INTERFAZ_ORDENES_CMA
                              SET IOC_OBSERVACIONES = ' ANULAR S4:'||V_CLOB
                                 ,IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                                 ,IOC_FECHA_ENTREGA = SYSDATE
                            WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                            V_ERRORES := V_ERRORES+1;
                         END IF;
                     END IF;

                  END IF;


                  IF V_EOC_MNEMONICO = 'CAN' THEN
                     IF V_INTERFAZ_CMA.IOC_CLASE_ORDEN  = 'C' THEN
                         P_ERRORES := 0;
                         P_ORDENES_COMERCIAL.P_ORDEN_CANCELAR(P_TIPO_ORDEN => 'C',
                                                              P_ID_ORDEN   => V_ORDENES_COMPRA.OCO_CONSECUTIVO,
                                                              P_FECHA      => SYSDATE,
                                                              P_MOTIVO     => 'CANCELADA DESDE S4',
                                                              P_USUARIO    => V_PERSONAS.PER_NOMBRE_USUARIO,
                                                              P_TID_CODIGO => V_PERSONAS.PER_TID_CODIGO,
                                                              P_NUM_IDEN   => V_PERSONAS.PER_NUM_IDEN,
                                                              P_TERMINAL   => 'INTERNET',
                                                              P_ERRORES    => P_ERRORES);
                         IF P_ERRORES = 0 THEN
                            UPDATE INTERFAZ_ORDENES_CMA
                              SET IOC_ESTADO_REGISTRO = 'PROCESADO'
                                 ,IOC_FECHA_ENTREGA = SYSDATE
                            WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                         ELSE
                            V_CLOB := P_CAB.ObtenerCLOB_ERROR ('CancelarOrden');
                            UPDATE INTERFAZ_ORDENES_CMA
                              SET IOC_OBSERVACIONES = ' CANCELAR S4:'||V_CLOB
                                 ,IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                                 ,IOC_FECHA_ENTREGA = SYSDATE
                            WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;

                            V_ERRORES := V_ERRORES+1;
                         END IF;
                     END IF;


                     IF V_INTERFAZ_CMA.IOC_CLASE_ORDEN  = 'V' THEN
                         P_ERRORES := 0;
                         P_ORDENES_COMERCIAL.P_ORDEN_CANCELAR(P_TIPO_ORDEN => 'V',
                                                              P_ID_ORDEN   => V_ORDENES_VENTA.OVE_CONSECUTIVO,
                                                              P_FECHA      => SYSDATE,
                                                              P_MOTIVO     => 'CANCELADA DESDE S4',
                                                              P_USUARIO    => V_PERSONAS.PER_NOMBRE_USUARIO,
                                                              P_TID_CODIGO => V_PERSONAS.PER_TID_CODIGO,
                                                              P_NUM_IDEN   => V_PERSONAS.PER_NUM_IDEN,
                                                              P_TERMINAL   => 'INTERNET',
                                                              P_ERRORES    => P_ERRORES);
                         IF P_ERRORES = 0 THEN
                            UPDATE INTERFAZ_ORDENES_CMA
                              SET IOC_ESTADO_REGISTRO = 'PROCESADO'
                                 ,IOC_FECHA_ENTREGA = SYSDATE
                            WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                         ELSE
                            V_CLOB := P_CAB.ObtenerCLOB_ERROR ('CancelarOrden');
                            UPDATE INTERFAZ_ORDENES_CMA
                              SET IOC_OBSERVACIONES = ' CANCELAR S4:'||V_CLOB
                                 ,IOC_ESTADO_REGISTRO = 'NO_PROCESADO'
                                 ,IOC_FECHA_ENTREGA = SYSDATE
                            WHERE IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
                            V_ERRORES := V_ERRORES+1;
                         END IF;
                     END IF;
                  END IF;
                END IF;
             END IF;
          END IF;
        END IF;
     END LOOP;
     CLOSE IO_CURSOR;
     P_ERRORES := V_ERRORES;
     COMMIT;
   END IF;
    --EXCEPTION
     --WHEN OTHERS THEN
         --UPDATE INTERFAZ_ORDENES_CMA
       --  SET IOC_OBSERVACIONES = ' ORDEN S2:'||SUBSTR(sqlerrm,1,90)
         --WHERE  IOC_CONSECUTIVO = V_INTERFAZ_CMA.IOC_CONSECUTIVO;
         --P_ERRORES := P_ERRORES+1;
       --P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento P_ACTUALIZA_INTERFAZ_CMA.SQL',substr(sqlerrm,1,3500));
END P_ACTUALIZA_INTERFAZ_CMA ;

PROCEDURE PR_COMPLEMENTA_OPERACIONES(P_ENA_MNEMONICO  VARCHAR2,
                                     P_TIPO_OPERACION VARCHAR2,
                                     P_MERCADO        VARCHAR2,
                                     P_CLASE_ORDEN    VARCHAR2,
                                     P_CONSECUTIO    NUMBER DEFAULT NULL) AS

   V_QUERY          VARCHAR2(4000);
   V_QUERY_MAN      VARCHAR2(4000);
   V_HOST_NAME      VARCHAR2(100);
   V_PUERTO         VARCHAR2(100);
   V_VALOR_CHAR     VARCHAR2(200);
   V_NUMERO_OPERACION VARCHAR2(100);
   V_ID_OPERACION     VARCHAR2(100);
   V_FECHA_OPERACION  VARCHAR2(20);
   V_SALIDA           VARCHAR2(4000);
   V_VALOR_DATE     DATE;
   V_VALOR          NUMBER;
   V_STRING_REQUEST CLOB;
   V_CLOB           CLOB;
   V_CURSOR         P_WEB_CLIENTE.O_CURSOR;
   V_CURSOR_MAN     P_WEB_CLIENTE.O_CURSOR;
   V_OVE            ORDENES_VENTA%ROWTYPE;
   V_OCO            ORDENES_COMPRA%ROWTYPE;
   V_LIC            LIQUIDACIONES_COMERCIAL%ROWTYPE;
   V_COD            COMITENTES_DECEVAL%ROWTYPE;
   V_PER            PERSONAS%ROWTYPE;
   V_CUD            CUENTAS_DECEVAL%ROWTYPE;
   V_CLI_PER_NUM_IDEN PERSONAS.PER_NUM_IDEN%TYPE;
   l_http_request   UTL_HTTP.req;
   l_http_response  UTL_HTTP.resp;
   L_BUFFER_SIZE    NUMBER(10) := 512;
   l_substring_msg  VARCHAR2(1000);
   TIMEZONE         VARCHAR2(50);
   L_RAW_DATA       RAW(512);

BEGIN

   P_TOOLS.CONSULTARCONSTANTE(
     P_CONSTANTE  => 'HIB',--'HCA',
     P_VALOR      => V_VALOR,
     P_VALOR_DATE => V_VALOR_DATE,
     P_VALOR_CHAR => V_VALOR_CHAR
   );
   V_HOST_NAME := NVL(V_VALOR_CHAR,' ');

   IF NVL(V_VALOR_CHAR,' ') IS NULL THEN
      RAISE_APPLICATION_ERROR(-20900, 'No existe constante HCA host de integracion');
   END IF;

   -- TRAYENDO DATOS DEL PUERTO:
   P_TOOLS.CONSULTARCONSTANTE(
     P_CONSTANTE  => 'PIB',--'PCA',
     P_VALOR      => V_VALOR,
     P_VALOR_DATE => V_VALOR_DATE,
     P_VALOR_CHAR => V_VALOR_CHAR
   );
   V_PUERTO := NVL(V_VALOR_CHAR,NULL);

   V_QUERY := NULL;

   IF P_MERCADO = 'ACC' THEN
       IF P_CLASE_ORDEN = 'OPA' THEN
           IF P_TIPO_OPERACION = 'V' THEN
              V_QUERY := 'SELECT OVE_CONSECUTIVO '||
                       ' ,NVL(OVE_TODO_NADA_OPA,''N'') OVE_TODO_NADA_OPA '||
                       ' ,OVE_NOMINAL_O_PESOS OVE_NOMINAL_O_PESOS '||
                       ' ,OVE_CCC_CLI_PER_TID_CODIGO '||
                       ' ,DECODE(OVE_CCC_CLI_PER_TID_CODIGO,''CC'',''01'', '||
                                             '''NIT'',''02'', '||
                                             '''CE'',''03'',  '||
                                             '''TI'',''04'',  '||
                                             '''PP'',''05'',  '||
                                             '''NIP'',''06'') '||
                                              ' PER_TID_CODIGO_BVC  '||
                       ' ,OVE_CCC_CLI_PER_NUM_IDEN  '||
                       ' ,DECODE(OVE_CCC_CLI_PER_TID_CODIGO,''NIT'',P_CLIENTES.RT_DIGITO_CONTROL(OVE_CCC_CLI_PER_NUM_IDEN)) DIGITO_VERIFICACION  '||
                       ' ,DECODE(OVE_CCC_CLI_PER_TID_CODIGO,''NIT'',CUD_ESPECIAL_FIDUCIARIO) ESPECIAL_FIDUCIARIO  '||
                       ' ,CUD_CUENTA_DECEVAL '||
                       ' ,TRUNC(OVE_COMISION,3) OVE_COMISION'||
                       ' ,OVE_CONSECUTIVO '||
                       ' ,LIC_NUMERO_OPERACION '||
                       ' ,LIC_CANTIDAD_FRACCION '||
                       ' ,LIC_NUMERO_FRACCION '||
                       ' ,LIC_TIPO_OPERACION '||
                       ' ,LIC_BOL_MNEMONICO '||
                 ' FROM TMP_LIQUIDACIONES_COM, '||
                     ' ORDENES_COMPRA, '||
                     ' CUENTAS_DECEVAL '||
                ' WHERE LIC_REFERENCIA_COMISIONISTA = OVE_CONSECUTIVO '||
                 '  AND LIC_TIPO_OPERACION = ''C'' '||
                 '  AND LIC_BOL_MNEMONICO = OVE_BOL_MNEMONICO '||
                 '  AND LIC_MNEMOTECNICO_TITULO = OVE_ENA_MNEMONICO '||
                 '  AND CUD_CUENTA_DECEVAL = OVE_CFC_CUENTA_DECEVAL '||
                 '  AND OVE_COC_CCO_MNEMONICO = ''EXT'' '||
                 '  AND OVE_COC_CTE_MNEMONICO = ''OPA''  '||
                 '  AND OVE_ENA_MNEMONICO = '||CHR(39)||P_ENA_MNEMONICO||CHR(39)||
                 '  AND OVE_BOL_MNEMONICO = ''COL'' '||
                 '  AND OVE_EOC_MNEMONICO = ''COL'' '||
                 '  AND OVE_COMISION != 0 '||
                 '  AND NVL(OVE_ESTADO_BOLSA,'' '') = ''REG''';

              IF  P_CONSECUTIO IS NOT NULL THEN
                 V_QUERY := V_QUERY || ' AND OVE_CONSECUTIVO = '||P_CONSECUTIO;
              END IF;

              V_CURSOR         := NULL;
              V_STRING_REQUEST := NULL;
              OPEN V_CURSOR FOR V_QUERY;
              LOOP
                 V_OVE    := NULL;
                 V_LIC    := NULL;
                 V_PER    := NULL;
                 V_CUD    := NULL;
                 V_NUMERO_OPERACION := NULL;
                 V_ID_OPERACION     := NULL;
                 V_FECHA_OPERACION  := NULL;

                 FETCH V_CURSOR INTO  V_OVE.OVE_CONSECUTIVO
                                     ,V_OVE.OVE_TODO_NADA_OPA
                                     ,V_OVE.OVE_NOMINAL_O_PESOS
                                     ,V_OVE.OVE_CCC_CLI_PER_TID_CODIGO
                                     ,V_PER.PER_TID_CODIGO
                                     ,V_OVE.OVE_CCC_CLI_PER_NUM_IDEN
                                     ,V_PER.PER_DIGITO_CONTROL
                                     ,V_CUD.CUD_ESPECIAL_FIDUCIARIO
                                     ,V_CUD.CUD_CUENTA_DECEVAL
                                     ,V_OVE.OVE_COMISION
                                     ,V_OVE.OVE_CONSECUTIVO
                                     ,V_LIC.LIC_NUMERO_OPERACION
                                     ,V_LIC.LIC_CANTIDAD_FRACCION
                                     ,V_LIC.LIC_NUMERO_FRACCION
                                     ,V_LIC.LIC_TIPO_OPERACION
                                     ,V_LIC.LIC_BOL_MNEMONICO ;
                 EXIT WHEN V_CURSOR%NOTFOUND;

                 V_NUMERO_OPERACION := TRIM(TO_CHAR(V_LIC.LIC_NUMERO_OPERACION));
                 V_NUMERO_OPERACION := '002'||SUBSTR(V_NUMERO_OPERACION,1,8)||'0'||SUBSTR(V_NUMERO_OPERACION,9,LENGTH(V_NUMERO_OPERACION));
                 V_ID_OPERACION     := SUBSTR(V_NUMERO_OPERACION,12,LENGTH(V_NUMERO_OPERACION));
                 V_FECHA_OPERACION  := TO_CHAR(SYSDATE,'YYYY-MM-DD');


                 IF V_OVE.OVE_CCC_CLI_PER_TID_CODIGO = 'NIT' THEN
                    V_OVE.OVE_CCC_CLI_PER_NUM_IDEN := V_OVE.OVE_CCC_CLI_PER_NUM_IDEN||'-'|| V_PER.PER_DIGITO_CONTROL;
                 END IF;

                 V_STRING_REQUEST := '<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/" xmlns:bvc="http://www.corredores.com/BVC-ComplementacionOperacion"> '||
                                     ' <soapenv:Header/> '||
                                     ' <soapenv:Body> '||
                                     ' <bvc:ComplementacionOperacion> '||
                                     ' <ComplementacionOperacionInput> '||
                                     '<IdMensaje>'||V_NUMERO_OPERACION||'</IdMensaje> '||
                                     '<TipoMensaje>0</TipoMensaje> '||
                                     '<Proposito>1</Proposito> '||
                                     '<Punta>2</Punta> '||
                                     '<Cantidad>'||V_LIC.LIC_CANTIDAD_FRACCION||'</Cantidad>'||
                                     '<FechaOperacion>'||V_FECHA_OPERACION||'</FechaOperacion> '||
                                     '<TotalAdicionales>0</TotalAdicionales> '||
                                     '<UltimoFragmento>false</UltimoFragmento> '||
                                     '<Orden> '||
                                     '<IdOperacion>'||V_ID_OPERACION||'</IdOperacion> '||
                                     '<PalabraClave>'||V_OVE.OVE_CONSECUTIVO||'</PalabraClave>'||
                                     '</Orden> '||
                                     '<Instrumento/> '||
                                     '<Parte> '||
                                     '<Id>002</Id> '||
                                     '<Rol>1</Rol> '||
                                     '</Parte> '||
                                     '<Fraccion> '||
                                     '<Id>0</Id> '||
                                     '<Cantidad>'||V_LIC.LIC_CANTIDAD_FRACCION||'</Cantidad> '||
                                     '<Parte> '||
                                     '<Id>'||V_OVE.OVE_CCC_CLI_PER_NUM_IDEN||'</Id> '||
                                     '<Rol>32</Rol> '||
                                     '<SubGrupo> '||
                                     '<Id>'||V_PER.PER_TID_CODIGO||'</Id> '||
                                     '<Tipo>4001</Tipo>'||
                                     '</SubGrupo> '||
                                     '</Parte> '||
                                     '<Comision> '||
                                     '<Valor>'||V_OVE.OVE_COMISION||'</Valor> '||
                                     '<Unidad>2</Unidad> '||
                                     '</Comision> '||
                                     '<Instruccion> '||
                                       '<InstruccionEntrega> '||
                                         '<Parte> '||
                                           '<Id>'||V_CUD.CUD_CUENTA_DECEVAL||'</Id> '||
                                           '<Rol>4002</Rol> '||
                                         '</Parte> '||
                                       '</InstruccionEntrega> '||
                                     '</Instruccion> '||
                                   '</Fraccion> '||
                                   '<Informacion> '||
                                   '<Id>Y</Id> '||
                                   '<Tipo>319</Tipo> '||
                                   '</Informacion>'||
                                 '</ComplementacionOperacionInput> '||
                                   '</bvc:ComplementacionOperacion> '||
                                '</soapenv:Body> '||
                             '</soapenv:Envelope>';


                 DBMS_OUTPUT.PUT_LINE('STRING ES  '||V_STRING_REQUEST);

                 UTL_HTTP.SET_TRANSFER_TIMEOUT(60);
                 l_http_request := UTL_HTTP.begin_request(url => 'http://' || V_HOST_NAME ||V_PUERTO ||'/BVC-ComplementacionOperacionWeb/sca/BVC-ComplementacionOperacionWS', method => 'POST', http_version => 'HTTP/1.1');
                 UTL_HTTP.set_header(l_http_request, 'User-Agent', 'Jakarta Commons-HttpClient/3.1');
                 UTL_HTTP.set_header(l_http_request, 'Connection', 'close');
                 UTL_HTTP.set_header(l_http_request, 'Content-Type', 'text/xml;charset=UTF-8');
                 UTL_HTTP.set_header(l_http_request, 'SOAPAction', '"ComplementacionOperacionInput"');
                 UTL_HTTP.set_header(l_http_request, 'Content-Length', LENGTH(V_STRING_REQUEST));
                 <<request_loop>>
                 FOR i IN 0..CEIL(LENGTH(V_STRING_REQUEST) / l_buffer_size) - 1 LOOP
                    l_substring_msg := SUBSTR(V_STRING_REQUEST, i * l_buffer_size + 1, l_buffer_size);
                    BEGIN
                       l_raw_data := utl_raw.cast_to_raw(l_substring_msg);
                       UTL_HTTP.write_raw(r => l_http_request, data => l_raw_data);
                       EXCEPTION
                           WHEN NO_DATA_FOUND THEN
                               EXIT request_loop;
                   END;
                 END LOOP request_loop;
                 l_http_response := UTL_HTTP.get_response(l_http_request);
                 DBMS_OUTPUT.put_line('Response> status_code: "'   || l_http_response.status_code || '"');
                 DBMS_OUTPUT.PUT_LINE('Response> reason_phrase: "' || L_HTTP_RESPONSE.REASON_PHRASE || '"');
                 DBMS_OUTPUT.put_line('Response> http_version: "'  || l_http_response.http_version || '"');
                 BEGIN
                    <<response_loop>>
                    LOOP
                       UTL_HTTP.READ_RAW(L_HTTP_RESPONSE, L_RAW_DATA, L_BUFFER_SIZE);
                       V_CLOB := V_CLOB || UTL_RAW.cast_to_varchar2(l_raw_data);
                    END LOOP response_loop;
                    EXCEPTION
                    WHEN UTL_HTTP.end_of_body THEN
                        UTL_HTTP.end_response(l_http_response);
                 END;
                 IF l_http_request.private_hndl IS NOT NULL THEN
                    UTL_HTTP.end_request(l_http_request);
                 END IF;
                 IF l_http_response.private_hndl IS NOT NULL THEN
                    UTL_HTTP.end_response(l_http_response);
                 END IF;

                 --DBMS_OUTPUT.put_line('P_CLOB :'||P_CLOB);
                 -- Convertir xml errores en tabla de errores
                 IF INSTR(V_CLOB,'<Codigo>0000</Codigo>') > 0 THEN
                    V_SALIDA := 'OK';
                    UPDATE TMP_LIQUIDACIONES_COM
                      SET LIC_ESTADO_COM        = 'COM'
                         ,LIC_OBSERVACIONES_COM = 'COMPLEMENTACION ENVIADA BOLSA'
                    WHERE LIC_NUMERO_OPERACION =  V_LIC.LIC_NUMERO_OPERACION
                      AND LIC_NUMERO_FRACCION  =  V_LIC.LIC_NUMERO_FRACCION
                      AND LIC_TIPO_OPERACION   =  V_LIC.LIC_TIPO_OPERACION
                      AND LIC_BOL_MNEMONICO   =  V_LIC.LIC_BOL_MNEMONICO
                      AND LIC_REFERENCIA_COMISIONISTA = V_OVE.OVE_CONSECUTIVO;
                 ELSE
                    V_SALIDA  := NULL;
                    P_CAB.ObtenerUnDato(V_CLOB ,'<Descripcion>' ,'</Descripcion>',V_SALIDA);
                    V_SALIDA := NVL(V_SALIDA,SQLERRM);
                    V_SALIDA := SUBSTR(V_SALIDA,1,500);
                    UPDATE TMP_LIQUIDACIONES_COM
                      SET LIC_ESTADO_COM        = 'NCOM'
                         ,LIC_OBSERVACIONES_COM = V_SALIDA
                    WHERE LIC_NUMERO_OPERACION =  V_LIC.LIC_NUMERO_OPERACION
                      AND LIC_NUMERO_FRACCION  =  V_LIC.LIC_NUMERO_FRACCION
                      AND LIC_TIPO_OPERACION   =  V_LIC.LIC_TIPO_OPERACION
                      AND LIC_BOL_MNEMONICO   =  V_LIC.LIC_BOL_MNEMONICO
                      AND LIC_REFERENCIA_COMISIONISTA = V_OVE.OVE_CONSECUTIVO;


                 END IF;
              END LOOP;
              CLOSE V_CURSOR;
           END IF;
       END IF;
   ELSIF P_MERCADO = 'RF' THEN
      IF P_CLASE_ORDEN = 'ORD' THEN
         IF P_TIPO_OPERACION = 'C' THEN
            V_QUERY := 'SELECT OCO_CONSECUTIVO '||
                       ' ,OCO_BOL_MNEMONICO '||
                       ' ,OCO_COC_CTO_MNEMONICO '||
                       ' ,OCO_NOMINAL_O_PESOS OCO_NOMINAL_O_PESOS '||
                       ' ,OCO_CCC_CLI_PER_TID_CODIGO '||
                       ' ,DECODE(OCO_CCC_CLI_PER_TID_CODIGO,''CC'',''01'', '||
                                             '''NIT'',''02'', '||
                                             '''CE'',''03'',  '||
                                             '''TI'',''04'',  '||
                                             '''PP'',''05'',  '||
                                             '''NIP'',''06'') '||
                                              ' PER_TID_CODIGO_BVC  '||
                       ' ,OCO_CCC_CLI_PER_NUM_IDEN  '||
                       ' ,DECODE(OCO_CCC_CLI_PER_TID_CODIGO,''NIT'',P_CLIENTES.RT_DIGITO_CONTROL(OCO_CCC_CLI_PER_NUM_IDEN)) DIGITO_VERIFICACION  '||
                       ' ,DECODE(OCO_CCC_CLI_PER_TID_CODIGO,''NIT'',CUD_ESPECIAL_FIDUCIARIO) ESPECIAL_FIDUCIARIO  '||
                       ' ,CUD_CUENTA_DECEVAL '||
                       ' ,TRUNC(NVL(OCO_COMISION,0),3) OCO_COMISION'||
                       ' ,OCO_CONSECUTIVO '||
                       ' ,LIC_NUMERO_OPERACION '||
                       ' ,LIC_CANTIDAD_FRACCION '||
                       ' ,LIC_NUMERO_FRACCION '||
                       ' ,LIC_TIPO_OPERACION '||
                       ' ,LIC_BOL_MNEMONICO '||
                 ' FROM TMP_LIQUIDACIONES_COM, '||
                     ' ORDENES_COMPRA, '||
                     ' CUENTAS_DECEVAL '||
                ' WHERE LIC_REFERENCIA_COMISIONISTA = OCO_CONSECUTIVO '||
                 '  AND LIC_TIPO_OPERACION = ''C'' '||
                 '  AND LIC_BOL_MNEMONICO = OCO_BOL_MNEMONICO '||
                 '  AND LIC_MNEMOTECNICO_TITULO = OCO_ENA_MNEMONICO '||
                 '  AND LIC_ESTADO_COM = ''REG'' '||
                 '  AND CUD_CUENTA_DECEVAL = OCO_CUD_CUENTA_DECEVAL '||
                 '  AND OCO_ENA_MNEMONICO = '||CHR(39)||P_ENA_MNEMONICO||CHR(39)||
                 '  AND OCO_BOL_MNEMONICO = ''MEC'' '||
                 '  AND OCO_EOC_MNEMONICO = ''COL'' '||
                 '  AND OCO_COC_CTE_MNEMONICO = ''PRI'' '||
                 --'  AND OCO_COMISION != 0 '||
                 '  AND NVL(OCO_ESTADO_BOLSA,'' '') = ''REG''';

            IF  P_CONSECUTIO IS NOT NULL THEN
                 V_QUERY := V_QUERY || ' AND OCO_CONSECUTIVO = '||P_CONSECUTIO;
            END IF;

            V_CURSOR         := NULL;
            V_STRING_REQUEST := NULL;

            V_CURSOR         := NULL;
              V_STRING_REQUEST := NULL;
              OPEN V_CURSOR FOR V_QUERY;
              LOOP
                 V_OCO    := NULL;
                 V_LIC    := NULL;
                 V_PER    := NULL;
                 V_CUD    := NULL;
                 V_NUMERO_OPERACION := NULL;
                 V_ID_OPERACION     := NULL;
                 V_FECHA_OPERACION  := NULL;

                 FETCH V_CURSOR INTO  V_OCO.OCO_CONSECUTIVO
                                     ,V_OCO.OCO_BOL_MNEMONICO
                                     ,V_OCO.OCO_COC_CTO_MNEMONICO
                                     ,V_OCO.OCO_NOMINAL_O_PESOS
                                     ,V_OCO.OCO_CCC_CLI_PER_TID_CODIGO
                                     ,V_PER.PER_TID_CODIGO
                                     ,V_OCO.OCO_CCC_CLI_PER_NUM_IDEN
                                     ,V_PER.PER_DIGITO_CONTROL
                                     ,V_CUD.CUD_ESPECIAL_FIDUCIARIO
                                     ,V_CUD.CUD_CUENTA_DECEVAL
                                     ,V_OCO.OCO_COMISION
                                     ,V_OCO.OCO_CONSECUTIVO
                                     ,V_LIC.LIC_NUMERO_OPERACION
                                     ,V_LIC.LIC_CANTIDAD_FRACCION
                                     ,V_LIC.LIC_NUMERO_FRACCION
                                     ,V_LIC.LIC_TIPO_OPERACION
                                     ,V_LIC.LIC_BOL_MNEMONICO ;
                 EXIT WHEN V_CURSOR%NOTFOUND;

                 V_NUMERO_OPERACION := TRIM(TO_CHAR(V_LIC.LIC_NUMERO_OPERACION));
                 V_NUMERO_OPERACION := '002'||SUBSTR(V_NUMERO_OPERACION,1,8)||'0'||SUBSTR(V_NUMERO_OPERACION,9,LENGTH(V_NUMERO_OPERACION));
                 V_ID_OPERACION     := SUBSTR(V_NUMERO_OPERACION,12,LENGTH(V_NUMERO_OPERACION));
                 V_FECHA_OPERACION  := TO_CHAR(SYSDATE,'YYYY-MM-DD');

                 V_CLI_PER_NUM_IDEN := V_OCO.OCO_CCC_CLI_PER_NUM_IDEN;


                 IF V_OCO.OCO_CCC_CLI_PER_TID_CODIGO = 'NIT' THEN
                    V_OCO.OCO_CCC_CLI_PER_NUM_IDEN := V_OCO.OCO_CCC_CLI_PER_NUM_IDEN||'-'|| V_PER.PER_DIGITO_CONTROL;
                 END IF;

                 V_STRING_REQUEST := '<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/" xmlns:bvc="http://www.corredores.com/BVC-ComplementacionOperacion"> '||
                                     ' <soapenv:Header/> '||
                                     ' <soapenv:Body> '||
                                     ' <bvc:ComplementacionOperacion> '||
                                     ' <ComplementacionOperacionInput> '||
                                     '<IdMensaje>'||V_NUMERO_OPERACION||'</IdMensaje> '||
                                     '<TipoMensaje>0</TipoMensaje> '||
                                     '<Proposito>1</Proposito> '||
                                     '<Punta>1</Punta> '||
                                     '<Cantidad>'||TRIM(TO_CHAR(V_OCO.OCO_NOMINAL_O_PESOS,'9999999999999.00'))||'</Cantidad>'||
                                     '<FechaOperacion>'||V_FECHA_OPERACION||'</FechaOperacion> '||
                                     '<TotalAdicionales>0</TotalAdicionales> '||
                                     '<UltimoFragmento>false</UltimoFragmento> '||
                                     '<Orden> '||
                                     '<IdOperacion>'||V_ID_OPERACION||'</IdOperacion> '||
                                     '<PalabraClave>'||V_OCO.OCO_CONSECUTIVO||'</PalabraClave>'||
                                     '</Orden> '||
                                     '<Instrumento/> '||
                                     '<Parte> '||
                                     '<Id>002</Id> '||
                                     '<Rol>1</Rol> '||
                                     '</Parte> '||
                                     '<Fraccion> '||
                                     '<Id>0</Id> '||
                                     '<Cantidad>'||TRIM(TO_CHAR(V_OCO.OCO_NOMINAL_O_PESOS,'9999999999999.00'))||'</Cantidad> '||

                                     '<Parte> '||
                                     '<Id>'||V_OCO.OCO_CCC_CLI_PER_NUM_IDEN||'</Id> '||
                                     '<Rol>32</Rol> '||
                                     '<SubGrupo> '||
                                     '<Id>'||V_PER.PER_TID_CODIGO||'</Id> '||
                                     '<Tipo>4001</Tipo>'||
                                     '</SubGrupo> ';

                 --DBMS_OUTPUT.PUT_LINE('STRING ES 1.  '||V_STRING_REQUEST);

                 --RAISE_APPLICATION_ERROR(-20001,'STOP: '||V_STRING_REQUEST);


                 IF V_CUD.CUD_ESPECIAL_FIDUCIARIO IS NOT NULL THEN
                    V_STRING_REQUEST := V_STRING_REQUEST||
                                       '<SubGrupo> '||
                                       '<Id>'||V_CUD.CUD_ESPECIAL_FIDUCIARIO||'</Id> '||
                                       '<Tipo>4002</Tipo>'||
                                       '</SubGrupo> ';
                 END IF;

                 V_STRING_REQUEST := V_STRING_REQUEST||
                                     '</Parte> ';


                 V_QUERY_MAN := NULL;
                 V_QUERY_MAN := 'SELECT COD_CLI_PER_NUM_IDEN_RELACIONA '||
                                ' ,DECODE(COD_CLI_PER_TID_CODIGO_RELACIO,''CC'',''01'', '||
                                             '''NIT'',''02'', '||
                                             '''CE'',''03'',  '||
                                             '''TI'',''04'',  '||
                                             '''PP'',''05'',  '||
                                             '''NIP'',''06'') '||
                                              ' COD_CLI_PER_TID_CODIGO_RELACIO ' ||
                                ',COD_CUD_CUENTA_DECEVAL '||
                                ',COD_CONSECUTIVO '||
                                ' FROM COMITENTES_DECEVAL '||
                                ' WHERE COD_CUD_CUENTA_DECEVAL ='|| V_CUD.CUD_CUENTA_DECEVAL||
                                ' ORDER BY COD_CONSECUTIVO';

                 V_CURSOR_MAN  := NULL;
                 OPEN V_CURSOR_MAN FOR V_QUERY_MAN;
                 LOOP
                    V_COD := NULL;

                    FETCH V_CURSOR_MAN INTO V_COD.COD_CLI_PER_NUM_IDEN_RELACIONA
                                           ,V_COD.COD_CLI_PER_TID_CODIGO_RELACIO
                                           ,V_COD.COD_CUD_CUENTA_DECEVAL
                                           ,V_COD.COD_CUD_CUENTA_DECEVAL;
                    EXIT WHEN V_CURSOR_MAN%NOTFOUND;
                       V_STRING_REQUEST := V_STRING_REQUEST||
                                           '<Parte> '||
                                           '<Id>'||V_COD.COD_CLI_PER_NUM_IDEN_RELACIONA||'</Id> '||
                                           '<Rol>32</Rol> '||
                                           '<SubGrupo> '||
                                           '<Id>'||V_COD.COD_CLI_PER_TID_CODIGO_RELACIO||'</Id> '||
                                           '<Tipo>4001</Tipo>'||
                                           '</SubGrupo> ';

                       IF V_CUD.CUD_ESPECIAL_FIDUCIARIO IS NOT NULL THEN
                          V_STRING_REQUEST := V_STRING_REQUEST||
                                              '<SubGrupo> '||
                                              '<Id>'||V_CUD.CUD_ESPECIAL_FIDUCIARIO||'</Id> '||
                                              '<Tipo>4002</Tipo>'||
                                              '</SubGrupo> ';
                       END IF;
                       V_STRING_REQUEST := V_STRING_REQUEST||
                                              '</Parte> ';
                 END LOOP;
                 CLOSE V_CURSOR_MAN;

                 V_STRING_REQUEST := V_STRING_REQUEST||
                                     '<Comision> '||
                                     '<Valor>'||V_OCO.OCO_COMISION||'</Valor> '||
                                     '<Unidad>1</Unidad> '||
                                     '</Comision> '||
                                     '<Instruccion> '||
                                       '<InstruccionEntrega> '||
                                         '<Parte> '||
                                           '<Id>'||V_CUD.CUD_CUENTA_DECEVAL||'</Id> '||
                                           '<Rol>4002</Rol> '||
                                         '</Parte> '||
                                         '<Parte> ';
                 IF  V_OCO.OCO_CCC_CLI_PER_TID_CODIGO = 'NIT' AND
                     V_CLI_PER_NUM_IDEN = '860079174' THEN
                     V_STRING_REQUEST := V_STRING_REQUEST|| ' <Id>01</Id> ';
                 ELSE
                    V_STRING_REQUEST := V_STRING_REQUEST|| ' <Id>02</Id> ';
                 END IF;

                 V_STRING_REQUEST := V_STRING_REQUEST||
                                            ' <Rol>4004</Rol> '||
                                        '</Parte> '||
                                        '<Parte> '||
                                            ' <Id>62250063</Id> '||
                                            ' <Rol>4003</Rol> '||
                                        '</Parte> '||
                                       '</InstruccionEntrega> '||
                                     '</Instruccion> '||
                                   '</Fraccion> '||
                                   '<Informacion> '||
                                   '<Id>Y</Id> '||
                                   '<Tipo>319</Tipo> '||
                                   '</Informacion>'||
                                 '</ComplementacionOperacionInput> '||
                                   '</bvc:ComplementacionOperacion> '||
                                '</soapenv:Body> '||
                             '</soapenv:Envelope>';


                 DBMS_OUTPUT.PUT_LINE('STRING ES  '||V_STRING_REQUEST);

                 UTL_HTTP.SET_TRANSFER_TIMEOUT(60);
                 l_http_request := UTL_HTTP.begin_request(url => 'http://' || V_HOST_NAME ||V_PUERTO ||'/BVC-ComplementacionOperacionWeb/sca/BVC-ComplementacionOperacionWS', method => 'POST', http_version => 'HTTP/1.1');
                 UTL_HTTP.set_header(l_http_request, 'User-Agent', 'Jakarta Commons-HttpClient/3.1');
                 UTL_HTTP.set_header(l_http_request, 'Connection', 'close');
                 UTL_HTTP.set_header(l_http_request, 'Content-Type', 'text/xml;charset=UTF-8');
                 UTL_HTTP.set_header(l_http_request, 'SOAPAction', '"ComplementacionOperacionInput"');
                 UTL_HTTP.set_header(l_http_request, 'Content-Length', LENGTH(V_STRING_REQUEST));
                 <<request_loop>>
                 FOR i IN 0..CEIL(LENGTH(V_STRING_REQUEST) / l_buffer_size) - 1 LOOP
                    l_substring_msg := SUBSTR(V_STRING_REQUEST, i * l_buffer_size + 1, l_buffer_size);
                    BEGIN
                       l_raw_data := utl_raw.cast_to_raw(l_substring_msg);
                       UTL_HTTP.write_raw(r => l_http_request, data => l_raw_data);
                       EXCEPTION
                           WHEN NO_DATA_FOUND THEN
                               EXIT request_loop;
                   END;
                 END LOOP request_loop;
                 l_http_response := UTL_HTTP.get_response(l_http_request);
                 DBMS_OUTPUT.put_line('Response> status_code: "'   || l_http_response.status_code || '"');
                 DBMS_OUTPUT.PUT_LINE('Response> reason_phrase: "' || L_HTTP_RESPONSE.REASON_PHRASE || '"');
                 DBMS_OUTPUT.put_line('Response> http_version: "'  || l_http_response.http_version || '"');
                 BEGIN
                    <<response_loop>>
                    LOOP
                       UTL_HTTP.READ_RAW(L_HTTP_RESPONSE, L_RAW_DATA, L_BUFFER_SIZE);
                       V_CLOB := V_CLOB || UTL_RAW.cast_to_varchar2(l_raw_data);
                    END LOOP response_loop;
                    EXCEPTION
                    WHEN UTL_HTTP.end_of_body THEN
                        UTL_HTTP.end_response(l_http_response);
                 END;
                 IF l_http_request.private_hndl IS NOT NULL THEN
                    UTL_HTTP.end_request(l_http_request);
                 END IF;
                 IF l_http_response.private_hndl IS NOT NULL THEN
                    UTL_HTTP.end_response(l_http_response);
                 END IF;

                 --DBMS_OUTPUT.put_line('P_CLOB :'||P_CLOB);
                 -- Convertir xml errores en tabla de errores
                 IF INSTR(V_CLOB,'<Codigo>0000</Codigo>') > 0 THEN
                    V_SALIDA := 'OK';
                    UPDATE TMP_LIQUIDACIONES_COM
                      SET LIC_ESTADO_COM        = 'COM'
                         ,LIC_OBSERVACIONES_COM = 'COMPLEMENTACION ENVIADA BOLSA'
                    WHERE LIC_NUMERO_OPERACION =  V_LIC.LIC_NUMERO_OPERACION
                      AND LIC_NUMERO_FRACCION  =  V_LIC.LIC_NUMERO_FRACCION
                      AND LIC_TIPO_OPERACION   =  V_LIC.LIC_TIPO_OPERACION
                      AND LIC_BOL_MNEMONICO   =  V_LIC.LIC_BOL_MNEMONICO
                      AND LIC_REFERENCIA_COMISIONISTA = V_OCO.OCO_CONSECUTIVO;

                    UPDATE ORDENES_COMPRA
                       SET OCO_ESTADO_BOLSA = 'COM'
                    WHERE OCO_CONSECUTIVO   = V_OCO.OCO_CONSECUTIVO
                      AND OCO_BOL_MNEMONICO = V_OCO.OCO_BOL_MNEMONICO
                      AND OCO_COC_CTO_MNEMONICO = V_OCO.OCO_COC_CTO_MNEMONICO;
                 ELSE
                    V_SALIDA  := NULL;
                    P_CAB.ObtenerUnDato(V_CLOB ,'<Descripcion>' ,'</Descripcion>',V_SALIDA);
                    V_SALIDA := NVL(V_SALIDA,SQLERRM);
                    V_SALIDA := SUBSTR(V_SALIDA,1,500);
                    UPDATE TMP_LIQUIDACIONES_COM
                      SET LIC_ESTADO_COM        = 'NCOM'
                         ,LIC_OBSERVACIONES_COM = V_SALIDA
                    WHERE LIC_NUMERO_OPERACION =  V_LIC.LIC_NUMERO_OPERACION
                      AND LIC_NUMERO_FRACCION  =  V_LIC.LIC_NUMERO_FRACCION
                      AND LIC_TIPO_OPERACION   =  V_LIC.LIC_TIPO_OPERACION
                      AND LIC_BOL_MNEMONICO   =  V_LIC.LIC_BOL_MNEMONICO
                      AND LIC_REFERENCIA_COMISIONISTA = V_OCO.OCO_CONSECUTIVO;


                 END IF;
              END LOOP;
              CLOSE V_CURSOR;
         END IF;
      END IF;
   END IF;
   COMMIT;

   EXCEPTION WHEN OTHERS THEN
     DBMS_OUTPUT.PUT_LINE('ERRROR :'||SQLERRM);
END PR_COMPLEMENTA_OPERACIONES;

FUNCTION PRECIO_LIMITE_COMPRAS (CONSECUTIVO_HOC NUMBER, CONSECUTIVO_OCO NUMBER )
 RETURN VARCHAR2 IS

LIMITE VARCHAR2(220);

-- Retona el valor del limite, si este es cambiado al mismo tiempo que el el vr nominal
CURSOR C_LIMITE_NOM_C IS
  SELECT  HOC_CONSECUTIVO, HOC_VALOR_ANTERIOR
  FROM  HISTORICO_ORDENES_COMPRA
  WHERE HOC_CAMPO = 'OCO_PRECIO_LIMITE_O_MARGEN'
  AND   HOC_FECHA = ( SELECT HOC_FECHA FECHA_NOMINAL
                  FROM HISTORICO_ORDENES_COMPRA
                  WHERE HOC_CONSECUTIVO = CONSECUTIVO_HOC --13375827 -- CONSECUTIVO_HOC
               )
  AND   HOC_OCO_CONSECUTIVO = CONSECUTIVO_OCO
  ORDER BY 1; --11930086; -- CONSECUTIVO_OCO

 R_LIMITE_NOM C_LIMITE_NOM_C%ROWTYPE;

 -- Retona el valor del limite, si este e no se cambio al mismo tiempo que el el vr nominal
CURSOR C_LIMITE_LIM_C IS
   SELECT HOC_CONSECUTIVO, HOC_VALOR_ANTERIOR
  FROM HISTORICO_ORDENES_COMPRA
  WHERE HOC_CAMPO = 'OCO_PRECIO_LIMITE_O_MARGEN'
  AND HOC_CONSECUTIVO <( SELECT HOC_CONSECUTIVO
                  FROM HISTORICO_ORDENES_COMPRA
                  WHERE HOC_CONSECUTIVO = CONSECUTIVO_HOC
                )
  AND HOC_OCO_CONSECUTIVO = CONSECUTIVO_OCO
  ORDER BY 1;
R_LIMITE_LIM  C_LIMITE_LIM_C%ROWTYPE;

CURSOR C_LIMITE_OCO IS
   SELECT OCO_PRECIO_LIMITE_O_MARGEN
  FROM ORDENES_COMPRA
  WHERE OCO_CONSECUTIVO = CONSECUTIVO_OCO;
R_LIMITE_OCO    C_LIMITE_OCO%ROWTYPE;

BEGIN
  OPEN C_LIMITE_NOM_C;
  FETCH C_LIMITE_NOM_C INTO R_LIMITE_NOM;

  IF C_LIMITE_NOM_C%FOUND THEN
     WHILE C_LIMITE_NOM_C%FOUND LOOP
      LIMITE := R_LIMITE_NOM.HOC_VALOR_ANTERIOR;
    FETCH C_LIMITE_NOM_C INTO R_LIMITE_NOM;
    END LOOP;
  ELSE
    OPEN C_LIMITE_LIM_C;
    FETCH C_LIMITE_LIM_C INTO R_LIMITE_LIM;
     IF C_LIMITE_LIM_C%FOUND THEN
        WHILE C_LIMITE_LIM_C%FOUND LOOP
          LIMITE := R_LIMITE_LIM.HOC_VALOR_ANTERIOR;
        FETCH C_LIMITE_LIM_C INTO R_LIMITE_LIM;
         END LOOP;
     ELSE
        OPEN C_LIMITE_OCO;
       FETCH C_LIMITE_OCO INTO R_LIMITE_OCO;
       CLOSE C_LIMITE_OCO;
       LIMITE := R_LIMITE_OCO.OCO_PRECIO_LIMITE_O_MARGEN;
     END IF;
    CLOSE C_LIMITE_LIM_C;
  END IF;
  CLOSE C_LIMITE_NOM_C;

  RETURN(LIMITE);

END PRECIO_LIMITE_COMPRAS;

FUNCTION PRECIO_LIMITE_VENTAS (CONSECUTIVO_HOV NUMBER, CONSECUTIVO_OVE NUMBER )
 RETURN VARCHAR2 IS

LIMITE VARCHAR2(220);

-- Retona el valor del limite, si este es cambiado al mismo tiempo que el el vr nominal
CURSOR C_LIMITE_NOM_V IS
  SELECT  HOV_CONSECUTIVO, HOV_VALOR_ANTERIOR
  FROM  HISTORICO_ORDENES_VENTA
  WHERE HOV_CAMPO = 'OVE_PRECIO_LIMITE_O_MARGEN'
  AND   HOV_FECHA = ( SELECT HOV_FECHA FECHA_NOMINAL
                  FROM HISTORICO_ORDENES_VENTA
                  WHERE HOV_CONSECUTIVO = CONSECUTIVO_HOV --13375827 -- CONSECUTIVO_HOV
               )
  AND   HOV_OVE_CONSECUTIVO = CONSECUTIVO_OVE
  ORDER BY 1; --11930086; -- CONSECUTIVO_OVE

 R_LIMITE_NOM_V C_LIMITE_NOM_V%ROWTYPE;

 -- Retona el valor del limite, si este e no se cambio al mismo tiempo que el el vr nominal
CURSOR C_LIMITE_LIM_V IS
   SELECT HOV_CONSECUTIVO, HOV_VALOR_ANTERIOR
  FROM HISTORICO_ORDENES_VENTA
  WHERE HOV_CAMPO = 'OVE_PRECIO_LIMITE_O_MARGEN'
  AND HOV_CONSECUTIVO <( SELECT HOV_CONSECUTIVO
                  FROM HISTORICO_ORDENES_VENTA
                  WHERE HOV_CONSECUTIVO = CONSECUTIVO_HOV
                )
  AND HOV_OVE_CONSECUTIVO = CONSECUTIVO_OVE
  ORDER BY 1;
R_LIMITE_LIM_V  C_LIMITE_LIM_V%ROWTYPE;

CURSOR C_LIMITE_OVE IS
   SELECT OVE_PRECIO_LIMITE_O_MARGEN
  FROM ORDENES_VENTA
  WHERE OVE_CONSECUTIVO = CONSECUTIVO_OVE;
R_LIMITE_OVE    C_LIMITE_OVE%ROWTYPE;

BEGIN
  OPEN C_LIMITE_NOM_V;
  FETCH C_LIMITE_NOM_V INTO R_LIMITE_NOM_V;

  IF C_LIMITE_NOM_V%FOUND THEN
     WHILE C_LIMITE_NOM_V%FOUND LOOP
      LIMITE := R_LIMITE_NOM_V.HOV_VALOR_ANTERIOR;
    FETCH C_LIMITE_NOM_V INTO R_LIMITE_NOM_V;
    END LOOP;
  ELSE
    OPEN C_LIMITE_LIM_V;
    FETCH C_LIMITE_LIM_V INTO R_LIMITE_LIM_V;
     IF C_LIMITE_LIM_V%FOUND THEN
        WHILE C_LIMITE_LIM_V%FOUND LOOP
          LIMITE := R_LIMITE_LIM_V.HOV_VALOR_ANTERIOR;
        FETCH C_LIMITE_LIM_V INTO R_LIMITE_LIM_V;
         END LOOP;
     ELSE
        OPEN C_LIMITE_OVE;
       FETCH C_LIMITE_OVE INTO R_LIMITE_OVE;
       CLOSE C_LIMITE_OVE;
       LIMITE := R_LIMITE_OVE.OVE_PRECIO_LIMITE_O_MARGEN;
     END IF;
    CLOSE C_LIMITE_LIM_V;
  END IF;
  CLOSE C_LIMITE_NOM_V;

  RETURN(LIMITE);

END PRECIO_LIMITE_VENTAS;

PROCEDURE PR_CREAR_SALDO_CFC (P_CUENTA_DECEVAL     IN NUMBER,
                              P_ISIN               IN VARCHAR2,
                              P_FUNGIBLE           IN VARCHAR2,
                              P_CLI_PER_NUM_IDEN   IN VARCHAR2,
                              P_CLI_PER_TID_CODIGO IN VARCHAR2,
                              P_CUENTA_CCC         IN NUMBER) AS
BEGIN
    INSERT INTO CUENTAS_FUNGIBLE_CLIENTE
                     (CFC_CUENTA_DECEVAL,
                      CFC_FUG_ISI_MNEMONICO,
                      CFC_FUG_MNEMONICO,
                      CFC_CCC_CLI_PER_NUM_IDEN,
                      CFC_CCC_CLI_PER_TID_CODIGO,
                      CFC_CCC_NUMERO_CUENTA,
                      CFC_SALDO_DCVAL_DISPONIBLE,
                      CFC_SALDO_DCVAL_GARANTIA,
                      CFC_SALDO_DCVAL_EMBARGADO,
                      CFC_SALDO_DCVAL_TRANSITO_ING,
                      CFC_SALDO_DCVAL_TRANSITO_RET,
                      CFC_SALDO_CLIENTE,CFC_ESTADO,
                      CFC_FECHA_ULTIMO_ABONO_CAP,
                      CFC_FECHA_ULTIMO_ABONO_INT,
                      CFC_FECHA_ULTIMO_ABONO_DIV,
                      CFC_SALDO_DCVAL_GAR_REPO,
                      CFC_SALDO_DCVAL_POR_CUMPLIR,
                      CFC_SALDO_DCVAL_GARANTIA_DER,
                      CFC_COSTO_PROMEDIO_COMPRA,
                      CFC_SALDO_COMPRA_X_CUMPLIR)
      VALUES         (P_CUENTA_DECEVAL,
                      P_ISIN,
                      P_FUNGIBLE,
                      P_CLI_PER_NUM_IDEN,
                      P_CLI_PER_TID_CODIGO,
                      P_CUENTA_CCC,
                      '0',
                      '0',
                      '0',
                      '0',
                      '0',
                      '0',
                      'A',
                      NULL,
                      NULL,
                      NULL,
                      '0',
                      '0',
                      '0',
                      NULL,
                      '0');
END PR_CREAR_SALDO_CFC;

PROCEDURE PR_ISIN_VENTA_CORTO_ACC(P_ENA_MNEMONICO    IN  VARCHAR2,
                                  P_PER_NUM_IDEN     IN  VARCHAR2,
                                  P_PER_TID_CODIGO   IN  VARCHAR2,
                                  P_ISIN             OUT VARCHAR2,
                                  P_CREA_SALDO       OUT VARCHAR2,
                                  P_MENSAJE          OUT VARCHAR2) IS

  CURSOR CFC IS
     SELECT COUNT(*)
     FROM FUNGIBLES FUG,CUENTAS_FUNGIBLE_CLIENTE CFC
     WHERE FUG.FUG_ISI_MNEMONICO = CFC.CFC_FUG_ISI_MNEMONICO
       AND FUG.FUG_MNEMONICO     = CFC.CFC_FUG_MNEMONICO
       AND FUG.FUG_ESTADO = 'A'
       AND FUG.FUG_ENA_MNEMONICO = P_ENA_MNEMONICO
       AND FUG.FUG_TIPO = 'ACC'
       AND CFC.CFC_CCC_CLI_PER_NUM_IDEN   = P_PER_NUM_IDEN
       AND CFC.CFC_CCC_CLI_PER_TID_CODIGO = P_PER_TID_CODIGO
       AND CFC.CFC_ESTADO = 'A';

  CURSOR FUG IS
     SELECT COUNT(*),FUG_ENA_MNEMONICO
     FROM FUNGIBLES
     WHERE FUG_ENA_MNEMONICO = P_ENA_MNEMONICO
      AND  FUG_TIPO = 'ACC'
      AND  FUG_ESTADO = 'A'
      GROUP BY FUG_ENA_MNEMONICO;

  CURSOR FUG_EXISTE IS
     SELECT FUG_ENA_MNEMONICO,FUG_ISI_MNEMONICO
     FROM FUNGIBLES
     WHERE FUG_ENA_MNEMONICO = P_ENA_MNEMONICO
      AND  FUG_TIPO = 'ACC'
      AND  FUG_ESTADO = 'A';

  CURSOR FUG_MARCADO IS
     SELECT FUG_ENA_MNEMONICO,FUG_ISI_MNEMONICO
     FROM FUNGIBLES
     WHERE FUG_ENA_MNEMONICO = P_ENA_MNEMONICO
      AND  FUG_TIPO = 'ACC'
      AND  FUG_ESTADO = 'A'
      AND  NVL(FUG_VENTAS_CORTO,' ') = 'S';

  V_CONTADOR_CFC  NUMBER(5);
  V_CONTADOR_FUG  NUMBER(5);
  V_ENA_MNEMONICO FUNGIBLES.FUG_ENA_MNEMONICO%TYPE;
  V_ISI_MNEMONICO FUNGIBLES.FUG_ISI_MNEMONICO%TYPE;

BEGIN
   -- CASOS
   -- 1. EXISTE EN CFC  RETORNA P_CREA_SALDO = 'N'
   -- 2. NO EXISTE EN CFC RETORNA P_CREA_SALDO = 'S'  E ISIN EL UNICO O MARCADO

   V_CONTADOR_FUG   := 0;
   V_CONTADOR_CFC   := 0;
   V_ENA_MNEMONICO  := NULL;
   P_MENSAJE        := NULL;
   V_ISI_MNEMONICO  := NULL;

   OPEN CFC;
   FETCH CFC INTO V_CONTADOR_CFC;
   CLOSE CFC;

   V_CONTADOR_CFC := NVL(V_CONTADOR_CFC,0);

   IF V_CONTADOR_CFC >= 1 THEN
      P_ISIN       := NULL;
      P_MENSAJE    := NULL;
      P_CREA_SALDO := 'N';
   ELSE
      OPEN FUG;
      FETCH FUG INTO V_CONTADOR_FUG,V_ENA_MNEMONICO;
      CLOSE FUG;

      V_CONTADOR_FUG := NVL(V_CONTADOR_FUG,0);
      IF V_CONTADOR_FUG = 0 THEN
         P_ISIN       := NULL;
         P_MENSAJE    := 'NO EXISTE FUNGIBLE';
         P_CREA_SALDO := 'N';
      ELSIF V_CONTADOR_FUG = 1 THEN
        V_ENA_MNEMONICO := NULL;
        V_ISI_MNEMONICO := NULL;
        OPEN FUG_EXISTE;
        FETCH FUG_EXISTE INTO V_ENA_MNEMONICO,V_ISI_MNEMONICO;
        CLOSE FUG_EXISTE;

        P_ISIN       := V_ISI_MNEMONICO;
        P_MENSAJE    := 'EXISTE FUNGIBLE';
        P_CREA_SALDO := 'S';

      ELSIF V_CONTADOR_FUG > 1 THEN
         V_ENA_MNEMONICO := NULL;
         V_ISI_MNEMONICO := NULL;

         OPEN FUG_MARCADO;
         FETCH FUG_MARCADO INTO V_ENA_MNEMONICO,V_ISI_MNEMONICO;
         CLOSE FUG_MARCADO;

         IF NVL(V_ENA_MNEMONICO,' ') = ' ' THEN
            P_ISIN       := NULL;
            P_MENSAJE    := 'FUNGIBLE NO MCARCADO PARA VENTAS EN CORTO';
            P_CREA_SALDO := 'N';
         ELSE
            P_ISIN       := V_ISI_MNEMONICO;
            P_MENSAJE    := 'EXISTE FUNGIBLE MARCADO';
            P_CREA_SALDO := 'S';
         END IF;
      END IF;
   END IF;
END PR_ISIN_VENTA_CORTO_ACC;

---AJUSTE LEORV SMORALES
FUNCTION NOMINAL_ORIGEN (CONSECUTIVO NUMBER, TIPO_OPERACION VARCHAR2 )
RETURN NUMBER IS

   CURSOR C_NOMINAL_ORIGEN_C IS
      SELECT  HOC_VALOR_ANTERIOR,
              HOC_CAMPO
      FROM    HISTORICO_ORDENES_COMPRA HOC1
      WHERE   HOC_OCO_CONSECUTIVO = CONSECUTIVO
      AND     HOC_CONSECUTIVO = (SELECT MIN(HOC_CONSECUTIVO)
                                 FROM   HISTORICO_ORDENES_COMPRA HOC2
                                 WHERE  HOC2.HOC_OCO_CONSECUTIVO = CONSECUTIVO
                                 AND    HOC_CAMPO IN ('OCO_NOMINAL_O_PESOS'));
   R_NOMINAL_C C_NOMINAL_ORIGEN_C%ROWTYPE;

   CURSOR C_ORDEN_COMPRA IS
     SELECT  OCO_NOMINAL_O_PESOS
     FROM    ORDENES_COMPRA
     WHERE   OCO_CONSECUTIVO = CONSECUTIVO;
   R_ORDEN_C C_ORDEN_COMPRA%ROWTYPE;

   CURSOR C_NOMINAL_ORIGEN_V IS
      SELECT  HOV_VALOR_ANTERIOR,
              HOV_CAMPO
      FROM  HISTORICO_ORDENES_VENTA HOV1
      WHERE HOV_OVE_CONSECUTIVO = CONSECUTIVO
      AND   HOV_CONSECUTIVO = (SELECT MIN(HOV_CONSECUTIVO)
                               FROM  HISTORICO_ORDENES_VENTA HOV2
                               WHERE HOV2.HOV_OVE_CONSECUTIVO = CONSECUTIVO
                               AND   HOV_CAMPO IN ('OVE_NOMINAL_O_PESOS'));
   R_NOMINAL_V C_NOMINAL_ORIGEN_V%ROWTYPE;

   CURSOR C_ORDEN_VENTA IS
     SELECT OVE_NOMINAL_O_PESOS
     FROM   ORDENES_VENTA
     WHERE  OVE_CONSECUTIVO = CONSECUTIVO;
   R_ORDEN_V  C_ORDEN_VENTA%ROWTYPE;

 NOMINAL NUMBER;

BEGIN
   IF TIPO_OPERACION = 'C' THEN
    OPEN C_NOMINAL_ORIGEN_C;
    FETCH C_NOMINAL_ORIGEN_C INTO R_NOMINAL_C;

          IF C_NOMINAL_ORIGEN_C%FOUND THEN
             NOMINAL := R_NOMINAL_C.HOC_VALOR_ANTERIOR;
          ELSE
              OPEN  C_ORDEN_COMPRA;
              FETCH C_ORDEN_COMPRA INTO R_ORDEN_C;
                    NOMINAL:= R_ORDEN_C.OCO_NOMINAL_O_PESOS;
              CLOSE C_ORDEN_COMPRA;
          END IF;
    CLOSE C_NOMINAL_ORIGEN_C;
   ELSIF  TIPO_OPERACION = 'V' THEN
    OPEN C_NOMINAL_ORIGEN_V;
    FETCH C_NOMINAL_ORIGEN_V INTO R_NOMINAL_V;
          IF C_NOMINAL_ORIGEN_V%FOUND THEN
             NOMINAL := R_NOMINAL_V.HOV_VALOR_ANTERIOR;
          ELSE
              OPEN C_ORDEN_VENTA;
              FETCH C_ORDEN_VENTA INTO R_ORDEN_V;
                 NOMINAL:= R_ORDEN_V.OVE_NOMINAL_O_PESOS;
              CLOSE C_ORDEN_VENTA;

          END IF;
    CLOSE C_NOMINAL_ORIGEN_V;
   END IF;
    RETURN NOMINAL;
 END;

 FUNCTION PRECIO_ORIGEN (CONSECUTIVO NUMBER , TIPO_OPERACION VARCHAR2 )
RETURN NUMBER IS

   CURSOR C_PRECIO_ORIGEN_C IS
      SELECT  HOC_VALOR_ANTERIOR,
              HOC_CAMPO
      FROM HISTORICO_ORDENES_COMPRA HOC1
      WHERE HOC_OCO_CONSECUTIVO = CONSECUTIVO
      AND HOC_CONSECUTIVO = (SELECT MIN(HOC_CONSECUTIVO)
                             FROM  HISTORICO_ORDENES_COMPRA HOC2
                             WHERE HOC2.HOC_OCO_CONSECUTIVO = CONSECUTIVO
                             AND HOC_CAMPO IN ('OCO_PRECIO_LIMITE_O_MARGEN'));
   R_PRECIO_C C_PRECIO_ORIGEN_C%ROWTYPE;

   CURSOR C_ORDEN_COMPRA IS
     SELECT  OCO_PRECIO_LIMITE_O_MARGEN
     FROM ORDENES_COMPRA
     WHERE OCO_CONSECUTIVO = CONSECUTIVO;
   R_ORDEN_C  C_ORDEN_COMPRA%ROWTYPE;

    CURSOR C_PRECIO_ORIGEN_V IS
      SELECT  HOV_VALOR_ANTERIOR,
              HOV_CAMPO
      FROM HISTORICO_ORDENES_VENTA HOV1
      WHERE HOV_OVE_CONSECUTIVO = CONSECUTIVO
      AND HOV_CONSECUTIVO = (SELECT MIN(HOV_CONSECUTIVO)
                             FROM  HISTORICO_ORDENES_VENTA HOV2
                             WHERE HOV2.HOV_OVE_CONSECUTIVO = CONSECUTIVO
                             AND HOV_CAMPO IN ('OVE_PRECIO_LIMITE_O_MARGEN'));
   R_PRECIO_V C_PRECIO_ORIGEN_V%ROWTYPE;

   CURSOR C_ORDEN_VENTA IS
     SELECT  OVE_PRECIO_LIMITE_O_MARGEN
     FROM ORDENES_VENTA
     WHERE OVE_CONSECUTIVO = CONSECUTIVO;
   R_ORDEN_V  C_ORDEN_VENTA%ROWTYPE;

 PRECIO NUMBER;

BEGIN
   IF TIPO_OPERACION = 'C' THEN
    OPEN C_PRECIO_ORIGEN_C;
    FETCH C_PRECIO_ORIGEN_C INTO R_PRECIO_C;

          IF C_PRECIO_ORIGEN_C%FOUND THEN
             PRECIO := R_PRECIO_C.HOC_VALOR_ANTERIOR;
          ELSE
              OPEN C_ORDEN_COMPRA;
              FETCH C_ORDEN_COMPRA INTO R_ORDEN_C;
                 PRECIO := R_ORDEN_C.OCO_PRECIO_LIMITE_O_MARGEN;
              CLOSE C_ORDEN_COMPRA;
          END IF;
    CLOSE C_PRECIO_ORIGEN_C;

   ELSIF  TIPO_OPERACION = 'V' THEN
      OPEN C_PRECIO_ORIGEN_V;
      FETCH C_PRECIO_ORIGEN_V INTO R_PRECIO_V;

          IF C_PRECIO_ORIGEN_V%FOUND THEN
             PRECIO := R_PRECIO_V.HOV_VALOR_ANTERIOR;
          ELSE
              OPEN C_ORDEN_VENTA;
              FETCH C_ORDEN_VENTA INTO R_ORDEN_V;
                 PRECIO := R_ORDEN_V.OVE_PRECIO_LIMITE_O_MARGEN;
              CLOSE C_ORDEN_VENTA;
          END IF;
    CLOSE C_PRECIO_ORIGEN_V;
   END IF;
    RETURN PRECIO;
 END;

FUNCTION FECH_PERMAN_ORIGEN (CONSECUTIVO NUMBER , TIPO_OPERACION VARCHAR2 )
RETURN VARCHAR2 IS

   CURSOR C_FECHA_ORIGEN_C IS
      SELECT  HOC_VALOR_ANTERIOR,
              HOC_CAMPO
      FROM HISTORICO_ORDENES_COMPRA HOC1
      WHERE HOC_OCO_CONSECUTIVO = CONSECUTIVO
      AND HOC_CONSECUTIVO = (SELECT MIN(HOC_CONSECUTIVO)
                             FROM  HISTORICO_ORDENES_COMPRA HOC2
                             WHERE HOC2.HOC_OCO_CONSECUTIVO = CONSECUTIVO
                             AND HOC_CAMPO IN ('OCO_FECHA_PERMANENCIA'));
   R_FECHA_C C_FECHA_ORIGEN_C%ROWTYPE;

   CURSOR C_ORDEN_COMPRA IS
     SELECT  TO_CHAR(OCO_FECHA_PERMANENCIA,'DD/MM/YYYY') OCO_FECHA_PERMANENCIA
     FROM ORDENES_COMPRA
     WHERE OCO_CONSECUTIVO = CONSECUTIVO;
   R_ORDEN_C  C_ORDEN_COMPRA%ROWTYPE;

    CURSOR C_FECHA_ORIGEN_V IS
      SELECT  HOV_VALOR_ANTERIOR,
              HOV_CAMPO
      FROM HISTORICO_ORDENES_VENTA HOV1
      WHERE HOV_OVE_CONSECUTIVO = CONSECUTIVO
      AND HOV_CONSECUTIVO = (SELECT MIN(HOV_CONSECUTIVO)
                             FROM  HISTORICO_ORDENES_VENTA HOV2
                             WHERE HOV2.HOV_OVE_CONSECUTIVO = CONSECUTIVO
                             AND HOV_CAMPO IN ('OVE_FECHA_PERMANENCIA'));
   R_FECHA_V C_FECHA_ORIGEN_V%ROWTYPE;

   CURSOR C_ORDEN_VENTA IS
     SELECT  TO_CHAR(OVE_FECHA_PERMANENCIA,'DD/MM/YYYY') OVE_FECHA_PERMANENCIA
     FROM ORDENES_VENTA
     WHERE OVE_CONSECUTIVO = CONSECUTIVO;
   R_ORDEN_V  C_ORDEN_VENTA%ROWTYPE;

 FECHA VARCHAR2(11);

BEGIN
   IF TIPO_OPERACION = 'C' THEN
    OPEN C_FECHA_ORIGEN_C;
    FETCH C_FECHA_ORIGEN_C INTO R_FECHA_C;

          IF C_FECHA_ORIGEN_C%FOUND THEN
             FECHA := SUBSTR(R_FECHA_C.HOC_VALOR_ANTERIOR,0,11);
          ELSE
              OPEN C_ORDEN_COMPRA;
              FETCH C_ORDEN_COMPRA INTO R_ORDEN_C;
                 FECHA  := R_ORDEN_C.OCO_FECHA_PERMANENCIA;
              CLOSE C_ORDEN_COMPRA;

          END IF;
    CLOSE C_FECHA_ORIGEN_C;

   ELSIF  TIPO_OPERACION = 'V' THEN
      OPEN C_FECHA_ORIGEN_V;
      FETCH C_FECHA_ORIGEN_V INTO R_FECHA_V;

          IF C_FECHA_ORIGEN_V%FOUND THEN
             FECHA := SUBSTR(R_FECHA_V.HOV_VALOR_ANTERIOR,0,11);
          ELSE
              OPEN C_ORDEN_VENTA;
              FETCH C_ORDEN_VENTA INTO R_ORDEN_V;
                 FECHA := R_ORDEN_V.OVE_FECHA_PERMANENCIA;
              CLOSE C_ORDEN_VENTA;

          END IF;
    CLOSE C_FECHA_ORIGEN_V;
   END IF;
    RETURN FECHA;
 END;

----
 PROCEDURE PR_ISIN_COMPRA_ACC(P_ENA_MNEMONICO    IN  VARCHAR2,
                             P_PER_NUM_IDEN     IN  VARCHAR2,
                             P_PER_TID_CODIGO   IN  VARCHAR2,
                             P_ISIN             OUT VARCHAR2,
                             P_CREA_SALDO       OUT VARCHAR2,
                             P_MENSAJE          OUT VARCHAR2) IS
  CURSOR CFC IS
     SELECT COUNT(*)
     FROM FUNGIBLES FUG,CUENTAS_FUNGIBLE_CLIENTE CFC
     WHERE FUG.FUG_ISI_MNEMONICO = CFC.CFC_FUG_ISI_MNEMONICO
       AND FUG.FUG_MNEMONICO     = CFC.CFC_FUG_MNEMONICO
       AND FUG.FUG_ESTADO = 'A'
       AND FUG.FUG_ENA_MNEMONICO = P_ENA_MNEMONICO
       AND FUG.FUG_TIPO = 'ACC'
       AND CFC.CFC_CCC_CLI_PER_NUM_IDEN   = P_PER_NUM_IDEN
       AND CFC.CFC_CCC_CLI_PER_TID_CODIGO = P_PER_TID_CODIGO
       AND CFC.CFC_ESTADO = 'A';

  CURSOR FUG IS
     SELECT COUNT(*),FUG_ENA_MNEMONICO
     FROM FUNGIBLES
     WHERE FUG_ENA_MNEMONICO = P_ENA_MNEMONICO
      AND  FUG_TIPO = 'ACC'
      AND  FUG_ESTADO = 'A'
      GROUP BY FUG_ENA_MNEMONICO;

  CURSOR FUG_EXISTE IS
     SELECT FUG_ENA_MNEMONICO,FUG_ISI_MNEMONICO
     FROM FUNGIBLES
     WHERE FUG_ENA_MNEMONICO = P_ENA_MNEMONICO
      AND  FUG_TIPO = 'ACC'
      AND  FUG_ESTADO = 'A';

  V_CONTADOR_CFC  NUMBER(5);
  V_CONTADOR_FUG  NUMBER(5);
  V_ENA_MNEMONICO FUNGIBLES.FUG_ENA_MNEMONICO%TYPE;
  V_ISI_MNEMONICO FUNGIBLES.FUG_ISI_MNEMONICO%TYPE;

BEGIN
   -- CASOS
   -- 1. EXISTE EN CFC  RETORNA P_CREA_SALDO = 'N'
   -- 2. NO EXISTE EN CFC RETORNA P_CREA_SALDO = 'S'

   V_CONTADOR_FUG   := 0;
   V_CONTADOR_CFC   := 0;
   V_ENA_MNEMONICO  := NULL;
   P_MENSAJE        := NULL;
   V_ISI_MNEMONICO  := NULL;

   OPEN CFC;
   FETCH CFC INTO V_CONTADOR_CFC;
   CLOSE CFC;

   V_CONTADOR_CFC := NVL(V_CONTADOR_CFC,0);

   IF V_CONTADOR_CFC >= 1 THEN
      P_ISIN       := NULL;
      P_MENSAJE    := NULL;
      P_CREA_SALDO := 'N';
   ELSE
      OPEN FUG;
      FETCH FUG INTO V_CONTADOR_FUG,V_ENA_MNEMONICO;
      CLOSE FUG;

      V_CONTADOR_FUG := NVL(V_CONTADOR_FUG,0);
      IF V_CONTADOR_FUG = 0 THEN
         P_ISIN       := NULL;
         P_MENSAJE    := 'NO EXISTE FUNGIBLE';
         P_CREA_SALDO := 'N';
      ELSIF V_CONTADOR_FUG = 1 THEN
        V_ENA_MNEMONICO := NULL;
        V_ISI_MNEMONICO := NULL;
        OPEN FUG_EXISTE;
        FETCH FUG_EXISTE INTO V_ENA_MNEMONICO,V_ISI_MNEMONICO;
        CLOSE FUG_EXISTE;

        P_ISIN       := V_ISI_MNEMONICO;
        P_MENSAJE    := 'EXISTE FUNGIBLE';
        P_CREA_SALDO := 'S';
      END IF;
   END IF;
END PR_ISIN_COMPRA_ACC;

FUNCTION F_LIC_VALOR_NETO_CON_IVA(
    P_NUMERO_OPERACION  IN LIQUIDACIONES_COMERCIAL.LIC_NUMERO_OPERACION%TYPE,
    P_NUMERO_FRACCION   IN LIQUIDACIONES_COMERCIAL.LIC_NUMERO_FRACCION%TYPE,
    P_TIPO_OPERACION  IN LIQUIDACIONES_COMERCIAL.LIC_TIPO_OPERACION%TYPE,
    P_BOL_MNEMONICO   IN LIQUIDACIONES_COMERCIAL.LIC_BOL_MNEMONICO%TYPE
)
  RETURN LIQUIDACIONES_COMERCIAL.LIC_VOLUMEN_NETO_FRACCION%TYPE
IS
  CURSOR C_LIC IS
  SELECT LIC_NIT_1
    ,LIC_TIPO_IDENTIFICACION_1
    ,LIC_VOLUMEN_NETO_FRACCION
    ,LIC_VALOR_COMISION
    ,LIC_MERCADO
    ,LIC_FECHA_OPERACION
    ,LIC_VALOR_EXTEMPO
    ,LIC_MNEMOTECNICO_TITULO
    ,LIC_DESCUENTO
    ,LIC_RETENCION_FUENTE
    ,LIC_TRASLADO_RTE_FTE
    ,LIC_VOLUMEN_FRACCION
    ,LIC_POSICION_EXTEMPO
  FROM LIQUIDACIONES_COMERCIAL
  WHERE LIC_NUMERO_OPERACION = P_NUMERO_OPERACION
    AND LIC_NUMERO_FRACCION = P_NUMERO_FRACCION
    AND LIC_TIPO_OPERACION = P_TIPO_OPERACION
    AND LIC_BOL_MNEMONICO = P_BOL_MNEMONICO;

  CURSOR C_EXCENTO_IVA(P_NUM_IDEN   VARCHAR2,P_TID_CODIGO VARCHAR2) IS
    SELECT CLI_EXCENTO_IVA
    FROM   CLIENTES
    WHERE  CLI_PER_NUM_IDEN = P_NUM_IDEN
    AND    CLI_PER_TID_CODIGO = P_TID_CODIGO;

  --CONSULTA CONSTANTES PARA CALCULO IVA
  CURSOR C_CON(P_CON_MNEMONICO VARCHAR) IS
    SELECT CON_VALOR,CON_VALOR_CHAR
    FROM CONSTANTES
    WHERE CON_MNEMONICO = P_CON_MNEMONICO;

  R_EXCENTO_IVA     C_EXCENTO_IVA%ROWTYPE;
  R_LIC           C_LIC%ROWTYPE;
  R_CON           C_CON%ROWTYPE;
  V_CON_IVA       NUMBER(22,4);
  V_IVA             NUMBER(22,4);
  VALOR_NETO        NUMBER(22,4);
  VALOR_NETO_CON_IVA    NUMBER(22,4);
  P_SIGNO_IVA_COMISION  NUMBER(2);
  V_SIGNO_EXTEMPO     NUMBER(2);

BEGIN

  OPEN C_LIC;
    FETCH C_LIC INTO R_LIC;
    CLOSE C_LIC;

  --VALIDAR SI EL CLIENTE ES EXCENTO DE IVA
  OPEN C_EXCENTO_IVA(R_LIC.LIC_NIT_1, R_LIC.LIC_TIPO_IDENTIFICACION_1);
    FETCH C_EXCENTO_IVA INTO R_EXCENTO_IVA;
    CLOSE C_EXCENTO_IVA;

  IF R_EXCENTO_IVA.CLI_EXCENTO_IVA = 'S' THEN
    V_CON_IVA := 0;
  ELSE
    OPEN C_CON('IVC');
      FETCH C_CON INTO R_CON;
      CLOSE C_CON;

    V_CON_IVA := R_CON.CON_VALOR;
  END IF;

  --SIGNO DEL IVA
  IF P_TIPO_OPERACION = 'C' THEN
    P_SIGNO_IVA_COMISION := 1;
  ELSE
    P_SIGNO_IVA_COMISION := -1;
  END IF;

  V_IVA := V_CON_IVA * P_SIGNO_IVA_COMISION * R_LIC.LIC_VALOR_COMISION;
  VALOR_NETO := R_LIC.LIC_VOLUMEN_NETO_FRACCION + R_LIC.LIC_RETENCION_FUENTE + R_LIC.LIC_TRASLADO_RTE_FTE;
  VALOR_NETO_CON_IVA := VALOR_NETO + V_IVA;

  --AJUSTE SANCION EXTEMPORANEA
  IF R_LIC.LIC_VALOR_EXTEMPO IS NOT NULL AND R_LIC.LIC_VALOR_EXTEMPO != 0 THEN
    IF (P_TIPO_OPERACION = 'C' AND R_LIC.LIC_POSICION_EXTEMPO = 'A') OR
       (P_TIPO_OPERACION = 'V' AND R_LIC.LIC_POSICION_EXTEMPO = 'S') THEN
        V_SIGNO_EXTEMPO := -1;
    ELSIF (P_TIPO_OPERACION = 'C' AND R_LIC.LIC_POSICION_EXTEMPO = 'S') OR
        (P_TIPO_OPERACION = 'V' AND R_LIC.LIC_POSICION_EXTEMPO = 'A') THEN
        V_SIGNO_EXTEMPO := 1;
    END IF;
    VALOR_NETO_CON_IVA := VALOR_NETO_CON_IVA + (R_LIC.LIC_VALOR_EXTEMPO * V_SIGNO_EXTEMPO);
  END IF;
  VALOR_NETO_CON_IVA := ROUND(VALOR_NETO_CON_IVA,2);

  RETURN VALOR_NETO_CON_IVA;
END F_LIC_VALOR_NETO_CON_IVA;

PROCEDURE PR_ORDEN_A_COMPLEMENTAR(P_FOLIO_BOLSA          IN VARCHAR2
                                 ,P_CLI_PER_NUM_IDEN     IN VARCHAR2
                                 ,P_CLI_PER_TID_CODIGO   IN VARCHAR2
                                 ,P_CUENTA_DECEVAL       IN NUMBER
                                 ,P_ID_ORDEN             IN NUMBER
                                 ,P_TIPO_ORDEN           IN VARCHAR2
                                 ,P_PORCENTAJE_COMISION  IN NUMBER
                                 ,P_USUARIO_SAE          IN VARCHAR2
                                 ,P_ESPECIAL_FIDUCIARIO  IN VARCHAR2 
                                 ,P_CANTIDAD             IN NUMBER
                                 ,P_PRECIO               IN NUMBER
                                 ,P_MNEMOTECNICO         IN VARCHAR2
                                 ,P_USUARIO              IN VARCHAR2
                                 ,P_NOMBRE               IN VARCHAR2
                                 ,P_APELLIDO             IN VARCHAR2
                                 ,P_CANAL_ORIGEN         IN VARCHAR2
                                 ,P_VALOR_COMISION       IN NUMBER
                                 ,P_ERRORES              OUT NUMBER) AS

  BEGIN
    P_ERRORES := 0;

    INSERT INTO NOTIFICACIONES_ORDENES_CMA(
                                 NOC_CONSECUTIVO
                                ,NOC_FOLIO_BOLSA
                                ,NOC_CLI_PER_NUM_IDEN
                                ,NOC_CLI_PER_TID_CODIGO
                                ,NOC_CUENTA_DECEVAL
                                ,NOC_ID_COEASY
                                ,NOC_TIPO_NEGOCIO
                                ,NOC_PORCENTAJE_COMISION
                                ,NOC_USUARIO_SAE
                                ,NOC_ESPECIAL_FIDUCIARIO
                                ,NOC_CANTIDAD
                                ,NOC_PRECIO
                                ,NOC_ESTADO
                                ,NOC_FECHA_INGRESO
                                ,NOC_FECHA_ENTREGA
                                ,NOC_ENA_MNEMONICO
                                ,NOC_CANAL_ORIGEN
                                ,NOC_PER_NOMBRE_USUARIO
                                ,NOC_PER_NOMBRE
                                ,NOC_PER_APELLIDOS
                                ,NOC_COMISION_ESPECIAL_ETRADE
                ,NOC_VALOR_COMISION)
                           VALUES
                           (
                                 NOC_SEQ.NEXTVAL                  --NOC_CONSECUTIVO
                                ,P_FOLIO_BOLSA                    --NOC_FOLIO_BOLSA
                                ,P_CLI_PER_NUM_IDEN               --NOC_CLI_PER_NUM_IDEN
                                ,P_CLI_PER_TID_CODIGO             --NOC_CLI_PER_TID_CODIGO
                                ,P_CUENTA_DECEVAL                 --NOC_CUENTA_DECEVAL
                                ,P_ID_ORDEN                       --NOC_ID_COEASY
                                ,P_TIPO_ORDEN                     --NOC_TIPO_NEGOCIO
                                ,TRUNC(P_PORCENTAJE_COMISION,3)   --NOC_PORCENTAJE_COMISION
                                ,P_USUARIO_SAE                    --NOC_USUARIO_SAE
                                ,P_ESPECIAL_FIDUCIARIO            --NOC_ESPECIAL_FIDUCIARIO
                                ,P_CANTIDAD                       --NOC_CANTIDAD
                                ,P_PRECIO                         --NOC_PRECIO
                                ,'POR_PROCESAR'                   --NOC_ESTADO
                                ,SYSDATE                          --NOC_FECHA_INGRESO
                                ,NULL                             --NOC_FECHA_ENTREGA
                                ,P_MNEMOTECNICO                   --NOC_ENA_MNEMONICO
                                ,P_CANAL_ORIGEN                   --NOC_CANAL_ORIGEN
                                ,P_USUARIO                        --NOC_PER_NOMBRE_USUARIO
                                ,P_NOMBRE                         --NOC_PER_NOMBRE
                                ,P_APELLIDO                       --NOC_PER_APELLIDOS
                                ,'N'                              --NOC_COMISION_ESPECIAL_ETRADE
                ,P_VALOR_COMISION                 --NOC_VALOR_COMISION
                           );
    COMMIT;

    EXCEPTION
      WHEN OTHERS THEN
        P_ERRORES := 1;

  END PR_ORDEN_A_COMPLEMENTAR;

END P_ORDENES_COMERCIAL;

/

  GRANT EXECUTE ON "PROD"."P_ORDENES_COMERCIAL" TO "R_FIXBROKER";
  GRANT EXECUTE ON "PROD"."P_ORDENES_COMERCIAL" TO "M_OP_SOPORTE_JEFE";
  GRANT EXECUTE ON "PROD"."P_ORDENES_COMERCIAL" TO "COE_RECURSOS";
  GRANT EXECUTE ON "PROD"."P_ORDENES_COMERCIAL" TO "RESOURCE";
  GRANT EXECUTE ON "PROD"."P_ORDENES_COMERCIAL" TO "NOCTURNO";
