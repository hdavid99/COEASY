--------------------------------------------------------
--  DDL for Package Body P_ORDENES_COMERCIAL
--------------------------------------------------------

  CREATE OR REPLACE EDITIONABLE PACKAGE BODY "PROD"."P_ORDENES_COMERCIAL" IS
-- Sub-Program Units
/* Inserta cambios al histżrico de ordenes de compra */
-- PL/SQL Block
-- Sub-Program Units
PROCEDURE INSERTAR_HOC
 (P_OCO_BOL_MNEMONICO     IN HISTORICO_ORDENES_COMPRA.HOC_OCO_BOL_MNEMONICO%TYPE
 ,P_OCO_COC_CTO_MNEMONICO IN HISTORICO_ORDENES_COMPRA.HOC_OCO_COC_CTO_MNEMONICO%TYPE
 ,P_OCO_CONSECUTIVO       IN HISTORICO_ORDENES_COMPRA.HOC_OCO_CONSECUTIVO%TYPE
 ,P_FECHA                 IN HISTORICO_ORDENES_COMPRA.HOC_FECHA%TYPE
 ,P_CAMPO                 IN HISTORICO_ORDENES_COMPRA.HOC_CAMPO%TYPE
 ,P_USUARIO               IN HISTORICO_ORDENES_COMPRA.HOC_USUARIO%TYPE
 ,P_TERMINAL              IN HISTORICO_ORDENES_COMPRA.HOC_TERMINAL%TYPE
 ,P_ACCION                IN HISTORICO_ORDENES_COMPRA.HOC_ACCION%TYPE
 ,P_VALOR_ANTERIOR        IN HISTORICO_ORDENES_COMPRA.HOC_VALOR_ANTERIOR%TYPE
 ,P_VALOR_POSTERIOR       IN HISTORICO_ORDENES_COMPRA.HOC_VALOR_POSTERIOR%TYPE
 )
 IS
-- PL/SQL Specification
-- PL/SQL Block
-- PL/SQL Block
BEGIN
  INSERT INTO HISTORICO_ORDENES_COMPRA
    (HOC_CONSECUTIVO,
    HOC_OCO_BOL_MNEMONICO,
    HOC_OCO_COC_CTO_MNEMONICO,
    HOC_OCO_CONSECUTIVO,
    HOC_FECHA,
    HOC_CAMPO,
    HOC_USUARIO,
    HOC_TERMINAL,
    HOC_ACCION,
    HOC_VALOR_ANTERIOR,
    HOC_VALOR_POSTERIOR)
  VALUES
    (HOC_SEQ.NEXTVAL,
    P_OCO_BOL_MNEMONICO,
    P_OCO_COC_CTO_MNEMONICO,
    P_OCO_CONSECUTIVO,
    P_FECHA,
    P_CAMPO,
    P_USUARIO,
    P_TERMINAL,
    P_ACCION,
    P_VALOR_ANTERIOR,
    P_VALOR_POSTERIOR);
END INSERTAR_HOC;
PROCEDURE INSERTAR_HOV
 (P_OVE_BOL_MNEMONICO     IN HISTORICO_ORDENES_VENTA.HOV_OVE_BOL_MNEMONICO%TYPE
 ,P_OVE_COC_CTO_MNEMONICO IN HISTORICO_ORDENES_VENTA.HOV_OVE_COC_CTO_MNEMONICO%TYPE
 ,P_OVE_CONSECUTIVO       IN HISTORICO_ORDENES_VENTA.HOV_OVE_CONSECUTIVO%TYPE
 ,P_FECHA                 IN HISTORICO_ORDENES_VENTA.HOV_FECHA%TYPE
 ,P_CAMPO                 IN HISTORICO_ORDENES_VENTA.HOV_CAMPO%TYPE
 ,P_USUARIO               IN HISTORICO_ORDENES_VENTA.HOV_USUARIO%TYPE
 ,P_TERMINAL              IN HISTORICO_ORDENES_VENTA.HOV_TERMINAL%TYPE
 ,P_ACCION                IN HISTORICO_ORDENES_VENTA.HOV_ACCION%TYPE
 ,P_VALOR_ANTERIOR        IN HISTORICO_ORDENES_VENTA.HOV_VALOR_ANTERIOR%TYPE
 ,P_VALOR_POSTERIOR       IN HISTORICO_ORDENES_VENTA.HOV_VALOR_POSTERIOR%TYPE
 )
 IS
-- PL/SQL Specification
-- PL/SQL Block
-- PL/SQL Block
BEGIN
  INSERT INTO HISTORICO_ORDENES_VENTA
    (HOV_CONSECUTIVO,
    HOV_OVE_BOL_MNEMONICO,
    HOV_OVE_COC_CTO_MNEMONICO,
    HOV_OVE_CONSECUTIVO,
    HOV_FECHA,
    HOV_CAMPO,
    HOV_USUARIO,
    HOV_TERMINAL,
    HOV_ACCION,
    HOV_VALOR_ANTERIOR,
    HOV_VALOR_POSTERIOR)
  VALUES
    (HOV_SEQ.NEXTVAL,
    P_OVE_BOL_MNEMONICO,
    P_OVE_COC_CTO_MNEMONICO,
    P_OVE_CONSECUTIVO,
    P_FECHA,
    P_CAMPO,
    P_USUARIO,
    P_TERMINAL,
    P_ACCION,
    P_VALOR_ANTERIOR,
    P_VALOR_POSTERIOR);
END INSERTAR_HOV;
PROCEDURE ANULACION_CANCELACION_ORDENES
 IS
   CURSOR C_DIAS(P_DIA DATE) IS
      SELECT 'X'
      FROM   DIAS_NO_HABILES
      WHERE  DNH_FECHA = TRUNC(P_DIA);
   CONTADOR  NUMBER;
   FECHA     DATE;
   DATO      VARCHAR2(1);
   CURSOR C_VIGENCIAS(P_VIO_CTO_MNEMONICO VIGENCIAS_ORDEN.VIO_CTO_MNEMONICO%TYPE) IS
      SELECT VIO_MNEMONICO
            ,VIO_DESCRIPCION
      FROM   VIGENCIAS_ORDEN
      WHERE  VIO_CTO_MNEMONICO = P_VIO_CTO_MNEMONICO
      ORDER BY 1;
   VIO1   C_VIGENCIAS%ROWTYPE;
   CURSOR C_CONSTANTE(P_CON_MNEMONICO CONSTANTES.CON_MNEMONICO%TYPE) IS
     SELECT CON_VALOR
     FROM   CONSTANTES
     WHERE  CON_MNEMONICO = P_CON_MNEMONICO;

    -- SMORALES - VAGTUS021787 - Anulacion Eximentes
   CURSOR C_ANULACION_EXIMENTES IS
      SELECT OFP_CONSECUTIVO
            ,OFP_OCO_CONSECUTIVO
      FROM   ORDENES_COMPRA
            ,OPERACIONES_FUERA_PERFIL
      WHERE  OPERACIONES_FUERA_PERFIL.OFP_OCO_CONSECUTIVO = ORDENES_COMPRA.OCO_CONSECUTIVO
      AND    ORDENES_COMPRA.OCO_EOC_MNEMONICO = 'ANU'
      AND    OPERACIONES_FUERA_PERFIL.OFP_ESTADO  NOT IN 'ANU'
      AND    OCO_FECHA_Y_HORA < TRUNC(SYSDATE);

      R_ANULACION C_ANULACION_EXIMENTES%ROWTYPE;

   -- VARIABLES PARA MAIL
   conn                    utl_smtp.connection;
   req                     utl_http.req;
   resp                    utl_http.resp;
   data                    RAW(200);
   NOM_ERROR               VARCHAR2(80);
   DIAS                    NUMBER;
   v_constante_saldo       NUMBER;
BEGIN
   /* Anulaciżn de ordenes de compra y venta OTC que quedaron colocadas */
   UPDATE ORDENES_COMPRA
   SET    OCO_EOC_MNEMONICO = 'ANU'
         ,OCO_FECHA_ANU_CAN = SYSDATE
         ,OCO_RAZON_ANU_CAN = 'PROC.AUT. ANULACION NEGOCIOS OTC'
         ,OCO_ANU_CAN_POR = 'AUTOMATICO'
         ,OCO_TERMINAL_ANU_CAN  = 'AUTOMATICO'
   WHERE  OCO_ORDEN_NEGOCIO = 'N'
   AND    OCO_BOL_MNEMONICO = 'MEC'
   AND    OCO_EOC_MNEMONICO IN ('COL','AUT')
   AND    OCO_FECHA_Y_HORA < TRUNC(SYSDATE);

   FOR OVE1 IN (SELECT OVE_BOL_MNEMONICO
                      ,OVE_COC_CTO_MNEMONICO
                      ,OVE_CONSECUTIVO
                FROM   ORDENES_VENTA
                WHERE  OVE_ORDEN_NEGOCIO = 'N'
                AND    OVE_BOL_MNEMONICO = 'MEC'
                AND    OVE_EOC_MNEMONICO  IN ('COL','AUT')
                AND    OVE_FECHA_Y_HORA < TRUNC(SYSDATE)) LOOP
      P_ORDENES_COMERCIAL.ANULACION_VENTAS
         (P_OVE_BOL_MNEMONICO     => OVE1.OVE_BOL_MNEMONICO
         ,P_OVE_COC_CTO_MNEMONICO => OVE1.OVE_COC_CTO_MNEMONICO
         ,P_OVE_CONSECUTIVO       => OVE1.OVE_CONSECUTIVO
         ,P_OVE_EOC_MNEMONICO     => 'ANU'
         ,P_OVE_RAZON_ANU_CAN     => 'PROC.AUT. ANULACION NEGOCIOS OTC');
   END LOOP;
   /* Cancelaciżn de ordenes de compra y venta OTC que quedaron parcialmente aplicadas */
   UPDATE ORDENES_COMPRA
   SET    OCO_EOC_MNEMONICO = 'CAN'
         ,OCO_FECHA_ANU_CAN = SYSDATE
         ,OCO_RAZON_ANU_CAN = 'PROC.AUT. CANCELACION NEGOCIOS OTC'
         ,OCO_ANU_CAN_POR = 'AUTOMATICO'
         ,OCO_TERMINAL_ANU_CAN  = 'AUTOMATICO'
   WHERE  OCO_ORDEN_NEGOCIO = 'N'
   AND    OCO_BOL_MNEMONICO = 'MEC'
   AND    OCO_EOC_MNEMONICO = 'PAP'
   AND    OCO_FECHA_Y_HORA < TRUNC(SYSDATE);
   FOR OVE1 IN (SELECT OVE_BOL_MNEMONICO
                      ,OVE_COC_CTO_MNEMONICO
                      ,OVE_CONSECUTIVO
                FROM   ORDENES_VENTA
                WHERE  OVE_ORDEN_NEGOCIO = 'N'
                AND    OVE_BOL_MNEMONICO = 'MEC'
                AND    OVE_EOC_MNEMONICO = 'PAP'
                AND    OVE_FECHA_Y_HORA < TRUNC(SYSDATE)) LOOP
      P_ORDENES_COMERCIAL.ANULACION_VENTAS
         (P_OVE_BOL_MNEMONICO     => OVE1.OVE_BOL_MNEMONICO
         ,P_OVE_COC_CTO_MNEMONICO => OVE1.OVE_COC_CTO_MNEMONICO
         ,P_OVE_CONSECUTIVO       => OVE1.OVE_CONSECUTIVO
         ,P_OVE_EOC_MNEMONICO     => 'CAN'
         ,P_OVE_RAZON_ANU_CAN     => 'PROC.AUT. CANCELACION NEGOCIOS OTC');
   END LOOP;
   COMMIT;
   v_constante_saldo := 0;
   OPEN C_CONSTANTE('COS');
   FETCH C_CONSTANTE INTO v_constante_saldo;
   CLOSE C_CONSTANTE;
   /* Anulacion de ordenes LEO RF y ACC por saldo inferior*/
   UPDATE ordenes_compra
   SET    OCO_EOC_MNEMONICO = 'CAN'
         ,OCO_FECHA_ANU_CAN = SYSDATE
         ,OCO_RAZON_ANU_CAN = 'PROC.AUT.CAN.ORDENES SALDO MENOR PESOS'
         ,OCO_ANU_CAN_POR = 'AUTOMATICO'
         ,OCO_TERMINAL_ANU_CAN = 'AUTOMATICO'
   WHERE  OCO_BOL_MNEMONICO = 'COL'
   AND    OCO_TIPO_NOMINAL_O_PESOS = 'P'
   AND    OCO_COC_CCO_MNEMONICO = 'ORD'
   AND    OCO_COC_CTE_MNEMONICO = 'NA'
   AND    OCO_EOC_MNEMONICO = 'PAP'
   AND    OCO_FECHA_Y_HORA < TRUNC(SYSDATE)
   AND    (OCO_NOMINAL_O_PESOS-nvl((SELECT SUM(LIC_VOLUMEN_NETO_FRACCION)
                                    FROM   LIQUIDACIONES_COMERCIAL
                                    WHERE  LIC_BOL_MNEMONICO = OCO_BOL_MNEMONICO
                                    AND    LIC_OCO_COC_CTO_MNEMONICO = OCO_COC_CTO_MNEMONICO
                                    AND    LIC_OCO_CONSECUTIVO = OCO_CONSECUTIVO
                                    AND    LIC_TIPO_OPERACION = 'V'
                                    AND    LIC_ELI_MNEMONICO = 'APL'),0)) <= V_CONSTANTE_SALDO;
   FOR OVE1 IN (SELECT OVE_BOL_MNEMONICO
                      ,OVE_COC_CTO_MNEMONICO
                      ,OVE_CONSECUTIVO
                FROM   ORDENES_VENTA
                WHERE  OVE_BOL_MNEMONICO = 'COL'
                AND    OVE_TIPO_NOMINAL_O_PESOS = 'P'
                AND    OVE_COC_CCO_MNEMONICO = 'ORD'
                AND    OVE_COC_CTE_MNEMONICO = 'NA'
                AND    OVE_EOC_MNEMONICO = 'PAP'
                AND    OVE_FECHA_Y_HORA < TRUNC(SYSDATE)
                AND    (OVE_NOMINAL_O_PESOS-nvl((SELECT SUM(LIC_VOLUMEN_NETO_FRACCION)
                                                 FROM   LIQUIDACIONES_COMERCIAL
                                                 WHERE  LIC_BOL_MNEMONICO = OVE_BOL_MNEMONICO
                                                 AND    LIC_OVE_COC_CTO_MNEMONICO = OVE_COC_CTO_MNEMONICO
                                                 AND    LIC_OVE_CONSECUTIVO = OVE_CONSECUTIVO
                                                 AND    LIC_TIPO_OPERACION = 'V'
                                                 AND    LIC_ELI_MNEMONICO = 'APL'),0)) <= V_CONSTANTE_SALDO) LOOP
      P_ORDENES_COMERCIAL.ANULACION_VENTAS
         (P_OVE_BOL_MNEMONICO     => OVE1.OVE_BOL_MNEMONICO
         ,P_OVE_COC_CTO_MNEMONICO => OVE1.OVE_COC_CTO_MNEMONICO
         ,P_OVE_CONSECUTIVO       => OVE1.OVE_CONSECUTIVO
         ,P_OVE_EOC_MNEMONICO     => 'CAN'
         ,P_OVE_RAZON_ANU_CAN     => 'PROC.AUT.CAN.ORDENES SALDO MENOR PESOS');
   END LOOP;
   COMMIT;
   /* Anulaciżn y cancelaciżn de ordenes renta fija para ordenes segun vigencia.
      Se utiliza el algoritmo anterior para ordenes de acciones */
   OPEN C_VIGENCIAS('RF');
   FETCH C_VIGENCIAS INTO VIO1;
   WHILE C_VIGENCIAS%FOUND LOOP
      IF VIO1.VIO_MNEMONICO = 'PER' THEN
         DIAS := 6;
      ELSE
         DIAS := TO_NUMBER(VIO1.VIO_MNEMONICO);
      END IF;
      CONTADOR := 0;
      SELECT SYSDATE INTO FECHA FROM DUAL;
      WHILE CONTADOR < DIAS LOOP
         FECHA := FECHA - 1;
         IF TO_CHAR(FECHA,'D') IN ('1','7') THEN
            NULL;
         ELSE
            OPEN C_DIAS(FECHA);
            FETCH C_DIAS INTO DATO;
            IF C_DIAS%FOUND THEN
               NULL;
            ELSE
               CONTADOR := CONTADOR + 1;
            END IF;
            CLOSE C_DIAS;
         END IF;
      END LOOP;
      /* Anulaciżn orden compra y venta renta fija */
      UPDATE ORDENES_COMPRA
      SET    OCO_EOC_MNEMONICO = 'ANU'
            ,OCO_FECHA_ANU_CAN = SYSDATE
            ,OCO_RAZON_ANU_CAN = 'PROCESO AUT. DE ANULACION DE ORDENES'
            ,OCO_ANU_CAN_POR = 'AUTOMATICO'
            ,OCO_TERMINAL_ANU_CAN = 'AUTOMATICO'
      WHERE  OCO_COC_CTO_MNEMONICO = 'RF'
      AND    OCO_EOC_MNEMONICO IN ('COL','AUT')
      AND    OCO_ORDEN_NEGOCIO = 'O'
      AND    OCO_VIO_MNEMONICO = VIO1.VIO_MNEMONICO
      AND    TRUNC(OCO_FECHA_Y_HORA) < TRUNC(FECHA);
      FOR OVE1 IN (SELECT OVE_BOL_MNEMONICO
                         ,OVE_COC_CTO_MNEMONICO
                         ,OVE_CONSECUTIVO
                   FROM   ORDENES_VENTA
                   WHERE  OVE_COC_CTO_MNEMONICO = 'RF'
                   AND    OVE_EOC_MNEMONICO IN ('COL','AUT')
                   AND    OVE_ORDEN_NEGOCIO = 'O'
                   AND    OVE_VIO_MNEMONICO = VIO1.VIO_MNEMONICO
                   AND    TRUNC(OVE_FECHA_Y_HORA) < TRUNC(FECHA)) LOOP
         P_ORDENES_COMERCIAL.ANULACION_VENTAS
            (P_OVE_BOL_MNEMONICO     => OVE1.OVE_BOL_MNEMONICO
            ,P_OVE_COC_CTO_MNEMONICO => OVE1.OVE_COC_CTO_MNEMONICO
            ,P_OVE_CONSECUTIVO       => OVE1.OVE_CONSECUTIVO
            ,P_OVE_EOC_MNEMONICO     => 'ANU'
            ,P_OVE_RAZON_ANU_CAN     => 'PROCESO AUT. DE ANULACION DE ORDENES');
      END LOOP;
      /* Cancelaciżn orden compra y venta renta fija */
      UPDATE ORDENES_COMPRA
      SET    OCO_EOC_MNEMONICO = 'CAN'
            ,OCO_FECHA_ANU_CAN = SYSDATE
            ,OCO_RAZON_ANU_CAN = 'PROCESO AUT. DE CANCELACION DE ORDENES'
            ,OCO_ANU_CAN_POR = 'AUTOMATICO'
            ,OCO_TERMINAL_ANU_CAN = 'AUTOMATICO'
      WHERE  OCO_COC_CTO_MNEMONICO = 'RF'
      AND    OCO_EOC_MNEMONICO = 'PAP'
      AND    OCO_VIO_MNEMONICO = VIO1.VIO_MNEMONICO
      AND    TRUNC(OCO_FECHA_Y_HORA) < TRUNC(FECHA);
      FOR OVE1 IN (SELECT OVE_BOL_MNEMONICO
                         ,OVE_COC_CTO_MNEMONICO
                         ,OVE_CONSECUTIVO
                   FROM   ORDENES_VENTA
                   WHERE  OVE_COC_CTO_MNEMONICO = 'RF'
                   AND    OVE_EOC_MNEMONICO = 'PAP'
                   AND    OVE_ORDEN_NEGOCIO = 'O'
                   AND    OVE_VIO_MNEMONICO = VIO1.VIO_MNEMONICO
                   AND    TRUNC(OVE_FECHA_Y_HORA) < TRUNC(FECHA)) LOOP
         P_ORDENES_COMERCIAL.ANULACION_VENTAS
            (P_OVE_BOL_MNEMONICO     => OVE1.OVE_BOL_MNEMONICO
            ,P_OVE_COC_CTO_MNEMONICO => OVE1.OVE_COC_CTO_MNEMONICO
            ,P_OVE_CONSECUTIVO       => OVE1.OVE_CONSECUTIVO
            ,P_OVE_EOC_MNEMONICO     => 'CAN'
            ,P_OVE_RAZON_ANU_CAN     => 'PROCESO AUT. DE CANCELACION DE ORDENES');
      END LOOP;
      FETCH C_VIGENCIAS INTO VIO1;
   END LOOP;
   CLOSE C_VIGENCIAS;
   COMMIT;
   /* Proceso para la anulaciżn, cancelaciżn de ordenes de ACCIONES cuya vigencia es un dia*/
   UPDATE ORDENES_COMPRA
   SET    OCO_EOC_MNEMONICO = 'ANU'
         ,OCO_FECHA_ANU_CAN = SYSDATE
         ,OCO_RAZON_ANU_CAN = 'PROCESO AUT. DE ANULACION DE ORDENES'
         ,OCO_ANU_CAN_POR = 'AUTOMATICO'
         ,OCO_TERMINAL_ANU_CAN  = 'AUTOMATICO'
   WHERE  OCO_COC_CTO_MNEMONICO = 'ACC'
   AND    OCO_EOC_MNEMONICO IN ('COL','AUT')
   AND    OCO_VIO_MNEMONICO IN ('DIA','HHO','INM','SES')
   AND    OCO_FECHA_Y_HORA < TRUNC(SYSDATE);
   FOR OVE1 IN (SELECT OVE_BOL_MNEMONICO
                      ,OVE_COC_CTO_MNEMONICO
                      ,OVE_CONSECUTIVO
                FROM   ORDENES_VENTA
                WHERE  OVE_COC_CTO_MNEMONICO = 'ACC'
                AND    OVE_EOC_MNEMONICO IN ('COL','AUT')
                AND    OVE_VIO_MNEMONICO IN ('DIA','HHO','INM','SES')
                AND    OVE_FECHA_Y_HORA < TRUNC(SYSDATE)
                /*VAGTUS069751
        AND    (OVE_COC_CCO_MNEMONICO NOT IN ('EXT')
                AND    OVE_COC_CTE_MNEMONICO NOT IN ('OPA')
                AND    OVE_ENA_MNEMONICO NOT IN ('ISAGEN','VALOREM'))*/) LOOP
      P_ORDENES_COMERCIAL.ANULACION_VENTAS
         (P_OVE_BOL_MNEMONICO     => OVE1.OVE_BOL_MNEMONICO
         ,P_OVE_COC_CTO_MNEMONICO => OVE1.OVE_COC_CTO_MNEMONICO
         ,P_OVE_CONSECUTIVO       => OVE1.OVE_CONSECUTIVO
         ,P_OVE_EOC_MNEMONICO     => 'ANU'
         ,P_OVE_RAZON_ANU_CAN     => 'PROCESO AUT. DE ANULACION DE ORDENES');
   END LOOP;
   UPDATE ORDENES_COMPRA
   SET    OCO_EOC_MNEMONICO = 'CAN'
         ,OCO_FECHA_ANU_CAN = SYSDATE
         ,OCO_RAZON_ANU_CAN = 'PROCESO AUT. DE CANCELACION DE ORDENES'
         ,OCO_ANU_CAN_POR = 'AUTOMATICO'
         ,OCO_TERMINAL_ANU_CAN  = 'AUTOMATICO'
   WHERE  OCO_COC_CTO_MNEMONICO = 'ACC'
   AND    OCO_EOC_MNEMONICO = 'PAP'
   AND    OCO_VIO_MNEMONICO IN ('DIA','HHO','INM','SES')
   AND    OCO_FECHA_Y_HORA < TRUNC(SYSDATE);
   FOR OVE1 IN (SELECT OVE_BOL_MNEMONICO
                      ,OVE_COC_CTO_MNEMONICO
                      ,OVE_CONSECUTIVO
                FROM   ORDENES_VENTA
                WHERE  OVE_COC_CTO_MNEMONICO = 'ACC'
                AND    OVE_EOC_MNEMONICO = 'PAP'
                AND    OVE_VIO_MNEMONICO IN ('DIA','HHO','INM','SES')
                AND    OVE_FECHA_Y_HORA < TRUNC(SYSDATE)
                /*VAGTUS069751
        AND    (OVE_COC_CCO_MNEMONICO NOT IN ('EXT')
                AND    OVE_COC_CTE_MNEMONICO NOT IN ('OPA')
                AND    OVE_ENA_MNEMONICO NOT IN ('ISAGEN','VALOREM'))*/) LOOP
      P_ORDENES_COMERCIAL.ANULACION_VENTAS
         (P_OVE_BOL_MNEMONICO     => OVE1.OVE_BOL_MNEMONICO
         ,P_OVE_COC_CTO_MNEMONICO => OVE1.OVE_COC_CTO_MNEMONICO
         ,P_OVE_CONSECUTIVO       => OVE1.OVE_CONSECUTIVO
         ,P_OVE_EOC_MNEMONICO     => 'CAN'
         ,P_OVE_RAZON_ANU_CAN     => 'PROC.AUT. CANCELACION DE ORDENES');
   END LOOP;
   COMMIT;
   /* Proceso para la anulaciżn, cancelaciżn de ordenes de ACCIONES HASTA UNA FECHA */
   UPDATE ORDENES_COMPRA
   SET    OCO_EOC_MNEMONICO = 'ANU'
         ,OCO_FECHA_ANU_CAN = SYSDATE
         ,OCO_RAZON_ANU_CAN = 'PROCESO AUT. DE ANULACION DE ORDENES'
         ,OCO_ANU_CAN_POR = 'AUTOMATICO'
         ,OCO_TERMINAL_ANU_CAN  = 'AUTOMATICO'
   WHERE  OCO_COC_CTO_MNEMONICO = 'ACC'
   AND    OCO_VIO_MNEMONICO IN ('PER','HFE')
   AND    OCO_EOC_MNEMONICO IN ('COL','AUT')
   AND    NVL(OCO_FECHA_PERMANENCIA,OCO_FECHA_Y_HORA) < TRUNC(SYSDATE);
   FOR OVE1 IN (SELECT OVE_BOL_MNEMONICO
                      ,OVE_COC_CTO_MNEMONICO
                      ,OVE_CONSECUTIVO
                FROM   ORDENES_VENTA
                WHERE  OVE_COC_CTO_MNEMONICO = 'ACC'
                AND    OVE_VIO_MNEMONICO IN ('PER','HFE')
                AND    OVE_EOC_MNEMONICO IN ('COL','AUT')
                AND    NVL(OVE_FECHA_PERMANENCIA,OVE_FECHA_Y_HORA) < TRUNC(SYSDATE)
                /*VAGTUS069751
        AND    (OVE_COC_CCO_MNEMONICO NOT IN ('EXT')
                AND    OVE_COC_CTE_MNEMONICO NOT IN ('OPA')
                AND    OVE_ENA_MNEMONICO NOT IN ('ISAGEN','VALOREM'))*/) LOOP
      P_ORDENES_COMERCIAL.ANULACION_VENTAS
         (P_OVE_BOL_MNEMONICO     => OVE1.OVE_BOL_MNEMONICO
         ,P_OVE_COC_CTO_MNEMONICO => OVE1.OVE_COC_CTO_MNEMONICO
         ,P_OVE_CONSECUTIVO       => OVE1.OVE_CONSECUTIVO
         ,P_OVE_EOC_MNEMONICO     => 'ANU'
         ,P_OVE_RAZON_ANU_CAN     => 'PROCESO AUT. DE ANULACION DE ORDENES');
   END LOOP;
   UPDATE ORDENES_COMPRA
   SET    OCO_EOC_MNEMONICO = 'CAN'
         ,OCO_FECHA_ANU_CAN = SYSDATE
         ,OCO_RAZON_ANU_CAN = 'PROCESO AUT. DE CANCELACION DE ORDENES'
         ,OCO_ANU_CAN_POR = 'AUTOMATICO'
         ,OCO_TERMINAL_ANU_CAN  = 'AUTOMATICO'
   WHERE  OCO_COC_CTO_MNEMONICO = 'ACC'
   AND    OCO_VIO_MNEMONICO IN ('PER','HFE')
   AND    OCO_EOC_MNEMONICO = 'PAP'
   AND    NVL(OCO_FECHA_PERMANENCIA,OCO_FECHA_Y_HORA) < TRUNC(SYSDATE);
   FOR OVE1 IN (SELECT OVE_BOL_MNEMONICO
                      ,OVE_COC_CTO_MNEMONICO
                      ,OVE_CONSECUTIVO
                FROM   ORDENES_VENTA
                WHERE  OVE_COC_CTO_MNEMONICO = 'ACC'
                AND    OVE_VIO_MNEMONICO IN ('PER','HFE')
                AND    OVE_EOC_MNEMONICO = 'PAP'
                AND    NVL(OVE_FECHA_PERMANENCIA,OVE_FECHA_Y_HORA) < TRUNC(SYSDATE)
                /*VAGTUS069751
        AND    (OVE_COC_CCO_MNEMONICO NOT IN ('EXT')
                AND    OVE_COC_CTE_MNEMONICO NOT IN ('OPA')
                AND    OVE_ENA_MNEMONICO NOT IN ('ISAGEN','VALOREM'))*/) LOOP
      P_ORDENES_COMERCIAL.ANULACION_VENTAS
         (P_OVE_BOL_MNEMONICO     => OVE1.OVE_BOL_MNEMONICO
         ,P_OVE_COC_CTO_MNEMONICO => OVE1.OVE_COC_CTO_MNEMONICO
         ,P_OVE_CONSECUTIVO       => OVE1.OVE_CONSECUTIVO
         ,P_OVE_EOC_MNEMONICO     => 'CAN'
         ,P_OVE_RAZON_ANU_CAN     => 'PROCESO AUT. DE CANCELACION DE ORDENES');
   END LOOP;
   COMMIT;

   /* Proceso para la cancelaciżn, anulaciżn de ordenes con estado de bolsa canceladas por comercial en plataforma*/
   UPDATE ORDENES_COMPRA
   SET    OCO_EOC_MNEMONICO = DECODE(OCO_EOC_MNEMONICO, 'COL', 'ANU', 'PAP', 'CAN')
         ,OCO_FECHA_ANU_CAN = SYSDATE
         ,OCO_RAZON_ANU_CAN = 'PROC. AUT. ANULACION ORDENES CPC'
         ,OCO_ANU_CAN_POR = 'AUTOMATICO'
         ,OCO_TERMINAL_ANU_CAN  = 'AUTOMATICO'
   WHERE  OCO_EOC_MNEMONICO IN ('COL','PAP')
   AND    OCO_ESTADO_BOLSA IN ('CPC')
   AND    OCO_FECHA_Y_HORA < TRUNC(SYSDATE);

   UPDATE ORDENES_VENTA
   SET    OVE_EOC_MNEMONICO = DECODE(OVE_EOC_MNEMONICO, 'COL', 'ANU', 'PAP', 'CAN')
         ,OVE_FECHA_ANU_CAN = SYSDATE
         ,OVE_RAZON_ANU_CAN = 'PROC. AUT. ANULACION ORDENES CPC'
         ,OVE_ANU_CAN_POR = 'AUTOMATICO'
         ,OVE_TERMINAL_ANU_CAN  = 'AUTOMATICO'
   WHERE  OVE_EOC_MNEMONICO IN ('COL','PAP')
   AND    OVE_ESTADO_BOLSA IN ('CPC')
   AND    OVE_FECHA_Y_HORA < TRUNC(SYSDATE);

   /* Proceso para la anulaciżn, cancelaciżn de ordenes de ACCIONES HASTA CANCELACION */
   DIAS := NULL;
   OPEN C_CONSTANTE('DMP');
   FETCH C_CONSTANTE INTO DIAS;
   CLOSE C_CONSTANTE;
   DIAS := NVL(DIAS,30);
   UPDATE ORDENES_COMPRA
   SET    OCO_EOC_MNEMONICO = 'ANU'
         ,OCO_FECHA_ANU_CAN = SYSDATE
         ,OCO_RAZON_ANU_CAN = 'PROCESO AUT. DE ANULACION DE ORDENES'
         ,OCO_ANU_CAN_POR = 'AUTOMATICO'
         ,OCO_TERMINAL_ANU_CAN  = 'AUTOMATICO'
   WHERE  OCO_COC_CTO_MNEMONICO = 'ACC'
   AND    OCO_VIO_MNEMONICO = 'HCA'
   AND    OCO_EOC_MNEMONICO IN ('COL','AUT')
   AND    OCO_FECHA_Y_HORA < TRUNC(SYSDATE) - DIAS;
   FOR OVE1 IN (SELECT OVE_BOL_MNEMONICO
                      ,OVE_COC_CTO_MNEMONICO
                      ,OVE_CONSECUTIVO
                FROM   ORDENES_VENTA
                WHERE  OVE_COC_CTO_MNEMONICO = 'ACC'
                AND    OVE_VIO_MNEMONICO = 'HCA'
                /*VAGTUS069751
        AND    (OVE_COC_CCO_MNEMONICO NOT IN ('EXT')
                AND    OVE_COC_CTE_MNEMONICO NOT IN ('OPA')
                AND    OVE_ENA_MNEMONICO NOT IN ('ISAGEN','VALOREM'))*/
                AND    OVE_EOC_MNEMONICO IN ('COL','AUT')
                AND    OVE_FECHA_Y_HORA < TRUNC(SYSDATE) - DIAS) LOOP
      P_ORDENES_COMERCIAL.ANULACION_VENTAS
         (P_OVE_BOL_MNEMONICO     => OVE1.OVE_BOL_MNEMONICO
         ,P_OVE_COC_CTO_MNEMONICO => OVE1.OVE_COC_CTO_MNEMONICO
         ,P_OVE_CONSECUTIVO       => OVE1.OVE_CONSECUTIVO
         ,P_OVE_EOC_MNEMONICO     => 'ANU'
         ,P_OVE_RAZON_ANU_CAN     => 'PROCESO AUT. DE ANULACION DE ORDENES');
   END LOOP;
   UPDATE ORDENES_COMPRA
   SET    OCO_EOC_MNEMONICO = 'CAN'
         ,OCO_FECHA_ANU_CAN = SYSDATE
         ,OCO_RAZON_ANU_CAN = 'PROCESO AUT. DE CANCELACION DE ORDENES'
         ,OCO_ANU_CAN_POR = 'AUTOMATICO'
         ,OCO_TERMINAL_ANU_CAN  = 'AUTOMATICO'
   WHERE  OCO_COC_CTO_MNEMONICO = 'ACC'
   AND    OCO_VIO_MNEMONICO = 'HCA'
   AND    OCO_EOC_MNEMONICO = 'PAP'
   AND    OCO_FECHA_Y_HORA < TRUNC(SYSDATE) - DIAS;
   FOR OVE1 IN (SELECT OVE_BOL_MNEMONICO
                      ,OVE_COC_CTO_MNEMONICO
                      ,OVE_CONSECUTIVO
                FROM   ORDENES_VENTA
                WHERE  OVE_COC_CTO_MNEMONICO = 'ACC'
                AND    OVE_VIO_MNEMONICO IN ('PER','HCA')
                AND    OVE_EOC_MNEMONICO = 'PAP'
                AND    OVE_FECHA_Y_HORA < TRUNC(SYSDATE) - DIAS
                /*VAGTUS069751
        AND    (OVE_COC_CCO_MNEMONICO NOT IN ('EXT')
                AND    OVE_COC_CTE_MNEMONICO NOT IN ('OPA')
                AND    OVE_ENA_MNEMONICO NOT IN ('ISAGEN','VALOREM'))*/) LOOP
      P_ORDENES_COMERCIAL.ANULACION_VENTAS
         (P_OVE_BOL_MNEMONICO     => OVE1.OVE_BOL_MNEMONICO
         ,P_OVE_COC_CTO_MNEMONICO => OVE1.OVE_COC_CTO_MNEMONICO
         ,P_OVE_CONSECUTIVO       => OVE1.OVE_CONSECUTIVO
         ,P_OVE_EOC_MNEMONICO     => 'CAN'
         ,P_OVE_RAZON_ANU_CAN     => 'PROCESO AUT. DE CANCELACION DE ORDENES');
   END LOOP;
   COMMIT;
   /* Proceso para la anulaciżn, cancelaciżn de ordenes de REPO de ACCIONES */
   UPDATE ORDENES_COMPRA
   SET    OCO_EOC_MNEMONICO = 'ANU'
         ,OCO_FECHA_ANU_CAN = SYSDATE
         ,OCO_RAZON_ANU_CAN = 'PROCESO AUT. DE ANULACION DE ORDENES'
         ,OCO_ANU_CAN_POR = 'AUTOMATICO'
         ,OCO_TERMINAL_ANU_CAN  = 'AUTOMATICO'
   WHERE  OCO_COC_CTO_MNEMONICO = 'ACC'
   AND    OCO_EOC_MNEMONICO IN ('COL','AUT')
   AND    OCO_BOL_MNEMONICO = 'MEC'
   AND    OCO_FECHA_Y_HORA < TRUNC(SYSDATE);
   FOR OVE1 IN (SELECT OVE_BOL_MNEMONICO
                      ,OVE_COC_CTO_MNEMONICO
                      ,OVE_CONSECUTIVO
                FROM   ORDENES_VENTA
                WHERE  OVE_COC_CTO_MNEMONICO = 'ACC'
                AND    OVE_EOC_MNEMONICO IN ('COL','AUT')
                AND    OVE_BOL_MNEMONICO = 'MEC'
                AND    OVE_FECHA_Y_HORA < TRUNC(SYSDATE)) LOOP
      P_ORDENES_COMERCIAL.ANULACION_VENTAS
         (P_OVE_BOL_MNEMONICO     => OVE1.OVE_BOL_MNEMONICO
         ,P_OVE_COC_CTO_MNEMONICO => OVE1.OVE_COC_CTO_MNEMONICO
         ,P_OVE_CONSECUTIVO       => OVE1.OVE_CONSECUTIVO
         ,P_OVE_EOC_MNEMONICO     => 'ANU'
         ,P_OVE_RAZON_ANU_CAN     => 'PROCESO AUT. DE ANULACION DE ORDENES');
   END LOOP;
   UPDATE ORDENES_COMPRA
   SET    OCO_EOC_MNEMONICO = 'CAN'
         ,OCO_FECHA_ANU_CAN = SYSDATE
         ,OCO_RAZON_ANU_CAN = 'PROCESO AUT. DE CANCELACION DE ORDENES'
         ,OCO_ANU_CAN_POR = 'AUTOMATICO'
         ,OCO_TERMINAL_ANU_CAN  = 'AUTOMATICO'
   WHERE  OCO_COC_CTO_MNEMONICO = 'ACC'
   AND    OCO_EOC_MNEMONICO = 'PAP'
   AND    OCO_BOL_MNEMONICO = 'MEC'
   AND    OCO_FECHA_Y_HORA < TRUNC(SYSDATE);
   FOR OVE1 IN (SELECT OVE_BOL_MNEMONICO
                      ,OVE_COC_CTO_MNEMONICO
                      ,OVE_CONSECUTIVO
                FROM   ORDENES_VENTA
                WHERE  OVE_COC_CTO_MNEMONICO = 'ACC'
                AND    OVE_EOC_MNEMONICO = 'PAP'
                AND    OVE_BOL_MNEMONICO = 'MEC'
                AND    OVE_FECHA_Y_HORA < TRUNC(SYSDATE)) LOOP
      P_ORDENES_COMERCIAL.ANULACION_VENTAS
         (P_OVE_BOL_MNEMONICO     => OVE1.OVE_BOL_MNEMONICO
         ,P_OVE_COC_CTO_MNEMONICO => OVE1.OVE_COC_CTO_MNEMONICO
         ,P_OVE_CONSECUTIVO       => OVE1.OVE_CONSECUTIVO
         ,P_OVE_EOC_MNEMONICO     => 'CAN'
         ,P_OVE_RAZON_ANU_CAN     => 'PROC.AUT. CANCELACION DE ORDENES');
   END LOOP;
   COMMIT;
   /* Anulaciżn de ordenes de pago manuales de clientes de mas de dos dias habiles */
   CONTADOR := 0;
   DIAS := 2;
   SELECT SYSDATE INTO FECHA FROM DUAL;
   WHILE CONTADOR < DIAS LOOP
         IF TO_CHAR(FECHA,'D') IN ('1','7') THEN
            NULL;
         ELSE
            OPEN C_DIAS(FECHA);
            FETCH C_DIAS INTO DATO;
            IF C_DIAS%FOUND THEN
               NULL;
            ELSE
               CONTADOR := CONTADOR + 1;
            END IF;
            CLOSE C_DIAS;
         END IF;
         FECHA := FECHA - 1;
   END LOOP;
   UPDATE ORDENES_DE_PAGO
   SET ODP_ESTADO = 'ANU'
      ,ODP_ANULADA_POR = 'AUTOMATICO'
      ,ODP_FECHA_ANULACION = SYSDATE
      ,ODP_RAZON_ANULACION = 'PROC. AUTOMATICO ANULACION ORDENES'
   WHERE ODP_FECHA_EJECUCION < TRUNC(FECHA + 1)
   AND   ODP_ESTADO IN ('COL','APR')
   AND   ODP_ES_CLIENTE = 'S'
   AND   ODP_OVE_CONSECUTIVO IS NULL
   AND   ODP_OFO_CONSECUTIVO IS NULL
   AND   ODP_CEG_CONSECUTIVO IS NULL
   AND   ODP_CGE_CONSECUTIVO IS NULL
   AND   ODP_TBC_CONSECUTIVO IS NULL
   AND   ODP_TCC_CONSECUTIVO IS NULL
   AND   ODP_PRC_PRF_CONSECUTIVO IS NULL
   AND   ODP_OCR_CONSECUTIVO IS NULL
   AND   ODP_ORD_CONSECUTIVO IS NULL
   AND   ODP_MTO_PCC_CONSECUTIVO IS NULL
   AND   ODP_PCC_CONSECUTIVO IS NULL
   AND   ODP_TCF_NUMERO_TITULO IS NULL
   AND   NOT EXISTS (SELECT 'X'
                     FROM   PAGOS_ADMON_VALORES
                     WHERE  PAV_ODP_CONSECUTIVO = ODP_CONSECUTIVO
                     AND    PAV_ODP_SUC_CODIGO = ODP_SUC_CODIGO
                     AND    PAV_ODP_NEG_CONSECUTIVO = ODP_NEG_CONSECUTIVO);
   /* Anulaciżn de ordenes de pago de operaciones de venta canceladas o anuladas en dias anteriores
      que se encuentran vivas y sin ejecutar */
   UPDATE ORDENES_DE_PAGO
   SET ODP_ESTADO = 'ANU'
      ,ODP_ANULADA_POR = 'AUTOMATICO'
      ,ODP_FECHA_ANULACION = SYSDATE
      ,ODP_RAZON_ANULACION = 'PROC. AUTOMATICO ANULACION ORDENES'
   WHERE ODP_FECHA_EJECUCION < TRUNC(SYSDATE)
   AND   ODP_ESTADO IN ('COL','APR')
   AND   ODP_ES_CLIENTE = 'S'
   AND   ODP_CEG_CONSECUTIVO IS NULL
   AND   ODP_CGE_CONSECUTIVO IS NULL
   AND   ODP_TBC_CONSECUTIVO IS NULL
   AND   ODP_TCC_CONSECUTIVO IS NULL
   AND   ODP_OVE_CONSECUTIVO IS NOT NULL
   AND   EXISTS (SELECT 'X'
                 FROM   ORDENES_VENTA
                 WHERE  OVE_CONSECUTIVO = ODP_OVE_CONSECUTIVO
                 AND    OVE_BOL_MNEMONICO = ODP_OVE_BOL_MNEMONICO
                 AND    OVE_COC_CTO_MNEMONICO = ODP_OVE_COC_CTO_MNEMONICO
                 AND    OVE_EOC_MNEMONICO IN ('ANU','CAN'));

   /* Anulacion de ordenes de compra Y venta que estan en estado PCO que
      no quedaron en estado COL
      Ordenes ingresadas en PLV y UDF
      */

   /*UPDATE ORDENES_COMPRA
   SET    OCO_EOC_MNEMONICO = 'ANU'
         ,OCO_FECHA_ANU_CAN = SYSDATE
         ,OCO_RAZON_ANU_CAN = 'PROCESO AUT. DE ANULACION DE ORDENES'
         ,OCO_ANU_CAN_POR = 'AUTOMATICO'
         ,OCO_TERMINAL_ANU_CAN  = 'AUTOMATICO'
   WHERE  OCO_COC_CTO_MNEMONICO = 'ACC'
   AND    OCO_EOC_MNEMONICO IN ('PCO')
   AND    OCO_FECHA_Y_HORA < TRUNC(SYSDATE)
   AND    OCO_CANAL_ORIGEN IN ('S2','PLV') ;


   FOR OVE1 IN (SELECT OVE_BOL_MNEMONICO
                      ,OVE_COC_CTO_MNEMONICO
                      ,OVE_CONSECUTIVO
                FROM   ORDENES_VENTA
                WHERE  OVE_COC_CTO_MNEMONICO = 'ACC'
                AND    OVE_EOC_MNEMONICO IN ('PCO')
                AND    OVE_FECHA_Y_HORA < TRUNC(SYSDATE)
                AND    OVE_CANAL_ORIGEN IN ('S2','PLV')) LOOP
      P_ORDENES_COMERCIAL.ANULACION_VENTAS
         (P_OVE_BOL_MNEMONICO     => OVE1.OVE_BOL_MNEMONICO
         ,P_OVE_COC_CTO_MNEMONICO => OVE1.OVE_COC_CTO_MNEMONICO
         ,P_OVE_CONSECUTIVO       => OVE1.OVE_CONSECUTIVO
         ,P_OVE_EOC_MNEMONICO     => 'ANU'
         ,P_OVE_RAZON_ANU_CAN     => 'PROCESO AUT. DE ANULACION DE ORDENES');
   END LOOP;
   */
 --Anulacion Eximentes asociados a Ordenes anuladas --smorales
   FOR R_ANULACION IN C_ANULACION_EXIMENTES  LOOP
      UPDATE OPERACIONES_FUERA_PERFIL
      SET OFP_ESTADO = 'ANU'
      WHERE OFP_CONSECUTIVO = R_ANULACION.OFP_CONSECUTIVO
      AND OFP_OCO_CONSECUTIVO = R_ANULACION.OFP_OCO_CONSECUTIVO;
      COMMIT;
   END LOOP;

   COMMIT;
EXCEPTION
   WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento ANULACION_CANCELACION_ORDENES.SQL',substr(sqlerrm,1,3500));
END ANULACION_CANCELACION_ORDENES;

PROCEDURE ANULACION_VENTAS
 (P_OVE_BOL_MNEMONICO     IN ORDENES_VENTA.OVE_BOL_MNEMONICO%TYPE
 ,P_OVE_COC_CTO_MNEMONICO IN ORDENES_VENTA.OVE_COC_CTO_MNEMONICO%TYPE
 ,P_OVE_CONSECUTIVO       IN ORDENES_VENTA.OVE_CONSECUTIVO%TYPE
 ,P_OVE_EOC_MNEMONICO     IN ORDENES_VENTA.OVE_EOC_MNEMONICO%TYPE
 ,P_OVE_RAZON_ANU_CAN     IN ORDENES_VENTA.OVE_RAZON_ANU_CAN%TYPE) IS
BEGIN
   IF P_OVE_EOC_MNEMONICO = 'ANU' THEN
      UPDATE ORDENES_DE_PAGO
      SET    ODP_ESTADO = 'ANU'
            ,ODP_ANULADA_POR = 'AUTOMATICO'
            ,ODP_FECHA_ANULACION = SYSDATE
            ,ODP_RAZON_ANULACION = 'ANULACION ORDEN VENTA'
      WHERE  ODP_OVE_BOL_MNEMONICO = P_OVE_BOL_MNEMONICO
      AND    ODP_OVE_COC_CTO_MNEMONICO = P_OVE_COC_CTO_MNEMONICO
      AND    ODP_OVE_CONSECUTIVO = P_OVE_CONSECUTIVO
      AND    ODP_CGE_CONSECUTIVO IS NULL
      AND    ODP_CEG_CONSECUTIVO IS NULL
      AND    ODP_TCC_CONSECUTIVO IS NULL
      AND    ODP_TBC_CONSECUTIVO IS NULL
      AND    ODP_ESTADO IN ('COL','APR');
      UPDATE TITULOS
      SET    TLO_COMPROMETIDO_VENTA = 'N'
      WHERE  TLO_ETC_MNEMONICO = 'DIS'
      AND    TLO_CODIGO IN (SELECT OTI_TLO_CODIGO
                            FROM   ORDENES_Y_TITULOS
                                  ,ORDENES_VENTA
                            WHERE  OTI_OVE_BOL_MNEMONICO = OVE_BOL_MNEMONICO
                            AND    OTI_OVE_COC_CTO_MNEMONICO = OVE_COC_CTO_MNEMONICO
                            AND    OTI_OVE_CONSECUTIVO = OVE_CONSECUTIVO
                            AND    OVE_BOL_MNEMONICO = P_OVE_BOL_MNEMONICO
                            AND    OVE_COC_CTO_MNEMONICO = P_OVE_COC_CTO_MNEMONICO
                            AND    OVE_CONSECUTIVO = P_OVE_CONSECUTIVO);
   END IF;
   UPDATE ORDENES_VENTA
   SET    OVE_EOC_MNEMONICO = P_OVE_EOC_MNEMONICO
         ,OVE_FECHA_ANU_CAN = SYSDATE
         ,OVE_RAZON_ANU_CAN = P_OVE_RAZON_ANU_CAN
         ,OVE_ANU_CAN_POR = 'AUTOMATICO'
         ,OVE_TERMINAL_ANU_CAN  = 'AUTOMATICO'
   WHERE  OVE_BOL_MNEMONICO = P_OVE_BOL_MNEMONICO
   AND    OVE_COC_CTO_MNEMONICO = P_OVE_COC_CTO_MNEMONICO
   AND    OVE_CONSECUTIVO = P_OVE_CONSECUTIVO;

   EXCEPTION
     WHEN OTHERS THEN
        P_MAIL.ENVIO_MAIL_ERROR('Error en procedimiento ANULACION_VENTAS','Orden :'||P_OVE_CONSECUTIVO||' '||substr(sqlerrm,1,3500));
END ANULACION_VENTAS;
/*************************************************
*** TOTAL POR BANCO DE DETALLES PAGOS ACH     ****
*************************************************/
PROCEDURE TraerBancoDPA (P_SUC IN NUMBER,
                         P_NEG IN NUMBER,
                         P_ODP IN NUMBER,
                         P_DPA IN OUT t_banco_dpa) IS
   CURSOR C_DPA IS
      SELECT DPA_BAN_CODIGO BAN_CODIGO,
             BAN_NOMBRE BAN_NOMBRE,
             COUNT(*) NUMERO_PAGOS,
             SUM(DPA_MONTO) TOTAL_PAGOS
      FROM DETALLES_PAGOS_ACH,
           BANCOS
      WHERE DPA_BAN_CODIGO = BAN_CODIGO (+)
        AND DPA_ODP_SUC_CODIGO = P_SUC
        AND DPA_ODP_NEG_CONSECUTIVO = P_NEG
        AND DPA_ODP_CONSECUTIVO = P_ODP
      GROUP BY DPA_BAN_CODIGO,BAN_NOMBRE
      ORDER BY 4 DESC;
   R_DPA C_DPA%ROWTYPE;
   v_registro number;
BEGIN
   P_DPA.DELETE;
   OPEN C_DPA;
   FETCH C_DPA INTO R_DPA;
   WHILE C_DPA%FOUND LOOP
      v_registro := P_DPA.count;
      P_DPA(v_registro).BAN_CODIGO   := R_DPA.BAN_CODIGO;
      P_DPA(v_registro).BAN_NOMBRE   := R_DPA.BAN_NOMBRE;
      P_DPA(v_registro).NUMERO_PAGOS := R_DPA.NUMERO_PAGOS;
      P_DPA(v_registro).TOTAL_PAGOS  := R_DPA.TOTAL_PAGOS;
      FETCH C_DPA INTO R_DPA;
   END LOOP;
   CLOSE C_DPA;
EXCEPTION
   WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20001,'Error en procedimiento TraerBancoDPA: '||sqlerrm);
END TraerBancoDPA;
/****************************************************
*** TOTAL POR BANCO PARA EJECUCION DE TRB Y ACH  ****
****************************************************/
PROCEDURE TraerBancoEjecucion (P_DPA IN OUT t_banco_dpa) IS
   CURSOR C_DPA IS
      SELECT BAN_CODIGO,
             BAN_NOMBRE,
             GENERA_ARCHIVO,
             NUMERO_PAGOS,
             TOTAL_PAGOS
      FROM ( SELECT DPA_BAN_CODIGO   BAN_CODIGO,
                    BAN_NOMBRE       BAN_NOMBRE,
                    'S'              GENERA_ARCHIVO,
                    SUM(DPA_NUMERO)  NUMERO_PAGOS,
                    SUM(DPA_MONTO)   TOTAL_PAGOS
             FROM EJECUTA_TRB E,
                  BANCOS B
             WHERE E.DPA_BAN_CODIGO = B.BAN_CODIGO
               AND EXISTS (SELECT 'X'
                           FROM BANCOS C
                           WHERE C.BAN_CODIGO = E.DPA_BAN_CODIGO
                             AND NVL(C.BAN_GENERA_ARCHIVO,'N') = 'S')
             GROUP BY DPA_BAN_CODIGO,BAN_NOMBRE
             UNION ALL
             SELECT 9999             BAN_CODIGO,
                    'OTROS'          BAN_NOMBRE,
                    'N'              GENERA_ARCHIVO,
                    SUM(DPA_NUMERO)  NUMERO_PAGOS,
                    SUM(DPA_MONTO)   TOTAL_PAGOS
             FROM EJECUTA_TRB E
             WHERE NOT EXISTS (SELECT 'X'
                               FROM BANCOS C
                               WHERE C.BAN_CODIGO = E.DPA_BAN_CODIGO
                                 AND NVL(C.BAN_GENERA_ARCHIVO,'N') = 'S'))
      WHERE NUMERO_PAGOS != 0
      ORDER BY 1;
   R_DPA C_DPA%ROWTYPE;
   v_registro number;
BEGIN
   P_DPA.DELETE;
   OPEN C_DPA;
   FETCH C_DPA INTO R_DPA;
   WHILE C_DPA%FOUND LOOP
      v_registro := P_DPA.count;
      P_DPA(v_registro).BAN_CODIGO       := R_DPA.BAN_CODIGO;
      P_DPA(v_registro).BAN_NOMBRE       := R_DPA.BAN_NOMBRE;
      P_DPA(v_registro).GENERA_ARCHIVO   := R_DPA.GENERA_ARCHIVO;
      P_DPA(v_registro).NUMERO_PAGOS     := R_DPA.NUMERO_PAGOS;
      P_DPA(v_registro).TOTAL_PAGOS      := R_DPA.TOTAL_PAGOS;
      FETCH C_DPA INTO R_DPA;
   END LOOP;
   CLOSE C_DPA;
EXCEPTION
   WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20001,'Error en procedimiento TraerBancoEjecucion: '||sqlerrm);
END TraerBancoEjecucion;
FUNCTION BENEFICIARIO_CUENTA (P_CUENTA_DECEVAL    IN COMITENTES_DECEVAL.COD_CUD_CUENTA_DECEVAL%TYPE
                             ,P_TIPO              IN NUMBER) RETURN VARCHAR2 IS
   CURSOR C_COMITENTES_DECEVAL IS
      SELECT PER_NOMBRE
      FROM   COMITENTES_DECEVAL
            ,FILTRO_PERSONAS
      WHERE  COD_CUD_CUENTA_DECEVAL = P_CUENTA_DECEVAL
      AND    COD_CLI_PER_NUM_IDEN_RELACIONA = PER_NUM_IDEN
      AND    COD_CLI_PER_TID_CODIGO_RELACIO = PER_TID_CODIGO
      ORDER BY COD_CONSECUTIVO;
   PER1   C_COMITENTES_DECEVAL%ROWTYPE;
BEGIN
   OPEN C_COMITENTES_DECEVAL;
   FETCH C_COMITENTES_DECEVAL INTO PER1;
   IF C_COMITENTES_DECEVAL%FOUND THEN
      IF P_TIPO = 1 THEN
         CLOSE C_COMITENTES_DECEVAL;
         RETURN NVL(PER1.PER_NOMBRE,' ');
      ELSE
         FETCH C_COMITENTES_DECEVAL INTO PER1;
         IF C_COMITENTES_DECEVAL%FOUND THEN
            CLOSE C_COMITENTES_DECEVAL;
            IF P_TIPO = 2 THEN
               RETURN NVL(PER1.PER_NOMBRE,' ');
            END IF;
            RETURN ' ';
         END IF;
      END IF;
   END IF;
   CLOSE C_COMITENTES_DECEVAL;
   RETURN ' ';
END BENEFICIARIO_CUENTA;
PROCEDURE ORDENES_SIN_REGISTRAR
 (P_ORDENES_SUELTAS IN OUT T_ACCIONES
 ,P_ORDENES_AGRUPADAS IN OUT T_ACCIONES_AGRUPADO) IS
   CURSOR C_ORDENES_ACCIONES IS
      SELECT ACC_INICIALES_USUARIO
            ,ACC_TIPO_ORDEN
            ,ACC_FECHA
            ,ACC_CONSECUTIVO
            ,ACC_BOL_MNEMONICO
            ,ACC_COC_CTO_MNEMONICO
            ,ACC_ENA_MNEMONICO
            ,ACC_TIPO_NOMINAL_O_PESOS
            ,ACC_NOMINAL_O_PESOS
            ,ACC_COMISION
            ,ACC_CONDICION_PRECIO
            ,ACC_PRECIO_LIMITE_O_MARGEN
            ,ACC_CRITERIOS_ADICIONALES
            ,ACC_CANTIDAD_MINIMA
            ,ACC_VISIBLE
            ,ACC_PORCENTAJE_VISIBLE
            ,ACC_STOP
            ,ACC_PRECIO_STOP
            ,ACC_VIO_MNEMONICO
            ,ACC_FECHA_PERMANENCIA
            ,ACC_HORA_DURACION
            ,ACC_PERMITE_AGRUPAMIENTO
            ,ACC_LEO_CONSECUTIVO
            ,0 ACC_CONSECUTIVO_AGRUPAMIENTO
            ,SYSDATE ACC_FECHA_RUEDA
      FROM   REGISTROS_ACCIONES
      ORDER BY ACC_FECHA, ACC_CONSECUTIVO, ACC_ENA_MNEMONICO;
   CURSOR C_CONSTANTES(P_CON_MNEMONICO VARCHAR2) IS
      SELECT CON_VALOR
            ,CON_VALOR_CHAR
      FROM   CONSTANTES
      WHERE  CON_MNEMONICO = P_CON_MNEMONICO;
   CON1   C_CONSTANTES%ROWTYPE;
   CON2   C_CONSTANTES%ROWTYPE;
   REGISTRO  NUMBER;
   REGISTRO1 NUMBER;
   EXISTE    VARCHAR2(2);
   FECHA     DATE;
BEGIN
   OPEN C_CONSTANTES('TMA');
   FETCH C_CONSTANTES INTO CON1;
   CLOSE C_CONSTANTES;
   CON1.CON_VALOR := NVL(CON1.CON_VALOR,0);
   OPEN C_CONSTANTES('HRA');
   FETCH C_CONSTANTES INTO CON2;
   CLOSE C_CONSTANTES;
   CON2.CON_VALOR_CHAR := NVL(CON2.CON_VALOR_CHAR,' ');
   FOR ACC1 IN C_ORDENES_ACCIONES LOOP
      REGISTRO := P_ORDENES_SUELTAS.COUNT;
      P_ORDENES_SUELTAS(REGISTRO) := ACC1;
      P_ORDENES_SUELTAS(REGISTRO).ACC_FECHA_RUEDA := ACC1.ACC_FECHA;
      SELECT TO_DATE(TO_CHAR(SYSDATE) || ' ' || CON2.CON_VALOR_CHAR,'DD-MON-YYYY HH24:MI:SS') INTO FECHA FROM DUAL;
      IF P_ORDENES_SUELTAS(REGISTRO).ACC_FECHA_RUEDA < FECHA THEN
         P_ORDENES_SUELTAS(REGISTRO).ACC_FECHA_RUEDA := FECHA;
      END IF;
      IF ACC1.ACC_PERMITE_AGRUPAMIENTO = 'S' THEN
         SELECT SYSDATE INTO FECHA FROM DUAL;
         IF FECHA - P_ORDENES_SUELTAS(REGISTRO).ACC_FECHA_RUEDA  >  CON1.CON_VALOR / 1440 THEN
            P_ORDENES_SUELTAS(REGISTRO).ACC_PERMITE_AGRUPAMIENTO := NULL;
         ELSE
            EXISTE := 'N';
            IF P_ORDENES_AGRUPADAS.COUNT > 0 THEN
               FOR I IN P_ORDENES_AGRUPADAS.FIRST .. P_ORDENES_AGRUPADAS.LAST LOOP
                  IF P_ORDENES_AGRUPADAS(I).ACC_ENA_MNEMONICO = ACC1.ACC_ENA_MNEMONICO AND
                     P_ORDENES_AGRUPADAS(I).ACC_TIPO_ORDEN = ACC1.ACC_TIPO_ORDEN AND
                     P_ORDENES_AGRUPADAS(I).ACC_LEO_CONSECUTIVO = ACC1.ACC_LEO_CONSECUTIVO AND
                     NVL(P_ORDENES_AGRUPADAS(I).ACC_CONDICION_PRECIO,' ') = NVL(ACC1.ACC_CONDICION_PRECIO,' ') AND
                     NVL(P_ORDENES_AGRUPADAS(I).ACC_CRITERIOS_ADICIONALES,'NON') = NVL(ACC1.ACC_CRITERIOS_ADICIONALES,'NON') AND
                     NVL(P_ORDENES_AGRUPADAS(I).ACC_PRECIO_LIMITE_O_MARGEN,0) = NVL(ACC1.ACC_PRECIO_LIMITE_O_MARGEN,0) THEN
                     P_ORDENES_AGRUPADAS(I).ACC_NOMINAL_O_PESOS := P_ORDENES_AGRUPADAS(I).ACC_NOMINAL_O_PESOS + ACC1.ACC_NOMINAL_O_PESOS;
                     P_ORDENES_AGRUPADAS(I).ACC_TOTAL_AGRUPADAS := P_ORDENES_AGRUPADAS(I).ACC_TOTAL_AGRUPADAS + 1;
                     P_ORDENES_SUELTAS(REGISTRO).ACC_CONSECUTIVO_AGRUPAMIENTO := I;
                     EXISTE := 'S';
                     EXIT;
                  END IF;
               END LOOP;
            END IF;
            IF EXISTE = 'N' THEN
               REGISTRO1 := P_ORDENES_AGRUPADAS.COUNT;
               P_ORDENES_AGRUPADAS(REGISTRO1).ACC_TIPO_ORDEN := ACC1.ACC_TIPO_ORDEN;
               P_ORDENES_AGRUPADAS(REGISTRO1).ACC_ENA_MNEMONICO := ACC1.ACC_ENA_MNEMONICO;
               P_ORDENES_AGRUPADAS(REGISTRO1).ACC_TIPO_NOMINAL_O_PESOS := ACC1.ACC_TIPO_NOMINAL_O_PESOS;
               P_ORDENES_AGRUPADAS(REGISTRO1).ACC_NOMINAL_O_PESOS := ACC1.ACC_NOMINAL_O_PESOS;
               P_ORDENES_AGRUPADAS(REGISTRO1).ACC_CONDICION_PRECIO := ACC1.ACC_CONDICION_PRECIO;
               P_ORDENES_AGRUPADAS(REGISTRO1).ACC_PRECIO_LIMITE_O_MARGEN := ACC1.ACC_PRECIO_LIMITE_O_MARGEN;
               P_ORDENES_AGRUPADAS(REGISTRO1).ACC_CRITERIOS_ADICIONALES := ACC1.ACC_CRITERIOS_ADICIONALES;
               P_ORDENES_AGRUPADAS(REGISTRO1).ACC_LEO_CONSECUTIVO := ACC1.ACC_LEO_CONSECUTIVO;
               P_ORDENES_AGRUPADAS(REGISTRO1).ACC_CONSECUTIVO_AGRUPAMIENTO := REGISTRO1;
               P_ORDENES_AGRUPADAS(REGISTRO1).ACC_TOTAL_AGRUPADAS := 1;
               P_ORDENES_AGRUPADAS(REGISTRO1).ACC_CONSECUTIVO_PRIMERA := ACC1.ACC_CONSECUTIVO;
               P_ORDENES_SUELTAS(REGISTRO).ACC_CONSECUTIVO_AGRUPAMIENTO := REGISTRO1;
            END IF;
         END IF;
      END IF;
   END LOOP;
/*   IF P_ORDENES_SUELTAS.COUNT > 0 THEN
      FOR I IN P_ORDENES_SUELTAS.FIRST .. P_ORDENES_SUELTAS.LAST LOOP
         IF P_ORDENES_SUELTAS(I).ACC_PERMITE_AGRUPAMIENTO = 'S' THEN
            FOR J IN P_ORDENES_AGRUPADAS.FIRST .. P_ORDENES_AGRUPADAS.LAST LOOP
               IF P_ORDENES_AGRUPADAS(J).ACC_TOTAL_AGRUPADAS = 1 AND
                  P_ORDENES_AGRUPADAS(J).ACC_CONSECUTIVO_PRIMERA = P_ORDENES_SUELTAS(I).ACC_CONSECUTIVO THEN
                  P_ORDENES_SUELTAS(I).ACC_PERMITE_AGRUPAMIENTO := NULL;
                  EXIT;
               END IF;
            END LOOP;
         END IF;
      END LOOP;
   END IF;*/
END ORDENES_SIN_REGISTRAR;
PROCEDURE ESTADO_ORDENES
 (P_ACC_CONSECUTIVO       IN  ORDENES_COMPRA.OCO_CONSECUTIVO%TYPE
 ,P_ACC_BOL_MNEMONICO     IN ORDENES_COMPRA.OCO_BOL_MNEMONICO%TYPE
 ,P_ACC_COC_CTO_MNEMONICO IN ORDENES_COMPRA.OCO_COC_CTO_MNEMONICO%TYPE
 ,P_ACC_TIPO_ORDEN        IN VARCHAR2
 ,P_REG_COM               IN VARCHAR2
 ,P_RESPUESTA             IN OUT VARCHAR2) IS
   CURSOR C_ESTADO_ORDEN_C IS
      SELECT OCO_ESTADO_BOLSA
            ,OCO_EOC_MNEMONICO
      FROM   ORDENES_COMPRA
      WHERE  OCO_CONSECUTIVO = P_ACC_CONSECUTIVO
      AND    OCO_BOL_MNEMONICO = P_ACC_BOL_MNEMONICO
      AND    OCO_COC_CTO_MNEMONICO = P_ACC_COC_CTO_MNEMONICO;
   CURSOR C_ESTADO_ORDEN_V IS
      SELECT OVE_ESTADO_BOLSA
            ,OVE_EOC_MNEMONICO
      FROM   ORDENES_VENTA
      WHERE  OVE_CONSECUTIVO = P_ACC_CONSECUTIVO
      AND    OVE_BOL_MNEMONICO = P_ACC_BOL_MNEMONICO
      AND    OVE_COC_CTO_MNEMONICO = P_ACC_COC_CTO_MNEMONICO;
   ESTADO  ORDENES_COMPRA.OCO_ESTADO_BOLSA%TYPE;
   EOC     ORDENES_COMPRA.OCO_EOC_MNEMONICO%TYPE;
BEGIN
   IF P_REG_COM = 'REG' THEN
      IF P_ACC_TIPO_ORDEN = 'C' THEN
         OPEN C_ESTADO_ORDEN_C;
         FETCH C_ESTADO_ORDEN_C INTO ESTADO
                                    ,EOC;
         CLOSE C_ESTADO_ORDEN_C;
         IF ESTADO IS NOT NULL THEN
            P_RESPUESTA := 'La Operacion: ' || TO_CHAR(P_ACC_CONSECUTIVO) || ' se encuentra en estado '
                        || ESTADO || '. Ya no puede ser registrada';
         ELSE
            IF EOC != 'COL' THEN
               P_RESPUESTA := 'La Operacion: ' || TO_CHAR(P_ACC_CONSECUTIVO) || ' se encuentra en estado '
                           || EOC || '. Solo pueden registrar operaciones en estado COL';
            ELSE
               P_RESPUESTA := NULL;
            END IF;
         END IF;
      ELSIF P_ACC_TIPO_ORDEN = 'V' THEN
         OPEN C_ESTADO_ORDEN_V;
         FETCH C_ESTADO_ORDEN_V INTO ESTADO
                                    ,EOC;
         CLOSE C_ESTADO_ORDEN_V;
         IF ESTADO IS NOT NULL THEN
            P_RESPUESTA := 'La Operacion: ' || TO_CHAR(P_ACC_CONSECUTIVO) || ' se encuentra en estado '
                        || ESTADO || '. Ya no puede ser registrada';
         ELSE
            IF EOC != 'COL' THEN
               P_RESPUESTA := 'La Operacion: ' || TO_CHAR(P_ACC_CONSECUTIVO) || ' se encuentra en estado '
                           || EOC || '. Solo pueden registrar operaciones en estado COL';
            ELSE
               P_RESPUESTA := NULL;
            END IF;
         END IF;
      END IF;
   ELSIF P_REG_COM = 'COM' THEN
      IF P_ACC_TIPO_ORDEN = 'C' THEN
         OPEN C_ESTADO_ORDEN_C;
         FETCH C_ESTADO_ORDEN_C INTO ESTADO
                                    ,EOC;
         CLOSE C_ESTADO_ORDEN_C;
         IF ESTADO != 'REG' THEN
            P_RESPUESTA := 'La Operacion: ' || TO_CHAR(P_ACC_CONSECUTIVO) || ' se encuentra en estado '
                        || ESTADO || '. Ya no puede ser complementada';
         ELSE
            IF EOC NOT IN ('COL','PAP') THEN
               P_RESPUESTA := 'La Operacion: ' || TO_CHAR(P_ACC_CONSECUTIVO) || ' se encuentra en estado '
                           || EOC || '. Solo pueden complementear operaciones en estado COL o PAP';
            ELSE
               P_RESPUESTA := NULL;
            END IF;
         END IF;
      ELSIF P_ACC_TIPO_ORDEN = 'V' THEN
         OPEN C_ESTADO_ORDEN_V;
         FETCH C_ESTADO_ORDEN_V INTO ESTADO
                                    ,EOC;
         CLOSE C_ESTADO_ORDEN_V;
         IF ESTADO != 'REG' THEN
            P_RESPUESTA := 'La Operacion: ' || TO_CHAR(P_ACC_CONSECUTIVO) || ' se encuentra en estado '
                        || ESTADO || '. Ya no puede ser complementada';
         ELSE
            IF EOC NOT IN ('COL','PAP') THEN
               P_RESPUESTA := 'La Operacion: ' || TO_CHAR(P_ACC_CONSECUTIVO) || ' se encuentra en estado '
                           || EOC || '. Solo pueden complementar operaciones en estado COL o PAP';
            ELSE
               P_RESPUESTA := NULL;
            END IF;
         END IF;
      END IF;
   ELSIF P_REG_COM = 'COR' THEN
      IF P_ACC_TIPO_ORDEN = 'C' THEN
         OPEN C_ESTADO_ORDEN_C;
         FETCH C_ESTADO_ORDEN_C INTO ESTADO
                                    ,EOC;
         CLOSE C_ESTADO_ORDEN_C;
         IF ESTADO != 'COR' THEN
            P_RESPUESTA := 'La Operacion: ' || TO_CHAR(P_ACC_CONSECUTIVO) || ' se encuentra en estado '
                        || ESTADO || '. Ya no puede ser corregida';
         ELSE
            IF EOC NOT IN ('COL','PAP') THEN
               P_RESPUESTA := 'La Operacion: ' || TO_CHAR(P_ACC_CONSECUTIVO) || ' se encuentra en estado '
                           || EOC || '. Solo pueden corregir operaciones en estado COL o PAP';
            ELSE
               P_RESPUESTA := NULL;
            END IF;
         END IF;
      ELSIF P_ACC_TIPO_ORDEN = 'V' THEN
         OPEN C_ESTADO_ORDEN_V;
         FETCH C_ESTADO_ORDEN_V INTO ESTADO
                                    ,EOC;
         CLOSE C_ESTADO_ORDEN_V;
         IF ESTADO != 'COR' THEN
            P_RESPUESTA := 'La Operacion: ' || TO_CHAR(P_ACC_CONSECUTIVO) || ' se encuentra en estado '
                        || ESTADO || '. Ya no puede ser corregida';
         ELSE
            IF EOC NOT IN ('COL','PAP') THEN
               P_RESPUESTA := 'La Operacion: ' || TO_CHAR(P_ACC_CONSECUTIVO) || ' se encuentra en estado '
                           || EOC || '. Solo pueden corregir operaciones en estado COL o PAP';
            ELSE
               P_RESPUESTA := NULL;
            END IF;
         END IF;
      END IF;
   ELSIF P_REG_COM = 'REC' THEN
      IF P_ACC_TIPO_ORDEN = 'C' THEN
         OPEN C_ESTADO_ORDEN_C;
         FETCH C_ESTADO_ORDEN_C INTO ESTADO
                                    ,EOC;
         CLOSE C_ESTADO_ORDEN_C;
         IF ESTADO NOT IN ('REG','COR') THEN
            P_RESPUESTA := 'La Operacion: ' || TO_CHAR(P_ACC_CONSECUTIVO) || ' se encuentra en estado '
                        || ESTADO || '. Ya no puede ser confirmada en la anulaciżn o cancelaciżn';
         ELSE
            IF EOC NOT IN ('ANU','CAN') THEN
               P_RESPUESTA := 'La Operacion: ' || TO_CHAR(P_ACC_CONSECUTIVO) || ' se encuentra en estado '
                           || EOC || '. Solo pueden confirmar operaciones en estado ANU o CANL';
            ELSE
               P_RESPUESTA := NULL;
            END IF;
         END IF;
      ELSIF P_ACC_TIPO_ORDEN = 'V' THEN
         OPEN C_ESTADO_ORDEN_V;
         FETCH C_ESTADO_ORDEN_V INTO ESTADO
                                    ,EOC;
         CLOSE C_ESTADO_ORDEN_V;
         IF ESTADO NOT IN ('REG','COR') THEN
            P_RESPUESTA := 'La Operacion: ' || TO_CHAR(P_ACC_CONSECUTIVO) || ' se encuentra en estado '
                        || ESTADO || '. Ya no puede ser confirmada en la anulaciżn o cancelaciżn';
         ELSE
            IF EOC NOT IN ('ANU','CAN') THEN
               P_RESPUESTA := 'La Operacion: ' || TO_CHAR(P_ACC_CONSECUTIVO) || ' se encuentra en estado '
                           || EOC || '. Solo pueden confirmar operaciones en estado ANU o CANL';
            ELSE
               P_RESPUESTA := NULL;
            END IF;
         END IF;
      END IF;
   END IF;
END ESTADO_ORDENES;
PROCEDURE CREAR_COMPLEMENTACION_ORDEN
 (P_CONSECUTIVO           IN ORDENES_COMPRA.OCO_CONSECUTIVO%TYPE
 ,P_BOL_MNEMONICO         IN ORDENES_COMPRA.OCO_BOL_MNEMONICO%TYPE
 ,P_COC_CTO_MNEMONICO     IN ORDENES_COMPRA.OCO_COC_CTO_MNEMONICO%TYPE
 ,P_ESTADO_BOLSA          IN ORDENES_COMPRA.OCO_ESTADO_BOLSA%TYPE
 ,P_CANTIDAD              IN COMPLEMENTACIONES_ORDENES.CMO_CANTIDAD%TYPE
 ,P_NUMERO_OPERACION      IN COMPLEMENTACIONES_ORDENES.CMO_NUMERO_OPERACION%TYPE
 ,P_TIPO_ORDEN            IN VARCHAR2
 ,P_ACT_INS               IN VARCHAR2) IS
BEGIN
   IF P_TIPO_ORDEN = 'C' THEN
      IF P_BOL_MNEMONICO = 'COL' THEN
         IF P_ACT_INS = 'A' THEN
            UPDATE ORDENES_COMPRA
            SET    OCO_ESTADO_BOLSA = P_ESTADO_BOLSA
            WHERE  OCO_CONSECUTIVO = P_CONSECUTIVO
            AND    OCO_BOL_MNEMONICO = P_BOL_MNEMONICO
            AND    OCO_COC_CTO_MNEMONICO = P_COC_CTO_MNEMONICO;
         END IF;
         INSERT INTO COMPLEMENTACIONES_ORDENES
            (CMO_CONSECUTIVO
            ,CMO_CANTIDAD
            ,CMO_NUMERO_OPERACION
            ,CMO_OCO_CONSECUTIVO
            ,CMO_OCO_BOL_MNEMONICO
            ,CMO_OCO_COC_CTO_MNEMONICO)
         VALUES
            (CMO_SEQ.NEXTVAL
            ,P_CANTIDAD
            ,P_NUMERO_OPERACION
            ,P_CONSECUTIVO
            ,P_BOL_MNEMONICO
            ,P_COC_CTO_MNEMONICO);
      ELSE
         UPDATE ORDENES_COMPRA
         SET    OCO_ESTADO_BOLSA = P_ESTADO_BOLSA
         WHERE  OCO_CONSECUTIVO = P_CONSECUTIVO
         AND    OCO_BOL_MNEMONICO = P_BOL_MNEMONICO
         AND    OCO_COC_CTO_MNEMONICO = P_COC_CTO_MNEMONICO;
         IF P_ACT_INS = 'A' THEN
            UPDATE COMPLEMENTACIONES_ORDENES
            SET    CMO_NUMERO_OPERACION = P_NUMERO_OPERACION
            WHERE  CMO_OCO_CONSECUTIVO = P_CONSECUTIVO
            AND    CMO_OCO_BOL_MNEMONICO = P_BOL_MNEMONICO
            AND    CMO_OCO_COC_CTO_MNEMONICO = P_COC_CTO_MNEMONICO;
         ELSE
            INSERT INTO COMPLEMENTACIONES_ORDENES
               (CMO_CONSECUTIVO
               ,CMO_NUMERO_OPERACION
               ,CMO_OCO_CONSECUTIVO
               ,CMO_OCO_BOL_MNEMONICO
               ,CMO_OCO_COC_CTO_MNEMONICO)
            VALUES
               (CMO_SEQ.NEXTVAL
               ,P_NUMERO_OPERACION
               ,P_CONSECUTIVO
               ,P_BOL_MNEMONICO
               ,P_COC_CTO_MNEMONICO);
         END IF;
      END IF;
   ELSIF P_TIPO_ORDEN = 'V' THEN
      IF P_BOL_MNEMONICO = 'COL' THEN
         IF P_ACT_INS = 'A' THEN
            UPDATE ORDENES_VENTA
            SET    OVE_ESTADO_BOLSA = P_ESTADO_BOLSA
            WHERE  OVE_CONSECUTIVO = P_CONSECUTIVO
            AND    OVE_BOL_MNEMONICO = P_BOL_MNEMONICO
            AND    OVE_COC_CTO_MNEMONICO = P_COC_CTO_MNEMONICO;
         END IF;
         INSERT INTO COMPLEMENTACIONES_ORDENES
            (CMO_CONSECUTIVO
            ,CMO_CANTIDAD
            ,CMO_NUMERO_OPERACION
            ,CMO_OVE_CONSECUTIVO
            ,CMO_OVE_BOL_MNEMONICO
            ,CMO_OVE_COC_CTO_MNEMONICO)
         VALUES
            (CMO_SEQ.NEXTVAL
            ,P_CANTIDAD
            ,P_NUMERO_OPERACION
            ,P_CONSECUTIVO
            ,P_BOL_MNEMONICO
            ,P_COC_CTO_MNEMONICO);
      ELSE
         UPDATE ORDENES_VENTA
         SET    OVE_ESTADO_BOLSA = P_ESTADO_BOLSA
         WHERE  OVE_CONSECUTIVO = P_CONSECUTIVO
         AND    OVE_BOL_MNEMONICO = P_BOL_MNEMONICO
         AND    OVE_COC_CTO_MNEMONICO = P_COC_CTO_MNEMONICO;
         IF P_ACT_INS = 'A' THEN
            UPDATE COMPLEMENTACIONES_ORDENES
            SET    CMO_NUMERO_OPERACION = P_NUMERO_OPERACION
            WHERE  CMO_OVE_CONSECUTIVO = P_CONSECUTIVO
            AND    CMO_OVE_BOL_MNEMONICO = P_BOL_MNEMONICO
            AND    CMO_OVE_COC_CTO_MNEMONICO = P_COC_CTO_MNEMONICO;
         ELSE
            INSERT INTO COMPLEMENTACIONES_ORDENES
               (CMO_CONSECUTIVO
               ,CMO_NUMERO_OPERACION
               ,CMO_OVE_CONSECUTIVO
               ,CMO_OVE_BOL_MNEMONICO
               ,CMO_OVE_COC_CTO_MNEMONICO)
            VALUES
               (CMO_SEQ.NEXTVAL
               ,P_NUMERO_OPERACION
               ,P_CONSECUTIVO
               ,P_BOL_MNEMONICO
               ,P_COC_CTO_MNEMONICO);
         END IF;
      END IF;
   END IF;
END CREAR_COMPLEMENTACION_ORDEN;

PROCEDURE P_COLOCAR_ORDEN( P_CLI_TID_CODIGO       IN VARCHAR2,
                           P_CLI_NUM_IDEN         IN VARCHAR2,
                           P_USUARIO              IN VARCHAR2,
                           P_CUENTA_CORREDORES    IN NUMBER,
                           P_COLOCA_USUARIO       IN VARCHAR2,
                           P_COLOCA_TID_CODIGO    IN VARCHAR2,
                           P_COLOCA_NUM_IDEN      IN VARCHAR2,
                           P_COLOCA_TERMINAL      IN VARCHAR2,
                           P_DUENO_TID_CODIGO     IN VARCHAR2,
                           P_DUENO_NUM_IDEN       IN VARCHAR2,
                           P_ORDENANTE_TID_CODIGO IN VARCHAR2,
                           P_ORDENANTE_NUM_IDEN   IN VARCHAR2,
                           P_TIPO_ORDEN           IN VARCHAR2,
                           P_ESPECIE              IN VARCHAR2,
                           P_CANTIDAD             IN NUMBER,
                           P_FECHA_HORA           IN VARCHAR2,--IN DATE,
                           P_PORCENTAJE_COMISION  IN NUMBER,
                           P_VIG_TIPO_VIGENCIA    IN VARCHAR2,
                           P_VIG_FECHA_PERMANENCI IN VARCHAR2,--IN DATE,
                           P_VIG_HORA_PERMANENCIA IN VARCHAR2,
                           P_COND_PRECIO          IN VARCHAR2,
                           P_COND_PRECIO_LIMITIE  IN NUMBER,
                           P_COND_CRITERIOS_ADICI IN VARCHAR2,
                           P_COND_CANTIDAD_MINIMA IN NUMBER,
                           P_VIS_VISIBLE          IN NUMBER,
                           P_VIS_PORCENTAJE       IN NUMBER,
                           P_STOP_STOP            IN NUMBER,
                           P_STOP_PRECIO_STOP     IN NUMBER,
                           P_CONSOLIDAR           IN NUMBER,
                           P_CUENTA_DECEVAL       IN NUMBER,
                           P_TITULO_ORIGEN        IN VARCHAR2,
                           P_TITULO_CTA_DVAL      IN NUMBER,
                           P_TITULO_COD_FUNGIBLE  IN NUMBER,
                           P_TITULO_COD_ISIN      IN VARCHAR2,
                           P_INS_REC_MEDIO        IN VARCHAR2,
                           P_INS_REC_HORA         IN VARCHAR2,
                           P_INS_REC_DETALLE      IN VARCHAR2,
                           P_INS_ENV_FAX          IN NUMBER,
                           P_INS_ENV_NUM_FAX      IN VARCHAR2,
                           P_INS_ENV_DIRECCION    IN NUMBER,
                           P_INS_ENV_NUM_DIRECCION IN VARCHAR2,
                           P_INS_ENV_COD_CIUDAD    IN NUMBER,
                           P_INS_ENV_CONTACTO      IN VARCHAR,
                           P_CLI_PROFESIONAL       IN VARCHAR2,
                           P_OPX                   IN VARCHAR2,
                           P_CANTIDAD_INTENCION    IN NUMBER,
                           P_PRECIO_INTENCION      IN NUMBER,
                           P_COMISION_INTENCION    IN NUMBER,
                           P_IVA_ITENCION          IN NUMBER,
                           P_TOTAL_OPERACION_INT   IN NUMBER,
                           P_NETO_OPERACION_INT    IN NUMBER,
                           P_FECHA_RECEPCION       IN VARCHAR2,
                           P_ABONO_CUENTA          IN VARCHAR2 DEFAULT NULL,
                           P_VALOR_ABONO_CUENTA    IN NUMBER DEFAULT NULL,
                           P_PAGAR_A_PAGO          IN VARCHAR2 DEFAULT NULL,
