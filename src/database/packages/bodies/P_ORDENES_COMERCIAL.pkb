                           P_TODO_NADA_OPA         IN VARCHAR2 DEFAULT NULL,
                           P_VENTA_CORTO           IN VARCHAR2 DEFAULT NULL,
                           P_ID_BOLSA              IN VARCHAR2 DEFAULT NULL,
                           P_ID_ORDEN              OUT NUMBER,
                           P_CLOB                  OUT CLOB,
                           /****WGONZALEZ******/
                           P_TIPO_ORDEN_COM        IN VARCHAR2 DEFAULT NULL,
                           P_SUBYACENTE            IN VARCHAR2 DEFAULT NULL,
                           P_TIPOS_SUBYACENTE      IN VARCHAR2 DEFAULT NULL,
                           P_NUMERO_FRONT          IN VARCHAR2 DEFAULT NULL,
                           P_NUMERO_XSTREAM        IN VARCHAR2 DEFAULT NULL,
                           P_CUENTA_CAMARA         IN VARCHAR2 DEFAULT NULL,
                           P_FECHA_VENCIDA         IN VARCHAR2 DEFAULT NULL,--IN DATE,
                           P_FECHA_VENCIMIENTO     IN VARCHAR2 DEFAULT NULL,--IN DATE,
                           P_GARANTIAS_DISPONIBLES IN NUMBER DEFAULT NULL,
                           P_GARANTIAS_REQUERIDAS  IN NUMBER DEFAULT NULL,
                           P_RENTABILIDAD          IN NUMBER DEFAULT NULL,
                           P_RECEPCION_USUARIO     IN VARCHAR2 DEFAULT NULL,
                           P_ENRUTA_USUARIO        IN VARCHAR2 DEFAULT NULL,
                           P_FINALIDAD             IN VARCHAR2 DEFAULT NULL,
                           P_MERCADO               IN VARCHAR2 DEFAULT NULL,
                           P_CTA_CRCC_CRUZADA      IN VARCHAR2 DEFAULT NULL,
                           P_PRECIO_PROMEDIO       IN NUMBER DEFAULT NULL,
                           P_OBSERVACION           IN VARCHAR2 DEFAULT NULL,
                           P_PUNTOS_FORWARD        IN NUMBER DEFAULT NULL,
                           P_NDF_FORWARD           IN NUMBER DEFAULT NULL,
                           P_CONCEPTO              IN VARCHAR2 DEFAULT NULL,
                           P_CLI_TID_CODIGO_REG    IN VARCHAR2 DEFAULT NULL,
                           P_CLI_NUM_IDEN_REG      IN VARCHAR2 DEFAULT NULL,
                           P_CUENTA_CORREDORES_REG IN NUMBER DEFAULT NULL,
                           P_CUENTA_CAMARA_REG     IN VARCHAR2 DEFAULT NULL,
                           P_OBSERVACION_REG       IN VARCHAR2 DEFAULT NULL,
                           P_CANAL_ORIGEN          IN VARCHAR2 DEFAULT NULL,
                           P_TIPO_COMISION         IN VARCHAR2 DEFAULT NULL,
                           P_ORDENANTE             IN VARCHAR2 DEFAULT NULL,
               /* fdm  */
                           P_MAS_INSTRUCCIONES_PAGO IN VARCHAR2 DEFAULT NULL,
                           P_TIPO_INSTRUCCION       IN VARCHAR2 DEFAULT NULL,
                           P_FONDO                  IN VARCHAR2 DEFAULT NULL,
                           P_APORTE                 IN NUMBER DEFAULT NULL,
                           P_PAGAR_A                IN VARCHAR2 DEFAULT NULL,
                           P_TIPO_PAGO              IN VARCHAR2 DEFAULT NULL,
                           P_SUCURSAL               IN NUMBER DEFAULT NULL,
                           P_CRUCE                  IN VARCHAR2 DEFAULT NULL,
                           P_TERCERO_NOMBRE         IN VARCHAR2 DEFAULT NULL, /* info del tercero    */
                           P_TERCERO_TIPO_ID        IN VARCHAR2 DEFAULT NULL,
                           P_TERCERO_NUMERO_ID      IN VARCHAR2 DEFAULT NULL,
                           P_CONSIGNAR              IN VARCHAR2 DEFAULT NULL, /* consignar cheque  */
                           P_CONSIGNAR_BANCO        IN NUMBER DEFAULT NULL,
                           P_CONSIGNAR_CUENTA       IN VARCHAR2 DEFAULT NULL,
                           P_CONSIGNAR_TIPO_CUENTA  IN VARCHAR2 DEFAULT NULL,
                           P_TR_CUENTA_C_TIPO_ID    IN VARCHAR2 DEFAULT NULL, /* transferencia cta corredores  */
                           P_TR_CUENTA_C_NUM_ID     IN VARCHAR2 DEFAULT NULL,
                           P_TR_CUENTA_C_NUM_CUENTA IN VARCHAR2 DEFAULT NULL,
                           P_SEBRA_ID_CONTRAPARTE   IN VARCHAR2 DEFAULT NULL, /* pago sebra  */
                           P_SEBRA_OTRA_CUENTA      IN VARCHAR2 DEFAULT NULL,
                           P_SEBRA_ID_BANCO         IN NUMBER DEFAULT NULL,
                           P_SEBRA_NUMERO_CUENTA    IN VARCHAR2 DEFAULT NULL,
                           P_SEBRA_TIPO_CUENTA      IN VARCHAR2 DEFAULT NULL,
                           P_TR_BANC_ID_BANCO       IN NUMBER DEFAULT NULL,
                           P_TR_BANC_CUENTA         IN VARCHAR2 DEFAULT NULL,
                           P_TR_BANC_TIPO_CUENTA    IN VARCHAR2 DEFAULT NULL,
                           P_TASA_REGISTRO          IN NUMBER DEFAULT NULL,
                           P_ACH_ID_BANCO           IN NUMBER DEFAULT NULL,
                           P_ACH_CUENTA             IN VARCHAR2 DEFAULT NULL,
                           P_ACH_TIPO_CUENTA        IN VARCHAR2 DEFAULT NULL,
                           P_CUENTA_INSCRITA        IN VARCHAR2 DEFAULT NULL,
                           P_SOPORTE_FISICO         IN VARCHAR2 DEFAULT NULL,
                           --P_TITULO_CTA_DCV         IN NUMBER   DEFAULT NULL,
               P_TITULO_CTA_DCV         IN VARCHAR2   DEFAULT NULL, --MIC DCV BANCO REPUBLICA
                           P_RECPROF_CONSECUTIVO    IN NUMBER   DEFAULT NULL) IS

--WILLIAM CAMPOS 03/04/2020 VARIABLES PARA TIMOUT HOMEBROKER
P_NUM_INI NUMBER;
P_NUM_FIN NUMBER;
P_INI_ORDEN DATE;
P_FIN_ORDEN DATE;
P_DIF_MIN_ORDEN NUMBER;
--FIN WILLIAM CAMPOS

  CURSOR C_ENA(P_ENA_MNEMONICO ESPECIES_NACIONALES.ENA_MNEMONICO%TYPE) IS
      SELECT ENA_GNA_MNEMONICO
            ,ENA_EMI_MNEMONICO
      FROM   ESPECIES_NACIONALES
      WHERE  ENA_MNEMONICO = P_ENA_MNEMONICO;

 CURSOR ORDENANTE IS
      SELECT PER3.PER_PRIMER_APELLIDO||' '||
             PER3.PER_SEGUNDO_APELLIDO||' '||
             PER3.PER_NOMBRE
            ,RLC1.RLC_PER_NUM_IDEN
            ,RLC1.RLC_PER_TID_CODIGO
            ,RLC1.RLC_ROL_CODIGO
      FROM   PERSONAS_RELACIONADAS RLC1
            ,PERSONAS PER3
      WHERE  RLC1.RLC_CLI_PER_NUM_IDEN = P_CLI_NUM_IDEN
      AND    RLC1.RLC_CLI_PER_TID_CODIGO = P_CLI_TID_CODIGO
      AND    RLC1.RLC_ROL_CODIGO IN (1,6,7)
      AND    RLC1.RLC_ESTADO = 'A'
      AND    PER3.PER_NUM_IDEN = RLC1.RLC_PER_NUM_IDEN
      AND    PER3.PER_TID_CODIGO = RLC1.RLC_PER_TID_CODIGO
      AND    RLC1.RLC_PER_NUM_IDEN  = P_ORDENANTE_NUM_IDEN
      AND    RLC1.RLC_PER_TID_CODIGO = P_ORDENANTE_TID_CODIGO;
  C_ORDENANTE   ORDENANTE%ROWTYPE;

   CURSOR ORDENANTE_ETRADE IS
      SELECT PER3.PER_PRIMER_APELLIDO||' '||
             PER3.PER_SEGUNDO_APELLIDO||' '||
             PER3.PER_NOMBRE
            ,RLC1.RLC_PER_NUM_IDEN
            ,RLC1.RLC_PER_TID_CODIGO
            ,RLC1.RLC_ROL_CODIGO
      FROM   PERSONAS PER3
            ,PERSONAS_RELACIONADAS RLC1
      WHERE  PER3.PER_NUM_IDEN = RLC1.RLC_PER_NUM_IDEN
      AND    PER3.PER_TID_CODIGO = RLC1.RLC_PER_TID_CODIGO
      AND    RLC1.RLC_CLI_PER_NUM_IDEN = P_CLI_NUM_IDEN
      AND    RLC1.RLC_CLI_PER_TID_CODIGO = P_CLI_TID_CODIGO
      AND    NVL(RLC1.RLC_ETRADE,'N') = 'S'
      AND    RLC1.RLC_ROL_CODIGO IN (1,6,7)
      AND    RLC1.RLC_ESTADO = 'A';

   CURSOR ORDENANTE_ETRADE_INS IS
      SELECT PER3.PER_PRIMER_APELLIDO||' '||
             PER3.PER_SEGUNDO_APELLIDO||' '||
             PER3.PER_NOMBRE
            ,RLC1.RLC_PER_NUM_IDEN
            ,RLC1.RLC_PER_TID_CODIGO
            ,RLC1.RLC_ROL_CODIGO
      FROM   PERSONAS PER3
            ,PERSONAS_RELACIONADAS RLC1
      WHERE  PER3.PER_NUM_IDEN = RLC1.RLC_PER_NUM_IDEN
      AND    PER3.PER_TID_CODIGO = RLC1.RLC_PER_TID_CODIGO
      AND    RLC1.RLC_CLI_PER_NUM_IDEN = P_CLI_NUM_IDEN
      AND    RLC1.RLC_CLI_PER_TID_CODIGO = P_CLI_TID_CODIGO
      AND    RLC1.RLC_PER_NUM_IDEN  = P_ORDENANTE_NUM_IDEN
      AND    RLC1.RLC_PER_TID_CODIGO = P_ORDENANTE_TID_CODIGO
      AND    NVL(RLC1.RLC_ETRADE_INSTITUCIONAL,'N') = 'S'
      AND    RLC1.RLC_ROL_CODIGO IN (1,6,7)
      AND    RLC1.RLC_ESTADO = 'A';
  C_ORDENANTE_ETRADE ORDENANTE_ETRADE%ROWTYPE;

  CURSOR INICIALES IS
      SELECT PER_TID_CODIGO
            ,PER_NUM_IDEN
            ,PER_INICIALES_USUARIO
            ,PER_SUC_CODIGO
            ,PER_EJECUTA_ORDEN_MESA
            ,SUC_NOMBRE
            ,PER_TIPO_COMERCIAL
            ,CPR_CONSULTA_GRUPO_INDIVIDUAL
            ,PER_CODIGO_SAE_ACC
            ,PER_TIP_COMERCIAL_UDF
      FROM   CENTROS_PRODUCCION
            ,PERSONAS_CENTROS_PRODUCCION
            ,PERSONAS
            ,SUCURSALES
      WHERE  CPR_ESTADO = 'A'
      AND    CPR_MNEMONICO = PCP_CPR_MNEMONICO
      AND    PCP_PER_NUM_IDEN = PER_NUM_IDEN
      AND    PCP_PER_TID_CODIGO = PER_TID_CODIGO
      AND    PER_NUM_IDEN = P_COLOCA_NUM_IDEN
      AND    PER_TID_CODIGO = P_COLOCA_TID_CODIGO
      AND    PER_ES_CORREDOR = 'S' /*CORREDOR*/
      AND    PER_ESTADO = 'A'
      AND    PER_SUC_CODIGO = SUC_CODIGO;
  C_INICIALES    INICIALES%ROWTYPE;
  CURSOR C_LEO IS
      SELECT SUC_LEO_CONSECUTIVO
      FROM SUCURSALES
      WHERE  SUC_CODIGO = C_INICIALES.PER_SUC_CODIGO;
  LEO  LIBROS_ELECTRONICOS.LEO_CONSECUTIVO%TYPE;

  CURSOR C_COMITENTES(P_CUENTA_DA NUMBER) IS
      SELECT COD_CLI_PER_NUM_IDEN_RELACIONA
            ,COD_CLI_PER_TID_CODIGO_RELACIO
            ,PER_NOMBRE
      FROM   COMITENTES_DECEVAL
            ,FILTRO_PERSONAS
      WHERE  PER_NUM_IDEN = COD_CLI_PER_NUM_IDEN_RELACIONA
      AND    PER_TID_CODIGO = COD_CLI_PER_TID_CODIGO_RELACIO
      AND    COD_CUD_CUENTA_DECEVAL = P_CUENTA_DA
      AND    COD_CLI_PER_NUM_IDEN_RELACIONA = PER_NUM_IDEN
      AND    COD_CLI_PER_TID_CODIGO_RELACIO = PER_TID_CODIGO
      ORDER BY COD_CONSECUTIVO;
  CURSOR CONSTANTE IS
    SELECT CON_VALOR
    FROM CONSTANTES
    WHERE CON_MNEMONICO = 'TNS';

  CURSOR PRODUCTO IS
    SELECT  CCC_ETRADE,'SP' CCP_PRO_MNEMONICO,CCC_PANTALLA_LIVIANA
    FROM CUENTAS_CLIENTE_CORREDORES
    WHERE CCC_CLI_PER_NUM_IDEN = P_CLI_NUM_IDEN
      AND CCC_CLI_PER_TID_CODIGO = P_CLI_TID_CODIGO
      AND CCC_NUMERO_CUENTA = P_CUENTA_CORREDORES;

  CURSOR PRODUCTO_ETRADE IS
    SELECT  CCC_ETRADE,'SP' CCP_PRO_MNEMONICO,CCC_PANTALLA_LIVIANA
    FROM CUENTAS_CLIENTE_CORREDORES
    WHERE CCC_CLI_PER_NUM_IDEN = P_CLI_NUM_IDEN
      AND CCC_CLI_PER_TID_CODIGO = P_CLI_TID_CODIGO
      AND CCC_NUMERO_CUENTA = P_CUENTA_CORREDORES
      AND NVL(CCC_ETRADE,' ') ='S';

  CURSOR PRODUCTO_ETRADE_INS IS
    SELECT   CCC_ETRADE_INSTITUCIONAL CCC_ETRADE
           ,'SP' CCP_PRO_MNEMONICO
           ,CCC_PANTALLA_LIVIANA
    FROM CUENTAS_CLIENTE_CORREDORES
    WHERE CCC_CLI_PER_NUM_IDEN = P_CLI_NUM_IDEN
      AND CCC_CLI_PER_TID_CODIGO = P_CLI_TID_CODIGO
      AND CCC_NUMERO_CUENTA = P_CUENTA_CORREDORES
      AND NVL(CCC_ETRADE_INSTITUCIONAL,' ') ='S';

  CURSOR PRODUCTO_ETRADE_PLV IS
    SELECT  CCC_PANTALLA_LIVIANA CCC_ETRADE
           ,'SP' CCP_PRO_MNEMONICO
           ,CCC_PANTALLA_LIVIANA
    FROM CUENTAS_CLIENTE_CORREDORES
    WHERE CCC_CLI_PER_NUM_IDEN = P_CLI_NUM_IDEN
      AND CCC_CLI_PER_TID_CODIGO = P_CLI_TID_CODIGO
      AND CCC_NUMERO_CUENTA = P_CUENTA_CORREDORES
      AND NVL(CCC_PANTALLA_LIVIANA,' ') ='S';
  C_PRODUCTO PRODUCTO%ROWTYPE;

  CURSOR ADM_PORTAFOLIO IS
    SELECT NVL(CLI_ADM_PORTAFOLIO_DCVAL,'S') CLI_ADM_PORTAFOLIO_DCVAL
        ,DECODE(P_TIPO_ORDEN,'V',DECODE( CLI_ECL_MNEMONICO,'BAA',NVL((SELECT NVL(MOI_COLOCAR_ORDEN,'N')
                                                FROM   MOTIVOS_INACTIVACIONES
                                                WHERE  MOI_MNEMONICO = CLI_MOI_MNEMONICO
                                                AND    MOI_COLOCAR_ORDEN = 'S'),'N'),
                                         NVL(( SELECT  NVL(ECL_COLOCAR_ORDEN,'N')
                                           FROM ESTADOS_CLIENTE
                                           WHERE  ECL_MNEMONICO = CLI_ECL_MNEMONICO),'N')
                                          ),
                                        NVL(( SELECT  NVL(ECL_COLOCAR_ORDEN,'N')
                                           FROM ESTADOS_CLIENTE
                                           WHERE ECL_MNEMONICO = CLI_ECL_MNEMONICO ),'N')
                                          ) ECL_COLOCAR_ORDEN
        ,PER.PER_NOMBRE
        ,CLI_PERFIL_RIESGO
    FROM FILTRO_PERSONAS PER, CLIENTES CLI
    WHERE PER.PER_TID_CODIGO = CLI.CLI_PER_TID_CODIGO
     AND PER.PER_NUM_IDEN = CLI.CLI_PER_NUM_IDEN
     AND CLI.CLI_PER_NUM_IDEN = P_CLI_NUM_IDEN
     AND CLI.CLI_PER_TID_CODIGO = P_CLI_TID_CODIGO;

  CURSOR PORTAFOLIO(P_ENA_MNEMONICO VARCHAR2,
                    P_CUENTA_DECEVAL NUMBER) IS
    SELECT SUM(SALDO_DISPONIBLE) SALDO_DISPONIBLE
      FROM GL_PORTAFOLIO_CLIENTE
   WHERE ENA_MNEMONICO = P_ENA_MNEMONICO
    AND  CUENTA_DECEVAL = P_CUENTA_DECEVAL ;

  CURSOR PERSONA_TIPO (P_NUN_IDEN VARCHAR2,P_TID_CODIGO VARCHAR2) IS
    SELECT PER_TIPO
          ,PER_ORIGEN
          ,DECODE(PER_TIPO,'PJU',PER_RAZON_SOCIAL,PER_NOMBRE) PER_NOMBRE
          ,TRIM(PER_PRIMER_APELLIDO)||' '||
           TRIM(PER_SEGUNDO_APELLIDO) PER_APELLIDOS
    FROM PERSONAS
    WHERE PER_NUM_IDEN = P_NUN_IDEN
    AND PER_TID_CODIGO = P_TID_CODIGO;


  /*****WGONZALEZ******/
  CURSOR INICIALES_D IS
      SELECT PER_TID_CODIGO
            ,PER_NUM_IDEN
            ,PER_INICIALES_USUARIO
            ,PER_SUC_CODIGO
            ,PER_EJECUTA_ORDEN_MESA
            ,SUC_NOMBRE
            ,PER_TIPO_COMERCIAL
            ,CPR_CONSULTA_GRUPO_INDIVIDUAL
            ,PER_CODIGO_SAE_ACC
            ,PER_TIP_COMERCIAL_UDF
      FROM   CENTROS_PRODUCCION
            ,PERSONAS_CENTROS_PRODUCCION
            ,PERSONAS
            ,SUCURSALES
      WHERE  CPR_ESTADO         = 'A'
      AND    CPR_MNEMONICO      = PCP_CPR_MNEMONICO
      AND    PCP_PER_NUM_IDEN   = PER_NUM_IDEN
      AND    PCP_PER_TID_CODIGO = PER_TID_CODIGO
      AND    PER_NOMBRE_USUARIO = P_COLOCA_USUARIO
      AND    PER_ES_CORREDOR    = 'S' /*CORREDOR*/
      AND    PER_ESTADO         = 'A'
      AND    PER_SUC_CODIGO     = SUC_CODIGO;

-- fdm mensaje de error muy largo en el bus
/*****CRCASTILLO******/
  CURSOR INICIALES_R IS
      SELECT PER_TID_CODIGO
            ,PER_NUM_IDEN
            ,PER_INICIALES_USUARIO
            ,PER_SUC_CODIGO
            ,PER_EJECUTA_ORDEN_MESA
            ,SUC_NOMBRE
            ,PER_TIPO_COMERCIAL
            ,CPR_CONSULTA_GRUPO_INDIVIDUAL
            ,PER_CODIGO_SAE_ACC
            ,PER_TIP_COMERCIAL_UDF
            ,CPR_MNEMONICO
      FROM   CENTROS_PRODUCCION
            ,PERSONAS_CENTROS_PRODUCCION
            ,PERSONAS
            ,SUCURSALES
      WHERE  CPR_ESTADO         = 'A'
      AND    CPR_MNEMONICO      = PCP_CPR_MNEMONICO
      AND    PCP_PER_NUM_IDEN   = PER_NUM_IDEN
      AND    PCP_PER_TID_CODIGO = PER_TID_CODIGO
      AND    PER_NOMBRE_USUARIO = P_RECEPCION_USUARIO
      AND    PER_ES_CORREDOR    = 'S' /*CORREDOR*/
      AND    PER_ESTADO         = 'A'
      AND    PER_SUC_CODIGO     = SUC_CODIGO;

   R_INICIALES_R INICIALES_R%ROWTYPE;       
   CURSOR C_EXCEPCIONES (NRO_ID  VARCHAR2,
                         TIPO_ID VARCHAR2,
                         P_DIAS  NUMBER) IS
      SELECT COUNT(*)
      FROM OPERACIONES_FUERA_PERFIL
      WHERE OFP_CLI_PER_NUM_IDEN = NRO_ID
      AND OFP_CLI_PER_TID_CODIGO = TIPO_ID
      AND OFP_FECHA_OPERACION >= TRUNC(SYSDATE) - P_DIAS
      AND OFP_ESTADO NOT IN ('ANU','NEJ')
      AND OFP_TIPO_EXIMENTE = 'FP';

   CURSOR C_EXCEP_DISPONIBLEFP (NRO_ID  VARCHAR2,
                             TIPO_ID VARCHAR2,
                             TIPO    VARCHAR2,
                             P_DIAS  NUMBER
                             ) IS
      SELECT 'X'
      FROM OPERACIONES_FUERA_PERFIL
      WHERE OFP_CLI_PER_NUM_IDEN = NRO_ID
      AND OFP_CLI_PER_TID_CODIGO = TIPO_ID
      AND OFP_FECHA_OPERACION >= TRUNC(SYSDATE) - P_DIAS
      AND OFP_ESTADO NOT IN ('ANU','NEJ')  -- ANU = ANULADAS, NEJ = NO EJECUTADAS
      AND OFP_OCO_CONSECUTIVO IS NULL
      AND OFP_TIPO_EXIMENTE = TIPO;

   CURSOR C_EXCEP_DISPONIBLE (NRO_ID  VARCHAR2,
                             TIPO_ID VARCHAR2,
                             TIPO    VARCHAR2,
                             ESPECIE    VARCHAR2,
                             P_DIAS  NUMBER) IS
      SELECT 'X'
      FROM OPERACIONES_FUERA_PERFIL
      WHERE OFP_CLI_PER_NUM_IDEN = NRO_ID
      AND OFP_CLI_PER_TID_CODIGO = TIPO_ID
      AND OFP_FECHA_OPERACION >= TRUNC(SYSDATE) - P_DIAS
      AND OFP_ESTADO NOT IN ('ANU','NEJ')  -- ANU = ANULADAS, NEJ = NO EJECUTADAS
      AND OFP_OCO_CONSECUTIVO IS NULL
      AND OFP_TIPO_EXIMENTE = TIPO
      AND OFP_ENA_MNEMONICO =  ESPECIE;

      CURSOR C_ENA2(P_ENA_MNEMONICO ESPECIES_NACIONALES.ENA_MNEMONICO%TYPE) IS
      SELECT ENA_GNA_MNEMONICO
            ,ENA_EMI_MNEMONICO
            ,ENA_RIESGO_CORREDORES
      FROM   ESPECIES_NACIONALES
      WHERE  ENA_MNEMONICO = P_ENA_MNEMONICO;

      CURSOR C_CLIENTE IS
      SELECT CLI_PERFIL_RIESGO
            ,CLI_FECHA_NACIMIENTO
            ,PER_TIPO
            ,CLI_PROFESIONAL
      FROM   CLIENTES
            ,PERSONAS
      WHERE  CLI_PER_NUM_IDEN = P_CLI_NUM_IDEN
      AND    CLI_PER_TID_CODIGO = P_CLI_TID_CODIGO
      AND    PER_NUM_IDEN = CLI_PER_NUM_IDEN
      AND    PER_TID_CODIGO = CLI_PER_TID_CODIGO;


      CURSOR C_CUENTA_DECEVAL(P_CUENTA_DECEVAL NUMBER,P_CLI_PER_NUM_IDEN VARCHAR2, P_CLI_PER_TID_CODIGO VARCHAR2)   IS
      SELECT CUD_CUENTA_APT
      FROM CUENTAS_DECEVAL
      WHERE CUD_CUENTA_DECEVAL = P_CUENTA_DECEVAL
      AND CUD_CLI_PER_NUM_IDEN = P_CLI_PER_NUM_IDEN
      AND CUD_CLI_PER_TID_CODIGO = P_CLI_PER_TID_CODIGO;

      CURSOR C_ENA_T(P_ENA_MNEMONICO ESPECIES_NACIONALES.ENA_MNEMONICO%TYPE) IS
      SELECT ENA_GNA_MNEMONICO
            ,ENA_EMI_MNEMONICO
            ,ENA_RIESGO_CORREDORES
      FROM   ESPECIES_NACIONALES
      WHERE  ENA_MNEMONICO = P_ENA_MNEMONICO;

      CURSOR C_ENA2_T(P_GNA_MNEMONICO ESPECIES_NACIONALES.ENA_GNA_MNEMONICO%TYPE
                ,P_EMI_MNEMONICO ESPECIES_NACIONALES.ENA_EMI_MNEMONICO%TYPE) IS
      SELECT ENA_GNA_MNEMONICO
            ,ENA_EMI_MNEMONICO
            ,ENA_RIESGO_CORREDORES
      FROM   ESPECIES_NACIONALES
      WHERE  ENA_GNA_MNEMONICO = P_GNA_MNEMONICO
      AND    ENA_EMI_MNEMONICO = P_EMI_MNEMONICO;

      CURSOR C_CONSTANTES(P_CON_MNEMONICO VARCHAR2) IS
      SELECT CON_VALOR
      FROM   CONSTANTES
      WHERE  CON_MNEMONICO = P_CON_MNEMONICO;

   --- fin fdm

/*2022-10-27 JBOHORQUEZ REGLAS DE NEGOCIO DECRETO 661*/
  CURSOR C_CLASF_PROD (PRO_MNEMONICO IN VARCHAR2) IS
     SELECT PRO_CLASIFICACION
     FROM PRODUCTOS
     WHERE PRO_MNEMONICO = PRO_MNEMONICO;

   V_PROD_CLASIFICACION VARCHAR2(4);
 /*FIN DECRETO 661*/
 R_INICIALES    INICIALES_D%ROWTYPE;

  C_CONSTANTE          CONSTANTE%ROWTYPE;
  V_GNA_MNEMONICO      ESPECIES_NACIONALES.ENA_GNA_MNEMONICO%TYPE;
  V_EMI_MNEMONICO      ESPECIES_NACIONALES.ENA_EMI_MNEMONICO%TYPE;
  V_TIPO_PERSONA       PERSONAS.PER_TIPO%TYPE;
  V_PER_NOMBRE_PER     PERSONAS.PER_RAZON_SOCIAL%TYPE;
  V_PER_APELLIDOS      PERSONAS.PER_RAZON_SOCIAL%TYPE;
  COMITENTES           C_COMITENTES%ROWTYPE;
  V_CUENTAS_DECEVAL     CUENTAS_DECEVAL%ROWTYPE;
  --C_ADM_PORTAFOLIO     ADM_PORTAFOLIO%ROWTYPE;
  C_PORTAFOLIO         PORTAFOLIO%ROWTYPE;
  V_CCP_PRO_MNEMONICO  VARCHAR2(50);
  V_LEO                LIBROS_ELECTRONICOS.LEO_CONSECUTIVO%TYPE;
  V_CLI_ADM_POR_DCVAL  CLIENTES.CLI_ADM_PORTAFOLIO_DCVAL%TYPE;
  V_ECL_COLOCAR_ORDEN  ESTADOS_CLIENTE.ECL_COLOCAR_ORDEN%TYPE;
  V_ABONO_CUENTA       ORDENES_VENTA.OVE_ABONO_CUENTA%TYPE;
  V_PER_NOMBRE         FILTRO_PERSONAS.PER_NOMBRE%TYPE;
  V_ODP_CONSECUTIVO    ORDENES_DE_PAGO.ODP_CONSECUTIVO%TYPE;
  V_ODP_A_NOMBRE_DE    ORDENES_DE_PAGO.ODP_A_NOMBRE_DE%TYPE;
  V_ODP_PAGAR_A        ORDENES_DE_PAGO.ODP_PAGAR_A%TYPE;
  V_ODP_NUM_IDEN       ORDENES_DE_PAGO.ODP_NUM_IDEN%TYPE;
  V_ODP_TID_CODIGO     ORDENES_DE_PAGO.ODP_TID_CODIGO%TYPE;
  V_OVE_GIRAR          ORDENES_VENTA.OVE_GIRAR%TYPE;
  V_OVE_TIPO_ABONO     ORDENES_VENTA.OVE_TIPO_PAGO_ABONO_CUENTA%TYPE;
  V_PER_TID_ENRUTA     PERSONAS.PER_TID_CODIGO%TYPE;
  V_PER_NUM_ENRUTA     PERSONAS.PER_NUM_IDEN%TYPE;
  V_CANAL_ORIGEN       ORDENES_COMPRA.OCO_CANAL_ORIGEN%TYPE;
  V_TPA_MNEMONICO      ORDENES_DE_PAGO.ODP_TPA_MNEMONICO%TYPE;
  V_ODP_CONSIGNAR      ORDENES_DE_PAGO.ODP_CONSIGNAR%TYPE;
  V_DUENO_NUM_IDEN     ORDENES_VENTA.OVE_PER_NUM_IDEN_ES_DUENO%TYPE;
  V_PER_ORIGEN         PERSONAS.PER_ORIGEN%TYPE;
  V_ISIN               FUNGIBLES.FUG_ISI_MNEMONICO%TYPE;
  V_NOC_CLI_PER_NUM_IDE CUENTAS_CLIENTE_CORREDORES.CCC_CLI_PER_NUM_IDEN%TYPE;

  V_VALOR_CONS_INT     CONSTANTES.CON_VALOR%TYPE;
  V_VALOR_DATE_CONS    CONSTANTES.CON_VALOR_DATE%TYPE;
  V_VALOR_SAE_S4       CONSTANTES.CON_VALOR_CHAR%TYPE;
  V_NO_REGIS_INST      ORDENES_COMPRA.OCO_NO_REGISTRA_INSTRUCCION%TYPE;

  V_CLI_PERFIL_RIESGO  CLIENTES.CLI_PERFIL_RIESGO%TYPE;
  V_OCO_COC_CTO_MNEMONICO ORDENES_COMPRA.OCO_COC_CTO_MNEMONICO%TYPE;

  V_ERRORES_ODP        NUMBER;
  V_INS_ENV_FAX        VARCHAR2(1);
  V_INS_ENV_DIRECCION  VARCHAR2(1);
  V_VIS_VISIBLE        VARCHAR2(1);
  V_STOP_STOP          VARCHAR2(1);
  V_VALOR_CHAR         VARCHAR2(200);
  V_FECHA_RECEPCION    VARCHAR2(20);
  V_DETALLE_ACH        VARCHAR2(1);
  V_CREA_SALDO         VARCHAR2(1);
  V_MENSAJE_SALDO      VARCHAR2(4000);
  V_QUERY_CUD          VARCHAR2(4000);
  V_DSP_SALDO          NUMBER;
  V_VALOR              NUMBER;
  V_SUMA               NUMBER := 0;
  V_VALOR1             NUMBER;
  V_TOTAL              NUMBER;
  V_APLIC              NUMBER;
  V_DSP_TOTAL_ORDENES  NUMBER;
  V_DSP_NETO           NUMBER;
  V_CUENTA_DECEVAL     NUMBER;
  V_TITULO_CTA_DVAL    NUMBER;
  V_ERRORES            NUMBER;
  V_SALDO              NUMBER;
  V_VALOR_CONSTANTE    NUMBER;
  V_VALOR_NEG          NUMBER;
  V_VALOR_DATE         DATE;
  V_VALOR_MMH          NUMBER;
  V_VALOR_IMH          NUMBER;
  V_VALOR_TMMH         NUMBER;
  IO_CURSOR            P_WEB_CLIENTE.O_CURSOR;
  IO_CURSOR_CUD         P_WEB_CLIENTE.O_CURSOR;
  V_RENTA_FIJA VARCHAR2(200);
  CANTIDAD_EXC  NUMBER;
  COND_EXC      VARCHAR2(1);
  ENA1  C_ENA2%ROWTYPE;
    --fdm nuevas variables instrucciones
  V_ODP_ENTREGAR_RECOGE      VARCHAR2(1); -- NOT NULL
  V_ODP_ENVIA_FAX            VARCHAR2(1); -- NOT NULL
  V_ODP_CRUCE_CHEQUE         VARCHAR2(2); -- NOT NULL
  V_ODP_ES_CLIENTE           VARCHAR2(1); -- NOT NULL
  V_ODP_BAN_CODIGO           NUMBER(5);
  V_ODP_NUM_CUENTA_CONSIGNAR VARCHAR2(20);
  V_ODP_TCB_MNEMONICO        VARCHAR2(3);
  V_ODP_FIC_CODIGO_BOLSA     ORDENES_DE_PAGO.ODP_FIC_CODIGO_BOLSA%TYPE;
  V_ODP_FIC_PER_TID_CODIGO   ORDENES_DE_PAGO.ODP_FIC_PER_TID_CODIGO%TYPE;
  AUTORIZADO           VARCHAR2(5);
  CLIENTE C_CLIENTE%ROWTYPE;
  V_CUD_CUENTA_APT     CUENTAS_DECEVAL.CUD_CUENTA_APT%TYPE;
  V_GNA_MNEMONICO_T      ESPECIES_NACIONALES.ENA_GNA_MNEMONICO%TYPE;
  V_EMI_MNEMONICO_T      ESPECIES_NACIONALES.ENA_EMI_MNEMONICO%TYPE;
  V_CALIFICACION_T       ESPECIES_NACIONALES.ENA_RIESGO_CORREDORES%TYPE;
  DIAS  NUMBER;
  FECHA_T DATE;
  vtest varchar2(1000);
  --fdm fin nuevas variables
  --App Complementaciones RF RV 19/11/2020
  V_OCO_COBRAR_RETIRO_PARCIAL   ORDENES_COMPRA.OCO_COBRAR_RETIRO_PARCIAL%TYPE;
  V_OCO_CFO_FON_CODIGO          ORDENES_COMPRA.OCO_CFO_FON_CODIGO%TYPE;
  V_OCO_CFO_CODIGO              ORDENES_COMPRA.OCO_CFO_CODIGO%TYPE;
  V_OCO_NO_REGISTRA_INSTRUCCION ORDENES_COMPRA.OCO_NO_REGISTRA_INSTRUCCION%TYPE;
  V_OVE_INCREMENTO_FONDO        ORDENES_VENTA.OVE_INCREMENTO_FONDO%TYPE;
  V_OVE_CFO_FON_CODIGO          ORDENES_VENTA.OVE_CFO_FON_CODIGO%TYPE;
  V_OVE_CFO_CODIGO              ORDENES_VENTA.OVE_CFO_CODIGO%TYPE;
  V_OVE_MAS_INSTRUC_COBRO_PAGO  ORDENES_VENTA.OVE_MAS_INSTRUC_COBRO_PAGO%TYPE;
  V_OVE_NO_REGISTRA_INSTRUCCION ORDENES_VENTA.OVE_NO_REGISTRA_INSTRUCCION%TYPE;
  V_VALOR_COMRV                  VARCHAR2(5);
  V_VALOR_COMRF                  VARCHAR2(5);
  V_ORDEN_DCV                    VARCHAR2(1);
  V_DIAS                         NUMBER;
  V_LIMITE_EX                    NUMBER;
  V_DIAS_PERFILAM                 NUMBER;
  V_CONTADOR_P                   NUMBER;
  P_LEO_CONSECUTIVO ORDENES_DERIVADOS.ORDE_LEO_CONSECUTIVO%TYPE;          

BEGIN
   V_ERRORES := 0;
   P_ID_ORDEN := NULL;
   --App Complementaciones RF RV
   V_VALOR_COMRV:='COMRV';
   V_VALOR_COMRF:='COMRF';

   --WILLIAM CAMPOS , PARA CALCULO DE TIMEOUT EN ORDENES HOMBEBROKER POR SERVICIO
      P_INI_ORDEN := SYSDATE;
      --P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_ORDENES_COMERCIAL.P_COLOCAR_ORDEN','INI:'|| P_CANAL_ORIGEN);
   -- FIN WILLIAM CAMPOS

IF TRIM(P_CANAL_ORIGEN) IN ('FIXBR') THEN
   P_TOOLS.CONSULTARCONSTANTE(
   P_CONSTANTE => 'ODE',
   P_VALOR => V_VALOR_CONSTANTE,
   P_VALOR_DATE => V_VALOR_DATE,
   P_VALOR_CHAR => V_VALOR_CHAR
   );

   IF  NVL(V_VALOR_CHAR,'N') = 'N' THEN
      V_ERRORES := V_ERRORES + 1;
      P_CAB.CREARERROR('Colocacion de Ordenes de Derivados no Habilitada.. Intentar mas tarde');
   END IF;

   OPEN INICIALES_D;
   FETCH INICIALES_D INTO R_INICIALES;
      IF INICIALES_D%NOTFOUND THEN
         V_ERRORES := V_ERRORES + 1;
         P_CAB.CREARERROR('Comercial no existe en COEASY');
      END IF;
   CLOSE INICIALES_D;

   OPEN INICIALES_R;
   FETCH INICIALES_R INTO R_INICIALES_R;
      IF INICIALES_R%NOTFOUND THEN
         V_ERRORES := V_ERRORES + 1;
         P_CAB.CREARERROR('Comercial no existe en COEASY');
      END IF;
   CLOSE INICIALES_R;

   IF R_INICIALES_R.CPR_MNEMONICO IN (60,61,41,42,43,44,45,46,47,51,52,53,70,71,72,73,75,76,77,80,83) THEN
     P_LEO_CONSECUTIVO := 11;
   ELSIF R_INICIALES_R.CPR_MNEMONICO IN (820,35,36,650,78,37,33,34,24,25,26,27,28,29,525,3,4,5,18,19,
                                       8,11,13,20,21,22,23,30,31,58,59,54,56,57,55,64,65,62,63,17,
                                       67,68,66,38,39,40,48,49,50,69,74,79,81,82) THEN
     P_LEO_CONSECUTIVO := 10;
   END IF;
   IF V_ERRORES = 0 THEN
      SELECT ORDE_SEQ.NEXTVAL INTO P_ID_ORDEN FROM DUAL;
      INSERT INTO ORDENES_DERIVADOS
            (ORDE_CONSECUTIVO
            ,ORDE_VIO_MNEMONICO
            ,ORDE_TOC_MNEMONICO
            ,ORDE_PER_TID_CODIGO
            ,ORDE_PER_NUM_IDEN
            ,ORDE_LEO_CONSECUTIVO
            ,ORDE_FIC_ID
            ,ORDE_ESC_SYT_MNEMONICO
            ,ORDE_ESC_SYT_TSU_MNEMONICO
            ,ORDE_ESC_MNEMONICO
            ,ORDE_EOC_MNEMONICO
            ,ORDE_CCC_CLI_PER_TID_CODIGO
            ,ORDE_CCC_CLI_PER_NUM_IDEN
            ,ORDE_CCC_NUMERO_CUENTA
            ,ORDE_BOL_MNEMONICO
            ,ORDE_NUMERO_FRONT
            ,ORDE_NUMERO_XSTREAM
            ,ORDE_CONSECUTIVO_LEO
            ,ORDE_CTCA_CAMARA
            ,ORDE_TIPO_ORDEN
            ,ORDE_HORA_RECEPCION
            ,ORDE_FECHA_Y_HORA
            ,ORDE_FECHA_CRONOLOGICA
            ,ORDE_FECHA_PERMANENCIA
            ,ORDE_HORA_PERMANENCIA
            ,ORDE_FECHA_MODIFICACION
            ,ORDE_FECHA_ANU_CAN
            ,ORDE_FECHA_VENCIDA
            ,ORDE_FECHA_VENCIMIENTO
            ,ORDE_ANU_CAN_POR
            ,ORDE_RAZON_ANU_CAN
            ,ORDE_MODIFICADA_POR
            ,ORDE_CANTIDAD_CONTRATOS
            ,ORDE_CANTIDAD_MINIMA
            ,ORDE_CANTIDAD_VISIBLE
            ,ORDE_CANTIDAD_ACUMULADA
            ,ORDE_PRECIO_LIMITE
            ,ORDE_STOP
            ,ORDE_PRECIO_STOP
            ,ORDE_COMISION
            ,ORDE_VALOR_COMISION
            ,ORDE_IVA_COMISION
            ,ORDE_MEDIO_RECEPCION
            ,ORDE_DETALLE_MEDIO_RECEPCION
            ,ORDE_ORDENANTE
            ,ORDE_GARANTIAS_DISPONIBLES
            ,ORDE_GARANTIAS_REQUERIDAS
            ,ORDE_OPERACION_TOTAL
            ,ORDE_RENTABILIDAD
            ,ORDE_USUARIO_INGRESA
            ,ORDE_ORIGEN
            ,ORDE_USUARIO_RECEPCION
            ,ORDE_USUARIO_ENRUTA
            ,ORDE_ORDE_FINALIDAD
            ,ORDE_MERCADO
            ,ORDE_CTA_CRCC_CRUZADA
            ,ORDE_PRECIO_PROMEDIO
            ,ORDE_OBSERVACION
            ,ORDE_EJECUTA_ORDEN_MESA
            ,ORDE_PUNTOS_FORWARD
            ,ORDE_NDF_FORWARD
            ,ORDE_CONCEPTO
            ,ORDE_CCC_CLI_PER_TID_COD_REG
            ,ORDE_CCC_CLI_PER_NUM_IDEN_REG
            ,ORDE_CCC_NUMERO_CUENTA_REG
            ,ORDE_ORDE_CONSECUTIVO
            ,ORDE_CTCA_CAMARA_REG
            ,ORDE_OBSERVACION_REG
            ,ORDE_CANAL_ORIGEN
            ,ORDE_ANULADO_POR
            ,ORDE_FECHA_ANULACION
            ,ORDE_MOTIVO_ANULACION
            ,ORDE_OBSERVACION_CORRECCION
            ,ORDE_PER_NUM_IDEN_MODIFICA
            ,ORDE_PER_TID_CODIGO_MODIFICA
            ,ORDE_TIPO_COMISION
            ,ORDE_RLC_PER_NUM_IDEN
            ,ORDE_RLC_PER_TID_CODIGO
            ,ORDE_ULTIMA_ACTUALIZACION
            )
            VALUES (P_ID_ORDEN              --ORDE_CONSECUTIVO
                   ,P_VIG_TIPO_VIGENCIA     --ORDE_VIO_MNEMONICO
                   ,P_TIPO_ORDEN_COM        --ORDE_TOC_MNEMONICO
                   ,P_DUENO_TID_CODIGO      --ORDE_PER_TID_CODIGO
                   ,P_DUENO_NUM_IDEN        --ORDE_PER_NUM_IDEN
                   ,P_LEO_CONSECUTIVO                      --ORDE_LEO_CONSECUTIVO
                   ,'860079174'             --ORDE_FIC_ID
                   ,P_SUBYACENTE            --ORDE_ESC_SYT_MNEMONICO
                   ,P_TIPOS_SUBYACENTE      --ORDE_ESC_SYT_TSU_MNEMONICO
                   ,P_ESPECIE               --ORDE_ESC_MNEMONICO
                   ,'COL'                   --ORDE_EOC_MNEMONICO
                   ,P_CLI_TID_CODIGO        --ORDE_CCC_CLI_PER_TID_CODIGO
                   ,P_CLI_NUM_IDEN          --ORDE_CCC_CLI_PER_NUM_IDEN
                   ,P_CUENTA_CORREDORES     --ORDE_CCC_NUMERO_CUENTA
                   ,'BOG'                   --ORDE_BOL_MNEMONICO
                   ,P_NUMERO_FRONT          --ORDE_NUMERO_FRONT
                   ,P_NUMERO_XSTREAM        --ORDE_NUMERO_XSTREAM
                   ,NULL                    --ORDE_CONSECUTIVO_LEO
                   ,P_CUENTA_CAMARA         --ORDE_CTCA_CAMARA
                   ,P_TIPO_ORDEN            --ORDE_TIPO_ORDEN
                   ,P_INS_REC_HORA          --ORDE_HORA_RECEPCION
                   ,SYSDATE                 --ORDE_FECHA_Y_HORA
                   ,SYSDATE                 --ORDE_FECHA_CRONOLOGICA
                   ,TO_DATE(P_VIG_FECHA_PERMANENCI,'DD-MM-YYYY HH24:MI:SS')  --ORDE_FECHA_PERMANENCIA
                   ,P_VIG_HORA_PERMANENCIA  --ORDE_HORA_PERMANENCIA
                   ,NULL                    --ORDE_FECHA_MODIFICACION
                   ,NULL                    --ORDE_FECHA_ANU_CAN
                   ,TO_DATE(P_FECHA_VENCIDA,'DD-MM-YYYY HH24:MI:SS')         --ORDE_FECHA_VENCIDA
                   ,TO_DATE(P_FECHA_VENCIMIENTO,'DD-MM-YYYY HH24:MI:SS')     --ORDE_FECHA_VENCIMIENTO
                   ,NULL                    --ORDE_ANU_CAN_POR
                   ,NULL                    --ORDE_RAZON_ANU_CAN
                   ,NULL                    --ORDE_MODIFICADA_POR
                   ,P_CANTIDAD              --ORDE_CANTIDAD_CONTRATOS
                   ,P_COND_CANTIDAD_MINIMA  --ORDE_CANTIDAD_MINIMA
                   ,P_VIS_VISIBLE           --ORDE_CANTIDAD_VISIBLE
                   ,P_CANTIDAD_INTENCION    --ORDE_CANTIDAD_ACUMULADA
                   ,P_COND_PRECIO_LIMITIE   --ORDE_PRECIO_LIMITE
                   ,DECODE(P_STOP_STOP,0,'N') --ORDE_STOP
                   ,P_STOP_PRECIO_STOP      --ORDE_PRECIO_STOP
                   ,P_PORCENTAJE_COMISION   --ORDE_COMISION
                   ,P_COMISION_INTENCION    --ORDE_VALOR_COMISION
                   ,P_IVA_ITENCION          --ORDE_IVA_COMISION
                   ,DECODE(P_INS_REC_MEDIO,'INT','OTR',P_INS_REC_MEDIO) --ORDE_MEDIO_RECEPCION
                   ,P_INS_REC_DETALLE       --ORDE_DETALLE_MEDIO_RECEPCION
                   ,P_ORDENANTE             --ORDE_ORDENANTE
                   ,P_GARANTIAS_DISPONIBLES --ORDE_GARANTIAS_DISPONIBLES
                   ,P_GARANTIAS_REQUERIDAS  --ORDE_GARANTIAS_REQUERIDAS
                   ,P_TOTAL_OPERACION_INT   --ORDE_OPERACION_TOTAL
                   ,P_RENTABILIDAD          --ORDE_RENTABILIDAD
                   ,P_COLOCA_USUARIO        --ORDE_USUARIO_INGRESA
                   ,DECODE(P_TITULO_ORIGEN,'DA','0'
                                          ,'SP','1'
                                          ,'NP','2'
                                          ,NULL)         --ORDE_ORIGEN
                   ,P_RECEPCION_USUARIO     --ORDE_USUARIO_RECEPCION
                   ,P_ENRUTA_USUARIO        --ORDE_USUARIO_ENRUTA
                   ,P_FINALIDAD             --ORDE_ORDE_FINALIDAD
                   ,P_MERCADO               --ORDE_MERCADO
                   ,P_CTA_CRCC_CRUZADA      --ORDE_CTA_CRCC_CRUZADA
                   ,P_PRECIO_PROMEDIO       --ORDE_PRECIO_PROMEDIO
                   ,P_OBSERVACION           --ORDE_OBSERVACION
                   ,R_INICIALES.PER_EJECUTA_ORDEN_MESA --ORDE_EJECUTA_ORDEN_MESA
                   ,P_PUNTOS_FORWARD        --ORDE_PUNTOS_FORWARD
                   ,P_NDF_FORWARD           --ORDE_NDF_FORWARD
                   ,P_CONCEPTO              --ORDE_CONCEPTO
                   ,P_CLI_TID_CODIGO_REG    --ORDE_CCC_CLI_PER_TID_COD_REG
                   ,P_CLI_NUM_IDEN_REG      --ORDE_CCC_CLI_PER_NUM_IDEN_REG
                   ,DECODE(P_CUENTA_CORREDORES_REG,0,NULL,P_CUENTA_CORREDORES_REG) --ORDE_CCC_NUMERO_CUENTA_REG
                   ,NULL                    --ORDE_ORDE_CONSECUTIVO
                   ,P_CUENTA_CAMARA_REG     --ORDE_CTCA_CAMARA_REG
                   ,P_OBSERVACION_REG       --ORDE_OBSERVACION_REG
                   ,P_CANAL_ORIGEN          --ORDE_CANAL_ORIGEN
                   ,NULL                    --ORDE_ANULADO_POR
                   ,NULL                    --ORDE_FECHA_ANULACION
                   ,NULL                    --ORDE_MOTIVO_ANULACION
                   ,NULL                    --ORDE_OBSERVACION_CORRECCION
                   ,NULL                    --ORDE_PER_NUM_IDEN_MODIFICA
                   ,NULL                    --ORDE_PER_TID_CODIGO_MODIFICA
                   ,P_TIPO_COMISION         --ORDE_TIPO_COMISION
                   ,P_ORDENANTE_NUM_IDEN    --ORDE_RLC_PER_NUM_IDEN
                   ,P_ORDENANTE_TID_CODIGO  --ORDE_RLC_PER_TID_CODIGO
                   ,'COL'                   --ORDE_ULTIMA_ACTUALIZACION
                   );
                   COMMIT;

        IF SQL%ROWCOUNT = 0 THEN
           P_ID_ORDEN := NULL;
        END IF;
   END IF;

ELSE

   P_TOOLS.CONSULTARCONSTANTE(
    P_CONSTANTE => 'COC',
    P_VALOR => V_VALOR_CONSTANTE,
    P_VALOR_DATE => V_VALOR_DATE,
    P_VALOR_CHAR => V_VALOR_CHAR
    );

   IF  NVL(V_VALOR_CHAR,'N') = 'N' THEN
     V_ERRORES := V_ERRORES + 1;
     P_CAB.CrearError('Colocacion de ordenes no Habilitada.. Intentar mas tarde');
   END IF;

   IF NVL(P_CUENTA_DECEVAL,0) > 0 THEN
     V_CUENTA_DECEVAL :=  P_CUENTA_DECEVAL;
   ELSE
     V_CUENTA_DECEVAL := NULL;
   END IF;

   IF NVL(P_TITULO_CTA_DVAL,0) > 0 THEN
     V_TITULO_CTA_DVAL :=  P_TITULO_CTA_DVAL;
   ELSE
     V_TITULO_CTA_DVAL :=  NULL;
   END IF;

   /*valida que comision no puede ser cero*/
   --App complementacion RF RV 16/02/2021
   IF NVL(P_PORCENTAJE_COMISION,0) = 0  AND P_CANAL_ORIGEN NOT IN('FIXRF','COMRF','COMRV') THEN
     V_ERRORES := V_ERRORES + 1;
     P_CAB.CrearError('Para ordenes de acciones la comision no puede ser cero');
   END IF;

   /* Validaciones para ingresos de ordenes  para control de saldos*/
   V_CLI_ADM_POR_DCVAL := 'N';
   V_ECL_COLOCAR_ORDEN := 'S';
   V_PER_NOMBRE := ' ';
   OPEN ADM_PORTAFOLIO;
   FETCH ADM_PORTAFOLIO INTO   V_CLI_ADM_POR_DCVAL,V_ECL_COLOCAR_ORDEN,V_PER_NOMBRE,V_CLI_PERFIL_RIESGO;
   CLOSE ADM_PORTAFOLIO;

   V_CLI_ADM_POR_DCVAL := NVL(V_CLI_ADM_POR_DCVAL,'N');
   V_ECL_COLOCAR_ORDEN := NVL(V_ECL_COLOCAR_ORDEN,'N');
   V_PER_NOMBRE := NVL(V_PER_NOMBRE,' ');

   IF V_ECL_COLOCAR_ORDEN = 'N' THEN
     V_ERRORES := V_ERRORES + 1;
     P_CAB.CrearError('Cliente no activo en Coeasy');
   END IF;



   IF V_CLI_ADM_POR_DCVAL = 'S' AND P_TITULO_CTA_DCV IS NULL  THEN   --VAGTUD885-3 Complementacion RFRV

     IF P_INS_REC_MEDIO = 'INT' AND NVL(P_TITULO_ORIGEN,' ') IN ('NP','SP') THEN
       V_ERRORES := V_ERRORES + 1;
       P_CAB.CrearError('Para Ordenes de E-Trade solo es permitido ordenes con origen en deceval');
     END IF;

     IF P_TIPO_ORDEN = 'C' AND  V_CUENTA_DECEVAL IS NULL  THEN
       V_ERRORES := V_ERRORES + 1;
       P_CAB.CrearError('Para clientes en DCVAL que se les administra portafolio hay que indicar la cuenta de DCVAL');
     END IF;

     IF P_TIPO_ORDEN = 'V' THEN
       IF V_TITULO_CTA_DVAL IS NULL THEN
         V_ERRORES := V_ERRORES + 1;
         P_CAB.CrearError('Para clientes en DCVAL que se les administra portafolio hay que indicar la cuenta de DCVAL');
       END IF;
       IF NVL(P_TITULO_ORIGEN,' ') = 'NP' THEN
         V_ERRORES := V_ERRORES + 1;
         P_CAB.CrearError('Para clientes en DCVAL que se les administra portafolio solo es permitido operaciones Deceval o Excede Saldo');
       END IF;
     END IF;
   END IF;


   IF V_CLI_ADM_POR_DCVAL = 'N' AND P_TIPO_ORDEN = 'V'  THEN
     IF NVL(P_TITULO_ORIGEN,' ') != 'NP' THEN
       V_ERRORES := V_ERRORES + 1;
       P_CAB.CrearError('Para clientes que NO se les administra portafolio solo es permitido operaciones Sin cuenta Deceval o Sin titulo ');
     END IF;
   END IF;

   OPEN INICIALES;
   FETCH INICIALES INTO C_INICIALES;
   IF INICIALES%NOTFOUND THEN
     V_ERRORES := V_ERRORES + 1;
     P_CAB.CrearError('Comercial no existe en COEASY');
   ELSE
     IF P_TIPO_ORDEN IN ('C','V') THEN
        /* Asignacion de LEO segun origen
        @cciones comisinista = 3
        @Etrade clientes = 5
        PLV = 8 se reasigna al leo 3 VAGTUS030559
        UDF = 9
        */
      CASE
       WHEN C_INICIALES.PER_TIP_COMERCIAL_UDF IN ( 'PRO','ASE','ASP') THEN
          IF P_CODIGO_INFORMADOR IS NOT NULL THEN
             V_LEO := 3;
             V_CANAL_ORIGEN := 'PLV';
          ELSE
             IF P_INS_REC_MEDIO = 'INT'  THEN
                V_LEO := 5;

                IF P_INS_REC_DETALLE = 'Internet ACC-E' THEN
                   V_CANAL_ORIGEN := 'ACC-E';
                ELSIF P_INS_REC_DETALLE = 'Fix-Ins' THEN
                   V_CANAL_ORIGEN := 'Fix-I';
                ELSE
                   V_CANAL_ORIGEN := 'S2';
                END IF;
             ELSE
                V_LEO := 9;
                V_CANAL_ORIGEN := 'UDF-A';
              END IF;
          END IF;

          IF P_CANAL_ORIGEN = 'FIXRF' THEN
            V_CANAL_ORIGEN := 'FIXRF';
            V_RENTA_FIJA :='RF';
          END IF;

        WHEN P_CANAL_ORIGEN = 'FIXRF' THEN

          V_CANAL_ORIGEN := 'FIXRF';
          V_RENTA_FIJA :='RF';
        --Complementaciones automaticas 21/09/2020 (se agrega codigo para renta fija y renta variable)
         WHEN P_CANAL_ORIGEN = V_VALOR_COMRF THEN
              V_CANAL_ORIGEN  := V_VALOR_COMRF;
              V_RENTA_FIJA    :='RF';
              V_LEO           :=2;
              --VAGTUD885-3 Complementacion RF RV
              IF P_TITULO_CTA_DCV IS NOT NULL THEN
                V_ORDEN_DCV := 'S';
              ELSE
                V_ORDEN_DCV := 'N';
              END IF;
         WHEN P_CANAL_ORIGEN = V_VALOR_COMRV THEN
              V_CANAL_ORIGEN     := V_VALOR_COMRV;
              V_LEO              :=2;
              --VAGTUD885-3 Complementacion RF RV
              IF P_TITULO_CTA_DCV IS NOT NULL THEN
                V_ORDEN_DCV := 'S';
              ELSE
                V_ORDEN_DCV := 'N';
              END IF;
       ELSE
          SELECT DECODE(P_INS_REC_MEDIO,'INT',5,3) INTO V_LEO FROM DUAL;
          IF V_LEO = 5 THEN
             IF P_INS_REC_DETALLE = 'Internet ACC-E' THEN
                V_CANAL_ORIGEN := 'ACC-E';
             ELSIF P_INS_REC_DETALLE = 'Fix-Ins' THEN
                V_CANAL_ORIGEN := 'Fix-I';
             ELSE
                V_CANAL_ORIGEN := 'S2';
             END IF;
          END IF;

          IF V_LEO = 3 THEN
             V_CANAL_ORIGEN := 'ACC';
          END IF;
       END CASE;
     END IF;

     IF C_INICIALES.PER_TIP_COMERCIAL_UDF IS NOT NULL THEN
       IF C_INICIALES.PER_TIP_COMERCIAL_UDF = 'PRO' AND TRIM(C_INICIALES.PER_CODIGO_SAE_ACC) IS NULL THEN
         V_ERRORES := V_ERRORES + 1;
         P_CAB.CrearError('Profesional de UdF sin codigo de ingreso de ordenes a bolsa');
       END IF;

       /* validar montos de negociacion */
         --ASE - VR MAXIMO OPERACION UDF ASE,
         --ASP  - VR MAXIMO OPERACION UDF ASP
         --PRO        VR MAXIMO OPERACION UDF PRO
       V_VALOR_NEG := 0;
       IF C_INICIALES.PER_TIP_COMERCIAL_UDF = 'ASE' THEN
          P_TOOLS.CONSULTARCONSTANTE(P_CONSTANTE => 'ASE',
                                     P_VALOR => V_VALOR_NEG,
                                     P_VALOR_DATE => V_VALOR_DATE,
                                     P_VALOR_CHAR => V_VALOR_CHAR);
       END IF;

       IF C_INICIALES.PER_TIP_COMERCIAL_UDF = 'ASP' THEN
          P_TOOLS.CONSULTARCONSTANTE(P_CONSTANTE => 'ASP',
                                     P_VALOR => V_VALOR_NEG,
                                     P_VALOR_DATE => V_VALOR_DATE,
                                     P_VALOR_CHAR => V_VALOR_CHAR);
       END IF;

       IF C_INICIALES.PER_TIP_COMERCIAL_UDF = 'PRO' THEN
          P_TOOLS.CONSULTARCONSTANTE(P_CONSTANTE => 'PRO',
                                     P_VALOR => V_VALOR_NEG,
                                     P_VALOR_DATE => V_VALOR_DATE,
                                     P_VALOR_CHAR => V_VALOR_CHAR);
       END IF;

       IF V_CANAL_ORIGEN NOT IN  ('S2','S4','Fix-I','ACC-E') THEN
         IF NVL(P_TOTAL_OPERACION_INT,0) > NVL(V_VALOR_NEG,0) THEN
           V_ERRORES := V_ERRORES + 1;
           P_CAB.CrearError('El monto mżximo permitido para operar es de $ '||TO_CHAR(V_VALOR_NEG,'9,999,999,999,999,999.00'));
         END IF;
       END IF;
     ELSE
       IF V_CANAL_ORIGEN NOT IN ('S2','S4','Fix-I','ACC-E',V_VALOR_COMRV,V_VALOR_COMRF) THEN
          IF TRIM(C_INICIALES.PER_CODIGO_SAE_ACC) IS NULL THEN
             V_ERRORES := V_ERRORES + 1;
             P_CAB.CREARERROR('Comercial sin codigo de ingreso de ordenes a bolsa');
          END IF;
       END IF;
     END IF;
   END IF;
   CLOSE INICIALES;

   C_PRODUCTO.CCP_PRO_MNEMONICO := NULL;
   IF P_INS_REC_MEDIO = 'INT' THEN
     IF V_CANAL_ORIGEN = 'PLV' THEN
        V_CCP_PRO_MNEMONICO := NULL;
        OPEN PRODUCTO_ETRADE_PLV;
        FETCH PRODUCTO_ETRADE_PLV INTO C_PRODUCTO;
        WHILE PRODUCTO_ETRADE_PLV%FOUND LOOP
           IF C_PRODUCTO.CCP_PRO_MNEMONICO = 'ACC' THEN
             V_CCP_PRO_MNEMONICO := 'ACC';
             EXIT;
           ELSE
             V_CCP_PRO_MNEMONICO := C_PRODUCTO.CCP_PRO_MNEMONICO;
           END IF;
        FETCH PRODUCTO_ETRADE_PLV INTO C_PRODUCTO;
        END LOOP;
        CLOSE PRODUCTO_ETRADE_PLV;

        C_PRODUCTO.CCP_PRO_MNEMONICO :=NVL(V_CCP_PRO_MNEMONICO,'SP');
     ELSE --aqui
        V_CCP_PRO_MNEMONICO := NULL;
        IF V_CANAL_ORIGEN = 'Fix-I' THEN
           OPEN PRODUCTO_ETRADE_INS;
           FETCH PRODUCTO_ETRADE_INS INTO C_PRODUCTO;
           WHILE PRODUCTO_ETRADE_INS%FOUND LOOP
           IF C_PRODUCTO.CCP_PRO_MNEMONICO = 'ACC' THEN
             V_CCP_PRO_MNEMONICO := 'ACC';
             EXIT;
           ELSE
             V_CCP_PRO_MNEMONICO := C_PRODUCTO.CCP_PRO_MNEMONICO;
           END IF;
           FETCH PRODUCTO_ETRADE_INS INTO C_PRODUCTO;
           END LOOP;
           CLOSE PRODUCTO_ETRADE_INS;

           C_PRODUCTO.CCP_PRO_MNEMONICO :=NVL(V_CCP_PRO_MNEMONICO,'SP');
        ELSE
           OPEN PRODUCTO_ETRADE;
           FETCH PRODUCTO_ETRADE INTO C_PRODUCTO;
           WHILE PRODUCTO_ETRADE%FOUND LOOP
           IF C_PRODUCTO.CCP_PRO_MNEMONICO = 'ACC' THEN
             V_CCP_PRO_MNEMONICO := 'ACC';
             EXIT;
           ELSE
             V_CCP_PRO_MNEMONICO := C_PRODUCTO.CCP_PRO_MNEMONICO;
           END IF;
           FETCH PRODUCTO_ETRADE INTO C_PRODUCTO;
        END LOOP;
        CLOSE PRODUCTO_ETRADE;

        C_PRODUCTO.CCP_PRO_MNEMONICO :=NVL(V_CCP_PRO_MNEMONICO,'SP');
        END IF;
     END IF;
   ELSE
     V_CCP_PRO_MNEMONICO := NULL;
     OPEN PRODUCTO;
     FETCH PRODUCTO INTO C_PRODUCTO;
     WHILE PRODUCTO%FOUND LOOP
       IF C_PRODUCTO.CCP_PRO_MNEMONICO = 'ACC' THEN
         V_CCP_PRO_MNEMONICO := 'ACC';
         EXIT;
       ELSE
         V_CCP_PRO_MNEMONICO := C_PRODUCTO.CCP_PRO_MNEMONICO;
       END IF;
       FETCH PRODUCTO INTO C_PRODUCTO;
     END LOOP;
     CLOSE PRODUCTO;

     C_PRODUCTO.CCP_PRO_MNEMONICO :=NVL(V_CCP_PRO_MNEMONICO,'SP');
   END IF;


   OPEN C_ENA(P_ESPECIE);
   FETCH C_ENA INTO V_GNA_MNEMONICO,V_EMI_MNEMONICO;
   CLOSE C_ENA;

   C_ORDENANTE :=NULL;
   C_ORDENANTE_ETRADE :=NULL;
   IF P_INS_REC_MEDIO = 'INT' THEN

     IF V_CANAL_ORIGEN != 'Fix-I' THEN
       IF V_CLI_ADM_POR_DCVAL = 'N'  THEN
          V_ERRORES := V_ERRORES + 1;
          P_CAB.CrearError('Cliente no administra portafolio por corredores');
       END IF;
     ELSE
       IF V_CLI_ADM_POR_DCVAL = 'S'  THEN
          V_ERRORES := V_ERRORES + 1;
          P_CAB.CrearError('Cliente administra portafolio por corredores');
       END IF;
     END IF;
     /* BUSCAR ORDENANTE AUTORIZADO PARA PJU*/
     V_TIPO_PERSONA := NULL;
     V_PER_ORIGEN   := NULL;
     V_PER_NOMBRE_PER := NULL;
     V_PER_APELLIDOS := NULL;
     OPEN PERSONA_TIPO(P_CLI_NUM_IDEN,P_CLI_TID_CODIGO);
     FETCH PERSONA_TIPO INTO V_TIPO_PERSONA,V_PER_ORIGEN,V_PER_NOMBRE_PER,V_PER_APELLIDOS;
     IF PERSONA_TIPO %NOTFOUND THEN
       V_ERRORES := V_ERRORES + 1;
       P_CAB.CrearError('Cliente con tipo de persona invalido');
     END IF;
     CLOSE PERSONA_TIPO;
   IF V_TIPO_PERSONA='PJU' THEN
     V_PER_APELLIDOS:=NULL;
   END IF;

     V_TIPO_PERSONA  := NVL(V_TIPO_PERSONA ,' ' );
     IF V_TIPO_PERSONA= 'PJU' THEN

       IF NVL(C_PRODUCTO.CCC_ETRADE,'N') = 'S' THEN

          IF V_CANAL_ORIGEN = 'Fix-I' THEN
             OPEN ORDENANTE_ETRADE_INS;
             FETCH ORDENANTE_ETRADE_INS INTO C_ORDENANTE_ETRADE;
             IF ORDENANTE_ETRADE_INS%NOTFOUND THEN
                V_ERRORES := V_ERRORES + 1;
                P_CAB.CrearError('Cliente sin ordenantes activos para colocar ordenes');
             END IF;
             CLOSE ORDENANTE_ETRADE_INS;
             C_ORDENANTE.RLC_ROL_CODIGO        := C_ORDENANTE_ETRADE.RLC_ROL_CODIGO;
             C_ORDENANTE.RLC_PER_NUM_IDEN      :=  C_ORDENANTE_ETRADE.RLC_PER_NUM_IDEN;
             C_ORDENANTE.RLC_PER_TID_CODIGO    :=  C_ORDENANTE_ETRADE.RLC_PER_TID_CODIGO;

          ELSE
             OPEN ORDENANTE_ETRADE;
             FETCH ORDENANTE_ETRADE INTO C_ORDENANTE_ETRADE;
             IF ORDENANTE_ETRADE%NOTFOUND THEN
                V_ERRORES := V_ERRORES + 1;
                P_CAB.CrearError('Cliente sin ordenantes activos para colocar ordenes');
             END IF;
             CLOSE ORDENANTE_ETRADE;
             C_ORDENANTE.RLC_ROL_CODIGO        := C_ORDENANTE_ETRADE.RLC_ROL_CODIGO;
             C_ORDENANTE.RLC_PER_NUM_IDEN      :=  C_ORDENANTE_ETRADE.RLC_PER_NUM_IDEN;
             C_ORDENANTE.RLC_PER_TID_CODIGO    :=  C_ORDENANTE_ETRADE.RLC_PER_TID_CODIGO;
         END IF;
       END IF;
     ELSE
       OPEN ORDENANTE;
       FETCH ORDENANTE INTO C_ORDENANTE;
       IF ORDENANTE%NOTFOUND THEN
         V_ERRORES := V_ERRORES + 1;
         P_CAB.CrearError('Cliente sin ordenantes activos para colocar ordenes');
       END IF;
       CLOSE ORDENANTE;
     END IF;
   ELSE
     OPEN ORDENANTE;
     FETCH ORDENANTE INTO C_ORDENANTE;
     IF ORDENANTE%NOTFOUND THEN
       V_ERRORES := V_ERRORES + 1;
       P_CAB.CrearError('Cliente sin ordenantes activos para colocar ordenes');
     END IF;
     CLOSE ORDENANTE;
   END IF;


   IF LENGTH(TRIM(P_INS_REC_DETALLE)) > 30 THEN
       V_ERRORES := V_ERRORES + 1;
       P_CAB.CrearError('El detalle del medio de recepcion superior a 30 caracteres');
   END IF;


   IF P_INS_ENV_FAX = 1 THEN
     V_INS_ENV_FAX := 'S';
   ELSE
     V_INS_ENV_FAX := 'N';
   END IF;
   IF P_INS_ENV_DIRECCION = 1 THEN
     V_INS_ENV_DIRECCION := 'S';
   ELSE
     V_INS_ENV_DIRECCION := 'N';
   END IF;
   --OPEN C_LEO;
   --FETCH C_LEO INTO LEO;
   --CLOSE C_LEO;
   IF P_VIS_VISIBLE = 1 THEN
     V_VIS_VISIBLE := 'S';
   ELSE
     V_VIS_VISIBLE := NULL;
   END IF;
   IF P_STOP_STOP = 1 THEN
     V_STOP_STOP := 'S';
   ELSE
     V_STOP_STOP := NULL;
   END IF;
   /*Validacion que la cuenta sea solo del titular*/
   IF V_CUENTA_DECEVAL IS NOT NULL OR
      V_TITULO_CTA_DVAL  IS NOT NULL  THEN
     IF V_CUENTA_DECEVAL IS NOT  NULL THEN
       OPEN C_COMITENTES(V_CUENTA_DECEVAL);
     ELSIF V_TITULO_CTA_DVAL  IS NOT NULL THEN
       OPEN C_COMITENTES(V_TITULO_CTA_DVAL);
     END IF;
     FETCH C_COMITENTES INTO COMITENTES;
     IF C_COMITENTES%FOUND THEN
       V_ERRORES := V_ERRORES + 1;
       P_CAB.CrearError('Para acciones la cuenta de DECEVAL debe ser sin beneficiarios');
     END IF;
     CLOSE C_COMITENTES;
   END IF;
   --C_CONSTANTE.CON_VALOR := 0;
   --OPEN CONSTANTE;
   --FETCH CONSTANTE INTO C_CONSTANTE;
   --CLOSE CONSTANTE;
   --C_CONSTANTE.CON_VALOR :=    NVL(C_CONSTANTE.CON_VALOR,0);
   --IF (NVL(P_CANTIDAD,0)*NVL(P_COND_PRECIO_LIMITIE,0))> C_CONSTANTE.CON_VALOR THEN
   --  V_ERRORES := V_ERRORES + 1;
   --  P_CAB.CrearError('Orden mayor al tope maximo de colocacion :'||to_char(C_CONSTANTE.CON_VALOR,'999,999,999,999.00'));
   --END IF;

   /* Validar el tipo de producto asociado a la orden
      Para leo 3:
      - cuentas con producto OPX o ACC, o sin producto
      - Para Etrade solo cuentas con producto ETRADE
   */


   V_FECHA_RECEPCION := P_FECHA_RECEPCION;
   IF P_INS_REC_MEDIO = 'INT' THEN -- operaciones de etrade
     /* Validar que la cueenta sea para producto ETRADE*/
     V_FECHA_RECEPCION := TO_CHAR(SYSDATE,'DD/MM/YYYY');
     IF NVL(C_PRODUCTO.CCC_ETRADE,' ') != 'S' THEN
       V_ERRORES := V_ERRORES + 1;
       P_CAB.CrearError('Cuenta en corredores no habilitada para operaciones de ETRADE');
     END IF;
   END IF;

   /* VAGTUD576 - Se elimina lżgica OPX */
   IF NVL(C_PRODUCTO.CCP_PRO_MNEMONICO,'SP') NOT IN ('ACC','SP') THEN
         V_ERRORES := V_ERRORES + 1;
         P_CAB.CrearError('Cuenta en corredores no habilitada para operaciones de Acciones');
   END IF;

   IF V_FECHA_RECEPCION IS NULL THEN
     V_ERRORES := V_ERRORES + 1;
     P_CAB.CrearError('Fecha de recepcion invalida');
   END IF;

   IF P_TIPO_ORDEN = 'C' THEN
      /* Asignacion de LEO segun origen
      @cciones comisinista = 3
      @Etrade clientes = 5
      PLV = 8  se reasigna al leo 3 VAGTUS030559
      UDF = 9
      */

     IF P_CODIGO_INFORMADOR IS NOT NULL AND NVL(C_PRODUCTO.CCC_PANTALLA_LIVIANA,'N') != 'S'  THEN
        V_ERRORES := V_ERRORES+1;
        P_CAB.CrearError('Cliente no habilitado para operar por pantalla liviana ');
     END IF;

     IF NVL(C_PRODUCTO.CCC_ETRADE,' ') = 'S' AND  P_INS_REC_MEDIO = 'INT'   THEN
        V_SALDO := 0;

        IF V_CANAL_ORIGEN != 'Fix-I' THEN
           P_WEB_CLIENTE.OBTENERSALDOSPESOS(P_TID_CODIGO => P_CLI_TID_CODIGO,
                                           P_NUM_IDEN   => P_CLI_NUM_IDEN,
                                           P_CUENTA     => P_CUENTA_CORREDORES,
                                           P_SALDO      => V_SALDO);
           V_SALDO := NVL(V_SALDO,0);
           IF NVL(V_SALDO,0) <= 0 THEN
              V_ERRORES := V_ERRORES+1;
              P_CAB.CrearError('Cuenta en corredores sin saldo disponible para operacion Etrade de compra');
           END IF;

           IF NVL(P_NETO_OPERACION_INT,0)  = 0 OR
              NVL(P_TOTAL_OPERACION_INT,0) = 0 THEN
              V_ERRORES := V_ERRORES+1;
              P_CAB.CrearError('Para operaciones Etrade se debe especificar Total y Neto Operacion');
           END IF;

           IF NVL(V_SALDO,0)-NVL(P_NETO_OPERACION_INT,0) < 0 THEN
              V_ERRORES := V_ERRORES+1;
              P_CAB.CrearError('Cliente sin saldo disponible para la operaciżn de compra Etrade');
           END IF;
        END IF;

       --SS
        IF V_CANAL_ORIGEN IN ('ACC-E', 'ACC') THEN --fdm canales de @cciones
           P_TOOLS.CONSULTARCONSTANTE(P_CONSTANTE => 'MMH',
                                      P_VALOR => V_VALOR_MMH,
                                      P_VALOR_DATE => V_VALOR_DATE,
                                      P_VALOR_CHAR => V_VALOR_CHAR);

           P_TOOLS.CONSULTARCONSTANTE(P_CONSTANTE => 'IMH',
                                      P_VALOR => V_VALOR_IMH,
                                      P_VALOR_DATE => V_VALOR_DATE,
                                      P_VALOR_CHAR => V_VALOR_CHAR); 

           V_VALOR_TMMH := V_VALOR_MMH + V_VALOR_IMH;     
           IF NVL(P_NETO_OPERACION_INT,0)  <  V_VALOR_TMMH THEN --OCO_NETO_OPERACION_ACC
              V_ERRORES := V_ERRORES+1;

              P_CAB.CrearError('La orden debe superar el monto minimo de: $'|| TO_CHAR (V_VALOR_MMH,'99G999G999') ||
                               ' mas comision e IVA de $ '|| TO_CHAR (V_VALOR_IMH,'99G999G999') ||
                               ' para un total de $ '|| TO_CHAR (V_VALOR_TMMH,'99G999G999'));
           END IF;
        END IF;

      END IF;

     IF V_CANAL_ORIGEN IN ('S2','S4') THEN  -- para bloquear ingreso de esto canales
     --IF V_CANAL_ORIGEN IN ('S2','S4','ACC-E') THEN  -- para bloquear ingreso de esto canales
       V_ERRORES := V_ERRORES + 1;
       P_CAB.CrearError('Ordenes por este canal no autorizadas');
     END IF;

 /*fdm errores de trigger*/
  ----***------

  ENA1 := NULL;
  OPEN C_ENA2(P_ESPECIE);
  FETCH C_ENA2 INTO ENA1;
  CLOSE C_ENA2;

  IF NVL(P_CLI_PROFESIONAL,'0') = '0' THEN
     IF NVL(ENA1.ENA_RIESGO_CORREDORES,' ') = 'NC' THEN

      OPEN C_CONSTANTES('OFP');
      FETCH C_CONSTANTES INTO V_DIAS;
      IF C_CONSTANTES%NOTFOUND THEN
         P_CAB.CrearError('No se pudo determinar la constante OFP');
      END IF;
      CLOSE C_CONSTANTES;

       OPEN C_EXCEP_DISPONIBLE(P_CLI_NUM_IDEN,
                               P_CLI_TID_CODIGO,
                               'NC',
                               P_ESPECIE,
                               V_DIAS);
       FETCH C_EXCEP_DISPONIBLE INTO COND_EXC;
       CLOSE C_EXCEP_DISPONIBLE;
       COND_EXC := NVL(COND_EXC,' ');


       IF COND_EXC = 'X' THEN
          COND_EXC := 'X';
       ELSE
          IF (NVL(V_LEO,-1) IN (5)) THEN  -- E-TRADE / HOMEBROKER
             V_ERRORES := V_ERRORES + 1;
             P_CAB.CREARERROR('Tżtulo NO COMERCIALIZABLE.' ||
                'Para realizar esta operaciżn comunicar con su asesor de inversiżn o con' ||
                ' el administrador de Davivienda Homebroker al telżfono 601 3123300 Ext 92156.');
          END IF;
          IF (NVL(V_LEO,-1) IN (3,8,9)) THEN  -- E-TRADE / HOMEBROKER
             V_ERRORES := V_ERRORES + 1;
             P_CAB.CREARERROR('Tżtulo NO COMERCIALIZABLE.' ||
                'Solicitar al cliente declare eximente de responsabilidad.' ||
                'Y diligenciarlo COEASY Comercial-Clientes-Perfil de Riesgo-Operaciones Fuera del Perfil');
          END IF;
       END IF;
     END IF;
  END IF;


  IF V_CLI_PERFIL_RIESGO IS NULL THEN
     V_ERRORES := V_ERRORES + 1;
     P_CAB.CrearError('Cliente sin perfil de riesgo Definido. No se puede registrar la operacion');
  ELSE
    --Complementaciones Automaticas se agregan el canal COMRF 21/09/2020 --
     IF V_CANAL_ORIGEN IN ('FIXRF','COMRF') AND V_RENTA_FIJA IS NOT NULL THEN
        V_OCO_COC_CTO_MNEMONICO := 'RF';
     ELSIF V_CANAL_ORIGEN != 'FIXRF' AND V_RENTA_FIJA IS NULL THEN
        V_OCO_COC_CTO_MNEMONICO := 'ACC';
     END IF;

     AUTORIZADO := NULL;
    AUTORIZADO :=  P_CLIENTES.AutorizaColocacionOrdenPerfil(V_OCO_COC_CTO_MNEMONICO,
                                                                     'C',
                                                                     'CON',
                                                                     'N',
                                                                     V_CLI_PERFIL_RIESGO,
                                                                     NVL(ENA1.ENA_RIESGO_CORREDORES,'N'),
                                                                     NVL(V_TIPO_PERSONA,'N'));

    /*2022-10-27 JBOHORQUEZ REGLAS DE NEGOCIO PROYECTO DECRETO 661 PORDUCTO SIMPLE UNIVERSAL Y PERFIL DE CLIENTE PROFESIONAL*/
    OPEN C_CLASF_PROD(V_OCO_COC_CTO_MNEMONICO);
    FETCH C_CLASF_PROD INTO V_PROD_CLASIFICACION;
    CLOSE C_CLASF_PROD;
    IF V_PROD_CLASIFICACION = 'SIU' OR CLIENTE.CLI_PROFESIONAL = 'S' THEN
     AUTORIZADO := 'S';
    END IF;    
    /**************************************************************************************************/
     IF AUTORIZADO = 'F' THEN
        IF (NVL(V_LEO,-1) IN (5)) THEN  -- E-TRADE / HOMEBROKER
                      V_ERRORES := V_ERRORES + 1;
                        P_CAB.CREARERROR('Este tipo de Operacion no esta en la Matriz de Riesgo. Comuniquese con su asesor Comercial.'
                                         ||' Operacion ' ||V_OCO_COC_CTO_MNEMONICO
                                         ||'Negocio ' ||'CON'
                                         ||'Act/Pas '||'N'
                                         ||'Perfil '||V_CLI_PERFIL_RIESGO
                                         ||'Calificaciżn '||ENA1.ENA_RIESGO_CORREDORES
                                         ||'Tipo persona '||V_TIPO_PERSONA
                                         );
        ELSE
           V_ERRORES := V_ERRORES + 1;
           P_CAB.CrearError('Este tipo de Operacion no esta en la Matriz de Riesgo. Comuniquese con el żrea de Contraloria.');
        END IF;
     ELSIF AUTORIZADO = 'N' THEN

        OPEN C_CONSTANTES('OFP');
        FETCH C_CONSTANTES INTO V_DIAS;
        IF C_CONSTANTES%NOTFOUND THEN
           P_CAB.CrearError('No se pudo determinar la constante OFP');
        END IF;
        CLOSE C_CONSTANTES;

        OPEN C_CONSTANTES('LEX');
        FETCH C_CONSTANTES INTO V_LIMITE_EX;
        IF C_CONSTANTES%NOTFOUND THEN
           P_CAB.CrearError('No se pudo determinar la constante LEX');
        END IF;
        CLOSE C_CONSTANTES;

        V_CONTADOR_P  := P_TOOLS.FN_DIAS_PERFILAMIENTO(P_CLI_TID_CODIGO, P_CLI_NUM_IDEN, 'C' );  

        IF V_CONTADOR_P > 0 THEN
           V_DIAS_PERFILAM := P_TOOLS.FN_DIAS_PERFILAMIENTO(P_CLI_TID_CODIGO, P_CLI_NUM_IDEN );

           IF V_DIAS_PERFILAM < V_DIAS THEN       
              V_DIAS := V_DIAS_PERFILAM;   
           END IF;
        END IF;

        OPEN C_EXCEPCIONES(P_CLI_NUM_IDEN,
                           P_CLI_TID_CODIGO,
                           V_DIAS);
        FETCH C_EXCEPCIONES INTO CANTIDAD_EXC;
        CLOSE C_EXCEPCIONES;
        CANTIDAD_EXC := NVL(CANTIDAD_EXC,0);

        IF CANTIDAD_EXC > V_LIMITE_EX THEN
           IF (NVL(V_LEO,-1) IN (5)) THEN -- E-TRADE / HOMEBROKER
              V_ERRORES := V_ERRORES + 1;
              P_CAB.CrearError('Esta operacion no corresponde con su perfil de riesgo. '||
                 'Puede realizar la encuesta en la zona transaccional, Menu '||
                 'principal/ Servicios/Encuesta de perfil de riesgo '||
                 'o comuniquese con el telefono 3123300.');
           ELSE
              V_ERRORES := V_ERRORES + 1;
              P_CAB.CrearError('La orden / operaciżn estż por fuera del perfil del cliente. '||
                               'Para continuar, usted puede realizar '||
                               'por medio verificable el reperfilamiento a travżs de encuesta.');
           END IF;
        ELSE
           OPEN C_EXCEP_DISPONIBLEFP(P_CLI_NUM_IDEN,
                                    P_CLI_TID_CODIGO,
                                    'FP',
                                    V_DIAS);
           FETCH C_EXCEP_DISPONIBLEFP INTO COND_EXC;
           CLOSE C_EXCEP_DISPONIBLEFP;
           COND_EXC := NVL(COND_EXC,' ');

           IF COND_EXC = 'X' THEN
              AUTORIZADO := 'S';
           ELSE
              IF (NVL(V_LEO,-1) IN (5)) THEN  -- E-TRADE / HOMEBROKER
                 V_ERRORES := V_ERRORES + 1;
                 P_CAB.CREARERROR('Esta operacion no corresponde con su perfil de riesgo. '||
                  'Puede realizar la encuesta en la zona transaccional, Menu '||
                  'principal/ Servicios/Encuesta de perfil de riesgo '||
                  'o comuniquese con el telefono 3123300.');
              ELSE
                 V_ERRORES := V_ERRORES + 1;
                 P_CAB.CrearError('La orden-operaciżn fuera del perfil del cliente.'||
                                  'reperfilar por medio verificable,encuesta '||
                                  'o solicitar al cliente declare su exoneraciżn de responsabilidad');
              END IF;
           END IF;
         END IF;
     END IF;
  END IF;


  IF P_ESPECIE IS NOT NULL THEN
         OPEN C_ENA_T(P_ESPECIE);
         FETCH C_ENA_T INTO V_GNA_MNEMONICO_T,V_EMI_MNEMONICO_T, V_CALIFICACION_T;
         IF C_ENA_T%NOTFOUND THEN
            CLOSE C_ENA_T;
            P_CAB.CrearError('No existe la especie a negociar');
         ELSE
            CLOSE C_ENA_T;
            IF V_GNA_MNEMONICO <> V_GNA_MNEMONICO_T OR
               V_EMI_MNEMONICO <> V_EMI_MNEMONICO_T THEN
               P_CAB.CrearError('No corresponde el grupo y el emisor con la especie a negociar.');
            END IF;
         END IF;
   ELSIF V_EMI_MNEMONICO IS NOT NULL THEN
         OPEN C_ENA2_T(V_GNA_MNEMONICO,V_EMI_MNEMONICO);
         FETCH C_ENA2_T INTO V_GNA_MNEMONICO_T,V_EMI_MNEMONICO_T, V_CALIFICACION_T;
         IF C_ENA2_T%NOTFOUND THEN
            CLOSE C_ENA2_T;
            P_CAB.CrearError('El emisor '||V_EMI_MNEMONICO||' no emite especies del grupo '||V_GNA_MNEMONICO);
         ELSE
            CLOSE C_ENA2_T;
         END IF;
   END IF;

  IF P_VIG_TIPO_VIGENCIA = 'HFE' THEN

       SELECT SYSDATE INTO FECHA_T FROM DUAL;
       IF TRUNC(TO_DATE(P_VIG_FECHA_PERMANENCI,'DD-MM-YYYY HH24:MI:SS')) <= TRUNC(FECHA_T) THEN
          V_ERRORES := V_ERRORES + 1;
          P_CAB.CrearError('Para una orden con vigencia HASTA FECHA la FECHA DE VIGENCIA debe ser mayor a hoy');
       END IF;
       OPEN C_CONSTANTES('DMP');
       FETCH C_CONSTANTES INTO DIAS;
       IF C_CONSTANTES%NOTFOUND THEN
          CLOSE C_CONSTANTES;
          V_ERRORES := V_ERRORES + 1;
          P_CAB.CrearError('No se pudo determinar la constante de dias mżximos de permanencia de la orden');
       END IF;
       CLOSE C_CONSTANTES;
       IF TRUNC(FECHA_T) + DIAS < TRUNC(TO_DATE(P_VIG_FECHA_PERMANENCI,'DD-MM-YYYY HH24:MI:SS')) THEN
             V_ERRORES := V_ERRORES + 1;
             P_CAB.CREARERROR('En ordenes HASTA FECHA la FECHA DE VIGENCIA debe ser menor o igual a ' || DIAS || ' dias');
      END IF;
  END IF;


  OPEN C_CLIENTE;
      FETCH C_CLIENTE INTO CLIENTE;
      CLOSE C_CLIENTE;

      IF CLIENTE.PER_TIPO = 'PNA' AND
         P_CLI_TID_CODIGO IN ('TI','NIUP') THEN
         CLIENTE.CLI_FECHA_NACIMIENTO := NVL(CLIENTE.CLI_FECHA_NACIMIENTO,SYSDATE);
         IF ADD_MONTHS(CLIENTE.CLI_FECHA_NACIMIENTO,222) < TRUNC(SYSDATE) THEN
            V_ERRORES := V_ERRORES + 1;
            P_CAB.CrearError('Cliente con identificaciżn de menor de edad y ya es mayor de edad. No puede operar con este documento');
         END IF;
      END IF;

      /* VALIDAR CUENTA DECEVAL NO SEA DE APT*/
      V_CUD_CUENTA_APT  := NULL;
      IF V_LEO IN (3,5,8,9) AND V_CUENTA_DECEVAL IS NOT NULL THEN
         OPEN C_CUENTA_DECEVAL(P_CUENTA_DECEVAL     => V_CUENTA_DECEVAL,
                               P_CLI_PER_NUM_IDEN   => P_CLI_NUM_IDEN,
                               P_CLI_PER_TID_CODIGO => P_CLI_TID_CODIGO);
         FETCH C_CUENTA_DECEVAL INTO  V_CUD_CUENTA_APT;
         CLOSE C_CUENTA_DECEVAL;

         V_CUD_CUENTA_APT := NVL(V_CUD_CUENTA_APT,' ');

         IF V_CUD_CUENTA_APT = 'S' THEN
            V_ERRORES := V_ERRORES + 1;
            P_CAB.CREARERROR('Cuenta deceval :'||V_CUENTA_DECEVAL||' no valida para ordenes por este canal');
         END IF;
      END IF;


  ----***-----

     IF V_ERRORES = 0 THEN
        V_ISIN            := NULL;
        V_CREA_SALDO      := NULL;
        V_MENSAJE_SALDO   := NULL;
        P_ORDENES_COMERCIAL.PR_ISIN_COMPRA_ACC(P_ENA_MNEMONICO => P_ESPECIE,
                                              P_PER_NUM_IDEN   => P_CLI_NUM_IDEN,
                                              P_PER_TID_CODIGO => P_CLI_TID_CODIGO,
                                              P_ISIN           => V_ISIN,
                                              P_CREA_SALDO     => V_CREA_SALDO,
                                              P_MENSAJE        => V_MENSAJE_SALDO);
        IF NVL(V_CREA_SALDO,' ') = 'S' THEN
           P_ORDENES_COMERCIAL.PR_CREAR_SALDO_CFC(P_CUENTA_DECEVAL     => V_CUENTA_DECEVAL,
                                                  P_ISIN               => V_ISIN,
                                                  P_FUNGIBLE           => 0,
                                                  P_CLI_PER_NUM_IDEN   => P_CLI_NUM_IDEN,
                                                  P_CLI_PER_TID_CODIGO => P_CLI_TID_CODIGO,
                                                  P_CUENTA_CCC         => P_CUENTA_CORREDORES);
        END IF;
     END IF;


     IF V_ERRORES = 0 AND V_RENTA_FIJA IS NULL THEN

        /* CREACION DE LA ORDEN DE COMPRA*/
--begin
        SELECT COR_SEQ.NEXTVAL INTO P_ID_ORDEN FROM DUAL;
        INSERT INTO CONSECUTIVO_ORDENES
            (COR_CONSECUTIVO
            ,COR_CLASE
            ,COR_BOLSA)
        VALUES
            (P_ID_ORDEN
            ,'ACC'
            ,'COL');
       INSERT INTO ORDENES_COMPRA
       (  OCO_CONSECUTIVO
        , OCO_BOL_MNEMONICO
        , OCO_COC_CTO_MNEMONICO
        , OCO_COC_CCO_MNEMONICO
        , OCO_COC_CTE_MNEMONICO
        , OCO_TOC_MNEMONICO
        , OCO_CNE_MNEMONICO
        , OCO_EOC_MNEMONICO
        , OCO_VIO_MNEMONICO
