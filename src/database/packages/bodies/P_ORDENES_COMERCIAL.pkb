         V_NO_REGIS_INST := 'N';
       ELSE
         V_NO_REGIS_INST :=  P_TIPO_INSTRUCCION;
       END IF;*/


       INSERT INTO ORDENES_COMPRA
       (  OCO_CONSECUTIVO
        , OCO_BOL_MNEMONICO
        , OCO_COC_CTO_MNEMONICO
        , OCO_COC_CCO_MNEMONICO
        , OCO_COC_CTE_MNEMONICO
        , OCO_TOC_MNEMONICO
        , OCO_CNE_MNEMONICO
        , OCO_EOC_MNEMONICO
        , OCO_VIO_MNEMONICO
        , OCO_CCC_CLI_PER_NUM_IDEN
        , OCO_CCC_CLI_PER_TID_CODIGO
        , OCO_CCC_NUMERO_CUENTA
        , OCO_PER_NUM_IDEN
        , OCO_PER_TID_CODIGO
        , OCO_RLC_PER_NUM_IDEN
        , OCO_RLC_PER_TID_CODIGO
        , OCO_RLC_ROL_CODIGO
        , OCO_LTI_MNEMONICO
        , OCO_GNA_MNEMONICO
        , OCO_FECHA_Y_HORA
        , OCO_FECHA_CRONOLOGICA
        , OCO_NOMINAL_O_PESOS
        , OCO_TIPO_NOMINAL_O_PESOS
        , OCO_OPERACION_TOTAL
