         ,ofo_per_tid_codigo_orden
         ,ofo_per_num_iden_cta
         ,ofo_per_tid_codigo_cta
       )
       VALUES(
          consecutivo_orden
         ,c_orden_origen.ofo_suc_codigo
         ,c_orden_origen.ofo_cfo_ccc_cli_per_num_iden
         ,c_orden_origen.ofo_cfo_ccc_cli_per_tid_codigo
         ,c_orden_origen.ofo_cfo_ccc_numero_cuenta
         ,c_orden_origen.ofo_cfo_fon_codigo
         ,c_orden_origen.ofo_cfo_codigo
         ,'APR'
         ,c_orden_origen.ofo_per_num_iden
         ,c_orden_origen.ofo_per_tid_codigo
         ,v_tipo_orden
         ,c_orden_origen.ofo_tto_tit_codigo
         ,P_OFO_FECHA_EJECUCION
         ,v_monto_orden
         ,'S'
         ,v_monto_orden
         ,null
         ,P_OFO_FECHA_EJECUCION
         ,c_orden_origen.ofo_modificacion
         ,P_OFO_FECHA_EJECUCION
         ,'N'
         ,c_orden_origen.ofo_per_num_iden_coloco
         ,c_orden_origen.ofo_per_tid_codigo_coloco
         ,null
         ,null
         ,'N'
         ,NULL
         ,NULL
         ,NULL
         ,NULL
         ,NULL
         ,NULL
         ,NULL
         ,NULL
         ,'N'
         ,NULL
         ,NULL
