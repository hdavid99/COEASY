-- FUNCION QUE VALIDA SI EL FONDO TIENE SALTO ENTRE PARTICIPACIONES
-- VAGTUD991
FUNCTION FN_APLICA_SALTOS
        (P_FONDO VARCHAR2 -- FONDO PARTICIPACION
        ) RETURN VARCHAR IS


   -- CURSOR QUE TRAE EL FONDO PAPA DE LA PARTICIPACION
   CURSOR C_PFO1 IS
      SELECT PFO_RANGO_MIN_CHAR
        FROM PARAMETROS_FONDOS
       WHERE PFO_FON_CODIGO = P_FONDO
         AND PFO_PAR_CODIGO = 71;
   V_FONDO_PADRE VARCHAR2(15);

   -- CURSOR QUE VALIDA SI ALGUNA PARTICIPACION DEL FONDO PAPA TIENE PARAMETRO 81
   CURSOR C_PFO2 (QFON_PAPA VARCHAR2) IS
      SELECT COUNT(1)
        FROM PARAMETROS_FONDOS PF1, FONDOS
       WHERE PF1.PFO_PAR_CODIGO = 71
         AND PF1.PFO_RANGO_MIN_CHAR = QFON_PAPA
         AND PF1.PFO_FON_CODIGO = FON_CODIGO
         AND FON_ESTADO = 'A'
         AND EXISTS (
             SELECT 'S'
               FROM PARAMETROS_FONDOS PF2
              WHERE PF1.PFO_FON_CODIGO = PF2.PFO_FON_CODIGO
                AND PF2.PFO_PAR_CODIGO = 81        -- PARAMETRO PARA SALTO DE PARTICIPACIONES
                AND UPPER(PFO_RANGO_MIN_CHAR) = 'S'
             );
   V_EXISTE NUMBER(2);
   V_APLICA VARCHAR2(1);

BEGIN
   V_APLICA := 'N';
   OPEN C_PFO1;
   FETCH C_PFO1 INTO V_FONDO_PADRE;
   IF C_PFO1%NOTFOUND THEN
      CLOSE C_PFO1;
      RETURN ('N');
   ELSE
      OPEN C_PFO2 (V_FONDO_PADRE);
      FETCH C_PFO2 INTO V_EXISTE;
      CLOSE C_PFO2;
      IF NVL(V_EXISTE,0) > 0 THEN
         V_APLICA := 'S';
      END IF;
      CLOSE C_PFO1;
      RETURN V_APLICA;
   END IF;

EXCEPTION
   WHEN OTHERS THEN
      RETURN 'N';

END FN_APLICA_SALTOS;

--------------------------------------------------------------------------------------------------------------------------------
-- VAGTUD991 - NUEVAS PARTICIPACIONES F.INTERES
-- INVOCADO DESDE P_MOVIMIENTOS_COMPARTIMENTOS_J
PROCEDURE P_TOPES_INV_COMPARTIMENTOS_J
         (P_FON_CODIGO        VARCHAR2
         ,P_SALARIO_MINIMO    NUMBER
         ,P_MINIMO_INVERSION  OUT NUMBER
         ,P_MAXIMO_INVERSION  OUT NUMBER
         ,P_VALIDA_SIN_TOPE   OUT VARCHAR2
         ) AS

   CURSOR VALOR_PAR(TIPO NUMBER,P_FONDO VARCHAR2) IS
      SELECT PFO_RANGO_MIN_NUMBER,
             PFO_RANGO_MAX_NUMBER,
             PFO_RANGO_MIN_CHAR,
             PFO_RANGO_MAX_CHAR
        FROM PARAMETROS_FONDOS A
       WHERE PFO_FON_CODIGO = P_FONDO
         AND A.PFO_PAR_CODIGO = TIPO;

   CURSOR VALOR_FONDO (P_FONDO VARCHAR2) IS
      SELECT VFO_CAPITAL + VFO_REND_RF + VFO_REND_RV - VFO_RETENCION VALOR_FONDO
        FROM VALORIZACIONES_FONDO
       WHERE VFO_FON_CODIGO = P_FONDO
    ORDER BY VFO_FECHA_VALORIZACION  DESC;

   LIMITES            VALOR_PAR%ROWTYPE;
   MINSALFON          VALOR_PAR%ROWTYPE;
   MINIMO_INVER       VALOR_PAR%ROWTYPE;
   MAXIMO_INVER       VALOR_PAR%ROWTYPE;
   SIN_LIMITES        VALOR_PAR%ROWTYPE;
   LIMITE_FONDO       VALOR_PAR%ROWTYPE;
   FONDO_PAPA         VALOR_PAR%ROWTYPE;
   C_VALOR_FONDO      VALOR_FONDO%ROWTYPE;
   V_VALIDA_INGRESO   VARCHAR2(1);
   NO_LIMITES         EXCEPTION;
   NO_LIMITE_FONDO    EXCEPTION;
   NO_LIMITES_MAX     EXCEPTION;
   NO_FONDO_PAPA      EXCEPTION;

BEGIN

   /*1. DETERMINAR EL TOPE MINIMO DE INVERSION EN EL FONDO*/
   OPEN VALOR_PAR(112,P_FON_CODIGO); -- PARAMETRO DE VALOR MINIMO DE INVERSION
   FETCH VALOR_PAR INTO MINIMO_INVER;
   IF VALOR_PAR%NOTFOUND THEN
      CLOSE VALOR_PAR;
      OPEN  VALOR_PAR(28,P_FON_CODIGO);   -- PARAMETRO SALDO MINIMO DE FONDOS
      FETCH VALOR_PAR INTO MINSALFON;
      IF VALOR_PAR%NOTFOUND THEN
         CLOSE VALOR_PAR;
         OPEN  VALOR_PAR(5,P_FON_CODIGO); -- PARAMETRO DE VALOR MINIMO DE INVERSION
         FETCH VALOR_PAR INTO LIMITES;
         CLOSE VALOR_PAR;
      ELSE
         LIMITES.PFO_RANGO_MIN_NUMBER  := MINSALFON.PFO_RANGO_MIN_NUMBER;
         LIMITES.PFO_RANGO_MAX_NUMBER  := MINSALFON.PFO_RANGO_MAX_NUMBER;
         CLOSE VALOR_PAR;
      END IF;
   ELSE
      LIMITES.PFO_RANGO_MIN_NUMBER  := MINIMO_INVER.PFO_RANGO_MIN_NUMBER;
      LIMITES.PFO_RANGO_MAX_NUMBER  := MINIMO_INVER.PFO_RANGO_MAX_NUMBER;
      CLOSE VALOR_PAR;
   END IF;

   IF NVL(LIMITES.PFO_RANGO_MIN_NUMBER,0) = 0 THEN
      V_VALIDA_INGRESO := 'N';
      RAISE NO_LIMITES;
   END IF;

   /*2. DETERMINAR EL TOPE MAXIMO DE INVERSION EN EL FONDO*/
   P_VALIDA_SIN_TOPE := 'N';

   OPEN  VALOR_PAR(75,P_FON_CODIGO); -- PARAMETRO QUE IDENTIFICA SI LA PARTICIPACION ES SIN TOPE MAXIMO DE INVERSION
   FETCH VALOR_PAR INTO SIN_LIMITES;
   IF VALOR_PAR%FOUND THEN
      P_VALIDA_SIN_TOPE := 'S';
   END IF;
   CLOSE VALOR_PAR;

   IF NVL(P_VALIDA_SIN_TOPE,'N') = 'S' THEN
      /* OBTENER NIT DEL FONDO PAPA*/
      OPEN  VALOR_PAR(71,P_FON_CODIGO);
      FETCH VALOR_PAR INTO FONDO_PAPA;
      IF VALOR_PAR%NOTFOUND THEN
         CLOSE VALOR_PAR;
         RAISE NO_FONDO_PAPA;
      END IF;
      CLOSE VALOR_PAR;

      OPEN VALOR_FONDO(FONDO_PAPA.PFO_RANGO_MIN_CHAR);
      FETCH VALOR_FONDO INTO C_VALOR_FONDO;
      CLOSE VALOR_FONDO;

      OPEN  VALOR_PAR(14,P_FON_CODIGO);
      FETCH VALOR_PAR INTO LIMITE_FONDO;
      IF VALOR_PAR%NOTFOUND THEN
         RAISE NO_LIMITE_FONDO;
      END IF;
      CLOSE VALOR_PAR;

      P_MAXIMO_INVERSION :=    (NVL(C_VALOR_FONDO.VALOR_FONDO,0) * NVL(LIMITE_FONDO.PFO_RANGO_MIN_NUMBER,0));
      P_VALIDA_SIN_TOPE := 'N';
   ELSE
      OPEN  VALOR_PAR(113,P_FON_CODIGO); -- PARAMETRO DE VALOR MAXIMO DE INVERSION
      FETCH VALOR_PAR INTO MAXIMO_INVER;
      P_MAXIMO_INVERSION := (NVL(MAXIMO_INVER.PFO_RANGO_MIN_NUMBER,0));     -- EL PARAMETRO DEBE INDICAR EL VALOR MAX CON DECIMALES
   END IF;

   P_MINIMO_INVERSION := NVL(LIMITES.PFO_RANGO_MIN_NUMBER,0);

   EXCEPTION
      WHEN  NO_LIMITES THEN
         RAISE_APPLICATION_ERROR(-20401,'No es posible determinar valor minimo de inversion del fondo:'||P_FON_CODIGO) ;
      WHEN   NO_LIMITE_FONDO THEN
         RAISE_APPLICATION_ERROR(-20402,'No se encuentra parametro de valor movimiento  vrs  valor fondo (%)- (14)');
      WHEN  NO_LIMITES_MAX THEN
         RAISE_APPLICATION_ERROR(-20401,'No es posible determinar valor maximo de inversion del fondo:'||P_FON_CODIGO) ;
      WHEN  NO_FONDO_PAPA THEN
         RAISE_APPLICATION_ERROR(-20401,'No es posible determinar el fondo principal de los compartimentos'||P_FON_CODIGO) ;
      WHEN OTHERS THEN
         RAISE_APPLICATION_ERROR(-20400,'Error P_TOPES_INV_COMPARTIMENTOS_J '||sqlerrm);
END P_TOPES_INV_COMPARTIMENTOS_J;
--------------------------------------------------------------------------------------------------------------------------------

FUNCTION FN_VALIDA_CARTA_EXO
        (P_NID    IN VARCHAR2
        ,P_TID    IN VARCHAR2
        ,P_FONDO  IN VARCHAR2
        ) RETURN VARCHAR2 IS

   -- CURSOR QUE VALIDA FONDO FIC O FCP
   CURSOR C_FONDO (QFON VARCHAR2) IS
      SELECT FON_TIPO_ADMINISTRACION, FON_CAPITAL_PRIVADO
        FROM FONDOS
       WHERE FON_CODIGO = QFON;
   FON C_FONDO%ROWTYPE;

   -- CURSOR PARA TRAER FONDO PADRE
   CURSOR C_FONPDR (QFON VARCHAR2) IS
      SELECT PFO_RANGO_MIN_CHAR
        FROM PARAMETROS_FONDOS
       WHERE PFO_FON_CODIGO = P_FONDO
         AND PFO_PAR_CODIGO = 71;
   V_FONPDR VARCHAR2(15);

   CURSOR C_CCF (QFON VARCHAR2, QNID VARCHAR2, QTID VARCHAR2) IS
      SELECT CCF_FON_CODIGO, CCF_CLI_PER_NUM_IDEN, CCF_CLI_PER_TID_CODIGO, CCF_RADICACION_ADHESION, CCF_CARTA_EXONERACION
        FROM CUENTAS_CLIENTES_FONDOS
       WHERE CCF_FON_CODIGO LIKE QFON||'%'
         AND CCF_CLI_PER_NUM_IDEN = QNID
         AND CCF_CLI_PER_TID_CODIGO = QTID;
   CCF C_CCF%ROWTYPE;

   V_EXO VARCHAR2(1);
   V_FONDO VARCHAR2(15);
   V_SIGA VARCHAR2(1);

BEGIN
   V_SIGA := 'S';
   OPEN C_FONDO (P_FONDO);
   FETCH C_FONDO INTO FON;
   IF FON.FON_TIPO_ADMINISTRACION = 'A' THEN
      V_SIGA := 'N';       -- PARA APT NO APLICA
   END IF;
   CLOSE C_FONDO;

   IF V_SIGA = 'S' THEN
      OPEN C_FONPDR (P_FONDO);
      FETCH C_FONPDR INTO V_FONPDR;
      IF C_FONPDR%FOUND THEN
         V_FONDO := V_FONPDR;
      ELSE
         V_FONDO := SUBSTR(P_FONDO, 1, INSTR(P_FONDO, '-', 1) - 1);
         IF V_FONDO IS NULL THEN
            V_FONDO := P_FONDO;
         END IF;
         V_SIGA := 'N';
      END IF;
      CLOSE C_FONPDR;

      OPEN C_CCF (V_FONDO, P_NID, P_TID);
      FETCH C_CCF INTO CCF;
      IF C_CCF%NOTFOUND THEN
         V_EXO := 'N';
      ELSE
         V_EXO := NVL(CCF.CCF_CARTA_EXONERACION,'N');
      END IF;
      CLOSE C_CCF;
   ELSE
      V_EXO := 'N';
   END IF;

   RETURN V_EXO;

EXCEPTION
   WHEN OTHERS THEN
         RETURN 'N';

END FN_VALIDA_CARTA_EXO;
--------------------------------------------------------------------------------------------------------------------------------
FUNCTION FN_VALIDA_CARTA_ADH
        (P_NID    IN VARCHAR2
        ,P_TID    IN VARCHAR2
        ,P_FONDO  IN VARCHAR2
        ) RETURN VARCHAR2 IS

   -- CURSOR QUE VALIDA FONDO FIC O FCP
   CURSOR C_FONDO (QFON VARCHAR2) IS
      SELECT FON_TIPO_ADMINISTRACION, FON_CAPITAL_PRIVADO
        FROM FONDOS
       WHERE FON_CODIGO = QFON;
   FON C_FONDO%ROWTYPE;

   -- CURSOR PARA TRAER FONDO PADRE
   CURSOR C_FONPDR (QFON VARCHAR2) IS
      SELECT PFO_RANGO_MIN_CHAR
        FROM PARAMETROS_FONDOS
       WHERE PFO_FON_CODIGO = P_FONDO
         AND PFO_PAR_CODIGO = 71;
   V_FONPDR VARCHAR2(15);

   CURSOR C_CCF (QFON VARCHAR2, QNID VARCHAR2, QTID VARCHAR2) IS
      SELECT 'S'
        FROM CUENTAS_CLIENTES_FONDOS
       WHERE CCF_FON_CODIGO LIKE QFON||'%'
         AND CCF_CLI_PER_NUM_IDEN = QNID
         AND CCF_CLI_PER_TID_CODIGO = QTID;
   V_EXISTE VARCHAR2(1);

   V_FONDO VARCHAR2(15);
   V_SIGA VARCHAR2(1);

BEGIN
   V_SIGA := 'S';
   OPEN C_FONDO (P_FONDO);
   FETCH C_FONDO INTO FON;
   IF FON.FON_TIPO_ADMINISTRACION = 'F' THEN
      IF FON.FON_CAPITAL_PRIVADO != 'N' THEN
         V_SIGA := 'N';       -- PARA FCP NO SE VALIDA CARTA DE ADHESION
      END IF;
   ELSE
      V_SIGA := 'N';          -- SI NO ES FIC NO SE VALIDA CARTA DE ADHESION
   END IF;
   CLOSE C_FONDO;

   IF V_SIGA = 'S' THEN
      OPEN C_FONPDR (P_FONDO);
      FETCH C_FONPDR INTO V_FONPDR;
      IF C_FONPDR%FOUND THEN
         V_FONDO := V_FONPDR;
      ELSE
         V_FONDO := SUBSTR(P_FONDO, 1, INSTR(P_FONDO, '-', 1) - 1);
         IF V_FONDO IS NULL THEN
            V_FONDO := P_FONDO;
         END IF;
         V_SIGA := 'N';
      END IF;
      CLOSE C_FONPDR;

      OPEN C_CCF (V_FONDO, P_NID, P_TID);
      FETCH C_CCF INTO V_EXISTE;
      IF C_CCF%NOTFOUND THEN
         V_EXISTE := 'N';
      END IF;
      CLOSE C_CCF;
   ELSE
      V_EXISTE := 'N';
   END IF;
   RETURN V_EXISTE;

EXCEPTION
   WHEN OTHERS THEN
         RETURN 'N';
END FN_VALIDA_CARTA_ADH;

END P_ORDENES_FONDOS;

/

  GRANT EXECUTE ON "PROD"."P_ORDENES_FONDOS" TO "M_OP_SOPORTE_PROFESIONAL";
  GRANT EXECUTE ON "PROD"."P_ORDENES_FONDOS" TO "COE_RECURSOS";
  GRANT EXECUTE ON "PROD"."P_ORDENES_FONDOS" TO "M_AUX_OP_TESORERIA_MED";
  GRANT EXECUTE ON "PROD"."P_ORDENES_FONDOS" TO "M_J_OP_VAL_CTRL";
