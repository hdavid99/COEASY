--------------------------------------------------------
--  DDL for Package Body P_ORDENES_FONDOS
--------------------------------------------------------

  CREATE OR REPLACE EDITIONABLE PACKAGE BODY "PROD"."P_ORDENES_FONDOS" IS
/************************************************************/
/******************************************************************************************
***  FUNCION NOMBRE BASE DE DATOS           ****
*******************************************************************************************/
FUNCTION FN_DATABASE
RETURN VARCHAR2 IS
V_DBNAME VARCHAR2(50);
BEGIN
SELECT VALUE INTO V_DBNAME
FROM V$SYSTEM_PARAMETER
WHERE NAME = 'db_name';
   RETURN (V_DBNAME);
END;


/******************************************************************************************
***  FUNCION CALCULO FECHA T+N           ****
*******************************************************************************************/
FUNCTION FN_DIA_TN(FECHA_CAPTURA DATE, V_DIAS_PAGO NUMBER)
RETURN DATE IS

/*CURSOR C_FECHA (P_OFO_CONSECUTIVO NUMBER) IS
  SELECT OFO_FECHA_CAPTURA
  FROM ORDENES_FONDOS
  WHERE OFO_CONSECUTIVO =  P_OFO_CONSECUTIVO;*/

CURSOR C_DIA_NO_HABIL2(FECHA DATE) IS
  SELECT 'X'
  FROM   DIAS_NO_HABILES
  WHERE  TRUNC(DNH_FECHA) = TRUNC(FECHA);

COND2 VARCHAR2(1);
FECHA_EJECUCION DATE;
DIAS NUMBER;

BEGIN
--   OPEN C_FECHA (P_OFO_CONSECUTIVO);
--   FETCH C_FECHA INTO FECHA_EJECUCION;
--   CLOSE C_FECHA;
   DIAS :=  V_DIAS_PAGO;
   FECHA_EJECUCION := FECHA_CAPTURA;
  --MSG_ALERT('DIAS  FECHA_EJE  '||DIAS||' -- '||FECHA_EJE ,'E',FALSE);
   WHILE DIAS > 0 LOOP
      FECHA_EJECUCION := FECHA_EJECUCION + 1;
      LOOP
       --MSG_ALERT('DIAS  FECHA_EJE  '||DIAS||' -- '||FECHA_EJE ,'E',FALSE);
               COND2 := NULL;
               OPEN C_DIA_NO_HABIL2(FECHA_EJECUCION);
               FETCH C_DIA_NO_HABIL2 INTO COND2;
               CLOSE C_DIA_NO_HABIL2;
               IF NVL(COND2,' ') = 'X' OR TO_CHAR(FECHA_EJECUCION,'D') IN (1,7) THEN
                  FECHA_EJECUCION := FECHA_EJECUCION + 1;
               ELSE
                  EXIT;
               END IF;
            END LOOP;
            DIAS := DIAS - 1;
       END LOOP;
   RETURN (FECHA_EJECUCION);
END;

PROCEDURE CONFIRMA_ORDEN(P_OFO_SUC_CODIGO  NUMBER
                        ,P_OFO_CONSECUTIVO NUMBER
                        ,P_COMPARTIMENTO                    VARCHAR2 DEFAULT NULL
                        ,P_FON_PADRE_COMPARTIMENTO          VARCHAR2 DEFAULT NULL
                        ,P_VALIDAR_MATRIZ                   VARCHAR2 DEFAULT NULL
                        ,P_CONPENSA_APT                     VARCHAR2 DEFAULT NULL) IS --WGONZALEZ VAGTUD944-3

 CURSOR C_CONSTANTES(CONSTANTE VARCHAR2) IS
     SELECT CON_VALOR_CHAR
     FROM   CONSTANTES
     WHERE  CON_MNEMONICO = CONSTANTE;
   CON   VARCHAR2(1000);
   CURSOR C_OFO IS
      SELECT  OFO_SUC_CODIGO
             ,OFO_CONSECUTIVO
             ,OFO_CFO_CCC_CLI_PER_NUM_IDEN
             ,OFO_CFO_CCC_CLI_PER_TID_CODIGO
             ,OFO_CFO_CCC_NUMERO_CUENTA
             ,OFO_CFO_FON_CODIGO
             ,OFO_CFO_CODIGO
             ,OFO_EOF_CODIGO
             ,OFO_TTO_TOF_CODIGO
             ,OFO_FECHA_EJECUCION
             ,OFO_FECHA_CAPTURA
             ,OFO_MONTO
             ,OFO_MONTO_ANTICIPO
             ,OFO_OFO_SUC_CODIGO
             ,OFO_OFO_CONSECUTIVO
             ,OFO_CARGO_ABONO_CUENTA
             ,OFO_FECHA_CUMPLIMIENTO
             ,OFO_AEFI_CONSECUTIVO
             ,OFO_CNL_CONSECUTIVO
      FROM    ORDENES_FONDOS
      WHERE   OFO_SUC_CODIGO = P_OFO_SUC_CODIGO
      AND     OFO_CONSECUTIVO = P_OFO_CONSECUTIVO;
   R_OFO C_OFO%ROWTYPE;

   CURSOR C_VALOR_PAR(P_TIPO NUMBER) IS
      SELECT PFO_RANGO_MIN_CHAR
      FROM   PARAMETROS_FONDOS A
      WHERE  PFO_FON_CODIGO = R_OFO.OFO_CFO_FON_CODIGO
      AND    A.PFO_PAR_CODIGO = P_TIPO;

   CURSOR EXCENTO IS
      SELECT CCC_EXENTA_GMF
      FROM   CUENTAS_CLIENTE_CORREDORES
      WHERE  CCC_CLI_PER_NUM_IDEN = R_OFO.OFO_CFO_CCC_CLI_PER_NUM_IDEN
      AND    CCC_CLI_PER_TID_CODIGO = R_OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO
      AND    CCC_NUMERO_CUENTA = R_OFO.OFO_CFO_CCC_NUMERO_CUENTA;

   CURSOR HORA_LIMITE(TIPO NUMBER)IS
      SELECT a.PFO_RANGO_MIN_CHAR
            ,a.PFO_RANGO_MAX_CHAR
      FROM   parametros_fondos a
      WHERE  a.pfo_fon_codigo = R_OFO.OFO_CFO_FON_CODIGO
      AND    a.pfo_par_codigo = tipo;

   CURSOR C_ESTADO IS
      SELECT CFO_ESTADO
      FROM   CUENTAS_FONDOS
      WHERE  CFO_CCC_CLI_PER_TID_CODIGO = R_OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO
      AND    CFO_CCC_CLI_PER_NUM_IDEN = R_OFO.OFO_CFO_CCC_CLI_PER_NUM_IDEN
      AND    CFO_CCC_NUMERO_CUENTA = R_OFO.OFO_CFO_CCC_NUMERO_CUENTA
      AND    CFO_FON_CODIGO = R_OFO.OFO_CFO_FON_CODIGO
      AND    CFO_CODIGO = R_OFO.OFO_CFO_CODIGO;

   CURSOR VALOR_UNIDAD IS
      SELECT VF.VFO_VALOR         DATO_VALOR_UNIDAD
      FROM   VALORIZACIONES_FONDO VF
      WHERE  VF.VFO_FECHA_VALORIZACION = TO_DATE(TO_CHAR(SYSDATE,'DD-MON-YYYY')
                     || ' ' || TO_CHAR(VF.VFO_FECHA_VALORIZACION,'HH24:MI:SS'),'DD-MON-YYYY HH24:MI:SS')
      AND    VF.VFO_FON_CODIGO = R_OFO.OFO_CFO_FON_CODIGO;
   VU VALOR_UNIDAD%ROWTYPE;

   CURSOR SALDOS IS
      SELECT CFO_SALDO_RENDIMIENTOS_RF    SAL_RND_RF
            ,CFO_SALDO_RENDIMIENTOS_RV    SAL_RND_RV
            ,CFO_SALDO_RETEFUENTE         SAL_RET
            ,CFO_SALDO_CAPITAL            SAL_CAP
            ,CFO_SALDO_INVER              SAL_INV
            ,CFO_SALDO_UNIDADES           SAL_UNI
            ,CFO_SALDO_INTERESES_PAGADOS  SAL_INT
            ,CFO_TASA_PROMEDIO            SAL_TAS
            ,SYSDATE                      SAL_FEC
      FROM   CUENTAS_FONDOS
      WHERE  CFO_CCC_CLI_PER_TID_CODIGO = R_OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO
      AND    CFO_CCC_CLI_PER_NUM_IDEN = R_OFO.OFO_CFO_CCC_CLI_PER_NUM_IDEN
      AND    CFO_CCC_NUMERO_CUENTA = R_OFO.OFO_CFO_CCC_NUMERO_CUENTA
      AND    CFO_FON_CODIGO = R_OFO.OFO_CFO_FON_CODIGO
      AND    CFO_CODIGO = R_OFO.OFO_CFO_CODIGO;
   SAL   SALDOS%ROWTYPE;

   CURSOR TIPO_FONDO IS
      SELECT FON_TIPO
            ,FON_BMO_MNEMONICO
            ,FON_RETEFUENTE
            ,FON_TIPO_ADMINISTRACION
            ,FON_CAPITAL_PRIVADO --VAGTUD412-13"CONTROLES EN CIERRE DE FONDOS DE VALORES"
      FROM  FONDOS
      WHERE FON_CODIGO = R_OFO.OFO_CFO_FON_CODIGO;
   TF   TIPO_FONDO%ROWTYPE;

   CURSOR cant_orden1 IS
     SELECT SUM(ofo_monto)
     FROM   ORDENES_FONDOS
     WHERE  OFO_CFO_CCC_CLI_PER_NUM_IDEN = R_OFO.OFO_CFO_CCC_CLI_PER_NUM_IDEN
     AND    OFO_CFO_CCC_CLI_PER_TID_CODIGO = R_OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO
     AND    ofo_cfo_codigo = R_OFO.OFO_CFO_CODIGO
     AND    ofo_cfo_fon_codigo = R_OFO.OFO_CFO_FON_CODIGO
     AND    ofo_cfo_ccc_numero_cuenta = R_OFO.OFO_CFO_CCC_NUMERO_CUENTA
     AND    OFO_EOF_CODIGO IN ('COL','CON','APL')
     AND    OFO_TTO_TOF_CODIGO IN ('RP','RPS','PSC','PSR','CRC','PCS','RCA','RDA','CRD');

   CURSOR cant_orden2 IS
      SELECT SUM(ofo_monto)
      FROM   ORDENES_FONDOS
      WHERE  OFO_CFO_CCC_CLI_PER_NUM_IDEN = R_OFO.OFO_CFO_CCC_CLI_PER_NUM_IDEN
      AND    OFO_CFO_CCC_CLI_PER_TID_CODIGO = R_OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO
      AND    ofo_cfo_codigo = R_OFO.OFO_CFO_CODIGO
      AND    ofo_cfo_fon_codigo = R_OFO.OFO_CFO_FON_CODIGO
      AND    ofo_cfo_ccc_numero_cuenta = R_OFO.OFO_CFO_CCC_NUMERO_CUENTA
      AND    OFO_EOF_CODIGO IN ('COL','CON','APL')
      AND    OFO_TTO_TOF_CODIGO IN ('ING','INC');

   CURSOR C_RETIRO_TRASLADO IS
      SELECT 'X'
      FROM   ORDENES_FONDOS
      WHERE  OFO_OFO_CONSECUTIVO = P_OFO_CONSECUTIVO
      AND    OFO_OFO_SUC_CODIGO = P_OFO_SUC_CODIGO;
   TRASLADO VARCHAR2(1);

--CURSOR PARA EVALUAR EL PARAMETRO 96
   CURSOR C_VALOR_PAR2(TIPO NUMBER) IS
      SELECT PFO_RANGO_MIN_NUMBER,
             PFO_RANGO_MAX_NUMBER
      FROM   PARAMETROS_FONDOS A
      WHERE  PFO_FON_CODIGO = R_OFO.OFO_CFO_FON_CODIGO
      AND    A.PFO_PAR_CODIGO = TIPO;
   PFO1 C_VALOR_PAR2%ROWTYPE;

--CURSOR PARA VERIFICAR SI EL FONDO YA DISTRIBUYO PARA ESE DIA
   CURSOR C_DISTRIBUCION_FONDO IS
      SELECT CFD_DISTRIBUCION
      FROM   CONFIRMACION_FONDOS_DIA
      WHERE  CFD_FECHA      = TO_CHAR(SYSDATE)
      AND    CFD_FON_CODIGO = R_OFO.OFO_CFO_FON_CODIGO;
   FON_DISTRIBUCION VARCHAR2(1);

   -- INICIO OMORA CUENTA UNICA C3
   -- ORDENES DE FONDOS DE FICS ACTIVOS CON ORDEN DE RECAUDO, QUE NO SEAN DE DAVICASH
   CURSOR C_ORDEN_RECAUDO_FICS IS
   SELECT ORR_CONSECUTIVO,
          ORR_SUC_CODIGO,
          ORR_NEG_CONSECUTIVO,
          ORR_TPA_MNEMONICO,
          ORR_COT_MNEMONICO,
          ORR_CONFIRMADA_BANCOS
     FROM ORDENES_FONDOS,
          ORDENES_RECAUDO,
          FONDOS
    WHERE OFO_CONSECUTIVO = ORR_OFO_CONSECUTIVO
      AND OFO_SUC_CODIGO = ORR_OFO_SUC_CODIGO
      AND OFO_CFO_FON_CODIGO = FON_CODIGO
      AND OFO_TTO_TOF_CODIGO IN ('ING', 'INC')
      AND NVL(ORR_COT_MNEMONICO, 'X') <> ('AXCB')
      AND FON_ESTADO = 'A'
      AND FON_TIPO = 'A'
      AND FON_TIPO_ADMINISTRACION = 'F'
      AND FON_CAPITAL_PRIVADO = 'N'
      AND OFO_CONSECUTIVO = P_OFO_CONSECUTIVO
      AND OFO_SUC_CODIGO = P_OFO_SUC_CODIGO;
   P_ORR_CONSECUTIVO       ORDENES_RECAUDO.ORR_CONSECUTIVO%TYPE;
   P_ORR_SUC_CODIGO        ORDENES_RECAUDO.ORR_SUC_CODIGO%TYPE;
   P_ORR_NEG_CONSECUTIVO   ORDENES_RECAUDO.ORR_NEG_CONSECUTIVO%TYPE;
   P_ORR_TPA_MNEMONICO     ORDENES_RECAUDO.ORR_TPA_MNEMONICO%TYPE;
   P_ORR_COT_MNEMONICO     ORDENES_RECAUDO.ORR_COT_MNEMONICO%TYPE;
   P_ORR_CONFIRMADA_BANCOS ORDENES_RECAUDO.ORR_CONFIRMADA_BANCOS%TYPE;
   -- FIN OMORA CUENTA UNICA C3

   V_DIAS_PAGO          NUMBER;
   P_EXC                VARCHAR2(1) := NULL;
   P_PERMITE_ANTICIPO   VARCHAR2(1) := NULL;
   P_TIPO_FONDO         VARCHAR2(3) := NULL;
   P_T0                 VARCHAR2(5) := NULL;
   EST1                 VARCHAR2(1);
   CONDI                VARCHAR2(1);
   TIPO                 VARCHAR2(5);
   SALDO_RETIROS        NUMBER;
   SALDO_INGRESOS       NUMBER;
   MONTO_ORDENES        NUMBER;
   MONTO_ANTICIPO       NUMBER;
   RP_PRC               NUMBER;
   MONTO_ORDEN          NUMBER;
   F_EJECUCION          DATE;
   NO_HORA_LIMITE       EXCEPTION;
   FIN_HORA_LIMITE      EXCEPTION;
   DISTRIBUCION_FONDO   EXCEPTION;
   NO_CONFIRMA          EXCEPTION;
   ESTADO_INACTIVO      EXCEPTION;
   YA_VALORO            EXCEPTION;
   NO_SALDO             EXCEPTION;
   NO_EXCENTO           EXCEPTION;
   NO_TIPO_FONDO        EXCEPTION;
   SALDO_INSUFICIENTE   EXCEPTION;
   HORA                HORA_LIMITE%ROWTYPE;
BEGIN

   OPEN C_OFO;
   FETCH C_OFO INTO R_OFO;
   CLOSE C_OFO;
   --------------------------
   -- DIAS PARA PAGO
   --------------------------
  OPEN C_VALOR_PAR2(96);
   FETCH C_VALOR_PAR2 INTO PFO1;
   IF C_VALOR_PAR2%NOTFOUND THEN
         PFO1.PFO_RANGO_MIN_NUMBER:= 0;
   END IF;
   V_DIAS_PAGO := NVL(PFO1.PFO_RANGO_MIN_NUMBER,0);
   CLOSE C_VALOR_PAR2;

   OPEN C_VALOR_PAR(33);
   FETCH C_VALOR_PAR INTO P_T0;
   CLOSE C_VALOR_PAR;
   P_T0 := NVL(P_T0,'N');
   IF P_T0 = 'S' THEN
      OPEN C_VALOR_PAR(34);
      FETCH C_VALOR_PAR INTO P_PERMITE_ANTICIPO;
      CLOSE C_VALOR_PAR;
      P_PERMITE_ANTICIPO := NVL(P_PERMITE_ANTICIPO,'N');
   ELSE
      P_PERMITE_ANTICIPO := 'N';
   END IF;

   OPEN EXCENTO;
   FETCH EXCENTO INTO P_EXC;
   IF EXCENTO%NOTFOUND THEN
      CLOSE EXCENTO;
      RAISE NO_EXCENTO;
   END IF;
   CLOSE EXCENTO;
   /*
   ** Rutina para la creacion de movimientos de una cuenta de fondos
   ** - Verifica que la orden tenga como estado 'aprobada'.
   ** - Chequea el tipo de movimiento.
   ** - Ejecuta la insersion de nuevos movimientos a la cuenta.
   */
   IF R_OFO.OFO_EOF_CODIGO = 'COL' THEN
      -- INICIO OMORA CUENTA UNICA C3
      OPEN C_ORDEN_RECAUDO_FICS;
      FETCH C_ORDEN_RECAUDO_FICS
       INTO P_ORR_CONSECUTIVO,
            P_ORR_SUC_CODIGO,
            P_ORR_NEG_CONSECUTIVO,
            P_ORR_TPA_MNEMONICO,
            P_ORR_COT_MNEMONICO,
            P_ORR_CONFIRMADA_BANCOS;
      CLOSE C_ORDEN_RECAUDO_FICS;
      -- FIN OMORA CUENTA UNICA C3

      IF NVL(R_OFO.OFO_CARGO_ABONO_CUENTA,' ') != 'S' THEN
         OPEN HORA_LIMITE(9);
         FETCH HORA_LIMITE INTO HORA;
         IF HORA_LIMITE%NOTFOUND THEN
            RAISE NO_HORA_LIMITE;
         END IF;
         IF TO_CHAR(SYSDATE,'HH24:MI') > HORA.PFO_RANGO_MAX_CHAR AND
            TRUNC(R_OFO.OFO_FECHA_EJECUCION)= TRUNC(R_OFO.OFO_FECHA_CAPTURA) AND
            NVL(P_VALIDAR_MATRIZ,'X') = 'X' THEN
            RAISE FIN_HORA_LIMITE;
         ELSIF NVL(P_VALIDAR_MATRIZ,'X') in ('IB') THEN --APLICA PARA INGRESOS E INCREMENTOS DESDE CANALES DEL BANCO
            OPEN C_CONSTANTES('HMI'); --HORA LIMITE INCREMENTOS CANALES BANCO
            FETCH C_CONSTANTES INTO CON;
            IF C_CONSTANTES%NOTFOUND THEN
              CLOSE C_CONSTANTES;
              RAISE_APPLICATION_ERROR(-20039,'No se encontro la costante HMI hora limite incrementos canales banco');
            ELSE
               IF TO_CHAR(SYSDATE,'HH24:MI') > CON THEN
                RAISE_APPLICATION_ERROR(-20040,'La Hora de incrementos desde canales banco ha terminado');
               END IF;
            END IF;
         ELSIF NVL(P_VALIDAR_MATRIZ,'X') in ('RB') THEN --APLICA PARA INGRESOS E INCREMENTOS Y RETIROS PARCIALES DESDE CANALES DEL BANCO
            OPEN C_CONSTANTES('HRB'); --HORA LIMITE RETIROS CANALES BANCO
            FETCH C_CONSTANTES INTO CON;
            IF C_CONSTANTES%NOTFOUND THEN
              CLOSE C_CONSTANTES;
              RAISE_APPLICATION_ERROR(-20039,'No se encontro la costante HRB hora limite retiros canales banco');
            ELSE
              IF TO_CHAR(SYSDATE,'HH24:MI') > CON THEN
                RAISE_APPLICATION_ERROR(-20040,'La Hora de retiros desde canales banco ha terminado');
              END IF;
            END IF;
         ELSE
            OPEN C_DISTRIBUCION_FONDO;
            FETCH C_DISTRIBUCION_FONDO INTO FON_DISTRIBUCION;
            IF C_DISTRIBUCION_FONDO%FOUND THEN
                IF NVL(FON_DISTRIBUCION, 'N') = 'S' AND
                   NVL(P_VALIDAR_MATRIZ,'X') = 'D' THEN                 -- Aplica para: Generación de Ordenes de Fondos  para codigo de barras GEOFCB
                    RAISE DISTRIBUCION_FONDO;
                END IF;
            END IF;
            CLOSE C_DISTRIBUCION_FONDO;
         END IF;
         CLOSE HORA_LIMITE;
      END IF;
      IF TIPO = 'S' THEN
         OPEN VALOR_UNIDAD;
         FETCH VALOR_UNIDAD INTO VU;
         IF VALOR_UNIDAD%FOUND THEN
            CLOSE VALOR_UNIDAD;
            RAISE YA_VALORO;
         END IF;
         CLOSE VALOR_UNIDAD;
      END IF;
      OPEN C_ESTADO;
      FETCH C_ESTADO INTO EST1;
      CLOSE C_ESTADO;
      IF EST1 != 'A' THEN
         RAISE ESTADO_INACTIVO;
      END IF;
      CONDI := 'S';
      IF R_OFO.OFO_TTO_TOF_CODIGO IN ('ING','INC','RP','RT') THEN
         P_ORDENES_FONDOS.VERIFICA_TRANSFERENCIA( R_OFO.OFO_OFO_SUC_CODIGO
                                                 ,R_OFO.OFO_OFO_CONSECUTIVO
                                                 ,R_OFO.OFO_SUC_CODIGO
                                                 ,R_OFO.OFO_CONSECUTIVO
                                                 ,R_OFO.OFO_EOF_CODIGO
                                                 ,R_OFO.OFO_CFO_CCC_CLI_PER_NUM_IDEN
                                                 ,'ANU'
                                                 ,CONDI);
      END IF;
      IF CONDI = 'S' THEN
         /*Si la orden no es de ingreso se cargan los saldos*/
         IF R_OFO.OFO_TTO_TOF_CODIGO ='ING' THEN
            SAL.SAL_FEC := SYSDATE;
         ELSE
            OPEN SALDOS;
            FETCH SALDOS INTO SAL;
            IF (SALDOS%NOTFOUND) THEN
              RAISE NO_SALDO;
            END IF;
            CLOSE SALDOS;
         END IF;
         /* VERIFICACION DE A QUE TIPO CORRESPONDE LA ORDEN */
         /*
         **
         ** INGRESO
         **
         */
         IF R_OFO.OFO_TTO_TOF_CODIGO = 'ING' THEN
            /*Determina si el fondo es abierto o cerrado*/
            OPEN TIPO_FONDO;
            FETCH TIPO_FONDO INTO TF;
            IF (TIPO_FONDO%NOTFOUND) THEN
               RAISE NO_TIPO_FONDO;
            END IF;
            CLOSE TIPO_FONDO;


            P_TIPO_FONDO := TF.FON_TIPO;
            SELECT SYSDATE INTO F_EJECUCION FROM SYS.DUAL;
            SELECT SYSDATE INTO SAL.SAL_FEC FROM SYS.DUAL;
            UPDATE ORDENES_RECAUDO
            SET    ORR_ESTADO = 'APR'
            WHERE  ORR_OFO_SUC_CODIGO = R_OFO.OFO_SUC_CODIGO
            AND    ORR_OFO_CONSECUTIVO = R_OFO.OFO_CONSECUTIVO;
            IF TF.FON_TIPO_ADMINISTRACION != 'A' AND TF.FON_CAPITAL_PRIVADO = 'N' THEN
               P_ORDENES_FONDOS.INSERTAR_MOVIMIENTO_CORREDORES(R_OFO.OFO_CFO_CCC_CLI_PER_NUM_IDEN
                                                              ,R_OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO
                                                              ,R_OFO.OFO_CFO_CCC_NUMERO_CUENTA
                                                              ,R_OFO.OFO_MONTO
                                                              ,R_OFO.OFO_CONSECUTIVO
                                                              ,R_OFO.OFO_SUC_CODIGO
                                                              ,'ING');

          -- INGRESA MOVIMIENTO_CUENTA_CORREDORES PARA APORTES EN ESPECIE - APES - VAGTUD661-3
               IF R_OFO.OFO_AEFI_CONSECUTIVO IS NOT NULL THEN
                  P_ORDENES_FONDOS.INSERT_MVTO_CORREDORES_ESPECIE(R_OFO.OFO_CFO_CCC_CLI_PER_NUM_IDEN
                                                                  ,R_OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO
                                                                  ,R_OFO.OFO_CFO_CCC_NUMERO_CUENTA
                                                                  ,R_OFO.OFO_MONTO
                                                                  ,R_OFO.OFO_CONSECUTIVO
                                                                  ,R_OFO.OFO_SUC_CODIGO
                                                                  ,'ING');

               END IF;
            END IF;

            -- INICIO OMORA CUENTA UNICA C3
            IF P_ORR_CONSECUTIVO IS NOT NULL AND P_ORR_SUC_CODIGO IS NOT NULL AND P_ORR_NEG_CONSECUTIVO IS NOT NULL AND
               P_ORR_TPA_MNEMONICO = 'TRB' AND P_ORR_COT_MNEMONICO IS NULL AND NVL(P_ORR_CONFIRMADA_BANCOS, 'N') = 'N' THEN
                UPDATE ORDENES_RECAUDO
                   SET ORR_MOTEFO_PENDIENTE = 'S'
                 WHERE ORR_CONSECUTIVO = P_ORR_CONSECUTIVO
                   AND ORR_SUC_CODIGO = P_ORR_SUC_CODIGO
                   AND ORR_NEG_CONSECUTIVO = P_ORR_NEG_CONSECUTIVO;
            ELSE
                P_ORDENES_FONDOS.MOVIMIENTO_BANCARIO(P_OFO_SUC_CODIGO             => R_OFO.OFO_SUC_CODIGO
                                                    ,P_OFO_CONSECUTIVO            => R_OFO.OFO_CONSECUTIVO
                                                    ,P_OFO_CFO_FON_CODIGO         => R_OFO.OFO_CFO_FON_CODIGO
                                                    ,P_OFO_TTO_TOF_CODIGO         => R_OFO.OFO_TTO_TOF_CODIGO
                                                    ,P_EXC                        => P_EXC
                                                    ,P_TIPO                       => 'R'
                                                    ,P_COMPARTIMENTO_B            => P_COMPARTIMENTO
                                                    ,P_FON_PADRE_COMPARTIMENTO_B  => P_FON_PADRE_COMPARTIMENTO
                                                    ,P_ESTADO                     => 'APR'
                                                    ,P_OFO_CANAL                  => R_OFO.OFO_CNL_CONSECUTIVO);
            END IF;
            -- FIN OMORA CUENTA UNICA C3

           P_ORDENES_FONDOS.ABONO_CARGO_CUENTA( R_OFO.OFO_SUC_CODIGO
                                               ,R_OFO.OFO_CONSECUTIVO
                                               ,R_OFO.OFO_CFO_CCC_cLI_PER_NUM_IDEN
                                               ,R_OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO
                                               ,R_OFO.OFO_CFO_CCC_NUMERO_CUENTA
                                               ,R_OFO.OFO_CFO_FON_CODIGO
                                               ,R_OFO.OFO_CFO_CODIGO
                                               ,P_EXC
                                               ,'C'
                                               ,'ING');
            UPDATE ORDENES_FONDOS
            SET    OFO_FECHA_EJECUCION = F_EJECUCION,
                   OFO_EOF_CODIGO = 'CON'
            WHERE  OFO_SUC_CODIGO = R_OFO.OFO_SUC_CODIGO
            AND    OFO_CONSECUTIVO = R_OFO.OFO_CONSECUTIVO;
            /*
            **
            ** INCREMENTO
            **
            */
         ELSIF R_OFO.OFO_TTO_TOF_CODIGO = 'INC' OR R_OFO.OFO_TTO_TOF_CODIGO IN ('INR','IDC','INM') THEN -- OMORA
            -- MODIFICACION PARA TENER EN CUENTA LOS INCREMENTOS DE LOS ESCALONADOS
            /*Determina si el fondo es abierto o cerrado*/
            OPEN TIPO_FONDO;
            FETCH TIPO_FONDO INTO TF;
            IF (TIPO_FONDO%NOTFOUND) THEN
               RAISE NO_TIPO_FONDO;
            END IF;
            CLOSE TIPO_FONDO;
            SELECT SYSDATE INTO F_EJECUCION FROM SYS.DUAL;
            SELECT SYSDATE INTO SAL.SAL_FEC FROM SYS.DUAL;
            UPDATE ORDENES_RECAUDO
            SET    ORR_ESTADO = 'APR'
            WHERE  ORR_OFO_SUC_CODIGO = R_OFO.OFO_SUC_CODIGO
            AND    ORR_OFO_CONSECUTIVO = R_OFO.OFO_CONSECUTIVO;
            IF R_OFO.OFO_TTO_TOF_CODIGO = 'INC' THEN
               IF TF.FON_TIPO_ADMINISTRACION != 'A' AND TF.FON_CAPITAL_PRIVADO = 'N' THEN
                  P_ORDENES_FONDOS.INSERTAR_MOVIMIENTO_CORREDORES(R_OFO.OFO_CFO_CCC_CLI_PER_NUM_IDEN
                                                                 ,R_OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO
                                                                 ,R_OFO.OFO_CFO_CCC_NUMERO_CUENTA
                                                                 ,R_OFO.OFO_MONTO
                                                                 ,R_OFO.OFO_CONSECUTIVO
                                                                 ,R_OFO.OFO_SUC_CODIGO
                                                                 ,'INC');
          END IF;

          IF R_OFO.OFO_AEFI_CONSECUTIVO IS NOT NULL THEN
              P_ORDENES_FONDOS.INSERT_MVTO_CORREDORES_ESPECIE(R_OFO.OFO_CFO_CCC_CLI_PER_NUM_IDEN
                                                              ,R_OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO
                                                              ,R_OFO.OFO_CFO_CCC_NUMERO_CUENTA
                                                              ,R_OFO.OFO_MONTO
                                                              ,R_OFO.OFO_CONSECUTIVO
                                                              ,R_OFO.OFO_SUC_CODIGO
                                                              ,'INC');

               END IF;
            END IF;

            -- INICIO OMORA CUENTA UNICA C3
            IF P_ORR_CONSECUTIVO IS NOT NULL AND P_ORR_SUC_CODIGO IS NOT NULL AND P_ORR_NEG_CONSECUTIVO IS NOT NULL AND
               P_ORR_TPA_MNEMONICO = 'TRB' AND P_ORR_COT_MNEMONICO IS NULL AND NVL(P_ORR_CONFIRMADA_BANCOS, 'N') = 'N' THEN
                UPDATE ORDENES_RECAUDO
                   SET ORR_MOTEFO_PENDIENTE = 'S'
                 WHERE ORR_CONSECUTIVO = P_ORR_CONSECUTIVO
                   AND ORR_SUC_CODIGO = P_ORR_SUC_CODIGO
                   AND ORR_NEG_CONSECUTIVO = P_ORR_NEG_CONSECUTIVO;
            ELSE
                P_ORDENES_FONDOS.MOVIMIENTO_BANCARIO(P_OFO_SUC_CODIGO             => R_OFO.OFO_SUC_CODIGO
                                                    ,P_OFO_CONSECUTIVO            => R_OFO.OFO_CONSECUTIVO
                                                    ,P_OFO_CFO_FON_CODIGO         => R_OFO.OFO_CFO_FON_CODIGO
                                                    ,P_OFO_TTO_TOF_CODIGO         => R_OFO.OFO_TTO_TOF_CODIGO
                                                    ,P_EXC                        => P_EXC
                                                    ,P_TIPO                       => 'R'
                                                    ,P_COMPARTIMENTO_B            => P_COMPARTIMENTO
                                                    ,P_FON_PADRE_COMPARTIMENTO_B  => P_FON_PADRE_COMPARTIMENTO
                                                    ,P_ESTADO                     => 'APR'
                                                    ,P_OFO_CANAL                  => R_OFO.OFO_CNL_CONSECUTIVO
                                                    ,P_CONPENSA_APT               => P_CONPENSA_APT); --WGONZALEZ VAGTUD944-3
            END IF;
            -- FIN OMORA CUENTA UNICA C3

            P_ORDENES_FONDOS.ABONO_CARGO_CUENTA(R_OFO.OFO_SUC_CODIGO
                                               ,R_OFO.OFO_CONSECUTIVO
                                               ,R_OFO.OFO_CFO_CCC_CLI_PER_NUM_IDEN
                                               ,R_OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO
                                               ,R_OFO.OFO_CFO_CCC_NUMERO_CUENTA
                                               ,R_OFO.OFO_CFO_FON_CODIGO
                                               ,R_OFO.OFO_CFO_CODIGO
                                               ,P_EXC
                                               ,'C'
                                               ,'INC');
            UPDATE ORDENES_FONDOS
            SET    OFO_FECHA_EJECUCION = F_EJECUCION
                  ,OFO_EOF_CODIGO = 'CON'
            WHERE  OFO_SUC_CODIGO = R_OFO.OFO_SUC_CODIGO
            AND    OFO_CONSECUTIVO = R_OFO.OFO_CONSECUTIVO;
            /*
            **
            ** RETIRO TOTAL
            **
            */
         ELSIF R_OFO.OFO_TTO_TOF_CODIGO = 'RT' THEN
            OPEN TIPO_FONDO;
            FETCH TIPO_FONDO INTO TF;
            IF (TIPO_FONDO%NOTFOUND) THEN
               RAISE NO_TIPO_FONDO;
            END IF;
            CLOSE TIPO_FONDO;
            SALDO_RETIROS := 0;
            OPEN CANT_ORDEN1;
            FETCH CANT_ORDEN1 INTO SALDO_RETIROS;
            CLOSE CANT_ORDEN1;
            SALDO_INGRESOS := 0;
            OPEN CANT_ORDEN2;
            FETCH CANT_ORDEN2 INTO SALDO_INGRESOS;
            CLOSE CANT_ORDEN2;
            SAL.SAL_INV := (NVL(SAL.SAL_INV,0) + NVL(SALDO_INGRESOS,0)) - NVL(SALDO_RETIROS,0);
            IF SAL.SAL_INV <= 0  THEN
               RAISE SALDO_INSUFICIENTE;
            ELSE
               IF TF.FON_TIPO = 'A' AND
                  TF.FON_BMO_MNEMONICO = 'PESOS' THEN
                  MONTO_ORDENES:= P_ORDENES_FONDOS.MONTO_ORDENES_PAGO(R_OFO.OFO_SUC_CODIGO
                                                                     ,R_OFO.OFO_CONSECUTIVO
                                                                     ,'A');
                  MONTO_ANTICIPO := NVL(MONTO_ORDENES,0);
                  P_ORDENES_FONDOS.APROBAR_ORDENES_PAGO(R_OFO.OFO_SUC_CODIGO, R_OFO.OFO_CONSECUTIVO,'RT',P_T0);

                  IF V_DIAS_PAGO > 0 AND TRUNC(R_OFO.OFO_FECHA_CUMPLIMIENTO) > TRUNC(R_OFO.OFO_FECHA_EJECUCION) THEN
                     NULL;
                  ELSE
                     P_ORDENES_FONDOS.MOVIMIENTO_BANCARIO(P_OFO_SUC_CODIGO               => R_OFO.OFO_SUC_CODIGO
                                                         ,P_OFO_CONSECUTIVO              => R_OFO.OFO_CONSECUTIVO
                                                         ,P_OFO_CFO_FON_CODIGO           => R_OFO.OFO_CFO_FON_CODIGO
                                                         ,P_OFO_TTO_TOF_CODIGO           => R_OFO.OFO_TTO_TOF_CODIGO
                                                         ,P_EXC                          => P_EXC
                                                         ,P_TIPO                         => 'P'
                                                         ,P_COMPARTIMENTO_B              => P_COMPARTIMENTO
                                                         ,P_FON_PADRE_COMPARTIMENTO_B    => P_FON_PADRE_COMPARTIMENTO
                                                         ,P_ESTADO                       => 'APR'
                                                         ,P_OFO_CANAL                    => R_OFO.OFO_CNL_CONSECUTIVO);

                     /* Verifica si el retiro total es un traslado entre fondos. Si es asi no se inserta movimiento
                        en MOVIMIENTOS_CARGOS_ABONO para que en la aprobacion de la noche se genere todo el monto
                        con fecha de dia siguiente */

                    OPEN C_RETIRO_TRASLADO;
                    FETCH C_RETIRO_TRASLADO INTO TRASLADO;
                    CLOSE C_RETIRO_TRASLADO;

                    IF NVL(TRASLADO,' ') = ' ' THEN
                       P_ORDENES_FONDOS.ABONO_CARGO_CUENTA(R_OFO.OFO_SUC_CODIGO
                                                          ,R_OFO.OFO_CONSECUTIVO
                                                          ,R_OFO.OFO_CFO_CCC_cLI_PER_NUM_IDEN
                                                          ,R_OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO
                                                          ,R_OFO.OFO_CFO_CCC_NUMERO_CUENTA
                                                          ,R_OFO.OFO_CFO_FON_CODIGO
                                                          ,R_OFO.OFO_CFO_CODIGO
                                                          ,P_EXC
                                                          ,'A'
                                                          ,'RT');
                    END IF;
                 END IF;
               END IF;
            END IF;
            IF TF.FON_BMO_MNEMONICO = 'PESOS' THEN
               IF P_T0 = 'S' THEN
                  IF NVL(R_OFO.OFO_MONTO_ANTICIPO,0) > 0 THEN
                     IF TF.FON_TIPO_ADMINISTRACION != 'A' THEN
                        IF V_DIAS_PAGO > 0 AND TRUNC(R_OFO.OFO_FECHA_CUMPLIMIENTO) > TRUNC(R_OFO.OFO_FECHA_EJECUCION) THEN
                           NULL;
                        ELSE
                           P_ORDENES_FONDOS.INSERTAR_MOVIMIENTO_CORREDORES(R_OFO.OFO_CFO_CCC_CLI_PER_NUM_IDEN
                                                                          ,R_OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO
                                                                          ,R_OFO.OFO_CFO_CCC_NUMERO_CUENTA
                                                                          ,R_OFO.OFO_MONTO_ANTICIPO
                                                                          ,R_OFO.OFO_CONSECUTIVO
                                                                          ,R_OFO.OFO_SUC_CODIGO
                                                                          ,'RT');
                        END IF;
                     END IF;
                  END IF;
               ELSE
                  IF TF.FON_TIPO_ADMINISTRACION != 'A' THEN
                     IF V_DIAS_PAGO > 0 AND TRUNC(R_OFO.OFO_FECHA_CUMPLIMIENTO) > TRUNC(R_OFO.OFO_FECHA_EJECUCION) THEN
                        NULL;
                     ELSE
                        P_ORDENES_FONDOS.INSERTAR_MOVIMIENTO_CORREDORES(R_OFO.OFO_CFO_CCC_CLI_PER_NUM_IDEN
                                                                       ,R_OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO
                                                                       ,R_OFO.OFO_CFO_CCC_NUMERO_CUENTA
                                                                       ,R_OFO.OFO_MONTO
                                                                       ,R_OFO.OFO_CONSECUTIVO
                                                                       ,R_OFO.OFO_SUC_CODIGO
                                                                       ,'RT');
                     END IF;
                  END IF;
               END IF;
            END IF;
            UPDATE ORDENES_FONDOS
            SET    OFO_EOF_CODIGO = 'CON'
                  ,OFO_MONTO_ANTICIPO = MONTO_ANTICIPO
            WHERE  OFO_SUC_CODIGO = P_OFO_SUC_CODIGO
            AND    OFO_CONSECUTIVO = P_OFO_CONSECUTIVO;
            /*
            **
            ** RETIRO PARCIAL
            **
            */
         ELSIF R_OFO.OFO_TTO_TOF_CODIGO = 'RP'  THEN
            /*
            ** Una vez se obtiene el saldo de inversion. Se calcula el
            ** porcentaje equivalente del monto a retirar y se efectua
            ** un descuento proporcional para cada uno de los saldos de
            ** capital, rendimientos y retencion en la fuente.
            ** Teniendo en cuenta el ajuste al peso de la retencion.
            */
            OPEN TIPO_FONDO;
            FETCH TIPO_FONDO INTO TF;
            IF (TIPO_FONDO%NOTFOUND) THEN
               RAISE NO_TIPO_FONDO;
            END IF;
            CLOSE TIPO_FONDO;
            SALDO_RETIROS := 0;
            OPEN CANT_ORDEN1;
            FETCH CANT_ORDEN1 INTO SALDO_RETIROS;
            CLOSE CANT_ORDEN1;
            SALDO_RETIROS := NVL(SALDO_RETIROS,0)-R_OFO.OFO_MONTO;
            SALDO_INGRESOS := 0;
            OPEN CANT_ORDEN2;
            FETCH CANT_ORDEN2 INTO SALDO_INGRESOS;
            CLOSE CANT_ORDEN2;
            SAL.SAL_INV := (NVL(SAL.SAL_INV,0)+NVL(SALDO_INGRESOS,0))-NVL(SALDO_RETIROS,0);
            RP_PRC := R_OFO.OFO_MONTO / SAL.SAL_INV;
            IF (R_OFO.OFO_MONTO > SAL.SAL_INV) THEN
               RAISE SALDO_INSUFICIENTE;
            ELSE
              IF TF.FON_TIPO = 'A' AND
                 TF.FON_BMO_MNEMONICO = 'PESOS' THEN
                 P_ORDENES_FONDOS.APROBAR_ORDENES_PAGO(R_OFO.OFO_SUC_CODIGO, R_OFO.OFO_CONSECUTIVO,'RP',P_T0);
                 IF V_DIAS_PAGO > 0 AND TRUNC(R_OFO.OFO_FECHA_CUMPLIMIENTO) > TRUNC(R_OFO.OFO_FECHA_EJECUCION) THEN
                    NULL;
                 ELSE
                     P_ORDENES_FONDOS.MOVIMIENTO_BANCARIO(P_OFO_SUC_CODIGO             => R_OFO.OFO_SUC_CODIGO
                                                         ,P_OFO_CONSECUTIVO            => R_OFO.OFO_CONSECUTIVO
                                                         ,P_OFO_CFO_FON_CODIGO         => R_OFO.OFO_CFO_FON_CODIGO
                                                         ,P_OFO_TTO_TOF_CODIGO         => R_OFO.OFO_TTO_TOF_CODIGO
                                                         ,P_EXC                        => P_EXC
                                                         ,P_TIPO                       => 'P'
                                                         ,P_COMPARTIMENTO_B            => P_COMPARTIMENTO
                                                         ,P_FON_PADRE_COMPARTIMENTO_B  => P_FON_PADRE_COMPARTIMENTO
                                                         ,P_ESTADO                     => 'APR'
                                                         ,P_OFO_CANAL                  => R_OFO.OFO_CNL_CONSECUTIVO
                                                         ,P_CONPENSA_APT               => P_CONPENSA_APT); --WGONZALEZ VAGTUD944-3
                     P_ORDENES_FONDOS.ABONO_CARGO_CUENTA(R_OFO.OFO_SUC_CODIGO
                                                        ,R_OFO.OFO_CONSECUTIVO
                                                        ,R_OFO.OFO_CFO_CCC_CLI_PER_NUM_IDEN
                                                        ,R_OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO
                                                        ,R_OFO.OFO_CFO_CCC_NUMERO_CUENTA
                                                        ,R_OFO.OFO_CFO_FON_CODIGO
                                                        ,R_OFO.OFO_CFO_CODIGO
                                                        ,P_EXC
                                                        ,'A'
                                                        ,'RP');
                 END IF;
              END IF;
            END IF;
            IF TF.FON_BMO_MNEMONICO = 'PESOS' THEN
               IF TF.FON_TIPO_ADMINISTRACION != 'A' THEN
                  IF V_DIAS_PAGO > 0 AND TRUNC(R_OFO.OFO_FECHA_CUMPLIMIENTO) > TRUNC(R_OFO.OFO_FECHA_EJECUCION) THEN
                     NULL;
                  ELSE
                      P_ORDENES_FONDOS.INSERTAR_MOVIMIENTO_CORREDORES(R_OFO.OFO_CFO_CCC_CLI_PER_NUM_IDEN
                                                                     ,R_OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO
                                                                     ,R_OFO.OFO_CFO_CCC_NUMERO_CUENTA
                                                                     ,R_OFO.OFO_MONTO
                                                                     ,R_OFO.OFO_CONSECUTIVO
                                                                     ,R_OFO.OFO_SUC_CODIGO
                                                                     ,'RP');
                  END IF;
               END IF;
            END IF;
            UPDATE ORDENES_FONDOS
            SET    OFO_EOF_CODIGO = 'CON'
            WHERE  OFO_SUC_CODIGO = P_OFO_SUC_CODIGO
            AND    OFO_CONSECUTIVO = P_OFO_CONSECUTIVO;
         /*
         **
         ** PAGO DE FLUJO FONDOS CERRADOS O ESCALONADOS
         **
         */
         ELSIF R_OFO.OFO_TTO_TOF_CODIGO = 'PFL' THEN
            OPEN TIPO_FONDO;
            FETCH TIPO_FONDO INTO TF;
            IF (TIPO_FONDO%NOTFOUND) THEN
               RAISE NO_TIPO_FONDO;
            END IF;
            CLOSE TIPO_FONDO;
            -- TODO SE EJECUTAN UNA VEZ CONOCIDO EL  VALOR DE LA UNIDAD DEL FONDO
            SELECT SYSDATE INTO F_EJECUCION FROM SYS.DUAL;
            UPDATE ORDENES_FONDOS
            SET    OFO_EOF_CODIGO = 'CON'
                  ,OFO_FECHA_EJECUCION = F_EJECUCION
            WHERE  OFO_SUC_CODIGO = P_OFO_SUC_CODIGO
            AND    OFO_CONSECUTIVO = P_OFO_CONSECUTIVO;
         /*
         **
         ** Retiro pro retefuente no praciticada
         **
         */
         ELSIF R_OFO.OFO_TTO_TOF_CODIGO = 'RRF'  THEN
            OPEN TIPO_FONDO;
            FETCH TIPO_FONDO INTO TF;
            IF (TIPO_FONDO%NOTFOUND) THEN
               RAISE NO_TIPO_FONDO;
            END IF;
            CLOSE TIPO_FONDO;
            IF (MONTO_ORDEN > SAL.SAL_CAP) THEN
               RAISE SALDO_INSUFICIENTE;
            END IF;
            SELECT SYSDATE INTO F_EJECUCION FROM SYS.DUAL;
            UPDATE ORDENES_FONDOS
            SET    OFO_EOF_CODIGO = 'CON'
                  ,OFO_FECHA_EJECUCION = F_EJECUCION
            WHERE  OFO_SUC_CODIGO = P_OFO_SUC_CODIGO
            AND    OFO_CONSECUTIVO = P_OFO_CONSECUTIVO;
         END IF;
      END IF;
      --SE HA CONFIRMADO LA ORDEN
   ELSE
      RAISE NO_CONFIRMA;
   END IF;
EXCEPTION
   WHEN NO_EXCENTO THEN
      RAISE_APPLICATION_ERROR(-20001,'No se puede determinar si la cuenta del cliente '
         ||R_OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO||'-'||R_OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO||'-'||R_OFO.OFO_CFO_CCC_NUMERO_CUENTA
         || ' es excenta de GMF');
   WHEN NO_HORA_LIMITE THEN
      RAISE_APPLICATION_ERROR(-20002,'NO EXISTE HORA LIMITE');
   WHEN FIN_HORA_LIMITE THEN
      RAISE_APPLICATION_ERROR(-20003,'LA HORA DE COLOCACION HA TERMINADO');
   WHEN YA_VALORO THEN
      RAISE_APPLICATION_ERROR(-20004,'Ya existe proceso de valorizacion para el dia no se pueden confirmar ordenes ');
   WHEN ESTADO_INACTIVO THEN
      RAISE_APPLICATION_ERROR(-20005,'La orden ' || TO_CHAR(R_OFO.OFO_CONSECUTIVO) ||' pertenece a la cuenta '
         || R_OFO.OFO_CFO_CCC_CLI_PER_NUM_IDEN || '-' || R_OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO || '-' ||TO_CHAR(R_OFO.OFO_CFO_CCC_NUMERO_CUENTA)
         || '-' || R_OFO.OFO_CFO_FON_CODIGO || '-' || TO_CHAR(R_OFO.OFO_CFO_CODIGO) || ' que se encuentra inactiva');
   WHEN NO_SALDO THEN
      RAISE_APPLICATION_ERROR(-20006,'Error: No se pueden calcular saldos.No se confirma la orden');
   WHEN NO_TIPO_FONDO THEN
      RAISE_APPLICATION_ERROR(-20007,'Error: No se determino el tipo de fondo. No se confirma la orden');
   WHEN SALDO_INSUFICIENTE THEN
      RAISE_APPLICATION_ERROR(-20008,'Saldo insuficiente.No se confirma la orden');
   WHEN NO_CONFIRMA THEN
      RAISE_APPLICATION_ERROR(-20009,'La orden no se confirma porque esta en estado diferente a Colocado '||R_OFO.OFO_EOF_CODIGO);
   WHEN DISTRIBUCION_FONDO THEN
      RAISE_APPLICATION_ERROR(-20011,'EL FONDO YA DISTRIBUYO PARA EL DIA DE HOY');
   WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20010,SQLERRM);
END CONFIRMA_ORDEN;
/***********************************************************/
PROCEDURE VERIFICA_TRANSFERENCIA(P_OFO_OFO_SUC_CODIGO           NUMBER
                                ,P_OFO_OFO_CONSECUTIVO          NUMBER
                                ,P_OFO_SUC_CODIGO               NUMBER
                                ,P_OFO_CONSECUTIVO              NUMBER
                                ,P_OFO_EOF_CODIGO               VARCHAR2
                                ,P_OFO_CFO_CCC_CLI_PER_NUM_IDEN VARCHAR2
                                ,P_TIPO IN                      VARCHAR2
                                ,P_COND OUT                     VARCHAR2) IS
   CURSOR C_ESTADO IS
      SELECT OFO_CONSECUTIVO
            ,OFO_EOF_CODIGO
      FROM   ORDENES_FONDOS
      WHERE  OFO_SUC_CODIGO = P_OFO_OFO_SUC_CODIGO
      AND    OFO_CONSECUTIVO = P_OFO_OFO_CONSECUTIVO;
   OFO1  C_ESTADO%ROWTYPE;
   CURSOR C_ESTADO1 IS
      SELECT OFO_CONSECUTIVO
            ,OFO_EOF_CODIGO
      FROM   ORDENES_FONDOS
      WHERE  OFO_OFO_SUC_CODIGO = P_OFO_SUC_CODIGO
      AND    OFO_OFO_CONSECUTIVO = P_OFO_CONSECUTIVO;
   ESTADO VARCHAR2(3);
   NO_CONFIRMA EXCEPTION;
BEGIN
   P_COND := 'S';
   IF P_OFO_EOF_CODIGO IN ('CON','APL') THEN
      IF P_OFO_OFO_SUC_CODIGO IS NOT NULL AND
         P_OFO_OFO_CONSECUTIVO IS NOT NULL THEN
         OFO1.OFO_EOF_CODIGO := NULL;
         OPEN C_ESTADO;
         FETCH C_ESTADO INTO OFO1;
         CLOSE C_ESTADO;
         IF NVL(OFO1.OFO_EOF_CODIGO,' ') = P_TIPO THEN
            RAISE NO_CONFIRMA;
            ESTADO := 'COL';
            P_COND := 'N';
         END IF;
      END IF;
      OFO1.OFO_EOF_CODIGO := NULL;
      OPEN C_ESTADO1;
      FETCH C_ESTADO1 INTO OFO1;
      CLOSE C_ESTADO1;
      IF NVL(OFO1.OFO_EOF_CODIGO,' ') = P_TIPO THEN
         RAISE NO_CONFIRMA;
         ESTADO := 'COL';
         P_COND := 'N';
      END IF;
   END IF;
EXCEPTION
   WHEN NO_CONFIRMA THEN
      RAISE_APPLICATION_ERROR(-20011,'No se puede confirmar la orden '|| TO_CHAR(P_OFO_CONSECUTIVO) || ' del cliente '
               || P_OFO_CFO_CCC_CLI_PER_NUM_IDEN|| ' porque la orden proviene de una transferencia '
               || 'y la otra punta '|| TO_CHAR(OFO1.OFO_CONSECUTIVO)|| ' esta anulada. La orden no sera aprobada');
   WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20012,'Error en Verifica_transferencia '||SQLERRM);
END VERIFICA_TRANSFERENCIA;
/***********************************************************/
PROCEDURE INSERTAR_MOVIMIENTO_CORREDORES(IDENTIFICACION  VARCHAR2
                                        ,TIPO            VARCHAR2
                                        ,CUENTA          NUMBER
                                        ,MONTO           NUMBER
                                        ,ORDEN_FONDOS    NUMBER
                                        ,SUCURSAL        NUMBER
                                        ,TIPO_MOVIMIENTO VARCHAR2)IS

BEGIN
  IF TIPO_MOVIMIENTO IN ('RT','RP') THEN
     INSERT INTO MOVIMIENTOS_CUENTA_CORREDORES
              (MCC_CONSECUTIVO
              ,MCC_CCC_CLI_PER_NUM_IDEN
              ,MCC_CCC_CLI_PER_TID_CODIGO
              ,MCC_CCC_NUMERO_CUENTA
              ,MCC_FECHA
              ,MCC_TMC_MNEMONICO
              ,MCC_MONTO
              ,MCC_MONTO_A_PLAZO
              ,MCC_MONTO_A_CONTADO
              ,MCC_MONTO_ADMON_VALORES
              ,MCC_OFO_SUC_CODIGO
              ,MCC_OFO_CONSECUTIVO)
     VALUES
              (MCC_SEQ.NEXTVAL
              ,IDENTIFICACION
              ,TIPO
              ,CUENTA
              ,SYSDATE
              ,DECODE(TIPO_MOVIMIENTO
                     ,'RT','ARTF'
                     ,'RP','ARPF')
              ,DECODE(TIPO_MOVIMIENTO
                     ,'RT',MONTO
                     ,'RP',MONTO)
              ,0
              ,0
              ,0
              ,SUCURSAL
              ,ORDEN_FONDOS);

     VERIF_ABONO_CARGO_CUENTA (IDENTIFICACION
                              ,TIPO
                              ,CUENTA
                              ,MONTO
                              ,ORDEN_FONDOS
                              ,SUCURSAL
                              ,TIPO_MOVIMIENTO);
  ELSIF TIPO_MOVIMIENTO IN ('ING','INC') THEN
     VERIF_ABONO_CARGO_CUENTA (IDENTIFICACION
                             ,TIPO
                             ,CUENTA
                             ,MONTO
                             ,ORDEN_FONDOS
                             ,SUCURSAL
                             ,TIPO_MOVIMIENTO);

     INSERT INTO MOVIMIENTOS_CUENTA_CORREDORES
              (MCC_CONSECUTIVO
              ,MCC_CCC_CLI_PER_NUM_IDEN
              ,MCC_CCC_CLI_PER_TID_CODIGO
              ,MCC_CCC_NUMERO_CUENTA
              ,MCC_FECHA
              ,MCC_TMC_MNEMONICO
              ,MCC_MONTO
              ,MCC_MONTO_A_PLAZO
              ,MCC_MONTO_A_CONTADO
              ,MCC_MONTO_ADMON_VALORES
              ,MCC_OFO_SUC_CODIGO
              ,MCC_OFO_CONSECUTIVO)
     VALUES
              (MCC_SEQ.NEXTVAL
              ,IDENTIFICACION
              ,TIPO
              ,CUENTA
              ,SYSDATE
              ,DECODE(TIPO_MOVIMIENTO
                     ,'ING','CIGF'
                     ,'INC','CICF')
              ,DECODE(TIPO_MOVIMIENTO
                     ,'ING',-MONTO
                     ,'INC',-MONTO)
              ,0
              ,0
              ,0
              ,SUCURSAL
              ,ORDEN_FONDOS);
  END IF;
EXCEPTION
   WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20013,'Error en INSERTAR_MOVIMIENTO_CORREDORES '||SQLERRM);
END INSERTAR_MOVIMIENTO_CORREDORES;
PROCEDURE INSERTAR_MOVIMIENTO_CORREDORES(P_OFO_CFO_CCC_CLI_PER_NUM_IDEN    VARCHAR2
                                        ,P_OFO_CFO_CCC_CLI_PER_TID_CODI    VARCHAR2
                                        ,P_OFO_CFO_CCC_NUMERO_CUENTA       NUMBER
                                        ,P_OFO_CFO_FON_CODIGO              VARCHAR2
                                        ,P_OFO_CFO_CODIGO                  NUMBER
                                        ,MONTO                             NUMBER
                                        ,ORDEN_FONDOS                      NUMBER
                                        ,SUCURSAL                          NUMBER
                                        ,FECHA                             DATE
                                        ,TIPO_MOVIMIENTO                   VARCHAR2) IS
   CURSOR MCFASOCIADO IS
      SELECT MAX(MCF_CONSECUTIVO)
      FROM   MOVIMIENTOS_CUENTAS_FONDOS
      WHERE MCF_FECHA                       = FECHA
      AND   MCF_CFO_CCC_CLI_PER_NUM_IDEN    = P_OFO_CFO_CCC_CLI_PER_NUM_IDEN
      AND   MCF_CFO_CCC_CLI_PER_TID_CODIGO  = P_OFO_CFO_CCC_CLI_PER_TID_CODI
      AND   MCF_CFO_CCC_NUMERO_CUENTA       = P_OFO_CFO_CCC_NUMERO_CUENTA
      AND   MCF_CFO_FON_CODIGO              = P_OFO_CFO_FON_CODIGO
      AND   MCF_CFO_CODIGO                  = P_OFO_CFO_CODIGO;
   MCFCONS   NUMBER;
BEGIN
   OPEN MCFASOCIADO;
   FETCH MCFASOCIADO INTO MCFCONS;
   IF MCFASOCIADO%NOTFOUND THEN
      MCFCONS := NULL;
   END IF;
   VERIF_ABONO_CARGO_CUENTA_PENAL (P_OFO_CFO_CCC_CLI_PER_NUM_IDEN
                                   ,P_OFO_CFO_CCC_CLI_PER_TID_CODI
                                   ,P_OFO_CFO_CCC_NUMERO_CUENTA
                                   ,MONTO
                                   ,ORDEN_FONDOS
                                   ,SUCURSAL
                                  ,TIPO_MOVIMIENTO);
   INSERT INTO MOVIMIENTOS_CUENTA_CORREDORES
              (MCC_CONSECUTIVO
              ,MCC_CCC_CLI_PER_NUM_IDEN
              ,MCC_CCC_CLI_PER_TID_CODIGO
              ,MCC_CCC_NUMERO_CUENTA
              ,MCC_FECHA
              ,MCC_TMC_MNEMONICO
              ,MCC_MONTO
              ,MCC_MONTO_A_PLAZO
              ,MCC_MONTO_A_CONTADO
              ,MCC_MONTO_ADMON_VALORES
              ,MCC_MCF_CONSECUTIVO
              ,MCC_OFO_SUC_CODIGO
              ,MCC_OFO_CONSECUTIVO)
   VALUES (MCC_SEQ.NEXTVAL
             ,P_OFO_CFO_CCC_CLI_PER_NUM_IDEN
             ,P_OFO_CFO_CCC_CLI_PER_TID_CODI
             ,P_OFO_CFO_CCC_NUMERO_CUENTA
             ,FECHA
             ,DECODE(TIPO_MOVIMIENTO,
                     'RT','ARTF',
                     'RP','ARPF')
             ,DECODE(TIPO_MOVIMIENTO,
                     'RT',MONTO,
                     'RP',MONTO)
             ,0
             ,0
             ,0
             ,MCFCONS
             ,SUCURSAL
             ,ORDEN_FONDOS);
   -- BUSCA REGISTRO YA INSERTADOS Y LES ACTUALIZA LAS LLEVE DE CD MCF
   UPDATE MOVIMIENTOS_CUENTA_CORREDORES
      SET MCC_MCF_CONSECUTIVO = MCFCONS
    WHERE MCC_OFO_SUC_CODIGO     = SUCURSAL
      AND MCC_OFO_CONSECUTIVO    = ORDEN_FONDOS;
EXCEPTION
   WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20015,'Error en INSERTAR_MOVIMIENTO_CORREDORES '||SQLERRM);
END INSERTAR_MOVIMIENTO_CORREDORES;
/***********************************************************/
PROCEDURE MOVIMIENTO_BANCARIO (P_OFO_SUC_CODIGO             NUMBER
                              ,P_OFO_CONSECUTIVO            NUMBER
                              ,P_OFO_CFO_FON_CODIGO         VARCHAR2
                              ,P_OFO_TTO_TOF_CODIGO         VARCHAR2
                              ,P_EXC                        VARCHAR2
                              ,P_TIPO                       VARCHAR2
                              ,P_LLAMADO_FF_FG              VARCHAR2 DEFAULT NULL
                              ,P_FECHA_EJECUCION            DATE     DEFAULT NULL
                              ,P_COMPARTIMENTO_B            VARCHAR2 DEFAULT NULL
                              ,P_FON_PADRE_COMPARTIMENTO_B  VARCHAR2 DEFAULT NULL
                              ,P_ESTADO                     VARCHAR2
                              ,P_OFO_CANAL                  VARCHAR2 DEFAULT NULL
                              ,P_CONPENSA_APT               VARCHAR2 DEFAULT NULL) IS

   -- INICIO OMORA CUENTA UNICA
   CURSOR C_FONDO(P_FON_CODIGO VARCHAR2) IS
   SELECT FON_TIPO_ADMINISTRACION,
          FON_CAPITAL_PRIVADO
     FROM FONDOS F
    WHERE F.FON_CODIGO = P_FON_CODIGO;
   P_FON_TIPO_ADMINISTRACION FONDOS.FON_TIPO_ADMINISTRACION%TYPE;
   P_FON_CAPITAL_PRIVADO     FONDOS.FON_CAPITAL_PRIVADO%TYPE;
   -- FIN OMORA CUENTA UNICA

   CURSOR C_ORDENES_RECAUDO IS
      SELECT ORR_TPA_MNEMONICO
            ,ORR_MONTO
            ,ORR_CBA_BAN_CODIGO
            ,ORR_CBA_NUMERO_CUENTA -- SORTIZ DAV.COM
            ,ORR_SUC_CODIGO
      ,ORR_CCC_CLI_PER_TID_CODIGO --WGONZALEZ VAGTUD944-3
            ,ORR_CCC_NUMERO_CUENTA      --WGONZALEZ VAGTUD944-3
            ,ORR_CCC_CLI_PER_NUM_IDEN   --WGONZALEZ VAGTUD944-3
      ,ORR_MANTENER_CTA_BANCARIA  -- OMORA
      FROM   ORDENES_RECAUDO
      WHERE  ORR_OFO_SUC_CODIGO = P_OFO_SUC_CODIGO
      AND    ORR_OFO_CONSECUTIVO = P_OFO_CONSECUTIVO
      AND    ORR_ESTADO = P_ESTADO;
   ORR1   C_ORDENES_RECAUDO%ROWTYPE;

   CURSOR C_ORDENES_PAGO(P_TIPO_ORDEN VARCHAR2) IS
      SELECT ODP_TPA_MNEMONICO
            ,ODP_MONTO_ORDEN
            ,ODP_BAN_CODIGO
            ,ODP_NUM_CUENTA_CONSIGNAR
            ,ODP_CCC_CLI_PER_NUM_IDEN
            ,ODP_CCC_CLI_PER_TID_CODIGO
            ,ODP_CCC_NUMERO_CUENTA
            ,ODP_SUC_CODIGO
            ,ODP_NEG_CONSECUTIVO
            ,ODP_CONSECUTIVO
            ,ODP_PAGAR_A
            ,ODP_FECHA_EJECUCION
            ,ODP_OFO_CONSECUTIVO
            ,ODP_ANTICIPO
      FROM   ORDENES_DE_PAGO
      WHERE  ODP_OFO_SUC_CODIGO = P_OFO_SUC_CODIGO
      AND    ODP_OFO_CONSECUTIVO = P_OFO_CONSECUTIVO
      AND    ODP_ESTADO = P_ESTADO
      AND    ODP_TPA_MNEMONICO != 'TCC'
      -- SE EXCLUYEN LAS ORDENES DE PAGO DE OMNIBUS
      AND NOT EXISTS
          (SELECT 1
             FROM ORDENES_FONDOS OFO
            WHERE OFO.OFO_CONSECUTIVO = ODP_OFO_CONSECUTIVO
              AND OFO.OFO_SUC_CODIGO  = ODP_OFO_SUC_CODIGO
              AND OFO.OFO_TTO_TIT_CODIGO = 'ABO'
              AND OFO.OFO_CFO_FON_CODIGO IN
                     (SELECT PF.PFO_FON_CODIGO FROM PARAMETROS_FONDOS PF WHERE PF.PFO_PAR_CODIGO = 115))

      AND    ((NVL(P_LLAMADO_FF_FG,'N') = 'N'
               AND ((P_TIPO_ORDEN = 'RT' AND NVL(ODP_ANTICIPO,'S') = 'S') OR (P_TIPO_ORDEN != 'RT')))
           OR    (NVL(P_LLAMADO_FF_FG,'N') = 'S'
               AND ((P_ESTADO = 'ANU' and ODP_ODP_CONSECUTIVO IS NULL) OR (P_ESTADO != 'ANU' AND ODP_ANTICIPO IS NULL)))
           OR (P_TIPO_ORDEN = 'RT' AND ODP_TPA_MNEMONICO = 'TRB') -- OMORA CUENTA UNICA
           OR  (ODP_OFO_CONSECUTIVO IN (SELECT OFO_CONSECUTIVO
                                        FROM   ORDENES_FONDOS
                                        WHERE  OFO_TTO_TOF_CODIGO = 'RT'
                                        AND    TRUNC(OFO_FECHA_CUMPLIMIENTO) > TRUNC(OFO_FECHA_EJECUCION)
                                        AND    OFO_CFO_FON_CODIGO IN(SELECT PFO_FON_CODIGO
                                                                     FROM   PARAMETROS_FONDOS
                                                                     WHERE  PFO_PAR_CODIGO = 96
                                                                     AND    NVL(PFO_RANGO_MIN_NUMBER,0) > 0)))
              );
   ODP1   C_ORDENES_PAGO%ROWTYPE;

   CURSOR EXCENTO IS
      SELECT CCC_EXENTA_GMF
            ,CCC_TUC_MNEMONICO
            ,TUC_DESCRIPCION
      FROM   CUENTAS_CLIENTE_CORREDORES
            ,TIPOS_USOS_CUENTAS_BANCOS
      WHERE  CCC_CLI_PER_NUM_IDEN = ODP1.ODP_CCC_CLI_PER_NUM_IDEN
      AND    CCC_CLI_PER_TID_CODIGO = ODP1.ODP_CCC_CLI_PER_TID_CODIGO
      AND    CCC_NUMERO_CUENTA = ODP1.ODP_CCC_NUMERO_CUENTA
      AND    CCC_TUC_MNEMONICO = TUC_MNEMONICO (+);
   CCC1   EXCENTO%ROWTYPE;
   EXC VARCHAR2(1);

   CURSOR C_CUENTA_BANCARIA_TRB(P_BANCO NUMBER,
                                P_CANAL_DAVIVIENDA VARCHAR2 DEFAULT NULL) IS
      SELECT DISTINCT CBF_BAN_CODIGO
            ,CBF_NUMERO_CUENTA
      FROM   CUENTAS_BANCARIAS_FONDOS
      WHERE  CBF_BAN_CODIGO = P_BANCO
      AND    ((NVL(P_COMPARTIMENTO_B,'N') = 'N'
               AND CBF_FON_CODIGO = P_OFO_CFO_FON_CODIGO)
               OR (NVL(P_COMPARTIMENTO_B,'N')= 'S'
               AND CBF_FON_CODIGO = (SELECT pfo_rango_min_char
                                     FROM   PARAMETROS_FONDOS
                                     WHERE  PFO_FON_CODIGO = P_OFO_CFO_FON_CODIGO
                                     AND    PFO_PAR_CODIGO IN (71) ))
                OR (NVL(P_COMPARTIMENTO_B,'N')= 'N' --CUENTAS PARTICIPACIONES FCP
                AND CBF_FON_CODIGO = (SELECT PFO_RANGO_MIN_CHAR
                                      FROM   PARAMETROS_FONDOS
                                      WHERE  PFO_FON_CODIGO = P_OFO_CFO_FON_CODIGO
                                      AND    PFO_PAR_CODIGO IN (119) ))                    )
      AND    CBF_GIRA_RECAUDA_TRB = 'S'
      AND    NVL(CBF_DAVICASH, 'N') = 'N'
      AND    CBF_ESTADO = 'A'
      AND    ((NVL(P_CANAL_DAVIVIENDA,'N') = 'N' AND NVL(CBF_IND_CANAL, 'N') = 'N')
               OR (P_CANAL_DAVIVIENDA = 'S' AND CBF_IND_CANAL = 'S'));
   CBF1   C_CUENTA_BANCARIA_TRB%ROWTYPE;

   -- OMORA CUENTA UNICA
   CURSOR C_CUENTA_BANCARIA_TRB_FICS(P_BANCO NUMBER,
                                     P_CANAL_DAVIVIENDA VARCHAR2 DEFAULT NULL) IS
      SELECT DISTINCT CBF_BAN_CODIGO
            ,CBF_NUMERO_CUENTA
      FROM   CUENTAS_BANCARIAS_FONDOS
            ,CUENTAS_BANCARIAS_CORREDORES
      WHERE CBF_NUMERO_CUENTA = CBA_NUMERO_CUENTA
      AND CBF_BAN_CODIGO = CBA_BAN_CODIGO
      AND CBF_BAN_CODIGO = P_BANCO
      AND    ((NVL(P_COMPARTIMENTO_B,'N') = 'N'
               AND CBF_FON_CODIGO = P_OFO_CFO_FON_CODIGO)
               OR (NVL(P_COMPARTIMENTO_B,'N')= 'S'
               AND CBF_FON_CODIGO = (SELECT pfo_rango_min_char
                                     FROM   PARAMETROS_FONDOS
                                     WHERE  PFO_FON_CODIGO = P_OFO_CFO_FON_CODIGO
                                     AND    PFO_PAR_CODIGO IN (71) ))
                OR (NVL(P_COMPARTIMENTO_B,'N')= 'N' --CUENTAS PARTICIPACIONES FCP
                AND CBF_FON_CODIGO = (SELECT PFO_RANGO_MIN_CHAR
                                      FROM   PARAMETROS_FONDOS
                                      WHERE  PFO_FON_CODIGO = P_OFO_CFO_FON_CODIGO
                                      AND    PFO_PAR_CODIGO IN (119) ))                    )
      AND    CBF_GIRA_RECAUDA_TRB = 'S'
      AND    NVL(CBF_DAVICASH, 'N') = 'N'
      AND    CBF_ESTADO = 'A'
      AND NVL(CBF_IND_CANAL, 'N') = 'N'
      -- AND CBF_COMPENSA = 'S' -- NO APLICA!!
      AND CBA_TUC_MNEMONICO = 'APFV'
      AND CBF_TIPO_CUENTA = 'A';
   -- OMORA CUENTA UNICA

   CURSOR C_CUENTA_BANCARIA_PSE_R(P_BANCO NUMBER) IS
      SELECT DISTINCT CBF_BAN_CODIGO
            ,CBF_NUMERO_CUENTA
      FROM   CUENTAS_BANCARIAS_FONDOS
      WHERE  CBF_BAN_CODIGO = P_BANCO
      AND    ((NVL(P_COMPARTIMENTO_B,'N') = 'N' AND
               CBF_FON_CODIGO = P_OFO_CFO_FON_CODIGO)
              OR
               (NVL(P_COMPARTIMENTO_B,'N')= 'S' AND
                CBF_FON_CODIGO = (SELECT pfo_rango_min_char
                                   FROM PARAMETROS_FONDOS
                                  WHERE pfo_fon_codigo = P_OFO_CFO_FON_CODIGO
                                    AND pfo_par_codigo = 71))

               OR -- CUENTAS PARTICIPACIONES FCP
               (NVL(P_COMPARTIMENTO_B,'N')= 'N' AND
                CBF_FON_CODIGO = (SELECT pfo_rango_min_char
                                   FROM PARAMETROS_FONDOS
                                  WHERE pfo_fon_codigo = P_OFO_CFO_FON_CODIGO
                                    AND pfo_par_codigo = 119)))
      AND    CBF_GIRA_RECAUDA_PSE = 'S'
      AND    NVL(CBF_DAVICASH, 'N') = 'N'
      AND    CBF_ESTADO = 'A';

   CURSOR C_CUENTA_BANCARIA_PSE_G IS
      SELECT DISTINCT CBF_BAN_CODIGO
            ,CBF_NUMERO_CUENTA
      FROM   CUENTAS_BANCARIAS_FONDOS
      WHERE  ((NVL(P_COMPARTIMENTO_B,'N') = 'N' AND
               CBF_FON_CODIGO = P_OFO_CFO_FON_CODIGO)
              OR
              (NVL(P_COMPARTIMENTO_B,'N')= 'S' AND
               CBF_FON_CODIGO = (SELECT pfo_rango_min_char
                           FROM PARAMETROS_FONDOS
                          WHERE PFO_FON_CODIGO = P_OFO_CFO_FON_CODIGO
                          AND pfo_par_codigo = 71))
             OR
              (NVL(P_COMPARTIMENTO_B,'N')= 'N' AND
               CBF_FON_CODIGO = (SELECT pfo_rango_min_char
                           FROM PARAMETROS_FONDOS
                          WHERE PFO_FON_CODIGO = P_OFO_CFO_FON_CODIGO
                          AND pfo_par_codigo = 119)))
      AND    CBF_GIRA_RECAUDA_PSE = 'S'
      AND    NVL(CBF_DAVICASH, 'N') = 'N'
      AND    CBF_ESTADO = 'A';

   CURSOR C_CUENTA_BANCARIA_CEF(P_BANCO NUMBER, P_SUCURSAL NUMBER) IS
      SELECT DISTINCT CBF_BAN_CODIGO
            ,CBF_NUMERO_CUENTA
      FROM   CUENTAS_BANCARIAS_FONDOS
            ,CUENTAS_BANCARIAS_CORREDORES
            ,PARAMETROS_CUENTAS_BANCARIAS
            ,PARAMETROS_TIPOS_PAGOS
            ,FONDOS
      WHERE  CBF_BAN_CODIGO         = P_BANCO
      AND    ((NVL(P_COMPARTIMENTO_B,'N') = 'N' AND
               CBF_FON_CODIGO = P_OFO_CFO_FON_CODIGO)
              OR
              (NVL(P_COMPARTIMENTO_B,'N')= 'S' AND
        CBF_FON_CODIGO = (SELECT pfo_rango_min_char
                           FROM PARAMETROS_FONDOS
                          WHERE pfo_fon_codigo = P_OFO_CFO_FON_CODIGO
                          AND PFO_PAR_CODIGO = 71))
              OR
              (NVL(P_COMPARTIMENTO_B,'N')= 'N' AND
        CBF_FON_CODIGO = (SELECT pfo_rango_min_char
                           FROM PARAMETROS_FONDOS
                          WHERE pfo_fon_codigo = P_OFO_CFO_FON_CODIGO
                          AND pfo_par_codigo = 119)))
      AND    CBF_BAN_CODIGO = CBA_BAN_CODIGO
      AND    CBF_NUMERO_CUENTA = CBA_NUMERO_CUENTA
      AND    CBF_FON_CODIGO = FON_CODIGO
      AND    CBA_BAN_CODIGO = PBA_CBA_BAN_CODIGO
      AND    CBA_NUMERO_CUENTA = PBA_CBA_NUMERO_CUENTA
      AND    CBA_ESTADO = 'A'
      AND    PBA_PRO_MNEMONICO = FON_NPR_PRO_MNEMONICO
      AND    PTP_CBA_BAN_CODIGO = PBA_CBA_BAN_CODIGO
      AND    PTP_CBA_NUMERO_CUENTA = PBA_CBA_NUMERO_CUENTA
      AND    PBA_SUC_CODIGO = P_SUCURSAL
      AND    PBA_INDICADOR_PERSONA IN ('C','A')
      AND    NVL(CBF_DAVICASH, 'N') = 'N'
      AND    PTP_TPA_MNEMONICO = 'CEF';
   CBFCEF   C_CUENTA_BANCARIA_CEF%ROWTYPE;

   CURSOR C_CUENTA_BANCARIA_R(P_BANCO NUMBER) IS
      SELECT DISTINCT CBF_BAN_CODIGO
            ,CBF_NUMERO_CUENTA
      FROM   CUENTAS_BANCARIAS_FONDOS
      WHERE  CBF_BAN_CODIGO = P_BANCO
      AND    ((NVL(P_COMPARTIMENTO_B,'N')= 'N' AND
               CBF_FON_CODIGO = P_OFO_CFO_FON_CODIGO)
              OR
              (NVL(P_COMPARTIMENTO_B,'N')= 'S' AND
               CBF_FON_CODIGO = (SELECT pfo_rango_min_char
                           FROM PARAMETROS_FONDOS
                          WHERE pfo_fon_codigo = P_OFO_CFO_FON_CODIGO
                          AND pfo_par_codigo = 71))
               OR
              (NVL(P_COMPARTIMENTO_B,'N')= 'N' AND
               CBF_FON_CODIGO = (SELECT pfo_rango_min_char
                           FROM PARAMETROS_FONDOS
                          WHERE pfo_fon_codigo = P_OFO_CFO_FON_CODIGO
                          AND pfo_par_codigo = 119)))
      AND    CBF_RECAUDA_OTROS = 'S'
      AND    NVL(CBF_DAVICASH, 'N') = 'N'
      AND    CBF_ESTADO = 'A';
   CBFR   C_CUENTA_BANCARIA_R%ROWTYPE;

   CURSOR C_CUENTA_BANCARIA_G(P_TPA_MNEMONICO VARCHAR2) IS
      SELECT CBF_BAN_CODIGO
            ,CBF_NUMERO_CUENTA
            ,NULL MTF_FECHA
            ,NULL MTF_CONSECUTIVO
      FROM   CUENTAS_BANCARIAS_FONDOS
      WHERE  ((NVL(P_COMPARTIMENTO_B,'N')= 'N' AND
               CBF_FON_CODIGO = P_OFO_CFO_FON_CODIGO)
              OR
               (NVL(P_COMPARTIMENTO_B,'N')= 'S' AND
        CBF_FON_CODIGO = (SELECT pfo_rango_min_char
                           FROM PARAMETROS_FONDOS
                          WHERE pfo_fon_codigo = P_OFO_CFO_FON_CODIGO
                          AND PFO_PAR_CODIGO = 71))
              OR
               (NVL(P_COMPARTIMENTO_B,'N')= 'N' AND
        CBF_FON_CODIGO = (SELECT pfo_rango_min_char
                           FROM PARAMETROS_FONDOS
                          WHERE PFO_FON_CODIGO = P_OFO_CFO_FON_CODIGO
                          AND pfo_par_codigo = 119)))
      AND    CBF_GIRA_OTROS = 'S'
      AND    (P_ESTADO != 'ANU' OR P_TPA_MNEMONICO != 'ACH')
      AND    CBF_ESTADO = 'A'
      UNION
      SELECT MTF_CBF_BAN_CODIGO
            ,MTF_CBF_NUMERO_CUENTA
            ,MTF_FECHA
            ,MTF_CONSECUTIVO
      FROM   MOVIMIENTOS_TESORERIA_FONDOS
      WHERE  MTF_OFO_CONSECUTIVO = P_OFO_CONSECUTIVO
      AND    MTF_OFO_SUC_CODIGO = P_OFO_SUC_CODIGO
      AND    MTF_ODP_SUC_CODIGO = ODP1.ODP_SUC_CODIGO
      AND    MTF_ODP_NEG_CONSECUTIVO = ODP1.ODP_NEG_CONSECUTIVO
      AND    MTF_ODP_CONSECUTIVO = ODP1.ODP_CONSECUTIVO
      AND    P_ESTADO = 'ANU'
      AND    P_TPA_MNEMONICO = 'ACH'
      ORDER BY MTF_CONSECUTIVO DESC;
   CBFG   C_CUENTA_BANCARIA_G%ROWTYPE;

   CURSOR C_CUENTA_BANCARIA_GCE (P_TPA_MNEMONICO VARCHAR2) IS
      SELECT CBF_BAN_CODIGO
            ,CBF_NUMERO_CUENTA
            ,NULL MTF_FECHA
            ,NULL MTF_CONSECUTIVO
      FROM   CUENTAS_BANCARIAS_FONDOS
            ,CUENTAS_BANCARIAS_CORREDORES
      WHERE  ((NVL(P_COMPARTIMENTO_B,'N')= 'N' AND
               CBF_FON_CODIGO = P_OFO_CFO_FON_CODIGO)
              OR
              (NVL(P_COMPARTIMENTO_B,'N')= 'S' AND
              CBF_FON_CODIGO = (SELECT pfo_rango_min_char
                           FROM PARAMETROS_FONDOS
                          WHERE pfo_fon_codigo = P_OFO_CFO_FON_CODIGO
                          AND pfo_par_codigo = 71))
              OR
              (NVL(P_COMPARTIMENTO_B,'N')= 'N' AND
               CBF_FON_CODIGO = (SELECT pfo_rango_min_char
                                 FROM PARAMETROS_FONDOS
                                 WHERE pfo_fon_codigo = P_OFO_CFO_FON_CODIGO
                                 AND pfo_par_codigo = 119)))
      AND    CBF_GIRA_CLIENTES_EXENTOS = 'S'
      AND    (P_ESTADO != 'ANU' OR P_TPA_MNEMONICO != 'ACH')
      AND    CBF_ESTADO = 'A'
      AND    CBF_BAN_CODIGO = CBA_BAN_CODIGO
      AND    CBF_NUMERO_CUENTA = CBA_NUMERO_CUENTA
      AND    CBA_TUC_MNEMONICO = CCC1.CCC_TUC_MNEMONICO
      UNION
      SELECT MTF_CBF_BAN_CODIGO
            ,MTF_CBF_NUMERO_CUENTA
            ,MTF_FECHA
            ,MTF_CONSECUTIVO
      FROM   MOVIMIENTOS_TESORERIA_FONDOS
      WHERE  MTF_OFO_CONSECUTIVO = P_OFO_CONSECUTIVO
      AND    MTF_OFO_SUC_CODIGO = P_OFO_SUC_CODIGO
      AND    MTF_ODP_SUC_CODIGO = ODP1.ODP_SUC_CODIGO
      AND    MTF_ODP_NEG_CONSECUTIVO = ODP1.ODP_NEG_CONSECUTIVO
      AND    MTF_ODP_CONSECUTIVO = ODP1.ODP_CONSECUTIVO
      AND    P_ESTADO = 'ANU'
      AND    P_TPA_MNEMONICO = 'ACH'
      ORDER BY MTF_CONSECUTIVO DESC;
   CBFGCE   C_CUENTA_BANCARIA_GCE%ROWTYPE;

   CURSOR C_CUENTA_CORREDORES IS
      SELECT CBA_APLICA_IMP_BANCARIO
      FROM   CUENTAS_BANCARIAS_CORREDORES
      WHERE  CBA_BAN_CODIGO = CBF1.CBF_BAN_CODIGO
      AND    CBA_NUMERO_CUENTA = CBF1.CBF_NUMERO_CUENTA;
   CBA1   C_CUENTA_CORREDORES%ROWTYPE;

   CURSOR C_CONSTANTE IS
      SELECT CON_VALOR
      FROM   CONSTANTES
      WHERE  CON_MNEMONICO = 'IBA';
   CON1   C_CONSTANTE%ROWTYPE;


   CURSOR C_ULTIMO_MOVIMIENTO_BANCO IS
      SELECT
             MTF.MTF_SALDO
            ,MTF.MTF_SALDO_INTERESES
            ,MTF.MTF_FECHA
      FROM   MOVIMIENTOS_TESORERIA_FONDOS MTF
      WHERE  MTF.MTF_CBF_NUMERO_CUENTA = CBF1.CBF_NUMERO_CUENTA
      AND    MTF.MTF_CBF_BAN_CODIGO = CBF1.CBF_BAN_CODIGO
      AND    ((NVL(P_COMPARTIMENTO_B,'N')= 'N' AND
               MTF.MTF_CBF_FON_CODIGO = P_OFO_CFO_FON_CODIGO)
              OR
              (NVL(P_COMPARTIMENTO_B,'N')= 'S' AND
               MTF.MTF_CBF_FON_CODIGO = (SELECT pfo_rango_min_char
                           FROM PARAMETROS_FONDOS
                          WHERE pfo_fon_codigo = P_OFO_CFO_FON_CODIGO
                          AND PFO_PAR_CODIGO = 71))
              OR
              (NVL(P_COMPARTIMENTO_B,'N')= 'N' AND
               MTF.MTF_CBF_FON_CODIGO = (SELECT pfo_rango_min_char
                           FROM PARAMETROS_FONDOS
                          WHERE pfo_fon_codigo = P_OFO_CFO_FON_CODIGO
                          AND PFO_PAR_CODIGO = 119)))
   ORDER BY MTF.MTF_FECHA DESC;

   MTF1   C_ULTIMO_MOVIMIENTO_BANCO%ROWTYPE;

   --WGONZALEZ VARGTUD944-3
   CURSOR C_ULT_MTF (P_BAN_CODIGO VARCHAR2, P_NUMERO_CUENTA VARCHAR2, P_FON_CODIGO VARCHAR2) IS
      SELECT MTF_SALDO
            ,MTF_SALDO_INTERESES
            ,MTF_FECHA
        FROM MOVIMIENTOS_TESORERIA_FONDOS
       WHERE MTF_CBF_BAN_CODIGO    = P_BAN_CODIGO
         AND MTF_CBF_NUMERO_CUENTA = P_NUMERO_CUENTA
         AND MTF_CBF_FON_CODIGO    = P_FON_CODIGO
       ORDER BY MTF_CONSECUTIVO DESC;
   R_ULTIMO_MTF C_ULT_MTF%ROWTYPE;
   --WGONZALEZ VARGTUD944-3
   CURSOR C_BANCO (P_TID_CODIGO VARCHAR2
                  ,P_NUM_IDEN   VARCHAR2
                  ,P_CTA        NUMBER
                  ,P_BAN_CODIGO NUMBER
                  ,P_CTA_BAN    VARCHAR2) IS
      SELECT CBF_BAN_CODIGO
            ,CBF_NUMERO_CUENTA
            ,CBF_BMO_MNEMONICO
            ,FON_CODIGO
        FROM FONDOS,
             CUENTAS_FONDOS,
             CUENTAS_CLIENTE_CORREDORES,
             CUENTAS_BANCARIAS_FONDOS
        WHERE FON_CODIGO = CFO_FON_CODIGO
         AND FON_TIPO_ADMINISTRACION    = 'A'
         AND FON_ESTADO                 = 'A'
         AND CFO_CCC_CLI_PER_TID_CODIGO = CCC_CLI_PER_TID_CODIGO
         AND CFO_CCC_CLI_PER_NUM_IDEN   = CCC_CLI_PER_NUM_IDEN
         AND CFO_CCC_NUMERO_CUENTA      = CCC_NUMERO_CUENTA
         AND CCC_CLI_PER_TID_CODIGO     = P_TID_CODIGO --ORR1.ORR_CCC_CLI_PER_TID_CODIGO
         AND CCC_CLI_PER_NUM_IDEN       = P_NUM_IDEN   --ORR1.ORR_CCC_CLI_PER_NUM_IDEN
         AND CCC_NUMERO_CUENTA          = P_CTA        --ORR1.ORR_CBA_BAN_CODIGO
         AND CBF_FON_CODIGO             = FON_CODIGO
         AND CBF_BAN_CODIGO             = P_BAN_CODIGO
         AND CBF_NUMERO_CUENTA          LIKE NVL(P_CTA_BAN,'%');
   R_BANCO C_BANCO%ROWTYPE;

   CURSOR C_DESCRIPCION_MOVIMIENTO IS
      SELECT TTE_MNEMONICO
            ,TTE_DESCRIPCION
      FROM   TIPOS_MOVIMIENTOS_TESORERIA
      WHERE  TTE_TPA_MNEMONICO_RECAUDO = ORR1.ORR_TPA_MNEMONICO
      AND    TTE_DE_REVERSION  = DECODE(P_ESTADO,'ANU','S','N');
   TTE1   C_DESCRIPCION_MOVIMIENTO%ROWTYPE;

   CURSOR C_DESCRIPCION_MOVIMIENTO2 IS
      SELECT TTE_MNEMONICO
            ,TTE_DESCRIPCION
      FROM   TIPOS_MOVIMIENTOS_TESORERIA
      WHERE  TTE_TPA_MNEMONICO = ODP1.ODP_TPA_MNEMONICO
      AND    TTE_DE_REVERSION  = DECODE(P_ESTADO,'ANU','S','N');
   TTE2   C_DESCRIPCION_MOVIMIENTO2%ROWTYPE;

   CURSOR C_DESCRIPCION IS
      SELECT TTE_DESCRIPCION
      FROM   TIPOS_MOVIMIENTOS_TESORERIA
      WHERE  TTE_MNEMONICO = DECODE(P_ESTADO,'ANU','RIBA','IBA');
   TTE3   C_DESCRIPCION%ROWTYPE;

   CURSOR C_PARAMETRO (TIPO NUMBER) IS
      SELECT 'X'
      FROM PARAMETROS_FONDOS
      WHERE PFO_PAR_CODIGO = TIPO
      AND PFO_FON_CODIGO = P_OFO_CFO_FON_CODIGO;

   CURSOR C_PARM IS
      SELECT PFO_RANGO_MIN_CHAR
      FROM PARAMETROS_FONDOS
      WHERE PFO_FON_CODIGO = P_OFO_CFO_FON_CODIGO
      AND PFO_PAR_CODIGO = 71;

    CURSOR C_GLRC IS
      SELECT DISTINCT GLRC.GLRC_UUID
      FROM   PROD.GL_RECIBOS_CONVENIOS GLRC
      WHERE  GLRC.GLRC_OFO_CONSECUTIVO = P_OFO_CONSECUTIVO
      AND    GLRC.GLRC_OFO_SUC_CODIGO = P_OFO_SUC_CODIGO;

    V_UUID              VARCHAR2(64);
    CURSOR C_RCA IS
      SELECT COUNT(1)
      FROM RECIBOS_DE_CAJA RCA
      WHERE RCA.RCA_OFO_CONSECUTIVO = P_OFO_CONSECUTIVO
      AND RCA.RCA_OFO_SUC_CODIGO =  P_OFO_SUC_CODIGO
      AND RCA.RCA_COT_MNEMONICO = 'AXCB'
      AND RCA.RCA_ID_PROC_INC = V_UUID;

    V_FONDO             CUENTAS_BANCARIAS_FONDOS.CBF_FON_CODIGO%TYPE;
    CURSOR C_CTA_DAVICASH IS
      SELECT CBF.CBF_BAN_CODIGO, CBF.CBF_NUMERO_CUENTA
      FROM   CUENTAS_BANCARIAS_FONDOS CBF
      WHERE  CBF.CBF_BAN_CODIGO = ORR1.ORR_CBA_BAN_CODIGO
      AND    CBF.CBF_FON_CODIGO = V_FONDO
      AND    CBF.CBF_DAVICASH = 'S'
      AND    CBF.CBF_ESTADO = 'A'
      AND    CBF.CBF_NUMERO_CUENTA = ORR1.ORR_CBA_NUMERO_CUENTA;
    R_CTA_DAVICASH C_CTA_DAVICASH%ROWTYPE;

    --
    CURSOR C_CUENTA_BANCARIA_R_D(P_BANCO NUMBER) IS
      SELECT CBF_BAN_CODIGO
            ,CBF_NUMERO_CUENTA
      FROM   CUENTAS_BANCARIAS_FONDOS
      WHERE  CBF_BAN_CODIGO = P_BANCO
      AND    ((NVL(P_COMPARTIMENTO_B,'N')= 'N' AND
               CBF_FON_CODIGO = P_OFO_CFO_FON_CODIGO)
              OR
              (NVL(P_COMPARTIMENTO_B,'N')= 'S' AND
               CBF_FON_CODIGO = (SELECT pfo_rango_min_char
                           FROM PARAMETROS_FONDOS
                          WHERE pfo_fon_codigo = P_OFO_CFO_FON_CODIGO
                          AND pfo_par_codigo = 71))
               OR
              (NVL(P_COMPARTIMENTO_B,'N')= 'N' AND
               CBF_FON_CODIGO = (SELECT pfo_rango_min_char
                           FROM PARAMETROS_FONDOS
                          WHERE pfo_fon_codigo = P_OFO_CFO_FON_CODIGO
                          AND pfo_par_codigo = 119)))
      AND    CBF_RECAUDA_OTROS = 'S'
      AND    CBF_ESTADO = 'A'
      AND    CBF_NUMERO_CUENTA = ORR1.ORR_CBA_NUMERO_CUENTA;

    CURSOR C_CUENTA_BANCARIA_TRB_D(P_BANCO NUMBER,
                                   P_CANAL_DAVIVIENDA VARCHAR2 DEFAULT NULL) IS
      SELECT CBF_BAN_CODIGO
            ,CBF_NUMERO_CUENTA
      FROM   CUENTAS_BANCARIAS_FONDOS
      WHERE  CBF_BAN_CODIGO = P_BANCO
      AND    ((NVL(P_COMPARTIMENTO_B,'N') = 'N'
               AND CBF_FON_CODIGO = P_OFO_CFO_FON_CODIGO)
               OR (NVL(P_COMPARTIMENTO_B,'N')= 'S'
               AND CBF_FON_CODIGO = (SELECT pfo_rango_min_char
                                     FROM   PARAMETROS_FONDOS
                                     WHERE  PFO_FON_CODIGO = P_OFO_CFO_FON_CODIGO
                                     AND    PFO_PAR_CODIGO IN (71) ))
                OR (NVL(P_COMPARTIMENTO_B,'N')= 'N' --CUENTAS PARTICIPACIONES FCP
                AND CBF_FON_CODIGO = (SELECT PFO_RANGO_MIN_CHAR
                                      FROM   PARAMETROS_FONDOS
                                      WHERE  PFO_FON_CODIGO = P_OFO_CFO_FON_CODIGO
                                      AND    PFO_PAR_CODIGO IN (119) ))                    )
      AND    CBF_GIRA_RECAUDA_TRB = 'S'
      AND    CBF_ESTADO = 'A'
      AND    ((NVL(P_CANAL_DAVIVIENDA,'N') = 'N' AND NVL(CBF_IND_CANAL, 'N') = 'N')
               OR (P_CANAL_DAVIVIENDA = 'S' AND CBF_IND_CANAL = 'S'))
      AND    CBF_NUMERO_CUENTA = ORR1.ORR_CBA_NUMERO_CUENTA;

    CURSOR C_CUENTA_BANCARIA_PSE_R_D(P_BANCO NUMBER) IS
      SELECT CBF_BAN_CODIGO
            ,CBF_NUMERO_CUENTA
      FROM   CUENTAS_BANCARIAS_FONDOS
      WHERE  CBF_BAN_CODIGO = P_BANCO
      AND    ((NVL(P_COMPARTIMENTO_B,'N') = 'N' AND
               CBF_FON_CODIGO = P_OFO_CFO_FON_CODIGO)
              OR
               (NVL(P_COMPARTIMENTO_B,'N')= 'S' AND
                CBF_FON_CODIGO = (SELECT pfo_rango_min_char
                                   FROM PARAMETROS_FONDOS
                                  WHERE pfo_fon_codigo = P_OFO_CFO_FON_CODIGO
                                    AND pfo_par_codigo = 71))

               OR -- CUENTAS PARTICIPACIONES FCP
               (NVL(P_COMPARTIMENTO_B,'N')= 'N' AND
                CBF_FON_CODIGO = (SELECT pfo_rango_min_char
                                   FROM PARAMETROS_FONDOS
                                  WHERE pfo_fon_codigo = P_OFO_CFO_FON_CODIGO
                                    AND pfo_par_codigo = 119)))
      AND    CBF_GIRA_RECAUDA_PSE = 'S'
      AND    CBF_ESTADO = 'A'
      AND    CBF_NUMERO_CUENTA = ORR1.ORR_CBA_NUMERO_CUENTA;

    CURSOR C_CUENTA_BANCARIA_CEF_D(P_BANCO NUMBER, P_SUCURSAL NUMBER) IS
      SELECT CBF_BAN_CODIGO
            ,CBF_NUMERO_CUENTA
      FROM   CUENTAS_BANCARIAS_FONDOS
            ,CUENTAS_BANCARIAS_CORREDORES
            ,PARAMETROS_CUENTAS_BANCARIAS
            ,PARAMETROS_TIPOS_PAGOS
            ,FONDOS
      WHERE  CBF_BAN_CODIGO         = P_BANCO
      AND    ((NVL(P_COMPARTIMENTO_B,'N') = 'N' AND
               CBF_FON_CODIGO = P_OFO_CFO_FON_CODIGO)
              OR
              (NVL(P_COMPARTIMENTO_B,'N')= 'S' AND
        CBF_FON_CODIGO = (SELECT pfo_rango_min_char
                           FROM PARAMETROS_FONDOS
                          WHERE pfo_fon_codigo = P_OFO_CFO_FON_CODIGO
                          AND PFO_PAR_CODIGO = 71))
              OR
              (NVL(P_COMPARTIMENTO_B,'N')= 'N' AND
        CBF_FON_CODIGO = (SELECT pfo_rango_min_char
                           FROM PARAMETROS_FONDOS
                          WHERE pfo_fon_codigo = P_OFO_CFO_FON_CODIGO
                          AND pfo_par_codigo = 119)))
      AND    CBF_BAN_CODIGO = CBA_BAN_CODIGO
      AND    CBF_NUMERO_CUENTA = CBA_NUMERO_CUENTA
      AND    CBF_FON_CODIGO = FON_CODIGO
      AND    CBA_BAN_CODIGO = PBA_CBA_BAN_CODIGO
      AND    CBA_NUMERO_CUENTA = PBA_CBA_NUMERO_CUENTA
      AND    CBA_ESTADO = 'A'
      AND    PBA_PRO_MNEMONICO = FON_NPR_PRO_MNEMONICO
      AND    PTP_CBA_BAN_CODIGO = PBA_CBA_BAN_CODIGO
      AND    PTP_CBA_NUMERO_CUENTA = PBA_CBA_NUMERO_CUENTA
      AND    PBA_SUC_CODIGO = P_SUCURSAL
      AND    PBA_INDICADOR_PERSONA IN ('C','A')
      AND    PTP_TPA_MNEMONICO = 'CEF'
      AND    CBF_NUMERO_CUENTA = ORR1.ORR_CBA_NUMERO_CUENTA;
    --

  V_CANAL_DAVIVIENDA VARCHAR2(1);
  V_PARAMETRO VARCHAR2(1);

   FECHA1              DATE;
   V_CANT              NUMBER;
   TIPO_MOV            VARCHAR2(5);
   V_FON_CODIGO        VARCHAR2(15);
   V_BAN_CODIGO        NUMBER; --WGONZALEZ VARGTUD944-3C
   V_NUM_CTA           VARCHAR2(15); --WGONZALEZ VARGTUD944-3
   MOV_DESCRIPCION     VARCHAR2(40); --WGONZALEZ VARGTUD944-3
   NO_MOVIMIENTO_TES   EXCEPTION;
   NO_MOVIMIENTO_TES2  EXCEPTION;
   NO_ENCUENTRA_CTA    EXCEPTION;
   NO_MVTO             EXCEPTION;
   NO_CUENTA_TRB_R     EXCEPTION;
   NO_CUENTA_TRB_G     EXCEPTION;
   NO_CUENTA_PSE_R     EXCEPTION;
   NO_CUENTA_OTROS_R   EXCEPTION;
   NO_CUENTA_OTROS_G   EXCEPTION;
   NO_CUENTA_OTROS_GCE EXCEPTION;
   NO_CUENTA_CEF       EXCEPTION;
   NO_CUENTA_DAVICASH  EXCEPTION;
   NO_BANCO            EXCEPTION; --WGONZALEZ VARGTUD944-3
BEGIN
  -- INICIO OMORA CUENTA UNICA
  OPEN C_FONDO(P_OFO_CFO_FON_CODIGO);
  FETCH C_FONDO
   INTO P_FON_TIPO_ADMINISTRACION,
        P_FON_CAPITAL_PRIVADO;
  CLOSE C_FONDO;
  -- FIN OMORA CUENTA UNICA

  IF NVL(P_OFO_CANAL,0) IN (4,5,14) THEN
    V_CANAL_DAVIVIENDA := 'S';
  ELSE
    V_CANAL_DAVIVIENDA := 'N';
  END IF;
  --
  OPEN C_GLRC;
  FETCH C_GLRC INTO V_UUID;
  CLOSE C_GLRC;

  OPEN C_RCA;
  FETCH C_RCA INTO V_CANT;
  CLOSE C_RCA;

  IF V_CANT IS NULL THEN
    V_CANT := 0;
  END IF;

  ORR1 := NULL;
  TTE1  := NULL;
   IF P_TIPO = 'R' THEN
      OPEN C_ORDENES_RECAUDO;
      FETCH C_ORDENES_RECAUDO INTO ORR1;
      WHILE C_ORDENES_RECAUDO%FOUND LOOP
         OPEN C_DESCRIPCION_MOVIMIENTO;
         FETCH C_DESCRIPCION_MOVIMIENTO INTO TTE1;
         IF C_DESCRIPCION_MOVIMIENTO%NOTFOUND THEN
            CLOSE C_DESCRIPCION_MOVIMIENTO;
            RAISE NO_MOVIMIENTO_TES;
         END IF;
         CLOSE C_DESCRIPCION_MOVIMIENTO;
         TIPO_MOV := TTE1.TTE_MNEMONICO;

         IF V_CANT > 0 THEN
         --
            IF ORR1.ORR_TPA_MNEMONICO IN ('TRB','CEF','PSE', 'CHE') THEN

              OPEN C_PARM ;
              FETCH C_PARM INTO V_FONDO;
              CLOSE C_PARM;

              OPEN C_CTA_DAVICASH;
              FETCH C_CTA_DAVICASH INTO R_CTA_DAVICASH;
              IF C_CTA_DAVICASH%NOTFOUND THEN
                --
                IF ORR1.ORR_TPA_MNEMONICO NOT IN ('TRB','CEF','PSE') THEN
                  OPEN C_CUENTA_BANCARIA_R_D(ORR1.ORR_CBA_BAN_CODIGO);
                  FETCH C_CUENTA_BANCARIA_R_D INTO CBFR;
                  IF C_CUENTA_BANCARIA_R_D%NOTFOUND THEN
                     CLOSE C_CUENTA_BANCARIA_R_D;
                     RAISE NO_CUENTA_DAVICASH;
                  END IF;
                  CLOSE C_CUENTA_BANCARIA_R_D;
                  IF CBFR.CBF_BAN_CODIGO = ORR1.ORR_CBA_BAN_CODIGO THEN
                     CBF1.CBF_BAN_CODIGO := CBFR.CBF_BAN_CODIGO;
                     CBF1.CBF_NUMERO_CUENTA := CBFR.CBF_NUMERO_CUENTA;
                  ELSE
                     OPEN C_CUENTA_BANCARIA_TRB_D(ORR1.ORR_CBA_BAN_CODIGO,V_CANAL_DAVIVIENDA);
                     FETCH C_CUENTA_BANCARIA_TRB_D INTO CBF1;
                     IF C_CUENTA_BANCARIA_TRB_D%NOTFOUND THEN
                        CLOSE C_CUENTA_BANCARIA_TRB_D;
                        RAISE NO_CUENTA_DAVICASH;
                     END IF;
                     CLOSE C_CUENTA_BANCARIA_TRB_D;
                  END IF;
                ELSIF ORR1.ORR_TPA_MNEMONICO = 'TRB' THEN  --smorales fcp
                  OPEN C_CUENTA_BANCARIA_TRB_D(ORR1.ORR_CBA_BAN_CODIGO,V_CANAL_DAVIVIENDA);
                  FETCH C_CUENTA_BANCARIA_TRB_D INTO CBF1;
                  IF C_CUENTA_BANCARIA_TRB_D%NOTFOUND THEN
                     CLOSE C_CUENTA_BANCARIA_TRB_D;
                     RAISE NO_CUENTA_DAVICASH;
                  END IF;
                  CLOSE C_CUENTA_BANCARIA_TRB_D;
                ELSIF ORR1.ORR_TPA_MNEMONICO = 'PSE' THEN
                  OPEN C_CUENTA_BANCARIA_PSE_R_D(ORR1.ORR_CBA_BAN_CODIGO);
                  FETCH C_CUENTA_BANCARIA_PSE_R_D INTO CBF1;
                  IF C_CUENTA_BANCARIA_PSE_R_D%NOTFOUND THEN
                     CLOSE C_CUENTA_BANCARIA_PSE_R_D;
                     RAISE NO_CUENTA_DAVICASH;
                  END IF;
                  CLOSE C_CUENTA_BANCARIA_PSE_R_D;
                ELSE

                  IF ORR1.ORR_CBA_NUMERO_CUENTA IS NOT NULL THEN -- SORTIZ DAV.COM
                     CBF1.CBF_BAN_CODIGO := ORR1.ORR_CBA_BAN_CODIGO;  -- SORTIZ DAV.COM
                     CBF1.CBF_NUMERO_CUENTA := ORR1.ORR_CBA_NUMERO_CUENTA;  -- SORTIZ DAV.COM
                  ELSE -- SORTIZ DAV.COM
                     OPEN C_CUENTA_BANCARIA_CEF_D(ORR1.ORR_CBA_BAN_CODIGO,ORR1.ORR_SUC_CODIGO);
                     FETCH C_CUENTA_BANCARIA_CEF_D INTO CBFCEF;
                     IF C_CUENTA_BANCARIA_CEF_D%NOTFOUND THEN
                        CLOSE C_CUENTA_BANCARIA_CEF_D;
                        RAISE NO_CUENTA_DAVICASH;
                     END IF;
                     CBF1.CBF_BAN_CODIGO := CBFCEF.CBF_BAN_CODIGO;
                     CBF1.CBF_NUMERO_CUENTA := CBFCEF.CBF_NUMERO_CUENTA;
                     CLOSE C_CUENTA_BANCARIA_CEF_D;

                  END IF; -- SORTIZ DAV.COM
                END IF;
                --
              ELSE
                CBF1.CBF_NUMERO_CUENTA := R_CTA_DAVICASH.CBF_NUMERO_CUENTA;
              END IF;
              CLOSE C_CTA_DAVICASH;
            END IF;

         ELSIF V_CANT = 0 THEN
         --
           IF ORR1.ORR_TPA_MNEMONICO NOT IN ('TRB','CEF','PSE') THEN
              OPEN C_CUENTA_BANCARIA_R(ORR1.ORR_CBA_BAN_CODIGO);
              FETCH C_CUENTA_BANCARIA_R INTO CBFR;
              IF C_CUENTA_BANCARIA_R%NOTFOUND THEN
                 CLOSE C_CUENTA_BANCARIA_R;
                 RAISE NO_CUENTA_OTROS_R;
              END IF;
              CLOSE C_CUENTA_BANCARIA_R;
              IF CBFR.CBF_BAN_CODIGO = ORR1.ORR_CBA_BAN_CODIGO THEN
                 CBF1.CBF_BAN_CODIGO := CBFR.CBF_BAN_CODIGO;
                 CBF1.CBF_NUMERO_CUENTA := CBFR.CBF_NUMERO_CUENTA;
              ELSE
                 OPEN C_CUENTA_BANCARIA_TRB(ORR1.ORR_CBA_BAN_CODIGO,V_CANAL_DAVIVIENDA);
                 FETCH C_CUENTA_BANCARIA_TRB INTO CBF1;
                 IF C_CUENTA_BANCARIA_TRB%NOTFOUND THEN
                    CLOSE C_CUENTA_BANCARIA_TRB;
                    RAISE NO_CUENTA_TRB_R;
                 END IF;
                 CLOSE C_CUENTA_BANCARIA_TRB;
              END IF;
           ELSIF ORR1.ORR_TPA_MNEMONICO = 'TRB' THEN  --smorales fcp

            -- OMORA CUENTA UNICA
            IF NVL(ORR1.ORR_MANTENER_CTA_BANCARIA,'N') = 'S' THEN
             CBF1.CBF_BAN_CODIGO := ORR1.ORR_CBA_BAN_CODIGO;
             CBF1.CBF_NUMERO_CUENTA := ORR1.ORR_CBA_NUMERO_CUENTA;
            ELSE
            IF NVL(P_FON_TIPO_ADMINISTRACION,'X') = 'F' AND NVL(P_FON_CAPITAL_PRIVADO,'N') = 'N'
               AND NVL(V_CANAL_DAVIVIENDA,'N') = 'N' THEN
               OPEN C_CUENTA_BANCARIA_TRB_FICS(ORR1.ORR_CBA_BAN_CODIGO,V_CANAL_DAVIVIENDA);
               FETCH C_CUENTA_BANCARIA_TRB_FICS INTO CBF1;
               IF C_CUENTA_BANCARIA_TRB_FICS%NOTFOUND THEN
                CLOSE C_CUENTA_BANCARIA_TRB_FICS;
                RAISE NO_CUENTA_TRB_R;
               END IF;
               CLOSE C_CUENTA_BANCARIA_TRB_FICS;
            ELSE
               OPEN C_CUENTA_BANCARIA_TRB(ORR1.ORR_CBA_BAN_CODIGO,V_CANAL_DAVIVIENDA);
               FETCH C_CUENTA_BANCARIA_TRB INTO CBF1;
               IF C_CUENTA_BANCARIA_TRB%NOTFOUND THEN
                CLOSE C_CUENTA_BANCARIA_TRB;
                RAISE NO_CUENTA_TRB_R;
               END IF;
               CLOSE C_CUENTA_BANCARIA_TRB;
            END IF;
            END IF;
            -- FIN OMORA CUENTA UNICA

           ELSIF ORR1.ORR_TPA_MNEMONICO = 'PSE' THEN
              OPEN C_CUENTA_BANCARIA_PSE_R(ORR1.ORR_CBA_BAN_CODIGO);
              FETCH C_CUENTA_BANCARIA_PSE_R INTO CBF1;
              IF C_CUENTA_BANCARIA_PSE_R%NOTFOUND THEN
                 CLOSE C_CUENTA_BANCARIA_PSE_R;
                 RAISE NO_CUENTA_PSE_R;
              END IF;
              CLOSE C_CUENTA_BANCARIA_PSE_R;
           ELSE

              IF ORR1.ORR_CBA_NUMERO_CUENTA IS NOT NULL THEN -- SORTIZ DAV.COM
                 CBF1.CBF_BAN_CODIGO := ORR1.ORR_CBA_BAN_CODIGO;  -- SORTIZ DAV.COM
                 CBF1.CBF_NUMERO_CUENTA := ORR1.ORR_CBA_NUMERO_CUENTA;  -- SORTIZ DAV.COM
              ELSE -- SORTIZ DAV.COM
                 OPEN C_CUENTA_BANCARIA_CEF(ORR1.ORR_CBA_BAN_CODIGO,ORR1.ORR_SUC_CODIGO);
                 FETCH C_CUENTA_BANCARIA_CEF INTO CBFCEF;
                 IF C_CUENTA_BANCARIA_CEF%NOTFOUND THEN
                    CLOSE C_CUENTA_BANCARIA_CEF;
                    RAISE NO_CUENTA_CEF;
                 END IF;
                 CBF1.CBF_BAN_CODIGO := CBFCEF.CBF_BAN_CODIGO;
                 CBF1.CBF_NUMERO_CUENTA := CBFCEF.CBF_NUMERO_CUENTA;
                 CLOSE C_CUENTA_BANCARIA_CEF;

              END IF; -- SORTIZ DAV.COM
           END IF;
         END IF;

         MTF1.MTF_SALDO := 0;
         MTF1.MTF_SALDO_INTERESES := 0;
         OPEN C_ULTIMO_MOVIMIENTO_BANCO;
         FETCH C_ULTIMO_MOVIMIENTO_BANCO INTO MTF1;
         CLOSE C_ULTIMO_MOVIMIENTO_BANCO;
         MTF1.MTF_SALDO := NVL(MTF1.MTF_SALDO,0);
         MTF1.MTF_SALDO_INTERESES := NVL(MTF1.MTF_SALDO_INTERESES,0);
         IF NVL(P_COMPARTIMENTO_B,'N') = 'N' THEN
            V_FON_CODIGO := P_OFO_CFO_FON_CODIGO;
         ELSE
            BEGIN
               SELECT pfo_rango_min_char INTO V_FON_CODIGO
               FROM PARAMETROS_FONDOS
               WHERE PFO_FON_CODIGO = P_OFO_CFO_FON_CODIGO
               AND pfo_par_codigo IN (71,119);
            END;
         END IF;

         P_ULTIMOS_MOVIMIENTOS.NUEVA_FECHA_MTF
            (CBF1.CBF_NUMERO_CUENTA
            ,ORR1.ORR_CBA_BAN_CODIGO
            ,V_FON_CODIGO
            ,FECHA1);
         INSERT INTO MOVIMIENTOS_TESORERIA_FONDOS
            (MTF_CBF_BAN_CODIGO
            ,MTF_CBF_NUMERO_CUENTA
            ,MTF_CBF_FON_CODIGO
            ,MTF_FECHA
            ,MTF_TTE_MNEMONICO
            ,MTF_DEBITO
            ,MTF_CREDITO
            ,MTF_SALDO
            ,MTF_SALDO_INTERESES
            ,MTF_DESCRIPCION
            ,MTF_OFO_SUC_CODIGO
            ,MTF_OFO_CONSECUTIVO)
         VALUES
            (ORR1.ORR_CBA_BAN_CODIGO   --7
            ,CBF1.CBF_NUMERO_CUENTA --048000113
            ,V_FON_CODIGO-- 900000004-C2-P1
            ,SYSDATE
            ,TIPO_MOV  --RTRB
            ,DECODE(P_ESTADO,'ANU',-ORR1.ORR_MONTO,ORR1.ORR_MONTO) --1000000
            ,0
            ,DECODE(P_ESTADO,'ANU',MTF1.MTF_SALDO - ORR1.ORR_MONTO,MTF1.MTF_SALDO + ORR1.ORR_MONTO) --1000000
            ,MTF1.MTF_SALDO_INTERESES   --0
            ,TTE1.TTE_DESCRIPCION || ' Suc: ' || TO_CHAR(P_OFO_SUC_CODIGO) || ' Ord: ' || TO_CHAR(P_OFO_CONSECUTIVO) --TTE_DESCRIPCION  'RECAUDO CON TRANSFERENCIA BANCARIA'  VARCHAR2(40)
            ,P_OFO_SUC_CODIGO  --1
            ,P_OFO_CONSECUTIVO); --2733361

         FETCH C_ORDENES_RECAUDO INTO ORR1;
      END LOOP;
      CLOSE C_ORDENES_RECAUDO;
   ELSE
      OPEN C_ORDENES_PAGO(P_OFO_TTO_TOF_CODIGO);
      FETCH C_ORDENES_PAGO INTO ODP1;
      WHILE C_ORDENES_PAGO%FOUND LOOP
         OPEN C_DESCRIPCION_MOVIMIENTO2;
         FETCH C_DESCRIPCION_MOVIMIENTO2 INTO TTE2;
         IF C_DESCRIPCION_MOVIMIENTO2%NOTFOUND THEN
            CLOSE C_DESCRIPCION_MOVIMIENTO2;
            RAISE NO_MOVIMIENTO_TES2;
         END IF;
         CLOSE C_DESCRIPCION_MOVIMIENTO2;
         TIPO_MOV := TTE2.TTE_MNEMONICO;
         IF ODP1.ODP_TPA_MNEMONICO IN ('CHE','CHG','ACH') THEN
            EXC := 'N';
            OPEN EXCENTO;
            FETCH EXCENTO INTO CCC1;
            IF EXCENTO%NOTFOUND THEN
               EXC := 'N';
            END IF;
            EXC := NVL(CCC1.CCC_EXENTA_GMF,'N');
            CLOSE EXCENTO;
            IF EXC = 'N' THEN
               OPEN C_CUENTA_BANCARIA_G(ODP1.ODP_TPA_MNEMONICO);
               FETCH C_CUENTA_BANCARIA_G INTO CBFG;
               IF C_CUENTA_BANCARIA_G%NOTFOUND THEN
                  CLOSE C_CUENTA_BANCARIA_G;
                  RAISE NO_CUENTA_OTROS_G;
               END IF;
               CLOSE C_CUENTA_BANCARIA_G;
               CBF1.CBF_BAN_CODIGO := CBFG.CBF_BAN_CODIGO;
               CBF1.CBF_NUMERO_CUENTA := CBFG.CBF_NUMERO_CUENTA;
            ELSE
               OPEN C_CUENTA_BANCARIA_GCE(ODP1.ODP_TPA_MNEMONICO);
               FETCH C_CUENTA_BANCARIA_GCE INTO CBFGCE;
               IF C_CUENTA_BANCARIA_GCE%NOTFOUND THEN
                  CLOSE C_CUENTA_BANCARIA_GCE;
                  RAISE NO_CUENTA_OTROS_GCE;
               END IF;
               CLOSE C_CUENTA_BANCARIA_GCE;
               CBF1.CBF_BAN_CODIGO := CBFGCE.CBF_BAN_CODIGO;
               CBF1.CBF_NUMERO_CUENTA := CBFGCE.CBF_NUMERO_CUENTA;
            END IF;
         ELSIF ODP1.ODP_TPA_MNEMONICO = 'PSE' THEN
            OPEN C_CUENTA_BANCARIA_PSE_G;
            FETCH C_CUENTA_BANCARIA_PSE_G INTO CBF1;
            IF C_CUENTA_BANCARIA_PSE_G%NOTFOUND THEN
               CLOSE C_CUENTA_BANCARIA_PSE_G;
               RAISE NO_CUENTA_TRB_G;
            END IF;
            CLOSE C_CUENTA_BANCARIA_PSE_G;
         ELSE
           -- INICIO OMORA CUENTA UNICA
           IF NVL(P_FON_TIPO_ADMINISTRACION,'X') = 'F' AND NVL(P_FON_CAPITAL_PRIVADO,'N') = 'N'
          AND NVL(V_CANAL_DAVIVIENDA,'N') = 'N' THEN
              OPEN C_CUENTA_BANCARIA_TRB_FICS(ODP1.ODP_BAN_CODIGO,V_CANAL_DAVIVIENDA);
              FETCH C_CUENTA_BANCARIA_TRB_FICS INTO CBF1;
              IF C_CUENTA_BANCARIA_TRB_FICS%NOTFOUND THEN
                 CLOSE C_CUENTA_BANCARIA_TRB_FICS;
                 RAISE NO_CUENTA_TRB_G;
              END IF;
              CLOSE C_CUENTA_BANCARIA_TRB_FICS;
           ELSE

            IF ODP1.ODP_PAGAR_A = 'C' THEN
               OPEN C_CUENTA_BANCARIA_TRB(ODP1.ODP_BAN_CODIGO, V_CANAL_DAVIVIENDA);
               FETCH C_CUENTA_BANCARIA_TRB INTO CBF1;
               IF C_CUENTA_BANCARIA_TRB%NOTFOUND THEN
                  CLOSE C_CUENTA_BANCARIA_TRB;
                  RAISE NO_CUENTA_TRB_G;
               END IF;
               CLOSE C_CUENTA_BANCARIA_TRB;
            ELSE
               EXC := 'N';
               OPEN EXCENTO;
               FETCH EXCENTO INTO CCC1;
               IF EXCENTO%NOTFOUND THEN
                  EXC := 'N';
               END IF;
               EXC := NVL(CCC1.CCC_EXENTA_GMF,'N');
               CLOSE EXCENTO;
               IF EXC = 'N' THEN
                  OPEN C_CUENTA_BANCARIA_G(ODP1.ODP_TPA_MNEMONICO);
                  FETCH C_CUENTA_BANCARIA_G INTO CBFG;
                  IF C_CUENTA_BANCARIA_G%NOTFOUND THEN
                     CLOSE C_CUENTA_BANCARIA_G;
                     RAISE NO_CUENTA_OTROS_G;
                  END IF;
                  CLOSE C_CUENTA_BANCARIA_G;
                  CBF1.CBF_BAN_CODIGO := CBFG.CBF_BAN_CODIGO;
                  CBF1.CBF_NUMERO_CUENTA := CBFG.CBF_NUMERO_CUENTA;
               ELSE
                  OPEN C_CUENTA_BANCARIA_GCE(ODP1.ODP_TPA_MNEMONICO);
                  FETCH C_CUENTA_BANCARIA_GCE INTO CBFGCE;
                  IF C_CUENTA_BANCARIA_GCE%NOTFOUND THEN
                     CLOSE C_CUENTA_BANCARIA_GCE;
                     RAISE NO_CUENTA_OTROS_GCE;
                  END IF;
                  CLOSE C_CUENTA_BANCARIA_GCE;
                  CBF1.CBF_BAN_CODIGO := CBFGCE.CBF_BAN_CODIGO;
                  CBF1.CBF_NUMERO_CUENTA := CBFGCE.CBF_NUMERO_CUENTA;
               END IF;
            END IF;
      END IF; -- OMORA CUENTA UNICA
         END IF;
         MTF1.MTF_SALDO := 0;
         MTF1.MTF_SALDO_INTERESES := 0;
         OPEN C_ULTIMO_MOVIMIENTO_BANCO;
         FETCH C_ULTIMO_MOVIMIENTO_BANCO INTO MTF1;
         CLOSE C_ULTIMO_MOVIMIENTO_BANCO;
         MTF1.MTF_SALDO := NVL(MTF1.MTF_SALDO,0);
         MTF1.MTF_SALDO_INTERESES := NVL(MTF1.MTF_SALDO_INTERESES,0);
         IF NVL(P_COMPARTIMENTO_B,'N') = 'N' THEN
            V_FON_CODIGO := P_OFO_CFO_FON_CODIGO;
         ELSE
            BEGIN
               SELECT pfo_rango_min_char INTO V_FON_CODIGO
               FROM PARAMETROS_FONDOS
               WHERE PFO_FON_CODIGO = P_OFO_CFO_FON_CODIGO
                 AND pfo_par_codigo in (71,119);
            END;
         END IF;

         IF NVL(P_LLAMADO_FF_FG,'N') = 'S' THEN
            IF P_FECHA_EJECUCION  <=  MTF1.MTF_FECHA  THEN
               FECHA1 :=  MTF1.MTF_FECHA + 0.00002;
            ELSE
               FECHA1 :=  P_FECHA_EJECUCION;
            END IF;
         ELSE
            SELECT SYSDATE INTO FECHA1 FROM DUAL;
            IF FECHA1 <= MTF1.MTF_FECHA THEN
               FECHA1 := MTF1.MTF_FECHA + 0.00002;
            END IF;
         END IF;
         INSERT INTO MOVIMIENTOS_TESORERIA_FONDOS
            (MTF_CBF_BAN_CODIGO
            ,MTF_CBF_NUMERO_CUENTA
            ,MTF_CBF_FON_CODIGO
            ,MTF_FECHA
            ,MTF_TTE_MNEMONICO
            ,MTF_DEBITO
            ,MTF_CREDITO
            ,MTF_SALDO
            ,MTF_SALDO_INTERESES
            ,MTF_DESCRIPCION
            ,MTF_OFO_SUC_CODIGO
            ,MTF_OFO_CONSECUTIVO
            ,MTF_ODP_SUC_CODIGO
            ,MTF_ODP_NEG_CONSECUTIVO
            ,MTF_ODP_CONSECUTIVO)
         VALUES
            (CBF1.CBF_BAN_CODIGO
            ,CBF1.CBF_NUMERO_CUENTA
            ,V_FON_CODIGO
            ,FECHA1--SYSDATE
            ,TIPO_MOV
            ,0
            ,DECODE(P_ESTADO,'ANU',-ODP1.ODP_MONTO_ORDEN,ODP1.ODP_MONTO_ORDEN)
            ,MTF1.MTF_SALDO - DECODE(P_ESTADO,'ANU',-ODP1.ODP_MONTO_ORDEN,ODP1.ODP_MONTO_ORDEN)
            ,MTF1.MTF_SALDO_INTERESES
            ,TTE2.TTE_DESCRIPCION || ' Suc: ' || TO_CHAR(P_OFO_SUC_CODIGO) || ' Ord: ' || TO_CHAR(P_OFO_CONSECUTIVO)
            ,P_OFO_SUC_CODIGO
            ,P_OFO_CONSECUTIVO
            ,ODP1.ODP_SUC_CODIGO
            ,ODP1.ODP_NEG_CONSECUTIVO
            ,ODP1.ODP_CONSECUTIVO);

     --WGONZALEZ VAGTUD944-3
         IF P_CONPENSA_APT = 'S' THEN
            R_BANCO := NULL;
            OPEN C_BANCO(ODP1.ODP_CCC_CLI_PER_TID_CODIGO
                        ,ODP1.ODP_CCC_CLI_PER_NUM_IDEN
                        ,ODP1.ODP_CCC_NUMERO_CUENTA
                        ,ODP1.ODP_BAN_CODIGO
                        ,ODP1.ODP_NUM_CUENTA_CONSIGNAR);
                        --,CBF1.CBF_BAN_CODIGO);
            FETCH C_BANCO INTO R_BANCO;
               IF C_BANCO%NOTFOUND THEN
                  CLOSE C_BANCO;
                  RAISE NO_BANCO;
               END IF;
            CLOSE C_BANCO;

            MOV_DESCRIPCION := NULL;
            SELECT TTE_DESCRIPCION
              INTO MOV_DESCRIPCION
              FROM TIPOS_MOVIMIENTOS_TESORERIA
             WHERE TTE_MNEMONICO =  DECODE(P_ESTADO,'ANU','RET','TRA');

            R_ULTIMO_MTF := NULL;
            OPEN C_ULT_MTF (R_BANCO.CBF_BAN_CODIGO, R_BANCO.CBF_NUMERO_CUENTA, R_BANCO.FON_CODIGO);
           FETCH C_ULT_MTF INTO R_ULTIMO_MTF;
           CLOSE C_ULT_MTF;

            INSERT INTO MOVIMIENTOS_TESORERIA_FONDOS
                (MTF_CBF_BAN_CODIGO
                ,MTF_CBF_NUMERO_CUENTA
                ,MTF_CBF_FON_CODIGO
                ,MTF_FECHA
                ,MTF_TTE_MNEMONICO
                ,MTF_DEBITO
                ,MTF_CREDITO
                ,MTF_SALDO
                ,MTF_SALDO_INTERESES
                ,MTF_DESCRIPCION
                ,MTF_OFO_SUC_CODIGO
                ,MTF_OFO_CONSECUTIVO)
             VALUES
                (R_BANCO.CBF_BAN_CODIGO   --7
                ,R_BANCO.CBF_NUMERO_CUENTA --048000113
                ,R_BANCO.FON_CODIGO-- 900000004-C2-P1
                ,SYSDATE
                ,DECODE(P_ESTADO,'ANU','RET','TRA')--TIPO_MOV  --RTRB
                ,DECODE(P_ESTADO,'ANU',0,ODP1.ODP_MONTO_ORDEN) --1000000
                ,DECODE(P_ESTADO,'ANU',ODP1.ODP_MONTO_ORDEN,0) --1000000
                ,DECODE(P_ESTADO,'ANU',R_ULTIMO_MTF.MTF_SALDO - ODP1.ODP_MONTO_ORDEN,R_ULTIMO_MTF.MTF_SALDO + ODP1.ODP_MONTO_ORDEN) --1000000
                ,R_ULTIMO_MTF.MTF_SALDO_INTERESES   --0
                ,MOV_DESCRIPCION || ' Suc: ' || TO_CHAR(P_OFO_SUC_CODIGO) || ' Ord: ' || TO_CHAR(P_OFO_CONSECUTIVO) --TTE_DESCRIPCION  'RECAUDO CON TRANSFERENCIA BANCARIA'  VARCHAR2(40)
                ,P_OFO_SUC_CODIGO  --1
                ,P_OFO_CONSECUTIVO); --2733361
         END IF;

         OPEN C_CUENTA_CORREDORES;
         FETCH C_CUENTA_CORREDORES INTO CBA1;
         IF C_CUENTA_CORREDORES%NOTFOUND THEN
            CLOSE C_CUENTA_CORREDORES;
            RAISE NO_ENCUENTRA_CTA;
         END IF;
         CLOSE C_CUENTA_CORREDORES;
         IF CBA1.CBA_APLICA_IMP_BANCARIO = 'S' THEN
            IF P_EXC = 'N' THEN
               OPEN C_CONSTANTE;
               FETCH C_CONSTANTE INTO CON1;
               CLOSE C_CONSTANTE;
               CON1.CON_VALOR := NVL(CON1.CON_VALOR,0);
            ELSE
               CON1.CON_VALOR := 0;
            END IF;
         ELSE
            CON1.CON_VALOR := 0;
         END IF;
         IF ODP1.ODP_TPA_MNEMONICO = 'TRB' AND
            ODP1.ODP_PAGAR_A = 'C' AND
            ODP1.ODP_BAN_CODIGO = CBF1.CBF_BAN_CODIGO THEN
            CON1.CON_VALOR := 0;
         END IF;
         IF ROUND(ODP1.ODP_MONTO_ORDEN * CON1.CON_VALOR,2) != 0 THEN
            OPEN C_DESCRIPCION;
            FETCH C_DESCRIPCION INTO TTE3;
            IF C_DESCRIPCION%NOTFOUND THEN
               CLOSE C_DESCRIPCION;
               RAISE NO_MVTO;
            END IF;
            CLOSE C_DESCRIPCION;
            MTF1.MTF_SALDO := 0;
            MTF1.MTF_SALDO_INTERESES := 0;
            OPEN C_ULTIMO_MOVIMIENTO_BANCO;
            FETCH C_ULTIMO_MOVIMIENTO_BANCO INTO MTF1;
            CLOSE C_ULTIMO_MOVIMIENTO_BANCO;
            MTF1.MTF_SALDO := NVL(MTF1.MTF_SALDO,0);
            MTF1.MTF_SALDO_INTERESES := NVL(MTF1.MTF_SALDO_INTERESES,0);
            IF NVL(P_COMPARTIMENTO_B,'N') = 'N' THEN
               V_FON_CODIGO := P_OFO_CFO_FON_CODIGO;
            ELSE
              BEGIN
                 SELECT pfo_rango_min_char INTO V_FON_CODIGO
                 FROM PARAMETROS_FONDOS
                 WHERE pfo_fon_codigo = P_OFO_CFO_FON_CODIGO
                   AND pfo_par_codigo = 71;
              END;
            END IF;
            IF FECHA1 <= MTF1.MTF_FECHA THEN
               FECHA1 := MTF1.MTF_FECHA + 0.00002;
            END IF;
            INSERT INTO MOVIMIENTOS_TESORERIA_FONDOS
               (MTF_CBF_BAN_CODIGO
               ,MTF_CBF_NUMERO_CUENTA
               ,MTF_CBF_FON_CODIGO
               ,MTF_FECHA
               ,MTF_TTE_MNEMONICO
               ,MTF_DEBITO
               ,MTF_CREDITO
               ,MTF_SALDO
               ,MTF_SALDO_INTERESES
               ,MTF_DESCRIPCION
               ,MTF_OFO_SUC_CODIGO
               ,MTF_OFO_CONSECUTIVO
               ,MTF_ODP_SUC_CODIGO
               ,MTF_ODP_NEG_CONSECUTIVO
               ,MTF_ODP_CONSECUTIVO)
            VALUES
               (CBF1.CBF_BAN_CODIGO
               ,CBF1.CBF_NUMERO_CUENTA
               ,V_FON_CODIGO
               ,FECHA1--SYSDATE
               ,DECODE(P_ESTADO,'ANU','RIBA','IBA')
               ,0
               ,DECODE(P_ESTADO,'ANU',- ROUND(ODP1.ODP_MONTO_ORDEN * CON1.CON_VALOR,2), ROUND(ODP1.ODP_MONTO_ORDEN * CON1.CON_VALOR,2))
               ,MTF1.MTF_SALDO - DECODE(P_ESTADO,'ANU',- ROUND(ODP1.ODP_MONTO_ORDEN * CON1.CON_VALOR,2), ROUND(ODP1.ODP_MONTO_ORDEN * CON1.CON_VALOR,2))
               ,MTF1.MTF_SALDO_INTERESES
               ,TTE3.TTE_DESCRIPCION || ' Suc: ' || TO_CHAR(P_OFO_SUC_CODIGO) || ' Ord: ' || TO_CHAR(P_OFO_CONSECUTIVO)
               ,P_OFO_SUC_CODIGO
               ,P_OFO_CONSECUTIVO
               ,ODP1.ODP_SUC_CODIGO
               ,ODP1.ODP_NEG_CONSECUTIVO
               ,ODP1.ODP_CONSECUTIVO);
         END IF;
         FETCH C_ORDENES_PAGO INTO ODP1;
      END LOOP;
      CLOSE C_ORDENES_PAGO;
   END IF;
EXCEPTION
   WHEN NO_MOVIMIENTO_TES THEN
      RAISE_APPLICATION_ERROR(-20014,'Error: No se pudo determinar el movimiento de tesoreria '
         || 'para el tipo de recaudo ' || ORR1.ORR_TPA_MNEMONICO
         || ' favor comunicarse con el area de fondos para la creacion de este movimiento');
   WHEN NO_CUENTA_TRB_R THEN
      RAISE_APPLICATION_ERROR(-20015,'fcp - Error:-'||P_FON_PADRE_COMPARTIMENTO_B||'No se pudo determinar la cuenta bancaria '
         || 'configurada para recaudar transferencias para el banco '
         || TO_CHAR(ORR1.ORR_CBA_BAN_CODIGO)
         || ' favor comunicarse con el area de fondos para la creacion de esta cuenta');
   WHEN NO_CUENTA_OTROS_R THEN
      RAISE_APPLICATION_ERROR(-20016,'Error:-'||P_FON_PADRE_COMPARTIMENTO_B||'No se pudo determinar la cuenta bancaria '
         || 'configurada como recaudadora para el banco '
         || TO_CHAR(ORR1.ORR_CBA_BAN_CODIGO)
         || ' favor comunicarse con el area de fondos para la creacion de esta cuenta');
   WHEN NO_CUENTA_TRB_G THEN
      RAISE_APPLICATION_ERROR(-20017,'Error:-'||P_FON_PADRE_COMPARTIMENTO_B||'No se pudo determinar la cuenta bancaria '
         || 'configurada para girar transferencias para el banco '
         || TO_CHAR(ORR1.ORR_CBA_BAN_CODIGO)
         || ' favor comunicarse con el area de fondos para la creacion de esta cuenta');
   WHEN NO_CUENTA_OTROS_G THEN
      RAISE_APPLICATION_ERROR(-20018,'Error:-'||P_FON_PADRE_COMPARTIMENTO_B||'No se pudo determinar la cuenta bancaria '
         || 'configurada para girar. '
         || ' Favor comunicarse con el area de fondos para la creacion de esta cuenta');
   WHEN NO_CUENTA_OTROS_GCE THEN
      RAISE_APPLICATION_ERROR(-20019,'Error:-'||P_FON_PADRE_COMPARTIMENTO_B|| 'No se pudo determinar la cuenta bancaria '
         || 'configurada para girar a clientes exentos para el tipo de uso ' || CCC1.TUC_DESCRIPCION
         || '. Favor comunicarse con el area de fondos para la creacion de esta cuenta');
   WHEN NO_MOVIMIENTO_TES2 THEN
      RAISE_APPLICATION_ERROR(-20020,'Error: No se pudo determinar el movimiento de tesoreria '
         || 'para el tipo de pago ' || ODP1.ODP_TPA_MNEMONICO
         || ' favor comunicarse con el area de fondos para la creacion de '
         || 'este movimiento');
   WHEN NO_ENCUENTRA_CTA THEN
      RAISE_APPLICATION_ERROR(-20021,'Error: No se pudo encontrar la cuenta ' || CBF1.CBF_NUMERO_CUENTA
         || ' del banco ' || TO_CHAR(CBF1.CBF_BAN_CODIGO) || ' en tesoreria'
         || ' favor comunicarse con el area de fondos para la creacion de '
         || 'esta cuenta');
   WHEN NO_MVTO THEN
      RAISE_APPLICATION_ERROR(-20022,'Error: No se pudo determinar el movimiento de tesoreria '
         || 'para el impuesto bancario');
   WHEN NO_CUENTA_CEF THEN
      RAISE_APPLICATION_ERROR(-20022,'Error: Falta parametrizar la cuenta CEF en el banco:'||'-'||P_OFO_CFO_FON_CODIGO||' '
          ||TO_CHAR(ORR1.ORR_CBA_BAN_CODIGO)||' sucursal:'||to_char(ORR1.ORR_SUC_CODIGO));
   WHEN NO_CUENTA_DAVICASH THEN
      RAISE_APPLICATION_ERROR(-20024,'Error: Falta parametrizar la cuenta como Davicash en el banco:'||TO_CHAR(ORR1.ORR_CBA_BAN_CODIGO)||' '||P_OFO_CFO_FON_CODIGO
          ||' sucursal:'||to_char(ORR1.ORR_SUC_CODIGO)||' cuenta:'||to_char(ORR1.ORR_CBA_NUMERO_CUENTA));
   WHEN NO_BANCO THEN
      RAISE_APPLICATION_ERROR(-20025,'Error: El cliente identificado con '||NVL(ORR1.ORR_CCC_CLI_PER_TID_CODIGO,ODP1.ODP_CCC_CLI_PER_TID_CODIGO)||'-'||NVL(ORR1.ORR_CCC_CLI_PER_NUM_IDEN,ODP1.ODP_CCC_CLI_PER_NUM_IDEN)||' no tiene cuenta parametrizada para el banco: '||NVL(ORR1.ORR_CBA_BAN_CODIGO,CBF1.CBF_BAN_CODIGO)||' Tipo OP: '||P_TIPO);
   WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20023,'ERROR EN P_ORDENES.MOVIMIENTO_BANCARIO '|| SQLERRM);
END MOVIMIENTO_BANCARIO;
/***********************************************************/
PROCEDURE ABONO_CARGO_CUENTA(P_OFO_SUC_CODIGO               NUMBER
                            ,P_OFO_CONSECUTIVO              NUMBER
                            ,P_OFO_CFO_CCC_CLI_PER_NUM_IDEN VARCHAR2
                            ,P_OFO_CFO_CCC_CLI_PER_TID_COD  VARCHAR2
                            ,P_OFO_CFO_CCC_NUMERO_CUENTA    NUMBER
                            ,P_OFO_CFO_FON_CODIGO           VARCHAR2
                            ,P_OFO_CFO_CODIGO               NUMBER
                            ,P_EXC                          VARCHAR2
                            ,P_TIPO                         VARCHAR2
                            ,P_TIPO_MOVIMIENTO              VARCHAR2
                            ,P_LLAMADO_FF_FG                VARCHAR2 DEFAULT NULL
                            ,P_FECHA_EJECUCION              DATE     DEFAULT NULL) IS
   CURSOR C_DETALLES_CARGOS IS
      SELECT DAU_SUC_CODIGO
            ,DAU_NEG_CONSECUTIVO
            ,DAU_CONSECUTIVO
            ,DAU_TIU_MNEMONICO
            ,DAU_VALOR
            ,DAU_TRASLADO_CC
      FROM   DETALLES_CARGOS_CUENTAS
      WHERE  DAU_OFO_SUC_CODIGO = P_OFO_SUC_CODIGO
      AND    DAU_OFO_CONSECUTIVO = P_OFO_CONSECUTIVO;
   DAU1   C_DETALLES_CARGOS%ROWTYPE;
   CURSOR C_DETALLES_ABONOS IS
      SELECT DAA_SUC_CODIGO
            ,DAA_NEG_CONSECUTIVO
            ,DAA_CONSECUTIVO
            ,DAA_TAC_MNEMONICO
            ,DAA_VALOR
            ,DAA_VALOR_IMGF
            ,DAA_TRASLADO_CC
      FROM   DETALLES_ABONOS_CUENTAS
      WHERE  DAA_OFO_SUC_CODIGO = P_OFO_SUC_CODIGO
      AND    DAA_OFO_CONSECUTIVO = P_OFO_CONSECUTIVO;
   DAA1   C_DETALLES_ABONOS%ROWTYPE;
   CURSOR C_CONSECUTIVO IS
      SELECT MAX(MCA_CONSECUTIVO)
      FROM   MOVIMIENTOS_CARGOS_ABONOS;
   SIGUIENTE NUMBER;
  CURSOR C_MOVIMIENTO IS
      SELECT SUM(MCA_VALOR) MCA_VALOR
      FROM   MOVIMIENTOS_CARGOS_ABONOS
      WHERE  MCA_OFO_CONSECUTIVO = P_OFO_CONSECUTIVO
      AND    MCA_OFO_SUC_CODIGO = P_OFO_SUC_CODIGO
      AND    MCA_DAA_SUC_CODIGO = DAA1.DAA_SUC_CODIGO
      AND    MCA_DAA_NEG_CONSECUTIVO = DAA1.DAA_NEG_CONSECUTIVO
      AND    MCA_DAA_CONSECUTIVO = DAA1.DAA_CONSECUTIVO
      AND    MCA_TIPO_MOVIMIENTO = 'AC';
   MCA1   C_MOVIMIENTO%ROWTYPE;
   CURSOR C_ESTADO_ORDEN IS
      SELECT OFO_EOF_CODIGO
      FROM   ORDENES_FONDOS
      WHERE  OFO_CONSECUTIVO = P_OFO_CONSECUTIVO
      AND    OFO_SUC_CODIGO = P_OFO_SUC_CODIGO;
   OFO1   C_ESTADO_ORDEN%ROWTYPE;
   P_VER_IMPUESTO VARCHAR2(1) := NULL;
   V_FECHA        DATE;
   NO_IBA         EXCEPTION;
   VALOR_ABONO    NUMBER;
   VALOR_IMGF     NUMBER;
   --	cursor dias no habiles (dias festivos)
	CURSOR C_DIA_NO_HABIL 
		IS
	SELECT	'X'
	FROM	DIAS_NO_HABILES
	WHERE	DNH_FECHA >= TRUNC(V_FECHA)
	AND		DNH_FECHA < TRUNC(V_FECHA + 1);
	
	COND   VARCHAR2(1);
   BEGIN
   IF P_TIPO = 'C' THEN
      OPEN C_DETALLES_CARGOS;
      FETCH C_DETALLES_CARGOS INTO DAU1;
      WHILE C_DETALLES_CARGOS%FOUND LOOP
         OPEN C_CONSECUTIVO;
         FETCH C_CONSECUTIVO INTO SIGUIENTE;
         CLOSE C_CONSECUTIVO;
         SIGUIENTE := NVL(SIGUIENTE,0) + 1;
         INSERT INTO MOVIMIENTOS_CARGOS_ABONOS
            (MCA_CONSECUTIVO
            ,MCA_FECHA
            ,MCA_TIPO_MOVIMIENTO
            ,MCA_VALOR
            ,MCA_OFO_SUC_CODIGO
            ,MCA_OFO_CONSECUTIVO
            ,MCA_DAU_SUC_CODIGO
            ,MCA_DAU_NEG_CONSECUTIVO
            ,MCA_DAU_CONSECUTIVO
            ,MCA_TIU_MNEMONICO
            ,MCA_TRASLADO_CC)
         VALUES
            (SIGUIENTE
            ,SYSDATE
            ,'CC'
            ,DAU1.DAU_VALOR
            ,P_OFO_SUC_CODIGO
            ,P_OFO_CONSECUTIVO
            ,DAU1.DAU_SUC_CODIGO
            ,DAU1.DAU_NEG_CONSECUTIVO
            ,DAU1.DAU_CONSECUTIVO
            ,DAU1.DAU_TIU_MNEMONICO
            ,DAU1.DAU_TRASLADO_CC);
         FETCH C_DETALLES_CARGOS INTO DAU1;
      END LOOP;
      CLOSE C_DETALLES_CARGOS;
   ELSIF P_TIPO = 'A' THEN
      P_VER_IMPUESTO := NULL;
      OPEN C_DETALLES_ABONOS;
      FETCH C_DETALLES_ABONOS INTO DAA1;
      WHILE C_DETALLES_ABONOS%FOUND LOOP
         VALOR_ABONO := DAA1.DAA_VALOR;
         OPEN C_CONSECUTIVO;
         FETCH C_CONSECUTIVO INTO SIGUIENTE;
         CLOSE C_CONSECUTIVO;
         SIGUIENTE := NVL(SIGUIENTE,0) + 1;
         IF NVL(P_LLAMADO_FF_FG,'N') = 'S' THEN
           OPEN C_MOVIMIENTO;
           FETCH C_MOVIMIENTO INTO MCA1;
           CLOSE C_MOVIMIENTO;
           MCA1.MCA_VALOR := NVL(MCA1.MCA_VALOR,0);
           IF MCA1.MCA_VALOR != 0 THEN
             DAA1.DAA_VALOR := DAA1.DAA_VALOR + MCA1.MCA_VALOR;
           END IF;
           V_FECHA  := NVL(P_FECHA_EJECUCION,SYSDATE);
         ELSE
           SELECT SYSDATE INTO V_FECHA FROM DUAL;
         END IF;

         --	revisa que la fecha sea un dia diferente a un festivo, sabado o domingo	
         LOOP
			COND := NULL;
			OPEN C_DIA_NO_HABIL;
			FETCH C_DIA_NO_HABIL INTO COND;
			CLOSE C_DIA_NO_HABIL;
			IF NVL(COND,' ') = 'X' OR TO_CHAR(V_FECHA,'D') IN (1,7) THEN
				V_FECHA := TRUNC(V_FECHA) + 1;
			ELSE
				EXIT;
			END IF;
		END LOOP;
		
         IF DAA1.DAA_VALOR != 0 THEN
       INSERT INTO MOVIMIENTOS_CARGOS_ABONOS
            (MCA_CONSECUTIVO
            ,MCA_FECHA
            ,MCA_TIPO_MOVIMIENTO
            ,MCA_VALOR
            ,MCA_OFO_SUC_CODIGO
            ,MCA_OFO_CONSECUTIVO
            ,MCA_DAA_SUC_CODIGO
            ,MCA_DAA_NEG_CONSECUTIVO
            ,MCA_DAA_CONSECUTIVO
            ,MCA_TAC_MNEMONICO
            ,MCA_TRASLADO_CC)
          VALUES
            (SIGUIENTE
            ,V_FECHA
            ,'AC'
            ,- DAA1.DAA_VALOR
            ,P_OFO_SUC_CODIGO
            ,P_OFO_CONSECUTIVO
            ,DAA1.DAA_SUC_CODIGO
            ,DAA1.DAA_NEG_CONSECUTIVO
            ,DAA1.DAA_CONSECUTIVO
            ,DAA1.DAA_TAC_MNEMONICO
            ,DAA1.DAA_TRASLADO_CC);
         END IF;
         -- Solo inserta el movimiento IBC si la orden esta en estado aprobado FIN DE DIA
         OPEN C_ESTADO_ORDEN;
         FETCH C_ESTADO_ORDEN INTO OFO1;
         CLOSE C_ESTADO_ORDEN;
         IF NVL(OFO1.OFO_EOF_CODIGO,' ') = 'CON' THEN
            VALOR_IMGF := -NVL(DAA1.DAA_VALOR_IMGF,0);
            IF VALOR_IMGF != 0 THEN
               OPEN C_CONSECUTIVO;
               FETCH C_CONSECUTIVO INTO SIGUIENTE;
               CLOSE C_CONSECUTIVO;
               SIGUIENTE := NVL(SIGUIENTE,0) + 1;
               IF NVL(P_LLAMADO_FF_FG,'N') = 'S' THEN
                 V_FECHA  := P_FECHA_EJECUCION;
               ELSE
                 SELECT SYSDATE INTO V_FECHA FROM DUAL;
               END IF;
				--	revisa que la fecha se un dia diferente a un festivo, sabado o domingo	
				LOOP
					COND := NULL;
					OPEN C_DIA_NO_HABIL;
					FETCH C_DIA_NO_HABIL INTO COND;
					CLOSE C_DIA_NO_HABIL;
					IF NVL(COND,' ') = 'X' OR TO_CHAR(V_FECHA,'D') IN (1,7) THEN
						V_FECHA := TRUNC(V_FECHA) + 1;
					ELSE
						EXIT;
					END IF;
				END LOOP;
					
               INSERT INTO MOVIMIENTOS_CARGOS_ABONOS
                  (MCA_CONSECUTIVO
                  ,MCA_FECHA
                  ,MCA_TIPO_MOVIMIENTO
                  ,MCA_VALOR
                  ,MCA_OFO_SUC_CODIGO
                  ,MCA_OFO_CONSECUTIVO
                  ,MCA_DAA_SUC_CODIGO
                  ,MCA_DAA_NEG_CONSECUTIVO
                  ,MCA_DAA_CONSECUTIVO
                  ,MCA_TAC_MNEMONICO
                  ,MCA_TRASLADO_CC)
               VALUES
                  (SIGUIENTE
                  ,V_FECHA--SYSDATE
                  ,'IBC'
                  ,- VALOR_IMGF
                  ,P_OFO_SUC_CODIGO
                  ,P_OFO_CONSECUTIVO
                  ,DAA1.DAA_SUC_CODIGO
                  ,DAA1.DAA_NEG_CONSECUTIVO
                  ,DAA1.DAA_CONSECUTIVO
                  ,DAA1.DAA_TAC_MNEMONICO
                  ,DAA1.DAA_TRASLADO_CC);
            END IF;
         END IF;
         FETCH C_DETALLES_ABONOS INTO DAA1;
      END LOOP;
      CLOSE C_DETALLES_ABONOS;
   END IF;
EXCEPTION
   WHEN NO_IBA THEN
      RAISE_APPLICATION_ERROR(-20022,'No se pudo determinar el parametro del impuesto bancario');
   WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20023,'Error en P_ORDENES_FONDOS.ABONO_CARGO_CUENTA '||SQLERRM);
END ABONO_CARGO_CUENTA;
/***********************************************************/
PROCEDURE TRASLADO_CLIENTE_EXEC (P_OFO_SUC_CODIGO               NUMBER
                                ,P_OFO_CONSECUTIVO              NUMBER
                                ,P_OFO_CFO_CCC_CLI_PER_NUM_IDEN VARCHAR2
                                ,P_OFO_CFO_CCC_CLI_PER_TID_COD  VARCHAR2
                                ,P_OFO_CFO_CCC_NUMERO_CUENTA    NUMBER
                                ,P_OFO_CFO_FON_CODIGO           VARCHAR2
                                ,P_OFO_CFO_CODIGO               NUMBER
                                ,P_VER_IMPUESTO IN OUT          VARCHAR2) IS
   CURSOR C_SEGUNDO(P_PER_NUM_IDEN    VARCHAR2
                   ,P_PER_TID_CODIGO  VARCHAR2
                   ,P_NUMERO_CUENTA   NUMBER
                   ,P_FON_CODIGO      VARCHAR2
                   ,P_CUENTA_FONDO    NUMBER) IS
      SELECT CFO_OCL_CLI_PER_NUM_IDEN_RELAC
      FROM   CUENTAS_FONDOS
      WHERE  CFO_CCC_CLI_PER_NUM_IDEN = P_PER_NUM_IDEN
      AND    CFO_CCC_CLI_PER_TID_CODIGO = P_PER_TID_CODIGO
      AND    CFO_CCC_NUMERO_CUENTA = P_NUMERO_CUENTA
      AND    CFO_FON_CODIGO = P_FON_CODIGO
      AND    CFO_CODIGO = P_CUENTA_FONDO
      AND    CFO_OCL_CLI_PER_NUM_IDEN_RELAC IS NOT NULL;
   IDENT VARCHAR2(20);
   CURSOR C_FONDO IS
      SELECT OFO_CFO_CCC_CLI_PER_NUM_IDEN
            ,OFO_CFO_CCC_CLI_PER_TID_CODIGO
            ,OFO_CFO_CCC_NUMERO_CUENTA
            ,OFO_CFO_FON_CODIGO
            ,OFO_CFO_CODIGO
      FROM   ORDENES_FONDOS
      WHERE  OFO_OFO_SUC_CODIGO = P_OFO_SUC_CODIGO
      AND    OFO_OFO_CONSECUTIVO = P_OFO_CONSECUTIVO;
   OFO1   C_FONDO%ROWTYPE;
BEGIN
   P_VER_IMPUESTO := 'N';
   OPEN C_FONDO;
   FETCH C_FONDO INTO OFO1;
   IF C_FONDO%FOUND THEN
      CLOSE C_FONDO;
      OPEN C_SEGUNDO(P_OFO_CFO_CCC_CLI_PER_NUM_IDEN
                    ,P_OFO_CFO_CCC_CLI_PER_TID_COD
                    ,P_OFO_CFO_CCC_NUMERO_CUENTA
                    ,P_OFO_CFO_FON_CODIGO
                    ,P_OFO_CFO_CODIGO);
      FETCH C_SEGUNDO INTO IDENT;
      IF C_SEGUNDO%FOUND THEN
         P_VER_IMPUESTO := 'S';
         CLOSE C_SEGUNDO;
      ELSE
         CLOSE C_SEGUNDO;
         OPEN C_SEGUNDO(OFO1.OFO_CFO_CCC_CLI_PER_NUM_IDEN
                       ,OFO1.OFO_CFO_CCC_CLI_PER_TID_CODIGO
                       ,OFO1.OFO_CFO_CCC_NUMERO_CUENTA
                       ,OFO1.OFO_CFO_FON_CODIGO
                       ,OFO1.OFO_CFO_CODIGO);
         FETCH C_SEGUNDO INTO IDENT;
         IF C_SEGUNDO%FOUND THEN
            P_VER_IMPUESTO := 'S';
         END IF;
         CLOSE C_SEGUNDO;
      END IF;
   ELSE
      CLOSE C_FONDO;
      P_VER_IMPUESTO := 'S';
   END IF;
EXCEPTION
   WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20024,'Error en P_ORDENES_FONDOS.TRASLADO_CLIENTE_EXEC '||SQLERRM);
END TRASLADO_CLIENTE_EXEC;
/***********************************************************/
FUNCTION MONTO_ORDENES_PAGO(P_OFO_SUC_CODIGO  NUMBER
                           ,P_OFO_CONSECUTIVO NUMBER
                           ,TIPO_FONDO        VARCHAR2)
   RETURN NUMBER IS
   CURSOR C_MONTO IS
      SELECT SUM(ODP_MONTO_ORDEN)
      FROM   ORDENES_DE_PAGO
      WHERE  ODP_OFO_SUC_CODIGO = P_OFO_SUC_CODIGO
      AND    ODP_OFO_CONSECUTIVO = P_OFO_CONSECUTIVO
      AND    ODP_ANTICIPO = 'S';
   TOTAL NUMBER:= 0;
BEGIN
   OPEN  C_MONTO;
   FETCH C_MONTO INTO TOTAL;
   CLOSE C_MONTO;
   RETURN NVL(TOTAL,0);
END MONTO_ORDENES_PAGO;
/***********************************************************/
PROCEDURE APROBAR_ORDENES_PAGO(P_OFO_SUC_CODIGO  NUMBER
                              ,P_OFO_CONSECUTIVO NUMBER
                              ,P_TIPO_RETIRO     VARCHAR2
                              ,P_T0              VARCHAR2) IS
BEGIN
   IF P_TIPO_RETIRO = 'RT' THEN
      IF P_T0 = 'S' THEN
         UPDATE ordenes_de_pago
         SET    ODP_ESTADO = 'APR'
               ,ODP_FECHA_APROBACION = SYSDATE
               ,ODP_APROBADA_POR = USER
         WHERE  ODP_OFO_SUC_CODIGO  = P_OFO_SUC_CODIGO
         AND    ODP_OFO_CONSECUTIVO = P_OFO_CONSECUTIVO
         AND    ODP_ESTADO = 'COL'
         AND    ODP_ANTICIPO = 'S';
      ELSE
         UPDATE ordenes_de_pago
         SET    ODP_ESTADO = 'APR'
               ,ODP_FECHA_APROBACION = SYSDATE
               ,ODP_APROBADA_POR = USER
         WHERE  ODP_OFO_SUC_CODIGO  = P_OFO_SUC_CODIGO
         AND    ODP_OFO_CONSECUTIVO = P_OFO_CONSECUTIVO
         AND    ODP_ESTADO = 'COL';
      END IF;
   ELSIF P_TIPO_RETIRO = 'RP' THEN
      UPDATE ordenes_de_pago
      SET    ODP_ESTADO = 'APR'
            ,ODP_FECHA_APROBACION = SYSDATE
            ,ODP_APROBADA_POR = USER
      WHERE  ODP_OFO_SUC_CODIGO  = P_OFO_SUC_CODIGO
      AND    ODP_OFO_CONSECUTIVO = P_OFO_CONSECUTIVO
      AND    ODP_ESTADO = 'COL';
   END IF;
EXCEPTION
   WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20025,'Error en P_ORDENES_FONDOS.APROBAR_ORDENES_PAGO '||SQLERRM);
END APROBAR_ORDENES_PAGO;
PROCEDURE REINTEGRO_ADMON_COMISION(P_FON_CODIGO         VARCHAR2
                                  ,P_FECHA_PROCESO      DATE
                                  ,P_TIPO_PROCESO       VARCHAR2
                                  ,P_VALOR_MOVIMIENTO   OUT NUMBER) IS
   /* Procedimiento : Calculo de reintegro de administracion por comision
     Fecha :  28-ago-2008
     Autor : RHCL
     Descripcion : Creacion del movimiento RAC por caalculo de reintegro de administracion por comision, por
                   permanencia en el fondo, con las siguientes especificaciones:
                   - Se hace el dia habil siguiente del del mes calculado
                   - Para retiros totales se calcula el rango de de periodo
                   - Solo se inserta lor calculos de reintegro diferente de cero
     Variables: P_FON_CODIGO : codigo del fondo a procesar
                 P_FECHA_PROCESO : Fecha de proceso de creacion del movimientodia habil del primer mes
                 P_TIPO_PRORCESO: RT --> No es dia habil, verificacion de reitiros totales
                                  T ---> Se hace para todos los fondos el dia habiel del mes
                   */
   CURSOR cuenta (P_FECHA DATE)IS
     SELECT CFO_CCC_CLI_PER_NUM_IDEN
        , CFO_CCC_CLI_PER_TID_CODIGO
      , CFO_CCC_NUMERO_CUENTA
      , CFO_FON_CODIGO
      , CFO_CODIGO
      , CFO_FECHA_APERTURA
      , CFO_SALDO_CAPITAL
      , CFO_SALDO_INVER
      , CFO_SALDO_UNIDADES
      , CFO_SALDO_UNIDADES_NO_DISP
      , CFO_SALDO_RENDIMIENTOS_RF
      , CFO_SALDO_RENDIMIENTOS_RV
      , CFO_SALDO_RETEFUENTE
      , CFO_SALDO_INTERESES_PAGADOS
      , CFO_SALDO_DIVIDENDOS
      , CFO_SALDO_NO_DISPONIBLE
      , CFO_ENVIAR_EXTRACTO
      , CFO_ENVIAR_REC_DERECHO
      , CFO_ESTADO
      , CFO_OCL_CLI_PER_NUM_IDEN_RELAC
      , CFO_OCL_CLI_PER_TID_CODIGO_REL
      , CFO_OCL_CLI_PER_NUM_IDEN
      , CFO_OCL_CLI_PER_TID_CODIGO
      , CFO_ZIP_NUMERO
      , CFO_CUENTA_CORRESPONSALIA
      , CFO_DIVIDENDOS
      , CFO_TASA_PROMEDIO
      , CFO_CUENTA_APT
      , CFO_REFERIDO_FG
      , CFO_FECHA_INCUMPLIMIENTO
      , CFO_FECHA_ULTIMO_ENVIO_CARTA
      , CFO_COMPROMISO_FCP
      , CFO_FECHA_COMPROMISO_FCP
      , CFO_BASE_COMPROMISO_FCP
      , CFO_ID_CLIENTE_OMNIBUS
      , CFO_ID_ENCARGO_OMNIBUS
      , CFO_DECLARANTE_OMNIBUS
      , CFO_RETENCION_OMNIBUS
      , CFO_GRAN_CONTRIBUYENTE_OMNIBUS
      , CFO_APT_INVERS_FICS
      , CFO_COMPROMISOS_LLAMADOS_FCP
      , CFO_COMPROMISOS_POR_LLAMAR_FCP
      , CFO_TIIN_CODIGO
      , CFO_TIPO_PERSONA_OMNIBUS
      , CFO_RESIDENTE_FISCAL_OMNIBUS
      , CFO_ENV_CORREO_INF
    FROM cuentas_fondos
     WHERE cfo_fon_codigo = P_FON_CODIGO
       AND EXISTS(SELECT 'X' FROM movimientos_cuentas_fondos
                  WHERE mcf_fecha                      >= TRUNC(P_FECHA)
                    AND mcf_fecha                      <  TRUNC(P_FECHA+1)
                    AND mcf_cfo_ccc_cli_per_num_iden   = cfo_ccc_cli_per_num_iden
                    AND mcf_cfo_ccc_cli_per_tid_codigo = cfo_ccc_cli_per_tid_codigo
                    AND mcf_cfo_ccc_numero_cuenta      = cfo_ccc_numero_cuenta
                    AND mcf_cfo_fon_codigo             = cfo_fon_codigo
                    AND mcf_cfo_codigo                 = cfo_codigo
                    AND mcf_saldo_inver                > 0);
   CURSOR verificacion_RT(P_CFO_CCC_CLI_PER_NUM_IDEN VARCHAR2
                         ,P_CFO_CCC_CLI_TID_CODIGO   VARCHAR2
                         ,P_CFO_CCC_NUMERO_CUENTA    NUMBER
                         ,P_CFO_FON_CODIGO           VARCHAR2
                         ,P_CFO_CODIGO               NUMBER
                         ,P_FECHA_INICIAL            DATE
                         ,P_FECHA_FINAL              DATE) IS
     SELECT MAX(mcf_fecha) mcf_fecha
     FROM movimientos_cuentas_fondos  m
     WHERE  m.mcf_fecha                          >= (p_fecha_inicial)
       AND m.mcf_fecha                          <  (p_fecha_final+1)
       AND m.mcf_cfo_ccc_cli_per_num_iden       = P_CFO_CCC_CLI_PER_NUM_IDEN
       AND m.mcf_cfo_ccc_cli_per_tid_codigo     = P_CFO_CCC_CLI_TID_CODIGO
       AND m.mcf_cfo_ccc_numero_cuenta          = P_CFO_CCC_NUMERO_CUENTA
       AND m.mcf_cfo_fon_codigo                 = P_CFO_FON_CODIGO
       AND m.mcf_cfo_codigo                     = P_CFO_CODIGO
       AND m.mcf_tmf_mnemonico                  = 'O'
       AND EXISTS (SELECT 'X' FROM ordenes_fondos ofo
                   WHERE ofo.ofo_consecutivo           = m.mcf_ofo_consecutivo
                     AND ofo.ofo_suc_codigo            = m.mcf_ofo_suc_codigo
                     AND ofo.ofo_eof_codigo            = 'APR'
                     AND ofo.ofo_tto_tof_codigo        = 'RT');
   CURSOR RT_orden(P_CFO_CCC_CLI_PER_NUM_IDEN VARCHAR2
                         ,P_CFO_CCC_CLI_TID_CODIGO   VARCHAR2
                         ,P_CFO_CCC_NUMERO_CUENTA    NUMBER
                         ,P_CFO_FON_CODIGO           VARCHAR2
                         ,P_CFO_CODIGO               NUMBER
                         ,P_FECHA_INICIAL            DATE
                         ,P_FECHA_FINAL              DATE) IS
     SELECT count(*) ordenes
     FROM ordenes_fondos ofo
     WHERE OFO_CFO_CCC_CLI_PER_NUM_IDEN    = P_CFO_CCC_CLI_PER_NUM_IDEN
       AND OFO_CFO_CCC_CLI_PER_TID_CODIGO  = P_CFO_CCC_CLI_TID_CODIGO
       AND OFO_CFO_CCC_NUMERO_CUENTA       = P_CFO_CCC_NUMERO_CUENTA
       AND  OFO_CFO_FON_CODIGO             = P_CFO_FON_CODIGO
       AND OFO_CFO_CODIGO                 = P_CFO_CODIGO
       AND OFO_EOF_CODIGO                 = 'CON'
        AND ofo.ofo_tto_tof_codigo        = 'RT';
   CURSOR obtiene_saldo  (P_CFO_CCC_CLI_PER_NUM_IDEN VARCHAR2
                         ,P_CFO_CCC_CLI_TID_CODIGO   VARCHAR2
                         ,P_CFO_CCC_NUMERO_CUENTA    NUMBER
                         ,P_CFO_FON_CODIGO           VARCHAR2
                         ,P_CFO_CODIGO               NUMBER
                         ,P_FECHA                    DATE ) IS
      SELECT /*+ INDEX (mcf MCF_FECHA_I) */  m.mcf_saldo_inver
      FROM movimientos_cuentas_fondos  m
      WHERE m.mcf_fecha                          >= (p_fecha)
        AND m.mcf_fecha                          <  (p_fecha+1)
        AND m.mcf_cfo_ccc_cli_per_num_iden       = P_CFO_CCC_CLI_PER_NUM_IDEN
        AND m.mcf_cfo_ccc_cli_per_tid_codigo     = P_CFO_CCC_CLI_TID_CODIGO
        AND m.mcf_cfo_ccc_numero_cuenta          = P_CFO_CCC_NUMERO_CUENTA
        AND m.mcf_cfo_fon_codigo                 = P_CFO_FON_CODIGO
        AND m.mcf_cfo_codigo                     = P_CFO_CODIGO
     ORDER BY m.mcf_consecutivo desc;
   CURSOR valor_unidad IS
      SELECT vf.vfo_valor
      FROM   valorizaciones_fondo vf
      WHERE  vf.vfo_fecha_valorizacion >= trunc(P_FECHA_PROCESO)
        AND  vf.vfo_fecha_valorizacion < trunc(P_FECHA_PROCESO+1)
        AND  vf.vfo_fon_codigo         = P_FON_CODIGO;
   CURSOR reintegro(P_SALDO NUMBER,P_SALARIO NUMBER) IS
     SELECT RSR_CONSECUTIVO
        , RSR_FON_CODIGO
      , RSR_SALDO_INVER_MINIMO
      , RSR_SALDO_INVER_MAXIMO
      , RSR_PORCENTAJE
      , RSR_USUARIO_CREACION
      , RSR_TERMINAL_CREACION
      , RSR_FECHA_CREACION
      , RSR_USUARIO_MODIFICACION
      , RSR_TERMINAL_MODIFICACION
      , RSR_FECHA_MODIFICACION
     FROM rangos_saldos_reintegros
     WHERE rsr_fon_codigo = P_FON_CODIGO
      AND p_saldo between (rsr_saldo_inver_minimo*P_SALARIO) AND (rsr_saldo_inver_maximo*P_SALARIO);
   CURSOR constante(P_CONSTANTE VARCHAR2) IS
      SELECT con_valor
      FROM   constantes
      WHERE  con_mnemonico  = P_CONSTANTE;
   c_cuenta           cuenta%ROWTYPE;
   c_verificacion_RT  verificacion_RT%ROWTYPE;
   c_obtiene_saldo    obtiene_saldo%ROWTYPE;
   c_valor_unidad     valor_unidad%ROWTYPE;
   c_reintegro        reintegro%ROWTYPE;
   c_constante        constante%ROWTYPE;
   C_RT_orden         RT_orden%ROWTYPE;
   v_fecha_inicial    DATE;
   v_fecha_inicial_p  DATE;
   v_fecha_final      DATE;
   v_fecha_mov        DATE;
   v_fecha_mcf        DATE;
   v_dias             NUMBER;
   v_mensaje_error    VARCHAR2(1000);
   v_saldo_inversion  movimientos_cuentas_fondos.mcf_saldo_inver%TYPE;
   v_saldo_promedio   movimientos_cuentas_fondos.mcf_saldo_inver%TYPE;
   v_unidades         movimientos_cuentas_fondos.mcf_unidades_movimiento%TYPE;
   v_capital          movimientos_cuentas_fondos.mcf_capital%TYPE;
   v_valor_movimiento movimientos_cuentas_fondos.mcf_capital%TYPE;
   error              EXCEPTION;
BEGIN
   OPEN valor_unidad;
   FETCH valor_unidad INTO c_valor_unidad;
   IF valor_unidad%NOTFOUND THEN
      CLOSE valor_unidad;
      v_mensaje_error := '1. No existe valor de unidad para el dia:'||to_char(p_fecha_proceso)||' del fondo;'|| P_FON_CODIGO;
      RAISE ERROR;
   END IF;
   CLOSE valor_unidad;
   OPEN constante(P_CONSTANTE => 'SAM');
   FETCH constante INTO c_constante;
   IF constante%NOTFOUND THEN
     CLOSE constante;
     v_mensaje_error := '2. No existe valor de constante de Salario Minimo (SAM) del fondo;'|| P_FON_CODIGO;
     RAISE ERROR;
   END IF;
   CLOSE constante;
   v_valor_movimiento := 0;
   IF P_TIPO_PROCESO = 'RT' THEN
     v_fecha_inicial  := trunc(p_fecha_proceso,'MM');
     v_fecha_final    := trunc(P_FECHA_PROCESO);
   ELSE
      v_fecha_inicial  := add_months(trunc(p_fecha_proceso,'MM'),-1);
      select last_day(v_fecha_inicial) into v_fecha_final from dual;
   END IF;
   OPEN cuenta(P_FECHA => v_fecha_final);
   FETCH cuenta INTO c_cuenta;
   WHILE cuenta%FOUND LOOP
      /*Validar si existen retiros en el periodo */
      IF P_TIPO_PROCESO = 'RT' THEN
         v_fecha_inicial  := trunc(p_fecha_proceso,'MM');
         v_fecha_final    := trunc(P_FECHA_PROCESO);
      ELSE
         v_fecha_inicial  := add_months(trunc(p_fecha_proceso,'MM'),-1);
         select last_day(v_fecha_inicial) into v_fecha_final from dual;
      END IF;
      c_verificacion_RT.mcf_fecha := null;
      IF P_TIPO_PROCESO = 'RT' THEN
        c_rt_orden.ordenes := null;
        OPEN rt_orden(P_CFO_CCC_CLI_PER_NUM_IDEN => c_cuenta.cfo_ccc_cli_per_num_iden
                            ,P_CFO_CCC_CLI_TID_CODIGO   => c_cuenta.cfo_ccc_cli_per_tid_codigo
                            ,P_CFO_CCC_NUMERO_CUENTA    => c_cuenta.cfo_ccc_numero_cuenta
                            ,P_CFO_FON_CODIGO           => c_cuenta.cfo_fon_codigo
                            ,P_CFO_CODIGO               => c_cuenta.cfo_codigo
                            ,P_FECHA_INICIAL            => TRUNC(P_FECHA_PROCESO)
                            ,P_FECHA_FINAL              => trunc(p_fecha_proceso));
        FETCH rt_orden into c_rt_orden;
        close rt_orden;
      END IF;
      OPEN verificacion_RT(P_CFO_CCC_CLI_PER_NUM_IDEN => c_cuenta.cfo_ccc_cli_per_num_iden
                          ,P_CFO_CCC_CLI_TID_CODIGO   => c_cuenta.cfo_ccc_cli_per_tid_codigo
                          ,P_CFO_CCC_NUMERO_CUENTA    => c_cuenta.cfo_ccc_numero_cuenta
                          ,P_CFO_FON_CODIGO           => c_cuenta.cfo_fon_codigo
                          ,P_CFO_CODIGO               => c_cuenta.cfo_codigo
                          ,P_FECHA_INICIAL            => v_fecha_inicial
                          ,P_FECHA_FINAL              => v_fecha_final);
      FETCH   verificacion_RT INTO c_verificacion_RT;
      CLOSE  verificacion_RT ;
      IF ((P_TIPO_PROCESO = 'RT' AND NVL(c_rt_orden.ordenes,0) > 0) OR
           (P_TIPO_PROCESO = 'T')) THEN
        v_fecha_inicial     := NVL(c_verificacion_RT.mcf_fecha+1,v_fecha_inicial);
        v_saldo_inversion   := 0;
        v_saldo_promedio    := 0;
        v_dias              := (TRUNC(v_fecha_final) - TRUNC(v_fecha_inicial))+1;
        WHILE v_fecha_inicial <= v_fecha_final LOOP
           c_obtiene_saldo.mcf_saldo_inver := 0;
           OPEN obtiene_saldo  (P_CFO_CCC_CLI_PER_NUM_IDEN =>c_cuenta.cfo_ccc_cli_per_num_iden
                               ,P_CFO_CCC_CLI_TID_CODIGO   => c_cuenta.cfo_ccc_cli_per_tid_codigo
                               ,P_CFO_CCC_NUMERO_CUENTA    => c_cuenta.cfo_ccc_numero_cuenta
                               ,P_CFO_FON_CODIGO           => c_cuenta.cfo_fon_codigo
                               ,P_CFO_CODIGO               => c_cuenta.cfo_codigo
                               ,P_FECHA                    => v_fecha_inicial );
           FETCH  obtiene_saldo   INTO c_obtiene_saldo;
           CLOSE obtiene_saldo;
           v_saldo_inversion := v_saldo_inversion + nvl(c_obtiene_saldo.mcf_saldo_inver,0);
           v_fecha_inicial := v_fecha_inicial+1;
        END LOOP;
        IF P_TIPO_PROCESO = 'T' AND TRUNC(C_VERIFICACION_RT.MCF_FECHA) = TRUNC(V_FECHA_FINAL) THEN --AANGEL
           V_SALDO_PROMEDIO := 0;
        ELSE
           v_saldo_promedio  := NVL((v_saldo_inversion/v_dias),0);
        END IF;
        IF v_saldo_promedio   > 0 THEN   --- creacion del movimiento de RAC
           OPEN reintegro(P_SALDO   => v_saldo_promedio
                         ,P_SALARIO => c_constante.con_valor);
           FETCH reintegro INTO c_reintegro;
           IF reintegro%NOTFOUND THEN
             CLOSE reintegro;
             v_mensaje_error := 'No existe rango valido de reintegro para el saldo:'||TO_CHAR(v_saldo_promedio,'999,999,999,999,999.99')||' para el fondo:'||p_fon_codigo;
             RAISE error;
           END IF;
           CLOSE reintegro;
           /* creacion de movimiento de rentegro*/
           v_fecha_mcf := TRUNC(P_FECHA_PROCESO);
           v_capital   :=NVL(round(v_saldo_promedio*((power((1+c_reintegro.rsr_porcentaje),(v_dias/365)))-1),2),0);
           v_unidades := ROUND((v_capital/c_valor_unidad.vfo_valor),8);
           IF NVL(v_capital,0) > 0 THEN
              v_valor_movimiento := v_valor_movimiento +v_capital;
              INSERT INTO MOVIMIENTOS_CUENTAS_FONDOS
               (MCF_CONSECUTIVO,
                MCF_CFO_CCC_CLI_PER_TID_CODIGO,
                MCF_CFO_CCC_CLI_PER_NUM_IDEN,
                MCF_CFO_CCC_NUMERO_CUENTA,
                MCF_CFO_CODIGO,
                MCF_CFO_FON_CODIGO,
                MCF_TMF_MNEMONICO,
                MCF_FECHA,
                MCF_CAPITAL,
                MCF_UNIDADES_MOVIMIENTO,
                MCF_RENDIMIENTOS_RF,
                MCF_RENDIMIENTOS_RV,
                MCF_RETEFUENTE_MOVIMIENTO,
                 MCF_INTERESES_PAGADOS,
                MCF_SALDO_RENDIMIENTOS_RF,
                MCF_SALDO_RENDIMIENTOS_RV,
                MCF_SALDO_RETEFUENTE,
                MCF_SALDO_CAPITAL,
                MCF_SALDO_INVER,
                MCF_SALDO_UNIDADES,
                MCF_SALDO_INTERESES_PAGADOS,
                MCF_SALDO_DIVIDENDOS)
              VALUES
               (mcf_seq.nextval,
                c_cuenta.cfo_ccc_cli_per_tid_codigo,    /* CLIENTE TID          */
                c_cuenta.cfo_ccc_cli_per_num_iden,      /* CLIENTE ID           */
                c_cuenta.cfo_ccc_numero_cuenta,         /* NUMERO CTA CCC       */
                c_cuenta.cfo_codigo,                    /* FONDO CTA FONDO      */
                c_cuenta.cfo_fon_codigo,                /* CODIGO DEL FONDO     */
                'RAC',                                  /* TIPO MOVIMIENTO      */
                v_fecha_mcf,                            /* FECHA                */
                v_capital,                              /* MONTO                */
                v_unidades,                             /* MONTO EN UNIDADES    */
                0,                                      /* RENDIMIENTOS_RF      */
                0,                                      /* RENDIMIENTOS_RV      */
                0,                                      /* RETEFUENTE           */
                0,                                      /* INTERESES  PAGADOS   */
                c_cuenta.cfo_saldo_rendimientos_rf,     /* SALDO RENDI RF       */
                c_cuenta.cfo_saldo_rendimientos_rv,     /* SALDO RENDI RV       */
                c_cuenta.cfo_saldo_retefuente,          /* SALDO RETEFUENTE     */
                c_cuenta.cfo_saldo_capital+v_capital,   /* SALDO CAPITAL        */
                c_cuenta.cfo_saldo_inver+v_capital,      /* SALDO INVERSION      */
                c_cuenta.cfo_saldo_unidades+v_unidades, /* SALDO UNIDADES       */
                c_cuenta.cfo_saldo_intereses_pagados,    /* SALDO INTERESES PAGADOS*/
                c_cuenta.cfo_saldo_dividendos);         /* SALDO DIVIDENDOS*/
           END IF;
        END IF;
      END IF;
      FETCH cuenta INTO c_cuenta;
   END LOOP;
   CLOSE cuenta;
   P_VALOR_MOVIMIENTO := NVL(v_valor_movimiento,0);
   EXCEPTION
     WHEN ERROR THEN
        RAISE_APPLICATION_ERROR(-20001,v_mensaje_error||SQLERRM);
     WHEN OTHERS THEN
        RAISE_APPLICATION_ERROR(-20002,'Error en P_ORDENES_FONDOS.REINTEGRO_ADMON_COMISION '||SQLERRM);
END REINTEGRO_ADMON_COMISION;
PROCEDURE P_SALDOS_NO_DISPONIBLES(P_FECHA_PROCESO DATE DEFAULT NULL)     IS
   /* Nombre : P_SALDOS_NO_DISPONIBLES antiguo P_SALDO_NO.SQL
      Descripcion : Proceso que actualiza el saldo de unidades disponibles de los clientes de fondos
                    - Se debe corrar para todos los fondos con parametro 7 LAPSO DE TIEMPO PARA RETIROS es del default
                    - Para los fondos que tenga los paramtros   se debe correr este proceso
                         60 DIAS HABILES CHEQUES FONDOS
                         61 DIAS HABILES DIF. CHEQUES FONDOS
                         si el fondo no tiene estos parametros se debe ejecutar con el parametro 7
    FECHA MODIFICACION  : 11 JULIO 2009
    AUTOR : RIGOBRTO COCOMA
    OBSERVACIONES : Se ingresa calculo de unidades no disponibles
                  para fondos conn parametro 65 FACTIR FUTURO
                  menejados enla tabla unidades_penalizaciones_fondos
    Modificaciones:
    FEcha : 11dic2009
    Observaciones: Para calculo de unidades no disoponibles es necesario incluir
                   movimientos RTC e ITC
                         */
   CURSOR C_FONDOS IS
      SELECT FON_CODIGO
            ,PFO_RANGO_MIN_NUMBER
      FROM   FONDOS
            ,PARAMETROS_FONDOS
      WHERE  FON_TIPO = 'A'
        AND  FON_CODIGO = PFO_FON_CODIGO
        AND  PFO_PAR_CODIGO = 7
        AND  EXISTS(SELECT 'X' FROM valorizaciones_fondo
                    WHERE vfo_fon_codigo = fon_codigo);
   FON1   C_FONDOS%ROWTYPE;

   CURSOR C_DIAS_PAGO (P_FONDO VARCHAR2)IS
      SELECT PFO1.PFO_RANGO_MIN_NUMBER
      FROM   PARAMETROS_FONDOS PFO1
      WHERE  PFO1.PFO_PAR_CODIGO = 96
      AND    PFO1.PFO_FON_CODIGO = P_FONDO;

   CURSOR C_FONDOS_HAB IS
      SELECT FON_CODIGO
      FROM   FONDOS
      WHERE  FON_TIPO = 'A'
        AND  FON_CODIGO = FON1.FON_CODIGO
        AND  EXISTS(SELECT 'X' FROM  PARAMETROS_FONDOS
                    WHERE PFO_FON_CODIGO = FON_CODIGO
                      AND PFO_PAR_CODIGO IN (60,61));
   CURSOR C_PARAMETRO(P_FONDO VARCHAR2,P_PAR_CODIGO NUMBER) IS
     SELECT PFO_RANGO_MIN_NUMBER
           ,PFO_PAR_CODIGO
      FROM  PARAMETROS_FONDOS
      WHERE  PFO_FON_CODIGO = P_FONDO
        AND  PFO_PAR_CODIGO = P_PAR_CODIGO;
   PARAMETRO_60 C_PARAMETRO%ROWTYPE;
   PARAMETRO_61 C_PARAMETRO%ROWTYPE;
   PARAMETRO_65 C_PARAMETRO%ROWTYPE;
   FON_HAB   C_FONDOS_HAB%ROWTYPE;
   CURSOR C_CUENTAS(P_FONDO VARCHAR2) IS
      SELECT CFO_CCC_CLI_PER_NUM_IDEN
            ,CFO_CCC_CLI_PER_TID_CODIGO
            ,CFO_CCC_NUMERO_CUENTA
            ,CFO_FON_CODIGO
            ,CFO_CODIGO
            ,CFO_SALDO_CAPITAL
            ,CFO_SALDO_UNIDADES
            ,CFO_SALDO_UNIDADES_NO_DISP
      FROM   CUENTAS_FONDOS
      WHERE  CFO_FON_CODIGO = P_FONDO
      AND    CFO_SALDO_UNIDADES_NO_DISP != 0
      FOR UPDATE OF CFO_SALDO_UNIDADES_NO_DISP;
   CFO1 C_CUENTAS%ROWTYPE;
   CURSOR C_CUENTAS_PEN(P_FONDO VARCHAR2) IS
      SELECT CFO_CCC_CLI_PER_NUM_IDEN
            ,CFO_CCC_CLI_PER_TID_CODIGO
            ,CFO_CCC_NUMERO_CUENTA
            ,CFO_FON_CODIGO
            ,CFO_CODIGO
            ,CFO_SALDO_CAPITAL
            ,CFO_SALDO_UNIDADES
            ,CFO_SALDO_UNIDADES_NO_DISP
      FROM   CUENTAS_FONDOS
      WHERE  CFO_FON_CODIGO = P_FONDO
      AND  EXISTS(SELECT 'X' FROM UNIDADES_PENALIZACIONES_FONDOS
                    WHERE UPF_CFO_CCC_CLI_PER_NUM_IDEN = CFO_CCC_CLI_PER_NUM_IDEN
                      AND UPF_CFO_CCC_CLI_PER_TID_CODIGO = CFO_CCC_CLI_PER_TID_CODIGO
                      AND UPF_CFO_CCC_NUMERO_CUENTA  = CFO_CCC_NUMERO_CUENTA
                      AND UPF_CFO_FON_CODIGO  = CFO_FON_CODIGO
                      AND UPF_CFO_CODIGO = CFO_CODIGO
                      AND UPF_UNIDADES_POR_PENALIZAR > 0
                      )
    FOR UPDATE OF CFO_SALDO_UNIDADES_NO_DISP;
   CFO1_PEN C_CUENTAS_PEN%ROWTYPE;
   CURSOR C_FECHA (P_FONDO VARCHAR2) IS
      SELECT VFO_FECHA_VALORIZACION
            ,VFO_VALOR
      FROM   VALORIZACIONES_FONDO
      WHERE  VFO_FON_CODIGO = P_FONDO
      ORDER BY VFO_FECHA_VALORIZACION DESC;
   FEC1 C_FECHA%ROWTYPE;
   CURSOR C_MOVIMIENTOS(P_FECHA DATE) IS
      SELECT SUM(MCF_UNIDADES_MOVIMIENTO) SUMA
            ,SUM(MCF_CAPITAL) SUMA_CAPITAL
      FROM   ORDENES_FONDOS OFO
            ,MOVIMIENTOS_CUENTAS_FONDOS
      WHERE  OFO.OFO_TTO_TOF_CODIGO IN('INC','ING')
      AND    OFO.OFO_EOF_CODIGO = 'APR'
      AND    OFO.OFO_SUC_CODIGO = MCF_OFO_SUC_CODIGO
      AND    OFO.OFO_CONSECUTIVO = MCF_OFO_CONSECUTIVO
      AND    MCF_CFO_CCC_CLI_PER_NUM_IDEN = CFO1.CFO_CCC_CLI_PER_NUM_IDEN
      AND    MCF_CFO_CCC_CLI_PER_TID_CODIGO = CFO1.CFO_CCC_CLI_PER_TID_CODIGO
      AND    MCF_CFO_CCC_NUMERO_CUENTA = CFO1.CFO_CCC_NUMERO_CUENTA
      AND    SUBSTR (MCF_CFO_FON_CODIGO, 1, INSTR (MCF_CFO_FON_CODIGO, '-', 1)-1) = SUBSTR (CFO1.CFO_FON_CODIGO, 1, INSTR (CFO1.CFO_FON_CODIGO, '-', 1)-1)
      AND    MCF_CFO_CODIGO = CFO1.CFO_CODIGO
      AND    MCF_FECHA >= TRUNC(P_FECHA) - FON1.PFO_RANGO_MIN_NUMBER
    AND    NOT EXISTS ( SELECT OFO_CONSECUTIVO
                  FROM ORDENES_FONDOS
                  WHERE OFO_BLOQUEO_ING = 'S'
                  AND OFO_CONSECUTIVO = OFO.OFO_CONSECUTIVO
                      );
  v_fecha_proceso     DATE;
  CURSOR C_MOVIMIENTOS_COM IS
      SELECT SUM(MCF_UNIDADES_MOVIMIENTO) SUMA
            ,SUM(MCF_CAPITAL) SUMA_CAPITAL
      FROM   MOVIMIENTOS_CUENTAS_FONDOS
      WHERE  MCF_CFO_CCC_CLI_PER_NUM_IDEN = CFO1.CFO_CCC_CLI_PER_NUM_IDEN
        AND  MCF_CFO_CCC_CLI_PER_TID_CODIGO = CFO1.CFO_CCC_CLI_PER_TID_CODIGO
        AND  MCF_CFO_CCC_NUMERO_CUENTA = CFO1.CFO_CCC_NUMERO_CUENTA
        AND  MCF_CFO_FON_CODIGO = CFO1.CFO_FON_CODIGO
        AND  MCF_CFO_CODIGO = CFO1.CFO_CODIGO
        AND  MCF_FECHA >= TRUNC(v_fecha_proceso) + 1
        AND  MCF_TMF_MNEMONICO IN ('ITC');
  CURSOR C_RECAUDOS(P_FECHA DATE, P_TPA_MNEMONICO VARCHAR2) IS
      SELECT SUM(((ORR_MONTO*MCF_UNIDADES_MOVIMIENTO)/MCF_CAPITAL))  ORR_UNIDADES_MOVIMIENTO,
             SUM(ORR_MONTO) ORR_MONTO
      FROM   ORDENES_RECAUDO
            ,ORDENES_FONDOS
            ,MOVIMIENTOS_CUENTAS_FONDOS
      WHERE  ORR_OFO_CONSECUTIVO = OFO_CONSECUTIVO
      AND    ORR_OFO_SUC_CODIGO  = OFO_SUC_CODIGO
      AND    ((P_TPA_MNEMONICO = 'CHE' AND
              ORR_TPA_MNEMONICO = 'CHE') OR
              (P_TPA_MNEMONICO != 'CHE' AND
               ORR_TPA_MNEMONICO != 'CHE')      )
      AND    OFO_TTO_TOF_CODIGO IN('INC','ING')
      AND    OFO_EOF_CODIGO = 'APR'
      AND    OFO_SUC_CODIGO = MCF_OFO_SUC_CODIGO
      AND    OFO_CONSECUTIVO = MCF_OFO_CONSECUTIVO
      AND    MCF_CFO_CCC_CLI_PER_NUM_IDEN = CFO1.CFO_CCC_CLI_PER_NUM_IDEN
      AND    MCF_CFO_CCC_CLI_PER_TID_CODIGO = CFO1.CFO_CCC_CLI_PER_TID_CODIGO
      AND    MCF_CFO_CCC_NUMERO_CUENTA = CFO1.CFO_CCC_NUMERO_CUENTA
      AND    SUBSTR (MCF_CFO_FON_CODIGO, 1, INSTR (MCF_CFO_FON_CODIGO, '-', 1)-1) = SUBSTR (CFO1.CFO_FON_CODIGO, 1, INSTR (CFO1.CFO_FON_CODIGO, '-', 1)-1)
      AND    MCF_CFO_CODIGO = CFO1.CFO_CODIGO
      AND    MCF_FECHA >= TRUNC(P_FECHA) ;
  CURSOR C_DETALLES(P_FECHA DATE) IS
      SELECT SUM(((DAU_VALOR*MCF_UNIDADES_MOVIMIENTO)/MCF_CAPITAL))  DAU_UNIDADES_MOVIMIENTO,
             SUM(DAU_VALOR) DAU_VALOR
      FROM   DETALLES_CARGOS_CUENTAS
            ,ORDENES_FONDOS
            ,MOVIMIENTOS_CUENTAS_FONDOS
      WHERE  DAU_OFO_CONSECUTIVO = OFO_CONSECUTIVO
      AND    DAU_OFO_SUC_CODIGO  = OFO_SUC_CODIGO
      AND    OFO_TTO_TOF_CODIGO IN('INC','ING')
      AND    OFO_EOF_CODIGO = 'APR'
      AND    OFO_SUC_CODIGO = MCF_OFO_SUC_CODIGO
      AND    OFO_CONSECUTIVO = MCF_OFO_CONSECUTIVO
      AND    MCF_CFO_CCC_CLI_PER_NUM_IDEN = CFO1.CFO_CCC_CLI_PER_NUM_IDEN
      AND    MCF_CFO_CCC_CLI_PER_TID_CODIGO = CFO1.CFO_CCC_CLI_PER_TID_CODIGO
      AND    MCF_CFO_CCC_NUMERO_CUENTA = CFO1.CFO_CCC_NUMERO_CUENTA
      AND    MCF_CFO_FON_CODIGO = CFO1.CFO_FON_CODIGO
      AND    MCF_CFO_CODIGO = CFO1.CFO_CODIGO
      AND    MCF_FECHA >= TRUNC(P_FECHA) ;
  CURSOR C_UPF(P_CFO_CCC_CLI_PER_NUM_IDEN    VARCHAR2
              ,P_CFO_CCC_CLI_PER_TID_CODIGO  VARCHAR2
              ,P_CFO_CCC_NUMERO_CUENTA       NUMBER
              ,P_CFO_FON_CODIGO              VARCHAR2
              ,P_CFO_CODIGO                  NUMBER
              ,P_FECHA                       DATE) IS
     SELECT upf_unidades_por_penalizar
           , upf_fecha_disponible
           , upf_fecha_pago
           , upf_cfo_ccc_cli_per_num_iden
           , upf_cfo_ccc_cli_per_tid_codigo
           , upf_cfo_ccc_numero_cuenta
           , upf_cfo_fon_codigo
           , upf_cfo_codigo
           , upf_consecutivo
     FROM unidades_penalizaciones_fondos
     WHERE upf_eof_codigo = 'APR'
       AND upf_cfo_ccc_cli_per_num_iden = p_cfo_ccc_cli_per_num_iden
       AND upf_cfo_ccc_cli_per_tid_codigo = p_cfo_ccc_cli_per_tid_codigo
       AND upf_cfo_ccc_numero_cuenta  = p_cfo_ccc_numero_cuenta
       AND upf_cfo_fon_codigo  = p_cfo_fon_codigo
       AND upf_cfo_codigo = p_cfo_codigo
       AND upf_unidades_por_penalizar > 0
       AND trunc(upf_fecha_pago) >= trunc(p_fecha);
  CURSOR C_UPD_UPF(P_CFO_CCC_CLI_PER_NUM_IDEN    VARCHAR2
                  ,P_CFO_CCC_CLI_PER_TID_CODIGO  VARCHAR2
                  ,P_CFO_CCC_NUMERO_CUENTA       NUMBER
                  ,P_CFO_FON_CODIGO              VARCHAR2
                  ,P_CFO_CODIGO                  NUMBER
                  ,P_FECHA                       DATE) IS
     SELECT upf_unidades_por_penalizar
           , upf_fecha_disponible
           , upf_fecha_pago
           , upf_cfo_ccc_cli_per_num_iden
           , upf_cfo_ccc_cli_per_tid_codigo
           , upf_cfo_ccc_numero_cuenta
           , upf_cfo_fon_codigo
           , upf_cfo_codigo
           , upf_consecutivo
     FROM unidades_penalizaciones_fondos
     WHERE upf_eof_codigo = 'APR'
       AND upf_cfo_ccc_cli_per_num_iden = p_cfo_ccc_cli_per_num_iden
       AND upf_cfo_ccc_cli_per_tid_codigo = p_cfo_ccc_cli_per_tid_codigo
       AND upf_cfo_ccc_numero_cuenta  = p_cfo_ccc_numero_cuenta
       AND upf_cfo_fon_codigo  = p_cfo_fon_codigo
       AND upf_cfo_codigo = p_cfo_codigo
       AND upf_unidades_por_penalizar > 0
       AND (upf_fecha_disponible+1) >= trunc(p_fecha)
       AND (upf_fecha_disponible+1) <  trunc(p_fecha+1);
       /*AND (upf_fecha_pago) >= trunc(p_fecha)
       AND (upf_fecha_pago) <  trunc(p_fecha+1);*/
   MCF1                C_MOVIMIENTOS%ROWTYPE;
   MCF1_COM            C_MOVIMIENTOS_COM%ROWTYPE;
   RECAUDOS            C_RECAUDOS%ROWTYPE;
   RECAUDOS_NCHE       C_RECAUDOS%ROWTYPE;
   DETALLES            C_DETALLES%ROWTYPE;
   UPF                 C_UPF%ROWTYPE;
   UPD_UPF             C_UPD_UPF%ROWTYPE;
   NO_FECHA            EXCEPTION;
   NO_PARAMETRO        EXCEPTION;
   v_valida_parametro  VARCHAR2(1);
   v_calculo_fondo_ff  VARCHAR2(1);
   v_existe_uni_pen    VARCHAR2(1);
   v_fecha             DATE;
   v_fecha_disponible  DATE;
   v_fecha_pago        DATE;
   V_UNIDADES_NO_DISP  CUENTAS_FONDOS.CFO_SALDO_UNIDADES_NO_DISP%TYPE;
   V_SALDO_NO_DISP     CUENTAS_FONDOS.CFO_SALDO_NO_DISPONIBLE%TYPE;
   -- PARAMETROS PARA REGISTRO DE INICIO/FIN DE PROCESO
   P_NUM_INI NUMBER;
   P_NUM_FIN NUMBER;
   FECHA_PAGO DATE;
   DIAS_PAGO NUMBER;

   -- INICIO OMORA CUENTA UNICA
   CURSOR C_CUENTAS_RC_SIN_CONFIRMAR IS
    SELECT CF.CFO_CCC_CLI_PER_NUM_IDEN,
           CF.CFO_CCC_CLI_PER_TID_CODIGO,
           CF.CFO_CCC_NUMERO_CUENTA,
           CF.CFO_FON_CODIGO,
           CF.CFO_CODIGO
      FROM FONDOS          F,
           CUENTAS_FONDOS  CF,
           ORDENES_FONDOS  OFO,
           RECIBOS_DE_CAJA RE,
           ORDENES_RECAUDO ORE
     WHERE F.FON_CODIGO = CF.CFO_FON_CODIGO
       AND CF.CFO_CCC_CLI_PER_NUM_IDEN = OFO.OFO_CFO_CCC_CLI_PER_NUM_IDEN
       AND CF.CFO_CCC_CLI_PER_TID_CODIGO = OFO.OFO_CFO_CCC_CLI_PER_TID_CODIGO
       AND CF.CFO_CCC_NUMERO_CUENTA = OFO.OFO_CFO_CCC_NUMERO_CUENTA
       AND CF.CFO_FON_CODIGO = OFO.OFO_CFO_FON_CODIGO
       AND CF.CFO_CODIGO = OFO.OFO_CFO_CODIGO
       AND OFO.OFO_CONSECUTIVO = RE.RCA_OFO_CONSECUTIVO
       AND OFO.OFO_SUC_CODIGO = RE.RCA_OFO_SUC_CODIGO
       AND RE.RCA_CONSECUTIVO = ORE.ORR_RCA_CONSECUTIVO
       AND RE.RCA_SUC_CODIGO = ORE.ORR_RCA_SUC_CODIGO
       AND RE.RCA_NEG_CONSECUTIVO = ORE.ORR_RCA_NEG_CONSECUTIVO
       AND F.FON_ESTADO = 'A'
       AND F.FON_TIPO = 'A'
       AND F.FON_TIPO_ADMINISTRACION = 'F'
       AND F.FON_CAPITAL_PRIVADO = 'N'
       AND OFO.OFO_TTO_TOF_CODIGO IN ('ING', 'INC')
       AND OFO.OFO_EOF_CODIGO NOT IN ('ANU')
       AND NVL(ORE.ORR_CONFIRMADA_BANCOS, 'X') = 'N';
       R_CUENTAS_RC_SIN_CONFIRMAR C_CUENTAS_RC_SIN_CONFIRMAR%ROWTYPE;

   P_SALDO_NODISP_RC    CUENTAS_FONDOS.CFO_SALDO_NO_DISPONIBLE%TYPE;
   P_UNIDADES_NODISP_RC CUENTAS_FONDOS.CFO_SALDO_UNIDADES_NO_DISP%TYPE;
   P_ERROR              VARCHAR2(1);
   P_MENSAJE            VARCHAR2(1000);
   -- FIN OMORA

   -- VAGTUD991
   V_APLICA_SALTOS VARCHAR2(1);
   V_FONDO_ACTIVO VARCHAR2(15);
   V_FONDO_ND     VARCHAR2(15);

   CURSOR C_PARCHAR(P_FONDO VARCHAR2,P_PAR_CODIGO NUMBER) IS
      SELECT PFO_RANGO_MIN_CHAR
            ,PFO_PAR_CODIGO
        FROM PARAMETROS_FONDOS
       WHERE PFO_FON_CODIGO = P_FONDO
         AND PFO_PAR_CODIGO = P_PAR_CODIGO;
   PARCHAR C_PARCHAR%ROWTYPE;
   V_ES_OMNIBUS VARCHAR2(1);

BEGIN
   -- REGISTRO DE FECHA Y HORA DE INICIO DEL PROCESO
   P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_ORDENES_FONDOS.P_SALDOS_NO_DISPONIBLES', 'INI');
   IF P_FECHA_PROCESO IS NULL THEN
     SELECT SYSDATE INTO v_fecha_proceso FROM DUAL;
   ELSE
    v_fecha_proceso := trunc(P_FECHA_PROCESO);
   END IF;

   -- INICIO OMORA
   OPEN C_CUENTAS_RC_SIN_CONFIRMAR;
   FETCH C_CUENTAS_RC_SIN_CONFIRMAR INTO R_CUENTAS_RC_SIN_CONFIRMAR;
   WHILE C_CUENTAS_RC_SIN_CONFIRMAR%FOUND LOOP

   P_CUENTA_UNICA.PR_CONSULTA_NODISPONIBLE_RC(P_CFO_CCC_CLI_PER_NUM_IDEN   => R_CUENTAS_RC_SIN_CONFIRMAR.CFO_CCC_CLI_PER_NUM_IDEN,
                                              P_CFO_CCC_CLI_PER_TID_CODIGO => R_CUENTAS_RC_SIN_CONFIRMAR.CFO_CCC_CLI_PER_TID_CODIGO,
                                              P_CFO_CCC_NUMERO_CUENTA      => R_CUENTAS_RC_SIN_CONFIRMAR.CFO_CCC_NUMERO_CUENTA,
                                              P_CFO_FON_CODIGO             => R_CUENTAS_RC_SIN_CONFIRMAR.CFO_FON_CODIGO,
                                              P_CFO_CODIGO                 => R_CUENTAS_RC_SIN_CONFIRMAR.CFO_CODIGO,
                                              P_SALDO_NODISP_RC            => P_SALDO_NODISP_RC,
                                              P_UNIDADES_NODISP_RC         => P_UNIDADES_NODISP_RC,
                                              P_ERROR                      => P_ERROR,
                                              P_MENSAJE                    => P_MENSAJE);

   IF P_ERROR = 'N' AND NVL(P_SALDO_NODISP_RC,0) > 0 THEN
      -- VAGTUD991 - SE VALIDA SI EL FONDO TIENE SALTOS PARA APLICAR LAS UNIDADES NO DISP A LA PARTICIPACION ACTIVA
      V_APLICA_SALTOS := 'N';
      V_FONDO_ACTIVO := NULL;
      V_ES_OMNIBUS := NULL;
      V_APLICA_SALTOS := P_ORDENES_FONDOS.FN_APLICA_SALTOS(R_CUENTAS_RC_SIN_CONFIRMAR.CFO_FON_CODIGO);
      OPEN C_PARCHAR(R_CUENTAS_RC_SIN_CONFIRMAR.CFO_FON_CODIGO,115);
      FETCH C_PARCHAR INTO PARCHAR;
      IF C_PARCHAR%NOTFOUND THEN
         V_ES_OMNIBUS := 'N';
      ELSE
         V_ES_OMNIBUS := PARCHAR.PFO_RANGO_MIN_CHAR;
      END IF;
      CLOSE C_PARCHAR;
      V_FONDO_ND := R_CUENTAS_RC_SIN_CONFIRMAR.CFO_FON_CODIGO;
      IF NVL(V_APLICA_SALTOS,'N') = 'S' AND V_ES_OMNIBUS = 'N' THEN     -- TRAE EL FONDO ACTIVO PARA LOS QUE NO SON OMNIBUS
         V_FONDO_ACTIVO := P_RECAUDOS_DAVICASH.FN_PARTICIPACION_ACTIVA
                                              (P_CCC_CLI_PER_TID_CODIGO => R_CUENTAS_RC_SIN_CONFIRMAR.CFO_CCC_CLI_PER_TID_CODIGO
                                              ,P_CCC_CLI_PER_NUM_IDEN   => R_CUENTAS_RC_SIN_CONFIRMAR.CFO_CCC_CLI_PER_NUM_IDEN
                                              ,P_CCC_NUMERO_CUENTA      => R_CUENTAS_RC_SIN_CONFIRMAR.CFO_CCC_NUMERO_CUENTA
                                              ,P_CFO_FON_CODIGO         => R_CUENTAS_RC_SIN_CONFIRMAR.CFO_FON_CODIGO
                                              ,P_CFO_CODIGO             => R_CUENTAS_RC_SIN_CONFIRMAR.CFO_CODIGO
                                              );
         IF V_FONDO_ACTIVO IS NOT NULL AND
            V_FONDO_ACTIVO != R_CUENTAS_RC_SIN_CONFIRMAR.CFO_FON_CODIGO THEN
            V_FONDO_ND := V_FONDO_ACTIVO;

            -- RECALCULA LAS UNIDADES PARA EL FONDO ACTIVO
            P_UNIDADES_NODISP_RC := P_SALDO_NODISP_RC /
                                 P_CUENTA_UNICA.FN_CONSULTA_VALOR_UNIDAD(P_FON_CODIGO => V_FONDO_ACTIVO,
                                                                         P_FECHA      => NULL);

         END IF;
      END IF;
      -- FIN VAGTUD991

     -- AJUSTE VAGTUD991 - SI LA PARTICIPACION ES DIFERENTE LA ORIGINAL SE DEJA EN CERO
     IF V_FONDO_ND != R_CUENTAS_RC_SIN_CONFIRMAR.CFO_FON_CODIGO THEN
        UPDATE CUENTAS_FONDOS CF
           SET CF.CFO_SALDO_NO_DISPONIBLE_RC = 0,
               CF.CFO_UNIDADES_NO_DISP_RC    = 0,
               CF.CFO_SALDO_NO_DISPONIBLE    = 0,
               CF.CFO_SALDO_UNIDADES_NO_DISP = 0
         WHERE CF.CFO_CCC_CLI_PER_NUM_IDEN   = R_CUENTAS_RC_SIN_CONFIRMAR.CFO_CCC_CLI_PER_NUM_IDEN
           AND CF.CFO_CCC_CLI_PER_TID_CODIGO = R_CUENTAS_RC_SIN_CONFIRMAR.CFO_CCC_CLI_PER_TID_CODIGO
           AND CF.CFO_CCC_NUMERO_CUENTA      = R_CUENTAS_RC_SIN_CONFIRMAR.CFO_CCC_NUMERO_CUENTA
           AND CF.CFO_FON_CODIGO             = R_CUENTAS_RC_SIN_CONFIRMAR.CFO_FON_CODIGO   -- VAGTUD991
           AND CF.CFO_CODIGO                 = R_CUENTAS_RC_SIN_CONFIRMAR.CFO_CODIGO;
     END IF;
     -- FIN AJUSTE VAGTUD991

     UPDATE CUENTAS_FONDOS CF
        SET CF.CFO_SALDO_NO_DISPONIBLE_RC = P_SALDO_NODISP_RC,
            CF.CFO_UNIDADES_NO_DISP_RC    = P_UNIDADES_NODISP_RC,
            CF.CFO_SALDO_NO_DISPONIBLE    = P_SALDO_NODISP_RC,
            CF.CFO_SALDO_UNIDADES_NO_DISP = P_UNIDADES_NODISP_RC
      WHERE CF.CFO_CCC_CLI_PER_NUM_IDEN   = R_CUENTAS_RC_SIN_CONFIRMAR.CFO_CCC_CLI_PER_NUM_IDEN
        AND CF.CFO_CCC_CLI_PER_TID_CODIGO = R_CUENTAS_RC_SIN_CONFIRMAR.CFO_CCC_CLI_PER_TID_CODIGO
        AND CF.CFO_CCC_NUMERO_CUENTA      = R_CUENTAS_RC_SIN_CONFIRMAR.CFO_CCC_NUMERO_CUENTA
        AND CF.CFO_FON_CODIGO             = V_FONDO_ND              --- R_CUENTAS_RC_SIN_CONFIRMAR.CFO_FON_CODIGO   -- VAGTUD991
        AND CF.CFO_CODIGO                 = R_CUENTAS_RC_SIN_CONFIRMAR.CFO_CODIGO;
   END IF;

   FETCH C_CUENTAS_RC_SIN_CONFIRMAR INTO R_CUENTAS_RC_SIN_CONFIRMAR;
   END LOOP;
   CLOSE C_CUENTAS_RC_SIN_CONFIRMAR;
   -- FIN OMORA

   OPEN C_FONDOS;
   FETCH C_FONDOS INTO FON1;
   WHILE C_FONDOS%FOUND LOOP
      /* para fondos con parametro 65 se hace el caluclo especial de unidades de penalizacion
         de la tabla unidades_penalizaciones_fondos*/
      v_calculo_fondo_ff := 'N';
      OPEN C_PARAMETRO(P_FONDO => FON1.FON_CODIGO,P_PAR_CODIGO=> 65) ;
      FETCH C_PARAMETRO INTO PARAMETRO_65;
      IF C_PARAMETRO%FOUND THEN
        v_calculo_fondo_ff  := 'S';
      ELSE
        v_calculo_fondo_ff  := 'N';
      END IF;
      CLOSE C_PARAMETRO ;
      IF v_calculo_fondo_ff = 'S' THEN
         OPEN C_FECHA (FON1.FON_CODIGO);
         FETCH C_FECHA INTO FEC1;
         IF C_FECHA%NOTFOUND THEN
           RAISE NO_FECHA;
         END IF;
         CLOSE C_FECHA;
         OPEN C_CUENTAS_PEN(FON1.FON_CODIGO);
         FETCH C_CUENTAS_PEN INTO CFO1_PEN;
         WHILE C_CUENTAS_PEN%FOUND LOOP
           V_UNIDADES_NO_DISP  := 0;
           V_SALDO_NO_DISP     := 0;
           v_existe_uni_pen    := 'N';
           OPEN C_UPF(P_CFO_CCC_CLI_PER_NUM_IDEN    => CFO1_PEN.CFO_CCC_CLI_PER_NUM_IDEN
                     ,P_CFO_CCC_CLI_PER_TID_CODIGO  => CFO1_PEN.CFO_CCC_CLI_PER_TID_CODIGO
                     ,P_CFO_CCC_NUMERO_CUENTA       => CFO1_PEN.CFO_CCC_NUMERO_CUENTA
                     ,P_CFO_FON_CODIGO              => CFO1_PEN.CFO_FON_CODIGO
                     ,P_CFO_CODIGO                  => CFO1_PEN.CFO_CODIGO
                     ,P_FECHA                       => v_fecha_proceso);
           FETCH C_UPF INTO UPF;
           WHILE C_UPF%FOUND LOOP
             v_existe_uni_pen := 'S';
             IF TRUNC(v_fecha_proceso) = TRUNC(UPF.UPF_FECHA_DISPONIBLE) THEN
               V_UNIDADES_NO_DISP := 0;
               V_SALDO_NO_DISP := 0;
             ELSE
               V_UNIDADES_NO_DISP := V_UNIDADES_NO_DISP+UPF.upf_unidades_por_penalizar;
             END IF;
             FETCH C_UPF INTO UPF;
           END LOOP;
           CLOSE C_UPF;
           IF v_existe_uni_pen = 'S' THEN
             V_SALDO_NO_DISP    := V_UNIDADES_NO_DISP*FEC1.VFO_VALOR;
             UPDATE CUENTAS_FONDOS
             SET    CFO_SALDO_UNIDADES_NO_DISP = V_UNIDADES_NO_DISP + CFO_UNIDADES_NO_DISP_RC -- OMORA
                   ,CFO_SALDO_NO_DISPONIBLE = V_SALDO_NO_DISP + CFO_SALDO_NO_DISPONIBLE_RC -- OMORA
             WHERE  CURRENT OF C_CUENTAS_PEN;
           END IF;
           FETCH C_CUENTAS_PEN INTO CFO1_PEN;
         END LOOP;
         CLOSE C_CUENTAS_PEN;
         /* actualizar fechas de pago y vencimientos para cuentas con saldos en el dia siguiente al pago */
         OPEN C_CUENTAS_PEN(FON1.FON_CODIGO);
         FETCH C_CUENTAS_PEN INTO CFO1_PEN;
         WHILE C_CUENTAS_PEN%FOUND LOOP
           V_UNIDADES_NO_DISP  := 0;
           V_SALDO_NO_DISP     := 0;
           OPEN C_UPD_UPF(P_CFO_CCC_CLI_PER_NUM_IDEN    => CFO1_PEN.CFO_CCC_CLI_PER_NUM_IDEN
                         ,P_CFO_CCC_CLI_PER_TID_CODIGO  => CFO1_PEN.CFO_CCC_CLI_PER_TID_CODIGO
                         ,P_CFO_CCC_NUMERO_CUENTA       => CFO1_PEN.CFO_CCC_NUMERO_CUENTA
                         ,P_CFO_FON_CODIGO              => CFO1_PEN.CFO_FON_CODIGO
                         ,P_CFO_CODIGO                  => CFO1_PEN.CFO_CODIGO
                         ,P_FECHA                       => v_fecha_proceso);
           FETCH C_UPD_UPF INTO UPD_UPF;
           WHILE C_UPD_UPF%FOUND LOOP
         /****VAGTUD876 FONDO ALTERNATIVO SE CAMBIA EL ACLCULO DE LA RENOVACIÓN PARQ EU LO HAGA CONTRA LA FECHA DISPONIBLE +1 ****/
             --IF TRUNC(UPD_UPF.UPF_FECHA_PAGO) = TRUNC(V_FECHA_PROCESO) THEN
             IF TRUNC(UPD_UPF.UPF_FECHA_DISPONIBLE)+1 = TRUNC(V_FECHA_PROCESO) THEN
               V_UNIDADES_NO_DISP := V_UNIDADES_NO_DISP + UPD_UPF.UPF_UNIDADES_POR_PENALIZAR;
               V_SALDO_NO_DISP    := V_SALDO_NO_DISP + (V_UNIDADES_NO_DISP * FEC1.VFO_VALOR);
               v_fecha_disponible := TRUNC(UPD_UPF.UPF_FECHA_DISPONIBLE) + NVL(FON1.PFO_RANGO_MIN_NUMBER,0);
               V_FECHA_DISPONIBLE := P_SALDOS_CLIENTES.F_FECHA_HABIL(P_FECHA_INICIAL => V_FECHA_DISPONIBLE
                                                                    ,P_DIAS          => 1);
               DIAS_PAGO := 0;
               OPEN C_DIAS_PAGO(CFO1_PEN.CFO_FON_CODIGO);
               FETCH C_DIAS_PAGO INTO DIAS_PAGO;
               CLOSE C_DIAS_PAGO;

               IF NVL(DIAS_PAGO,0) > 1 THEN
                  v_fecha_pago := P_TOOLS.SUMAR_HABILES_A_FECHA(P_FECHA => v_fecha_disponible
                                                               ,P_DIAS  => DIAS_PAGO);
               ELSE
                  v_fecha_pago := P_SALDOS_CLIENTES.F_FECHA_HABIL(P_FECHA_INICIAL => v_fecha_disponible + 1
                                                                 ,P_DIAS          =>1);
               END IF;
               /** actualizacion de las nuevas de fechas de pago y disponibles*/
               UPDATE unidades_penalizaciones_fondos
                 SET upf_fecha_disponible = v_fecha_disponible
                   ,upf_fecha_pago       = v_fecha_pago
                 WHERE upf_consecutivo = UPD_UPF.upf_consecutivo;
             END IF;
             FETCH C_UPD_UPF INTO UPD_UPF;
           END LOOP;
           CLOSE C_UPD_UPF;
           IF V_UNIDADES_NO_DISP > 0 THEN
             UPDATE CUENTAS_FONDOS
             SET    CFO_SALDO_UNIDADES_NO_DISP = V_UNIDADES_NO_DISP + CFO_UNIDADES_NO_DISP_RC -- OMORA
                   ,CFO_SALDO_NO_DISPONIBLE = V_SALDO_NO_DISP + CFO_SALDO_NO_DISPONIBLE_RC -- OMORA
             WHERE  CURRENT OF C_CUENTAS_PEN;
           END IF;
           FETCH C_CUENTAS_PEN INTO CFO1_PEN;
         END LOOP;
         CLOSE C_CUENTAS_PEN;
      ELSE
        /* VALIDAR SI EL FONDO TIENE LOS PARAMETROS 60 Y 61 SE DEBE CALCULAR PARA DIAS HABILES*/
        v_valida_parametro := 'N';
        IF TRUNC(P_SALDOS_CLIENTES.F_FECHA_HABIL(P_FECHA_INICIAL => TRUNC(V_FECHA_PROCESO),
                                           P_DIAS          => 1)) = TRUNC(V_FECHA_PROCESO) THEN /* El proceso de canje solo dias habiles*/
          /* determinar la fecha de calculo de las ordenes*/
          OPEN C_FONDOS_HAB;
          FETCH C_FONDOS_HAB INTO FON_HAB;
          WHILE C_FONDOS_HAB%FOUND LOOP
            v_valida_parametro := 'S';
            OPEN C_PARAMETRO(P_FONDO => FON_HAB.FON_CODIGO,P_PAR_CODIGO=> 60) ;
            FETCH C_PARAMETRO INTO PARAMETRO_60;
            IF C_PARAMETRO%NOTFOUND THEN
              CLOSE C_PARAMETRO ;
              RAISE NO_PARAMETRO;
            END IF;
            CLOSE C_PARAMETRO ;
            OPEN C_PARAMETRO(P_FONDO => FON_HAB.FON_CODIGO,P_PAR_CODIGO=> 61) ;
            FETCH C_PARAMETRO INTO PARAMETRO_61;
            IF C_PARAMETRO%NOTFOUND THEN
              CLOSE C_PARAMETRO ;
              RAISE NO_PARAMETRO;
            END IF;
            CLOSE C_PARAMETRO ;
            OPEN C_FECHA(FON_HAB.FON_CODIGO);
            FETCH C_FECHA INTO FEC1;
            IF C_FECHA%NOTFOUND THEN
               RAISE NO_FECHA;
            END IF;
            CLOSE C_FECHA;
            OPEN C_CUENTAS(FON_HAB.FON_CODIGO);
            FETCH C_CUENTAS INTO CFO1;
            WHILE C_CUENTAS%FOUND LOOP
               DBMS_OUTPUT.PUT_LINE(TO_CHAR(CFO1.CFO_CCC_CLI_PER_NUM_IDEN)||' '||  FON1.FON_CODIGO);
               /* Calculo cheques*/
               RECAUDOS.ORR_UNIDADES_MOVIMIENTO := NULL;
               RECAUDOS.ORR_MONTO               := NULL;
               V_FECHA := P_TOOLS.F_DIA_HABIL_RETROFECHA(P_FECHA => TRUNC(v_fecha_proceso),
                                                 P_DIAS  => PARAMETRO_60.pfo_rango_min_number-1);
               OPEN C_RECAUDOS(P_FECHA => V_FECHA, P_TPA_MNEMONICO=> 'CHE') ;
               FETCH C_RECAUDOS INTO RECAUDOS;
               CLOSE C_RECAUDOS;
               /* Calculo detalles recaudos no cheques*/
               V_FECHA := P_TOOLS.F_DIA_HABIL_RETROFECHA(P_FECHA => TRUNC(v_fecha_proceso),
                                                 P_DIAS  => PARAMETRO_61.pfo_rango_min_number-1);
               RECAUDOS_NCHE.ORR_UNIDADES_MOVIMIENTO := NULL;
               RECAUDOS_NCHE.ORR_MONTO               := NULL;
               OPEN C_RECAUDOS(P_FECHA => V_FECHA, P_TPA_MNEMONICO=> 'NCHE') ;
               FETCH C_RECAUDOS INTO RECAUDOS_NCHE;
               CLOSE C_RECAUDOS;
               /* Calculo DETALLES recaudos no cheques*/
               OPEN C_DETALLES(P_FECHA => V_FECHA);
               FETCH C_DETALLES INTO DETALLES;
               CLOSE C_DETALLES;
               OPEN C_MOVIMIENTOS_COM;
               FETCH C_MOVIMIENTOS_COM INTO MCF1_COM;
               CLOSE C_MOVIMIENTOS_COM;
               RECAUDOS.ORR_UNIDADES_MOVIMIENTO  := ROUND((NVL(RECAUDOS.ORR_UNIDADES_MOVIMIENTO,0)+
                                                           NVL(RECAUDOS_NCHE.ORR_UNIDADES_MOVIMIENTO,0)+
                                                           NVL(DETALLES.DAU_UNIDADES_MOVIMIENTO,0)),8)+
                                                     NVL(MCF1_COM.SUMA,0);
               RECAUDOS.ORR_MONTO                := ROUND((NVL(RECAUDOS.ORR_MONTO,0)+
                                                           NVL(RECAUDOS_NCHE.ORR_MONTO,0)+
                                                           NVL(DETALLES.DAU_VALOR,0)),8)+
                                                     NVL(MCF1_COM.SUMA_CAPITAL,0);
               IF CFO1.CFO_SALDO_UNIDADES < RECAUDOS.ORR_UNIDADES_MOVIMIENTO THEN
                  RECAUDOS.ORR_UNIDADES_MOVIMIENTO := CFO1.CFO_SALDO_UNIDADES;
                  RECAUDOS.ORR_MONTO:= CFO1.CFO_SALDO_CAPITAL;
               END IF;
               UPDATE CUENTAS_FONDOS
               SET  CFO_SALDO_UNIDADES_NO_DISP = (RECAUDOS.ORR_MONTO/FEC1.VFO_VALOR) + CFO_UNIDADES_NO_DISP_RC -- OMORA
                   ,CFO_SALDO_NO_DISPONIBLE =    RECAUDOS.ORR_MONTO + CFO_SALDO_NO_DISPONIBLE_RC -- OMORA
               WHERE  CURRENT OF C_CUENTAS;
               FETCH C_CUENTAS INTO CFO1;
            END LOOP;
            CLOSE C_CUENTAS;
            FETCH C_FONDOS_HAB INTO FON_HAB;
          END LOOP;
          CLOSE C_FONDOS_HAB;
        END IF;
        IF v_valida_parametro = 'N' THEN
          OPEN C_FECHA (FON1.FON_CODIGO);
          FETCH C_FECHA INTO FEC1;
          IF C_FECHA%NOTFOUND THEN
             RAISE NO_FECHA;
          END IF;
          CLOSE C_FECHA;
          OPEN C_CUENTAS(FON1.FON_CODIGO);
          FETCH C_CUENTAS INTO CFO1;
          WHILE C_CUENTAS%FOUND LOOP
             DBMS_OUTPUT.PUT_LINE(TO_CHAR(CFO1.CFO_CCC_CLI_PER_NUM_IDEN)||' '
                      ||  FON1.FON_CODIGO);
             OPEN C_MOVIMIENTOS(v_fecha_proceso);
             FETCH C_MOVIMIENTOS INTO MCF1;
             CLOSE C_MOVIMIENTOS;
             OPEN C_MOVIMIENTOS_COM;
             FETCH C_MOVIMIENTOS_COM INTO MCF1_COM;
             CLOSE C_MOVIMIENTOS_COM;
             MCF1.SUMA         := NVL(MCF1.SUMA,0)+NVL(MCF1_COM.SUMA,0);
             MCF1.SUMA_CAPITAL := NVL(MCF1.SUMA_CAPITAL,0)+NVL(MCF1_COM.SUMA_CAPITAL,0);
             IF CFO1.CFO_SALDO_UNIDADES < MCF1.SUMA THEN
                MCF1.SUMA := CFO1.CFO_SALDO_UNIDADES;
                MCF1.SUMA_CAPITAL := CFO1.CFO_SALDO_CAPITAL;
             END IF;
             UPDATE CUENTAS_FONDOS
             SET    CFO_SALDO_UNIDADES_NO_DISP = (MCF1.SUMA_CAPITAL/FEC1.VFO_VALOR) + CFO_UNIDADES_NO_DISP_RC -- OMORA
                   ,CFO_SALDO_NO_DISPONIBLE = MCF1.SUMA_CAPITAL + CFO_SALDO_NO_DISPONIBLE_RC -- OMORA
             WHERE  CURRENT OF C_CUENTAS;
             FETCH C_CUENTAS INTO CFO1;
          END LOOP;
          CLOSE C_CUENTAS;
        END IF;
      END IF;
      FETCH C_FONDOS INTO FON1;
   END LOOP;
   CLOSE C_FONDOS;
   -- REGISTRO DE FECHA Y HORA DE FIN DEL PROCESO
   P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_ORDENES_FONDOS.P_SALDOS_NO_DISPONIBLES', 'FIN');
   COMMIT;
   EXCEPTION
     WHEN NO_PARAMETRO THEN
        P_MAIL.ENVIO_MAIL_ERROR('Error en P_ORDENES_FONDOS.P_SALDOS_NO_DISPONIBLES ','No se encontro valores para el parametor de dias habiles 60 o 61');
        RAISE_APPLICATION_ERROR(-20001,'Error en P_ORDENES_FONDOS.P_SALDOS_NO_DISPONIBLES '||'No se encontro valores para el parametor de dias habiles 60 o 61'||SQLERRM);
     WHEN NO_FECHA THEN
        P_MAIL.ENVIO_MAIL_ERROR('Error en P_ORDENES_FONDOS.P_SALDOS_NO_DISPONIBLES ','No se encontro fecha de valorizacion');
        RAISE_APPLICATION_ERROR(-20001,'Error en P_ORDENES_FONDOS.P_SALDOS_NO_DISPONIBLES '||'No se encontro fecha de valorizacion'||SQLERRM);
     WHEN OTHERS THEN
       P_MAIL.ENVIO_MAIL_ERROR('Error en P_ORDENES_FONDOS.P_SALDOS_NO_DISPONIBLES ',SQLERRM);
       RAISE_APPLICATION_ERROR(-20002,'Error en P_ORDENES_FONDOS.P_SALDOS_NO_DISPONIBLES '||SQLERRM);
END P_SALDOS_NO_DISPONIBLES;

FUNCTION  F_VALIDA_ORDENES_FONDOS(P_CLI_PER_NUM_IDEN   VARCHAR,
                                  P_CLI_PER_TID_CODIGO VARCHAR2,
                                  P_CCC_NUMERO_CUENTA  NUMBER,
                                  P_CFO_FON_CODIGO     VARCHAR2,
                                  P_CFO_CODIGO         NUMBER,
                                  P_FECHA              DATE) RETURN BOOLEAN  IS
  CURSOR c1 IS
    SELECT COUNT(*)
    FROM ordenes_fondos
    WHERE  ofo_cfo_ccc_cli_per_num_iden   = P_CLI_PER_NUM_IDEN
      AND  ofo_cfo_ccc_cli_per_tid_codigo = P_CLI_PER_TID_CODIGO
      AND  ofo_cfo_ccc_numero_cuenta      = P_CCC_NUMERO_CUENTA
      AND  ofo_cfo_fon_codigo             = P_CFO_FON_CODIGO
      AND  ofo_cfo_codigo                 = P_CFO_CODIGO
      AND  ofo_eof_codigo                 IN ('COL','APL','CON')
      AND  ofo_fecha_captura              > P_FECHA;
  v_count NUMBER(5);
BEGIN
  v_count  := 0;
  OPEN c1;
  FETCH c1 INTO v_count;
  CLOSE c1;
  v_count := nvl(v_count,0);
  IF nvl(v_count,0) > 1 THEN
    RETURN(TRUE);
  ELSE
    RETURN(FALSE);
  END IF;
  EXCEPTION
     WHEN OTHERS THEN
       RAISE_APPLICATION_ERROR(-20010,'Error en P_ORDENES_FONDOS.F_VALIDA_ORDENES_FONDOS '||SQLERRM);
END F_VALIDA_ORDENES_FONDOS;
/***********************************************************
  Procedimientos y Funciones para el manejo
  de penalizaciones
*/
PROCEDURE P_OBTIENE_PENALIZACION(P_FON_CODIGO       IN VARCHAR2
                                ,P_FECHA_INICIAL    IN DATE
                                ,P_FECHA_FINAL      IN DATE
                                ,P_PEN_CONSECUTIVO  OUT NUMBER
                                ,P_PEN_PORCENTAJE   OUT NUMBER) IS
  CURSOR penalizacion(P_DIAS NUMBER) is
    SELECT pen_fon_codigo
          ,pen_consecutivo
          ,pen_periodo_inicial
          ,pen_periodo_final
          ,pen_porcentaje
     FROM penalizaciones
     WHERE pen_fon_codigo = P_FON_CODIGO
       AND p_dias BETWEEN pen_periodo_inicial AND pen_periodo_final;
  c_penalizacion              penalizacion%ROWTYPE;
  v_dias                      NUMBER;
  no_datos_penalizacion       EXCEPTION;
BEGIN
  v_dias := 0;
  v_dias := TRUNC(P_FECHA_FINAL) - TRUNC(P_FECHA_INICIAL);
  OPEN penalizacion(P_DIAS => v_dias);
  FETCH penalizacion INTO c_penalizacion;
  IF penalizacion%NOTFOUND THEN
    RAISE no_datos_penalizacion;
  ELSE
    P_PEN_CONSECUTIVO  := c_penalizacion.pen_consecutivo;
    P_PEN_PORCENTAJE   := c_penalizacion.pen_porcentaje;
  END IF;
  CLOSE penalizacion;
  EXCEPTION
    WHEN no_datos_penalizacion THEN
       RAISE_APPLICATION_ERROR(-20100,'No existe rango de penalizacion de:'||v_dias||' dias, para el fondo:'||P_FON_CODIGO);
    WHEN OTHERS THEN
       RAISE_APPLICATION_ERROR(-20110,'Error en P_ORDENES_FONDOS.P_OBTIENE_PENALIZACION '||SQLERRM);
END P_OBTIENE_PENALIZACION;
PROCEDURE P_ACTUALIZA_PORCENTAJE(P_FON_CODIGO    IN VARCHAR2,
                                 P_FECHA_PROCESO IN DATE) IS

   CURSOR upf IS
      SELECT /*+ INDEX (upf UPF_PEN_FK_I) */
             upf_consecutivo
            ,upf_fecha
            ,upf_fecha_disponible
            ,upf_fecha_pago
            ,upf_unidades_por_penalizar
            ,upf_eof_codigo
            ,upf_cfo_ccc_cli_per_num_iden
            ,upf_cfo_ccc_cli_per_tid_codigo
            ,upf_cfo_ccc_numero_cuenta
            ,upf_cfo_fon_codigo
            ,upf_cfo_codigo
            ,upf_ofo_suc_codigo
            ,upf_ofo_consecutivo
            ,upf_pen_fon_codigo
            ,upf_pen_consecutivo
            ,upf_penalizar
      FROM   unidades_penalizaciones_fondos upf
      WHERE  upf_eof_codigo = 'APR'
      AND    upf_pen_fon_codigo = P_FON_CODIGO
      AND    upf_unidades_por_penalizar > 0;
   c_upf                 upf%ROWTYPE;
   v_pen_consecutivo     penalizaciones.pen_consecutivo%TYPE;
   v_pen_porcentaje      penalizaciones.pen_porcentaje%TYPE;
   no_datos_penalizacion EXCEPTION;
   FECHA_DISPONIBLE      DATE;
   FECHA_PAGO            DATE;
   DIAS                  NUMBER;

   CURSOR C_ORDENES IS
      SELECT DISTINCT OFO_CFO_CCC_CLI_PER_NUM_IDEN
            ,OFO_CFO_CCC_CLI_PER_TID_CODIGO
            ,OFO_CFO_CCC_NUMERO_CUENTA
            ,OFO_CFO_FON_CODIGO
            ,OFO_CFO_CODIGO
            ,CFO_SALDO_UNIDADES
      FROM   ORDENES_FONDOS
            ,CUENTAS_FONDOS
      WHERE  OFO_CFO_FON_CODIGO = P_FON_CODIGO
      AND    OFO_FECHA_EJECUCION >= TRUNC(SYSDATE - 1)
      AND    OFO_FECHA_EJECUCION < TRUNC(SYSDATE)
      AND    OFO_EOF_CODIGO = 'APR'
      AND    OFO_CFO_CCC_CLI_PER_NUM_IDEN = CFO_CCC_CLI_PER_NUM_IDEN
      AND    OFO_CFO_CCC_CLI_PER_TID_CODIGO = CFO_CCC_CLI_PER_TID_CODIGO
      AND    OFO_CFO_CCC_NUMERO_CUENTA = CFO_CCC_NUMERO_CUENTA
      AND    OFO_CFO_FON_CODIGO = CFO_FON_CODIGO
      AND    OFO_CFO_CODIGO = CFO_CODIGO
      AND    CFO_SALDO_UNIDADES != 0;
   OFO1  C_ORDENES%ROWTYPE;

   CURSOR C_TOTAL_APORTES_VIG IS
      SELECT SUM(UPF_UNIDADES_POR_PENALIZAR)
      FROM   UNIDADES_PENALIZACIONES_FONDOS
      WHERE  UPF_CFO_CCC_CLI_PER_NUM_IDEN = OFO1.OFO_CFO_CCC_CLI_PER_NUM_IDEN
      AND    UPF_CFO_CCC_CLI_PER_TID_CODIGO = OFO1.OFO_CFO_CCC_CLI_PER_TID_CODIGO
      AND    UPF_CFO_CCC_NUMERO_CUENTA = OFO1.OFO_CFO_CCC_NUMERO_CUENTA
      AND    UPF_CFO_FON_CODIGO = OFO1.OFO_CFO_FON_CODIGO
      AND    UPF_CFO_CODIGO = OFO1.OFO_CFO_CODIGO
      AND    UPF_EOF_CODIGO = 'APR';
   TOTAL NUMBER;

   CURSOR C_APORTE IS
      SELECT UPF_CONSECUTIVO
      FROM   UNIDADES_PENALIZACIONES_FONDOS
      WHERE  UPF_CFO_CCC_CLI_PER_NUM_IDEN = OFO1.OFO_CFO_CCC_CLI_PER_NUM_IDEN
      AND    UPF_CFO_CCC_CLI_PER_TID_CODIGO = OFO1.OFO_CFO_CCC_CLI_PER_TID_CODIGO
      AND    UPF_CFO_CCC_NUMERO_CUENTA = OFO1.OFO_CFO_CCC_NUMERO_CUENTA
      AND    UPF_CFO_FON_CODIGO = OFO1.OFO_CFO_FON_CODIGO
      AND    UPF_CFO_CODIGO = OFO1.OFO_CFO_CODIGO
      AND    UPF_EOF_CODIGO = 'APR'
      ORDER BY UPF_PEN_CONSECUTIVO DESC;
   UPF1   C_APORTE%ROWTYPE;
   -- PARAMETROS PARA REGISTRO DE INICIO/FIN DE PROCESO
   P_NUM_INI NUMBER;
   P_NUM_FIN NUMBER;
BEGIN
   -- REGISTRO DE FECHA Y HORA DE INICIO DEL PROCESO
   P_NUM_INI := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_ORDENES_FONDOS.P_ACTUALIZA_PORCENTAJE', 'INI');
   /*  Las siguientes dos instrucciones es para replicar los saldos de las unidades que quedaron del ingreso
       original cuando se hace una redencion parcial de un tramo ESTE PROCEDIMIENTO SE DEBE LLAMAR
       SOLO EN EL PROCESO NOCTURNO O DE LO CONTRARIO SE GENERA UN PROBLEMA CON LOS RETIROS PARCIALES */

   INSERT INTO UNIDADES_PENALIZACIONES_FONDOS
      (UPF_CONSECUTIVO
      ,UPF_FECHA
      ,UPF_FECHA_DISPONIBLE
      ,UPF_FECHA_PAGO
      ,UPF_UNIDADES_POR_PENALIZAR
      ,UPF_EOF_CODIGO
      ,UPF_CFO_CCC_CLI_PER_NUM_IDEN
      ,UPF_CFO_CCC_CLI_PER_TID_CODIGO
      ,UPF_CFO_CCC_NUMERO_CUENTA
      ,UPF_CFO_FON_CODIGO
      ,UPF_CFO_CODIGO
      ,UPF_OFO_SUC_CODIGO
      ,UPF_OFO_CONSECUTIVO
      ,UPF_PEN_FON_CODIGO
      ,UPF_PEN_CONSECUTIVO
      ,UPF_USUARIO_CREACION
      ,UPF_FECHA_CREACION
      ,UPF_TERMINAL_CREACION
      ,UPF_INSTRUCCION
      ,UPF_UPF_CONSECUTIVO
      ,UPF_PENALIZAR)
   SELECT UPF_SEQ.NEXTVAL
         ,UPF_FECHA
         ,UPF_FECHA_DISPONIBLE
         ,UPF_FECHA_PAGO
         ,UPF_UNIDADES_POR_PENALIZAR
         ,UPF_EOF_CODIGO
         ,UPF_CFO_CCC_CLI_PER_NUM_IDEN
         ,UPF_CFO_CCC_CLI_PER_TID_CODIGO
         ,UPF_CFO_CCC_NUMERO_CUENTA
         ,UPF_CFO_FON_CODIGO
         ,UPF_CFO_CODIGO
         ,UPF_OFO_SUC_CODIGO
         ,UPF_OFO_CONSECUTIVO
         ,UPF_PEN_FON_CODIGO
         ,UPF_PEN_CONSECUTIVO
         ,UPF_USUARIO_CREACION
         ,UPF_FECHA_CREACION
         ,UPF_TERMINAL_CREACION
         ,NULL
         ,UPF_CONSECUTIVO
         ,UPF_PENALIZAR
   FROM   UNIDADES_PENALIZACIONES_FONDOS
   WHERE  UPF_CFO_FON_CODIGO = P_FON_CODIGO
   AND    UPF_EOF_CODIGO = 'APR'
   AND    UPF_INSTRUCCION = 'RPO';

   UPDATE UNIDADES_PENALIZACIONES_FONDOS
   SET    UPF_EOF_CODIGO = 'ANU'
   WHERE  UPF_CFO_FON_CODIGO = P_FON_CODIGO
   AND    UPF_EOF_CODIGO = 'APR'
   AND    UPF_INSTRUCCION = 'RPO';


   OPEN upf;
   FETCH upf INTO c_upf;
   WHILE upf%FOUND LOOP
      -- Se verifica si el movimiento es migrado el cual quedara el primer mes sin penalizacion
      -- Se pregunta si la fecha de proceso es mayor o igual a la fecha de disponible
      -- En caso que sea mayor se pregunta si la fecha de proceso es menor o igual a la de pago
      -- En caso verdadero implica que es una redencion que todavia no tiene pago y la penalizacion debe ser cero
      -- En caso contrario toca renovar la fecha de disponibilidad y de pago con la periodicidad de permanencia y
      -- actualizar la penalizacion
      -- Si no es redencion ni renovacion se debe aplicar el nuevo porcentaje de penalizacion a la permanencia faltante

      IF NVL(C_UPF.UPF_PENALIZAR,'S') = 'N' THEN
         IF TO_DATE('22-04-2013','DD-MM-YYYY') < TRUNC(P_FECHA_PROCESO) THEN
            UPDATE UNIDADES_PENALIZACIONES_FONDOS
            SET    UPF_PENALIZAR = 'S'
            WHERE  UPF_CONSECUTIVO = C_UPF.UPF_CONSECUTIVO;
            C_UPF.UPF_PENALIZAR := 'S';
         END IF;
      END IF;

      IF NVL(C_UPF.UPF_PENALIZAR,'S') = 'S' THEN
      P_ORDENES_FONDOS.P_OBTIENE_PENALIZACION(P_FON_CODIGO       => P_FON_CODIGO
                                             ,P_FECHA_INICIAL    => TRUNC(P_FECHA_PROCESO)
                                             ,P_FECHA_FINAL      => TRUNC(c_upf.upf_fecha_disponible)
                                             ,P_PEN_CONSECUTIVO  => v_pen_consecutivo
                                             ,P_PEN_PORCENTAJE   => v_pen_porcentaje);

         IF v_pen_consecutivo IS NULL THEN
            CLOSE upf;
            RAISE no_datos_penalizacion;
         END IF;
         UPDATE unidades_penalizaciones_fondos
         SET    upf_pen_consecutivo = v_pen_consecutivo
         WHERE  upf_consecutivo = c_upf.upf_consecutivo;
      END IF;
      FETCH upf INTO c_upf;
   END LOOP;
   CLOSE upf;

   /* Por lo retiros se generan diferencias en el cuarto decimal entre las unidades de los aportes y el saldo de unidades
      del cliente en la cuenta. Las siguientes instrucciones ajustan estas diferencias dejandolas en el titulo de menor
      penalización*/
   OPEN C_ORDENES;
   FETCH C_ORDENES INTO OFO1;
   WHILE C_ORDENES%FOUND LOOP
      IF OFO1.CFO_SALDO_UNIDADES != 0 THEN
         TOTAL := 0;
         OPEN C_TOTAL_APORTES_VIG;
         FETCH C_TOTAL_APORTES_VIG INTO TOTAL;
         CLOSE C_TOTAL_APORTES_VIG;

         TOTAL := NVL(TOTAL,0);
         IF TOTAL != 0 AND
            TOTAL != OFO1.CFO_SALDO_UNIDADES THEN
            TOTAL := OFO1.CFO_SALDO_UNIDADES - TOTAL;

            OPEN C_APORTE;
            FETCH C_APORTE INTO UPF1;
            IF C_APORTE%FOUND THEN
               CLOSE C_APORTE;
               UPDATE UNIDADES_PENALIZACIONES_FONDOS
               SET    UPF_UNIDADES_POR_PENALIZAR = UPF_UNIDADES_POR_PENALIZAR + TOTAL
               WHERE  UPF_CONSECUTIVO = UPF1.UPF_CONSECUTIVO;
            ELSE
               CLOSE C_APORTE;
            END IF;
         END IF;
      END IF;
      FETCH C_ORDENES INTO OFO1;
   END LOOP;
   CLOSE C_ORDENES;
   -- REGISTRO DE FECHA Y HORA DE FIN DEL PROCESO
   P_NUM_FIN := P_TOOLS.FN_REGISTRA_PROCESO_NOCTURNO('P_ORDENES_FONDOS.P_ACTUALIZA_PORCENTAJE', 'FIN');
   COMMIT;
EXCEPTION
   WHEN no_datos_penalizacion THEN
      Raise_Application_Error(-20110,'Error en obtener valor penalizacion fondo:'||P_FON_CODIGO);
   WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20130,'Error en P_ORDENES_FONDOS.P_ACTUALIZA_PORCENTAJE '||C_UPF.UPF_CFO_CCC_CLI_PER_NUM_IDEN
      || ' Cons. ' || C_UPF.UPF_CONSECUTIVO || 'Fecha Ini: ' ||TRUNC(P_FECHA_PROCESO)
      || 'Fecha Fin: ' || TRUNC(C_UPF.UPF_FECHA_DISPONIBLE) ||SQLERRM);
END P_ACTUALIZA_PORCENTAJE;
PROCEDURE P_CALCULO_PENALIZACION(P_OFO_CFO_CCC_CLI_PER_NUM_IDEN   IN VARCHAR2
                                ,P_OFO_CFO_CCC_CLI_PER_TID_CODI   IN VARCHAR2
                                ,P_OFO_CFO_CCC_NUMERO_CUENTA      IN NUMBER
                                ,P_OFO_CFO_FON_CODIGO             IN VARCHAR2
                                ,P_OFO_CFO_CODIGO                 IN NUMBER
                                ,P_FECHA_PROCESO                  IN DATE
                                ,P_UNIDADES_MOVIMIENTO            IN NUMBER
                                ,P_TIPO_OPERACION                 IN VARCHAR2
                                ,P_VALOR_PENALIZACION             IN OUT NUMBER
                                ,P_UNIDADES_PENALIZACION          IN OUT NUMBER) IS
   CURSOR upf IS
     SELECT
           upf_consecutivo
          ,upf_fecha
          ,upf_fecha_disponible
          ,upf_unidades_por_penalizar
          ,upf_eof_codigo
          ,upf_cfo_ccc_cli_per_num_iden
          ,upf_cfo_ccc_cli_per_tid_codigo
          ,upf_cfo_ccc_numero_cuenta
          ,upf_cfo_fon_codigo
          ,upf_cfo_codigo
          ,upf_ofo_suc_codigo
          ,upf_ofo_consecutivo
          ,upf_pen_fon_codigo
          ,upf_pen_consecutivo
          ,pen_porcentaje
    FROM penalizaciones,unidades_penalizaciones_fondos upf
    WHERE pen_fon_codigo = upf_pen_fon_codigo
      AND pen_consecutivo = upf_pen_consecutivo
      AND upf_eof_codigo = 'APR'
      AND upf_cfo_ccc_cli_per_num_iden    = P_OFO_CFO_CCC_CLI_PER_NUM_IDEN
      AND upf_cfo_ccc_cli_per_tid_codigo  = P_OFO_CFO_CCC_CLI_PER_TID_CODI
      AND upf_cfo_ccc_numero_cuenta       = P_OFO_CFO_CCC_NUMERO_CUENTA
      AND upf_cfo_fon_codigo              = P_OFO_CFO_FON_CODIGO
      AND upf_cfo_codigo                  = P_OFO_CFO_CODIGO
      AND upf_unidades_por_penalizar      > 0
      AND upf_fecha_pago                  >= TRUNC(P_FECHA_PROCESO)
      ORDER BY upf_fecha_pago;
  CURSOR vfo IS
    SELECT vfo_valor
    FROM  valorizaciones_fondo
    WHERE vfo_fon_codigo= P_OFO_CFO_FON_CODIGO
      AND vfo_fecha_valorizacion >= TRUNC(P_FECHA_PROCESO)
      AND vfo_fecha_valorizacion <  TRUNC(P_FECHA_PROCESO+1);
  TYPE uni IS RECORD
  (p_upf_consecutivo           NUMBER,
   p_upf_unid_penalizar        NUMBER(18,8),
   p_pen_porcentaje            NUMBER(5,3));
  TYPE r_uni IS TABLE OF uni INDEX BY BINARY_INTEGER;
  array_uni               r_uni;
  v_unidades_penalizacion     unidades_penalizaciones_fondos.upf_unidades_por_penalizar%TYPE;
  v_saldo_uni_penalizacion    unidades_penalizaciones_fondos.upf_unidades_por_penalizar%TYPE;
  v_valor_penalizacion        unidades_penalizaciones_fondos.upf_unidades_por_penalizar%TYPE;
  c_upf                   upf%ROWTYPE;
  c_vfo                   vfo%ROWTYPE;
  ERROR                   EXCEPTION;
  ERROR_UNIDAD            EXCEPTION;
  v_registro              NUMBER;
  v_valida                VARCHAR2(1);
BEGIN
  array_uni.DELETE;
  v_unidades_penalizacion := 0;
  v_valor_penalizacion    := 0;
  v_unidades_penalizacion := ROUND(P_UNIDADES_MOVIMIENTO,8);
  v_saldo_uni_penalizacion    := v_unidades_penalizacion;
  v_valida := 'N';
  v_valida := P_FACTURAS.F_VALIDA_CONFIRMACION_VAL(P_FONDO =>  P_OFO_CFO_FON_CODIGO, P_FECHA => P_FECHA_PROCESO);
  IF NVL(v_valida,'N') = 'N' THEN
    RAISE ERROR;
  END IF;
  OPEN vfo;
  FETCH vfo INTO c_vfo;
  IF vfo%NOTFOUND THEN
    RAISE ERROR_UNIDAD;
  END IF;
  CLOSE vfo;
  OPEN upf;
  FETCH upf INTO c_upf;
  WHILE upf%FOUND LOOP
    v_registro := array_uni.COUNT();
    array_uni(v_registro).p_upf_consecutivo    := c_upf.upf_consecutivo;
    array_uni(v_registro).p_upf_unid_penalizar := c_upf.upf_unidades_por_penalizar;
    array_uni(v_registro).p_pen_porcentaje     := c_upf.pen_porcentaje;
    FETCH upf INTO c_upf;
  END LOOP;
  CLOSE upf;
  IF array_uni.COUNT() > 0 THEN
    IF P_TIPO_OPERACION = 'RP' THEN
      FOR reg IN array_uni.FIRST .. array_uni.LAST LOOP
       IF v_saldo_uni_penalizacion > 0 THEN
         IF array_uni(reg).p_upf_unid_penalizar <= v_saldo_uni_penalizacion THEN
           v_valor_penalizacion := ROUND((v_valor_penalizacion+(array_uni(reg).p_upf_unid_penalizar *array_uni(reg).p_pen_porcentaje)),8);
           v_saldo_uni_penalizacion := v_saldo_uni_penalizacion - array_uni(reg).p_upf_unid_penalizar;
        ELSE
           v_valor_penalizacion := ROUND((v_valor_penalizacion+(v_saldo_uni_penalizacion *array_uni(reg).p_pen_porcentaje)),8);
           v_saldo_uni_penalizacion := 0;
         END IF;
       ELSE
         EXIT;
       END IF;
      END LOOP;
    ELSE -- PENALIZACION POR RETIRO TOTAL
      FOR reg IN array_uni.FIRST .. array_uni.LAST LOOP
       v_valor_penalizacion := ROUND((v_valor_penalizacion+(array_uni(reg).p_upf_unid_penalizar *array_uni(reg).p_pen_porcentaje)),8);
       v_saldo_uni_penalizacion := v_saldo_uni_penalizacion - array_uni(reg).p_upf_unid_penalizar;
      END LOOP;
    END IF;
  ELSE
    v_unidades_penalizacion := 0;
    v_valor_penalizacion    := 0;
  END IF;
  P_VALOR_PENALIZACION             := ROUND(v_valor_penalizacion*c_vfo.vfo_valor,2);
  P_UNIDADES_PENALIZACION          := ROUND(v_valor_penalizacion,8);
  EXCEPTION
    WHEN ERROR THEN
       RAISE_APPLICATION_ERROR(-20140,'No se ha valorizado el fondo para la fecha :'|| P_FECHA_PROCESO);
    WHEN ERROR_UNIDAD THEN
       RAISE_APPLICATION_ERROR(-20141,'No se encontro valor unidad del fondo para la fecha :'|| P_FECHA_PROCESO);
END P_CALCULO_PENALIZACION;
PROCEDURE P_UPD_PENALIZACION(P_OFO_CFO_CCC_CLI_PER_NUM_IDEN   IN VARCHAR2
                            ,P_OFO_CFO_CCC_CLI_PER_TID_CODI   IN VARCHAR2
                            ,P_OFO_CFO_CCC_NUMERO_CUENTA      IN NUMBER
                            ,P_OFO_CFO_FON_CODIGO             IN VARCHAR2
                            ,P_OFO_CFO_CODIGO                 IN NUMBER
                            ,P_FECHA_PROCESO                  IN DATE
                            ,P_UNIDADES_MOVIMIENTO            IN NUMBER
                            ,P_TIPO_OPERACION                 IN VARCHAR2) IS
   CURSOR upf IS
     SELECT
           upf_consecutivo
          ,upf_fecha
          ,upf_fecha_disponible
          ,upf_unidades_por_penalizar
          ,upf_eof_codigo
          ,upf_cfo_ccc_cli_per_num_iden
          ,upf_cfo_ccc_cli_per_tid_codigo
          ,upf_cfo_ccc_numero_cuenta
          ,upf_cfo_fon_codigo
          ,upf_cfo_codigo
          ,upf_ofo_suc_codigo
          ,upf_ofo_consecutivo
          ,upf_pen_fon_codigo
          ,upf_pen_consecutivo
          ,pen_porcentaje
    FROM penalizaciones,unidades_penalizaciones_fondos upf
    WHERE pen_fon_codigo = upf_pen_fon_codigo
      AND pen_consecutivo = upf_pen_consecutivo
      AND upf_eof_codigo = 'APR'
      AND upf_cfo_ccc_cli_per_num_iden    = P_OFO_CFO_CCC_CLI_PER_NUM_IDEN
      AND upf_cfo_ccc_cli_per_tid_codigo  = P_OFO_CFO_CCC_CLI_PER_TID_CODI
      AND upf_cfo_ccc_numero_cuenta       = P_OFO_CFO_CCC_NUMERO_CUENTA
      AND upf_cfo_fon_codigo              = P_OFO_CFO_FON_CODIGO
      AND upf_cfo_codigo                  = P_OFO_CFO_CODIGO
      AND upf_unidades_por_penalizar      > 0
      AND upf_fecha_pago                  >= TRUNC(P_FECHA_PROCESO)
      ORDER BY upf_fecha_pago;
  TYPE uni IS RECORD
  (p_upf_consecutivo           NUMBER,
   p_upf_unid_penalizar        NUMBER(18,8),
   p_pen_porcentaje            NUMBER(5,3),
   p_unidades_redimir_tramo    NUMBER(18,8),
   p_eof_codigo                VARCHAR2(3));
  TYPE r_uni IS TABLE OF uni INDEX BY BINARY_INTEGER;
  array_uni               r_uni;
  v_unidades_penalizacion unidades_penalizaciones_fondos.upf_unidades_por_penalizar%TYPE;
  v_saldo_uni_penalizacion    unidades_penalizaciones_fondos.upf_unidades_por_penalizar%TYPE;
  c_upf                   upf%ROWTYPE;
  ERROR                   EXCEPTION;
  v_registro              NUMBER;
  v_valida                VARCHAR2(1);
BEGIN
  array_uni.DELETE;
  v_unidades_penalizacion := 0;
  v_unidades_penalizacion := P_UNIDADES_MOVIMIENTO;
  v_saldo_uni_penalizacion    := v_unidades_penalizacion;
  v_valida := 'N';
  v_valida := P_FACTURAS.F_VALIDA_CONFIRMACION_VAL(P_FONDO =>  P_OFO_CFO_FON_CODIGO, P_FECHA => P_FECHA_PROCESO);
  IF NVL(v_valida,'N') = 'N' THEN
    RAISE ERROR;
  END IF;
  OPEN upf;
  FETCH upf INTO c_upf;
  WHILE upf%FOUND LOOP
    v_registro := array_uni.COUNT();
    array_uni(v_registro).p_upf_consecutivo        := c_upf.upf_consecutivo;
    array_uni(v_registro).p_upf_unid_penalizar     := c_upf.upf_unidades_por_penalizar;
    array_uni(v_registro).p_pen_porcentaje         := c_upf.pen_porcentaje;
    array_uni(v_registro).p_unidades_redimir_tramo := 0;
    array_uni(v_registro).p_eof_codigo             := c_upf.upf_eof_codigo;
    FETCH upf INTO c_upf;
  END LOOP;
  CLOSE upf;
  IF array_uni.COUNT() > 0 THEN
    IF P_TIPO_OPERACION = 'RP' THEN
      FOR reg IN array_uni.FIRST .. array_uni.LAST LOOP
       IF v_saldo_uni_penalizacion > 0 THEN
         IF array_uni(reg).p_upf_unid_penalizar <= v_saldo_uni_penalizacion THEN
           v_saldo_uni_penalizacion := v_saldo_uni_penalizacion - array_uni(reg).p_upf_unid_penalizar;
           array_uni(reg).p_upf_unid_penalizar  := 0;
           array_uni(reg).p_unidades_redimir_tramo := 0;
           array_uni(reg).p_eof_codigo := 'ANU';
         ELSE
           array_uni(reg).p_upf_unid_penalizar     := array_uni(reg).p_upf_unid_penalizar - v_saldo_uni_penalizacion;
           array_uni(reg).p_unidades_redimir_tramo := array_uni(reg).p_upf_unid_penalizar;
           --array_uni(reg).p_eof_codigo             := 'CON';
           v_saldo_uni_penalizacion := 0;
         END IF;
       ELSE
         EXIT;
       END IF;
      END LOOP;
      FOR reg IN array_uni.FIRST .. array_uni.LAST LOOP
         UPDATE unidades_penalizaciones_fondos
           SET upf_unidades_por_penalizar  = array_uni(reg).p_upf_unid_penalizar
              ,upf_unidades_redimir_tramo  = array_uni(reg).p_unidades_redimir_tramo
              ,upf_eof_codigo              = array_uni(reg).p_eof_codigo
              ,upf_usuario_modificacion    = user
              ,upf_fecha_modificacion      = p_fecha_proceso
              ,upf_terminal_modificacion   = NVL(FN_TERMINAL,'PROD') -- OJO PRUEBAS
           WHERE upf_consecutivo = array_uni(reg).p_upf_consecutivo;
      END LOOP;
    ELSE  -- RETIRO TOTAL
      FOR reg IN array_uni.FIRST .. array_uni.LAST LOOP
         UPDATE unidades_penalizaciones_fondos
           SET upf_unidades_por_penalizar = 0
              ,upf_unidades_redimir_tramo = 0
              , upf_eof_codigo = 'ANU'
              ,upf_usuario_modificacion  = user
              ,upf_fecha_modificacion = p_fecha_proceso
              ,upf_terminal_modificacion = NVL(FN_TERMINAL,'PROD') -- OOJ PRUEBAS
           WHERE upf_consecutivo = array_uni(reg).p_upf_consecutivo;
      END LOOP;
    END IF;
  END IF;
  EXCEPTION
    WHEN ERROR THEN
       RAISE_APPLICATION_ERROR(-20140,'No se ha valorizado el fondo para la fecha :'|| P_FECHA_PROCESO);
    WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20145,'Error en P_ORDENES_FONDOS.P_UPD_PENALIZACION '||SQLERRM);
END P_UPD_PENALIZACION;
PROCEDURE P_INS_MOVIMIENTOS_FONDOS
  (
    P_FECHA_PROCESO                IN     DATE ,
    P_TIPO_ORDEN                   IN     VARCHAR2 ,
    P_OFO_SUC_CODIGO               IN     NUMBER,
    P_OFO_CONSECUTIVO              IN     NUMBER,
    P_OFO_MONTO                    IN OUT NUMBER,
    P_OFO_CFO_CCC_CLI_PER_NUM_IDEN IN     VARCHAR2,
    P_OFO_CFO_CCC_CLI_PER_TID_CODI IN     VARCHAR2,
    P_OFO_CFO_CCC_NUMERO_CUENTA    IN     NUMBER,
    P_OFO_CFO_FON_CODIGO           IN     VARCHAR2,
    P_OFO_CFO_CODIGO               IN     NUMBER,
    P_OFO_FECHA_EJECUCION          IN OUT DATE,
    P_EXC                          IN OUT VARCHAR2,
    P_OFO_MONTO_CARGO_ABONO_CUENTA IN OUT NUMBER,
    P_FECHA_ACTUALIZA_MCC          IN OUT DATE,
    P_FECHA                        IN OUT DATE,
    P_OFO_REGISTRO_AUTOMATICO      IN     VARCHAR2,
    P_OFO_TTO_TOF_CODIGO           IN     VARCHAR2,
    P_OFO_FECHA_CAPTURA            IN     DATE)     IS
  CURSOR VALOR_UNIDAD   IS
     SELECT VF.VFO_VALOR DATO_VALOR_UNIDAD
       FROM VALORIZACIONES_FONDO VF
      WHERE VF.VFO_FECHA_VALORIZACION >= TRUNC(P_OFO_FECHA_EJECUCION)
    AND VF.VFO_FECHA_VALORIZACION      < TRUNC(P_OFO_FECHA_EJECUCION) + 1
    AND VF.VFO_FON_CODIGO              = P_OFO_CFO_FON_CODIGO;
  VU VALOR_UNIDAD%ROWTYPE;
  CURSOR SALDOS  IS
     SELECT CFO_SALDO_RENDIMIENTOS_RF SAL_RND_RF,
       CFO_SALDO_RENDIMIENTOS_RV       SAL_RND_RV,
       CFO_SALDO_RETEFUENTE            SAL_RET,
       CFO_SALDO_CAPITAL               SAL_CAP,
       CFO_SALDO_INVER                 SAL_INV,
       CFO_SALDO_UNIDADES              SAL_UNI,
       CFO_SALDO_INTERESES_PAGADOS     SAL_INT,
       CFO_TASA_PROMEDIO               SAL_TAS,
       CFO_SALDO_UNIDADES_NO_DISP      SAL_UND,
       SYSDATE                         SAL_FEC
     FROM CUENTAS_FONDOS
     WHERE CFO_CCC_CLI_PER_TID_CODIGO = P_OFO_CFO_CCC_CLI_PER_TID_CODI
       AND CFO_CCC_CLI_PER_NUM_IDEN   = P_OFO_CFO_CCC_CLI_PER_NUM_IDEN
       AND CFO_CCC_NUMERO_CUENTA      = P_OFO_CFO_CCC_NUMERO_CUENTA
       AND CFO_FON_CODIGO             = P_OFO_CFO_FON_CODIGO
       AND CFO_CODIGO                 = P_OFO_CFO_CODIGO;
  SAL SALDOS%ROWTYPE;
  CURSOR C_CONSTANTE  IS
     SELECT CON_VALOR FROM CONSTANTES WHERE CON_MNEMONICO = 'IBA';
  CON C_CONSTANTE%ROWTYPE;
  CURSOR TIPO_FONDO  IS
     SELECT FON_TIPO          ,
      FON_BMO_MNEMONICO       ,
      FON_RETEFUENTE          ,
      FON_TIPO_ADMINISTRACION ,
      FON_EXTERIOR_NACIONAL
       FROM FONDOS
      WHERE FON_CODIGO = P_OFO_CFO_FON_CODIGO;
  TF TIPO_FONDO%ROWTYPE;
  CURSOR C_SEGUNDO(P_PER_NUM_IDEN VARCHAR2 ,P_PER_TID_CODIGO VARCHAR2 ,P_NUMERO_CUENTA NUMBER ,P_FON_CODIGO VARCHAR2 ,P_CUENTA_FONDO NUMBER)  IS
     SELECT CFO_OCL_CLI_PER_NUM_IDEN_RELAC
       FROM CUENTAS_FONDOS
      WHERE CFO_CCC_CLI_PER_NUM_IDEN    = P_PER_NUM_IDEN
    AND CFO_CCC_CLI_PER_TID_CODIGO      = P_PER_TID_CODIGO
    AND CFO_CCC_NUMERO_CUENTA           = P_NUMERO_CUENTA
    AND CFO_FON_CODIGO                  = P_FON_CODIGO
    AND CFO_CODIGO                      = P_CUENTA_FONDO
    AND CFO_OCL_CLI_PER_NUM_IDEN_RELAC IS NOT NULL;
  IDENT VARCHAR2(20);
  CURSOR C_FONDO  IS
     SELECT OFO_CFO_CCC_CLI_PER_NUM_IDEN ,
      OFO_CFO_CCC_CLI_PER_TID_CODIGO     ,
      OFO_CFO_CCC_NUMERO_CUENTA          ,
      OFO_CFO_FON_CODIGO                 ,
      OFO_CFO_CODIGO                     ,
      OFO_FECHA_EJECUCION
     FROM ORDENES_FONDOS
     WHERE OFO_OFO_SUC_CODIGO = P_OFO_SUC_CODIGO
    AND OFO_OFO_CONSECUTIVO    = P_OFO_CONSECUTIVO;
  OFO1 C_FONDO%ROWTYPE;
  CURSOR C_MONTO(P_TIPO_PAGO VARCHAR2) IS
     SELECT SUM(ODP_MONTO_ORDEN)
       FROM ORDENES_DE_PAGO
      WHERE ODP_OFO_SUC_CODIGO = P_OFO_SUC_CODIGO
    AND ODP_OFO_CONSECUTIVO    = P_OFO_CONSECUTIVO
    AND ((P_TIPO_PAGO          = 'CHE'
    AND ODP_TPA_MNEMONICO     IN ('CHE','PSE','CHG','ACH'))
    OR (P_TIPO_PAGO            ='TCC'
    AND ODP_TPA_MNEMONICO     IN ('TCC')));
  CURSOR C_PUNTA IS
      SELECT OFO_SUC_CODIGO
            ,OFO_CONSECUTIVO
            ,OFO_EOF_CODIGO
            ,OFO_TTO_TOF_CODIGO
      FROM   ORDENES_FONDOS
      WHERE  OFO_OFO_SUC_CODIGO = P_OFO_SUC_CODIGO
      AND    OFO_OFO_CONSECUTIVO = P_OFO_CONSECUTIVO;
   R_PUNTA C_PUNTA%ROWTYPE;
   CURSOR C_ORDENES_DE_PAGO IS
      SELECT ODP_SUC_CODIGO
            ,ODP_NEG_CONSECUTIVO
            ,ODP_CONSECUTIVO
            ,ODP_MONTO_ORDEN
            ,ODP_TPA_MNEMONICO
            ,ODP_PAGAR_A
      FROM   ORDENES_DE_PAGO
      WHERE  ODP_OFO_SUC_CODIGO = P_OFO_SUC_CODIGO
      AND    ODP_OFO_CONSECUTIVO = P_OFO_CONSECUTIVO
      AND    ODP_ODP_CONSECUTIVO IS NULL;
      -- 25-jul-2011AND    ODP_ESTADO != 'ANU';
   ODP1   C_ORDENES_DE_PAGO%ROWTYPE;

   CURSOR C_DAA IS --VAGTUD271 Decreto 660
     SELECT DAA_TRASLADO_CC
     FROM DETALLES_ABONOS_CUENTAS
     WHERE DAA_OFO_CONSECUTIVO = P_OFO_CONSECUTIVO
     AND DAA_SUC_CODIGO        = P_OFO_SUC_CODIGO;
  C_DAA1 C_DAA%ROWTYPE;

  CURSOR C_ORDEN  IS --VAGTUD271 Decreto 660
     SELECT OFO_TTO_TIT_CODIGO,
            OFO_MONTO_CARGO_ABONO_CUENTA,
            OFO_CARGO_ABONO_CUENTA
     FROM ORDENES_FONDOS
     WHERE OFO_SUC_CODIGO  = P_OFO_SUC_CODIGO
     AND   OFO_CONSECUTIVO = P_OFO_CONSECUTIVO;
  ORD1 C_ORDEN%ROWTYPE;

  SALDO_INSUFICIENTE EXCEPTION;
  NO_IMP_BANCARIO    EXCEPTION;
  NO_TIPO_FONDO      EXCEPTION;
  NO_VALOR_UNIDAD    EXCEPTION;
  TOTAL_PENALIZACION        CUENTAS_FONDOS.CFO_SALDO_CAPITAL%TYPE;
  TOTAL_PENAL_UNID          CUENTAS_FONDOS.CFO_SALDO_UNIDADES%TYPE;
  TOTAL_PAGOS               ORDENES_DE_PAGO.ODP_MONTO_ORDEN%TYPE;
  TOTAL_PAGOS_TCC           ORDENES_DE_PAGO.ODP_MONTO_ORDEN%TYPE;
  TOTAL_GASTOS              CUENTAS_FONDOS.CFO_SALDO_CAPITAL%TYPE;
  TOTAL_GASTOS_UND          CUENTAS_FONDOS.CFO_SALDO_UNIDADES%TYPE;
  TOTAL_IMP_GASTOS          CUENTAS_FONDOS.CFO_SALDO_CAPITAL%TYPE;
  TOTAL_IMP_GASTOS_UND      CUENTAS_FONDOS.CFO_SALDO_UNIDADES%TYPE;
  IMPUESTO                  CUENTAS_FONDOS.CFO_SALDO_CAPITAL%TYPE;
  IMP_UNID                  CUENTAS_FONDOS.CFO_SALDO_UNIDADES%TYPE;
  IMPUESTO1                 CUENTAS_FONDOS.CFO_SALDO_CAPITAL%TYPE;
  IMP_UNID1                 CUENTAS_FONDOS.CFO_SALDO_UNIDADES%TYPE;
  UNIDADES_OFO_MONTO        CUENTAS_FONDOS.CFO_SALDO_UNIDADES%TYPE;
  RP_PRC                    NUMBER;
  REND_ORDEN                NUMBER;
  RP_CAP                    CUENTAS_FONDOS.CFO_SALDO_CAPITAL%TYPE;
  RP_UND                    CUENTAS_FONDOS.CFO_SALDO_UNIDADES%TYPE;
  RP_RND_RF                 CUENTAS_FONDOS.CFO_SALDO_CAPITAL%TYPE;
  RP_RND_RV                 CUENTAS_FONDOS.CFO_SALDO_CAPITAL%TYPE;
  RP_RET                    CUENTAS_FONDOS.CFO_SALDO_CAPITAL%TYPE;
  RP_AJU                    CUENTAS_FONDOS.CFO_SALDO_CAPITAL%TYPE;
  MONTO_ORDENES             CUENTAS_FONDOS.CFO_SALDO_CAPITAL%TYPE;
  MONTO_TCC                 CUENTAS_FONDOS.CFO_SALDO_CAPITAL%TYPE;
  V_VALOR_PENALIZACION      CUENTAS_FONDOS.CFO_SALDO_CAPITAL%TYPE;
  V_UNIDADES_PENALIZACION   CUENTAS_FONDOS.CFO_SALDO_UNIDADES%TYPE;
  P_VER_IMPUESTO            VARCHAR2(1);
  V_OFO_FECHA_EJECUCION     DATE;
  SEGUNDO                   VARCHAR2(1);
  RENDIMIENTOS               NUMBER;
BEGIN
  OPEN  VALOR_UNIDAD;
  FETCH VALOR_UNIDAD INTO VU;
  IF (VALOR_UNIDAD%NOTFOUND) THEN
    RAISE NO_VALOR_UNIDAD;
  END IF;
  CLOSE VALOR_UNIDAD;
  IF (VU.DATO_VALOR_UNIDAD = 0) THEN
    RAISE NO_VALOR_UNIDAD;
  END IF;
  OPEN SALDOS;
  FETCH SALDOS INTO SAL;
  CLOSE SALDOS;
  IF P_TIPO_ORDEN = 'RP' THEN
      OPEN TIPO_FONDO;
      FETCH TIPO_FONDO INTO TF;
      IF (TIPO_FONDO%NOTFOUND) THEN
        RAISE NO_TIPO_FONDO;
      END IF;
      CLOSE TIPO_FONDO;
      OPEN C_CONSTANTE;
      FETCH C_CONSTANTE INTO CON;
      IF C_CONSTANTE%NOTFOUND THEN
        CLOSE C_CONSTANTE;
        RAISE NO_IMP_BANCARIO;
      END IF;
      CLOSE C_CONSTANTE;
      IF (P_OFO_MONTO > SAL.SAL_INV) THEN
        RAISE SALDO_INSUFICIENTE;
      ELSE
        P_VER_IMPUESTO := 'N';
        OPEN C_FONDO;
        FETCH C_FONDO INTO OFO1;
        IF C_FONDO%FOUND THEN
          CLOSE C_FONDO;
          OPEN C_SEGUNDO(P_OFO_CFO_CCC_CLI_PER_NUM_IDEN ,P_OFO_CFO_CCC_CLI_PER_TID_CODI ,P_OFO_CFO_CCC_NUMERO_CUENTA ,P_OFO_CFO_FON_CODIGO ,P_OFO_CFO_CODIGO);
          FETCH C_SEGUNDO INTO IDENT;
          IF C_SEGUNDO%FOUND THEN
            P_VER_IMPUESTO := 'S';
            CLOSE C_SEGUNDO;
          ELSE
            P_VER_IMPUESTO := 'N';
            CLOSE C_SEGUNDO;
            OPEN C_SEGUNDO(OFO1.OFO_CFO_CCC_CLI_PER_NUM_IDEN ,OFO1.OFO_CFO_CCC_CLI_PER_TID_CODIGO ,OFO1.OFO_CFO_CCC_NUMERO_CUENTA ,OFO1.OFO_CFO_FON_CODIGO ,OFO1.OFO_CFO_CODIGO);
            FETCH C_SEGUNDO INTO IDENT;
            IF C_SEGUNDO%FOUND THEN
              P_VER_IMPUESTO := 'S';
            END IF;
            CLOSE C_SEGUNDO;
          END IF;
        ELSE
          CLOSE C_FONDO;
          P_VER_IMPUESTO := 'S';
        END IF;
        IF P_EXC = 'N'  AND    P_VER_IMPUESTO = 'S' THEN
          P_VER_IMPUESTO := 'S';
        ELSE
          P_VER_IMPUESTO := 'N';
        END IF;
        IMPUESTO1 :=0;
        IMPUESTO  :=0;
        IMP_UNID1 :=0;
        IMP_UNID  :=0;
        UNIDADES_OFO_MONTO    := ROUND(P_OFO_MONTO/VU.DATO_VALOR_UNIDAD,8);
        P_ORDENES_FONDOS.P_CALCULO_PENALIZACION(P_OFO_CFO_CCC_CLI_PER_NUM_IDEN   => P_OFO_CFO_CCC_CLI_PER_NUM_IDEN
                              ,P_OFO_CFO_CCC_CLI_PER_TID_CODI   => P_OFO_CFO_CCC_CLI_PER_TID_CODI
                              ,P_OFO_CFO_CCC_NUMERO_CUENTA      => P_OFO_CFO_CCC_NUMERO_CUENTA
                              ,P_OFO_CFO_FON_CODIGO             => P_OFO_CFO_FON_CODIGO
                              ,P_OFO_CFO_CODIGO                 => P_OFO_CFO_CODIGO
                              ,P_FECHA_PROCESO                  => P_FECHA
                              ,P_UNIDADES_MOVIMIENTO            => UNIDADES_OFO_MONTO
                              ,P_TIPO_OPERACION                 => 'RP'
                              ,P_VALOR_PENALIZACION             => V_VALOR_PENALIZACION
                              ,P_UNIDADES_PENALIZACION          => V_UNIDADES_PENALIZACION);
        IF P_VER_IMPUESTO = 'S' THEN
          IF P_OFO_MONTO_CARGO_ABONO_CUENTA IS NOT NULL THEN
             /* Se vuelva a abrir el cursor de segundo de la cuenta porque independiente de cobrar el IMGF
                si la cuenta tiene segundo titular el IMGF se cobrar sobre el monto del abono a cuenta en
                cambio si la cuenta no tiene segundo titular el IMGF se cobra sobre los rendimientos y la
                retencion asociada al abono a cuenta siempre y cuando sea mayo a cero */

            OPEN C_SEGUNDO(P_OFO_CFO_CCC_CLI_PER_NUM_IDEN
                          ,P_OFO_CFO_CCC_CLI_PER_TID_CODI
                          ,P_OFO_CFO_CCC_NUMERO_CUENTA
                          ,P_OFO_CFO_FON_CODIGO
                          ,P_OFO_CFO_CODIGO);
            FETCH C_SEGUNDO INTO IDENT;
            IF C_SEGUNDO%FOUND THEN
              IMPUESTO1 := ROUND(P_OFO_MONTO_CARGO_ABONO_CUENTA*CON.CON_VALOR,2);
              IMP_UNID1 := ROUND(IMPUESTO1/VU.DATO_VALOR_UNIDAD,8);
            ELSE
              REND_ORDEN := SAL.SAL_RND_RF + SAL.SAL_RND_RV + SAL.SAL_RET;
              IF REND_ORDEN > 0 THEN
                 IMPUESTO1 := ROUND((P_OFO_MONTO_CARGO_ABONO_CUENTA * REND_ORDEN / SAL.SAL_INV) * CON.CON_VALOR,2);

                 --Control de VAGTUD271 Decreto 660
                 OPEN C_DAA;
                 FETCH C_DAA INTO C_DAA1;
                 CLOSE C_DAA;
                 IF C_DAA1.DAA_TRASLADO_CC = 'S' THEN
                    IMPUESTO1 := 0;
                    IMP_UNID1 := 0;
                 ELSE
                    OPEN C_ORDEN;
                    FETCH C_ORDEN INTO ORD1;
                    CLOSE C_ORDEN;
                    IF  ORD1.OFO_TTO_TIT_CODIGO = 'ABO' AND
                        ORD1.OFO_CARGO_ABONO_CUENTA = 'S'  THEN
                        IMPUESTO1 := 0;
                        IMP_UNID1 := 0;
                    END IF;
                  --Fin Control de VGATUD271 Decreto 660
                 END IF;
                 IMP_UNID1 := ROUND(IMPUESTO1/VU.DATO_VALOR_UNIDAD,8);
              ELSE
                 IMPUESTO1 := 0;
                 IMP_UNID1 := 0;
              END IF;
            END IF;
            CLOSE C_SEGUNDO;
          ELSE
            IMPUESTO1 := 0;
            IMP_UNID1 := 0;
          END IF;
          UPDATE DETALLES_ABONOS_CUENTAS
          SET    DAA_VALOR_IMGF = - ROUND(DAA_VALOR * IMPUESTO1 / P_OFO_MONTO_CARGO_ABONO_CUENTA,2)
          WHERE  DAA_OFO_CONSECUTIVO = P_OFO_CONSECUTIVO
          AND    DAA_OFO_SUC_CODIGO = P_OFO_SUC_CODIGO
          AND    NVL(DAA_TRASLADO_EXCENTO,'N') = 'N';

          OPEN C_ORDENES_DE_PAGO;
          FETCH C_ORDENES_DE_PAGO INTO ODP1;
          WHILE C_ORDENES_DE_PAGO%FOUND LOOP
            IF ODP1.ODP_TPA_MNEMONICO != 'TRB' AND ODP1.ODP_PAGAR_A != 'C' THEN
              IMPUESTO := ROUND((IMPUESTO+ODP1.ODP_MONTO_ORDEN*CON.CON_VALOR),2);
              --IMP_UNID := ROUND(((IMP_UNID+(ODP1.ODP_MONTO_ORDEN*CON.CON_VALOR))/VU.DATO_VALOR_UNIDAD),8); 20110822
              IMP_UNID := ROUND((IMP_UNID+((ODP1.ODP_MONTO_ORDEN*CON.CON_VALOR)/VU.DATO_VALOR_UNIDAD)),8);
            END IF;
            FETCH C_ORDENES_DE_PAGO INTO ODP1;
          END LOOP;
          CLOSE C_ORDENES_DE_PAGO;
        ELSE
          IMPUESTO1 := 0;
          IMPUESTO  := 0;
          IMP_UNID1 :=0;
          IMP_UNID  :=0;
        END IF;
        RP_PRC    := P_OFO_MONTO / SAL.SAL_INV;
        RP_CAP    := ROUND(SAL.SAL_CAP * RP_PRC,2);
        RP_UND    := ROUND(SAL.SAL_UNI * RP_PRC,8);
        RP_RND_RF := ROUND(SAL.SAL_RND_RF * RP_PRC,2);
        RP_RND_RV := ROUND(SAL.SAL_RND_RV * RP_PRC,2);
        RP_RET    := ROUND(SAL.SAL_RET * RP_PRC,2);
        RP_RET    := ROUND(RP_RET);
        RP_AJU    := ROUND((P_OFO_MONTO - (RP_CAP+RP_RND_RF+RP_RND_RV-RP_RET)),2);
        RP_CAP    := ROUND(RP_CAP + RP_AJU,2);
        P_ULTIMOS_MOVIMIENTOS.NUEVA_FECHA_MCF(P_OFO_CFO_CCC_CLI_PER_NUM_IDEN
                                             ,P_OFO_CFO_CCC_CLI_PER_TID_CODI
                                             ,P_OFO_CFO_CCC_NUMERO_CUENTA
                                             ,P_OFO_CFO_FON_CODIGO
                                             ,P_OFO_CFO_CODIGO
                                             ,P_OFO_FECHA_EJECUCION);
        P_ORDENES_FONDOS.INSERTAR_REGISTRO
         (P_OFO_CFO_CCC_CLI_PER_NUM_IDEN,        /* IDENTIFICACION CLIENTE*/
          P_OFO_CFO_CCC_CLI_PER_TID_CODI,        /* TIPO DE CLIENTE */
          P_OFO_CFO_CCC_NUMERO_CUENTA ,          /*  NUMERO DE CUENTA*/
          P_OFO_CFO_FON_CODIGO ,                 /*  FONDO */
          P_OFO_CFO_CODIGO ,                     /* APORTE */
          P_OFO_FECHA_EJECUCION ,                /* FECHA DE EJECUION */
          P_FECHA_ACTUALIZA_MCC ,                /* FECHA ACTUALIZACION EN MCC */
          P_OFO_TTO_TOF_CODIGO,                  /* TIPO DE ORDEN*/
          P_FECHA,                               /* FECHA MOVIMIENTO*/
         'O',                                    /* TIPO MOVIMIENTO      */
          -1 * RP_CAP,                           /* MONTO                */
          -1 * RP_UND,                           /* MONTO EN UNIDADES    */
          -1 * RP_RND_RF,                        /* RENDIMIENTOS_RF      */
          -1 * RP_RND_RV,                        /* RENDIMIENTOS_RV      */
          -1 * RP_RET,                           /* RETEFUENTE           */
          SAL.SAL_RND_RF - RP_RND_RF,            /* SALDO RENDI RF       */
          SAL.SAL_RND_RV - RP_RND_RV,            /* SALDO RENDI RV       */
          SAL.SAL_RET - RP_RET,                  /* SALDO RETEFUENTE     */
          SAL.SAL_CAP - RP_CAP,                  /* SALDO CAPITAL        */
          SAL.SAL_INV - P_OFO_MONTO,             /* SALDO INVERSION      */
          SAL.SAL_UNI - RP_UND,                  /* SALDO UNIDADES       */
          0,                                     /* INTERESES CAUSADOS   */
          0,                                     /* TOTAL INTERESES CAUSADOS */
          P_OFO_SUC_CODIGO,                      /* SUCURSAL DONDE SE COLOCA LA ORDEN */
          P_OFO_CONSECUTIVO,                     /* CONSECUTIVO DE LA ORDEN */
          SAL.SAL_TAS,                           /* TASA PROMEDIO PARA FONDOS ABIERTOS EN BASE != PESOS */
          P_OFO_TTO_TOF_CODIGO,                  /* TIPO DE MOVIMIENTO RP */
          NVL(P_OFO_REGISTRO_AUTOMATICO, 'N'));
         IF V_VALOR_PENALIZACION != 0 THEN
           P_OFO_FECHA_EJECUCION := P_OFO_FECHA_EJECUCION + 0.00001;
           P_ORDENES_FONDOS.INSERTAR_REGISTRO
             (P_OFO_CFO_CCC_CLI_PER_NUM_IDEN,        /* IDENTIFICACION CLIENTE*/
              P_OFO_CFO_CCC_CLI_PER_TID_CODI,        /* TIPO DE CLIENTE */
              P_OFO_CFO_CCC_NUMERO_CUENTA ,          /*  NUMERO DE CUENTA*/
              P_OFO_CFO_FON_CODIGO ,                 /*  FONDO */
              P_OFO_CFO_CODIGO ,                     /* APORTE */
              P_OFO_FECHA_EJECUCION ,                /* FECHA DE EJECUION */
              P_FECHA_ACTUALIZA_MCC ,                /* FECHA ACTUALIZACION EN MCC */
              P_OFO_TTO_TOF_CODIGO,                  /* TIPO DE ORDEN*/
              P_FECHA,                               /* FECHA MOVIMIENTO*/
              'PEN',                                 /* TIPO MOVIMIENTO      */
               -1*V_VALOR_PENALIZACION,              /* MONTO                */
               -1*V_UNIDADES_PENALIZACION,           /* MONTO EN UNIDADES    */
               0,                                    /* RENDIMIENTOS_RF      */
               0,                                    /* RENDIMIENTOS_RV      */
               0,                                    /* RETEFUENTE           */
               SAL.SAL_RND_RF - RP_RND_RF,           /* SALDO RENDI RF       */
               SAL.SAL_RND_RV - RP_RND_RV,           /* SALDO RENDI RV       */
               SAL.SAL_RET - RP_RET,                 /* SALDO RETEFUENTE     */
               SAL.SAL_CAP - RP_CAP - V_VALOR_PENALIZACION,  /* SALDO CAPITAL        */
               SAL.SAL_INV - P_OFO_MONTO - V_VALOR_PENALIZACION,  /* SALDO INVERSION      */
               SAL.SAL_UNI - RP_UND - V_UNIDADES_PENALIZACION,          /* SALDO UNIDADES       */
               0,                                                    /* INTERESES CAUSADOS   */
               0,                                     /* TOTAL INTERESES CAUSADOS */
               P_OFO_SUC_CODIGO,                 /* SUCURSAL DONDE SE COLOCA LA ORDEN */
               P_OFO_CONSECUTIVO,                /* CONSECUTIVO DE LA ORDEN */
               NULL,                            /* TASA PROMEDIO PARA FONDOS ABIERTOS EN BASE != PESOS */
               NULL,
               'N');
         END IF;
         IF IMPUESTO != 0 THEN
            P_OFO_FECHA_EJECUCION := P_OFO_FECHA_EJECUCION + 0.00001;
            P_ORDENES_FONDOS.INSERTAR_REGISTRO
               (P_OFO_CFO_CCC_CLI_PER_NUM_IDEN,        /* IDENTIFICACION CLIENTE*/
                P_OFO_CFO_CCC_CLI_PER_TID_CODI,        /* TIPO DE CLIENTE */
                P_OFO_CFO_CCC_NUMERO_CUENTA ,          /*  NUMERO DE CUENTA*/
                P_OFO_CFO_FON_CODIGO ,                 /*  FONDO */
                P_OFO_CFO_CODIGO ,                     /* APORTE */
                P_OFO_FECHA_EJECUCION ,                /* FECHA DE EJECUION */
                P_FECHA_ACTUALIZA_MCC ,                /* FECHA ACTUALIZACION EN MCC */
                P_OFO_TTO_TOF_CODIGO,                  /* TIPO DE ORDEN*/
                P_FECHA,                               /* FECHA MOVIMIENTO*/
                'IBA',                            /* TIPO MOVIMIENTO      */
                -1 * IMPUESTO,                    /* MONTO                */
                -1 * IMP_UNID,                    /* MONTO EN UNIDADES    */
                0,                                /* RENDIMIENTOS_RF      */
                0,                                /* RENDIMIENTOS_RV      */
                0,                                /* RETEFUENTE           */
                SAL.SAL_RND_RF - RP_RND_RF,       /* SALDO RENDI RF       */
                SAL.SAL_RND_RV - RP_RND_RV,       /* SALDO RENDI RV       */
                SAL.SAL_RET - RP_RET,             /* SALDO RETEFUENTE     */
                SAL.SAL_CAP - RP_CAP - V_VALOR_PENALIZACION - IMPUESTO,  /* SALDO CAPITAL        */
                SAL.SAL_INV - P_OFO_MONTO - V_VALOR_PENALIZACION  - IMPUESTO,  /* SALDO INVERSION      */
                SAL.SAL_UNI - RP_UND - V_UNIDADES_PENALIZACION - IMP_UNID,  /* SALDO UNIDADES       */
                0,                                     /* INTERESES CAUSADOS   */
                0,                                     /* TOTAL INTERESES CAUSADOS */
                P_OFO_SUC_CODIGO,                      /* SUCURSAL DONDE SE COLOCA LA ORDEN */
                P_OFO_CONSECUTIVO,                     /* CONSECUTIVO DE LA ORDEN */
                NULL,                                  /* TASA PROMEDIO PARA FONDOS ABIERTOS EN BASE != PESOS */
                NULL,
                'N');
         END IF;
         IF IMPUESTO1 != 0 THEN
           P_OFO_FECHA_EJECUCION := P_OFO_FECHA_EJECUCION + 0.00001;
           P_ORDENES_FONDOS.INSERTAR_REGISTRO
              (P_OFO_CFO_CCC_CLI_PER_NUM_IDEN,        /* IDENTIFICACION CLIENTE*/
               P_OFO_CFO_CCC_CLI_PER_TID_CODI,        /* TIPO DE CLIENTE */
               P_OFO_CFO_CCC_NUMERO_CUENTA ,           /*  NUMERO DE CUENTA*/
               P_OFO_CFO_FON_CODIGO ,                /*  FONDO */
               P_OFO_CFO_CODIGO ,                    /* APORTE */
               P_OFO_FECHA_EJECUCION ,                 /* FECHA DE EJECUION */
               P_FECHA_ACTUALIZA_MCC ,                 /* FECHA ACTUALIZACION EN MCC */
               P_OFO_TTO_TOF_CODIGO,                  /* TIPO DE ORDEN*/
               P_FECHA,                               /* FECHA MOVIMIENTO*/
               'IBC',                            /* TIPO MOVIMIENTO      */
               -1 * IMPUESTO1,                   /* MONTO                */
               -1 * IMP_UNID1,                   /* MONTO EN UNIDADES    */
               0,                                /* RENDIMIENTOS_RF      */
               0,                                /* RENDIMIENTOS_RV      */
               0,                                /* RETEFUENTE           */
               SAL.SAL_RND_RF - RP_RND_RF,       /* SALDO RENDI RF       */
               SAL.SAL_RND_RV - RP_RND_RV,       /* SALDO RENDI RV       */
               SAL.SAL_RET - RP_RET,             /* SALDO RETEFUENTE     */
               SAL.SAL_CAP - RP_CAP - V_VALOR_PENALIZACION  - IMPUESTO - IMPUESTO1,  /* SALDO CAPITAL        */
               SAL.SAL_INV - P_OFO_MONTO - V_VALOR_PENALIZACION  - IMPUESTO - IMPUESTO1,  /* SALDO INVERSION      */
               SAL.SAL_UNI - RP_UND - V_UNIDADES_PENALIZACION - IMP_UNID -IMP_UNID1,  /* SALDO UNIDADES       */
               0,                                /* INTERESES CAUSADOS   */
               0,                                /* TOTAL INTERESES CAUSADOS */
               P_OFO_SUC_CODIGO,                /* SUCURSAL DONDE SE COLOCA LA ORDEN */
               P_OFO_CONSECUTIVO,               /* CONSECUTIVO DE LA ORDEN */
               NULL,                            /* TASA PROMEDIO PARA FONDOS ABIERTOS EN BASE != PESOS */
               NULL,
               'N');
           IF P_OFO_CFO_FON_CODIGO = '900272400' THEN
              P_OFO_FECHA_EJECUCION := P_OFO_FECHA_EJECUCION + 0.00001;
              P_ORDENES_FONDOS.INSERTAR_REGISTRO
                 (P_OFO_CFO_CCC_CLI_PER_NUM_IDEN,        /* IDENTIFICACION CLIENTE*/
                  P_OFO_CFO_CCC_CLI_PER_TID_CODI,        /* TIPO DE CLIENTE */
                  P_OFO_CFO_CCC_NUMERO_CUENTA ,          /*  NUMERO DE CUENTA*/
                  P_OFO_CFO_FON_CODIGO ,                 /*  FONDO */
                  P_OFO_CFO_CODIGO ,                     /* APORTE */
                  P_OFO_FECHA_EJECUCION ,                /* FECHA DE EJECUION */
                  P_FECHA_ACTUALIZA_MCC ,                /* FECHA ACTUALIZACION EN MCC */
                  P_OFO_TTO_TOF_CODIGO,                  /* TIPO DE ORDEN*/
                  P_FECHA,                               /* FECHA MOVIMIENTO*/
                  'RIC',                                 /* TIPO MOVIMIENTO      */
                  IMPUESTO1,                             /* MONTO                */
                  IMP_UNID1,                             /* MONTO EN UNIDADES    */
                  0,                                /* RENDIMIENTOS_RF      */
                  0,                                /* RENDIMIENTOS_RV      */
                  0,                                /* RETEFUENTE           */
                  SAL.SAL_RND_RF - RP_RND_RF,       /* SALDO RENDI RF       */
                  SAL.SAL_RND_RV - RP_RND_RV,       /* SALDO RENDI RV       */
                  SAL.SAL_RET - RP_RET,             /* SALDO RETEFUENTE     */
                  SAL.SAL_CAP - RP_CAP - V_VALOR_PENALIZACION  - IMPUESTO - IMPUESTO1 + IMPUESTO1,      /* SALDO CAPITAL        */
                  SAL.SAL_INV - P_OFO_MONTO - V_VALOR_PENALIZACION  - IMPUESTO - IMPUESTO1 + IMPUESTO1, /* SALDO INVERSION      */
                  SAL.SAL_UNI - RP_UND - V_UNIDADES_PENALIZACION - IMP_UNID -IMP_UNID1 + IMP_UNID1,     /* SALDO UNIDADES       */
                  0,                                /* INTERESES CAUSADOS   */
                  0,                                /* TOTAL INTERESES CAUSADOS */
                  P_OFO_SUC_CODIGO,                 /* SUCURSAL DONDE SE COLOCA LA ORDEN */
                  P_OFO_CONSECUTIVO,                /* CONSECUTIVO DE LA ORDEN */
                  NULL,                             /* TASA PROMEDIO PARA FONDOS ABIERTOS EN BASE != PESOS */
                  NULL,
                  'N');
           END IF;
         END IF;
         -- descontar unidades de penalizacion
         --IF V_VALOR_PENALIZACION != 0 THEN
         P_ORDENES_FONDOS.P_UPD_PENALIZACION(P_OFO_CFO_CCC_CLI_PER_NUM_IDEN   => P_OFO_CFO_CCC_CLI_PER_NUM_IDEN
                                            ,P_OFO_CFO_CCC_CLI_PER_TID_CODI   => P_OFO_CFO_CCC_CLI_PER_TID_CODI
                                            ,P_OFO_CFO_CCC_NUMERO_CUENTA      => P_OFO_CFO_CCC_NUMERO_CUENTA
                                            ,P_OFO_CFO_FON_CODIGO             => P_OFO_CFO_FON_CODIGO
                                            ,P_OFO_CFO_CODIGO                 => P_OFO_CFO_CODIGO
                                            ,P_FECHA_PROCESO                  => P_FECHA
                                            ,P_UNIDADES_MOVIMIENTO            => NVL(RP_UND,0)+NVL(V_UNIDADES_PENALIZACION,0)+NVL(IMP_UNID,0)+NVL(IMP_UNID1,0)
                                            ,P_TIPO_OPERACION                 => 'RP');
         --END IF;
      END IF;
      V_OFO_FECHA_EJECUCION := P_SALDOS_CLIENTES.F_FECHA_HABIL(TRUNC(P_OFO_FECHA_EJECUCION+1),1);
      P_ORDENES_FONDOS.ABONO_CARGO_CUENTA(P_OFO_SUC_CODIGO
                                         ,P_OFO_CONSECUTIVO
                                         ,P_OFO_CFO_CCC_cLI_PER_NUM_IDEN
                                         ,P_OFO_CFO_CCC_CLI_PER_TID_CODI
                                         ,P_OFO_CFO_CCC_NUMERO_CUENTA
                                         ,P_OFO_CFO_FON_CODIGO
                                         ,P_OFO_CFO_CODIGO
                                         ,P_EXC
                                         ,'A'
                                         ,'RP'
                                         ,P_LLAMADO_FF_FG      => 'S'
                                         ,P_FECHA_EJECUCION    => V_OFO_FECHA_EJECUCION);
  END IF;
  IF P_TIPO_ORDEN = 'RT' THEN
    V_VALOR_PENALIZACION      := 0;
    V_UNIDADES_PENALIZACION   := 0;
    IMPUESTO    := 0;
    IMP_UNID    := 0;
    IMPUESTO1   := 0;
    IMP_UNID1   := 0;
    UNIDADES_OFO_MONTO      := 0;
    OPEN  VALOR_UNIDAD;
    FETCH VALOR_UNIDAD INTO VU;
    IF (VALOR_UNIDAD%NOTFOUND) THEN
      RAISE NO_VALOR_UNIDAD;
    END IF;
    CLOSE VALOR_UNIDAD;
    IF (VU.DATO_VALOR_UNIDAD = 0) THEN
      RAISE NO_VALOR_UNIDAD;
    END IF;
    OPEN C_CONSTANTE;
    FETCH C_CONSTANTE INTO CON;
    IF C_CONSTANTE%NOTFOUND THEN
      CLOSE C_CONSTANTE;
      RAISE NO_IMP_BANCARIO;
    END IF;
    CLOSE C_CONSTANTE;
    IF SAL.SAL_INV <= 0 THEN
      RAISE SALDO_INSUFICIENTE;
    END IF;
    P_VER_IMPUESTO := 'N';
    OPEN C_FONDO;
    FETCH C_FONDO INTO OFO1;
    IF C_FONDO%FOUND THEN
      CLOSE C_FONDO;
      OPEN C_SEGUNDO(P_OFO_CFO_CCC_CLI_PER_NUM_IDEN ,P_OFO_CFO_CCC_CLI_PER_TID_CODI ,P_OFO_CFO_CCC_NUMERO_CUENTA ,P_OFO_CFO_FON_CODIGO ,P_OFO_CFO_CODIGO);
      FETCH C_SEGUNDO INTO IDENT;
      IF C_SEGUNDO%FOUND THEN
        P_VER_IMPUESTO := 'S';
        SEGUNDO := 'S';
        CLOSE C_SEGUNDO;
      ELSE
        P_VER_IMPUESTO := 'N';
        CLOSE C_SEGUNDO;
        OPEN C_SEGUNDO(OFO1.OFO_CFO_CCC_CLI_PER_NUM_IDEN ,OFO1.OFO_CFO_CCC_CLI_PER_TID_CODIGO ,OFO1.OFO_CFO_CCC_NUMERO_CUENTA ,OFO1.OFO_CFO_FON_CODIGO ,OFO1.OFO_CFO_CODIGO);
        FETCH C_SEGUNDO INTO IDENT;
        IF C_SEGUNDO%FOUND THEN
          P_VER_IMPUESTO := 'S';
        END IF;
        CLOSE C_SEGUNDO;
      END IF;
    ELSE
      CLOSE C_FONDO;
      P_VER_IMPUESTO := 'S';
    END IF;
    P_ORDENES_FONDOS.P_CALCULO_PENALIZACION( P_OFO_CFO_CCC_CLI_PER_NUM_IDEN  => P_OFO_CFO_CCC_CLI_PER_NUM_IDEN
                                            ,P_OFO_CFO_CCC_CLI_PER_TID_CODI  => P_OFO_CFO_CCC_CLI_PER_TID_CODI
                                            ,P_OFO_CFO_CCC_NUMERO_CUENTA     => P_OFO_CFO_CCC_NUMERO_CUENTA
                                            ,P_OFO_CFO_FON_CODIGO            => P_OFO_CFO_FON_CODIGO
                                            ,P_OFO_CFO_CODIGO                => P_OFO_CFO_CODIGO
                                            ,P_FECHA_PROCESO                 => P_FECHA
                                            ,P_UNIDADES_MOVIMIENTO           => 0
                                            ,P_TIPO_OPERACION                => 'RT'
                                            ,P_VALOR_PENALIZACION            => V_VALOR_PENALIZACION
                                            ,P_UNIDADES_PENALIZACION         => V_UNIDADES_PENALIZACION);
    IF P_EXC = 'N' AND    P_VER_IMPUESTO = 'S' THEN
      P_VER_IMPUESTO := 'S';
    ELSE
      P_VER_IMPUESTO := 'N';
    END IF;
    RENDIMIENTOS := SAL.SAL_RND_RF + SAL.SAL_RND_RV + SAL.SAL_RET;
    RECALCULO_MONTO_ORDEN(P_SALDO                          => SAL.SAL_INV
                         ,P_OFO_SUC_CODIGO                 => P_OFO_SUC_CODIGO
                         ,P_OFO_CONSECUTIVO                => P_OFO_CONSECUTIVO
                         ,P_OFO_MONTO                      => P_OFO_MONTO
                         ,P_OFO_CFO_CCC_CLI_PER_NUM_IDEN   => P_OFO_CFO_CCC_CLI_PER_NUM_IDEN
                         ,P_OFO_CFO_CCC_CLI_PER_TID_CODI   => P_OFO_CFO_CCC_CLI_PER_TID_CODI
                         ,P_OFO_CFO_CCC_NUMERO_CUENTA      => P_OFO_CFO_CCC_NUMERO_CUENTA
                         ,P_OFO_CFO_FON_CODIGO             => P_OFO_CFO_FON_CODIGO
                         ,P_OFO_CFO_CODIGO                 => P_OFO_CFO_CODIGO
                         ,P_OFO_FECHA_CAPTURA              => P_OFO_FECHA_CAPTURA
                         ,P_VALOR_IMPUESTO                 => CON.CON_VALOR
                         ,P_VALOR_PENALIZACION             => V_VALOR_PENALIZACION
                         ,P_UNIDADES_PENALIZACION          => V_UNIDADES_PENALIZACION
                         ,P_VER_IMPUESTO                   => P_VER_IMPUESTO
                         ,P_VFO_VALOR                      => VU.DATO_VALOR_UNIDAD
                         ,P_OFO_MONTO_ORDEN                => P_OFO_MONTO
                         ,P_OFO_MONTO_CARGO_ABONO_CUENTA   => P_OFO_MONTO_CARGO_ABONO_CUENTA
                         ,P_IMPUESTO_ABONO_CUENTA          => IMPUESTO1
                         ,P_IMPUESTO_PAGOS                 => IMPUESTO
                         ,P_OFO_MONTO_ORDEN_UNIDADES       => UNIDADES_OFO_MONTO
                         ,P_IMPUESTO_ABONO_CUENTA_UNIDAD   => IMP_UNID1
                         ,P_IMPUESTO_PAGOS_UNIDADES        => IMP_UNID
                         ,P_TIENE_SEGUNDO                  => SEGUNDO
                         ,P_RENDIMIENTOS                   => RENDIMIENTOS);
   P_ULTIMOS_MOVIMIENTOS.NUEVA_FECHA_MCF(P_OFO_CFO_CCC_CLI_PER_NUM_IDEN
                                        ,P_OFO_CFO_CCC_CLI_PER_TID_CODI
                                        ,P_OFO_CFO_CCC_NUMERO_CUENTA
                                        ,P_OFO_CFO_FON_CODIGO
                                        ,P_OFO_CFO_CODIGO
                                        ,P_OFO_FECHA_EJECUCION);

   --Control de VAGTUD271 Decreto 660
   OPEN C_DAA;
   FETCH C_DAA INTO C_DAA1;
   CLOSE C_DAA;
   IF C_DAA1.DAA_TRASLADO_CC = 'S' THEN
      IMPUESTO1 := 0;
      IMP_UNID1 := 0;
   ELSE
      OPEN C_ORDEN;
      FETCH C_ORDEN INTO ORD1;
      CLOSE C_ORDEN;
      IF  ORD1.OFO_TTO_TIT_CODIGO = 'ABO' AND
          ORD1.OFO_CARGO_ABONO_CUENTA = 'S'  THEN
          IMPUESTO1 := 0;
          IMP_UNID1 := 0;
      END IF;
   END IF; --Fin Control de VGATUD271 Decreto 660

    /* CREACION DE MOVIMIENTO DE RETIRO*/
    P_ORDENES_FONDOS.INSERTAR_REGISTRO
       (P_OFO_CFO_CCC_CLI_PER_NUM_IDEN,         /* IDENTIFICACION CLIENTE*/
        P_OFO_CFO_CCC_CLI_PER_TID_CODI,           /* TIPO DE CLIENTE */
        P_OFO_CFO_CCC_NUMERO_CUENTA ,             /*  NUMERO DE CUENTA*/
        P_OFO_CFO_FON_CODIGO ,                    /*  FONDO */
        P_OFO_CFO_CODIGO ,                        /* APORTE */
        P_OFO_FECHA_EJECUCION ,                   /* FECHA DE EJECUION */
        P_FECHA_ACTUALIZA_MCC ,                   /* FECHA ACTUALIZACION EN MCC */
        P_OFO_TTO_TOF_CODIGO,                     /* TIPO DE ORDEN*/
        P_FECHA,                                  /* FECHA DE PROCESO*/
       'O',                                     /* TIPO MOVIMIENTO      */
       -1*SAL.SAL_CAP + V_VALOR_PENALIZACION + IMPUESTO + IMPUESTO1,   /* MONTO                */
       -1*SAL.SAL_UNI + V_UNIDADES_PENALIZACION+IMP_UNID+IMP_UNID1,   /* MONTO EN UNIDADES    */
       -1*SAL.SAL_RND_RF,                       /* RENDIMIENTOS_RF      */
       -1*SAL.SAL_RND_RV,                       /* RENDIMIENTOS_RV      */
       -1*SAL.SAL_RET,                          /* RETEFUENTE           */
       0,                                       /* SALDO RENDI RF       */
       0,                                       /* SALDO RENDI RV       */
       0,                                       /* SALDO RETEFUENTE     */
       V_VALOR_PENALIZACION+IMPUESTO1+IMPUESTO,                    /* SALDO CAPITAL        */
       V_VALOR_PENALIZACION+IMPUESTO1+IMPUESTO,                    /* SALDO INVERSION      */
       V_UNIDADES_PENALIZACION + IMP_UNID + IMP_UNID1,            /* SALDO UNIDADES       */
       0,                                       /* INTERESES CAUSADOS */
       0,                                       /* TOTAL INTERESES CAUSADOS */
       P_OFO_SUC_CODIGO,                        /* SUCURSAL DONDE SE COLOCA LA ORDEN */
       P_OFO_CONSECUTIVO,                       /* CONSECUTIVO DE LA ORDEN */
       SAL.SAL_TAS,                             /* TASA PROMEDIO PARA FONDOS ABIERTOS EN BASE != PESOS */
       'RT',
       NVL(P_OFO_REGISTRO_AUTOMATICO, 'N'));

    IF IMPUESTO != 0 THEN -- 4XMIL ORDENES DE PAGO
       P_OFO_FECHA_EJECUCION := P_OFO_FECHA_EJECUCION + 0.00001;
       P_ORDENES_FONDOS.INSERTAR_REGISTRO
          (P_OFO_CFO_CCC_CLI_PER_NUM_IDEN,          /* IDENTIFICACION CLIENTE*/
           P_OFO_CFO_CCC_CLI_PER_TID_CODI,            /* TIPO DE CLIENTE */
           P_OFO_CFO_CCC_NUMERO_CUENTA ,              /*  NUMERO DE CUENTA*/
           P_OFO_CFO_FON_CODIGO ,                   /*  FONDO */
           P_OFO_CFO_CODIGO ,                       /* APORTE */
           P_OFO_FECHA_EJECUCION ,                    /* FECHA DE EJECUION */
           P_FECHA_ACTUALIZA_MCC ,                    /* FECHA ACTUALIZACION EN MCC */
           P_OFO_TTO_TOF_CODIGO,                     /* TIPO DE ORDEN*/
           P_FECHA,                                  /* FECHA DE PROCESO*/
           'IBA',                          /* TIPO MOVIMIENTO      */
           -1*IMPUESTO,                    /* MONTO                */
           -1*IMP_UNID,                    /* MONTO EN UNIDADES    */
           0,                              /* RENDIMIENTOS_RF      */
           0,                              /* RENDIMIENTOS_RV      */
           0,                              /* RETEFUENTE           */
           0,                              /* SALDO RENDI RF       */
           0,                              /* SALDO RENDI RV       */
           0,                              /* SALDO RETEFUENTE     */
           V_VALOR_PENALIZACION+IMPUESTO1 ,                      /* SALDO CAPITAL        */
           V_VALOR_PENALIZACION+IMPUESTO1 ,                      /* SALDO INVERSION      */
           V_UNIDADES_PENALIZACION+IMP_UNID1 ,              /* SALDO UNIDADES       */
           0,                              /* INTERESES CAUSADOS */
           0,                              /* TOTAL INTERESES CAUSADOS */
           P_OFO_SUC_CODIGO,            /* SUCURSAL DONDE SE COLOCA LA ORDEN */
           P_OFO_CONSECUTIVO,           /* CONSECUTIVO DE LA ORDEN */
           NULL,                           /* TASA PROMEDIO PARA FONDOS ABIERTOS EN BASE != PESOS */
           NULL,
           'N');
    END IF;

    IF IMPUESTO1 != 0 THEN  -- 4XMIL ABONO CUENTA
      P_OFO_FECHA_EJECUCION := P_OFO_FECHA_EJECUCION + 0.00001;
      P_ORDENES_FONDOS.INSERTAR_REGISTRO
         (P_OFO_CFO_CCC_CLI_PER_NUM_IDEN,         /* IDENTIFICACION CLIENTE*/
          P_OFO_CFO_CCC_CLI_PER_TID_CODI,           /* TIPO DE CLIENTE */
          P_OFO_CFO_CCC_NUMERO_CUENTA ,             /*  NUMERO DE CUENTA*/
          P_OFO_CFO_FON_CODIGO ,                    /*  FONDO */
          P_OFO_CFO_CODIGO ,                        /* APORTE */
          P_OFO_FECHA_EJECUCION ,                   /* FECHA DE EJECUION */
          P_FECHA_ACTUALIZA_MCC ,                   /* FECHA ACTUALIZACION EN MCC */
          P_OFO_TTO_TOF_CODIGO,                     /* TIPO DE ORDEN*/
          P_FECHA,                                  /* FECHA DE PROCESO*/
          'IBC',                          /* TIPO MOVIMIENTO      */
          -1*IMPUESTO1,                    /* MONTO                */
          -1*IMP_UNID1,                    /* MONTO EN UNIDADES    */
          0,                              /* RENDIMIENTOS_RF      */
          0,                              /* RENDIMIENTOS_RV      */
          0,                              /* RETEFUENTE           */
          0,                               /* SALDO RENDI RF       */
          0,                               /* SALDO RENDI RV       */
          0,                              /* SALDO RETEFUENTE     */
          V_VALOR_PENALIZACION,                              /* SALDO CAPITAL        */
          V_VALOR_PENALIZACION,                              /* SALDO INVERSION      */
          V_UNIDADES_PENALIZACION,                      /* SALDO UNIDADES       */
          0,                              /* INTERESES CAUSADOS */
          0,                              /* TOTAL INTERESES CAUSADOS */
          P_OFO_SUC_CODIGO,            /* SUCURSAL DONDE SE COLOCA LA ORDEN */
          P_OFO_CONSECUTIVO,           /* CONSECUTIVO DE LA ORDEN */
          NULL,                          /* TASA PROMEDIO PARA FONDOS ABIERTOS EN BASE != PESOS */
          NULL,
          'N');
    END IF;

    IF V_VALOR_PENALIZACION != 0 THEN
      P_OFO_FECHA_EJECUCION := P_OFO_FECHA_EJECUCION + 0.00001;
      P_ORDENES_FONDOS.INSERTAR_REGISTRO
         (P_OFO_CFO_CCC_CLI_PER_NUM_IDEN,         /* IDENTIFICACION CLIENTE*/
          P_OFO_CFO_CCC_CLI_PER_TID_CODI,           /* TIPO DE CLIENTE */
          P_OFO_CFO_CCC_NUMERO_CUENTA ,             /*  NUMERO DE CUENTA*/
          P_OFO_CFO_FON_CODIGO ,                    /*  FONDO */
          P_OFO_CFO_CODIGO ,                        /* APORTE */
          P_OFO_FECHA_EJECUCION ,                   /* FECHA DE EJECUION */
          P_FECHA_ACTUALIZA_MCC ,                   /* FECHA ACTUALIZACION EN MCC */
          P_OFO_TTO_TOF_CODIGO,                     /* TIPO DE ORDEN*/
          P_FECHA,                                  /* FECHA DE PROCESO*/
          'PEN',                                     /* TIPO MOVIMIENTO      */
          -1*V_VALOR_PENALIZACION,                    /* MONTO                */
          -1*V_UNIDADES_PENALIZACION,                 /* MONTO EN UNIDADES    */
          0,                              /* RENDIMIENTOS_RF      */
          0,                              /* RENDIMIENTOS_RV      */
          0,                              /* RETEFUENTE           */
          0,                               /* SALDO RENDI RF       */
          0,                               /* SALDO RENDI RV       */
          0,                              /* SALDO RETEFUENTE     */
          0,                              /* SALDO CAPITAL        */
          0,                              /* SALDO INVERSION      */
          0,                      /* SALDO UNIDADES       */
          0,                              /* INTERESES CAUSADOS */
          0,                              /* TOTAL INTERESES CAUSADOS */
          P_OFO_SUC_CODIGO,            /* SUCURSAL DONDE SE COLOCA LA ORDEN */
          P_OFO_CONSECUTIVO,           /* CONSECUTIVO DE LA ORDEN */
          NULL,                          /* TASA PROMEDIO PARA FONDOS ABIERTOS EN BASE != PESOS */
          NULL,
          'N');
    END IF;
    INSERTAR_MOVIMIENTO_CORREDORES(P_OFO_CFO_CCC_CLI_PER_NUM_IDEN    =>P_OFO_CFO_CCC_CLI_PER_NUM_IDEN
                                 ,P_OFO_CFO_CCC_CLI_PER_TID_CODI    =>P_OFO_CFO_CCC_CLI_PER_TID_CODI
                                 ,P_OFO_CFO_CCC_NUMERO_CUENTA       => P_OFO_CFO_CCC_NUMERO_CUENTA
                                 ,P_OFO_CFO_FON_CODIGO              => P_OFO_CFO_FON_CODIGO
                                 ,P_OFO_CFO_CODIGO                  => P_OFO_CFO_CODIGO
                                 ,MONTO                             => P_OFO_MONTO
                                 ,ORDEN_FONDOS                      => P_OFO_CONSECUTIVO
                                 ,SUCURSAL                          => P_OFO_SUC_CODIGO
                                 ,FECHA                             => P_FECHA_ACTUALIZA_MCC
                                 ,TIPO_MOVIMIENTO                   => 'RT');
     /* APROBAR ORDENES DE PAGO*/
     V_OFO_FECHA_EJECUCION := P_SALDOS_CLIENTES.F_FECHA_HABIL(TRUNC(P_OFO_FECHA_EJECUCION+1),1);
     UPDATE ordenes_de_pago
     SET  ODP_ESTADO = 'APR'
         ,ODP_FECHA_APROBACION = P_OFO_FECHA_EJECUCION
         ,ODP_FECHA_EJECUCION  = V_OFO_FECHA_EJECUCION
         ,ODP_APROBADA_POR = USER
     WHERE  ODP_OFO_SUC_CODIGO  = P_OFO_SUC_CODIGO
      AND    ODP_OFO_CONSECUTIVO = P_OFO_CONSECUTIVO
      AND    ODP_ESTADO = 'COL'
      AND    NVL(ODP_ANTICIPO,'N') = 'N';
      P_ORDENES_FONDOS.MOVIMIENTO_BANCARIO (P_OFO_SUC_CODIGO     => P_OFO_SUC_CODIGO
                                           ,P_OFO_CONSECUTIVO    => P_OFO_CONSECUTIVO
                                           ,P_OFO_CFO_FON_CODIGO => P_OFO_CFO_FON_CODIGO
                                           ,P_OFO_TTO_TOF_CODIGO => P_OFO_TTO_TOF_CODIGO
                                           ,P_EXC                => P_EXC
                                           ,P_TIPO               => 'P'
                                           ,P_LLAMADO_FF_FG      => 'S'
                                           ,P_FECHA_EJECUCION    => V_OFO_FECHA_EJECUCION
                                           ,P_ESTADO             => 'APR');
      P_ORDENES_FONDOS.ABONO_CARGO_CUENTA(P_OFO_SUC_CODIGO
                                         ,P_OFO_CONSECUTIVO
                                         ,P_OFO_CFO_CCC_cLI_PER_NUM_IDEN
                                         ,P_OFO_CFO_CCC_CLI_PER_TID_CODI
                                         ,P_OFO_CFO_CCC_NUMERO_CUENTA
                                         ,P_OFO_CFO_FON_CODIGO
                                         ,P_OFO_CFO_CODIGO
                                         ,P_EXC
                                         ,'A'
                                         ,'RT'
                                         ,P_LLAMADO_FF_FG      => 'S'
                                         ,P_FECHA_EJECUCION    => V_OFO_FECHA_EJECUCION);
    OPEN C_PUNTA;
    FETCH C_PUNTA INTO R_PUNTA;
    IF C_PUNTA%FOUND AND R_PUNTA.OFO_EOF_CODIGO IN ('APL','COL') THEN
      IF P_OFO_TTO_TOF_CODIGO = 'RT'  AND R_PUNTA.OFO_TTO_TOF_CODIGO IN ('ING','INC') THEN
          UPDATE ORDENES_FONDOS
            SET  OFO_MONTO = P_OFO_MONTO
                ,OFO_MONTO_CARGO_ABONO_CUENTA = P_OFO_MONTO
          WHERE  OFO_SUC_CODIGO = R_PUNTA.OFO_SUC_CODIGO
          AND    OFO_CONSECUTIVO = R_PUNTA.OFO_CONSECUTIVO;
          UPDATE DETALLES_CARGOS_CUENTAS
            SET    DAU_VALOR = P_OFO_MONTO
            WHERE  DAU_OFO_CONSECUTIVO = R_PUNTA.OFO_CONSECUTIVO
             AND    DAU_OFO_SUC_CODIGO = R_PUNTA.OFO_SUC_CODIGO;
      END IF;
    END IF;
    CLOSE C_PUNTA;
    P_ORDENES_FONDOS.P_UPD_PENALIZACION(P_OFO_CFO_CCC_CLI_PER_NUM_IDEN   => P_OFO_CFO_CCC_CLI_PER_NUM_IDEN
                                          ,P_OFO_CFO_CCC_CLI_PER_TID_CODI   => P_OFO_CFO_CCC_CLI_PER_TID_CODI
                                          ,P_OFO_CFO_CCC_NUMERO_CUENTA      => P_OFO_CFO_CCC_NUMERO_CUENTA
                                          ,P_OFO_CFO_FON_CODIGO             => P_OFO_CFO_FON_CODIGO
                                          ,P_OFO_CFO_CODIGO                 => P_OFO_CFO_CODIGO
                                          ,P_FECHA_PROCESO                  => P_FECHA
                                          ,P_UNIDADES_MOVIMIENTO            => 0
                                          ,P_TIPO_OPERACION                 => 'RT');
  END IF;
EXCEPTION
    WHEN SALDO_INSUFICIENTE THEN
      RAISE_APPLICATION_ERROR(-20100,'Saldo insuficiente. PRE_UPDATE - Retiro parcial');
    WHEN NO_IMP_BANCARIO THEN
      RAISE_APPLICATION_ERROR(-20101,'No se encontro el valor del impuesto bancario');
    WHEN NO_TIPO_FONDO THEN
      RAISE_APPLICATION_ERROR(-20102,'No se determino el tipo de fondo');
    WHEN NO_VALOR_UNIDAD THEN
      RAISE_APPLICATION_ERROR(-20103,'No encontro valor unidad para el dia :'||TO_CHAR(P_OFO_FECHA_EJECUCION ,'DD-MON-YYYY'));
    WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20150,'Error en P_ORDENES_FONDOS.P_INS_MOVIMIENTOS_FONDOS '||SQLERRM);
END P_INS_MOVIMIENTOS_FONDOS;
PROCEDURE INSERTAR_REGISTRO (   P_OFO_CFO_CCC_CLI_PER_NUM_IDEN   IN VARCHAR2,
    P_OFO_CFO_CCC_CLI_PER_TID_CODI   IN VARCHAR2,
    P_OFO_CFO_CCC_NUMERO_CUENTA      IN NUMBER,
    P_OFO_CFO_FON_CODIGO             IN VARCHAR2,
    P_OFO_CFO_CODIGO                 IN NUMBER,
    P_OFO_FECHA_EJECUCION            IN OUT DATE,
    P_FECHA_ACTUALIZA_MCC            IN OUT DATE,
    P_OFO_TTO_TOF_CODIGO             IN VARCHAR2,
    P_FECHA                          IN OUT DATE,
    P_TMF_MNEMONICO               IN VARCHAR2,
    P_CAPITAL                     IN NUMBER,
    P_UNIDADES_MOVIMIENTO         IN NUMBER,
    P_RENDIMIENTOS_RF             IN NUMBER,
    P_RENDIMIENTOS_RV             IN NUMBER,
    P_RETEFUENTE_MOVIMIENTO       IN NUMBER,
    P_SALDO_RENDIMIENTOS_RF       IN NUMBER,
    P_SALDO_RENDIMIENTOS_RV       IN NUMBER,
    P_SALDO_RETEFUENTE            IN NUMBER,
    P_SALDO_CAPITAL               IN NUMBER,
    P_SALDO_INVER                 IN NUMBER,
    P_SALDO_UNIDADES              IN NUMBER,
    P_INTERESES_PAGADOS           IN NUMBER,
    P_SALDO_INTERESES_PAGADOS     IN NUMBER,
    P_SUC_CODIGO                  IN NUMBER,
    P_CONSECUTIVO                 IN NUMBER,
    P_TASA_PROMEDIO               IN NUMBER,
    P_TIPO_ORDEN                  IN VARCHAR2,
    P_AUTOMATICO                  IN VARCHAR2,
  P_IND_SALTO                   IN VARCHAR2 DEFAULT NULL) IS
  V_ULTIMA_FECHA_MCF  DATE;
  V_NUEVA_FECHA_MCF   DATE;
  V_ULTIMA_FECHA_MCC1 VARCHAR2(15);
  V_ULTIMA_FECHA_MCC  DATE;
  V_NUEVA_FECHA_MCC   DATE;
  FECHA               DATE;
  NVOCONS             NUMBER;
BEGIN
   SELECT MCF_SEQ.NEXTVAL INTO NVOCONS FROM DUAL;
   INSERT INTO MOVIMIENTOS_CUENTAS_FONDOS
     (MCF_CONSECUTIVO,
      MCF_CFO_CCC_CLI_PER_TID_CODIGO,
      MCF_CFO_CCC_CLI_PER_NUM_IDEN,
      MCF_CFO_CCC_NUMERO_CUENTA,
      MCF_CFO_CODIGO,
      MCF_CFO_FON_CODIGO,
      MCF_TMF_MNEMONICO,
      MCF_FECHA,
      MCF_CAPITAL,
      MCF_UNIDADES_MOVIMIENTO,
      MCF_RENDIMIENTOS_RF,
      MCF_RENDIMIENTOS_RV,
      MCF_RETEFUENTE_MOVIMIENTO,
      MCF_SALDO_RENDIMIENTOS_RF,
      MCF_SALDO_RENDIMIENTOS_RV,
      MCF_SALDO_RETEFUENTE,
      MCF_SALDO_CAPITAL,
      MCF_SALDO_INVER,
      MCF_SALDO_UNIDADES,
      MCF_OFO_CONSECUTIVO,
      MCF_OFO_SUC_CODIGO,
      MCF_INTERESES_PAGADOS,
      MCF_SALDO_INTERESES_PAGADOS,
      MCF_TASA_PROMEDIO,
      MCF_IND_SALTO)
   VALUES
     (NVOCONS,
      P_OFO_CFO_CCC_CLI_PER_TID_CODI, /* CLIENTE TID          */
      P_OFO_CFO_CCC_CLI_PER_NUM_IDEN,   /* CLIENTE ID           */
      P_OFO_CFO_CCC_NUMERO_CUENTA,      /* NUMERO CTA CCC       */
      P_OFO_CFO_CODIGO,                 /* FONDO CTA FONDO      */
      P_OFO_CFO_FON_CODIGO,             /* CODIGO DEL FONDO     */
      P_TMF_MNEMONICO,                     /* TIPO MOVIMIENTO      */
      P_OFO_FECHA_EJECUCION,             /* FECHA                */
      P_CAPITAL,                           /* MONTO                */
      P_UNIDADES_MOVIMIENTO,               /* MONTO EN UNIDADES    */
      P_RENDIMIENTOS_RF,                   /* RENDIMIENTOS_RF      */
      P_RENDIMIENTOS_RV,                   /* RENDIMIENTOS_RV      */
      P_RETEFUENTE_MOVIMIENTO,             /* RETEFUENTE           */
      P_SALDO_RENDIMIENTOS_RF,             /* SALDO RENDI RF       */
      P_SALDO_RENDIMIENTOS_RV,             /* SALDO RENDI RV       */
      P_SALDO_RETEFUENTE,                  /* SALDO RETEFUENTE     */
      P_SALDO_CAPITAL,                     /* SALDO CAPITAL        */
      P_SALDO_INVER,                       /* SALDO INVERSION      */
      P_SALDO_UNIDADES,                    /* SALDO UNIDADES       */
      P_CONSECUTIVO,                       /* NO ORDEN             */
      P_SUC_CODIGO,                        /* SUCURSAL             */
      P_INTERESES_PAGADOS,                 /* INTERESES PAGADOS FONDOS CERRADOS */
      P_SALDO_INTERESES_PAGADOS,           /* SALDO TOTAL DE INT.PAGADOS */
      P_TASA_PROMEDIO,                     /* TASA PROMEDIO PARA FONDOS ABIERTOS EN BASE != PESOS */
      P_IND_SALTO);                        /* INDICADOR DE SALTO ENTRE PARTICIPACIONES */
      IF P_TIPO_ORDEN IN('ING','INC','RP') AND P_CONSECUTIVO IS NOT NULL THEN
         P_FECHA := P_FECHA+0.00001;
         UPDATE MOVIMIENTOS_CUENTA_CORREDORES
         SET    MCC_MCF_CONSECUTIVO = NVOCONS
         WHERE  MCC_OFO_SUC_CODIGO = P_SUC_CODIGO
         AND    MCC_OFO_CONSECUTIVO = P_CONSECUTIVO;
      END IF;
      IF P_TIPO_ORDEN = 'RT' THEN
         P_FECHA_ACTUALIZA_MCC := P_OFO_FECHA_EJECUCION;
      END IF;
   EXCEPTION
     WHEN OTHERS THEN
        RAISE_APPLICATION_ERROR(-20250,'Error:'||P_CONSECUTIVO||' P_ORDENES_FONDOS.INSERTAR_REGISTRO '||SQLERRM);
END INSERTAR_REGISTRO;
PROCEDURE RECALCULO_MONTO_ORDEN(P_SALDO                          IN     NUMBER
                               ,P_OFO_SUC_CODIGO                 IN     NUMBER
                               ,P_OFO_CONSECUTIVO                IN     NUMBER
                               ,P_OFO_MONTO                      IN     NUMBER
                               ,P_OFO_CFO_CCC_CLI_PER_NUM_IDEN   IN     VARCHAR2
                               ,P_OFO_CFO_CCC_CLI_PER_TID_CODI   IN     VARCHAR2
                               ,P_OFO_CFO_CCC_NUMERO_CUENTA      IN     NUMBER
                               ,P_OFO_CFO_FON_CODIGO             IN     VARCHAR2
                               ,P_OFO_CFO_CODIGO                 IN     NUMBER
                               ,P_OFO_FECHA_CAPTURA              IN     DATE
                               ,P_VALOR_IMPUESTO                 IN     NUMBER
                               ,P_VALOR_PENALIZACION             IN     NUMBER
                               ,P_UNIDADES_PENALIZACION          IN     NUMBER
                               ,P_VER_IMPUESTO                   IN     VARCHAR2
                               ,P_VFO_VALOR                      IN     NUMBER
                               ,P_OFO_MONTO_ORDEN                IN OUT NUMBER
                               ,P_OFO_MONTO_CARGO_ABONO_CUENTA   IN OUT NUMBER
                               ,P_IMPUESTO_ABONO_CUENTA          IN OUT NUMBER
                               ,P_IMPUESTO_PAGOS                 IN OUT NUMBER
                               ,P_OFO_MONTO_ORDEN_UNIDADES       IN OUT NUMBER
                               ,P_IMPUESTO_ABONO_CUENTA_UNIDAD   IN OUT NUMBER
                               ,P_IMPUESTO_PAGOS_UNIDADES        IN OUT NUMBER
                               ,P_TIENE_SEGUNDO                  IN     VARCHAR2
                               ,P_RENDIMIENTOS                   IN     NUMBER) IS

   CURSOR C_ORDENES_DE_PAGO IS
      SELECT ODP_SUC_CODIGO
            ,ODP_NEG_CONSECUTIVO
            ,ODP_CONSECUTIVO
            ,ODP_MONTO_ORDEN
            ,ODP_TPA_MNEMONICO
            ,ODP_PAGAR_A
      FROM   ORDENES_DE_PAGO
      WHERE  ODP_OFO_SUC_CODIGO = P_OFO_SUC_CODIGO
      AND    ODP_OFO_CONSECUTIVO = P_OFO_CONSECUTIVO;
   ODP1   C_ORDENES_DE_PAGO%ROWTYPE;

   CURSOR C_DETALLE_ABONO IS
     SELECT DAA_VALOR,
            DAA_VALOR_DOLARES,
            DAA_OFO_SUC_CODIGO,
            DAA_OFO_CONSECUTIVO,
            DAA_SUC_CODIGO,
            DAA_NEG_CONSECUTIVO,
            DAA_CONSECUTIVO,
            DAA_VALOR_IMGF
     FROM DETALLES_ABONOS_CUENTAS
     WHERE DAA_OFO_SUC_CODIGO  = P_OFO_SUC_CODIGO
       AND DAA_OFO_CONSECUTIVO = P_OFO_CONSECUTIVO;


   CURSOR C_DAA IS --VAGTUD271 Decreto 660
     SELECT DAA_TRASLADO_CC
     FROM DETALLES_ABONOS_CUENTAS
     WHERE DAA_OFO_CONSECUTIVO = P_OFO_CONSECUTIVO
     AND DAA_SUC_CODIGO        = P_OFO_SUC_CODIGO;
   C_DAA1 C_DAA%ROWTYPE;

   CURSOR C_ORDEN  IS --VAGTUD271 Decreto 660
     SELECT OFO_TTO_TIT_CODIGO,
            OFO_MONTO_CARGO_ABONO_CUENTA,
            OFO_CARGO_ABONO_CUENTA
     FROM ORDENES_FONDOS
     WHERE OFO_SUC_CODIGO  = P_OFO_SUC_CODIGO
     AND   OFO_CONSECUTIVO = P_OFO_CONSECUTIVO;
   ORD1 C_ORDEN%ROWTYPE;

   DAA1   C_DETALLE_ABONO%ROWTYPE;

   MONTO_ORDEN                NUMBER;
   TOTAL                      NUMBER;
   TOTAL1                     NUMBER;
   V_MONTO_CARGO_ABONO_CUENTA NUMBER;
   TOTAL_PAGOS                NUMBER;
   TOTAL_ABONOS               NUMBER;
   VALOR_IMGF                 NUMBER;
   ABONO_CUENTA               NUMBER;
   AJUSTE                     NUMBER;
   COND                       VARCHAR2(1);
BEGIN
   -- Se recalculan los montos de los pagos y abonos a cuenta como si no tuviera
   TOTAL := 0;
   TOTAL1 := 0;
   MONTO_ORDEN := P_SALDO - P_VALOR_PENALIZACION;

   -- Todos los montos se recalcula como si no hubiera 4 por mil con respecto al saldo de la inversion
   -- Se coloca proporcionalmente al saldo del cierre el abono a cuenta
   IF P_OFO_MONTO_CARGO_ABONO_CUENTA IS NOT NULL THEN
      P_OFO_MONTO_CARGO_ABONO_CUENTA := ROUND(P_OFO_MONTO_CARGO_ABONO_CUENTA * MONTO_ORDEN / P_OFO_MONTO,2);
      TOTAL  := P_OFO_MONTO_CARGO_ABONO_CUENTA;
   END IF;

   -- Las ordenes de pago se recalculan con respecto al saldo de la inversion y se guarda el total de los pagos
   OPEN C_ORDENES_DE_PAGO;
   FETCH C_ORDENES_DE_PAGO INTO ODP1;
   WHILE C_ORDENES_DE_PAGO%FOUND LOOP
      UPDATE ORDENES_DE_PAGO
      SET    ODP_MONTO_ORDEN = ROUND(ODP1.ODP_MONTO_ORDEN * MONTO_ORDEN / P_OFO_MONTO,2)
      WHERE  ODP_SUC_CODIGO = ODP1.ODP_SUC_CODIGO
      AND    ODP_NEG_CONSECUTIVO = ODP1.ODP_NEG_CONSECUTIVO
      AND    ODP_CONSECUTIVO = ODP1.ODP_CONSECUTIVO;

      TOTAL := TOTAL + ROUND(ODP1.ODP_MONTO_ORDEN * MONTO_ORDEN / P_OFO_MONTO,2);
      FETCH C_ORDENES_DE_PAGO INTO ODP1;
   END LOOP;
   CLOSE C_ORDENES_DE_PAGO;

   -- Al final del ciclo anterior tenemos en la variable TOTAL el monto de la orden recalculada
   -- Actualizamos los detalles abonos a cuenta proporcional al saldo de cierre que esta en la variable MONTO ORDEN
   IF P_OFO_MONTO_CARGO_ABONO_CUENTA IS NOT NULL THEN
      OPEN C_DETALLE_ABONO;
      FETCH C_DETALLE_ABONO INTO DAA1;
      WHILE C_DETALLE_ABONO%FOUND LOOP
         UPDATE DETALLES_ABONOS_CUENTAS
         SET    DAA_VALOR = ROUND(DAA1.DAA_VALOR * MONTO_ORDEN / P_OFO_MONTO,2)
         WHERE  DAA_SUC_CODIGO = DAA1.DAA_SUC_CODIGO
         AND    DAA_NEG_CONSECUTIVO = DAA1.DAA_NEG_CONSECUTIVO
         AND    DAA_CONSECUTIVO = DAA1.DAA_CONSECUTIVO
         AND    DAA_OFO_SUC_CODIGO = DAA1.DAA_OFO_SUC_CODIGO
         AND    DAA_OFO_CONSECUTIVO = DAA1.DAA_OFO_CONSECUTIVO;
         TOTAL1 :=  TOTAL1 + ROUND(DAA1.DAA_VALOR * MONTO_ORDEN / P_OFO_MONTO,2);
         FETCH C_DETALLE_ABONO INTO DAA1;
      END LOOP;
      CLOSE C_DETALLE_ABONO;
   END IF;

   -- Se crea un ajuste a la ultima orden de pago dado por el saldo al cierre menos el monto calculado.
   -- La diferencia se le suma a la ultima orden de pago.
   UPDATE ORDENES_DE_PAGO
   SET    ODP_MONTO_ORDEN = ODP_MONTO_ORDEN + (MONTO_ORDEN - TOTAL)
   WHERE  ODP_SUC_CODIGO = ODP1.ODP_SUC_CODIGO
   AND    ODP_NEG_CONSECUTIVO = ODP1.ODP_NEG_CONSECUTIVO
   AND    ODP_CONSECUTIVO = ODP1.ODP_CONSECUTIVO;

   -- Se ajusta los abonos a cuenta con respecto al monto cargo abono cuenta para que queden iguales
   -- En el caso de que nu hubieran pagos el abono a cuenta es el saldo al cierre e igual el ajuste funcionaria
   IF P_OFO_MONTO_CARGO_ABONO_CUENTA IS NOT NULL THEN
      UPDATE DETALLES_ABONOS_CUENTAS
      SET    DAA_VALOR  = DAA_VALOR + (P_OFO_MONTO_CARGO_ABONO_CUENTA - TOTAL1)
      WHERE  DAA_SUC_CODIGO = DAA1.DAA_SUC_CODIGO
      AND    DAA_NEG_CONSECUTIVO = DAA1.DAA_NEG_CONSECUTIVO
      AND    DAA_CONSECUTIVO = DAA1.DAA_CONSECUTIVO
      AND    DAA_OFO_SUC_CODIGO = DAA1.DAA_OFO_SUC_CODIGO
      AND    DAA_OFO_CONSECUTIVO = DAA1.DAA_OFO_CONSECUTIVO;
   END IF;

   P_OFO_MONTO_ORDEN := MONTO_ORDEN;

   -- Una vez se recalcularon todos los valores al cierre del dia se empieza a recalcular el IMGF

   ABONO_CUENTA := P_OFO_MONTO_CARGO_ABONO_CUENTA;
   P_IMPUESTO_PAGOS := 0;
   P_IMPUESTO_PAGOS_UNIDADES := 0;
   P_IMPUESTO_ABONO_CUENTA := 0;
   P_IMPUESTO_ABONO_CUENTA_UNIDAD := 0;

   TOTAL_PAGOS := 0;
   TOTAL_ABONOS := 0;

   IF P_VER_IMPUESTO = 'S' THEN
      -- Se verifican las ordenes de pago y se les descuenta el IMGF
      OPEN C_ORDENES_DE_PAGO;
      FETCH C_ORDENES_DE_PAGO INTO ODP1;
      WHILE C_ORDENES_DE_PAGO%FOUND LOOP
         IF ODP1.ODP_TPA_MNEMONICO != 'TRB' AND ODP1.ODP_PAGAR_A != 'C' THEN
            UPDATE ORDENES_DE_PAGO
            SET    ODP_MONTO_ORDEN = ROUND(ODP1.ODP_MONTO_ORDEN / (1 + P_VALOR_IMPUESTO),2)
            WHERE  ODP_SUC_CODIGO = ODP1.ODP_SUC_CODIGO
            AND    ODP_NEG_CONSECUTIVO = ODP1.ODP_NEG_CONSECUTIVO
            AND    ODP_CONSECUTIVO = ODP1.ODP_CONSECUTIVO;

            P_IMPUESTO_PAGOS := P_IMPUESTO_PAGOS + ROUND(ROUND(ODP1.ODP_MONTO_ORDEN / (1 + P_VALOR_IMPUESTO),2) * P_VALOR_IMPUESTO,2);
            TOTAL_PAGOS := TOTAL_PAGOS + ROUND(ODP1.ODP_MONTO_ORDEN / (1 + P_VALOR_IMPUESTO),2);
         ELSE
            TOTAL_PAGOS := TOTAL_PAGOS + ODP1.ODP_MONTO_ORDEN;
         END IF;
         FETCH C_ORDENES_DE_PAGO INTO ODP1;
      END LOOP;
      CLOSE C_ORDENES_DE_PAGO;

      OPEN C_DETALLE_ABONO;
      FETCH C_DETALLE_ABONO INTO DAA1;
      WHILE C_DETALLE_ABONO%FOUND LOOP
         IF P_TIENE_SEGUNDO = 'S' THEN
            UPDATE DETALLES_ABONOS_CUENTAS
            SET    DAA_VALOR = ROUND(DAA1.DAA_VALOR / (1 + P_VALOR_IMPUESTO),2)
                  ,DAA_VALOR_IMGF = - ROUND(ROUND(DAA1.DAA_VALOR / (1 + P_VALOR_IMPUESTO),2) * P_VALOR_IMPUESTO,2)
            WHERE  DAA_SUC_CODIGO = DAA1.DAA_SUC_CODIGO
            AND    DAA_NEG_CONSECUTIVO = DAA1.DAA_NEG_CONSECUTIVO
            AND    DAA_CONSECUTIVO = DAA1.DAA_CONSECUTIVO;

            P_IMPUESTO_ABONO_CUENTA := P_IMPUESTO_ABONO_CUENTA + ROUND(ROUND(DAA1.DAA_VALOR / (1 + P_VALOR_IMPUESTO),2) * P_VALOR_IMPUESTO,2);
            TOTAL_ABONOS := TOTAL_ABONOS + ROUND(DAA1.DAA_VALOR / (1 + P_VALOR_IMPUESTO),2);
         ELSE
            IF P_RENDIMIENTOS > 0 THEN
               VALOR_IMGF := ROUND((DAA1.DAA_VALOR * P_RENDIMIENTOS / P_SALDO) * P_VALOR_IMPUESTO,2);

               --Control de VAGTUD271 Decreto 660
               OPEN C_DAA;
               FETCH C_DAA INTO C_DAA1;
               CLOSE C_DAA;
               IF C_DAA1.DAA_TRASLADO_CC = 'S' THEN
                  VALOR_IMGF := 0;
               ELSE
                  OPEN C_ORDEN;
                  FETCH C_ORDEN INTO ORD1;
                  CLOSE C_ORDEN;
                  IF  ORD1.OFO_TTO_TIT_CODIGO = 'ABO' AND
                      ORD1.OFO_CARGO_ABONO_CUENTA = 'S'  THEN
                      VALOR_IMGF := 0;
                  END IF;
               END IF; --Fin Control de VGATUD271 Decreto 660

               UPDATE DETALLES_ABONOS_CUENTAS
               SET    DAA_VALOR = DAA1.DAA_VALOR - VALOR_IMGF
                     ,DAA_VALOR_IMGF = - VALOR_IMGF
               WHERE  DAA_SUC_CODIGO = DAA1.DAA_SUC_CODIGO
               AND    DAA_NEG_CONSECUTIVO = DAA1.DAA_NEG_CONSECUTIVO
               AND    DAA_CONSECUTIVO = DAA1.DAA_CONSECUTIVO;

               P_IMPUESTO_ABONO_CUENTA := P_IMPUESTO_ABONO_CUENTA + VALOR_IMGF;
               TOTAL_ABONOS := TOTAL_ABONOS + DAA1.DAA_VALOR - VALOR_IMGF;
            ELSE
               TOTAL_ABONOS := TOTAL_ABONOS + DAA1.DAA_VALOR;
            END IF;
         END IF;
         FETCH C_DETALLE_ABONO INTO DAA1;
      END LOOP;
      CLOSE C_DETALLE_ABONO;

      /* Se recorre de nuevo la tabla de abonos para que en el primer abono sea para ajusta la diferencia de decimales
         si no hay abonos se hace sobre la primera orden de pago */

      AJUSTE := MONTO_ORDEN - (TOTAL_PAGOS + P_IMPUESTO_PAGOS + TOTAL_ABONOS + P_IMPUESTO_ABONO_CUENTA);
      COND := 'N';
      IF AJUSTE != 0 THEN
         OPEN C_DETALLE_ABONO;
         FETCH C_DETALLE_ABONO INTO DAA1;
         WHILE C_DETALLE_ABONO%FOUND LOOP
            COND := 'S';
            UPDATE DETALLES_ABONOS_CUENTAS
            SET    DAA_VALOR = DAA_VALOR + AJUSTE
            WHERE  DAA_SUC_CODIGO = DAA1.DAA_SUC_CODIGO
            AND    DAA_NEG_CONSECUTIVO = DAA1.DAA_NEG_CONSECUTIVO
            AND    DAA_CONSECUTIVO = DAA1.DAA_CONSECUTIVO;
            TOTAL_ABONOS := TOTAL_ABONOS + AJUSTE;
            EXIT;
         END LOOP;
         CLOSE C_DETALLE_ABONO;

         IF COND = 'N' THEN
            OPEN C_ORDENES_DE_PAGO;
            FETCH C_ORDENES_DE_PAGO INTO ODP1;
            WHILE C_ORDENES_DE_PAGO%FOUND LOOP
               UPDATE ORDENES_DE_PAGO
               SET    ODP_MONTO_ORDEN = ODP_MONTO_ORDEN + AJUSTE
               WHERE  ODP_SUC_CODIGO = ODP1.ODP_SUC_CODIGO
               AND    ODP_NEG_CONSECUTIVO = ODP1.ODP_NEG_CONSECUTIVO
               AND    ODP_CONSECUTIVO = ODP1.ODP_CONSECUTIVO;
               TOTAL_PAGOS := TOTAL_PAGOS + AJUSTE;
               EXIT;
            END LOOP;
            CLOSE C_ORDENES_DE_PAGO;
         END IF;
      END IF;

      P_OFO_MONTO_ORDEN := TOTAL_PAGOS + TOTAL_ABONOS;
      IF P_OFO_MONTO_CARGO_ABONO_CUENTA IS NOT NULL THEN
         P_OFO_MONTO_CARGO_ABONO_CUENTA := TOTAL_ABONOS;
      END IF;
   END IF;

--   P_OFO_MONTO_ORDEN := ROUND(NVL(P_OFO_MONTO_ORDEN,0)+NVL(P_OFO_MONTO_CARGO_ABONO_CUENTA,0),2);
   P_IMPUESTO_PAGOS        := ROUND(NVL(P_IMPUESTO_PAGOS,0),2);
   P_IMPUESTO_ABONO_CUENTA := ROUND(NVL(P_IMPUESTO_ABONO_CUENTA,0),2);

   P_OFO_MONTO_ORDEN_UNIDADES := ROUND(P_OFO_MONTO_ORDEN/P_VFO_VALOR,8);
   P_IMPUESTO_ABONO_CUENTA_UNIDAD := ROUND(P_IMPUESTO_ABONO_CUENTA/P_VFO_VALOR,8);
   P_IMPUESTO_PAGOS_UNIDADES := ROUND(P_IMPUESTO_PAGOS/P_VFO_VALOR,8);

   UPDATE ORDENES_FONDOS
   SET    OFO_MONTO = P_OFO_MONTO_ORDEN
         ,OFO_MONTO_CARGO_ABONO_CUENTA = P_OFO_MONTO_CARGO_ABONO_CUENTA
   WHERE  OFO_SUC_CODIGO = P_OFO_SUC_CODIGO
   AND    OFO_CONSECUTIVO = P_OFO_CONSECUTIVO ;
EXCEPTION
   WHEN OTHERS THEN
     RAISE_APPLICATION_ERROR(-20200,'Error RECALCULO_MONTO_ORDEN '||sqlerrm);
END RECALCULO_MONTO_ORDEN;
PROCEDURE P_CALCULO_IMPUESTOS(P_OFO_CFO_CCC_CLI_PER_NUM_IDEN   IN     VARCHAR2
                             ,P_OFO_CFO_CCC_CLI_PER_TID_CODI   IN     VARCHAR2
                             ,P_OFO_CFO_CCC_NUMERO_CUENTA      IN     NUMBER
                             ,P_OFO_CFO_FON_CODIGO             IN     VARCHAR2
                             ,P_OFO_CFO_CODIGO                 IN     NUMBER
                             ,P_OFO_CONSECUTIVO                IN     NUMBER
                             ,P_OFO_SUC_CODIGO                 IN     NUMBER
                             ,P_MONTO_ABONO_CUENTA             IN     NUMBER
                             ,P_VALOR_IMPUESTOS                IN OUT NUMBER
                             ,P_VALOR_IBA                      IN OUT NUMBER  --  4XMIL ORDENES DE PAGO
                             ,P_VALOR_IBC                      IN OUT NUMBER) IS -- 4XMIL ABONO CUENTA
  CURSOR tipo_fondo IS
    SELECT fon_tipo
          ,fon_bmo_mnemonico
          ,fon_retefuente
          ,fon_tipo_administracion
          ,fon_exterior_nacional
      FROM  fondos
      WHERE fon_codigo = P_OFO_CFO_FON_CODIGO;
  tf   tipo_fondo%ROWTYPE;

  CURSOR excento IS
      SELECT CCC_EXENTA_GMF
      FROM   CUENTAS_CLIENTE_CORREDORES
      WHERE  CCC_CLI_PER_NUM_IDEN   = P_OFO_CFO_CCC_CLI_PER_NUM_IDEN
      AND    CCC_CLI_PER_TID_CODIGO = P_OFO_CFO_CCC_CLI_PER_TID_CODI
      AND    CCC_NUMERO_CUENTA      = P_OFO_CFO_CCC_NUMERO_CUENTA;
  exc excento%rowtype;

  CURSOR c_constante IS
      SELECT con_valor
      FROM   constantes
      WHERE  con_mnemonico = 'IBA';
  con c_constante%ROWTYPE;

  CURSOR c_ordenes_de_pago IS
      SELECT odp_tpa_mnemonico
            ,odp_monto_orden
            ,odp_cobrar_costo_cheque
            ,odp_pagar_a
      FROM   ordenes_de_pago
      WHERE  odp_ofo_suc_codigo = P_OFO_SUC_CODIGO
      AND    odp_ofo_consecutivo = P_OFO_CONSECUTIVO
      AND    odp_odp_consecutivo is null;
   odp   c_ordenes_de_pago%ROWTYPE;

   CURSOR c_parametro(P_PARAMETRO NUMBER) IS
      SELECT pfo_rango_min_number
      FROM   parametros_fondos
      WHERE  pfo_fon_codigo = P_OFO_CFO_FON_CODIGO
        AND  pfo_par_codigo = P_PARAMETRO;
   pfo   c_parametro%ROWTYPE;

  CURSOR c_abonos IS
      SELECT SUM(daa_valor) TOTAL_ABONOS
            ,-SUM(DAA_VALOR_IMGF) TOTAL_IMPUESTOS
      FROM  detalles_abonos_cuentas
      WHERE DAA_OFO_CONSECUTIVO = P_OFO_CONSECUTIVO
      AND   DAA_OFO_SUC_CODIGO = P_OFO_SUC_CODIGO;
  r_abonos c_abonos%ROWTYPE;

  CURSOR C_TRASLADOS_PERMANENCIA IS
     SELECT SUM(TFE_VALOR_IMGF) TOTAL_TRASLADOS
     FROM   TRASLADOS_FONDO_ESCALA
     WHERE  TFE_OFO_SUC_CODIGO = P_OFO_SUC_CODIGO
     AND    TFE_OFO_CONSECUTIVO = P_OFO_CONSECUTIVO;

  v_exc          VARCHAR2(1);
  v_error        VARCHAR2(400);
  v_ver_impuesto VARCHAR2(1);
  v_monto_tcc    NUMBER;
  v_monto_gastos NUMBER;
  v_monto_odp    NUMBER;
  v_impuesto     NUMBER;  -- 4xmil pagos
  v_impuesto1    NUMBER; -- 4XMIL abonos cuentas
  v_impuesto_traslado            NUMBER;
  v_monto_cargo_abono_cuenta_imp NUMBER;
  e_error        EXCEPTION;
BEGIN
  OPEN tipo_fondo;
  FETCH tipo_fondo INTO tf;
  CLOSE tipo_fondo;
  OPEN excento;
  FETCH excento INTO exc;
  CLOSE excento;
  v_exc := NVL(exc.ccc_exenta_gmf,'N');
  OPEN c_constante;
  FETCH c_constante INTO con;
  IF c_constante%NOTFOUND THEN
     CLOSE c_constante;
     v_error := 'No se encontro el valor del impuesto bancario';
     RAISE e_error;
  END IF;
  CLOSE C_CONSTANTE;
  v_ver_impuesto := 'N';
  P_ORDENES_FONDOS.TRASLADO_CLIENTE_EXEC(P_OFO_SUC_CODIGO               => P_OFO_SUC_CODIGO,
                                         P_OFO_CONSECUTIVO              => P_OFO_CONSECUTIVO,
                                         P_OFO_CFO_CCC_CLI_PER_NUM_IDEN => P_OFO_CFO_CCC_CLI_PER_NUM_IDEN,
                                         P_OFO_CFO_CCC_CLI_PER_TID_COD  => P_OFO_CFO_CCC_CLI_PER_TID_CODI,
                                         P_OFO_CFO_CCC_NUMERO_CUENTA    => P_OFO_CFO_CCC_NUMERO_CUENTA,
                                         P_OFO_CFO_FON_CODIGO           => P_OFO_CFO_FON_CODIGO,
                                         P_OFO_CFO_CODIGO               => P_OFO_CFO_CODIGO,
                                         P_VER_IMPUESTO                 => v_ver_impuesto);
  IF tf.fon_tipo_administracion = 'A' THEN
    v_exc := 'S';
  END IF;
  v_monto_tcc    := 0;
  v_monto_gastos := 0;
  v_monto_odp    := 0;
  IF v_exc = 'N' AND
     v_ver_impuesto = 'S' THEN
    IF tf.fon_tipo = 'A' AND tf.fon_bmo_mnemonico = 'PESOS' THEN
      OPEN c_ordenes_de_pago;
      FETCH c_ordenes_de_pago INTO odp;
      WHILE c_ordenes_de_pago%FOUND LOOP
        IF odp.odp_tpa_mnemonico = 'CHE' THEN
          IF NVL(odp.odp_cobrar_costo_cheque,'N') = 'S' THEN
            OPEN c_parametro(44);
            FETCH c_parametro INTO PFO;
            IF c_parametro%FOUND THEN
              v_monto_gastos := v_monto_gastos + pfo.pfo_rango_min_number;
            END IF;
            CLOSE c_parametro;
          END IF;
        ELSIF odp.odp_tpa_mnemonico = 'CHG' THEN
          OPEN c_parametro(45);
          FETCH c_parametro INTO pfo;
          IF c_parametro%FOUND THEN
            v_monto_gastos := v_monto_gastos + pfo.pfo_rango_min_number;
          END IF;
          CLOSE c_parametro;
        ELSIF odp.odp_tpa_mnemonico = 'TRB' THEN
          OPEN c_parametro(46);
          FETCH c_parametro INTO PFO;
          IF c_parametro%FOUND THEN
            v_monto_gastos := v_monto_gastos + pfo.pfo_rango_min_number;
          END IF;
          CLOSE c_parametro;
        END IF;
        IF odp.odp_tpa_mnemonico IN ('CHE','PSE','CHG','ACH') OR
           (odp.odp_tpa_mnemonico = 'TRB' AND
            odp.odp_pagar_a != 'C') then
          v_monto_odp := v_monto_odp+nvl(odp.odp_monto_orden,0);
        END IF;
        IF odp.odp_tpa_mnemonico IN ('TCC') then
          v_monto_tcc := v_monto_tcc+nvl(odp.odp_monto_orden,0);
        END IF;
        FETCH c_ordenes_de_pago INTO odp;
      END LOOP;
      CLOSE c_ordenes_de_pago;
      v_monto_gastos := NVL(v_monto_gastos,0);
      v_monto_odp    := NVL(v_monto_odp,0);
      v_monto_tcc    := NVL(v_monto_tcc,0);
      IF v_monto_odp != 0 THEN
        v_impuesto     :=  ROUND(v_monto_odp * con.con_valor,2);
      END IF;

      IF V_VER_IMPUESTO = 'S' THEN
         OPEN c_abonos;
         FETCH c_abonos INTO r_abonos;
         IF c_abonos%FOUND THEN
            v_monto_cargo_abono_cuenta_imp := r_abonos.TOTAL_IMPUESTOS;
         ELSE
            V_MONTO_CARGO_ABONO_CUENTA_IMP := 0;
         END IF;
         CLOSE c_abonos;
      ELSE
        v_monto_cargo_abono_cuenta_imp := 0;
      END IF;
      IF NVL(v_monto_cargo_abono_cuenta_imp,0) + NVL(v_monto_tcc,0) = 0 THEN
        v_impuesto1 := 0;
      ELSE
          v_impuesto1 := NVL(v_monto_cargo_abono_cuenta_imp,0)
                       + ROUND(NVL(v_monto_tcc,0) * con.con_valor,2);
      END IF;
      OPEN C_TRASLADOS_PERMANENCIA;
      FETCH C_TRASLADOS_PERMANENCIA INTO V_IMPUESTO_TRASLADO;
      CLOSE C_TRASLADOS_PERMANENCIA;

      v_impuesto1 := v_impuesto1 + nvl(v_impuesto_traslado,0);
    ELSE
       v_impuesto  := 0;
       v_impuesto1 := 0;
    END IF;

  ELSE
    v_impuesto  := 0;
    v_impuesto1 := 0;
  END IF;
  P_VALOR_IMPUESTOS  := nvl(v_impuesto,0)+nvl(v_impuesto1,0);
  P_VALOR_IBA        := nvl(v_impuesto,0);
  P_VALOR_IBC        := nvl(v_impuesto1,0);
EXCEPTION
   WHEN e_error THEN
     RAISE_APPLICATION_ERROR(-20300,v_error);
   WHEN OTHERS THEN
     RAISE_APPLICATION_ERROR(-20400,'Error RECALCULO_MONTO_ORDEN '||sqlerrm);
END P_CALCULO_IMPUESTOS;
PROCEDURE P_TOPES_INV_COMPARTIMENTOS(P_FON_CODIGO        VARCHAR2,
                                     P_SALARIO_MINIMO    NUMBER,
                                     P_MINIMO_INVERSION  OUT NUMBER,
                                     P_MAXIMO_INVERSION  OUT NUMBER,
                                     P_VALIDA_SIN_TOPE   OUT VARCHAR2) AS
  CURSOR valor_par(TIPO NUMBER,P_FONDO VARCHAR2) IS
    SELECT pfo_rango_min_number,
           pfo_rango_max_number,
           pfo_rango_min_char,
           pfo_rango_max_char
      FROM   parametros_fondos a
      WHERE  pfo_fon_codigo = P_FONDO
        AND a.pfo_par_codigo = tipo;
  CURSOR valor_fondo (P_FONDO VARCHAR2) IS
     SELECT vfo_capital + vfo_rend_rf + vfo_rend_rv - vfo_retencion valor_fondo
     FROM valorizaciones_fondo
     WHERE vfo_fon_codigo = P_FONDO
     ORDER BY vfo_fecha_valorizacion  DESC;
   limites            valor_par%ROWTYPE;
   minimo_inver       valor_par%ROWTYPE;
   maximo_inver       valor_par%ROWTYPE;
   sin_limites        valor_par%ROWTYPE;
   limite_fondo       valor_par%ROWTYPE;
   fondo_papa         valor_par%ROWTYPE;
   c_valor_fondo      valor_fondo%ROWTYPE;
   v_valida_ingreso   VARCHAR2(1);
   NO_LIMITES         EXCEPTION;
   NO_LIMITE_FONDO    EXCEPTION;
   NO_LIMITES_MAX     EXCEPTION;
   NO_FONDO_PAPA      EXCEPTION;
BEGIN

  /*1. Determinar el tope minimo de inversion en el fondo*/

  OPEN  valor_par(112,P_FON_CODIGO); -- PARAMETRO DE VALOR MINIMO DE INVERSION
  FETCH valor_par INTO minimo_inver;
  IF valor_par%NOTFOUND THEN
    CLOSE valor_par;
    OPEN  valor_par(5,P_FON_CODIGO); -- PARAMETRO DE VALOR MINIMO DE INVERSION
    FETCH VALOR_PAR INTO limites;
    CLOSE VALOR_PAR;
  ELSE
    limites.pfo_rango_min_number  := (minimo_inver.pfo_rango_min_number);
    limites.pfo_rango_max_number  := minimo_inver.pfo_rango_max_number;
    CLOSE VALOR_PAR;
  END IF;

  IF NVL(limites.pfo_rango_min_number,0) = 0 THEN
    v_valida_ingreso := 'N';
    RAISE NO_LIMITES;
  END IF;

  /*2. Determinar el tope maximo de inversion en el fondo*/

  P_VALIDA_SIN_TOPE := 'N';

  OPEN  valor_par(75,P_FON_CODIGO); -- PARAMETRO QUE IDENTIFICA VALIDACION SIN TOPE MAXIMO DE INVERSION
  FETCH valor_par INTO sin_limites;
  IF valor_par%FOUND THEN
    P_VALIDA_SIN_TOPE := 'S';
  END IF;
  CLOSE valor_par;

  IF NVL(P_VALIDA_SIN_TOPE,'N') = 'S' THEN
    /* obtener nit del fondo papa*/
    OPEN  valor_par(71,P_FON_CODIGO);
    FETCH valor_par INTO fondo_papa;
    IF valor_par%NOTFOUND THEN
      RAISE NO_FONDO_PAPA;
    END IF;
    CLOSE valor_par;
    OPEN valor_fondo(fondo_papa.pfo_rango_min_char);
    FETCH valor_fondo INTO c_valor_fondo;
    CLOSE valor_fondo;
    OPEN  valor_par(14,P_FON_CODIGO);
    FETCH valor_par INTO limite_fondo;
    IF valor_par%NOTFOUND THEN
       RAISE NO_LIMITE_FONDO;
    END IF;
    CLOSE valor_par;
    P_MAXIMO_INVERSION :=    (NVL(c_valor_fondo.valor_fondo,0) * NVL(limite_fondo.pfo_rango_min_number,0));
    P_VALIDA_SIN_TOPE := 'N';
  ELSE
    OPEN  valor_par(113,P_FON_CODIGO); -- PARAMETRO DE VALOR MAXIMO DE INVERSION
    FETCH valor_par INTO maximo_inver;
    IF VALOR_PAR%NOTFOUND THEN
      --fmcRAISE NO_LIMITES_MAX;
      NULL;
    END IF;
    P_MAXIMO_INVERSION := (NVL(maximo_inver.pfo_rango_min_number,0))-1;
  END IF;
  P_MINIMO_INVERSION := NVL(limites.pfo_rango_min_number,0);
  EXCEPTION
    WHEN  NO_LIMITES THEN
      RAISE_APPLICATION_ERROR(-20401,'No es posible determinar valor minimo de inversion del fondo:'||P_FON_CODIGO) ;
    WHEN   NO_LIMITE_FONDO THEN
       RAISE_APPLICATION_ERROR(-20402,'No se encuentra parametro de valor movimiento  vrs  valor fondo (%)- (14)');
    WHEN  NO_LIMITES_MAX THEN
      RAISE_APPLICATION_ERROR(-20401,'No es posible determinar valor maximo de inversion del fondo:'||P_FON_CODIGO) ;
    WHEN  NO_FONDO_PAPA THEN
      RAISE_APPLICATION_ERROR(-20401,'No es posible determinar el fondo principal de los compartimentos'||P_FON_CODIGO) ;
    WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20400,'Error P_TOPES_INV_COMPARTIMENTOS '||sqlerrm);
END P_TOPES_INV_COMPARTIMENTOS;

PROCEDURE P_ORDEN_REDIMIR_TRAMO (P_OFO_CFO_CCC_CLI_PER_NUM_IDEN   IN     VARCHAR2
                                ,P_OFO_CFO_CCC_CLI_PER_TID_CODI   IN     VARCHAR2
                                ,P_OFO_CFO_CCC_NUMERO_CUENTA      IN     NUMBER
                                ,P_OFO_CFO_FON_CODIGO             IN     VARCHAR2
                                ,P_OFO_CFO_CODIGO                 IN     NUMBER
                                ,P_VFO_VALOR_UNIDAD               IN     NUMBER
                                ,P_EXC                            IN     VARCHAR2
                                ,P_VER_IMPUESTO                   IN     VARCHAR2
                                ,P_OFO_SUC_CODIGO                 IN     NUMBER
                                ,P_OFO_CONSECUTIVO                IN     NUMBER
                                ,P_CON_VALOR                      IN     NUMBER
                                ,P_OFO_FECHA_EJECUCION            IN OUT DATE
                                ,P_FECHA_ACTUALIZA_MCC            IN OUT DATE
                                ,P_FECHA                          IN OUT DATE) IS
  CURSOR redencion_tramo IS
    SELECT upf_consecutivo
          ,upf_fecha
          ,upf_fecha_disponible
          ,upf_unidades_por_penalizar
          ,upf_eof_codigo
          ,upf_cfo_ccc_cli_per_num_iden
          ,upf_cfo_ccc_cli_per_tid_codigo
          ,upf_cfo_ccc_numero_cuenta
          ,upf_cfo_fon_codigo
          ,upf_cfo_codigo
          ,upf_ofo_suc_codigo
          ,upf_ofo_consecutivo
          ,upf_pen_fon_codigo
          ,upf_pen_consecutivo
          ,upf_unidades_redimir_tramo
          ,pen_porcentaje
    FROM penalizaciones,unidades_penalizaciones_fondos upf
    WHERE pen_fon_codigo = upf_pen_fon_codigo
      AND pen_consecutivo = upf_pen_consecutivo
      AND upf_eof_codigo                  = 'CON'
      AND upf_cfo_ccc_cli_per_num_iden    = P_OFO_CFO_CCC_CLI_PER_NUM_IDEN
      AND upf_cfo_ccc_cli_per_tid_codigo  = P_OFO_CFO_CCC_CLI_PER_TID_CODI
      AND upf_cfo_ccc_numero_cuenta       = P_OFO_CFO_CCC_NUMERO_CUENTA
      AND upf_cfo_fon_codigo              = P_OFO_CFO_FON_CODIGO
      AND upf_cfo_codigo                  = P_OFO_CFO_CODIGO
      AND upf_unidades_redimir_tramo      > 0
      AND upf_fecha_pago                  >= TRUNC(P_OFO_FECHA_EJECUCION)
    ORDER BY upf_fecha_pago;
  c_redencion_tramo redencion_tramo%ROWTYPE;
  CURSOR valor_par(TIPO NUMBER) IS
      SELECT pfo_rango_min_number,
      pfo_rango_max_number
      FROM   parametros_fondos a
      WHERE a.pfo_fon_codigo = P_OFO_CFO_FON_CODIGO
        AND a.pfo_par_codigo = tipo;
   c_valor_par valor_par%ROWTYPE;
  CURSOR orden_origen IS
    SELECT OFO_CONSECUTIVO
         , OFO_SUC_CODIGO
       , OFO_CFO_CCC_CLI_PER_NUM_IDEN
       , OFO_CFO_CCC_CLI_PER_TID_CODIGO
       , OFO_CFO_CCC_NUMERO_CUENTA
       , OFO_CFO_FON_CODIGO
       , OFO_CFO_CODIGO
       , OFO_EOF_CODIGO
       , OFO_PER_NUM_IDEN
       , OFO_PER_TID_CODIGO
       , OFO_TTO_TOF_CODIGO
       , OFO_TTO_TIT_CODIGO
       , OFO_FECHA_CAPTURA
       , OFO_MONTO
       , OFO_CARGO_ABONO_CUENTA
       , OFO_MONTO_CARGO_ABONO_CUENTA
       , OFO_MONTO_ABONO_CUENTA_DOLARES
       , OFO_FECHA_MODIFICACION
       , OFO_MODIFICACION
       , OFO_FECHA_EJECUCION
       , OFO_IMPRIME_REC_DERECHOS
       , OFO_PER_NUM_IDEN_COLOCO
       , OFO_PER_TID_CODIGO_COLOCO
       , OFO_FECHA_COMPENSACION
       , OFO_A_NOMBRE_DE
       , OFO_TCF_NUMERO_TITULO
       , OFO_TCF_TAF_GRP_FON_CODIGO
       , OFO_TCF_TAF_GRP_MNEMONICO
       , OFO_TCF_TAF_MODALIDAD_TASA
       , OFO_REINVERSION
       , OFO_OCL_CLI_PER_NUM_IDEN
       , OFO_OCL_CLI_PER_TID_CODIGO
       , OFO_OCL_CLI_PER_NUM_IDEN_RELAC
       , OFO_OCL_CLI_PER_TID_CODIGO_REL
       , OFO_OCR_CONSECUTIVO
       , OFO_OCR_SUC_CODIGO
       , OFO_OFO_CONSECUTIVO
       , OFO_OFO_SUC_CODIGO
       , OFO_SOLICITUD_TARJETA
       , OFO_NOMBRE_REALCE
       , OFO_DESCRIPCION
       , OFO_AUTORIZACION
       , OFO_AUTORIZADO_POR
       , OFO_FECHA_AUTORIZACION
       , OFO_MOTIVO_AUTORIZACION
       , OFO_ORIGEN_RECURSOS
       , OFO_CUENTA_BANCO
       , OFO_PORCENTAJE
       , OFO_NUMERO_UNIDADES
       , OFO_PORCENTAJE_A
       , OFO_NUMERO_CHEQUE
       , OFO_NUMERO_COMP_EGRESO
       , OFO_NUMERO_REC_DERECHOS
       , OFO_NUMERO_REC_CAJA
       , OFO_NUMERO_LIQ_RETIRO
       , OFO_MONTO_ANTICIPO
       , OFO_CUPO_TARJETA
       , OFO_REGISTRO_AUTOMATICO
       , OFO_FECHA_IMPRESION_RD
       , OFO_USUARIO_IMPRESION_RD
       , OFO_FECHA_REIMPRESION_RD
       , OFO_USUARIO_REIMPRESION_RD
       , OFO_ORD_CONSECUTIVO
       , OFO_ORD_SUC_CODIGO
       , OFO_PRF_FON_CODIGO
       , OFO_PRF_CONSECUTIVO
       , OFO_TERMINAL_CAPTURA
       , OFO_USUARIO_CAPTURA
       , OFO_TERMINAL_CONFIRMACION
       , OFO_CONCEPTO_COBRO_APT
       , OFO_PROFESIONAL
       , OFO_RADICACION_PROFESIONAL
       , OFO_CONCEPTO_INC_APT
       , OFO_PER_NUM_IDEN_ORDEN
       , OFO_PER_TID_CODIGO_ORDEN
       , OFO_PER_NUM_IDEN_CTA
       , OFO_PER_TID_CODIGO_CTA
       , OFO_INCREMENTA_APT
       , OFO_PRIORIDAD_CLI
       , OFO_HORA_COMPROMISO_PRI
       , OFO_PORCENTAJE_PENALIZACION
       , OFO_MEDIO_RECEPCION
       , OFO_DETALLE_MEDIO_RECEPCION
       , OFO_HORA_RECEPCION
       , OFO_FECHA_RECEPCION
       , OFO_FECHA_CUMPLIMIENTO
       , OFO_AEFI_CONSECUTIVO
       , OFO_BLOQUEO_ING
       , OFO_CNL_CONSECUTIVO
       , OFO_OFC_CODIGO
       , OFO_TALON
    FROM ordenes_fondos
    WHERE ofo_suc_codigo = P_OFO_SUC_CODIGO
      AND ofo_consecutivo = P_OFO_CONSECUTIVO;
  c_orden_origen orden_origen%ROWTYPE;
   CURSOR SALDOS  IS
     SELECT CFO_SALDO_RENDIMIENTOS_RF SAL_RND_RF,
       CFO_SALDO_RENDIMIENTOS_RV       SAL_RND_RV,
       CFO_SALDO_RETEFUENTE            SAL_RET,
       CFO_SALDO_CAPITAL               SAL_CAP,
       CFO_SALDO_INVER                 SAL_INV,
       CFO_SALDO_UNIDADES              SAL_UNI,
       CFO_SALDO_INTERESES_PAGADOS     SAL_INT,
       CFO_TASA_PROMEDIO               SAL_TAS,
       CFO_SALDO_UNIDADES_NO_DISP      SAL_UND,
       SYSDATE                         SAL_FEC
     FROM CUENTAS_FONDOS
     WHERE CFO_CCC_CLI_PER_TID_CODIGO = P_OFO_CFO_CCC_CLI_PER_TID_CODI
       AND CFO_CCC_CLI_PER_NUM_IDEN   = P_OFO_CFO_CCC_CLI_PER_NUM_IDEN
       AND CFO_CCC_NUMERO_CUENTA      = P_OFO_CFO_CCC_NUMERO_CUENTA
       AND CFO_FON_CODIGO             = P_OFO_CFO_FON_CODIGO
       AND CFO_CODIGO                 = P_OFO_CFO_CODIGO;
   SAL SALDOS%ROWTYPE;
  NO_SALDO_MINIMO           EXCEPTION;
  NO_ORDEN_ORIGEN           EXCEPTION;
  SALDO_INSUFICIENTE        EXCEPTION;
  v_valida_tramos           NUMBER;
  impuesto1                 CUENTAS_FONDOS.CFO_SALDO_CAPITAL%TYPE;
  imp_unid1                 CUENTAS_FONDOS.CFO_SALDO_UNIDADES%TYPE;
  unidades_ofo_monto        CUENTAS_FONDOS.CFO_SALDO_UNIDADES%TYPE;
  v_monto_orden             ORDENES_FONDOS.OFO_MONTO%TYPE;
  v_valor_penalizacion      CUENTAS_FONDOS.CFO_SALDO_CAPITAL%TYPE;
  v_unidades_penalizacion   CUENTAS_FONDOS.CFO_SALDO_UNIDADES%TYPE;
  RP_PRC                    NUMBER;
  RP_CAP                    CUENTAS_FONDOS.CFO_SALDO_CAPITAL%TYPE;
  RP_UND                    CUENTAS_FONDOS.CFO_SALDO_UNIDADES%TYPE;
  RP_RND_RF                 CUENTAS_FONDOS.CFO_SALDO_CAPITAL%TYPE;
  RP_RND_RV                 CUENTAS_FONDOS.CFO_SALDO_CAPITAL%TYPE;
  RP_RET                    CUENTAS_FONDOS.CFO_SALDO_CAPITAL%TYPE;
  RP_AJU                    CUENTAS_FONDOS.CFO_SALDO_CAPITAL%TYPE;
  CONSECUTIVO_ORDEN         ORDENES_FONDOS.OFO_CONSECUTIVO%TYPE;
  v_tipo_orden              VARCHAR2(2);
  v_ofo_fecha_ejecucion     DATE;
BEGIN
  /*Creacion de orden de retiro parcial o total por saldos de redencion del tramo*/
  /*1.Obtener tramos con saldo pendiente de redencion*/
  OPEN  valor_par(28);
  FETCH valor_par INTO c_valor_par;
  IF valor_par%NOTFOUND THEN
    RAISE NO_SALDO_MINIMO;
  END IF;
  CLOSE VALOR_PAR;
  OPEN orden_origen;
  FETCH orden_origen INTO c_orden_origen;
  IF orden_origen%NOTFOUND THEN
    RAISE NO_ORDEN_ORIGEN;
  END IF;
  CLOSE orden_origen ;
  OPEN SALDOS;
  FETCH SALDOS INTO SAL;
  CLOSE SALDOS;
  v_ofo_fecha_ejecucion := P_SALDOS_CLIENTES.F_FECHA_HABIL(TRUNC(P_OFO_FECHA_EJECUCION+1),1);
  OPEN redencion_tramo;
  FETCH redencion_tramo INTO c_redencion_tramo;
  WHILE redencion_tramo%FOUND LOOP
    v_monto_orden := ROUND(c_redencion_tramo.upf_unidades_redimir_tramo*P_VFO_VALOR_UNIDAD,2);
    v_valor_penalizacion      := 0;
    v_unidades_penalizacion   := 0;
    IF v_monto_orden < c_valor_par.pfo_rango_min_number  THEN
      /* Generacion de la orden por el saldo de unidades menores al saldo minimo */
      /* Validar si existen tramos vigentes del cliente
         Si no existen mas se genera orden de RT
         Si existen mas tramos se genera orden de RP*/
       BEGIN
         v_valida_tramos := 0;
         SELECT COUNT(*)
         INTO v_valida_tramos
         FROM unidades_penalizaciones_fondos
         WHERE upf_eof_codigo                  = 'APR'
           AND upf_cfo_ccc_cli_per_num_iden    = P_OFO_CFO_CCC_CLI_PER_NUM_IDEN
           AND upf_cfo_ccc_cli_per_tid_codigo  = P_OFO_CFO_CCC_CLI_PER_TID_CODI
           AND upf_cfo_ccc_numero_cuenta       = P_OFO_CFO_CCC_NUMERO_CUENTA
           AND upf_cfo_fon_codigo              = P_OFO_CFO_FON_CODIGO
           AND upf_cfo_codigo                  = P_OFO_CFO_CODIGO
           AND upf_unidades_por_penalizar      > 0
           AND upf_fecha_pago            >= TRUNC(P_OFO_FECHA_EJECUCION);
       END;
       v_valida_tramos := nvl(v_valida_tramos,0);
       IF v_valida_tramos > 1 THEN
         v_tipo_orden := 'RP';
       ELSE
         v_tipo_orden := 'RT';
       END IF;
       /* CREACION DE LA ORDEN DE FONDOS*/
       SELECT OFO_SEQ.NEXTVAL
       INTO   CONSECUTIVO_ORDEN
       FROM   DUAL;
       INSERT INTO ordenes_fondos(
          ofo_consecutivo
         ,ofo_suc_codigo
         ,ofo_cfo_ccc_cli_per_num_iden
         ,ofo_cfo_ccc_cli_per_tid_codigo
         ,ofo_cfo_ccc_numero_cuenta
         ,ofo_cfo_fon_codigo
         ,ofo_cfo_codigo
         ,ofo_eof_codigo
         ,ofo_per_num_iden
         ,ofo_per_tid_codigo
         ,ofo_tto_tof_codigo
         ,ofo_tto_tit_codigo
         ,ofo_fecha_captura
         ,ofo_monto
         ,ofo_cargo_abono_cuenta
         ,ofo_monto_cargo_abono_cuenta
         ,ofo_monto_abono_cuenta_dolares
