       CLOSE C_ACC_PORTAFOLIO;

        OPEN C_ACC_PORTAFOLIO_LOCAL(TRUNC(V_FECHA_INICIO_SEMANA));--CONSULTA ACCIONES PORTAFOLIO LOCAL RSINRV
