              TRIM(TAE_REFERENCIA_CLIENTE) TAE_REFERENCIA_CLIENTE,
              SUBSTR(TAE_REFERENCIA_CLIENTE,1,INSTR(TAE_REFERENCIA_CLIENTE,' ')) ORDEN,
              SUBSTR(TAE_REFERENCIA_CLIENTE,INSTR(TAE_REFERENCIA_CLIENTE,' ')+1,2) SUCURSAL,
              TAE_FECHA_INGRESO,
              TAE_HORA_INSCRIPCION,
              TAE_MONTO_TRANSACCION,
              ABS(TO_NUMBER(NVL(TRIM(TAE_MONTO_TRANSACCION),'0'),'999,999,999,999,999.00')) MONTO_TRANSACCION,
