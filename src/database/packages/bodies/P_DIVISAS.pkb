--------------------------------------------------------
--  DDL for Package Body P_DIVISAS
--------------------------------------------------------

  CREATE OR REPLACE EDITIONABLE PACKAGE BODY "PROD"."P_DIVISAS" IS
 PROCEDURE RECALCULO_SALDOS_CLIENTES IS
   XSALDOINICIAL             NUMBER(22,2);
   XSALDOINICIAL_RESTRINGIDO NUMBER(22,2);
   XSALDOFINAL               NUMBER(22,2);
   XSALDOFINAL_RESTRINGIDO   NUMBER(22,2);
   CONTADOR                  NUMBER(5);
   XMIGRADO                  NUMBER(1);
   cursor CUR_CTA is
      select CDV_CCC_CLI_PER_NUM_IDEN    ,
             CDV_CCC_CLI_PER_TID_CODIGO  ,
             CDV_CCC_NUMERO_CUENTA       ,
             CDV_BMO_MNEMONICO
      FROM CUENTAS_CLIENTES_DIVISAS;
--      WHERE  CDV_CCC_CLI_PER_NUM_IDEN IN ('800173004');
   cursor CUR_MVTOINI (XNIT VARCHAR2, XTIPO VARCHAR, XCTA NUMBER, XBMO VARCHAR2) is
      select MCD_FECHA                     ,
             MCD_CDV_CCC_CLI_PER_NUM_IDEN  ,
             MCD_CDV_CCC_CLI_PER_TID_CODIGO,
             MCD_CDV_CCC_NUMERO_CUENTA     ,
             MCD_CDV_BMO_MNEMONICO         ,
             MCD_SALDO                     ,
             MCD_SALDO_RESTRINGIDO
      from MOVIMIENTOS_CUENTAS_DIVISAS
      WHERE MCD_TDV_MNEMONICO              = 'SALINI'
        AND MCD_CDV_CCC_CLI_PER_NUM_IDEN   = XNIT
        AND MCD_CDV_CCC_CLI_PER_TID_CODIGO = XTIPO
        AND MCD_CDV_CCC_NUMERO_CUENTA      = XCTA
        AND MCD_CDV_BMO_MNEMONICO          = XBMO;
   cursor CUR_MVTODIA (XNIT VARCHAR2, XTIPO VARCHAR, XCTA NUMBER, XBMO VARCHAR2) is
      select MCD_CDV_CCC_CLI_PER_NUM_IDEN            ,
             MCD_CDV_CCC_CLI_PER_TID_CODIGO          ,
             MCD_CDV_CCC_NUMERO_CUENTA               ,
             MCD_CDV_BMO_MNEMONICO                   ,
             MCD_FECHA                               ,
             MCD_MONTO                               ,
             MCD_MONTO_RESTRINGIDO                   ,
             MCD_SALDO                               ,
             MCD_SALDO_RESTRINGIDO
      from MOVIMIENTOS_CUENTAS_DIVISAS
      WHERE MCD_TDV_MNEMONICO              <> 'SALINI'
        AND MCD_CDV_CCC_CLI_PER_NUM_IDEN   = XNIT
        AND MCD_CDV_CCC_CLI_PER_TID_CODIGO = XTIPO
        AND MCD_CDV_CCC_NUMERO_CUENTA      = XCTA
        AND MCD_CDV_BMO_MNEMONICO          = XBMO
      ORDER BY MCD_FECHA;
begin
   XSALDOINICIAL             := 0;
   XSALDOINICIAL_RESTRINGIDO := 0;
   XMIGRADO                  := 0;
   CONTADOR                  := 0;
   For REC_CTA in CUR_CTA loop
      XMIGRADO     := 0;
      For REC_MVTOINI in CUR_MVTOINI (REC_CTA.CDV_CCC_CLI_PER_NUM_IDEN  ,
                                      REC_CTA.CDV_CCC_CLI_PER_TID_CODIGO,
                                      REC_CTA.CDV_CCC_NUMERO_CUENTA     ,
                                      REC_CTA.CDV_BMO_MNEMONICO)        loop
         XMIGRADO                  := 1;
         XSALDOINICIAL             := REC_MVTOINI.MCD_SALDO;
         XSALDOINICIAL_RESTRINGIDO := REC_MVTOINI.MCD_SALDO_RESTRINGIDO;
         XSALDOFINAL               := XSALDOINICIAL;
         XSALDOFINAL_RESTRINGIDO   := XSALDOINICIAL_RESTRINGIDO;
         For REC_MVTODIA in CUR_MVTODIA (REC_MVTOINI.MCD_CDV_CCC_CLI_PER_NUM_IDEN  ,
                                         REC_MVTOINI.MCD_CDV_CCC_CLI_PER_TID_CODIGO,
                                         REC_MVTOINI.MCD_CDV_CCC_NUMERO_CUENTA     ,
                                         REC_MVTOINI.MCD_CDV_BMO_MNEMONICO)        loop
            XSALDOFINAL              := XSALDOFINAL   + REC_MVTODIA.MCD_MONTO;
            XSALDOFINAL_RESTRINGIDO  := XSALDOFINAL_RESTRINGIDO   + REC_MVTODIA.MCD_MONTO_RESTRINGIDO;
            UPDATE MOVIMIENTOS_CUENTAS_DIVISAS
            SET    MCD_SALDO                      = XSALDOFINAL,
                   MCD_SALDO_RESTRINGIDO          = XSALDOFINAL_RESTRINGIDO
            WHERE  MCD_CDV_CCC_CLI_PER_NUM_IDEN   = REC_MVTODIA.MCD_CDV_CCC_CLI_PER_NUM_IDEN
              AND  MCD_CDV_CCC_CLI_PER_TID_CODIGO = REC_MVTODIA.MCD_CDV_CCC_CLI_PER_TID_CODIGO
              AND  MCD_CDV_CCC_NUMERO_CUENTA      = REC_MVTODIA.MCD_CDV_CCC_NUMERO_CUENTA
              AND  MCD_CDV_BMO_MNEMONICO          = REC_MVTODIA.MCD_CDV_BMO_MNEMONICO
              AND  MCD_FECHA                      = REC_MVTODIA.MCD_FECHA;
         End loop;
      End loop;
      IF XMIGRADO = 0 THEN
         XSALDOFINAL              := 0;
         XSALDOFINAL_RESTRINGIDO  := 0;
         For REC_MVTODIA in CUR_MVTODIA (REC_CTA.CDV_CCC_CLI_PER_NUM_IDEN  ,
                                         REC_CTA.CDV_CCC_CLI_PER_TID_CODIGO,
                                         REC_CTA.CDV_CCC_NUMERO_CUENTA     ,
                                         REC_CTA.CDV_BMO_MNEMONICO)        loop
            XSALDOFINAL              := XSALDOFINAL + REC_MVTODIA.MCD_MONTO;
            XSALDOFINAL_RESTRINGIDO  := XSALDOFINAL_RESTRINGIDO + REC_MVTODIA.MCD_MONTO_RESTRINGIDO;
            UPDATE  MOVIMIENTOS_CUENTAS_DIVISAS
            SET MCD_SALDO             = XSALDOFINAL,
                MCD_SALDO_RESTRINGIDO = XSALDOFINAL_RESTRINGIDO
            WHERE MCD_CDV_CCC_CLI_PER_NUM_IDEN   = REC_MVTODIA.MCD_CDV_CCC_CLI_PER_NUM_IDEN
            AND   MCD_CDV_CCC_CLI_PER_TID_CODIGO = REC_MVTODIA.MCD_CDV_CCC_CLI_PER_TID_CODIGO
            AND   MCD_CDV_CCC_NUMERO_CUENTA      = REC_MVTODIA.MCD_CDV_CCC_NUMERO_CUENTA
            AND   MCD_CDV_BMO_MNEMONICO          = REC_MVTODIA.MCD_CDV_BMO_MNEMONICO
            AND   MCD_FECHA                      = REC_MVTODIA.MCD_FECHA;
         End loop;
      END IF;
      UPDATE CUENTAS_CLIENTES_DIVISAS
      SET    CDV_SALDO             = XSALDOFINAL,
             CDV_SALDO_RESTRINGIDO = XSALDOFINAL_RESTRINGIDO
      WHERE  CDV_CCC_CLI_PER_NUM_IDEN   = REC_CTA.CDV_CCC_CLI_PER_NUM_IDEN
        AND  CDV_CCC_CLI_PER_TID_CODIGO = REC_CTA.CDV_CCC_CLI_PER_TID_CODIGO
        AND  CDV_CCC_NUMERO_CUENTA      = REC_CTA.CDV_CCC_NUMERO_CUENTA
        AND  CDV_BMO_MNEMONICO          = REC_CTA.CDV_BMO_MNEMONICO;
      CONTADOR    := CONTADOR + 1;
      IF CONTADOR = 10 THEN
         Commit;
         CONTADOR := 0;
      END IF;
   End loop;
   Commit;
EXCEPTION
   WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20301,SQLERRM || 'Error recalculando saldo de clientes en divisas');
END RECALCULO_SALDOS_CLIENTES;
--
--
PROCEDURE P_SUBCUENTA_EN_CEROS(P_CONN     IN OUT utl_smtp.connection
                            ,P_UC       VARCHAR2
                            ,P_SC       VARCHAR2
                            ,P_SIGNO    VARCHAR2
                            ,P_COL      VARCHAR2
                            ,P_CONSECU  IN OUT NUMBER
                            ,P_REGISTRO_230 IN OUT T_REGISTRO_230) IS
  v_bufline          VARCHAR2(2000) := NULL;
  crlf               VARCHAR2(2) :=  CHR(13)||CHR(10);
BEGIN
  P_CONSECU := P_CONSECU + 1;
  v_bufline := LPAD(P_CONSECU, 5, '0')||'4'||'230'||LPAD(P_COL, 2, '0')||P_UC||P_SC||P_SIGNO||LTRIM(TO_CHAR(0, '00000000000000000.00'), ' ');
  P_ESCRIBE_FORMATO_230(P_REGISTRO_230  => P_REGISTRO_230,P_BUFLINE      => v_bufline );
EXCEPTION
  WHEN OTHERS THEN
     P_MAIL.ENVIO_MAIL_ERROR('Error ejecutando P_DIVISAS.P_SUBCUENTA_EN_CEROS ',SQLERRM);
      RAISE_APPLICATION_ERROR(-20001,'Error ejecutando P_DIVISAS.P_SUBCUENTA_EN_CEROS '||SQLERRM);
END P_SUBCUENTA_EN_CEROS;
--
-- ------------------------------------------------------------------------------------------------------------------------------------------------------------------
PROCEDURE P_MAIL_FORMATO_230(P_FECHA           DATE     DEFAULT NULL
                            ,P_LLAMADO_REPORTE VARCHAR2 DEFAULT NULL
                            ,P_REGISTRO_230    IN OUT T_REGISTRO_230) IS
  --
  CURSOR CIERRE_CONT_DIV(P_FECHA DATE) IS
    SELECT NVL(CND_SALDO_LIBROS_BANCO, 0) + NVL(CND_SALDO_REMESAS,0) CND_SALDO_LIBROS_BANCO
          ,NVL(CND_SALDO_CONCILIACION, 0) CND_SALDO_CONCILIACION
    FROM CIERRES_CONTABLES_DIVISAS
    WHERE CND_FECHA >= TRUNC(P_FECHA)
    AND   CND_FECHA < TRUNC(P_FECHA + 1); --:CDI.CDI_FECHA_PROCESO;
  R_CIERRE_CONT_DIV CIERRE_CONT_DIV%ROWTYPE;
  --
  CURSOR CIERRE_DIV(P_FECHA DATE) IS
    SELECT (NVL(CDI_VALOR_NEXT_DAY, 0) + NVL(CDI_VALOR_NEXT_DAY_CLIENTE, 0)) OPERA_CONTADO
          ,CDI_VALOR_NEXT_DAY
          ,CDI_VALOR_NEXT_DAY_CLIENTE
          ,(NVL(CDI_VALOR_NEXT_DAY, 0) + NVL(CDI_VALOR_NEXT_DAY_CLIENTE, 0)) OPERA_CONTADO_PASIVO
          ,NVL(CDI_VALOR_POSICION_OPCF, 0)                                   CDI_VALOR_POSICION_OPCF
          ,NVL(CDI_VALOR_POSICION_OPCF, 0)                                   CDI_VALOR_POSICION_OPCF_OB
          ,NVL(CDI_COMPRAS_USD, 0)                                           CDI_COMPRAS_USD
          ,DECODE(NVL(CDI_COMPRAS_USD,0),0,0,(NVL(CDI_COMPRAS_PESOS, 0)/NVL(CDI_COMPRAS_USD, 1)))   TASA_PROM_C
          ,NVL(CDI_VENTAS_USD, 0)                                            CDI_VENTAS_USD
          ,DECODE(NVL(CDI_VENTAS_USD,0),0,0,(NVL(CDI_VENTAS_PESOS, 0)/NVL(CDI_VENTAS_USD, 1)))      TASA_PROM_V
          ,CDI_ACTIVOS_ME_1MES
          ,CDI_ACTIVOS_ME_1ANO
          ,CDI_PASIVOS_ME_1MES
          ,CDI_PASIVOS_ME_1ANO
          ,CDI_PATRIMONIO_TECNICO_USD
          ,CDI_VLRMAX_PP_PCAMB_GLOBAL
          ,CDI_VLRMAX_PP_CONTADO
          ,CDI_VLRMAX_PBRUTA_APALANC
          ,CDI_VLRMIN_PP_PCAMB_GLOBAL
          ,CDI_VLRMIN_PP_CONTADO
          ,CDI_PROMEDIO_PP
          ,CDI_PROMEDIO_PCAMB_GLOBAL
          ,CDI_PROMEDIO_PP_CONTADO
          ,CDI_PROMEDIO_PBRUTA_APALANC
          ,CDI_EXCESO_PP
          ,CDI_EXCESO_PCAMB_GLOBAL
          ,CDI_EXCESO_PP_CONTADO
          ,CDI_EXCESO_PBRUTA_APALANC
          ,CDI_DEFECTO_PP
          ,CDI_DEFECTO_PCAMB_GLOBAL
          ,CDI_DEFECTO_PP_CONTADO
          ,CDI_PBRUTA_APALANC_DERIVADOS
          ,CDI_INVENTARIO_FINAL_USD
          ,CDI_NEXT_INT_COMPRAS
          ,CDI_NEXT_INT_VENTAS
          ,CDI_OPCF_COMPRAS
          ,CDI_OPCF_VENTAS
          ,CDI_FORWARD_COMPRAS
          ,CDI_FORWARD_VENTAS
          ,CDI_DERIVADOS_COMPRAS
          ,CDI_DERIVADOS_VENTAS
          ,CDI_SANCION_POSICION
          ,CDI_ME_ACT_PROVE_LOC_LIQUIDA          
          ,CDI_ME_ACT_MENOR_2DIAS
          ,CDI_ME_PAS_FINAN_OPER_LIQUID
          ,CDI_ME_PAS_MENOR_2DIAS
          ,CDI_DERECHOS_ADQUIRIDOS
          ,CDI_DERECHOS_CEDIDOS
          ,CDI_DER_BVC_PP_COM
          ,CDI_DER_BVC_PP_VEN
          ,CDI_DER_BVC_CL_COM
          ,CDI_DER_BVC_CL_VEN
          ,nvl(CDI_SALDO_DEPOSITOS,0) CDI_SALDO_DEPOSITOS
          ,NVL(CDI_ACTIVOS_ME_PLAZO1,0) CDI_ACTIVOS_ME_PLAZO1
          ,NVL(CDI_ACTIVOS_ME_PLAZO2,0) CDI_ACTIVOS_ME_PLAZO2
          ,NVL(CDI_ACTIVOS_ME_PLAZO3,0) CDI_ACTIVOS_ME_PLAZO3
          ,NVL(CDI_ACTIVOS_ME_PLAZO4,0) CDI_ACTIVOS_ME_PLAZO4
          ,NVL(CDI_PASIVOS_ME_PLAZO1,0) CDI_PASIVOS_ME_PLAZO1
          ,NVL(CDI_PASIVOS_ME_PLAZO2,0) CDI_PASIVOS_ME_PLAZO2
          ,NVL(CDI_PASIVOS_ME_PLAZO3,0) CDI_PASIVOS_ME_PLAZO3
          ,NVL(CDI_PASIVOS_ME_PLAZO4,0) CDI_PASIVOS_ME_PLAZO4
    FROM CIERRE_DIVISAS
    WHERE CDI_FECHA_PROCESO >= TRUNC(P_FECHA)
    AND   CDI_FECHA_PROCESO < TRUNC(P_FECHA + 1);
  r_cierre_div CIERRE_DIV%ROWTYPE;
  --
  CURSOR FORWARDS(P_FECHA DATE, P_PUNTA VARCHAR2) IS
    SELECT SUM(FWA_VALOR_DOLARES) FWA_VALOR_DOLARES
    FROM FORWARDS
    WHERE FWA_FECHA_VENCIMIENTO >= TRUNC(P_FECHA)
    AND   FWA_FECHA_VENCIMIENTO < TRUNC(P_FECHA + 1)
    AND   FWA_PUNTA = P_PUNTA;
  R_FORWARDS FORWARDS%ROWTYPE;
  --
  CURSOR FORWARD_DIAS (P_PUNTA        VARCHAR2,
                       P_FECHA        DATE) IS
    SELECT SUM(FWA_VALOR_DOLARES) FWA_VALOR_DOLARES
    FROM forwards
    WHERE FWA_PUNTA = P_PUNTA
      AND FWA_FECHA_VENCIMIENTO >= TRUNC(P_FECHA+2);
  R_FORWARD_DIAS FORWARD_DIAS%ROWTYPE;
  --
  CURSOR TIPO_MOVDIV(P_TMD TIPOS_MVTOS_DIVISAS.TMD_MNEMONICO%TYPE) IS
    SELECT TMD_MOVIMIENTO_INTERBANCARIO
    FROM TIPOS_MVTOS_DIVISAS
    WHERE TMD_MNEMONICO = P_TMD;
  --
  CURSOR ORDDIV(P_FECHA DATE, P_INTERBANCARIO VARCHAR2) IS
    SELECT SUM(DECODE(ORD_TIPO_ORDEN, 'C', ORD_VALOR_DOLARES, -ORD_VALOR_DOLARES)) SUMA_USD
    FROM ORDENES_DIVISAS
    WHERE ORD_EOF_CODIGO = 'APR'
    AND   ORD_FECHA_APROBACION >= TRUNC(P_FECHA)
    AND   ORD_FECHA_APROBACION < TRUNC(P_FECHA + 1)
    AND   ORD_TIPO_ORDEN IN ('C', 'V')
    AND   ((P_INTERBANCARIO = 'N' AND ORD_CLI_PER_NUM_IDEN != '860079174')
           OR P_INTERBANCARIO = 'S')  
    AND   EXISTS (SELECT 'X'
                  FROM TIPOS_MVTOS_DIVISAS
                  WHERE TMD_MNEMONICO = ORD_TMD_MNEMONICO
                  AND   TMD_MOVIMIENTO_INTERBANCARIO = P_INTERBANCARIO);
  R_ORDDIV ORDDIV%ROWTYPE;
  --
  CURSOR VLR_DOLAR(P_FECHA DATE) IS
    SELECT CBM_VALOR
    FROM  COTIZACIONES_BASE_MONETARIAS
    WHERE CBM_BMO_MNEMONICO = 'DOLAR'
    AND   CBM_FECHA >= TRUNC(P_FECHA)
    AND   CBM_FECHA < TRUNC(P_FECHA + 1);
  --
  CURSOR OP_ENTRE_MESAS(P_FECHA DATE) IS
    SELECT COUNT(OMD_OPERACIONES_DE_COMPRA)                               c_numero_operaciones
          ,COUNT(OMD_OPERACIONES_DE_VENTA)                                v_numero_operaciones
          --,ROUND(AVG(OMD_TASA_PROM_PONDER_COMPRAS))                       c_tasa_promedio
          --,ROUND(AVG(OMD_TASA_PROM_PONDER_VENTAS))                        v_tasa_promedio
          ,SUM(OMD_VALOR_PESOS_COMPRAS)                                   c_total_valor_pesos
          ,SUM(OMD_VALOR_PESOS_VENTAS)                                    v_total_valor_pesos
          ,SUM(OMD_MONTO_DOLARES_COMPRAS) - SUM(OMD_MONTO_DOLARES_VENTAS) total_valor_dolares
    FROM OP_DIARIAS_DIVISAS_ENTRE_MESAS
    WHERE OMD_FECHA >= TRUNC(P_FECHA)
    AND   OMD_FECHA <  TRUNC(P_FECHA + 1);
  R_OP_ENTRE_MESAS OP_ENTRE_MESAS%ROWTYPE;

  --HROSAS,
  CURSOR C_VALOR_INVERS (P_FEC_APLIC  DATE) IS
      SELECT I.IFC_FACTOR
      FROM INVERSION_FILIALES_CORREDORES I 
      WHERE I.IFC_FECHA_APLICACION <= P_FEC_APLIC
      ORDER BY I.IFC_FECHA_APLICACION DESC;  
  VALOR_INVERS  NUMBER;
  --FIN HROSAS
  --VAGTUD644-2 - CIRC. REG. DODM139 - SMORALES
  CURSOR C_SUMA_SALDO (P_FECHA DATE) IS 
     SELECT NVL(SUM(SALDO),0) SUMA FROM (
        (SELECT HNI_CAUSACION
               ,HNI_COMENTARIO
               ,HNI_COMPLEMENTACION
               ,HNI_CONSECUTIVO
               ,HNI_CRP_MNEMONICO
               ,HNI_CRP_NOMBRE
               ,HNI_ESTADO
               ,HNI_FECHA_CAPTURA
               ,HNI_FECHA_REGISTRO
               ,HNI_MONETIZACION
               ,HNI_NIN_CONSECUTIVO
               ,HNI_NUM_FACTURA
               ,HNI_PAGO
               ,HNI_SALDO SALDO
               ,HNI_TIPO_MOV
               ,HNI_USUARIO
         FROM   HIST_NEGOCIOS_INTERNACIONALES 
         WHERE (HNI_ESTADO,
                HNI_CRP_MNEMONICO, 
                HNI_NIN_CONSECUTIVO) IN 
                   (SELECT  MAX(A.HNI_ESTADO)
                           ,A.HNI_CRP_MNEMONICO
                           ,A.HNI_NIN_CONSECUTIVO 
                    FROM   HIST_NEGOCIOS_INTERNACIONALES A
                          ,NEGOCIOS_INTERNACIONALES B
                    WHERE  A.HNI_NIN_CONSECUTIVO = B.NIN_CONSECUTIVO
                    AND    TRUNC(HNI_FECHA_CAPTURA) <= P_FECHA
                    GROUP BY A.HNI_CRP_MNEMONICO,A.HNI_NIN_CONSECUTIVO )));
  R_SUMA_SALDO   C_SUMA_SALDO%ROWTYPE;

  ---UC01002
   CURSOR CBE IS 
            SELECT CBE_BEX_MNEMONICO,
                   CBE_NUMERO_CUENTA,
                   CBE_BMO_MNEMONICO
            FROM CUENTAS_BANCARIAS_EXTERIOR
            WHERE CBE_ESTADO ='A'
            AND CBE_POSICION_PROPIA ='S';      
   C_CBE CBE%ROWTYPE;

   CURSOR SALDO_CBE(P_FECHA DATE) IS
      SELECT MBE_SALDO 
      FROM MOVIMIENTOS_BANCARIOS_EXTERIOR
      WHERE MBE_CBE_BEX_MNEMONICO = C_CBE.CBE_BEX_MNEMONICO
      AND MBE_CBE_NUMERO_CUENTA = C_CBE.CBE_NUMERO_CUENTA
      AND MBE_FECHA <= P_FECHA+1
      ORDER BY MBE_FECHA DESC;  

   CURSOR ODO(P_FECHA DATE,P_TIPO VARCHAR2) IS
      SELECT SUM(ODO_VALOR_COMPROMISO) 
      FROM OTROS_DERECHOS_OBLIGACIONES
      WHERE ODO_TIPO = P_TIPO--'CAJA MENOR'
      AND ODO_FECHA >= TRUNC(P_FECHA)
      AND ODO_FECHA < TRUNC(P_FECHA+1);

   CURSOR POSICION (UC VARCHAR2,SUBC VARCHAR2,P_FECHA DATE) IS      
      SELECT RMO_VALOR FROM REGISTROS_MONEDA_230
      WHERE RMO_MFO_UNIDAD_CAPTURA =UC
      AND RMO_MFO_SUBCUENTA =SUBC
      AND RMO_MFO_TIPO_INFORMACION ='TOTAL'
      AND RMO_FECHA >= TRUNC(P_FECHA)
      AND RMO_FECHA < TRUNC(P_FECHA+1);
   ---UC21
   ---SUBC005
   CURSOR UC21005 (P_FECHA DATE)IS
      SELECT SUM(RMO.RMO_VALOR) VALOR
      FROM REGISTROS_MONEDA_230 RMO
         ,BASES_MONETARIAS BMO
         ,MONEDAS_DIVISAS MDI
      WHERE RMO.RMO_MFO_BMO_MNEMONICO = BMO.BMO_MNEMONICO
      AND BMO.BMO_CODIGO_PIP = MDI.MDI_MNEMONICO
      AND RMO.RMO_COMPROMISO ='POSICION'
      AND RMO.RMO_MFO_UNIDAD_CAPTURA ='20'
      AND RMO.RMO_VALOR >= 0
      AND RMO_FECHA >= TRUNC(P_FECHA)
      AND RMO_FECHA < TRUNC(P_FECHA+1);
   ---SUBC005
   CURSOR UC21010 (P_FECHA DATE)IS
      SELECT SUM(RMO.RMO_VALOR) VALOR
      FROM REGISTROS_MONEDA_230 RMO
         ,BASES_MONETARIAS BMO
         ,MONEDAS_DIVISAS MDI
      WHERE RMO.RMO_MFO_BMO_MNEMONICO = BMO.BMO_MNEMONICO
      AND BMO.BMO_CODIGO_PIP = MDI.MDI_MNEMONICO
      AND RMO.RMO_COMPROMISO ='POSICION'
      AND RMO.RMO_MFO_UNIDAD_CAPTURA ='20'
      AND RMO.RMO_VALOR < 0
      AND RMO_FECHA >= TRUNC(P_FECHA)
      AND RMO_FECHA < TRUNC(P_FECHA+1);
--
   CURSOR UC11050 (P_FECHA DATE) IS
      SELECT SUM(VALOR)/3 VALOR FROM (
         SELECT 
         SUM(RMO.RMO_VALOR) VALOR, RMO_FECHA
         FROM REGISTROS_MONEDA_230 RMO
            ,BASES_MONETARIAS BMO
            ,MONEDAS_DIVISAS MDI
         WHERE RMO.RMO_MFO_BMO_MNEMONICO = BMO.BMO_MNEMONICO
         AND BMO.BMO_CODIGO_PIP = MDI.MDI_MNEMONICO
         AND RMO.RMO_COMPROMISO ='POSICION'
         AND RMO.RMO_MFO_UNIDAD_CAPTURA ='20'
         AND RMO.RMO_VALOR >= 0
         AND RMO_FECHA < TRUNC(P_FECHA+1) 
         GROUP BY RMO_FECHA
         ORDER BY RMO_FECHA DESC)
      WHERE ROWNUM >=0
      AND ROWNUM < 4;

   CURSOR UC11055 (P_FECHA DATE) IS
      SELECT SUM(VALOR)/3 VALOR FROM (
         SELECT 
         SUM(CASE WHEN RMO.RMO_VALOR < 0 THEN RMO.RMO_VALOR ELSE 0 END) VALOR, RMO_FECHA
         FROM REGISTROS_MONEDA_230 RMO
            ,BASES_MONETARIAS BMO
            ,MONEDAS_DIVISAS MDI
         WHERE RMO.RMO_MFO_BMO_MNEMONICO = BMO.BMO_MNEMONICO
         AND BMO.BMO_CODIGO_PIP = MDI.MDI_MNEMONICO
         AND RMO.RMO_COMPROMISO ='POSICION'
         AND RMO.RMO_MFO_UNIDAD_CAPTURA ='20'
       --  AND RMO.RMO_VALOR < 0
         AND RMO_FECHA < TRUNC(P_FECHA+1) 
         GROUP BY RMO_FECHA
         ORDER BY RMO_FECHA DESC)
      WHERE ROWNUM >=0
      AND ROWNUM < 4;

   CURSOR FECHA_CALCULO(P_FECHA DATE) IS
      SELECT 'X' 
      FROM FECHAS_PROMEDIOS_230
      WHERE FEP_FECHA_CALCULO >= TRUNC(P_FECHA)
      AND FEP_FECHA_CALCULO   < TRUNC(P_FECHA+1);      

  -- SORTIZ - TRANSMISIONES 3
   --CURSOR C_TFO_IAP IS
   CURSOR C_PORTAFOLIO_RF_PP (P_FECHA_DESDE DATE) IS
      --SELECT TFO_ENA_MNEMONICO, TFO_FON_CODIGO, TFO_CODIGO, TFO_FECHA_OPERACION
      --FROM   TITULOS_FONDOS
      --WHERE  TFO_ETI_CODIGO = 'IAP'
      --AND    TFO_FON_CODIGO = '860079174';
    SELECT  /*+ INDEX (MRF1 MRF_PK) */
              FON_CODIGO,
              FON_RAZON_SOCIAL,
              FON_BMO_MNEMONICO,
              FON_TIPO,
              EMI_MNEMONICO,
              EMI_DESCRIPCION,
              ENA_CBU_MNEMONICO,
              ENA_TITULO_PARTICIPATIVO,
              ENA_CTI_MNEMONICO,
              ENA_EMI_MNEMONICO,
              ENA_CLASIFICACION_REPORTE,
              GNA_MNEMONICO,
              GNA_DESCRIPCION,
              TFO_CODIGO,
              TFO_FON_CODIGO,
              TFO_ENA_MNEMONICO,
              TFO_VALOR_NOMINAL,
              TFO_TRE_MNEMONICO,
              TFO_TASA_FACIAL,
              TFO_BMO_MNEMONICO,
              TFO_FECHA_EMISION,
              TFO_FECHA_VENCIMIENTO,
              TFO_FECHA_OPERACION,
              TFO_FECHA_CUMPLIMIENTO,
              TFO_FECHA_VALORIZACION,
              TFO_VALOR_OPERACION,
              TFO_LTI_MNEMONICO,
              TFO_PRC_PRF_CONSECUTIVO,
              TFO_PRC_CONSECUTIVO,
              TFO_PRV_CONSECUTIVO,
              TFO_PRV_PRF_CONSECUTIVO,
              MRF1.MRF_VALOR_TITULO_TM MRF_VALOR_TITULO_TM,
              DECODE(TFO_TIPO_PAGO_FLUJO,'P','Previo','V','Vigente') TIPO_PAGO_FLUJO,
              MRF1.MRF_TMT_MNEMONICO MRF_TMT_MNEMONICO,
              MRF1.MRF_PRECIO  MRF_PRECIO,
              MRF1.MRF_VALOR_DISTRIBUIR_DIA MRF_VALOR_DISTRIBUIR_DIA,
              P_APORTES.FN_VALIDA_SIM (FON_CODIGO, TFO_CODIGO) TIPO
         FROM TITULOS_FONDOS,
              ESPECIES_NACIONALES,
              FONDOS,
              EMISORES,
              GRUPOS_NACIONALES,
              MVTOS_RENTA_FIJA MRF1
        WHERE ((FON_TIPO = 'A')
              OR (FON_TIPO IN ('C','E')
              AND TRUNC(FON_FECHA_FINALIZACION) >= TRUNC(P_FECHA_DESDE)))
              AND FON_CODIGO IN ('860079174','8600791743')
              AND (P_APORTES.FN_VALIDA_SIM (FON_CODIGO, TFO_CODIGO) IN ('Inversion','Inversion Aplazada') 
                OR P_APORTES.FN_VALIDA_SIM (FON_CODIGO, TFO_CODIGO) IS NULL) 
              AND TFO_BMO_MNEMONICO  = 'DOLAR'
              AND NOT EXISTS (SELECT 'X'
                                FROM PARAMETROS_FONDOS
                               WHERE PFO_FON_CODIGO = FONDOS.FON_CODIGO
                                 AND PFO_PAR_CODIGO IN (70)
                                 AND NVL(PFO_RANGO_MIN_CHAR,'N') = 'S'
                             )
              AND TFO_FON_CODIGO    = FON_CODIGO
              AND TFO_TYPE          = 'TRF'
              AND TFO_ENA_MNEMONICO = ENA_MNEMONICO
              AND EMI_MNEMONICO     = ENA_EMI_MNEMONICO
              AND GNA_MNEMONICO = ENA_GNA_MNEMONICO
              AND MRF1.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
              AND MRF1.MRF_TFO_CODIGO = TFO_CODIGO
              AND MRF1.MRF_FECHA >= TRUNC(P_FECHA_DESDE)
              AND MRF1.MRF_FECHA < TRUNC(P_FECHA_DESDE+1)
              AND (('S' = 'N'
                  AND (MRF1.MRF_TMT_MNEMONICO = 'VAF'
                  OR (MRF1.MRF_TMT_MNEMONICO  = 'VGA'
                  AND 'S' = 'S')))
                  OR ('S' = 'S'
                  AND MRF1.MRF_FECHA = (SELECT /*+ INDEX (MRF2 MRF_PK) */
                                               MAX(MRF2.MRF_FECHA)
                                          FROM MVTOS_RENTA_FIJA MRF2
                                         WHERE MRF2.MRF_TFO_FON_CODIGO = MRF1.MRF_TFO_FON_CODIGO
                                           AND MRF2.MRF_TFO_CODIGO = MRF1.MRF_TFO_CODIGO
                                           AND MRF2.MRF_FECHA >= TRUNC(P_FECHA_DESDE)
                                           AND MRF2.MRF_FECHA < TRUNC(P_FECHA_DESDE + 1)
                                          )
                  AND ((EXISTS (SELECT /*+ INDEX (CFD CFD_PK) */
                                       'X'
                                  FROM CONFIRMACION_FONDOS_DIA CFD
                                 WHERE CFD_FON_CODIGO = TFO_FON_CODIGO
                                   AND CFD_FECHA >= TRUNC(P_FECHA_DESDE + 1)
                                   AND CFD_FECHA < TRUNC(P_FECHA_DESDE + 2)
                                   AND CFD_VALORIZACION_PORTAFOLIO = 'S'
                                  )
                        AND EXISTS (SELECT /*+ INDEX (MRF3 MRF_PK) */
                                           'X'
                                      FROM MVTOS_RENTA_FIJA MRF3
                                     WHERE MRF3.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                                       AND MRF3.MRF_TFO_CODIGO       = TFO_CODIGO
                                       AND MRF3.MRF_FECHA           >= TRUNC(P_FECHA_DESDE + 1)
                                       AND MRF3.MRF_FECHA            < TRUNC(P_FECHA_DESDE + 2)
                                       AND (MRF3.MRF_TMT_MNEMONICO   = 'VAF'
                                       OR (MRF3.MRF_TMT_MNEMONICO    = 'VGA'
                                       AND 'S'                       = 'S'))
                                     )
                        AND TFO_FECHA_OPERACION < TRUNC(P_FECHA_DESDE + 1) 
                        )
                        OR (NOT EXISTS (SELECT /*+ INDEX (CFD CFD_PK) */
                                               'X'
                                          FROM CONFIRMACION_FONDOS_DIA
                                         WHERE CFD_FON_CODIGO            = TFO_FON_CODIGO
                                           AND CFD_FECHA                  >= TRUNC(P_FECHA_DESDE + 1)
                                           AND CFD_FECHA                   < TRUNC(P_FECHA_DESDE + 2)
                                           AND CFD_VALORIZACION_PORTAFOLIO = 'S'
                                        )
                        AND TFO_DIA_SIGUIENTE = 'S' )
                        OR ( EXISTS (SELECT /*+ INDEX (MRF4 MRF_PK) */
                                            'X'
                                      FROM MVTOS_RENTA_FIJA MRF4
                                     WHERE MRF4.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                                       AND MRF4.MRF_TFO_CODIGO       = TFO_CODIGO
                                       AND MRF4.MRF_FECHA           >= TRUNC(P_FECHA_DESDE)
                                       AND MRF4.MRF_FECHA            < TRUNC(P_FECHA_DESDE + 1)
                                       AND MRF4.MRF_TMT_MNEMONICO                  IN ( 'VGA','REN','AMR','CRE')
                                       AND MRF4.MRF_FECHA = (SELECT MAX(MRF5.MRF_FECHA)
                                                               FROM MVTOS_RENTA_FIJA MRF5
                                                              WHERE MRF5.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                                                                AND MRF5.MRF_TFO_CODIGO       = TFO_CODIGO
                                                             )
                                      )
                                      AND TFO_ETI_CODIGO IN ('ANU','TGA')
                                      AND 'S'             = 'S' 
                            )
                         OR ( EXISTS (SELECT /*+ INDEX (MRF4 MRF_PK) */
                                             'X'
                                        FROM MVTOS_RENTA_FIJA MRF4
                                       WHERE MRF4.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                                         AND MRF4.MRF_TFO_CODIGO       = TFO_CODIGO
                                         AND MRF4.MRF_FECHA           >= TRUNC(P_FECHA_DESDE)
                                         AND MRF4.MRF_FECHA            < TRUNC(P_FECHA_DESDE + 1)
                                         AND MRF4.MRF_TMT_MNEMONICO                  IN('VAF','CRF')
                                         AND MRF4.MRF_FECHA = (SELECT MAX(MRF5.MRF_FECHA)
                                                                 FROM MVTOS_RENTA_FIJA MRF5
                                                                WHERE MRF5.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                                                                  AND MRF5.MRF_TFO_CODIGO       = TFO_CODIGO
                                                              )
                                      )
                                      AND TFO_ETI_CODIGO IN ('UNI','FRC')
                                      AND EXISTS (SELECT /*+ INDEX (MRF4 MRF_PK) */
                                                         'X'
                                                    FROM MVTOS_RENTA_FIJA MRF4 ,
                                                         FRACCIONAMIENTOS_UNIFICACIONES
                                                   WHERE MRF4.MRF_TFO_FON_CODIGO = FUN_TFO_FON_CODIGO_ES_PRODUCID
                                                     AND MRF4.MRF_TFO_CODIGO       = FUN_TFO_CODIGO_ES_PRODUCIDA
                                                     AND MRF4.MRF_FECHA           >= TRUNC(P_FECHA_DESDE + 1)
                                                     AND MRF4.MRF_FECHA            < TRUNC(P_FECHA_DESDE + 2)
                                                     AND MRF4.MRF_TMT_MNEMONICO                  IN('UNI','FRA')
                                                     AND FUN_TFO_FON_CODIGO        = TFO_FON_CODIGO
                                                     AND FUN_TFO_CODIGO            = TFO_CODIGO
                                                  ) 
                            )
                         OR (EXISTS (SELECT /*+ INDEX (MRF4 MRF_PK) */
                                            'X'
                                       FROM MVTOS_RENTA_FIJA MRF4
                                      WHERE MRF4.MRF_TFO_FON_CODIGO = TFO_FON_CODIGO
                                        AND MRF4.MRF_TFO_CODIGO       = TFO_CODIGO
                                        AND MRF4.MRF_FECHA >= TRUNC(P_FECHA_DESDE)
                                        AND MRF4.MRF_FECHA < TRUNC(P_FECHA_DESDE + 1)
                                        AND MRF4.MRF_TMT_MNEMONICO IN( 'TGA')
                                        AND 'S' = 'S'
                                     )
                             ) 
                      ) 
                  ) 
              )
      ORDER BY FON_CODIGO,
        EMI_DESCRIPCION,
        GNA_DESCRIPCION,
        TFO_CODIGO;   
   PORTAFOLIO_RF C_PORTAFOLIO_RF_PP%ROWTYPE;

  -- TFO_IAP C_TFO_IAP%ROWTYPE;

   CURSOR C_MRF_IAP (P_FECHA DATE) IS
      SELECT MRF_FECHA, MRF_TFO_CODIGO, MRF_VALOR_TITULO_TM
      FROM   MVTOS_RENTA_FIJA
      WHERE MRF_TFO_FON_CODIGO = PORTAFOLIO_RF.TFO_FON_CODIGO
      AND   MRF_TFO_CODIGO = PORTAFOLIO_RF.TFO_CODIGO
      AND   TRUNC(MRF_FECHA) >= TRUNC(P_FECHA)
      AND   TRUNC(MRF_FECHA) < TRUNC(P_FECHA + 1)
      AND   MRF_TMT_MNEMONICO = 'VAF'
      AND   (EXISTS (SELECT 'X'
                       FROM TITULOS_FONDOS
                      WHERE TFO_ETI_CODIGO = 'IAP'
                        AND TFO_FON_CODIGO = '860079174' 
                        AND TFO_CODIGO = MRF_TFO_CODIGO
              AND TFO_FON_CODIGO = MRF_TFO_FON_CODIGO)
             OR (EXISTS (SELECT 'X'
                           FROM HIS_PORTAFOLIO_FONDOS_RF
                          WHERE PFRF_TFO_ETI_CODIGO = 'IAP'
                            AND PFRF_FON_CODIGO = '860079174' 
                            AND PFRF_TFO_CODIGO = MRF_TFO_CODIGO
                            AND PFRF_FON_CODIGO = MRF_TFO_FON_CODIGO
              AND PFRF_FECHA >= TRUNC(P_FECHA)
                            AND PFRF_FECHA < TRUNC(P_FECHA + 1)
            )
        )
      );     
   MRF_IAP C_MRF_IAP%ROWTYPE;

/*VAGTUD-978 ARBITRAJE INTERNACIONAL JABT*/      
   CURSOR C_DER_OPE_CONT (P_FECHA DATE) IS
   SELECT RMO_VALOR
   FROM REGISTROS_MONEDA_230
   WHERE RMO_MFO_TIPO_INFORMACION ='ACT_INTNAL'    
    AND RMO_COMPROMISO='DERECHO'
    AND RMO_MFO_BMO_MNEMONICO = 'DOLAR'
    AND RMO_FECHA >= TRUNC(P_FECHA)
    AND RMO_FECHA < TRUNC(P_FECHA + 1);
  V_DER_OPE_CONT REGISTROS_MONEDA_230.RMO_VALOR%TYPE;

  CURSOR C_OBL_OPE_CONT (P_FECHA DATE) IS
   SELECT RMO_VALOR
   FROM REGISTROS_MONEDA_230
   WHERE RMO_MFO_TIPO_INFORMACION ='ACT_INTNAL'    
    AND RMO_COMPROMISO='OBLIGACION'
    AND RMO_MFO_BMO_MNEMONICO = 'DOLAR'
    AND RMO_FECHA >= TRUNC(P_FECHA)
    AND RMO_FECHA < TRUNC(P_FECHA + 1);
  V_OBL_OPE_CONT REGISTROS_MONEDA_230.RMO_VALOR%TYPE;

   CURSOR C_ACC_PORTAFOLIO (P_FECHA DATE)IS
   SELECT sum(MIF_VALOR_CIERRE_USD)
           FROM INVERSIONES_INTNAL_FONDOS iif
               ,MVTOS_INV_INTNAL_FONDOS mif
         ,FUNGIBLES
         ,ESPECIES_NACIONALES
          WHERE IIF_CODIGO = MIF_IIF_CODIGO
            AND IIF_FON_CODIGO = MIF_IIF_FON_CODIGO
            AND MIF_TMT_MNEMONICO = 'VYR'
            AND IIF_FON_CODIGO = '860079174'
      AND IIF_FUG_ISI_MNEMONICO = FUG_ISI_MNEMONICO
            AND IIF_FUG_MNEMONICO = FUG_MNEMONICO
        AND FUG_ENA_MNEMONICO = ENA_MNEMONICO
            AND MIF_TOTAL_VALOR_NOMINAL != 0     
      AND TRUNC(MIF_FECHA) >= TRUNC(P_FECHA)
      AND TRUNC(MIF_FECHA) < TRUNC(P_FECHA+1)	
	 ;

  V_ACC_PORTAFOLIO NUMBER(10,2);

   CURSOR C_ACC_PORTAFOLIO_LOCAL (P_FECHA DATE)IS
   SELECT TPR_PORTA_RV_DOLAR
   FROM TMP_PORTA_RV_POSPRO 
   WHERE  TPR_FECHA_CONSULTA >= TRUNC(P_FECHA)
    AND TPR_FECHA_CONSULTA <  TRUNC(P_FECHA+1);
  V_ACC_PORTAFOLIO_LOCAL TMP_PORTA_RV_POSPRO.TPR_PORTA_RV_DOLAR%TYPE;


/*FIN ARBITRAJE INTERNACIONAL JABT*/    

  -- SORTIZ - TRANSMISIONES 3
  V_IAP_01_009 NUMBER;
  V_IAP_01_012 NUMBER;
  V_DIAS   NUMBER;  
  --
  V_DIA                     VARCHAR2(1);
  crlf                      VARCHAR2(2) :=  CHR(13)||CHR(10);
  v_mensaje_error           VARCHAR2(1000);
  v_tipo_entidad            VARCHAR2(2)  := '85';
  v_codigo_entidad          VARCHAR2(6)  := '000026';
  v_palabra_clave           VARCHAR2(11) := 'CDBCORRASOC';
  v_area_informacion        VARCHAR2(2)  := '01';
  v_tipo_informe            VARCHAR2(2)  := '21';
  v_bufline                 VARCHAR2(2000) := NULL;
  v_signo                   VARCHAR2(1);
  V_TRANSMITE_DIA_NO_HABIL  VARCHAR2(1);
  v_fecha_proceso           DATE;
  v_fecha_dia_corte         DATE;
  v_fecha_inicial_reporte   DATE;
  v_fecha_final_reporte     DATE;
  v_fecha_datos             DATE;
  v_fecha_inicial_rep1      DATE;
   v_fecha_inicio_semana    DATE;
    v_fecha_valida_semana   DATE;
  P_COLUMNA                 NUMBER;
  V_CONSECUTIVO             NUMBER(5)    := 0;
  V_TOTAL_REGISTROS         NUMBER(8)    := 1386;
  V_12_01                   NUMBER;
  v_999_01                  NUMBER;
  V_998_02                  NUMBER;
  V_999_02                  NUMBER;
  V_005_03                  NUMBER;
  V_999_05                  NUMBER;
  v_998_06                  NUMBER;
  V_999_06                  NUMBER;
  V_999_17                  NUMBER;
  V_005_07                  NUMBER;
  V_005_09                  NUMBER;
  V_005_10                  NUMBER;
  V_DOLAR                   COTIZACIONES_BASE_MONETARIAS.CBM_VALOR%TYPE;
  V_005_13                  NUMBER;
  V_999_14                  NUMBER;
  V_005_15                  NUMBER;
  V_DIAS_MES                NUMBER(2);
  V_010_09                  NUMBER;
  V_010_10                  NUMBER;
  V_010_15                  NUMBER;
  V_015_16                  NUMBER;
  V_VARIACION               NUMBER;
  V_REGISTRO                NUMBER;
  S_01002                   NUMBER;
  SALDO                     NUMBER; 
  SALDO_ODO                 NUMBER;
  SALDO_ODO_1               NUMBER;
  SALDO_ODO_2               NUMBER;
  SALDO_PP                  NUMBER;
  SALDO_UC11050             NUMBER;
  SALDO_UC11055             NUMBER;  
  SALDO_UC18                NUMBER;
  SALDO_UC19                NUMBER;
  SALDO_UC20                NUMBER;
  SALDO_UC21                NUMBER;
  CALCULA                   VARCHAR2(1);
  DIA_SEMANA                NUMBER;
  ES_DIA_HABIL              VARCHAR2(1);
  CANTIDAD                  NUMBER;  
  error                     EXCEPTION;
  conn                      utl_smtp.connection;
  PORTAFOLIO                NUMBER;
  --

  CURSOR C_TRM_SIG (FECHA DATE )IS 
   SELECT CBM_VALOR 
     FROM COTIZACIONES_BASE_MONETARIAS
     WHERE CBM_BMO_MNEMONICO = 'DOLAR' 
       AND TRUNC(CBM_FECHA) >= TRUNC(P_TOOLS.SUMAR_HABILES_A_FECHA(FECHA,1))
       AND TRUNC(CBM_FECHA) < TRUNC(P_TOOLS.SUMAR_HABILES_A_FECHA(FECHA,1) + 1)
       ;
  TRM_SIG NUMBER;  

BEGIN
  /* DETERMINAR DIA DE LA SEMANAA
     EL ARCHIVO SE DEBE EJECUTAR LOS LUNES DE INICIO DE LA SEMANA
    1-DOMINGO
    2-LUNES
    3-MARTES
    4-MIÉRCOLES
    5-JUEVES
    6-VIERNES
    7-SÁBADO
   */
  IF p_fecha IS NULL THEN
    --SELECT TO_CHAR(SYSDATE, 'D') INTO v_dia  FROM DUAL;
    SELECT (TO_CHAR(TO_DATE(SYSDATE), 'D'))-1 INTO DIA_SEMANA FROM DUAL;
    CANTIDAD:=0;
    FOR I IN 0..DIA_SEMANA LOOP
       ES_DIA_HABIL:= P_TOOLS.FN_ES_DIA_HABIL(SYSDATE-I);
       IF ES_DIA_HABIL = 'S' THEN
          CANTIDAD := CANTIDAD+1;
       END IF;
    END LOOP;    
    V_DIA:=CANTIDAD;     
    v_fecha_proceso := TRUNC(SYSDATE);
  ELSE
    --SELECT TO_CHAR(p_fecha, 'D') INTO v_dia  FROM DUAL;
    SELECT (TO_CHAR(TO_DATE(p_fecha), 'D'))-1 INTO DIA_SEMANA FROM DUAL;
    CANTIDAD:=0;
    FOR I IN 0..DIA_SEMANA LOOP
       ES_DIA_HABIL:= P_TOOLS.FN_ES_DIA_HABIL(p_fecha-I);
       IF ES_DIA_HABIL = 'S' THEN
          CANTIDAD := CANTIDAD+1;
       END IF;
    END LOOP;    
    V_DIA:=CANTIDAD; 
    v_fecha_proceso := TRUNC(p_fecha);
  END IF;
  --
  IF P_LLAMADO_REPORTE = 'F'  THEN
    v_dia := '2';
  END IF;
  --
  IF NVL(v_dia,' ') = '2'  THEN -- SOLO SE DEBE EJECUTAR LUNES EN LA MADRUGRADA*/
    IF P_LLAMADO_REPORTE = 'F'  THEN
       v_fecha_dia_corte := P_FECHA;
    ELSE
        P_MAIL.ENVIO_MAIL_ERROR('Mail diario de verificacion P_MAIL_FORMATO_230:'||to_char(sysdate,'dd-mm-yyyy'),' Mail diario de verificacion formato 230');
        v_fecha_dia_corte := F_DIA_HABIL_SEMANA(v_fecha_proceso);
    END IF;
    R_REGISTRO_230.DELETE;
    V_BUFLINE := LPAD(1, 5, '0') ||'1'||V_TIPO_ENTIDAD||V_CODIGO_ENTIDAD||TO_CHAR(V_FECHA_DIA_CORTE + 9, 'DDMMYYYY')||
    --v_bufline := LPAD(1, 5, '0') ||'1'||v_tipo_entidad||v_codigo_entidad||TO_CHAR(NEXT_DAY(NEXT_DAY(v_fecha_dia_corte,1),1), 'DDMMYYYY')||
    LPAD(v_total_registros, 5, '0') ||v_palabra_clave||v_area_informacion||v_tipo_informe;
    P_ESCRIBE_FORMATO_230(P_REGISTRO_230  => R_REGISTRO_230,P_BUFLINE      =>  v_bufline);
    v_bufline :=LPAD(2, 5, '0') ||'2'||'0000'||'0'||'2'||'1'||'0'||'0000';
    P_ESCRIBE_FORMATO_230(P_REGISTRO_230  => R_REGISTRO_230,
                           P_BUFLINE      =>  v_bufline);

    IF TO_CHAR(v_fecha_dia_corte,'D') = '6' THEN
       v_fecha_inicial_reporte  := v_fecha_dia_corte+3;  -- Dia habil de  inicio de transmision
       v_fecha_inicial_rep1    := v_fecha_dia_corte+3;
    ELSE
       v_fecha_inicial_reporte := v_fecha_dia_corte + (9 - TO_NUMBER(TO_CHAR(v_fecha_dia_corte,'D')));
       v_fecha_inicial_rep1    := v_fecha_dia_corte + (9 - TO_NUMBER(TO_CHAR(v_fecha_dia_corte,'D')));
    END IF;
    v_fecha_final_reporte   := v_fecha_inicial_reporte+6;
    --
    --DBMS_OUTPUT.PUT_LINE('FECHA INICIAL :'||TO_CHAR(v_fecha_inicial_reporte));
    --DBMS_OUTPUT.PUT_LINE('FECHA FINAL :'||TO_CHAR(v_fecha_final_reporte));
    --
    -- *************************************************************************************************************************************************************
    -- *****************************  Reportar informacion semana anterior Columna 1 unidad captura 1 **************************************************************
    -- *************************************************************************************************************************************************************
    --------------------------------------------- UC01 -----------------------------------------------
    --------------------------------------------- UC01 -----------------------------------------------
    /* Fecha : 13 ene 20111
    /* Autor : rhcl
    /* ajuste: Se debe validar que la fecha de corte no es dia habil debe tomar el dia habil del dia anterior
               para reportar informacion de inicio de semana
    */
    v_fecha_inicio_semana := NULL;
    v_fecha_valida_semana := NULL;
    v_fecha_inicio_semana :=  P_SALDOS_CLIENTES.F_FECHA_HABIL(v_fecha_dia_corte,1);
    IF TRUNC(v_fecha_dia_corte) = TRUNC(v_fecha_inicio_semana) THEN
      v_fecha_inicio_semana := v_fecha_dia_corte;
    ELSE
      v_fecha_inicio_semana := v_fecha_dia_corte;
      v_fecha_valida_semana := v_fecha_dia_corte;
      WHILE TRUE LOOP
        v_fecha_inicio_semana := p_tools.RESTAR_HABILES_A_FECHA( v_fecha_inicio_semana, 1);
        v_fecha_valida_semana := P_SALDOS_CLIENTES.F_FECHA_HABIL(v_fecha_inicio_semana,1);
        IF v_fecha_inicio_semana != v_fecha_valida_semana  THEN
          v_fecha_inicio_semana := v_fecha_inicio_semana-1;
        ELSE
          EXIT;
        END IF;
      END LOOP;
    END IF;

    OPEN cierre_div(v_fecha_inicio_semana);
    FETCH cierre_div INTO r_cierre_div;
      IF cierre_div%NOTFOUND THEN
        r_cierre_div.cdi_next_int_compras        := 0;
        r_cierre_div.cdi_next_int_ventas         := 0;
        r_cierre_div.cdi_inventario_final_usd    := 0;
        r_cierre_div.cdi_activos_me_1mes         := 0;
        r_cierre_div.cdi_activos_me_1ano         := 0;
        r_cierre_div.cdi_pasivos_me_1ano         := 0;
        r_cierre_div.cdi_pasivos_me_1mes         := 0;
        r_cierre_div.cdi_valor_posicion_opcf     := 0;
        r_cierre_div.cdi_derivados_compras       := 0;
        r_cierre_div.cdi_derivados_ventas        := 0;
        r_cierre_div.cdi_opcf_compras            := 0;
        r_cierre_div.cdi_opcf_ventas             := 0;
        r_cierre_div.cdi_compras_usd             := 0;
        r_cierre_div.cdi_ventas_usd              := 0;
        r_cierre_div.tasa_prom_c                 := 0;
        r_cierre_cont_div.cnd_saldo_conciliacion := 0;
        r_cierre_div.cdi_me_act_prove_loc_liquida := 0;
        r_cierre_div.cdi_me_act_menor_2dias       := 0;
        r_cierre_div.cdi_me_pas_finan_oper_liquid := 0;
        r_cierre_div.cdi_me_pas_menor_2dias       := 0;
        r_cierre_div.cdi_derechos_adquiridos      := 0;
        r_cierre_div.cdi_derechos_cedidos         := 0;
        r_cierre_div.CDI_DER_BVC_PP_COM          := 0;
        r_cierre_div.CDI_DER_BVC_PP_VEN          := 0;
        r_cierre_div.CDI_DER_BVC_CL_COM          := 0;
        r_cierre_div.CDI_DER_BVC_CL_VEN          := 0;
        r_cierre_div.CDI_SALDO_DEPOSITOS         := 0;
        r_cierre_div.CDI_ACTIVOS_ME_PLAZO1         := 0;
        r_cierre_div.CDI_ACTIVOS_ME_PLAZO2         := 0;
        r_cierre_div.CDI_ACTIVOS_ME_PLAZO3         := 0;
        r_cierre_div.CDI_ACTIVOS_ME_PLAZO4         := 0;
        r_cierre_div.CDI_PASIVOS_ME_PLAZO1         := 0;
        r_cierre_div.CDI_PASIVOS_ME_PLAZO2         := 0;
        r_cierre_div.CDI_PASIVOS_ME_PLAZO3         := 0;
        r_cierre_div.CDI_PASIVOS_ME_PLAZO4         := 0;
      ELSE
        IF r_cierre_div.opera_contado < 0 THEN              -- para activos
          r_cierre_div.opera_contado := 0;
        END IF;
        IF r_cierre_div.cdi_valor_posicion_opcf < 0 THEN    -- para los derechos a futuro
          r_cierre_div.cdi_valor_posicion_opcf := 0;
        END IF;
        IF r_cierre_div.opera_contado_pasivo > 0 THEN       -- para pasivos
          r_cierre_div.opera_contado_pasivo := 0;
        END IF;
        IF r_cierre_div.cdi_valor_posicion_opcf_ob > 0 THEN -- para las obligaciones a futuro
          r_cierre_div.cdi_valor_posicion_opcf_ob := 0;
        END IF;
      END IF;
    CLOSE cierre_div;
    v_consecutivo := 2;
    IF  trunc(v_fecha_datos) != trunc(v_fecha_inicial_reporte) THEN
      v_transmite_dia_no_habil := 'S';
    else
      v_transmite_dia_no_habil := 'N';
    END IF;

   V_IAP_01_009 := 0;
