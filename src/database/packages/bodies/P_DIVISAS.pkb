        AND TO_NUMBER(TRIM(SUBSTR(TAE_REFERENCIA_CLIENTE,1,INSTR(TAE_REFERENCIA_CLIENTE,' ')))) = P_ORD_CONSECUTIVO
        AND TO_NUMBER(TRIM(SUBSTR(TAE_REFERENCIA_CLIENTE,INSTR(TAE_REFERENCIA_CLIENTE,' ')+1,2))) = P_ORD_SUC_CODIGO;

  CURSOR RECIBO_CAJA (P_RECIBO_CAJA NUMBER) IS 
    SELECT RCD_CCC_CLI_PER_NUM_IDEN, RCD_CCC_CLI_PER_TID_CODIGO
    FROM RECIBOS_CAJA_DIVISAS
    WHERE RCD_CONSECUTIVO = P_RECIBO_CAJA;

  CURSOR C_PERSONAS (P_NUM_IDEN VARCHAR2, P_TID VARCHAR2) IS
    SELECT PER_TIPO,PER_RAZON_SOCIAL, PER_PRIMER_APELLIDO, PER_SEGUNDO_APELLIDO, PER_NOMBRE
    FROM PERSONAS
    WHERE PER_NUM_IDEN = P_NUM_IDEN
    AND PER_TID_CODIGO = P_TID;                                           
  CURSOR CARGUE_COM_1 IS
    SELECT  TAE_CONSECUTIVO,
            TAE_ESTADO_CARGUE,
            TAE_DESCRIPCION,
            TAE_NOMBRE_BANCO,
