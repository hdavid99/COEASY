         IF V_DIAS <= 3 THEN
            V_IAP_01_009 := V_IAP_01_009 + NVL(MRF_IAP.MRF_VALOR_TITULO_TM,0);
         ELSIF V_DIAS > 3 THEN
            V_IAP_01_012 := V_IAP_01_012 + NVL(MRF_IAP.MRF_VALOR_TITULO_TM,0);
         END IF;
        CLOSE C_MRF_IAP;
    --  FETCH C_TFO_IAP INTO TFO_IAP;
      FETCH C_PORTAFOLIO_RF_PP INTO PORTAFOLIO_RF;
      END LOOP;
      CLOSE C_PORTAFOLIO_RF_PP; 

