--DBMS_OUTPUT.PUT_LINE('INGRESE PARAMETRO = F');
--DBMS_OUTPUT.PUT_LINE('REGISTROS :'||R_registro_230.COUNT());
      /* CREACION DE COLECCION PARA RETORNO DE LLAMADO DE LA FORMA*/
      IF R_registro_230.COUNT() > 0 THEN
        p_registro_230.DELETE;
        FOR i IN r_registro_230.FIRST .. r_registro_230.LAST LOOP
          v_registro := p_registro_230.COUNT();
          p_registro_230(v_registro).bufline         := r_registro_230(i).bufline;
        END LOOP;
      END IF;
    ELSE
       P_GENERA_MAIL_230 ( P_REGISTRO_230    => r_registro_230,
                           P_FECHA_DIA_CORTE => v_fecha_dia_corte,
                           P_FECHA_PROCESO   => v_fecha_proceso,
                           P_FECHA_INICIAL   => v_fecha_inicial_rep1,
                           P_FECHA_FINAL     => v_fecha_final_reporte);
    END IF;
  END IF;
EXCEPTION
    WHEN ERROR THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error ejecutando P_DIVISAS.P_MAIL_FORMATO_230 ',V_MENSAJE_ERROR);
      RAISE_APPLICATION_ERROR(-20002,'Error ejecutando P_DIVISAS.P_MAIL_FORMATO_230 '||V_MENSAJE_ERROR);
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error ejecutando P_DIVISAS.P_MAIL_FORMATO_230 ',SQLERRM);
      RAISE_APPLICATION_ERROR(-20001,'Error ejecutando P_DIVISAS.P_MAIL_FORMATO_230 '||SQLERRM);
END P_MAIL_FORMATO_230;
