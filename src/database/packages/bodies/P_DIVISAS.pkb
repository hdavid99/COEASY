    V_DIAS := P_FINANCIERO.DIAS_365(TRUNC(PORTAFOLIO_RF.TFO_FECHA_OPERACION),TRUNC(v_fecha_inicio_semana));

    OPEN C_MRF_IAP(v_fecha_inicio_semana);
