              TAE_MOTIVO_NO_ACEPTADO,
              TAE_CODIGO_IMPUESTO,
              TAE_REQUISITO_ADICIONAL,
              TAE_COD_DETALLA_PAGO,
              TAE_NUM_CUENTA_BENEFI_PAGO,
              TAE_REFERENCIA_TIDE,
              TAE_NOMBRE_COD_BAN_BENE,
              TAE_COD_NOMBRE_SOLICITANTE,
              TAE_TASA_MERCADO,
              TAE_MARGEN,
              TAE_CAMISION_CAMBIO_DIVISA,
              TAE_MONEDA_CAMBIO_DIVISA,
              TAE_REF_RELACIONADA,
              TAE_NOMBRE_BENEFI_SOLIICTA,
              TAE_ID_CUENTA_BENEFICIARIO,
              TAE_BANCO_BENEFICIARIO,
              TAE_PARTE_NOMBRE_SOLICITANTE,
              TAE_PARTE_CUENTA_SOLICITANTE,
              TAE_BANCO_NOMBRE_ORDENANTE,
              TAE_PAGO_DETALLES_ORDENANTE,
              TAE_CODIGO_UIN_UIP,
              TAE_ID_MANDATARIO,
              TAE_IDENTIFICA_PLAN,
              TAE_FECHA_SOLICITUD_PAGO
      FROM TMP_CARGUES_BENEFICARIOS
      WHERE NVL(TAE_ESTADO_CARGUE,' ') NOT IN ('OK','PRO');
--AND TAE_ESTADO_CARGUE = 'CAR';      

   CURSOR ORDEN_DIV(P_ORD_CONSECUTIVO NUMBER,P_ORD_SUC_CODIGO NUMBER) IS
      SELECT ORD_SUC_CODIGO,
             ORD_CONSECUTIVO,
             ORD_TIPO_ORDEN,
             ORD_FECHA_APROBACION,
             ORD_FECHA_COLOCACION,
             ORD_VALOR_DOLARES,
             ORD_VALOR_DOLARES_NETOS,
             ORD_CLI_PER_NUM_IDEN,
             ORD_CLI_PER_TID_CODIGO,
             ORD_CCC_NUMERO_CUENTA,
             ORD_VALOR_FX,
             ORD_VALOR_FX_C,
             ORD_BMO_MNEMONICO_FX,
             ORD_BMO_MNEMONICO_FX_C,
             ORD_TIPO_CAMBIO,
             ORD_TIPO_CAMBIO_FX_C
      FROM ORDENES_DIVISAS 
      WHERE ORD_CONSECUTIVO                = P_ORD_CONSECUTIVO
        AND ORD_SUC_CODIGO                 = P_ORD_SUC_CODIGO
        AND  ORD_EOF_CODIGO                = 'APR';

   CURSOR PAIS(P_CODIGO VARCHAR2) IS
      SELECT PAI_CODIGO
      FROM PAISES
      WHERE PAI_CODIGO = P_CODIGO;


   CURSOR TOTAL_BEN (P_ORD_CONSECUTIVO NUMBER, P_ORD_SUC_CODIGO  NUMBER) IS 
   SELECT ORD_SUC_CODIGO
         ,ORD_CONSECUTIVO
         ,BENEFICIARIOS_UNO + BENEFICIARIOS_DOS + BENEFICIARIOS_TRES +BENEFICIARIOS_CUATRO  +BENEFICIARIOS_CINCO TOTAL_BEN
         ,BENEFICIARIOS_USD_UNO+BENEFICIARIOS_USD_DOS+ BENEFICIARIOS_USD_TRES+ BENEFICIARIOS_USD_CUATRO+BENEFICIARIOS_USD_CINCO TOTAL_BEN_USD
   FROM VW_ORDENES_BENEFICIARIOS 
   WHERE ORD_CONSECUTIVO =  P_ORD_CONSECUTIVO
   AND ORD_SUC_CODIGO = P_ORD_SUC_CODIGO;


   C_CARGUE    CARGUE%ROWTYPE;      
   C_ORDEN_DIV ORDEN_DIV%ROWTYPE;
   C_PAIS      PAIS%ROWTYPE;
   C_TOTAL_BEN TOTAL_BEN%ROWTYPE;

   V_ORD_CONSECUTIVO    ORDENES_DIVISAS.ORD_CONSECUTIVO%TYPE;
   V_ORD_SUC_CODIGO     ORDENES_DIVISAS.ORD_SUC_CODIGO%TYPE;
   V_MONTO_TRANSACCION  ORDENES_DIVISAS.ORD_VALOR_DOLARES%TYPE;

   V_POSICION           NUMBER(5);



BEGIN
   /* ESTADO DEL CARGUE */
   -- NOK : REGISTRO NO VALIDA PARA REGISTRAR
   -- NOR : NO EXISTE ORDEN EN COEASY
   -- VDE : Valor dolares orden errados
   -- ESD :ERROR CALCULANDO SUMATORIA DOLARES
   -- VDE : VALOR DOLARES VS ORDEN ERRADO
   -- OK  : INFORMACION VALIDA
   -- PRO : REGISTRO PROCESADO:
   -- VOM : VALOR OTRAS MONEDAS VS ORDEN ERRADO
   -- CPV : CODIGO DE PAIS INVALIDO VENTA
   -- CPC : CODIGO DE PAIS INVALIDO COMPRA
   -- TOI :TIPO DE ORDEN INVALIDA. PROCESO SOLO PARA COMPRAS O VENTAS
   -- MMO : MONTO DE COMPLEMENTACION MAYOR A LA ORDEN



   OPEN CARGUE;
   FETCH CARGUE INTO C_CARGUE;
   WHILE CARGUE%FOUND LOOP
       BEGIN
          SELECT TO_NUMBER(TRIM(C_CARGUE.ORDEN)) INTO V_ORD_CONSECUTIVO FROM DUAL;
          EXCEPTION WHEN OTHERS THEN
             P_DIVISAS.PR_ACTUALIZAR_ESTADO(P_CONSECUTIVO   => C_CARGUE.TAE_CONSECUTIVO,
                                            P_ESTADO        => 'NOR',
                                            P_OBSERVACIONES => '1. NO EXISTE ORDEN EN COEASY');
       END;


       BEGIN
          SELECT TO_NUMBER(TRIM(C_CARGUE.SUCURSAL)) INTO V_ORD_SUC_CODIGO FROM DUAL;
             EXCEPTION WHEN OTHERS THEN
             P_DIVISAS.PR_ACTUALIZAR_ESTADO(P_CONSECUTIVO   => C_CARGUE.TAE_CONSECUTIVO,
                                            P_ESTADO        => 'NOR',
                                            P_OBSERVACIONES => '2. NO EXISTE ORDEN EN COEASY');
       END;


       C_ORDEN_DIV := NULL;
       OPEN ORDEN_DIV(P_ORD_CONSECUTIVO => V_ORD_CONSECUTIVO,
                      P_ORD_SUC_CODIGO  => V_ORD_SUC_CODIGO);
       FETCH ORDEN_DIV INTO C_ORDEN_DIV;
       CLOSE ORDEN_DIV;

       IF C_ORDEN_DIV.ORD_CONSECUTIVO IS NULL THEN
          P_DIVISAS.PR_ACTUALIZAR_ESTADO(P_CONSECUTIVO   => C_CARGUE.TAE_CONSECUTIVO,
                                            P_ESTADO        => 'NOR',
                                            P_OBSERVACIONES => '3. NO EXISTE ORDEN EN COEASY');
       ELSE
          V_MONTO_TRANSACCION := 0;
          BEGIN
             SELECT ABS(SUM(TO_NUMBER(NVL(TRIM(TAE_MONTO_TRANSACCION),'0'),'999,999,999,999,999.00'))) INTO V_MONTO_TRANSACCION
             FROM TMP_CARGUES_BENEFICARIOS
             WHERE TO_NUMBER(SUBSTR(TRIM(TAE_REFERENCIA_CLIENTE),1,INSTR(TAE_REFERENCIA_CLIENTE,' ')))  = V_ORD_CONSECUTIVO
               AND TO_NUMBER(SUBSTR(TRIM(TAE_REFERENCIA_CLIENTE),INSTR(TAE_REFERENCIA_CLIENTE,' ')+1,2)) = V_ORD_SUC_CODIGO; 

             EXCEPTION WHEN OTHERS THEN
             P_DIVISAS.PR_ACTUALIZAR_ESTADO(P_CONSECUTIVO   => C_CARGUE.TAE_CONSECUTIVO,
                                            P_ESTADO        => 'ESD',
                                            P_OBSERVACIONES => 'ERROR CALCULANDO SUMATORIA DOLARES');
          END;

          /* OBTENER TOTAL DE VALORES COMPLEMENTADOS*/
          C_TOTAL_BEN := NULL;
          OPEN TOTAL_BEN(P_ORD_CONSECUTIVO => C_ORDEN_DIV.ORD_CONSECUTIVO, 
                         P_ORD_SUC_CODIGO  => C_ORDEN_DIV.ORD_SUC_CODIGO);
          FETCH TOTAL_BEN INTO C_TOTAL_BEN;
          CLOSE TOTAL_BEN;


          DBMS_OUTPUT.PUT_LINE('MONTOS :'||V_MONTO_TRANSACCION||' - '||C_ORDEN_DIV.ORD_VALOR_DOLARES );

          /* VALIDAR PAIS REGISTRADO EN EL ARCHIVO*/
          C_PAIS := NULL;

          SELECT SUBSTR(C_CARGUE.CADENA_INICIAL_CIUDAD,INSTR(C_CARGUE.CADENA_INICIAL_CIUDAD,':')+1,LENGTH(C_CARGUE.CADENA_INICIAL_CIUDAD)) INTO C_CARGUE.CADENA_INICIAL_CIUDAD FROM DUAL;

          V_POSICION := 0;
          SELECT INSTR(C_CARGUE.CADENA_INICIAL_CIUDAD,':') INTO V_POSICION FROM DUAL;

          SELECT SUBSTR(C_CARGUE.CADENA_INICIAL_CIUDAD,1,V_POSICION-1) INTO C_CARGUE.CIUDAD_VENTA FROM DUAL;

          SELECT SUBSTR(C_CARGUE.CADENA_INICIAL_CIUDAD,V_POSICION+1,LENGTH(C_CARGUE.CADENA_INICIAL_CIUDAD)) INTO C_CARGUE.CADENA_INICIAL_CIUDAD FROM DUAL;

          V_POSICION := 0;
          SELECT INSTR(C_CARGUE.CADENA_INICIAL_CIUDAD,':') INTO V_POSICION FROM DUAL;

          SELECT SUBSTR(C_CARGUE.CADENA_INICIAL_CIUDAD,1,V_POSICION-1) INTO C_CARGUE.PAIS_VENTA FROM DUAL;

          IF C_ORDEN_DIV.ORD_TIPO_ORDEN = 'C' THEN
             OPEN PAIS(P_CODIGO =>C_CARGUE.PAIS_VENTA );
             FETCH PAIS INTO C_PAIS;
             CLOSE PAIS;

             IF C_PAIS.PAI_CODIGO IS NULL THEN
                P_DIVISAS.PR_ACTUALIZAR_ESTADO(P_CONSECUTIVO   => C_CARGUE.TAE_CONSECUTIVO,
                                                  P_ESTADO        => 'CPC',
                                                  P_OBSERVACIONES => 'CODIGO DE PAIS INVALIDO COMPRA');  
             END IF;
          ELSIF C_ORDEN_DIV.ORD_TIPO_ORDEN = 'V' THEN
             OPEN PAIS(P_CODIGO =>C_CARGUE.PAIS_VENTA );
             FETCH PAIS INTO C_PAIS;
             CLOSE PAIS;

             IF C_PAIS.PAI_CODIGO IS NULL THEN
                P_DIVISAS.PR_ACTUALIZAR_ESTADO(P_CONSECUTIVO   => C_CARGUE.TAE_CONSECUTIVO,
                                                  P_ESTADO        => 'CPV',
                                                  P_OBSERVACIONES => 'CODIGO DE PAIS INVALIDO VENTA');  
             END IF;
          ELSE
             P_DIVISAS.PR_ACTUALIZAR_ESTADO(P_CONSECUTIVO   => C_CARGUE.TAE_CONSECUTIVO,
                                            P_ESTADO        => 'TOI',
                                            P_OBSERVACIONES => 'TIPO DE ORDEN INVALIDA. PROCESO SOLO PARA COMPRAS O VENTAS');
          END IF;


          IF  C_PAIS.PAI_CODIGO IS NOT NULL THEN
             IF C_ORDEN_DIV.ORD_TIPO_ORDEN = 'C' THEN
                IF C_ORDEN_DIV.ORD_BMO_MNEMONICO_FX_C IS NOT NULL THEN                   
                   IF NVL(V_MONTO_TRANSACCION,0) > C_ORDEN_DIV.ORD_VALOR_FX_C OR
                      (C_TOTAL_BEN.TOTAL_BEN+NVL(V_MONTO_TRANSACCION,0)) > C_ORDEN_DIV.ORD_VALOR_FX_C THEN                      
                      P_DIVISAS.PR_ACTUALIZAR_ESTADO(P_CONSECUTIVO   => C_CARGUE.TAE_CONSECUTIVO,
                                                     P_ESTADO        => 'MMO',
                                                     P_OBSERVACIONES => '1. MONTO DE COMPLEMENTACION MAYOR A LA ORDEN');  
                   ELSE
                      P_DIVISAS.PR_ACTUALIZAR_ESTADO(P_CONSECUTIVO   => C_CARGUE.TAE_CONSECUTIVO,
                                                        P_ESTADO        => 'OK',
                                                       P_OBSERVACIONES => '1. INFORMACION VALIDA');             
                   END IF;
                ELSE
                   IF NVL(V_MONTO_TRANSACCION,0) > C_ORDEN_DIV.ORD_VALOR_DOLARES OR 
                      (NVL(V_MONTO_TRANSACCION,0)+C_TOTAL_BEN.TOTAL_BEN) > C_ORDEN_DIV.ORD_VALOR_DOLARES  THEN                      
                      P_DIVISAS.PR_ACTUALIZAR_ESTADO(P_CONSECUTIVO   => C_CARGUE.TAE_CONSECUTIVO,
                                                     P_ESTADO        => 'MMO',
                                                     P_OBSERVACIONES => '2. MONTO DE COMPLEMENTACION MAYOR A LA ORDEN');  
                   ELSE
                      P_DIVISAS.PR_ACTUALIZAR_ESTADO(P_CONSECUTIVO   => C_CARGUE.TAE_CONSECUTIVO,
                                                        P_ESTADO        => 'OK',
                                                       P_OBSERVACIONES => '2. INFORMACION VALIDA');             

                   END IF;   
                END IF;
             ELSIF C_ORDEN_DIV.ORD_TIPO_ORDEN = 'V' THEN
                IF C_ORDEN_DIV.ORD_BMO_MNEMONICO_FX IS NOT NULL THEN
                   IF NVL(V_MONTO_TRANSACCION,0) > C_ORDEN_DIV.ORD_VALOR_FX  OR 
                      (NVL(V_MONTO_TRANSACCION,0)+ C_TOTAL_BEN.TOTAL_BEN) >  C_ORDEN_DIV.ORD_VALOR_FX   THEN                      
                      P_DIVISAS.PR_ACTUALIZAR_ESTADO(P_CONSECUTIVO   => C_CARGUE.TAE_CONSECUTIVO,
                                                     P_ESTADO        => 'MMO',
                                                     P_OBSERVACIONES => '3. MONTO DE COMPLEMENTACION MAYOR A LA ORDEN');  
                   ELSE
                      P_DIVISAS.PR_ACTUALIZAR_ESTADO(P_CONSECUTIVO   => C_CARGUE.TAE_CONSECUTIVO,
                                                        P_ESTADO        => 'OK',
                                                        P_OBSERVACIONES => '3. INFORMACION VALIDA');             
                   END IF;   
                ELSE
                   IF NVL(V_MONTO_TRANSACCION,0) > C_ORDEN_DIV.ORD_VALOR_DOLARES OR
                       (NVL(V_MONTO_TRANSACCION,0)+ C_TOTAL_BEN.TOTAL_BEN) > C_ORDEN_DIV.ORD_VALOR_DOLARES THEN                      
                      P_DIVISAS.PR_ACTUALIZAR_ESTADO(P_CONSECUTIVO   => C_CARGUE.TAE_CONSECUTIVO,
                                                     P_ESTADO        => 'MMO',
                                                     P_OBSERVACIONES => '4. MONTO DE COMPLEMENTACION MAYOR A LA ORDEN');  
                   ELSE
                      P_DIVISAS.PR_ACTUALIZAR_ESTADO(P_CONSECUTIVO   => C_CARGUE.TAE_CONSECUTIVO,
                                                       P_ESTADO        => 'OK',
                                                       P_OBSERVACIONES => '4. INFORMACION VALIDA');             
                   END IF;
                END IF;             
             END IF;
          END IF;
       END IF;       
       FETCH CARGUE INTO C_CARGUE;     
   END LOOP;
   CLOSE CARGUE;

   COMMIT;

   EXCEPTION WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20001,'Error PR_VALIDAR_COM_UIAF '||SQLERRM );
END PR_VALIDAR_COM_UIAF;

PROCEDURE PR_ACTUALIZAR_ESTADO(P_CONSECUTIVO NUMBER,
                               P_ESTADO VARCHAR2,
                               P_OBSERVACIONES VARCHAR2)  IS
BEGIN
   BEGIN
         UPDATE TMP_CARGUES_BENEFICARIOS
            SET TAE_ESTADO_CARGUE = P_ESTADO
               ,TAE_DESCRIPCION   = P_OBSERVACIONES
             WHERE  TAE_CONSECUTIVO = P_CONSECUTIVO;
   END;
   EXCEPTION WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20001,'Error PR_ACTUALIZAR_ESTADO '||SQLERRM );
END PR_ACTUALIZAR_ESTADO;


PROCEDURE PR_CARGUE_COM_UIAF (P_TERMINAL_COMPLEMENTA  VARCHAR2,
                              P_USUARIO_COMPLEMENTA   VARCHAR2,
                              P_FECHA_COMPLEMENTA     DATE,
                        P_BEX_MNEMONICO         VARCHAR2) IS
   CURSOR REGISTROS IS
      SELECT DISTINCT SUBSTR(TAE_REFERENCIA_CLIENTE,1,INSTR(TAE_REFERENCIA_CLIENTE,' ')) ORDEN,
             SUBSTR(TAE_REFERENCIA_CLIENTE,INSTR(TAE_REFERENCIA_CLIENTE,' ')+1,2) SUCURSAL
      FROM   TMP_CARGUES_BENEFICARIOS
      WHERE NVL(TAE_ESTADO_CARGUE,' ') IN ('OK','VDE','VOM');
  --AND SUBSTR(TAE_REFERENCIA_CLIENTE,1,INSTR(TAE_REFERENCIA_CLIENTE,' ')) LIKE '%229057%';  

   CURSOR ORDEN_DIV(P_ORD_CONSECUTIVO NUMBER,P_ORD_SUC_CODIGO NUMBER) IS
      SELECT ORD_SUC_CODIGO,
             ORD_CONSECUTIVO,
             ORD_TIPO_ORDEN,
             ORD_FECHA_APROBACION,
             ORD_FECHA_COLOCACION,
             ORD_VALOR_DOLARES,
             ORD_VALOR_DOLARES_NETOS,
             ORD_CLI_PER_NUM_IDEN,
             ORD_CLI_PER_TID_CODIGO,
             ORD_CCC_NUMERO_CUENTA,
             ORD_BMO_MNEMONICO_FX,
             ORD_BMO_MNEMONICO_FX_C
      FROM ORDENES_DIVISAS 
      WHERE ORD_CONSECUTIVO                = P_ORD_CONSECUTIVO
        AND ORD_SUC_CODIGO                 = P_ORD_SUC_CODIGO
        AND  ORD_EOF_CODIGO                = 'APR';

   CURSOR CARGUE(P_ORDEN VARCHAR,P_SUCURSAL VARCHAR2) IS
      SELECT  TAE_CONSECUTIVO,
              TAE_ESTADO_CARGUE,
              TAE_DESCRIPCION
      FROM TMP_CARGUES_BENEFICARIOS
      WHERE NVL(TAE_ESTADO_CARGUE,' ') IN ('OK','VDE','VOM')
        AND SUBSTR(TAE_REFERENCIA_CLIENTE,1,INSTR(TAE_REFERENCIA_CLIENTE,' '))   = P_ORDEN
        AND SUBSTR(TAE_REFERENCIA_CLIENTE,INSTR(TAE_REFERENCIA_CLIENTE,' ')+1,2) = P_SUCURSAL;

   CURSOR DECLARACION_UNO(P_ORD_CONSECUTIVO NUMBER,P_ORD_SUC_CODIGO NUMBER) IS
      SELECT DCA_NUMERO_DECLARACION
            ,DCA_FORMULARIO
            ,DCA_TIPO_OPERACION
            ,DCA_NUMERO_NIT_IMC
            ,DCA_ORD_CONSECUTIVO
            ,DCA_ORD_SUC_CODIGO
            ,FOU_VALOR_GIRO_UNO
            ,FOU_VALOR_GIRO_DOS            
            ,FOU_CLN_TIPO_MOVIMIENTO
            ,FOU_CLN_NUM_NUMERO
            ,FOU_CLN_NUM_NUMERO_TIENE
            ,FOU_CLN_TIPO_MOVIMIENTO_TIENE
            ,FOU_TIPO_CAMBIO_USD
            ,FOU_VALOR_USD_UNO
            ,FOU_VALOR_USD_DOS
      FROM FORMULARIOS_UNO,DECLARACIONES_CAMBIO
      WHERE FOU_DCA_NUMERO_DECLARACION = DCA_NUMERO_DECLARACION
        AND DCA_ORD_CONSECUTIVO        = P_ORD_CONSECUTIVO
        AND DCA_ORD_SUC_CODIGO         = P_ORD_SUC_CODIGO
        AND DCA_ESTADO                 = 'VIG'
        AND DCA_FORMULARIO             = 1;

   CURSOR DECLARACION_DOS(P_ORD_CONSECUTIVO NUMBER,P_ORD_SUC_CODIGO NUMBER) IS
      SELECT DCA_NUMERO_DECLARACION
            ,DCA_FORMULARIO
            ,DCA_TIPO_OPERACION
            ,DCA_NUMERO_NIT_IMC
            ,DCA_ORD_CONSECUTIVO
            ,DCA_ORD_SUC_CODIGO
            ,EXD_CLN_NUM_NUMERO 
            ,EXD_CLN_TIPO_MOVIMIENTO
            ,EXD_VALOR_REINTEGRO_USD
            ,FOD_TIPO_CAMBIO_USD
            ,FOD_TOTAL_VALOR_FOB                      
      FROM EXPORTACIONES_DEFINITIVAS,FORMULARIOS_DOS,DECLARACIONES_CAMBIO
      WHERE EXD_FOD_DCA_NUMERO_DECLARACION = FOD_DCA_NUMERO_DECLARACION
        AND EXD_CLN_NUM_NUMERO             IS NOT NULL
        AND FOD_DCA_NUMERO_DECLARACION     = DCA_NUMERO_DECLARACION
        AND DCA_ORD_CONSECUTIVO            = P_ORD_CONSECUTIVO
        AND DCA_ORD_SUC_CODIGO             = P_ORD_SUC_CODIGO
        AND DCA_ESTADO                     = 'VIG'
        AND DCA_FORMULARIO                 = 2;

   CURSOR DECLARACION_TRES(P_ORD_CONSECUTIVO NUMBER,P_ORD_SUC_CODIGO NUMBER) IS
      SELECT DCA_NUMERO_DECLARACION
            ,DCA_FORMULARIO
            ,DCA_TIPO_OPERACION
            ,DCA_NUMERO_NIT_IMC
            ,DCA_ORD_CONSECUTIVO
            ,DCA_ORD_SUC_CODIGO            
            ,NUL_CLN_NUM_NUMERO 
            ,NUL_CLN_TIPO_MOVIMIENTO
            ,NUL_VALOR_USD
            ,NUL_VALOR_MONEDA
            ,FOT_TIPO_CAMBIO_A_USD
      FROM NUMERACIONES_LIQUIDACIONES,FORMULARIOS_TRES,DECLARACIONES_CAMBIO
      WHERE NUL_FOT_DCA_NUMERO_DECLARACION = FOT_DCA_NUMERO_DECLARACION
        AND NUL_CLN_NUM_NUMERO             IS NOT NULL
        AND FOT_DCA_NUMERO_DECLARACION     = DCA_NUMERO_DECLARACION
        AND DCA_ORD_CONSECUTIVO            = P_ORD_CONSECUTIVO
        AND DCA_ORD_SUC_CODIGO             = P_ORD_SUC_CODIGO
        AND DCA_ESTADO                     = 'VIG'
        AND DCA_FORMULARIO                 = 3;


   CURSOR DECLARACION_CUATRO(P_ORD_CONSECUTIVO NUMBER,P_ORD_SUC_CODIGO NUMBER) IS
      SELECT DCA_NUMERO_DECLARACION
            ,DCA_FORMULARIO
            ,DCA_TIPO_OPERACION
            ,DCA_NUMERO_NIT_IMC
            ,DCA_ORD_CONSECUTIVO
            ,DCA_ORD_SUC_CODIGO
            ,FOC_CLN_TIPO_MOVIMIENTO
            ,FOC_CLN_NUM_NUMERO
            ,FOC_VALOR_GIRO_REINTEGRO
            ,FOC_VALOR_USD
            ,FOC_TIPO_CAMBIO_USD
      FROM FORMULARIOS_CUATRO,DECLARACIONES_CAMBIO
      WHERE FOC_DCA_NUMERO_DECLARACION = DCA_NUMERO_DECLARACION
        AND DCA_ORD_CONSECUTIVO        = P_ORD_CONSECUTIVO
        AND DCA_ORD_SUC_CODIGO         = P_ORD_SUC_CODIGO
        AND DCA_ESTADO                 = 'VIG'
        AND DCA_FORMULARIO             = 4;        

   CURSOR DECLARACION_CINCO(P_ORD_CONSECUTIVO NUMBER,P_ORD_SUC_CODIGO NUMBER) IS
      SELECT DCA_NUMERO_DECLARACION
            ,DCA_FORMULARIO
            ,DCA_TIPO_OPERACION
            ,DCA_NUMERO_NIT_IMC
            ,DCA_ORD_CONSECUTIVO
            ,DCA_ORD_SUC_CODIGO            
            ,DEO_CLN_NUM_NUMERO 
            ,DEO_CLN_TIPO_MOVIMIENTO
            ,DEO_VALOR_USD
            ,FOI_TIPO_CAMBIO_USD
      FROM DETALLE_OPERACIONES,FORMULARIOS_CINCO,DECLARACIONES_CAMBIO
      WHERE DEO_FOI_DCA_NUMERO_DECLARACION = FOI_DCA_NUMERO_DECLARACION
        AND DEO_CLN_NUM_NUMERO             IS NOT NULL
        AND DEO_VALOR_USD                  IS NOT NULL
        AND FOI_DCA_NUMERO_DECLARACION     = DCA_NUMERO_DECLARACION
        AND DCA_ORD_CONSECUTIVO            = P_ORD_CONSECUTIVO
        AND DCA_ORD_SUC_CODIGO             = P_ORD_SUC_CODIGO
        AND DCA_ESTADO                     = 'VIG'
        AND DCA_FORMULARIO                 = 5;

   CURSOR CARGUE_COM(P_TAE_CONSECUTIVO  NUMBER) IS
      SELECT  TAE_CONSECUTIVO,
              TAE_ESTADO_CARGUE,
              TAE_DESCRIPCION,
              TAE_NOMBRE_BANCO,
              TAE_NUMERO_BASE_CLIENTE,
              TAE_NOMBRE_CLIENTE,
              TAE_NUMERO_SUCURSAL,
              TAE_NOMBRE_SUCURSAL,
              TAE_NUMERO_CUENTA,
              TAE_NOMBRE_DE_LA_CUENTA,
              TAE_NUMERO_IBAN,
              TAE_MONEDA_CUENTA_DEUDORA,
              TAE_TIPO_CUENTA,
              TAE_FECHA_ULTIMO_REGISTRO,
              TAE_SALDO_CUENTA_DISPONIBLE,
              TAE_SALDO_CUENTA_ACTUAL,
              TAE_SALDO_INICIAL_DISPONIBLE,
              TAE_SALDO_DISPONIBLE_ACTUAL,
              TAE_REFERENCIA_BANCO,
              TRIM(TAE_REFERENCIA_CLIENTE) TAE_REFERENCIA_CLIENTE,
              SUBSTR(TAE_REFERENCIA_CLIENTE,1,INSTR(TAE_REFERENCIA_CLIENTE,' ')) ORDEN,
              SUBSTR(TAE_REFERENCIA_CLIENTE,INSTR(TAE_REFERENCIA_CLIENTE,' ')+1,2) SUCURSAL,
              TAE_FECHA_INGRESO,
              TAE_HORA_INSCRIPCION,
              TAE_MONTO_TRANSACCION,
              ABS(TO_NUMBER(NVL(TRIM(TAE_MONTO_TRANSACCION),'0'),'999,999,999,999,999.00')) MONTO_TRANSACCION,
              TAE_TIPO_PRODUCTO,
              TAE_DESCRIPCION_TRANSACCION,
              TAE_INFORMACION_ADICIONAL,
              TAE_DETALLE_PAGO,
              TAE_NUMERO_LOTE_RASTREO,
              TAE_REFERENCIA_BENEFICIARIO,
              TAE_REFERENCIA_REMITENTE,
              TAE_CUENTAS_BANCO_CORRESPONSAL,
              TAE_DIRECCION_BANCO_CORRES,
              TAE_DOMICILIO_UNO_INTER,
              TAE_DOMICILIO_DOS_INTER,
              TAE_DOMICILIO_TRES_INTER,
              TAE_DOMICILIO_CUATRO_INTER,
              TAE_TIPO_CAMBIO,
              TAE_CUENTA_BANCO_INTERMEDIARIO,
              TAE_NOMBRE_DIRECCION_INTER,
              TAE_DOMICILIO_UNO_CORRESPONSAL,
              TAE_DOMICILIO_DOS_CORRESPONSAL,
              TAE_DOMICILIO_TRES_CORRES,
              TAE_DOMICILIO_CUATRO_CORRESPON,
              TAE_CUENTA_CORRESPONSAL,
              TAE_NOMBRE_DIRECCION_CORRES,
              TAE_DOMICILIO_UNO_SOLICITANTE,
              TAE_DOMICILIO_DOS_SOLICITANTE,
              TAE_DOMICILIO_TRES_SOLICITANTE,
              TAE_DOMICILIO_CUATRO_SOLICI,
              TAE_CUENTA_BANCO_SOLICITANTE,
              TAE_DIRECCION_SOLICITANTE,
              TAE_DOMICILIO_UNO_ORDENANTE,
              TAE_DOMICILIO_DOS_ORDENANTE,
              TAE_DOMICILIO_TRES_ORDENANTE,
              TAE_DOMICILIO_TRES_ORDENANTE CIUDAD_COMPRA,
              TAE_DOMICILIO_TRES_ORDENANTE PAIS_COMPRA,
              TAE_DOMICILIO_CUATRO_ORDENA,
              TAE_CUENTA_ORDENANTE,
              TAE_NOMBRE_ORDENANTE,
              TAE_DOMICILIO_UNO_OTRO,
              TAE_DOMICILIO_DOS_OTRO,
              TAE_DOMICILIO_TRES_OTRO,
              TAE_DOMICILIO_CUATRO_OTRO,
              TAE_MONTO_ORIGINAL,
              TAE_MONEDA_ORIGINAL,
              TAE_MONTO_PAGO,
              TAE_MONEDA_PAGO,
              TAE_CUENTA_BANCO_ORIGINADOR,
              TAE_NOMBRE_DIREC_ORIGINADOR,
              TAE_DOMICILIO_UNO_COMPENSA,
              TAE_DOMICILIO_DOS_COMPENSA,
              TAE_DOMICILIO_TRES_COMPENSA,
              TAE_DOMICILIO_CUATRO_COMPENSA,
              TAE_IDENTIFICA_BANCO_COMPESA,
              TAE_TIPO_ID_NETTING,
              TAE_FECHA_CONTRATO,
              TAE_FECHA_VENCIMIENTO,
              TAE_MONTO_COMPRADO,
              TAE_MONEDA_COMPRADO,
              TAE_MONTO_VENDIO_BANCO,
              TAE_MENEDA_VENTA,
              TAE_TIPO_CAMBIO_VENTA,
              TAE_INSTRUCCION_REM_COMPRADOR,
              TAE_INSTRUCCION_REM_VENTA,
              TAE_RENOVACION,
              TAE_FECHA_INICIAL_CONTRATO,
              TAE_FECHA_FINAL_CONTRATO,
              TAE_DIAS_PREVIOS_NOTIFICA,
              TAE_TASA_INTERES,
              TAE_ESTADO_PAGO,
              TAE_ESTADO_REEMBOLSO,
              TAE_CONDICIONES_PAGO_INTERES,
              TAE_INDICADOR_REVOCACION,
              TAE_REFERENCIA_SOLICITANTES,
              TAE_TIPO_COSTO,
              TAE_MONTO_COMISION,
              TAE_MONEDAD_COMISION,
              TAE_REFERENCIA_SOLICITANTE,
              TAE_REFERENCIA_FACTURA_REMITE,
              TAE_REFERENCIA_RELACIONADA,
              TAE_FLOTACION_DIA_UNO,
              TAE_FLOTACION_DIA_DOS,
              TAE_FLOTACION_DIA_TRES,
              TAE_FLOTACION_DIA_CUATRO,
              TAE_FECHA_REAL_LIQUIDA,
              TAE_CODIGO_CORREDOR,
              TAE_INDICADOR_COMISIONES,
              TAE_FECHA_VALOR,
              TAE_NOMBRE_COMPANIA,
              TAE_FECHA_LIQUIDACION,
              TAE_CONTRAPARTE,
              TAE_AMORTIZADO_ACUMULATIVA,
              TAE_CANTIDAD_ACUMULATIVA,
              TAE_FACTOR_CORRIENTE,
              TAE_DESCRIPCION_CORRIENTE,
              TAE_TASA_DIVIDENDO,
              TAE_FECHA_AUTORIZACION,
              TAE_TASA_INTERES_IMPUESTOS,
              TAE_MONTO_IMPUESTOS,
              TAE_MONTO_IMPUESTOS_LOCALES,
              TAE_MONTO_NOMINAL,
              TAE_MONEDA_NOMINAL,
              TAE_NOMINADO,
              TAE_NETO_DIA_SIGUIENTE,
              TAE_NEMO_SEGUIRIDAD,
              TAE_NUMERO_SEGURIDAD,
              TAE_INDICADOR_IMPUESTO,
              TAE_INGRESO_PRINCIPAL,
              TAE_TIPO_VALOR,
              TAE_NUMERO_CONFIRMA_BURSATIL,
              TAE_CODIGO_IMPUESTO_USA,
              TAE_UNIDADES,
              TAE_FECHA_OPERACION,
              TAE_MONTO_IMPUESTO_RETENIDO,
              TAE_TASA_RETENCION_IMPOSITIVA,
              TAE_TIPO_TRANSACCION,
              TAE_PREFIJO_FONDO_COMUN,
              TAE_CUENTA_CUSTODIA,
              TAE_MONTO_CHEQUEQ,
              TAE_NUMERO_SERIE_CHEQUE,
              TAE_DUPLICADO,
              TAE_IDENTIFICACION_INS_REEM,
              TAE_NOMBRE_REEMBOLSO,
              TAE_DOMICILIO_UNO_REEMBOLSO,
              TAE_DOMICILIO_DOS_REEMBOLSO,
              TAE_DOMICILIO_TRES_REEMBOLSO,
