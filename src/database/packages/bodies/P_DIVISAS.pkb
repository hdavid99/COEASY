  ------------------------------iniciar reporte de dias de lunes a domingo --------------------------------------------
    while  trunc(v_fecha_inicial_reporte) <= trunc(v_fecha_final_reporte)   loop
      /* determinar dia habil de reporte */
      v_fecha_datos := f_dia_datos (p_fecha => v_fecha_inicial_reporte);
      v_dia         := dia_de_la_semana(v_fecha_inicial_reporte);
--DBMS_OUTPUT.PUT_LINE('v_fecha_inicial_reporte :'||v_fecha_inicial_reporte||' v_fecha_final_reporte :'||v_fecha_final_reporte);
--DBMS_OUTPUT.PUT_LINE('V_FECHA_DATOS :'||V_FECHA_DATOS||' V_DIA :'||V_DIA);
  /*1-domingo    = 8
    2-lunes      = 2
    3-martes     = 3
    4-miércoles  = 4
    5-jueves     = 5
    6-viernes    = 6
    7-sábado*    = 7*/
      IF v_dia = '1' THEN                                -- determinar la columna de impresion de acuerdo al dia
        p_columna := '8';                                -- domingo se imprime en columna 8
      else
        p_columna := v_dia;                              -- para los demas dias corresponde la columna
      END IF;
  /*msg_alert('fecha incial reporte:'||to_char(  v_fecha_inicial_reporte,'dd-mon-yyyy')||
            ' fecha que reporto :'||to_char(  v_fecha_datos,'dd-mon-yyyy')||
            ' dia semana que reporto:'||v_dia||
            ' p_columna:'||p_columna
            ,'e',false);
  IF p_columna = '7' THEN
    msg_alert('reportando columna 7','e',false);
  END IF;          */

      --------------------------------------------- uc01 -----------------------------------------------
      OPEN cierre_div(v_fecha_datos);
      FETCH cierre_div INTO r_cierre_div;
      IF cierre_div%notfound THEN
        r_cierre_div.cdi_next_int_compras        := 0;
        r_cierre_div.cdi_next_int_ventas         := 0;
        r_cierre_div.cdi_inventario_final_usd    := 0;
        r_cierre_div.cdi_activos_me_1mes         := 0;
        r_cierre_div.cdi_activos_me_1ano         := 0;
        r_cierre_div.cdi_pasivos_me_1ano         := 0;
        r_cierre_div.cdi_pasivos_me_1mes         := 0;
        r_cierre_div.cdi_valor_posicion_opcf     := 0;
        r_cierre_div.cdi_derivados_compras       := 0;
        r_cierre_div.cdi_derivados_ventas        := 0;
        r_cierre_div.cdi_opcf_compras            := 0;
        r_cierre_div.cdi_opcf_ventas             := 0;
        r_cierre_div.cdi_compras_usd             := 0;
        r_cierre_div.cdi_ventas_usd              := 0;
        r_cierre_div.tasa_prom_c                 := 0;
        r_cierre_cont_div.cnd_saldo_conciliacion := 0;
        r_cierre_div.CDI_DER_BVC_PP_COM          := 0;
        r_cierre_div.CDI_DER_BVC_PP_VEN          := 0;
        r_cierre_div.CDI_DER_BVC_CL_COM          := 0;
        r_cierre_div.CDI_DER_BVC_CL_VEN          := 0;
        r_cierre_div.CDI_SALDO_DEPOSITOS         := 0;
      else
        IF r_cierre_div.opera_contado < 0 THEN              -- para activos
            r_cierre_div.opera_contado := 0;
        END IF;
        IF r_cierre_div.cdi_valor_posicion_opcf < 0 THEN    -- para los derechos a futuro
            r_cierre_div.cdi_valor_posicion_opcf := 0;
        END IF;
        IF r_cierre_div.opera_contado_pasivo > 0 THEN       -- para pasivos
            r_cierre_div.opera_contado_pasivo := 0;
        END IF;
        IF r_cierre_div.cdi_valor_posicion_opcf_ob > 0 THEN -- para las obligaciones a futuro
            r_cierre_div.cdi_valor_posicion_opcf_ob := 0;
        END IF;
      END IF;
      close cierre_div;
      IF  trunc(v_fecha_datos) != trunc(v_fecha_inicial_reporte) THEN
        v_transmite_dia_no_habil := 'S';
      else
        v_transmite_dia_no_habil := 'N';
      END IF;
      /* reportar informacion semana anterior columna 1 unidad captura 1*/

      -- sortiz transmisiones 3
      V_IAP_01_009 := 0;
      V_IAP_01_012 := 0;
      V_DIAS := 0;
    OPEN C_TFO_IAP(v_fecha_DATOS);
      FETCH C_TFO_IAP INTO  TFO_IAP;
      WHILE C_TFO_IAP%FOUND LOOP
     V_DIAS := P_FINANCIERO.DIAS_365(TRUNC(TFO_IAP.TFO_FECHA_OPERACION),TRUNC(v_fecha_datos));

         OPEN C_MRF_IAP(v_fecha_datos);
         FETCH C_MRF_IAP INTO MRF_IAP;
       IF V_DIAS <= 3 THEN
        V_IAP_01_009 := V_IAP_01_009 + NVL(MRF_IAP.MRF_VALOR_TITULO_TM,0);
       ELSIF V_DIAS > 3 THEN
        V_IAP_01_012 := V_IAP_01_012 + NVL(MRF_IAP.MRF_VALOR_TITULO_TM,0);
       END IF;
         CLOSE C_MRF_IAP;
         FETCH C_TFO_IAP INTO  TFO_IAP;
      END LOOP;
      CLOSE C_TFO_IAP;

    /*VAGTUD-978 ARBITRAJE INTERNACIONAL JABT*/

     V_DER_OPE_CONT:=0;
       OPEN C_DER_OPE_CONT(TRUNC(V_FECHA_DATOS));--CONSULTA DERECHOS ACTIVOS INTERNACIONAL
       FETCH C_DER_OPE_CONT INTO V_DER_OPE_CONT;
       CLOSE C_DER_OPE_CONT;

    V_OBL_OPE_CONT:=0;
     OPEN C_OBL_OPE_CONT(TRUNC(V_FECHA_DATOS));--CONSULTA OBLIGACIONES ACTIVOS INTERNACIONAL
       FETCH C_OBL_OPE_CONT INTO V_OBL_OPE_CONT;
       CLOSE C_OBL_OPE_CONT;

     V_ACC_PORTAFOLIO:=0;
     V_ACC_PORTAFOLIO_LOCAL:=0;
     OPEN C_ACC_PORTAFOLIO(TRUNC(V_FECHA_DATOS));--CONSULTA ACCIONES PORTAFOLIO REININ
       FETCH C_ACC_PORTAFOLIO INTO V_ACC_PORTAFOLIO;
       CLOSE C_ACC_PORTAFOLIO; 

       OPEN C_ACC_PORTAFOLIO_LOCAL(TRUNC(V_FECHA_DATOS));--CONSULTA ACCIONES PORTAFOLIO REININ
       FETCH C_ACC_PORTAFOLIO_LOCAL INTO V_ACC_PORTAFOLIO_LOCAL;
       CLOSE C_ACC_PORTAFOLIO_LOCAL;

     /*VAGTUD-978 ARBITRAJE INTERNACIONAL JABT*/

      --------------------------------------------- uc01 -----------------------------------------------
      S_01002:=0;      
      OPEN CBE;
      FETCH CBE INTO C_CBE;
      WHILE CBE%FOUND LOOP
         SALDO:= 0;
         OPEN SALDO_CBE(v_fecha_datos);
         FETCH SALDO_CBE INTO SALDO;
         CLOSE SALDO_CBE;

         IF SALDO > 0 THEN
            S_01002:= S_01002 + NVL(SALDO,0);
         END IF;

      FETCH CBE INTO C_CBE;
      END LOOP;
      CLOSE CBE;        

      SALDO_ODO:=0;
      OPEN ODO(v_fecha_datos,'CAJA MENOR');
      FETCH ODO INTO SALDO_ODO;
      CLOSE ODO;

      S_01002:= S_01002 + NVL(SALDO_ODO,0);    

      IF nvl(S_01002,0) > 0 THEN
        P_ESCRIBE_PLANTILLA_230(P_REGISTRO        => R_REGISTRO,
                              P_UNIDAD_CAPTURA  => '01',
                              P_SUBCUENTA       => '002',
                              P_DIA             =>  p_columna,
                              P_VALOR           =>  nvl(S_01002,0));
      END IF;
