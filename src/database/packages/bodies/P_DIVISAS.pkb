PROCEDURE P_ESCRIBE_PLANTILLA_230(P_REGISTRO        IN OUT T_REGISTRO,
                                  P_UNIDAD_CAPTURA  VARCHAR2,
                                  P_SUBCUENTA       VARCHAR2,
                                  P_DIA             VARCHAR2,
                                  P_VALOR           NUMBER) IS
  v_numero_registro NUMBER;
BEGIN
  /************************/
  /* P_DIA 0 = semana anteriors
           2 = Lunes
           3 = martes
           4 = miercoles
           5 = jueves
           6 = viernes
           7 = sabado
           8 = domingo*/
  v_numero_registro := P_REGISTRO.COUNT();
  IF v_numero_registro > 0 THEN
    FOR i IN P_REGISTRO.FIRST .. P_REGISTRO.LAST loop
      IF P_REGISTRO(i).subcuenta                = P_SUBCUENTA AND
         P_REGISTRO(i).unidad_captura  = P_UNIDAD_CAPTURA THEN
         IF P_DIA = 0 THEN
           P_REGISTRO(i).semana_ant         := P_VALOR;
         ELSIF P_DIA = 2 THEN
           P_REGISTRO(i).lunes              := P_VALOR;
         ELSIF P_DIA = 3 THEN
           P_REGISTRO(i).martes             := P_VALOR;
         ELSIF P_DIA = 4 THEN
           P_REGISTRO(i).miercoles          := P_VALOR;
         ELSIF  P_DIA = 5 THEN
           P_REGISTRO(i).jueves             := P_VALOR;
         ELSIF  P_DIA = 6 THEN
           P_REGISTRO(i).viernes            := P_VALOR;
         ELSIF P_DIA = 7 THEN
           P_REGISTRO(i).sabado             := P_VALOR;
         ELSIF  P_DIA = 8 THEN
           P_REGISTRO(i).domingo            := P_VALOR;
         END IF;
      END IF;
    END LOOP;
  END IF;
END P_ESCRIBE_PLANTILLA_230;
PROCEDURE P_GENERA_MAIL_EXCEL_230( P_REGISTRO IN OUT T_REGISTRO,
                                   P_FECHA_DIA_CORTE DATE,
                                   P_FECHA_PROCESO   DATE,
                                   P_FECHA_INICIAL   DATE,
                                   P_FECHA_FINAL     DATE) IS
  /* OBTENER DIRECCIONES DE CORREO*/
  CURSOR CONSTANTE (P_MNEMONICO  VARCHAR2) IS
    SELECT CON_VALOR_CHAR
    FROM CONSTANTES
    WHERE CON_MNEMONICO = P_MNEMONICO;
  v_bufline          VARCHAR2(4000);
  v_mensaje_error    VARCHAR2(4000);
  crlf               VARCHAR2(2) :=  CHR(13)||CHR(10);
  v_archivo_detalle  VARCHAR2(500);
  C_CONSTANTE        CONSTANTE%ROWTYPE;
  ERROR              EXCEPTION;
  conn               utl_smtp.connection;
BEGIN
    OPEN constante(P_MNEMONICO => 'MED');
    FETCH constante INTO c_constante;
    IF constante%NOTFOUND THEN
      CLOSE constante;
      v_mensaje_error := 'No existe constante (MED) de correos para divisas';
      RAISE ERROR;
    END IF;
    CLOSE CONSTANTE;
  --c_constante.con_valor_char := 'aangel@corredores.com';
    v_archivo_detalle := 'FORMATO_EXCEL_230_'||TO_CHAR(P_FECHA_DIA_CORTE + 9, 'DDMONYYYY');
    conn := p_mail.begin_mail(sender     => 'administrador@corredores.com',
                              recipients   => TRIM(c_constante.con_valor_char),
                              subject      => 'Formato Excel 230 Fecha reporte:'||TO_CHAR(p_fecha_dia_corte + 9, 'DDMONYYYY'),
                              mime_type    => p_mail.MULTIPART_MIME_TYPE);
    p_mail.attach_text(conn      => conn,
                       data      => '<html>'||
                                     '<head>'||
                                       '<IMG src=http://www.corredores.com/portal/eContent/images/Banners/BannerNo1.jpg>'||
                                     '</head>'||
                                     '<body FACE=arial> '||
                                       '<br><br><br><br><br><br>'||
                                       '<table>'||
                                         '<font size=2 face=Arial Black>'||
                                         '<tr>'||
                                          'Informacion formato Excel 230 con fecha de corte al :'||to_char(P_FECHA_PROCESO,'DD-MM-YYYY')||'</tr>'||
                                         '<tr></tr>'||
                                         '<br><br><br><br><br><br>'||
                                         '<tr>'||' Atentamente,'||'</tr>'||
                                         '<br><br><br><br>'||
                                         '<tr><B>'||'CORREDORES DAVIVIENDA S.A.'||'</B></tr>'||
                                          '</font>'||
                                         '<br><br><br><br><br><br>'||
                                       '</table>'||
                                       '<br><br><br>'||
                                    '</body>'||
                                  '</html>',
                       mime_type => 'text/html');
    p_mail.begin_attachment(conn         => conn,
                            mime_type    => v_archivo_detalle||'/txt',
                            inline       => TRUE,
                            filename     => v_archivo_detalle||'.txt',
                            transfer_enc => 'text');
    /* Creacion de encabezados*/
    v_bufline := 'CONTROL DIARIO DE POSICION PROPIA DE CONTADO POSICION CAMBIARIA GLOBAL Y POSICION BRUTA DE APALANCAMIENTO';
    p_mail.write_mb_text(conn,v_bufline||CRLF);
    v_bufline := 'FORMATO 230';
    p_mail.write_mb_text(conn,v_bufline||CRLF);
    v_bufline := 'CIRCULAR EXTERNA 033 DE 2007 ';
    p_mail.write_mb_text(conn,v_bufline||CRLF);
    v_bufline := 'ENTIDAD'||','||
                 'CORREDORES DAVIVIENDA S.A.'||','||
                 'CIUDAD'||','||
                 'BOGOTA'||','||
                 'SEMANA DEL'||','||
                 TO_CHAR(p_fecha_inicial,'DDMMYYYY')||','||
                 'AL'||','||
                 TO_CHAR(p_fecha_final,'DDMMYYYY');
    p_mail.write_mb_text(conn,v_bufline||CRLF);
    v_bufline := 'SUBCUENTA'||','||
                 'NOMBRE'||','||
                 'POSICION SEMANA ANTERIOR'||','||
                 'LUNES'||','||
                 'MARTES'||','||
                 'MIERCOLES'||','||
                 'JUEVES'||','||
                 'VIERNES'||','||
                 'SABADO'||','||
                 'DOMINGO'||','||
                 'AUTOLIQUIDACION'||','||
                 'UNIDAD DE CAPTURA';
    p_mail.write_mb_text(conn,v_bufline||CRLF);
    IF p_registro.COUNT() > 0 THEN
      FOR i IN p_registro.FIRST .. p_registro.LAST LOOP
        v_bufline :=  P_REGISTRO(i).subcuenta||','||
                      P_REGISTRO(i).nombre||','||
                      P_REGISTRO(i).semana_ant||','||
                      P_REGISTRO(i).lunes ||','||
                      P_REGISTRO(i).martes ||','||
                      P_REGISTRO(i).miercoles ||','||
                      P_REGISTRO(i).jueves ||','||
                      P_REGISTRO(i).viernes ||','||
                      P_REGISTRO(i).sabado ||','||
                      P_REGISTRO(i).domingo ||','||
                      P_REGISTRO(i).autoliquida||','||
                      P_REGISTRO(i).unidad_captura;
        p_mail.write_mb_text(conn,v_bufline||CRLF);
      END LOOP;
    END IF;
    p_mail.end_attachment( conn => conn );
    p_mail.end_mail( conn => conn );
  EXCEPTION
    WHEN ERROR THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error ejecutando P_DIVISAS.P_GENERA_MAIL_EXCEL_230 ',V_MENSAJE_ERROR);
      RAISE_APPLICATION_ERROR(-20002,'Error ejecutando P_DIVISAS.P_GENERA_MAIL_EXCEL_230 '||V_MENSAJE_ERROR);
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error ejecutando P_DIVISAS.P_GENERA_MAIL_EXCEL_230 ',SQLERRM);
      RAISE_APPLICATION_ERROR(-20001,'Error ejecutando P_DIVISAS.P_GENERA_MAIL_EXCEL_230 '||SQLERRM);
END P_GENERA_MAIL_EXCEL_230;
--
PROCEDURE P_ESCRIBE_FORMATO_230(P_REGISTRO_230  IN OUT T_REGISTRO_230,
                                P_BUFLINE       VARCHAR2)IS
  v_registro NUMBER;
BEGIN
  v_registro := P_REGISTRO_230.COUNT();
  P_REGISTRO_230 (v_registro).bufline := P_BUFLINE;
END P_ESCRIBE_FORMATO_230;
--
PROCEDURE P_GENERA_MAIL_230( P_REGISTRO_230    IN OUT T_REGISTRO_230,
                             P_FECHA_DIA_CORTE DATE,
                             P_FECHA_PROCESO   DATE,
                             P_FECHA_INICIAL   DATE,
                             P_FECHA_FINAL     DATE) IS
  /* OBTENER DIRECCIONES DE CORREO*/
  CURSOR CONSTANTE (P_MNEMONICO  VARCHAR2) IS
    SELECT CON_VALOR_CHAR
    FROM CONSTANTES
    WHERE CON_MNEMONICO = P_MNEMONICO;
  v_bufline          VARCHAR2(4000);
  v_mensaje_error    VARCHAR2(4000);
  crlf               VARCHAR2(2) :=  CHR(13)||CHR(10);
  v_archivo_detalle  VARCHAR2(500);
  C_CONSTANTE        CONSTANTE%ROWTYPE;
  ERROR              EXCEPTION;
  conn               utl_smtp.connection;
BEGIN
    /* OBTENER DIRECCIONES DE CORREO*/
    OPEN constante(P_MNEMONICO => 'MDI');
    FETCH constante INTO c_constante;
    IF constante%NOTFOUND THEN
      CLOSE constante;
      v_mensaje_error := 'No existe constante (MDI) de correos para divisas';
      RAISE ERROR;
    END IF;
    CLOSE CONSTANTE;
    --raise_application_error(-20001,'va ha generar el mail');
  --c_constante.con_valor_char := 'aangel@corredores.com';
    /*********** INICIO FORMATO 230 ****/
    v_archivo_detalle := 'FORM230_'||TO_CHAR(P_FECHA_DIA_CORTE + 9, 'DDMONYYYY');
    conn := p_mail.begin_mail(sender     => 'administrador@corredores.com',
                              recipients   => TRIM(c_constante.con_valor_char),
                              subject      => 'Formato 230 Fecha reporte:'||TO_CHAR(P_FECHA_DIA_CORTE + 9, 'DDMONYYYY'),
                              mime_type    => p_mail.MULTIPART_MIME_TYPE);
    p_mail.attach_text(conn      => conn,
                       data      => '<html>'||
                                     '<head>'||
                                       '<IMG src=http://www.corredores.com/portal/eContent/images/Banners/BannerNo1.jpg>'||
                                     '</head>'||
                                     '<body FACE=arial> '||
                                       '<br><br><br><br><br><br>'||
                                       '<table>'||
                                         '<font size=2 face=Arial Black>'||
                                         '<tr>'||
                                          'Informacion formato 230 con fecha de corte al :'||to_char(P_FECHA_PROCESO,'DD-MM-YYYY')||'</tr>'||
                                         '<tr></tr>'||
                                         '<br><br><br><br><br><br>'||
                                         '<tr>'||' Atentamente,'||'</tr>'||
                                         '<br><br><br><br>'||
                                         '<tr><B>'||'CORREDORES DAVIVIENDA S.A.'||'</B></tr>'||
                                          '</font>'||
                                         '<br><br><br><br><br><br>'||
                                       '</table>'||
                                       '<br><br><br>'||
                                    '</body>'||
                                  '</html>',
                       mime_type => 'text/html');
    p_mail.begin_attachment(conn         => conn,
                            mime_type    => v_archivo_detalle||'/txt',
                            inline       => TRUE,
                            filename     => v_archivo_detalle||'.txt',
                            transfer_enc => 'text');
    IF p_registro_230.count() > 0 THEN
      FOR i IN p_registro_230.FIRST .. p_registro_230.LAST  LOOP
        v_bufline :=  P_REGISTRO_230(i).BUFLINE;
        IF i = 0 THEN 
          p_mail.write_mb_text(conn,v_bufline);
        ELSE
          p_mail.write_mb_text(conn,CRLF||v_bufline);
        END IF;   
      END LOOP;
    END IF;
    -- Se inactiva puesto ocasionaba que se generara un salto de linea adicional al final del archivo adjunto creado. 
    -- Adicionalmente, el quitar esta línea de código no se evidencia que impacta negativamente en la generación y envío del archivo.
    -- p_mail.end_attachment( conn => conn ); 
    p_mail.end_mail( conn => conn );
  EXCEPTION
    WHEN ERROR THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error ejecutando P_DIVISAS.P_GENERA_MAIL_230 ',V_MENSAJE_ERROR);
      RAISE_APPLICATION_ERROR(-20002,'Error ejecutando P_DIVISAS.P_GENERA_MAIL_230 '||V_MENSAJE_ERROR);
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error ejecutando P_DIVISAS.P_GENERA_MAIL_230 ',SQLERRM);
      RAISE_APPLICATION_ERROR(-20001,'Error ejecutando P_DIVISAS.P_GENERA_MAIL_230 '||SQLERRM);
END P_GENERA_MAIL_230;
PROCEDURE P_MAIL_FORMATO_465(P_FECHA DATE DEFAULT NULL,P_LLAMADO_REPORTE VARCHAR2  DEFAULT NULL,P_REGISTRO_465 IN OUT T_REGISTRO_465) IS
  v_fecha_proceso         DATE;
  v_fecha_dia_corte       DATE;
  v_fecha_inicial_rep1    DATE;
  v_fecha_inicial_reporte DATE;
  v_fecha_final_reporte   DATE;
  v_mensaje_error     VARCHAR2(1000);
  v_dia               VARCHAR2(1);
  v_bufline           VARCHAR2(2000) := NULL;
   v_tipo_entidad     VARCHAR2(2)  := '85';
  v_codigo_entidad    VARCHAR2(6)  := '000026';
  v_palabra_clave     VARCHAR2(11) := 'CDBCORRASOC';
  v_area_informacion  VARCHAR2(2)  := '09';
  v_tipo_informe      VARCHAR2(2)  := '06';
  v_total_registros   NUMBER(8)    := 5;
  v_registro          NUMBER;
  error               EXCEPTION;
BEGIN
  /* DETERMINAR DIA DE LA SEMANAA
     EL ARCHIVO SE DEBE EJECUTAR LOS LUNES DE INICIO DE LA SEMANA
    1-DOMINGO
    2-LUNES
    3-MARTES
    4-MIÉRCOLES
    5-JUEVES
    6-VIERNES
    7-SÁBADO
   */
  BEGIN
    IF p_fecha IS NULL THEN
      SELECT TO_CHAR(SYSDATE, 'D') INTO v_dia  FROM DUAL;
      v_fecha_proceso := TRUNC(SYSDATE);
    ELSE
      SELECT TO_CHAR(p_fecha, 'D') INTO v_dia  FROM DUAL;
      v_fecha_proceso := TRUNC(p_fecha);
    END IF;
  END;
  IF P_LLAMADO_REPORTE = 'F'  THEN
    v_dia := '2';
  END IF;
  IF NVL(v_dia,' ') = '2'  THEN -- SOLO SE DEBE EJECUTAR LUNES EN LA MADRUGRADA*/
    IF P_LLAMADO_REPORTE = 'F'  THEN
       v_fecha_dia_corte := P_FECHA;
    ELSE
        P_MAIL.ENVIO_MAIL_ERROR('Mail diario de verificacion P_MAIL_FORMATO_465:'||to_char(sysdate,'dd-mm-yyyy'),' Mail diario de verificacion formato 465');
        v_fecha_dia_corte := F_DIA_HABIL_SEMANA(v_fecha_proceso);
    END IF;
    R_REGISTRO_465.DELETE;
    v_bufline := LPAD(1, 8, '0') ||'1'||v_tipo_entidad||v_codigo_entidad||TO_CHAR(v_fecha_dia_corte + 9, 'DDMMYYYY')||
                 LPAD(v_total_registros, 8, '0') ||v_palabra_clave||v_area_informacion||v_tipo_informe;
    P_ESCRIBE_FORMATO_465(P_REGISTRO_465  => R_REGISTRO_465,P_BUFLINE      =>  v_bufline);

    IF TO_CHAR(v_fecha_dia_corte,'D') = '6' THEN
       v_fecha_inicial_reporte  := v_fecha_dia_corte+3;  -- Dia habil de  inicio de transmision
       v_fecha_inicial_rep1    := v_fecha_dia_corte+3;
    ELSE
       v_fecha_inicial_reporte := v_fecha_dia_corte + (9 - TO_NUMBER(TO_CHAR(v_fecha_dia_corte,'D')));
       v_fecha_inicial_rep1    := v_fecha_dia_corte + (9 - TO_NUMBER(TO_CHAR(v_fecha_dia_corte,'D')));
    END IF;
    v_fecha_final_reporte   := v_fecha_inicial_reporte+6;


    v_bufline :=  '0000000230000000000000000000000000000000000';
    P_ESCRIBE_FORMATO_465(P_REGISTRO_465  => R_REGISTRO_465,P_BUFLINE      =>  v_bufline);
    v_bufline :=  '0000000340000000000000000000002';
    P_ESCRIBE_FORMATO_465(P_REGISTRO_465  => R_REGISTRO_465,P_BUFLINE      =>  v_bufline);
    v_bufline :=  '0000000454659999999999+00000000000000000';
    P_ESCRIBE_FORMATO_465(P_REGISTRO_465  => R_REGISTRO_465,P_BUFLINE      =>  v_bufline);
    v_bufline :=  '000000056';
    P_ESCRIBE_FORMATO_465(P_REGISTRO_465  => R_REGISTRO_465,P_BUFLINE      =>  v_bufline);
    IF P_LLAMADO_REPORTE = 'F' THEN
      /* CREACION DE COLECCION PARA RETORNO DE LLAMADO DE LA FORMA*/
      IF R_registro_465.COUNT() > 0 THEN
        p_registro_465.DELETE;
        FOR i IN r_registro_465.FIRST .. r_registro_465.LAST LOOP
          v_registro := p_registro_465.COUNT();
          p_registro_465(v_registro).bufline         := r_registro_465(i).bufline;
        END LOOP;
      END IF;
    ELSE
       P_GENERA_MAIL_465 ( P_REGISTRO_465    => r_registro_465,
                           P_FECHA_DIA_CORTE => v_fecha_dia_corte,
                           P_FECHA_PROCESO   => v_fecha_proceso,
                           P_FECHA_INICIAL   => v_fecha_inicial_rep1,
                           P_FECHA_FINAL     => v_fecha_final_reporte);
    END IF;
  END IF;
  EXCEPTION
    WHEN ERROR THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error ejecutando P_DIVISAS.P_MAIL_FORMATO_465 ',V_MENSAJE_ERROR);
      RAISE_APPLICATION_ERROR(-20002,'Error ejecutando P_DIVISAS.P_MAIL_FORMATO_465 '||V_MENSAJE_ERROR);
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error ejecutando P_DIVISAS.P_MAIL_FORMATO_465 ',SQLERRM);
      RAISE_APPLICATION_ERROR(-20001,'Error ejecutando P_DIVISAS.P_MAIL_FORMATO_465 '||SQLERRM);
END P_MAIL_FORMATO_465;
PROCEDURE P_ESCRIBE_FORMATO_465(P_REGISTRO_465  IN OUT T_REGISTRO_465,
                                P_BUFLINE       VARCHAR2)IS
  v_registro NUMBER;
BEGIN
  v_registro := P_REGISTRO_465.COUNT();
  P_REGISTRO_465(v_registro).bufline := P_BUFLINE;
END P_ESCRIBE_FORMATO_465;
PROCEDURE P_GENERA_MAIL_465( P_REGISTRO_465    IN OUT T_REGISTRO_465,
                             P_FECHA_DIA_CORTE DATE,
                             P_FECHA_PROCESO   DATE,
                             P_FECHA_INICIAL   DATE,
                             P_FECHA_FINAL     DATE) IS
  /* OBTENER DIRECCIONES DE CORREO*/
  CURSOR CONSTANTE (P_MNEMONICO  VARCHAR2) IS
    SELECT CON_VALOR_CHAR
    FROM CONSTANTES
    WHERE CON_MNEMONICO = P_MNEMONICO;
  v_bufline          VARCHAR2(4000);
  v_mensaje_error    VARCHAR2(4000);
  crlf               VARCHAR2(2) :=  CHR(13)||CHR(10);
  v_archivo_detalle  VARCHAR2(500);
  C_CONSTANTE        CONSTANTE%ROWTYPE;
  ERROR              EXCEPTION;
  conn               utl_smtp.connection;
BEGIN
    /* OBTENER DIRECCIONES DE CORREO*/
    OPEN constante(P_MNEMONICO => 'MDI');
    FETCH constante INTO c_constante;
    IF constante%NOTFOUND THEN
      CLOSE constante;
      v_mensaje_error := 'No existe constante (MDI) de correos para divisas';
      RAISE ERROR;
    END IF;
    CLOSE CONSTANTE;
    /*********** INICIO FORMATO 465 ****/
    v_archivo_detalle := 'FORM465_'||TO_CHAR(P_FECHA_DIA_CORTE + 9, 'DDMONYYYY');
    conn := p_mail.begin_mail(sender     => 'administrador@corredores.com',
                              recipients   => TRIM(c_constante.con_valor_char),
                              subject      => 'Formato 465 Fecha reporte:'||TO_CHAR(P_FECHA_DIA_CORTE + 9, 'DDMONYYYY'),
                              mime_type    => p_mail.MULTIPART_MIME_TYPE);
    p_mail.attach_text(conn      => conn,
                       data      => '<html>'||
                                     '<head>'||
                                       '<IMG src=http://www.corredores.com/portal/eContent/images/Banners/BannerNo1.jpg>'||
                                     '</head>'||
                                     '<body FACE=arial> '||
                                       '<br><br><br><br><br><br>'||
                                       '<table>'||
                                         '<font size=2 face=Arial Black>'||
                                         '<tr>'||
                                          'Informacion formato 465 con fecha de corte al :'||to_char(P_FECHA_PROCESO,'DD-MM-YYYY')||'</tr>'||
                                         '<tr></tr>'||
                                         '<br><br><br><br><br><br>'||
                                         '<tr>'||' Atentamente,'||'</tr>'||
                                         '<br><br><br><br>'||
                                         '<tr><B>'||'CORREDORES DAVIVIENDA S.A.'||'</B></tr>'||
                                          '</font>'||
                                         '<br><br><br><br><br><br>'||
                                       '</table>'||
                                       '<br><br><br>'||
                                    '</body>'||
                                  '</html>',
                       mime_type => 'text/html');
    p_mail.begin_attachment(conn         => conn,
                            mime_type    => v_archivo_detalle||'/txt',
                            inline       => TRUE,
                            filename     => v_archivo_detalle||'.txt',
                            transfer_enc => 'text');
    IF p_registro_465.count() > 0 THEN
      FOR i IN p_registro_465.FIRST .. p_registro_465.LAST  LOOP
        v_bufline :=  P_REGISTRO_465(i).BUFLINE;
        p_mail.write_mb_text(conn,v_bufline||CRLF);
      END LOOP;
    END IF;
    p_mail.end_attachment( conn => conn );
    p_mail.end_mail( conn => conn );
  EXCEPTION
    WHEN ERROR THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error ejecutando P_DIVISAS.P_GENERA_MAIL_465 ',V_MENSAJE_ERROR);
      RAISE_APPLICATION_ERROR(-20002,'Error ejecutando P_DIVISAS.P_GENERA_MAIL_465 '||V_MENSAJE_ERROR);
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error ejecutando P_DIVISAS.P_GENERA_MAIL_465 ',SQLERRM);
      RAISE_APPLICATION_ERROR(-20001,'Error ejecutando P_DIVISAS.P_GENERA_MAIL_465 '||SQLERRM);
END P_GENERA_MAIL_465;
FUNCTION  F_DIA_HABIL_SEMANA(P_FECHA DATE) RETURN DATE IS
  V_FECHA            DATE;
  V_FECHA_VALIDACION DATE;
  V_DIA              NUMBER(5);
  V_RESTA_DIAS       NUMBER(5);
/*1-DOMINGO
2-LUNES
3-MARTES
4-MIÉRCOLES
5-JUEVES
6-VIERNES
7-SÁBADO*/
BEGIN
  V_FECHA := P_FECHA;
  V_DIA   := TO_CHAR(P_FECHA,'D');
  IF V_DIA = 1 THEN
    V_RESTA_DIAS  :=2;
  ELSIF V_DIA = 2 THEN
    V_RESTA_DIAS  :=3;
  ELSIF V_DIA = 3 THEN
    V_RESTA_DIAS  :=4;
  ELSIF V_DIA = 4 THEN
    V_RESTA_DIAS  :=5;
  ELSIF V_DIA = 5 THEN
    V_RESTA_DIAS  :=6;
  ELSIF V_DIA = 6 THEN
    V_RESTA_DIAS  :=7;
  ELSIF V_DIA = 7 THEN
    V_RESTA_DIAS  :=1;
  END IF;
  V_FECHA             := TRUNC(V_FECHA - V_RESTA_DIAS)-7;
  V_FECHA_VALIDACION  := TRUNC(V_FECHA);
  WHILE TRUE LOOP
    V_FECHA := P_SALDOS_CLIENTES.F_FECHA_HABIL(P_FECHA_INICIAL => TRUNC(V_FECHA),
                                                 P_DIAS          => 1);
    IF TRUNC(V_FECHA) = TRUNC(V_FECHA_VALIDACION) THEN
      EXIT;
    END IF;
    --V_FECHA            := V_FECHA-1;
    --V_FECHA_VALIDACION := V_FECHA;

    V_FECHA            := V_FECHA_VALIDACION-1;
    V_FECHA_VALIDACION := V_FECHA;
  END LOOP;
  RETURN(V_FECHA);
END F_DIA_HABIL_SEMANA;
FUNCTION F_SIGNO(VALOR NUMBER) RETURN VARCHAR2 IS
  signo VARCHAR2(1);
BEGIN
  IF valor < 0 THEN
    signo := '-';
  ELSE
    signo := '+';
  END IF;
  RETURN signo;
END F_SIGNO;
FUNCTION DIA_DE_LA_SEMANA(P_FECHA DATE) RETURN VARCHAR2 IS
  CURSOR DIA IS
    SELECT TO_CHAR(P_FECHA, 'D') ES
    FROM DUAL;
  V_DIA VARCHAR2(1) := 0;
BEGIN
  OPEN DIA;
  FETCH DIA INTO V_DIA;
  CLOSE DIA;
  RETURN V_DIA;
END DIA_DE_LA_SEMANA;
FUNCTION F_DIA_DATOS (P_FECHA DATE) RETURN DATE IS
  V_FECHA DATE;
  V_FECHA_DIA DATE;
  CURSOR DIA_NO_HABIL(P_FECHA DATE) IS
  SELECT dnh_fecha
    FROM   dias_no_habiles
    WHERE  TRUNC(dnh_fecha) = TRUNC(p_fecha);
  C_DIA_NO_HABIL DIA_NO_HABIL%ROWTYPE;
  V_CUENTA       NUMBER(5);
BEGIN
  V_FECHA := P_FECHA;
  V_CUENTA := 0;
  WHILE TRUE LOOP
    V_CUENTA := 0;
    FOR K IN DIA_NO_HABIL(v_fecha) LOOP
      V_CUENTA := V_CUENTA+1;
    END LOOP;
    IF nvl(V_CUENTA,0) > 0 OR TO_CHAR(V_FECHA,'D') IN (1,7) THEN
      v_fecha := v_fecha -1;
    ELSE
      EXIT;
    END IF;
  END LOOP;
  RETURN(V_FECHA);
END F_DIA_DATOS;
PROCEDURE P_MAIL_DECLARACIONES_CAMBIO
   (P_FECHA_INI    DATE
   ,P_FECHA_FIN    DATE) IS
   FECHA1 DATE;
   FECHA2 DATE;
   CURSOR C_DECLARACION_UNO(TIPO_OPERACION NUMBER) IS
      SELECT DCA_NUMERO_DECLARACION
            ,DCA_ESTADO
            ,DCA_FECHA
            ,DECODE(ORD_CLI_PER_TID_CODIGO,'CC','CC'
                                          ,'CE','CE'
                                          ,'NIT','NI'
                                          ,'PP','PB'
                                          ,'RC','RC') ORD_CLI_PER_TID_CODIGO
            ,ORD_CLI_PER_NUM_IDEN
            ,FOU_CLN_NUM_NUMERO
            ,FOU_VALOR_USD_UNO
            ,FOU_CLN_NUM_NUMERO_TIENE
            ,FOU_VALOR_USD_DOS
      FROM   FORMULARIOS_UNO
            ,DECLARACIONES_CAMBIO
            ,ORDENES_DIVISAS
      WHERE  FOU_DCA_NUMERO_DECLARACION = DCA_NUMERO_DECLARACION
      AND    DCA_FORMULARIO = 1
      AND    DCA_FECHA >= FECHA1
      AND    DCA_FECHA < FECHA2
      AND    DCA_ORD_CONSECUTIVO = ORD_CONSECUTIVO
      AND    DCA_ORD_SUC_CODIGO = ORD_SUC_CODIGO
      AND    ORD_EOF_CODIGO = 'APR'
      ORDER BY DCA_NUMERO_DECLARACION;
   DECLARACION_UNO C_DECLARACION_UNO%ROWTYPE;
   CURSOR C_DECLARACION_DOS (TIPO_OPERACION NUMBER) IS
      SELECT DCA_NUMERO_DECLARACION
            ,DCA_ESTADO
            ,DCA_FECHA
            ,DECODE(ORD_CLI_PER_TID_CODIGO,'CC','CC'
                                          ,'CE','CE'
                                          ,'NIT','NI'
                                          ,'PP','PB'
                                          ,'RC','RC') ORD_CLI_PER_TID_CODIGO
            ,ORD_CLI_PER_NUM_IDEN
      FROM   FORMULARIOS_DOS
            ,DECLARACIONES_CAMBIO
            ,ORDENES_DIVISAS
      WHERE  FOD_DCA_NUMERO_DECLARACION = DCA_NUMERO_DECLARACION
      AND    DCA_FORMULARIO = 2
      AND    DCA_FECHA >= FECHA1
      AND    DCA_FECHA < FECHA2
      AND    DCA_ORD_CONSECUTIVO = ORD_CONSECUTIVO
      AND    DCA_ORD_SUC_CODIGO = ORD_SUC_CODIGO
      AND    ORD_EOF_CODIGO = 'APR'
      ORDER BY DCA_NUMERO_DECLARACION;
   DECLARACION_DOS C_DECLARACION_DOS%ROWTYPE;
   CURSOR C_EXPORTACION_DEFINITIVA(NUMERO_DECLARACION NUMBER) IS
      SELECT EXD_FOD_DCA_NUMERO_DECLARACION
            ,EXD_CLN_NUM_NUMERO
            ,EXD_VALOR_REINTEGRO_USD
      FROM   EXPORTACIONES_DEFINITIVAS
      WHERE  EXD_FOD_DCA_NUMERO_DECLARACION = NUMERO_DECLARACION
      ORDER BY EXD_CONSECUTIVO;
   EXPORTACION_DEFINITIVA C_EXPORTACION_DEFINITIVA%ROWTYPE;
   CURSOR C_DECLARACION_TRES(TIPO_OPERACION NUMBER) IS
      SELECT DCA_NUMERO_DECLARACION
            ,DCA_ESTADO
            ,DCA_FECHA
            ,DECODE(ORD_CLI_PER_TID_CODIGO,'CC','CC'
                                          ,'CE','CE'
                                          ,'NIT','NI'
                                          ,'PP','PB'
                                          ,'RC','RC') ORD_CLI_PER_TID_CODIGO
            ,ORD_CLI_PER_NUM_IDEN
      FROM   FORMULARIOS_TRES
            ,DECLARACIONES_CAMBIO
            ,ORDENES_DIVISAS
      WHERE  FOT_DCA_NUMERO_DECLARACION = DCA_NUMERO_DECLARACION
      AND    DCA_FORMULARIO = 3
      AND    DCA_FECHA >= FECHA1
      AND    DCA_FECHA < FECHA2
      AND    DCA_ORD_CONSECUTIVO = ORD_CONSECUTIVO
      AND    DCA_ORD_SUC_CODIGO = ORD_SUC_CODIGO
      AND    ORD_EOF_CODIGO = 'APR'
      ORDER BY DCA_NUMERO_DECLARACION;
   DECLARACION_TRES C_DECLARACION_TRES%ROWTYPE;
   CURSOR C_NUMERACION_LIQUIDACION (NUMERO_DECLARACION NUMBER)  IS
      SELECT NUL_FOT_DCA_NUMERO_DECLARACION
            ,NUL_CLN_NUM_NUMERO
            ,NUL_VALOR_NEGOCIACION
            ,NUL_VALOR_MONEDA
            ,NUL_VALOR_USD
            ,NUL_VALOR_BASE_MONEDA_CONTRA
            ,NUL_FECHA_INICIO
            ,NUL_FECHA_FINAL
            ,NUL_DIAS
            ,NUL_TASA
      FROM   NUMERACIONES_LIQUIDACIONES
      WHERE  NUL_FOT_DCA_NUMERO_DECLARACION = NUMERO_DECLARACION
      ORDER BY NUL_CONSECUTIVO;
   NUMERACION_LIQUIDACION  C_NUMERACION_LIQUIDACION%ROWTYPE;
   CURSOR C_DECLARACION_CUATRO(TIPO_OPERACION NUMBER) IS
      SELECT DCA_NUMERO_DECLARACION
            ,DCA_ESTADO
            ,DCA_FECHA
            ,ORD_CLI_PER_NUM_IDEN
            ,DECODE(ORD_CLI_PER_TID_CODIGO,'CC','CC'
                                          ,'CE','CE'
                                          ,'NIT','NI'
                                          ,'PP','PB'
                                          ,'RC','RC') ORD_CLI_PER_TID_CODIGO
            ,FOC_CLN_NUM_NUMERO
            ,FOC_VALOR_USD
      FROM   FORMULARIOS_CUATRO
            ,DECLARACIONES_CAMBIO
            ,ORDENES_DIVISAS
      WHERE  FOC_DCA_NUMERO_DECLARACION = DCA_NUMERO_DECLARACION
      AND    DCA_FORMULARIO = 4
      AND    DCA_FECHA >= FECHA1
      AND    DCA_FECHA < FECHA2
      AND    DCA_ORD_CONSECUTIVO = ORD_CONSECUTIVO
      AND    DCA_ORD_SUC_CODIGO = ORD_SUC_CODIGO
      AND    ORD_EOF_CODIGO = 'APR'
      ORDER BY DCA_NUMERO_DECLARACION;
  DECLARACION_CUATRO C_DECLARACION_CUATRO%ROWTYPE;
   CURSOR C_DECLARACION_CINCO(TIPO_OPERACION NUMBER) IS
      SELECT DCA_NUMERO_DECLARACION
            ,DCA_ESTADO
            ,DCA_FECHA
            ,ORD_CLI_PER_NUM_IDEN
            ,DECODE(ORD_CLI_PER_TID_CODIGO,'CC','CC'
                                          ,'CE','CE'
                                          ,'NIT','NI'
                                          ,'PP','PB'
                                          ,'RC','RC') ORD_CLI_PER_TID_CODIGO
      FROM   FORMULARIOS_CINCO
            ,DECLARACIONES_CAMBIO
            ,ORDENES_DIVISAS
      WHERE  FOI_DCA_NUMERO_DECLARACION  = DCA_NUMERO_DECLARACION
      AND    DCA_FORMULARIO = 5
      AND    DCA_FECHA >= FECHA1
      AND    DCA_FECHA < FECHA2
      AND    DCA_ORD_CONSECUTIVO = ORD_CONSECUTIVO
      AND    DCA_ORD_SUC_CODIGO = ORD_SUC_CODIGO
      AND    ORD_EOF_CODIGO = 'APR'
      ORDER BY DCA_NUMERO_DECLARACION;
   DECLARACION_CINCO C_DECLARACION_CINCO%ROWTYPE;
   CURSOR C_DETALLE_OPERACION(NUMERO_DECLARACION NUMBER) IS
      SELECT DEO_FOI_DCA_NUMERO_DECLARACION
            ,DEO_CLN_NUM_NUMERO
            ,DEO_VALOR_USD
      FROM   DETALLE_OPERACIONES
      WHERE  DEO_FOI_DCA_NUMERO_DECLARACION  = NUMERO_DECLARACION
      ORDER BY DEO_CONSECUTIVO;
   DETALLE_OPERACION C_DETALLE_OPERACION%ROWTYPE;
   CURSOR C_DIA_NO_HABIL(P_FECHA  DATE) IS
      SELECT 'X'
      FROM   DIAS_NO_HABILES
      WHERE  TRUNC(DNH_FECHA) = TRUNC(P_FECHA);
   DIA_NO_HABIL           VARCHAR2(1);
   REGISTRO               VARCHAR2(500);
   I                      NUMBER(2);
   CONN                   UTL_SMTP.CONNECTION;
   CRLF                   VARCHAR2(2) := CHR(13)||CHR(10);
BEGIN
   IF TRUNC(P_FECHA_INI) = TRUNC(P_FECHA_FIN) THEN
      OPEN C_DIA_NO_HABIL(P_FECHA_FIN);
      FETCH C_DIA_NO_HABIL INTO DIA_NO_HABIL;
      CLOSE C_DIA_NO_HABIL;
      IF NVL(DIA_NO_HABIL,' ') = 'X' OR
         TO_CHAR(P_FECHA_FIN,'D') IN ('1','7') THEN
         DIA_NO_HABIL := 'X';
      END IF;
   END IF;

   IF NVL(DIA_NO_HABIL,' ') != 'X' THEN
      FECHA1 := TRUNC(P_FECHA_INI);
      FECHA2 := TRUNC(P_FECHA_FIN + 1);
      CONN := P_MAIL.BEGIN_MAIL(SENDER     => 'administrador@corredores.com',
                                RECIPIENTS => 'aangel@corredores.com;icastaneda@corredores.com',
                                SUBJECT    => 'Declaraciones de cambio fechas: ' || TO_CHAR(P_FECHA_INI,'DD-MON-YYYY')
                                              || ' - ' || TO_CHAR(P_FECHA_FIN,'DD-MON-YYYY'),
                                MIME_TYPE  => P_MAIL.MULTIPART_MIME_TYPE);
      P_MAIL.ATTACH_TEXT(CONN      => CONN,
                         data      => '<html>'||
                                       '<head>'||
                                          '<IMG src=http://www.corredores.com/portal/eContent/images/Banners/BannerNo1.jpg>'||
                                         '</head>'||
                                        '<body FACE=arial> '||
                                          '<br><br><br><br><br><br>'||
                                          '<table>'||
                                            '<font size=2 face=Arial Black>'||
                                            '<tr>'||
                                             'Declaraciones y numerales cambiarios'||'</tr>'||
                                            '<tr></tr>'||
                                            '<br><br><br><br><br><br>'||
                                            '<tr>'||' Atentamente,'||'</tr>'||
                                            '<br><br><br><br>'||
                                            '<tr><B>'||'CORREDORES DAVIVIENDA S.A.'||'</B></tr>'||
                                             '</font>'||
                                            '<br><br><br><br><br><br>'||
                                          '</table>'||
                                          '<br><br><br>'||
                                       '</body>'||
                                     '</html>',
                         MIME_TYPE => 'text/html');
      P_MAIL.BEGIN_ATTACHMENT(conn         => conn,
                              mime_type    => 'DECLARACIONES'||'/txt',
                              inline       => TRUE,
                              filename     => 'DECLARACIONES'||'.txt',
                              transfer_enc => 'text');
      REGISTRO := 'FORMULARIO;NUMERO DECLARACION;ESTADO;FECHA;No. IDENTIFICACION;T.I.;NUMERAL;VALOR USD';
      P_MAIL.WRITE_MB_TEXT(CONN,REGISTRO||CRLF);
      REGISTRO := ' ';
      OPEN C_DECLARACION_UNO(I);
      FETCH C_DECLARACION_UNO INTO DECLARACION_UNO;
      WHILE C_DECLARACION_UNO%FOUND LOOP
         REGISTRO := '01' || ';' ||
                     DECLARACION_UNO.DCA_NUMERO_DECLARACION || ';' ||
                     DECLARACION_UNO.DCA_ESTADO || ';' ||
                     DECLARACION_UNO.DCA_FECHA || ';' ||
                     DECLARACION_UNO.ORD_CLI_PER_NUM_IDEN || ';' ||
                     DECLARACION_UNO.ORD_CLI_PER_TID_CODIGO || ';' ||
                     DECLARACION_UNO.FOU_CLN_NUM_NUMERO || ';' ||
                     DECLARACION_UNO.FOU_VALOR_USD_UNO;
         P_MAIL.WRITE_MB_TEXT(CONN,REGISTRO||CRLF);
         IF DECLARACION_UNO.FOU_CLN_NUM_NUMERO_TIENE IS NOT NULL THEN
            REGISTRO := '01' || ';' ||
                        DECLARACION_UNO.DCA_NUMERO_DECLARACION || ';' ||
                        DECLARACION_UNO.DCA_ESTADO || ';' ||
                        DECLARACION_UNO.DCA_FECHA || ';' ||
                        DECLARACION_UNO.ORD_CLI_PER_NUM_IDEN || ';' ||
                        DECLARACION_UNO.ORD_CLI_PER_TID_CODIGO || ';' ||
                        DECLARACION_UNO.FOU_CLN_NUM_NUMERO_TIENE || ';' ||
                        DECLARACION_UNO.FOU_VALOR_USD_DOS;
            P_MAIL.WRITE_MB_TEXT(CONN,REGISTRO||CRLF);
         END IF;
         FETCH C_DECLARACION_UNO INTO DECLARACION_UNO;
      END LOOP;
      CLOSE C_DECLARACION_UNO;
      -- FORMULARIO DOS
      REGISTRO := ' ';
      OPEN C_DECLARACION_DOS(I);
      FETCH C_DECLARACION_DOS INTO DECLARACION_DOS;
      WHILE C_DECLARACION_DOS%FOUND LOOP
         REGISTRO := ' ';
         OPEN C_EXPORTACION_DEFINITIVA(DECLARACION_DOS.DCA_NUMERO_DECLARACION);
         FETCH C_EXPORTACION_DEFINITIVA INTO EXPORTACION_DEFINITIVA;
         WHILE C_EXPORTACION_DEFINITIVA% FOUND LOOP
            REGISTRO := '02' || ';' ||
                        DECLARACION_DOS.DCA_NUMERO_DECLARACION || ';' ||
                        DECLARACION_DOS.DCA_ESTADO || ';' ||
                        DECLARACION_DOS.DCA_FECHA || ';' ||
                        DECLARACION_DOS.ORD_CLI_PER_NUM_IDEN || ';' ||
                        DECLARACION_DOS.ORD_CLI_PER_TID_CODIGO || ';' ||
                        EXPORTACION_DEFINITIVA.EXD_CLN_NUM_NUMERO || ';' ||
                        EXPORTACION_DEFINITIVA.EXD_VALOR_REINTEGRO_USD;
            P_MAIL.WRITE_MB_TEXT(CONN,REGISTRO||CRLF);
            FETCH C_EXPORTACION_DEFINITIVA INTO EXPORTACION_DEFINITIVA;
         END LOOP;
         CLOSE C_EXPORTACION_DEFINITIVA;
         FETCH C_DECLARACION_DOS INTO DECLARACION_DOS;
      END LOOP;
      CLOSE C_DECLARACION_DOS;
      -- FORMULARIO TRES
      REGISTRO := ' ';
      OPEN C_DECLARACION_TRES(I);
      FETCH C_DECLARACION_TRES INTO DECLARACION_TRES;
      WHILE C_DECLARACION_TRES%FOUND LOOP
         REGISTRO := ' ';
         OPEN C_NUMERACION_LIQUIDACION(DECLARACION_TRES.DCA_NUMERO_DECLARACION);
         FETCH C_NUMERACION_LIQUIDACION INTO NUMERACION_LIQUIDACION;
         WHILE C_NUMERACION_LIQUIDACION%FOUND LOOP
            REGISTRO := '03' || ';' ||
                        DECLARACION_TRES.DCA_NUMERO_DECLARACION || ';' ||
                        DECLARACION_TRES.DCA_ESTADO || ';' ||
                        DECLARACION_TRES.DCA_FECHA || ';' ||
                        DECLARACION_TRES.ORD_CLI_PER_NUM_IDEN || ';' ||
                        DECLARACION_TRES.ORD_CLI_PER_TID_CODIGO || ';' ||
                        NUMERACION_LIQUIDACION.NUL_CLN_NUM_NUMERO|| ';' ||
                        NUMERACION_LIQUIDACION.NUL_VALOR_USD;
            P_MAIL.WRITE_MB_TEXT(CONN,REGISTRO||CRLF);
            FETCH C_NUMERACION_LIQUIDACION INTO NUMERACION_LIQUIDACION;
         END LOOP;
         CLOSE C_NUMERACION_LIQUIDACION;
         FETCH C_DECLARACION_TRES INTO DECLARACION_TRES;
      END LOOP;
      CLOSE C_DECLARACION_TRES;
      -- FORMULARIO CUATRO
      REGISTRO := ' ';
      OPEN C_DECLARACION_CUATRO(I);
      FETCH C_DECLARACION_CUATRO INTO DECLARACION_CUATRO;
      WHILE C_DECLARACION_CUATRO%FOUND LOOP
         REGISTRO := '04' || ';' ||
                     DECLARACION_CUATRO.DCA_NUMERO_DECLARACION || ';' ||
                     DECLARACION_CUATRO.DCA_ESTADO || ';' ||
                     DECLARACION_CUATRO.DCA_FECHA || ';' ||
                     DECLARACION_CUATRO.ORD_CLI_PER_NUM_IDEN || ';' ||
                     DECLARACION_CUATRO.ORD_CLI_PER_TID_CODIGO || ';' ||
                     DECLARACION_CUATRO.FOC_CLN_NUM_NUMERO || ';' ||
                     DECLARACION_CUATRO.FOC_VALOR_USD;
         P_MAIL.WRITE_MB_TEXT(CONN,REGISTRO||CRLF);
         FETCH C_DECLARACION_CUATRO INTO DECLARACION_CUATRO;
      END LOOP;
      CLOSE C_DECLARACION_CUATRO;
      -- FORMULARIO CINCO
      REGISTRO := ' ';
      OPEN C_DECLARACION_CINCO(I);
      FETCH C_DECLARACION_CINCO INTO DECLARACION_CINCO;
      WHILE C_DECLARACION_CINCO%FOUND LOOP
         REGISTRO := ' ';
         OPEN C_DETALLE_OPERACION(DECLARACION_CINCO.DCA_NUMERO_DECLARACION);
         FETCH C_DETALLE_OPERACION INTO DETALLE_OPERACION;
         WHILE C_DETALLE_OPERACION%FOUND LOOP
            REGISTRO := '05' || ';' ||
                        DECLARACION_CINCO.DCA_NUMERO_DECLARACION || ';' ||
                        DECLARACION_CINCO.DCA_ESTADO || ';' ||
                        DECLARACION_CINCO.DCA_FECHA || ';' ||
                        DECLARACION_CINCO.ORD_CLI_PER_NUM_IDEN || ';' ||
                        DECLARACION_CINCO.ORD_CLI_PER_TID_CODIGO || ';' ||
                        DETALLE_OPERACION.DEO_CLN_NUM_NUMERO || ';' ||
                        DETALLE_OPERACION.DEO_VALOR_USD;
            P_MAIL.WRITE_MB_TEXT(CONN,REGISTRO||CRLF);
            FETCH C_DETALLE_OPERACION INTO DETALLE_OPERACION;
         END LOOP;
         CLOSE C_DETALLE_OPERACION;
         FETCH C_DECLARACION_CINCO INTO DECLARACION_CINCO;
      END LOOP;
      CLOSE C_DECLARACION_CINCO;
      p_mail.end_attachment(conn => conn );
      p_mail.end_mail(conn => conn );
   END IF;
EXCEPTION
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error ejecutando P_DIVISAS.P_GENERA_MAIL_465 ',SQLERRM);
END P_MAIL_DECLARACIONES_CAMBIO;
--
-- --------------------------------------------------------------------------------------------------------------
PROCEDURE INSERTA_INFORME_BR(P_FECHA_TRANSMISION     IN INFORMES_BR_DECLARACIONES_IMC.IBR_FECHA_TRANSMISION%TYPE
                            ,P_HORA_TRANSMISION      IN INFORMES_BR_DECLARACIONES_IMC.IBR_HORA_TRANSMISION%TYPE
                            ,P_USUARIO               IN INFORMES_BR_DECLARACIONES_IMC.IBR_USUARIO%TYPE
                            ,P_ARCHIVO               IN INFORMES_BR_DECLARACIONES_IMC.IBR_ARCHIVO%TYPE
                            ,P_OPERACION             IN INFORMES_BR_DECLARACIONES_IMC.IBR_OPERACION%TYPE
                            ,P_FORMULARIO            IN INFORMES_BR_DECLARACIONES_IMC.IBR_FORMULARIO%TYPE
                            ,P_FECHA                 IN INFORMES_BR_DECLARACIONES_IMC.IBR_FECHA%TYPE
                            ,P_NUMERO                IN INFORMES_BR_DECLARACIONES_IMC.IBR_NUMERO%TYPE
                            ,P_VALOR_USD             IN INFORMES_BR_DECLARACIONES_IMC.IBR_VALOR_USD%TYPE
                            ,P_RESULTADO_INTEGRACION IN INFORMES_BR_DECLARACIONES_IMC.IBR_RESULTADO_INTEGRACION%TYPE
                            ,P_ERROR_MENSAJE         IN INFORMES_BR_DECLARACIONES_IMC.IBR_ERROR_MENSAJE%TYPE) IS
  CURSOR C_CONSEC IS
    SELECT MAX(NVL(IBR_CONSECUTIVO, 0) + 1) IBR_CONSECUTIVO
    FROM INFORMES_BR_DECLARACIONES_IMC
    WHERE TRUNC(IBR_FECHA_TRANSMISION) = TRUNC(P_FECHA_TRANSMISION);
  V_CONSECUTIVO INFORMES_BR_DECLARACIONES_IMC.IBR_CONSECUTIVO%TYPE;
  --
  CURSOR C_REEMPLAZO IS
    SELECT 'S'
    FROM INFORMES_BR_DECLARACIONES_IMC
    WHERE TRUNC(IBR_FECHA) = TRUNC(P_FECHA)
    /*IBR_FECHA_TRANSMISION = P_FECHA_TRANSMISION*/
    AND   IBR_NUMERO     = P_NUMERO
    AND   IBR_ARCHIVO    = P_ARCHIVO
    AND   IBR_OPERACION  = P_OPERACION
    AND   IBR_FORMULARIO = P_FORMULARIO;
  V_EXISTE VARCHAR2(1) := 'N';
  --
BEGIN
  OPEN C_REEMPLAZO;
  FETCH C_REEMPLAZO INTO V_EXISTE;
  CLOSE C_REEMPLAZO;
  --
  IF NVL(V_EXISTE, 'N') = 'S' THEN
    UPDATE INFORMES_BR_DECLARACIONES_IMC
    SET IBR_RESULTADO_INTEGRACION = 'C'
      -- ,IBR_IBR_HORA_TRANSMISION = P_HORA_TRANSMISION
    WHERE TRUNC(IBR_FECHA) = TRUNC(P_FECHA)
    /*TRUNC(IBR_FECHA_TRANSMISION) = TRUNC(P_FECHA_TRANSMISION)*/
    AND   IBR_NUMERO     = P_NUMERO
    AND   IBR_ARCHIVO    = P_ARCHIVO
    AND  (IBR_OPERACION  = P_OPERACION OR IBR_OPERACION = 5)
    AND   IBR_FORMULARIO = P_FORMULARIO;
  END IF;
  --
  OPEN C_CONSEC;
  FETCH C_CONSEC INTO V_CONSECUTIVO;
  CLOSE C_CONSEC;
  --
  IF V_CONSECUTIVO IS NULL THEN
    V_CONSECUTIVO := 1;
  END IF;
  --
  INSERT INTO INFORMES_BR_DECLARACIONES_IMC(IBR_FECHA_TRANSMISION
                                           ,IBR_CONSECUTIVO
                                           ,IBR_HORA_TRANSMISION
                                           ,IBR_USUARIO
                                           ,IBR_ARCHIVO
                                           ,IBR_OPERACION
                                           ,IBR_FORMULARIO
                                           ,IBR_FECHA
                                           ,IBR_NUMERO
                                           ,IBR_VALOR_USD
                                           ,IBR_RESULTADO_INTEGRACION
                                           ,IBR_ERROR_MENSAJE
                                           ,IBR_CRUZADO)
  VALUES(P_FECHA_TRANSMISION
        ,V_CONSECUTIVO
        ,P_HORA_TRANSMISION
        ,P_USUARIO
        ,P_ARCHIVO
        ,P_OPERACION
        ,P_FORMULARIO
        ,P_FECHA
        ,P_NUMERO
        ,P_VALOR_USD
        ,P_RESULTADO_INTEGRACION
        ,P_ERROR_MENSAJE
        ,'N');
  --
EXCEPTION
  WHEN OTHERS THEN
    RAISE_APPLICATION_ERROR(-20501, 'Error en P_DIVISAS.INSERTA_INFORME_BR '||SQLERRM);

END INSERTA_INFORME_BR;
--HROSAS, INFORME 311
/* P_LLAMADO_REPORTE = 'F' RETORNA REGISTROS A LA FORMA Y NO EJECUTA ENVIO DE MAIL*/
PROCEDURE PR_MAIL_EXCEL_311(P_FECHA_1 DATE DEFAULT NULL
                           ,P_FECHA_2 DATE DEFAULT NULL
                           ,P_REGISTRO IN OUT T_REGISTRO_2) IS

  CURSOR UND_CAPTURA_010 IS
    SELECT TO_DATE(ORD.ORD_FECHA_COLOCACION,'DD/MM/YYYY') FECHA
           ,TO_CHAR(SUM(ORD.ORD_VALOR_PESOS)/SUM(ORD.ORD_VALOR_DOLARES),'9999.99') TASA
           ,SUM(ORD.ORD_VALOR_DOLARES) VALOR_DOLARES
           ,NVL(ORD.ORD_DIAS_NEXT_DAY,0) DIAS_NEXT_DAY
           ,ORD.ORD_TIPO_ORDEN TIPO_ORDEN
    FROM ORDENES_DIVISAS ORD
    WHERE ORD.ORD_TIPO_ORDEN IN ('C','V')
      AND ORD.ORD_EOF_CODIGO IN ('APR','APL')
      AND ORD.ORD_TMD_MNEMONICO IN ('COCHN','VECHD')
      AND ORD.ORD_FECHA_COLOCACION >= TRUNC(P_FECHA_1)
      AND ORD.ORD_FECHA_COLOCACION < TRUNC(P_FECHA_2) + 1
    group by TO_DATE(ORD.ORD_FECHA_COLOCACION,'DD/MM/YYYY'), NVL(ORD.ORD_DIAS_NEXT_DAY,0), ORD.ORD_TIPO_ORDEN
    ORDER BY TO_DATE(ORD.ORD_FECHA_COLOCACION,'DD/MM/YYYY');
  C_UND_CAPTURA_010 UND_CAPTURA_010%ROWTYPE;

  CURSOR UND_CAPTURA_015 IS
    SELECT TO_DATE(ORD.ORD_FECHA_COLOCACION,'DD/MM/YYYY') FECHA
      ,TO_CHAR(SUM(FCI.FOI_VALOR_TOTAL_USD*ORD.ORD_TASA_CAMBIO)/SUM(FCI.FOI_VALOR_TOTAL_USD),'9999.99') TASA
      ,SUM(FCI.FOI_VALOR_TOTAL_USD) VALOR_DOLARES
      ,NVL(ORD.ORD_DIAS_NEXT_DAY,0) DIAS_NEXT_DAY
      ,ORD.ORD_TIPO_ORDEN TIPO_ORDEN
    FROM ORDENES_DIVISAS ORD
        ,DECLARACIONES_CAMBIO DCA
        ,FORMULARIOS_CINCO FCI
        ,DETALLE_OPERACIONES DEO
    WHERE DCA.DCA_ORD_CONSECUTIVO = ORD.ORD_CONSECUTIVO
      AND DCA.DCA_ORD_SUC_CODIGO = ORD.ORD_SUC_CODIGO
      AND DCA.DCA_NUMERO_DECLARACION = FCI.FOI_DCA_NUMERO_DECLARACION
      AND DEO.DEO_FOI_DCA_NUMERO_DECLARACION = FCI.FOI_DCA_NUMERO_DECLARACION
      AND DEO.DEO_CLN_NUM_NUMERO IN (1810,2910)
      AND ORD.ORD_TIPO_ORDEN IN ('C','V')
      AND ORD.ORD_EOF_CODIGO IN ('APR','APL')
      AND ORD.ORD_TMD_MNEMONICO NOT IN ('COCHN','VECHD','DXADR','CXADR','CTADR','ATADR')
      AND ORD.ORD_FECHA_COLOCACION >= TRUNC(P_FECHA_1)
      AND ORD.ORD_FECHA_COLOCACION < TRUNC(P_FECHA_2) + 1
    group by TO_DATE(ORD.ORD_FECHA_COLOCACION,'DD/MM/YYYY'), NVL(ORD.ORD_DIAS_NEXT_DAY,0), ORD.ORD_TIPO_ORDEN
    ORDER BY TO_DATE(ORD.ORD_FECHA_COLOCACION,'DD/MM/YYYY');
  C_UND_CAPTURA_015 UND_CAPTURA_015%ROWTYPE;

  CURSOR UND_CAPTURA_020 IS
    SELECT TO_DATE(FECHA,'DD/MM/YYYY') FECHA
      ,TO_CHAR(SUM(VALOR_PESOS)/SUM(VALOR_DOLARES),'9999.99') TASA
      ,SUM(VALOR_DOLARES) VALOR_DOLARES
      ,NVL(DIAS_NEXT_DAY,0) DIAS_NEXT_DAY
      ,TIPO_ORDEN
    FROM (SELECT TO_DATE(ORD.ORD_FECHA_COLOCACION,'DD/MM/YYYY') FECHA
            ,ORD.ORD_VALOR_PESOS VALOR_PESOS
            ,ORD.ORD_VALOR_DOLARES VALOR_DOLARES 
            ,NVL(ORD.ORD_DIAS_NEXT_DAY,0) DIAS_NEXT_DAY
            ,ORD.ORD_TIPO_ORDEN TIPO_ORDEN
      FROM ORDENES_DIVISAS ORD
      WHERE ORD.ORD_TIPO_ORDEN IN ('C','V')
        AND ORD.ORD_EOF_CODIGO IN ('APR','APL')
        AND ORD.ORD_TMD_MNEMONICO NOT IN ('COCHN','VECHD','DXADR','CXADR','CTADR','ATADR')
        AND ORD.ORD_FECHA_COLOCACION >= TRUNC(P_FECHA_1)
        AND ORD.ORD_FECHA_COLOCACION <  TRUNC(P_FECHA_2) + 1      
        AND ORD.ORD_CONSECUTIVO NOT IN (SELECT ORD.ORD_CONSECUTIVO
                                        FROM ORDENES_DIVISAS ORD
                                            ,DECLARACIONES_CAMBIO DCA
                                            ,FORMULARIOS_CINCO FCI
                                            ,DETALLE_OPERACIONES DEO
                                        WHERE DCA.DCA_ORD_CONSECUTIVO = ORD.ORD_CONSECUTIVO
                                          AND DCA.DCA_ORD_SUC_CODIGO = ORD.ORD_SUC_CODIGO
                                          AND DCA.DCA_NUMERO_DECLARACION = FCI.FOI_DCA_NUMERO_DECLARACION
                                          AND DEO.DEO_FOI_DCA_NUMERO_DECLARACION = FCI.FOI_DCA_NUMERO_DECLARACION
                                          AND DEO.DEO_CLN_NUM_NUMERO IN (1810,2910,8102,8106)
                                          AND ORD.ORD_TIPO_ORDEN IN ('C','V')
                                          AND ORD.ORD_EOF_CODIGO IN ('APR','APL')
                                          AND ORD.ORD_TMD_MNEMONICO NOT IN ('COCHN','VECHD')
                                          AND ORD.ORD_FECHA_COLOCACION >=TRUNC(P_FECHA_1)
                                          AND ORD.ORD_FECHA_COLOCACION < TRUNC(P_FECHA_2) + 1)
        AND ORD.ORD_CONSECUTIVO NOT IN (SELECT POF.POF_ORD_CONSECUTIVO 
                                        FROM PREORDENES_FIX POF
                                         ,ORDENES_DIVISAS ORD
                                        WHERE POF.POF_ORD_CONSECUTIVO = ORD.ORD_CONSECUTIVO
                                        AND POF.POF_ORD_SUC_CODIGO = ORD.ORD_SUC_CODIGO
                                        AND POF.POF_EOF_CODIGO = 'COM')
        --VAGTUS049780.OperacionesSetFxFogafin
        AND NOT EXISTS 
          (SELECT 'X'
           FROM   PERSONAS_SET_FX PSF
           WHERE  PSF.PSF_OPERA_COMO_IMC IN ('IMC', 'IMR')
           AND    PSF.PSF_PER_TID_CODIGO = ORD_CLI_PER_TID_CODIGO
           AND    PSF.PSF_PER_NUM_IDEN = ORD_CLI_PER_NUM_IDEN)
     UNION ALL
     SELECT TO_DATE(POF.POF_FECHA_COLOCACION,'DD/MM/YYYY') FECHA
           ,ORD.ORD_VALOR_PESOS VALOR_PESOS
           ,ORD.ORD_VALOR_DOLARES VALOR_DOLAR
           ,NVL(POF.POF_DIAS_FIX,0) DIAS_NEXT_DAY
           ,ORD.ORD_TIPO_ORDEN TIPO_ORDEN
     FROM ORDENES_DIVISAS ORD,
         PREORDENES_FIX POF
     WHERE POF.POF_ORD_CONSECUTIVO = ORD.ORD_CONSECUTIVO 
       AND POF.POF_ORD_SUC_CODIGO  = ORD.ORD_SUC_CODIGO          
       AND ORD.ORD_TIPO_ORDEN IN ('C','V')
       AND ORD.ORD_EOF_CODIGO IN ('APR','APL')
       AND ORD.ORD_TMD_MNEMONICO NOT IN ('COCHN','VECHD','DXADR','CXADR','CTADR','ATADR')
       AND ORD.ORD_FECHA_COLOCACION >=  TRUNC(P_FECHA_1)
       AND ORD.ORD_FECHA_COLOCACION <   TRUNC(P_FECHA_2) + 1 
       AND POF.POF_FECHA_COLOCACION >=  TRUNC(P_FECHA_1)
       AND POF.POF_FECHA_COLOCACION <   TRUNC(P_FECHA_2) + 1
       AND ORD.ORD_CONSECUTIVO NOT IN (SELECT ORD.ORD_CONSECUTIVO
                                       FROM ORDENES_DIVISAS ORD
                                          ,DECLARACIONES_CAMBIO DCA
                                          ,FORMULARIOS_CINCO FCI
                                          ,DETALLE_OPERACIONES DEO
                                       WHERE DCA.DCA_ORD_CONSECUTIVO = ORD.ORD_CONSECUTIVO
                                         AND DCA.DCA_ORD_SUC_CODIGO = ORD.ORD_SUC_CODIGO
                                         AND DCA.DCA_NUMERO_DECLARACION = FCI.FOI_DCA_NUMERO_DECLARACION
                                         AND DEO.DEO_FOI_DCA_NUMERO_DECLARACION = FCI.FOI_DCA_NUMERO_DECLARACION
                                         AND DEO.DEO_CLN_NUM_NUMERO IN (1810,2910,8102,8106)
                                         AND ORD.ORD_TIPO_ORDEN IN ('C','V')
                                         AND ORD.ORD_EOF_CODIGO IN ('APR','APL')
                                         AND ORD.ORD_TMD_MNEMONICO NOT IN ('COCHN','VECHD')
                                         AND ORD.ORD_FECHA_COLOCACION >=TRUNC(P_FECHA_1)
                                         AND ORD.ORD_FECHA_COLOCACION < TRUNC(P_FECHA_2) + 1)
       --VAGTUS049780.OperacionesSetFxFogafin
       AND NOT EXISTS 
         (SELECT 'X'
          FROM   PERSONAS_SET_FX PSF
          WHERE  PSF.PSF_OPERA_COMO_IMC IN ('IMC', 'IMR')
          AND    PSF.PSF_PER_TID_CODIGO = ORD_CLI_PER_TID_CODIGO
          AND    PSF.PSF_PER_NUM_IDEN = ORD_CLI_PER_NUM_IDEN)
     ) GROUP BY TO_DATE(FECHA,'DD/MM/YYYY'), NVL(DIAS_NEXT_DAY,0), TIPO_ORDEN
      ORDER BY TO_DATE(FECHA,'DD/MM/YYYY');
  C_UND_CAPTURA_020 UND_CAPTURA_020%ROWTYPE;

  CURSOR UND_CAPTURA_025_055 IS
    SELECT TO_DATE(LSF_FECHA,'DD/MM/YYYY') FECHA
        ,TO_CHAR(SUM(ODC_VALOR_PESOS)/SUM(ODC_VALOR_DOLARES),'9999.99') TASA
        ,SUM (ODC_VALOR_DOLARES) VALOR_DOLARES
        ,DECODE(LSF_DIAS, NULL, 0, LSF_DIAS) DIAS_NEXT_DAY
        ,ODC_TIPO_ORDEN TIPO_ORDEN
        ,DECODE(PSF_TIPO_ENTIDAD,'1','025'
                              ,'2','030'
                              ,'4','035'
                              ,'3','040'
                              ,'29','045'
                              ,'85','050'
                              ,'22','055') TIPO_ENTIDAD
    FROM LIQUIDACIONES_SET_FX
        ,PERSONAS_SET_FX
        ,ORDENES_DIVISAS_PRECARGADAS
    WHERE ODC_TIPO_ORDEN IN ('C','V')
      AND LSF_CLI_PER_NUM_IDEN = PSF_PER_NUM_IDEN
      AND LSF_CLI_PER_TID_CODIGO = PSF_PER_TID_CODIGO
      AND ODC_LSF_CONSECUTIVO = LSF_CONSECUTIVO
      AND ODC_CLI_PER_NUM_IDEN = LSF_CLI_PER_NUM_IDEN
      AND ODC_CLI_PER_TID_CODIGO = LSF_CLI_PER_TID_CODIGO
      AND ODC_ESTADO <> 'ANU'      
      AND TRUNC(LSF_FECHA) >= TRUNC(P_FECHA_1)
      AND TRUNC(LSF_FECHA) <  TRUNC(P_FECHA_2 + 1)
    group by TO_DATE(LSF_FECHA,'DD/MM/YYYY'), DECODE(LSF_DIAS, NULL, 0, LSF_DIAS), ODC_TIPO_ORDEN, DECODE(PSF_TIPO_ENTIDAD,'1','025'
                              ,'2','030'
                              ,'4','035'
                              ,'3','040'
                              ,'29','045'
                              ,'85','050'
                              ,'22','055')
     ORDER BY TO_DATE(LSF_FECHA,'DD/MM/YYYY');
  C_UND_CAPTURA_025_055 UND_CAPTURA_025_055%ROWTYPE;

  CURSOR EXCLUIR_FORMULARIO_5 (P_NEXT_DAY NUMBER, P_TIPO_ORDEN VARCHAR2, P_FECHA DATE) IS
    SELECT SUM(ORD.ORD_VALOR_DOLARES-FCI.FOI_VALOR_TOTAL_USD)
    FROM ORDENES_DIVISAS ORD
        ,DECLARACIONES_CAMBIO DCA
        ,FORMULARIOS_CINCO FCI
        ,DETALLE_OPERACIONES DEO
    WHERE DCA.DCA_ORD_CONSECUTIVO = ORD.ORD_CONSECUTIVO
    AND DCA.DCA_ORD_SUC_CODIGO = ORD.ORD_SUC_CODIGO
    AND DCA.DCA_NUMERO_DECLARACION = FCI.FOI_DCA_NUMERO_DECLARACION
    AND DEO.DEO_FOI_DCA_NUMERO_DECLARACION = FCI.FOI_DCA_NUMERO_DECLARACION
    AND DEO.DEO_CLN_NUM_NUMERO IN (1810,2910,8102,8106)
    AND ORD.ORD_EOF_CODIGO IN ('APR','APL')
    AND ORD.ORD_TMD_MNEMONICO NOT IN ('COCHN','VECHD')
    AND ORD.ORD_DIAS_NEXT_DAY = P_NEXT_DAY
    AND ORD.ORD_TIPO_ORDEN = P_TIPO_ORDEN
    AND ORD.ORD_FECHA_COLOCACION >= TRUNC(P_FECHA)
    AND ORD.ORD_FECHA_COLOCACION < TRUNC(P_FECHA) + 1;

  V_FECHA       DATE;
  v_dia         VARCHAR2(2);
  V_UND_CAP     VARCHAR2(255);
  I             NUMBER := 0;
  v_100_01      NUMBER;
  v_registro    NUMBER;
  VALOR_EXCLUIR NUMBER := 0;
  v_numero_registro NUMBER := 0;

  error      EXCEPTION;
BEGIN
  ------------------------------------------- INICIO FORMATO 311
  --------------------------------------------- Und Captura 01 - LUNES -----------------------------------------------
  ----------------- subcuenta 010
  V_FECHA := P_FECHA_1;
  OPEN UND_CAPTURA_010;
  FETCH UND_CAPTURA_010 INTO C_UND_CAPTURA_010;
  WHILE UND_CAPTURA_010%FOUND LOOP
    /* DETERMINAR DIA DE LA SEMANAA
     EL ARCHIVO SE DEBE EJECUTAR LOS LUNES DE INICIO DE LA SEMANA
    1-DOMINGO, 2-LUNES, 3-MARTES, 4-MIÉRCOLES, 5-JUEVES, 6-VIERNES, 7-SÁBADO*/
    SELECT TO_CHAR(C_UND_CAPTURA_010.FECHA-1, 'D')
      INTO v_dia
    FROM DUAL;

    V_UND_CAP := '0'||v_dia;
    IF C_UND_CAPTURA_010.FECHA = V_FECHA THEN
      IF C_UND_CAPTURA_010.DIAS_NEXT_DAY = 0 THEN
        IF C_UND_CAPTURA_010.TIPO_ORDEN = 'C' THEN
          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => '010',
                                  P_T               => '0_C',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_010.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_010.VALOR_DOLARES,0));
          V_FECHA := P_FECHA_1-1;
          FETCH UND_CAPTURA_010 INTO C_UND_CAPTURA_010;
        ELSIF C_UND_CAPTURA_010.TIPO_ORDEN = 'V' THEN
          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => '010',
                                  P_T               => '0_V',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_010.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_010.VALOR_DOLARES,0));
          V_FECHA := P_FECHA_1-1;
          FETCH UND_CAPTURA_010 INTO C_UND_CAPTURA_010;
        END IF;
      ELSIF C_UND_CAPTURA_010.DIAS_NEXT_DAY = 1 THEN
        IF C_UND_CAPTURA_010.TIPO_ORDEN = 'C' THEN
          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => '010',
                                  P_T               => '1_C',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_010.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_010.VALOR_DOLARES,0));
          V_FECHA := P_FECHA_1-1;
          FETCH UND_CAPTURA_010 INTO C_UND_CAPTURA_010;
        ELSIF C_UND_CAPTURA_010.TIPO_ORDEN = 'V' THEN
          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => '010',
                                  P_T               => '1_V',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_010.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_010.VALOR_DOLARES,0));
          V_FECHA := P_FECHA_1-1;
          FETCH UND_CAPTURA_010 INTO C_UND_CAPTURA_010;
        END IF;
      ELSIF C_UND_CAPTURA_010.DIAS_NEXT_DAY = 2 THEN
        IF C_UND_CAPTURA_010.TIPO_ORDEN = 'C' THEN
          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => '010',
                                  P_T               => '2_C',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_010.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_010.VALOR_DOLARES,0));
          V_FECHA := P_FECHA_1-1;
          FETCH UND_CAPTURA_010 INTO C_UND_CAPTURA_010;
        ELSIF C_UND_CAPTURA_010.TIPO_ORDEN = 'V' THEN
          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => '010',
                                  P_T               => '2_V',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_010.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_010.VALOR_DOLARES,0));
          V_FECHA := P_FECHA_1-1;
          FETCH UND_CAPTURA_010 INTO C_UND_CAPTURA_010;
        END IF;
      ELSIF C_UND_CAPTURA_010.DIAS_NEXT_DAY = 3 THEN
        IF C_UND_CAPTURA_010.TIPO_ORDEN = 'C' THEN
          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => '010',
                                  P_T               => '3_C',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_010.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_010.VALOR_DOLARES,0));
          V_FECHA := P_FECHA_1-1;
          FETCH UND_CAPTURA_010 INTO C_UND_CAPTURA_010;
        ELSIF C_UND_CAPTURA_010.TIPO_ORDEN = 'V' THEN
          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => '010',
                                  P_T               => '3_V',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_010.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_010.VALOR_DOLARES,0));
          V_FECHA := P_FECHA_1-1;
          FETCH UND_CAPTURA_010 INTO C_UND_CAPTURA_010;
        END IF;
      END IF;
    END IF;
    V_FECHA := V_FECHA+1;
  END LOOP;
  CLOSE UND_CAPTURA_010;
  ----------------  subcuenta 015
  V_FECHA := P_FECHA_1;
  OPEN UND_CAPTURA_015;
  FETCH UND_CAPTURA_015 INTO C_UND_CAPTURA_015;
  WHILE UND_CAPTURA_015%FOUND LOOP
    /* DETERMINAR DIA DE LA SEMANAA
     EL ARCHIVO SE DEBE EJECUTAR LOS LUNES DE INICIO DE LA SEMANA
    1-DOMINGO, 2-LUNES, 3-MARTES, 4-MIÉRCOLES, 5-JUEVES, 6-VIERNES, 7-SÁBADO*/
    SELECT TO_CHAR(C_UND_CAPTURA_015.FECHA-1, 'D')
      INTO v_dia
    FROM DUAL;

    V_UND_CAP := '0'||v_dia;
    IF C_UND_CAPTURA_015.FECHA = V_FECHA THEN
      IF C_UND_CAPTURA_015.DIAS_NEXT_DAY = 0 THEN
        IF C_UND_CAPTURA_015.TIPO_ORDEN = 'C' THEN
          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => '015',
                                  P_T               => '0_C',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_015.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_015.VALOR_DOLARES,0));
          V_FECHA := P_FECHA_1-1;
          FETCH UND_CAPTURA_015 INTO C_UND_CAPTURA_015;
        ELSIF C_UND_CAPTURA_015.TIPO_ORDEN = 'V' THEN
          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => '015',
                                  P_T               => '0_V',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_015.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_015.VALOR_DOLARES,0));
          V_FECHA := P_FECHA_1-1;
          FETCH UND_CAPTURA_015 INTO C_UND_CAPTURA_015;
        END IF;
      ELSIF C_UND_CAPTURA_015.DIAS_NEXT_DAY = 1 THEN
        IF C_UND_CAPTURA_015.TIPO_ORDEN = 'C' THEN
          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => '015',
                                  P_T               => '1_C',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_015.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_015.VALOR_DOLARES,0));
          V_FECHA := P_FECHA_1-1;
          FETCH UND_CAPTURA_015 INTO C_UND_CAPTURA_015;
        ELSIF C_UND_CAPTURA_015.TIPO_ORDEN = 'V' THEN
          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => '015',
                                  P_T               => '1_V',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_015.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_015.VALOR_DOLARES,0));
          V_FECHA := P_FECHA_1-1;
          FETCH UND_CAPTURA_015 INTO C_UND_CAPTURA_015;
        END IF;
      ELSIF C_UND_CAPTURA_015.DIAS_NEXT_DAY = 2 THEN
        IF C_UND_CAPTURA_015.TIPO_ORDEN = 'C' THEN
          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => '015',
                                  P_T               => '2_C',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_015.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_015.VALOR_DOLARES,0));
          V_FECHA := P_FECHA_1-1;
          FETCH UND_CAPTURA_015 INTO C_UND_CAPTURA_015;
        ELSIF C_UND_CAPTURA_015.TIPO_ORDEN = 'V' THEN
          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => '015',
                                  P_T               => '2_V',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_015.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_015.VALOR_DOLARES,0));
          V_FECHA := P_FECHA_1-1;
          FETCH UND_CAPTURA_015 INTO C_UND_CAPTURA_015;
        END IF;
      ELSIF C_UND_CAPTURA_015.DIAS_NEXT_DAY = 3 THEN
        IF C_UND_CAPTURA_015.TIPO_ORDEN = 'C' THEN
          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => '015',
                                  P_T               => '3_C',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_015.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_015.VALOR_DOLARES,0));
          V_FECHA := P_FECHA_1-1;
          FETCH UND_CAPTURA_015 INTO C_UND_CAPTURA_015;
        ELSIF C_UND_CAPTURA_015.TIPO_ORDEN = 'V' THEN
          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => '015',
                                  P_T               => '3_V',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_015.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_015.VALOR_DOLARES,0));
          V_FECHA := P_FECHA_1-1;
          FETCH UND_CAPTURA_015 INTO C_UND_CAPTURA_015;
        END IF;
      END IF;
    END IF;
    V_FECHA := V_FECHA+1;
  END LOOP;
  CLOSE UND_CAPTURA_015;
  ----------------  subcuenta 020
  V_FECHA := P_FECHA_1;
  OPEN UND_CAPTURA_020;
  FETCH UND_CAPTURA_020 INTO C_UND_CAPTURA_020;
  WHILE UND_CAPTURA_020%FOUND LOOP
    /* DETERMINAR DIA DE LA SEMANAA
     EL ARCHIVO SE DEBE EJECUTAR LOS LUNES DE INICIO DE LA SEMANA
    1-DOMINGO, 2-LUNES, 3-MARTES, 4-MIÉRCOLES, 5-JUEVES, 6-VIERNES, 7-SÁBADO*/
    SELECT TO_CHAR(C_UND_CAPTURA_020.FECHA-1, 'D')
      INTO v_dia
    FROM DUAL;

    V_UND_CAP := '0'||v_dia;
    IF C_UND_CAPTURA_020.FECHA = V_FECHA THEN
      IF C_UND_CAPTURA_020.DIAS_NEXT_DAY = 0 THEN
        IF C_UND_CAPTURA_020.TIPO_ORDEN = 'C' THEN

          OPEN EXCLUIR_FORMULARIO_5(C_UND_CAPTURA_020.DIAS_NEXT_DAY, C_UND_CAPTURA_020.TIPO_ORDEN, C_UND_CAPTURA_020.FECHA);
          FETCH EXCLUIR_FORMULARIO_5 INTO VALOR_EXCLUIR;
          CLOSE EXCLUIR_FORMULARIO_5;
          VALOR_EXCLUIR := NVL(VALOR_EXCLUIR,0);

          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => '020',
                                  P_T               => '0_C',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_020.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_020.VALOR_DOLARES,0)+VALOR_EXCLUIR);
          V_FECHA := P_FECHA_1-1;
          FETCH UND_CAPTURA_020 INTO C_UND_CAPTURA_020;
        ELSIF C_UND_CAPTURA_020.TIPO_ORDEN = 'V' THEN

          OPEN EXCLUIR_FORMULARIO_5(C_UND_CAPTURA_020.DIAS_NEXT_DAY, C_UND_CAPTURA_020.TIPO_ORDEN, C_UND_CAPTURA_020.FECHA);
          FETCH EXCLUIR_FORMULARIO_5 INTO VALOR_EXCLUIR;
          CLOSE EXCLUIR_FORMULARIO_5;
          VALOR_EXCLUIR := NVL(VALOR_EXCLUIR,0);

          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => '020',
                                  P_T               => '0_V',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_020.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_020.VALOR_DOLARES,0)+VALOR_EXCLUIR);
          V_FECHA := P_FECHA_1-1;
          FETCH UND_CAPTURA_020 INTO C_UND_CAPTURA_020;
        END IF;
      ELSIF C_UND_CAPTURA_020.DIAS_NEXT_DAY = 1 THEN
        IF C_UND_CAPTURA_020.TIPO_ORDEN = 'C' THEN

          OPEN EXCLUIR_FORMULARIO_5(C_UND_CAPTURA_020.DIAS_NEXT_DAY, C_UND_CAPTURA_020.TIPO_ORDEN, C_UND_CAPTURA_020.FECHA);
          FETCH EXCLUIR_FORMULARIO_5 INTO VALOR_EXCLUIR;
          CLOSE EXCLUIR_FORMULARIO_5;
          VALOR_EXCLUIR := NVL(VALOR_EXCLUIR,0);

          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => '020',
                                  P_T               => '1_C',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_020.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_020.VALOR_DOLARES,0)+VALOR_EXCLUIR);
          V_FECHA := P_FECHA_1-1;
          FETCH UND_CAPTURA_020 INTO C_UND_CAPTURA_020;
        ELSIF C_UND_CAPTURA_020.TIPO_ORDEN = 'V' THEN

          OPEN EXCLUIR_FORMULARIO_5(C_UND_CAPTURA_020.DIAS_NEXT_DAY, C_UND_CAPTURA_020.TIPO_ORDEN, C_UND_CAPTURA_020.FECHA);
          FETCH EXCLUIR_FORMULARIO_5 INTO VALOR_EXCLUIR;
          CLOSE EXCLUIR_FORMULARIO_5;
          VALOR_EXCLUIR := NVL(VALOR_EXCLUIR,0);

          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => '020',
                                  P_T               => '1_V',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_020.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_020.VALOR_DOLARES,0)+VALOR_EXCLUIR);
          V_FECHA := P_FECHA_1-1;
          FETCH UND_CAPTURA_020 INTO C_UND_CAPTURA_020;
        END IF;
      ELSIF C_UND_CAPTURA_020.DIAS_NEXT_DAY = 2 THEN
        IF C_UND_CAPTURA_020.TIPO_ORDEN = 'C' THEN

          OPEN EXCLUIR_FORMULARIO_5(C_UND_CAPTURA_020.DIAS_NEXT_DAY, C_UND_CAPTURA_020.TIPO_ORDEN, C_UND_CAPTURA_020.FECHA);
          FETCH EXCLUIR_FORMULARIO_5 INTO VALOR_EXCLUIR;
          CLOSE EXCLUIR_FORMULARIO_5;
          VALOR_EXCLUIR := NVL(VALOR_EXCLUIR,0);

          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => '020',
                                  P_T               => '2_C',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_020.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_020.VALOR_DOLARES,0)+VALOR_EXCLUIR);
          V_FECHA := P_FECHA_1-1;
          FETCH UND_CAPTURA_020 INTO C_UND_CAPTURA_020;
        ELSIF C_UND_CAPTURA_020.TIPO_ORDEN = 'V' THEN

          OPEN EXCLUIR_FORMULARIO_5(C_UND_CAPTURA_020.DIAS_NEXT_DAY, C_UND_CAPTURA_020.TIPO_ORDEN, C_UND_CAPTURA_020.FECHA);
          FETCH EXCLUIR_FORMULARIO_5 INTO VALOR_EXCLUIR;
          CLOSE EXCLUIR_FORMULARIO_5;
          VALOR_EXCLUIR := NVL(VALOR_EXCLUIR,0);

          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => '020',
                                  P_T               => '2_V',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_020.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_020.VALOR_DOLARES,0)+VALOR_EXCLUIR);
          V_FECHA := P_FECHA_1-1;
          FETCH UND_CAPTURA_020 INTO C_UND_CAPTURA_020;
        END IF;
      ELSIF C_UND_CAPTURA_020.DIAS_NEXT_DAY = 3 THEN
        IF C_UND_CAPTURA_020.TIPO_ORDEN = 'C' THEN

          OPEN EXCLUIR_FORMULARIO_5(C_UND_CAPTURA_020.DIAS_NEXT_DAY, C_UND_CAPTURA_020.TIPO_ORDEN, C_UND_CAPTURA_020.FECHA);
          FETCH EXCLUIR_FORMULARIO_5 INTO VALOR_EXCLUIR;
          CLOSE EXCLUIR_FORMULARIO_5;
          VALOR_EXCLUIR := NVL(VALOR_EXCLUIR,0);

          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => '020',
                                  P_T               => '3_C',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_020.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_020.VALOR_DOLARES,0)+VALOR_EXCLUIR);
          V_FECHA := P_FECHA_1-1;
          FETCH UND_CAPTURA_020 INTO C_UND_CAPTURA_020;
        ELSIF C_UND_CAPTURA_020.TIPO_ORDEN = 'V' THEN

          OPEN EXCLUIR_FORMULARIO_5(C_UND_CAPTURA_020.DIAS_NEXT_DAY, C_UND_CAPTURA_020.TIPO_ORDEN, C_UND_CAPTURA_020.FECHA);
          FETCH EXCLUIR_FORMULARIO_5 INTO VALOR_EXCLUIR;
          CLOSE EXCLUIR_FORMULARIO_5;
          VALOR_EXCLUIR := NVL(VALOR_EXCLUIR,0);

          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => '020',
                                  P_T               => '3_V',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_020.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_020.VALOR_DOLARES,0)+VALOR_EXCLUIR);
          V_FECHA := P_FECHA_1-1;
          FETCH UND_CAPTURA_020 INTO C_UND_CAPTURA_020;
        END IF;
      END IF;
    END IF;
    V_FECHA := V_FECHA+1;
  END LOOP;
  CLOSE UND_CAPTURA_020;
  ----------------  subcuenta 025 a la 055
V_FECHA := P_FECHA_1;
  OPEN UND_CAPTURA_025_055;
  FETCH UND_CAPTURA_025_055 INTO C_UND_CAPTURA_025_055;
  WHILE UND_CAPTURA_025_055%FOUND LOOP
    /* DETERMINAR DIA DE LA SEMANAA
     EL ARCHIVO SE DEBE EJECUTAR LOS LUNES DE INICIO DE LA SEMANA
    1-DOMINGO, 2-LUNES, 3-MARTES, 4-MIÉRCOLES, 5-JUEVES, 6-VIERNES, 7-SÁBADO*/
    SELECT TO_CHAR(C_UND_CAPTURA_025_055.FECHA-1, 'D')
      INTO v_dia
    FROM DUAL;

    V_UND_CAP := '0'||v_dia;
    IF C_UND_CAPTURA_025_055.FECHA = V_FECHA THEN
      IF C_UND_CAPTURA_025_055.DIAS_NEXT_DAY = 0 THEN
        IF C_UND_CAPTURA_025_055.TIPO_ORDEN = 'C' THEN
          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => C_UND_CAPTURA_025_055.TIPO_ENTIDAD,
                                  P_T               => '0_C',
                                  P_VALOR_1         => nvl(C_UND_CAPTURA_025_055.TASA,0),
                                  P_VALOR_2         => nvl(C_UND_CAPTURA_025_055.VALOR_DOLARES,0));
          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => '100',
                                  P_T               => '0_C',
                                  P_VALOR_1         => nvl(C_UND_CAPTURA_025_055.TASA,0),
                                  P_VALOR_2         => nvl(C_UND_CAPTURA_025_055.VALOR_DOLARES,0));
          V_FECHA := P_FECHA_1-1;
          FETCH UND_CAPTURA_025_055 INTO C_UND_CAPTURA_025_055;
        ELSIF C_UND_CAPTURA_025_055.TIPO_ORDEN = 'V' THEN
          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => C_UND_CAPTURA_025_055.TIPO_ENTIDAD,
                                  P_T               => '0_V',
                                  P_VALOR_1         => nvl(C_UND_CAPTURA_025_055.TASA,0),
                                  P_VALOR_2         => nvl(C_UND_CAPTURA_025_055.VALOR_DOLARES,0));
          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => '100',
                                  P_T               => '0_V',
                                  P_VALOR_1         => nvl(C_UND_CAPTURA_025_055.TASA,0),
                                  P_VALOR_2         => nvl(C_UND_CAPTURA_025_055.VALOR_DOLARES,0));                        
          V_FECHA := P_FECHA_1-1;
          FETCH UND_CAPTURA_025_055 INTO C_UND_CAPTURA_025_055;
        END IF;
      ELSIF C_UND_CAPTURA_025_055.DIAS_NEXT_DAY = 1 THEN
        IF C_UND_CAPTURA_025_055.TIPO_ORDEN = 'C' THEN
          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => C_UND_CAPTURA_025_055.TIPO_ENTIDAD,
                                  P_T               => '1_C',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_025_055.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_025_055.VALOR_DOLARES,0));
          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => '100',
                                  P_T               => '1_C',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_025_055.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_025_055.VALOR_DOLARES,0));
          V_FECHA := P_FECHA_1-1;
          FETCH UND_CAPTURA_025_055 INTO C_UND_CAPTURA_025_055;
        ELSIF C_UND_CAPTURA_025_055.TIPO_ORDEN = 'V' THEN
          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => C_UND_CAPTURA_025_055.TIPO_ENTIDAD,
                                  P_T               => '1_V',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_025_055.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_025_055.VALOR_DOLARES,0));
          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => '100',
                                  P_T               => '1_V',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_025_055.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_025_055.VALOR_DOLARES,0));
          V_FECHA := P_FECHA_1-1;
          FETCH UND_CAPTURA_025_055 INTO C_UND_CAPTURA_025_055;
        END IF;
      ELSIF C_UND_CAPTURA_025_055.DIAS_NEXT_DAY = 2 THEN
        IF C_UND_CAPTURA_025_055.TIPO_ORDEN = 'C' THEN
          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => C_UND_CAPTURA_025_055.TIPO_ENTIDAD,
                                  P_T               => '2_C',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_025_055.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_025_055.VALOR_DOLARES,0));
          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => '100',
                                  P_T               => '2_C',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_025_055.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_025_055.VALOR_DOLARES,0));
          V_FECHA := P_FECHA_1-1;
          FETCH UND_CAPTURA_025_055 INTO C_UND_CAPTURA_025_055;
        ELSIF C_UND_CAPTURA_025_055.TIPO_ORDEN = 'V' THEN
          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => C_UND_CAPTURA_025_055.TIPO_ENTIDAD,
                                  P_T               => '2_V',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_025_055.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_025_055.VALOR_DOLARES,0));
          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => '100',
                                  P_T               => '2_V',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_025_055.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_025_055.VALOR_DOLARES,0));
          V_FECHA := P_FECHA_1-1;
          FETCH UND_CAPTURA_025_055 INTO C_UND_CAPTURA_025_055;
        END IF;
      ELSIF C_UND_CAPTURA_025_055.DIAS_NEXT_DAY = 3 THEN
        IF C_UND_CAPTURA_025_055.TIPO_ORDEN = 'C' THEN
          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => C_UND_CAPTURA_025_055.TIPO_ENTIDAD,
                                  P_T               => '3_C',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_025_055.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_025_055.VALOR_DOLARES,0));
          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => '100',
                                  P_T               => '3_C',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_025_055.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_025_055.VALOR_DOLARES,0));
          V_FECHA := P_FECHA_1-1;
          FETCH UND_CAPTURA_025_055 INTO C_UND_CAPTURA_025_055;
        ELSIF C_UND_CAPTURA_025_055.TIPO_ORDEN = 'V' THEN
          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => C_UND_CAPTURA_025_055.TIPO_ENTIDAD,
                                  P_T               => '3_V',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_025_055.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_025_055.VALOR_DOLARES,0));
          PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        => P_REGISTRO,
                                  P_UNIDAD_CAPTURA  => V_UND_CAP,
                                  P_SUBCUENTA       => '100',
                                  P_T               => '3_V',
                                  P_VALOR_1           => nvl(C_UND_CAPTURA_025_055.TASA,0),
                                  P_VALOR_2           => nvl(C_UND_CAPTURA_025_055.VALOR_DOLARES,0));
          V_FECHA := P_FECHA_1-1;
          FETCH UND_CAPTURA_025_055 INTO C_UND_CAPTURA_025_055;
        END IF;
      END IF;
    END IF;
    V_FECHA := V_FECHA+1;
  END LOOP;
  CLOSE UND_CAPTURA_025_055;

  --Calcula la tasa promedio ponderada
  IF P_REGISTRO.COUNT > 0 THEN
    FOR und_captura IN 1 .. 5 LOOP      
      FOR i IN P_REGISTRO.FIRST .. P_REGISTRO.LAST loop
        IF P_REGISTRO(i).unidad_captura = '0'||to_char(und_captura) THEN
          IF P_REGISTRO(i).subcuenta = '100' THEN
            IF P_REGISTRO(i).COM_TC_0 <> 0 THEN
              P_REGISTRO(i).COM_TC_0  := to_number(P_REGISTRO(i).COM_TC_0) / to_number(P_REGISTRO(i).COM_MON_0);             
            END IF;
            IF P_REGISTRO(i).VEN_TC_0 <> 0 THEN
              P_REGISTRO(i).VEN_TC_0  := P_REGISTRO(i).VEN_TC_0 / P_REGISTRO(i).VEN_MON_0 ;
            END IF;
            IF P_REGISTRO(i).COM_TC_1 <> 0 THEN
              P_REGISTRO(i).COM_TC_1  := P_REGISTRO(i).COM_TC_1 / P_REGISTRO(i).COM_MON_1 ;
            END IF;
            IF P_REGISTRO(i).VEN_TC_1 <> 0 THEN
              P_REGISTRO(i).VEN_TC_1  := P_REGISTRO(i).VEN_TC_1 / P_REGISTRO(i).VEN_MON_1 ;
            END IF;
            IF P_REGISTRO(i).COM_TC_2 <> 0 THEN
              P_REGISTRO(i).COM_TC_2  := P_REGISTRO(i).COM_TC_2 / P_REGISTRO(i).COM_MON_2 ;
            END IF;
            IF P_REGISTRO(i).VEN_TC_2 <> 0 THEN  
              P_REGISTRO(i).VEN_TC_2  := P_REGISTRO(i).VEN_TC_2 / P_REGISTRO(i).VEN_MON_2 ;
            END IF;
            IF P_REGISTRO(i).COM_TC_3 <> 0 THEN  
              P_REGISTRO(i).COM_TC_3  := P_REGISTRO(i).COM_TC_3 / P_REGISTRO(i).COM_MON_3 ;
            END IF;
            IF P_REGISTRO(i).VEN_TC_3 <> 0 THEN  
              P_REGISTRO(i).VEN_TC_3  := P_REGISTRO(i).VEN_TC_3 / P_REGISTRO(i).VEN_MON_3 ;
            END IF;  
          END IF;
        END IF;
      END LOOP;
    END LOOP;
  END IF;

EXCEPTION
    WHEN ERROR THEN
      RAISE_APPLICATION_ERROR(-20002,'Error ejecutando P_DIVISAS.P_MAIL_EXCEL_230 '||SQLERRM);
    WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20001,'Error ejecutando P_DIVISAS.P_MAIL_EXCEL_230 '||SQLERRM);
END PR_MAIL_EXCEL_311;

PROCEDURE PR_PLANTILLA_311(P_REGISTRO IN OUT T_REGISTRO_2) IS
  v_registro NUMBER := 0;
BEGIN
  /************** UC01**************/
  /* LLENADO DE REGISTRO CON PLANTILLA*/
  --------- UC01----------------
  v_registro := P_REGISTRO.COUNT();
  P_REGISTRO(v_registro).subcuenta          := 'LUNES';
  P_REGISTRO(v_registro).nombre             := '';
  P_REGISTRO(v_registro).COM_TC_0           := '';
  P_REGISTRO(v_registro).COM_MON_0          := '';
  P_REGISTRO(v_registro).VEN_TC_0           := '';
  P_REGISTRO(v_registro).VEN_MON_0          := '';
  P_REGISTRO(v_registro).COM_TC_1           := '';
  P_REGISTRO(v_registro).COM_MON_1          := '';
  P_REGISTRO(v_registro).VEN_TC_1           := '';
  P_REGISTRO(v_registro).VEN_MON_1          := '';
  P_REGISTRO(v_registro).COM_TC_2           := '';
  P_REGISTRO(v_registro).COM_MON_2          := '';
  P_REGISTRO(v_registro).VEN_TC_2           := '';
  P_REGISTRO(v_registro).VEN_MON_2          := '';
  P_REGISTRO(v_registro).COM_TC_3           := '';
  P_REGISTRO(v_registro).COM_MON_3          := '';
  P_REGISTRO(v_registro).VEN_TC_3           := '';
  P_REGISTRO(v_registro).VEN_MON_3          := '';
  P_REGISTRO(v_registro).unidad_captura     := '';
  v_registro := P_REGISTRO.COUNT();
  P_REGISTRO(v_registro).subcuenta          := 'OPERACIONES POR VENTANILLA (No implican Movimiento electrónico de Divisas)';--'OPERACIONES POR VENTANILLA';
  P_REGISTRO(v_registro).nombre             := '';
  P_REGISTRO(v_registro).COM_TC_0           := '';
  P_REGISTRO(v_registro).COM_MON_0          := '';
  P_REGISTRO(v_registro).VEN_TC_0           := '';
  P_REGISTRO(v_registro).VEN_MON_0          := '';
  P_REGISTRO(v_registro).COM_TC_1           := '';
  P_REGISTRO(v_registro).COM_MON_1          := '';
  P_REGISTRO(v_registro).VEN_TC_1           := '';
  P_REGISTRO(v_registro).VEN_MON_1          := '';
  P_REGISTRO(v_registro).COM_TC_2           := '';
  P_REGISTRO(v_registro).COM_MON_2          := '';
  P_REGISTRO(v_registro).VEN_TC_2           := '';
  P_REGISTRO(v_registro).VEN_MON_2          := '';
  P_REGISTRO(v_registro).COM_TC_3           := '';
  P_REGISTRO(v_registro).COM_MON_3          := '';
  P_REGISTRO(v_registro).VEN_TC_3           := '';
  P_REGISTRO(v_registro).VEN_MON_3          := '';
  P_REGISTRO(v_registro).unidad_captura     := '';
  v_registro := P_REGISTRO.COUNT();
  P_REGISTRO(v_registro).subcuenta          :='005';
  P_REGISTRO(v_registro).nombre             := 'EFECTIVO';
  P_REGISTRO(v_registro).COM_TC_0           := 0;
  P_REGISTRO(v_registro).COM_MON_0          := 0;
  P_REGISTRO(v_registro).VEN_TC_0           := 0;
  P_REGISTRO(v_registro).VEN_MON_0          := 0;
  P_REGISTRO(v_registro).COM_TC_1           := 0;
  P_REGISTRO(v_registro).COM_MON_1          := 0;
