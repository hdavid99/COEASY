          p_registro(v_registro).jueves             := r_registro(i).jueves;
          p_registro(v_registro).viernes            := r_registro(i).viernes;
          p_registro(v_registro).sabado             := r_registro(i).sabado;
          p_registro(v_registro).domingo            := r_registro(i).domingo;
          p_registro(v_registro).autoliquida        := r_registro(i).autoliquida;
          p_registro(v_registro).unidad_captura     := r_registro(i).unidad_captura;
        END LOOP;
      END IF;
    ELSE
