            TAE_DOMICILIO_TRES_ORDENANTE CIUDAD_COMPRA,
            TAE_DOMICILIO_TRES_ORDENANTE PAIS_COMPRA,
            TAE_DOMICILIO_CUATRO_ORDENA,
            TAE_CUENTA_ORDENANTE,
            TAE_NOMBRE_ORDENANTE,
            TAE_DOMICILIO_UNO_OTRO,
            TAE_DOMICILIO_DOS_OTRO,
            TAE_DOMICILIO_TRES_OTRO,
            TAE_DOMICILIO_CUATRO_OTRO,
            TAE_MONTO_ORIGINAL,
            TAE_MONEDA_ORIGINAL,
            TAE_MONTO_PAGO,
            TAE_MONEDA_PAGO,
            TAE_CUENTA_BANCO_ORIGINADOR,
            TAE_NOMBRE_DIREC_ORIGINADOR,
            TAE_DOMICILIO_UNO_COMPENSA,
            TAE_DOMICILIO_DOS_COMPENSA,
            TAE_DOMICILIO_TRES_COMPENSA,
            TAE_DOMICILIO_CUATRO_COMPENSA,
            TAE_IDENTIFICA_BANCO_COMPESA,
            TAE_TIPO_ID_NETTING,
            TAE_FECHA_CONTRATO,
            TAE_FECHA_VENCIMIENTO,
            TAE_MONTO_COMPRADO,
            TAE_MONEDA_COMPRADO,
            TAE_MONTO_VENDIO_BANCO,
            TAE_MENEDA_VENTA,
            TAE_TIPO_CAMBIO_VENTA,
            TAE_INSTRUCCION_REM_COMPRADOR,
            TAE_INSTRUCCION_REM_VENTA,
            TAE_RENOVACION,
            TAE_FECHA_INICIAL_CONTRATO,
            TAE_FECHA_FINAL_CONTRATO,
            TAE_DIAS_PREVIOS_NOTIFICA,
            TAE_TASA_INTERES,
            TAE_ESTADO_PAGO,
            TAE_ESTADO_REEMBOLSO,
            TAE_CONDICIONES_PAGO_INTERES,
            TAE_INDICADOR_REVOCACION,
            TAE_REFERENCIA_SOLICITANTES,
            TAE_TIPO_COSTO,
            TAE_MONTO_COMISION,
            TAE_MONEDAD_COMISION,
            TAE_REFERENCIA_SOLICITANTE,
            TAE_REFERENCIA_FACTURA_REMITE,
            TAE_REFERENCIA_RELACIONADA,
            TAE_FLOTACION_DIA_UNO,
            TAE_FLOTACION_DIA_DOS,
            TAE_FLOTACION_DIA_TRES,
            TAE_FLOTACION_DIA_CUATRO,
            TAE_FECHA_REAL_LIQUIDA,
            TAE_CODIGO_CORREDOR,
            TAE_INDICADOR_COMISIONES,
            TAE_FECHA_VALOR,
            TAE_NOMBRE_COMPANIA,
            TAE_FECHA_LIQUIDACION,
            TAE_CONTRAPARTE,
            TAE_AMORTIZADO_ACUMULATIVA,
            TAE_CANTIDAD_ACUMULATIVA,
            TAE_FACTOR_CORRIENTE,
            TAE_DESCRIPCION_CORRIENTE,
            TAE_TASA_DIVIDENDO,
            TAE_FECHA_AUTORIZACION,
            TAE_TASA_INTERES_IMPUESTOS,
            TAE_MONTO_IMPUESTOS,
            TAE_MONTO_IMPUESTOS_LOCALES,
            TAE_MONTO_NOMINAL,
            TAE_MONEDA_NOMINAL,
            TAE_NOMINADO,
            TAE_NETO_DIA_SIGUIENTE,
            TAE_NEMO_SEGUIRIDAD,
            TAE_NUMERO_SEGURIDAD,
            TAE_INDICADOR_IMPUESTO,
            TAE_INGRESO_PRINCIPAL,
            TAE_TIPO_VALOR,
            TAE_NUMERO_CONFIRMA_BURSATIL,
            TAE_CODIGO_IMPUESTO_USA,
            TAE_UNIDADES,
            TAE_FECHA_OPERACION,
            TAE_MONTO_IMPUESTO_RETENIDO,
            TAE_TASA_RETENCION_IMPOSITIVA,
            TAE_TIPO_TRANSACCION,
            TAE_PREFIJO_FONDO_COMUN,
            TAE_CUENTA_CUSTODIA,
            TAE_MONTO_CHEQUEQ,
            TAE_NUMERO_SERIE_CHEQUE,
            TAE_DUPLICADO,
            TAE_IDENTIFICACION_INS_REEM,
            TAE_NOMBRE_REEMBOLSO,
            TAE_DOMICILIO_UNO_REEMBOLSO,
            TAE_DOMICILIO_DOS_REEMBOLSO,
            TAE_DOMICILIO_TRES_REEMBOLSO,
            TAE_DOMICILIO_CUA_REEMBOLSO,
            TAE_MONTO_INIDICADOR_ORIGINAL,
            TAE_MONEDA_IND_ORIGINAL,
            TAE_TIPO_CAMBIO_INDI_ORIGINAL,
            TAE_MONTO_GASTOS_RECEPTEROS,
            TAE_MONEDA_GASTOS_RECEP,
            TAE_MONTO_GASTOS_REMITENTE,
            TAE_MONEDA_GASTOS_REMITEN,
            TAE_MONTO_GASTOS_REMI_1,
            TAE_MONEDA_GASTOS_REMI_1,
            TAE_MONTO_GASTOS_REMI_2,
            TAE_MONEDA_GASTOS_REMI_2,
            TAE_MONTO_GASTOS_REMI_3,
            TAE_MONEDA_GASTOS_REMI_3,
            TAE_MONTO_GASTOS_REMI_4,
            TAE_MONEDA_GASTOS_REMI_4,
            TAE_MONTO_GASTOS_REMI_5,
            TAE_MONEDA_GASTOS_REMI_5,
            TAE_MONTO_GASTOS_REMI_6,
            TAE_MONEDA_GASTOS_REMI_6,
            TAE_MONTO_GASTOS_REMI_7,
            TAE_MONEDA_GASTOS_REMI_7,
            TAE_MONTO_GASTOS_REMI_8,
            TAE_MONEDA_GASTOS_REMI_8,
            TAE_MONTO_GASTOS_REMI_9,
            TAE_MONEDA_GASTOS_REMI_9,
            TAE_NOM_BENE_REMITENTE,
            TAE_DIREC_BENE_REMITENTE,
            TAE_IDEN_COM_BANCARIA,
            TAE_CUENTA_COM_BANCARIA,
            TAE_CUENTA_COM_BANCARIA_1,
            TAE_CUENTA_COM_BANCARIA_2,
            TAE_NUM_CUENTA_BENEFICIARIO,
            TAE_DIREC_CUENTA_BENFICIARIO,
            TAE_DOIMCILIO_BENI_UNO,
            TAE_DOIMCILIO_BENI_DOS,              
            REPLACE(TRIM(TAE_DOIMCILIO_BENI_UNO)||' '||TRIM(TAE_DOIMCILIO_BENI_DOS),' ') CADENA_INICIAL_CIUDAD,
            TAE_DOIMCILIO_BENI_UNO CIUDAD_VENTA,              
            TAE_DOIMCILIO_BENI_UNO PAIS_VENTA, 
            TAE_DOIMCILIO_BENI_TRES,
            TAE_DOIMCILIO_BENI_CUATRO,
            TAE_IDEN_CUENTA_BAN_BENEFI,
            NVL(TAE_DIRECCION_BENEFICIARIO,'CITIBANK') TAE_DIRECCION_BENEFICIARIO,
            TAE_DOMICILIO_LINEA_1,
            TAE_DOMICILIO_LINEA_2,
            TAE_DOMICILIO_LINEA_3,
            TAE_DOMICILIO_LINEA_4,
            TAE_MONTO_GASTOS,
            TAE_MONEDA_GASTOS,
            TAE_CUENTA_GASTOS,
            TAE_NUMERO_CREDITOS,
            TAE_MONTO_TOTAL_CREDITO,
            TAE_NUMERO_DEBITOS,
            TAE_MONTO_TOTAL_DEBITO,
            TAE_NUMERO_CHEQUES,
            TAE_MONTO_CHQUE,
            TAE_MONTO_NETO,
            TAE_NOMBRE_BENEFICIARIO,
            TAE_CUENTA_ID_BENEFICIARIO,
            TAE_NOMBRE_BAN_BENEFICIARIO,
            TAE_NOMBRE_PARTE_SOLICITANTE,
            TAE_CUENTA_PARTE_SOLICITANTE,
            TAE_NOMBRE_BANCO_ORDENANTE,
            TAE_DETALLES_PAGO,
            TAE_INDICADOR_REFERENCIA,
            TAE_IDENTIFICADOR_RERENCIA,
            TAE_ORDIN_ID,
            TAE_ORDEN_IDEN_CUENTA,
            TAE_NOM_DIRECCION_UNO,
            TAE_DOMICILIO_ACREE_DOS,
            TAE_DOMICILIO_ACREE_TRES,
            TAE_DOMICILIO_ACREE_CUATRO,
            TAE_TIP_REF_ACREEDORES,
            TAE_REF_ACREEDOR,
            TAE_REF_REMITENTE,
            TAE_FECHA_PAGO,
            TAE_TIPO_REF_POR_REFERENCIA,
            TAE_DETALLES_PAGO_UNO,
            TAE_REMITENTE_FINAL,
            TAE_ID_REMITENTE_FINAL,
            TAE_ULTIMO_BENEFICIARIO,
            TAE_ID_ULTIMO_BENEFICIARIO,
            TAE_CODIGO_PROPOSIRO,
            TAE_PROPOSITO,
            TAE_CODIGO_NO_ACEPTADO,
            TAE_MOTIVO_NO_ACEPTADO,
            TAE_CODIGO_IMPUESTO,
            TAE_REQUISITO_ADICIONAL,
            TAE_COD_DETALLA_PAGO,
            TAE_NUM_CUENTA_BENEFI_PAGO,
            TAE_REFERENCIA_TIDE,
            TAE_NOMBRE_COD_BAN_BENE,
            TAE_COD_NOMBRE_SOLICITANTE,
            TAE_TASA_MERCADO,
            TAE_MARGEN,
            TAE_CAMISION_CAMBIO_DIVISA,
            TAE_MONEDA_CAMBIO_DIVISA,
            TAE_REF_RELACIONADA,
            TAE_NOMBRE_BENEFI_SOLIICTA,
            TAE_ID_CUENTA_BENEFICIARIO,
            TAE_BANCO_BENEFICIARIO,
            TAE_PARTE_NOMBRE_SOLICITANTE,
            TAE_PARTE_CUENTA_SOLICITANTE,
            TAE_BANCO_NOMBRE_ORDENANTE,
            TAE_PAGO_DETALLES_ORDENANTE,
            TAE_CODIGO_UIN_UIP,
            TAE_ID_MANDATARIO,
            TAE_IDENTIFICA_PLAN,
            TAE_FECHA_SOLICITUD_PAGO
    FROM TMP_CARGUES_BENEFICARIOS
    WHERE NVL(TAE_ESTADO_CARGUE,' ') NOT IN ('OK','VDE','VOM', 'PRO')
    ; 

  R_PERSONAS            C_PERSONAS%ROWTYPE; 
  C_RECIBO_CAJA         RECIBO_CAJA%ROWTYPE;  
  C_CARGUE_COM_1        CARGUE_COM_1%ROWTYPE;                        
  C_CARGUE             CARGUE%ROWTYPE;   
  C_REGISTROS          REGISTROS%ROWTYPE; 
  C_DECLARACION_UNO    DECLARACION_UNO%ROWTYPE;
  C_DECLARACION_DOS    DECLARACION_DOS%ROWTYPE;
  C_DECLARACION_TRES   DECLARACION_TRES%ROWTYPE;
  C_DECLARACION_CUATRO DECLARACION_CUATRO%ROWTYPE;
  C_DECLARACION_CINCO  DECLARACION_CINCO%ROWTYPE;
  C_ORDEN_DIV          ORDEN_DIV%ROWTYPE;
  C_CARGUE_COM         CARGUE_COM%ROWTYPE;
  C_CARGUE_COM_VAL     CARGUE_COM_VAL%ROWTYPE;
  V_DECLARACION        DECLARACIONES_CAMBIO%ROWTYPE;
  V_NUMERALES          CLASIFICACIONES_NUMERALES%ROWTYPE;
  V_BENEFICIARIOS      BENEFICIARIOS_FORMULARIO_UNO%ROWTYPE;
  V_VALOR              BENEFICIARIOS_FORMULARIO_UNO.BFU_VALOR%TYPE;
  V_REGISTRO           NUMBER;
  I_REG                NUMBER;
  V_POSICION           NUMBER(5);
  V_FORMULARIO         DECLARACIONES_CAMBIO.DCA_FORMULARIO%TYPE;
  V_ORDEN              VARCHAR2(4000);
  V_PAIS                VARCHAR2(5);
  V_CIUDAD              VARCHAR2(20);
  V_DATO                VARCHAR2(26);
  V_DIFERENCIA          NUMBER;
  V_BENEFICIARIOS_1     BENEFICIARIOS_FORMULARIO_UIAF%ROWTYPE;
  V_MONTO               NUMBER;    
  V_REFERENCIA          NUMBER;                        

BEGIN

   OPEN REGISTROS;
   FETCH REGISTROS INTO C_REGISTROS;
   WHILE REGISTROS%FOUND LOOP
      R_TYPE_DECLARACION.DELETE;
      R_TYPE_BENEFICIARIO.DELETE;
      V_DECLARACION := NULL;
      V_VALOR       := 0;

      V_ORDEN       := C_REGISTROS.ORDEN;

      C_ORDEN_DIV := NULL;
      OPEN ORDEN_DIV(P_ORD_CONSECUTIVO => C_REGISTROS.ORDEN,
                     P_ORD_SUC_CODIGO  => C_REGISTROS.SUCURSAL);
      FETCH ORDEN_DIV INTO C_ORDEN_DIV;
      CLOSE ORDEN_DIV;     

      /* OBTENER NUMERALES CAMBIARIOS POR FORMUARIO*/
      C_DECLARACION_UNO := NULL;
      V_DECLARACION     := NULL;
      V_NUMERALES       := NULL;
      OPEN DECLARACION_UNO(P_ORD_CONSECUTIVO => C_ORDEN_DIV.ORD_CONSECUTIVO,
                           P_ORD_SUC_CODIGO  => C_ORDEN_DIV.ORD_SUC_CODIGO) ;
      FETCH DECLARACION_UNO INTO C_DECLARACION_UNO;
      WHILE DECLARACION_UNO%FOUND LOOP

          V_DECLARACION.DCA_NUMERO_DECLARACION     := C_DECLARACION_UNO.DCA_NUMERO_DECLARACION;
          V_DECLARACION.DCA_FORMULARIO             := C_DECLARACION_UNO.DCA_FORMULARIO;          
          V_DECLARACION.DCA_ORD_CONSECUTIVO        := C_DECLARACION_UNO.DCA_ORD_CONSECUTIVO;
          V_DECLARACION.DCA_ORD_SUC_CODIGO         := C_DECLARACION_UNO.DCA_ORD_SUC_CODIGO;
          V_VALOR                                  := C_DECLARACION_UNO.FOU_VALOR_GIRO_UNO;

          IF C_DECLARACION_UNO.FOU_CLN_NUM_NUMERO IS NOT NULL THEN
             V_NUMERALES.CLN_TIPO_MOVIMIENTO          := C_DECLARACION_UNO.FOU_CLN_TIPO_MOVIMIENTO;
             V_NUMERALES.CLN_NUM_NUMERO               := C_DECLARACION_UNO.FOU_CLN_NUM_NUMERO;


             PR_ESCRIBE_TYPE_DECLARACION(P_TYPE_DECLARACION            => R_TYPE_DECLARACION,
                                        P_DECLARACIONES_CAMBIO        => V_DECLARACION,
                                        P_CLASIFICACIONES_NUMERALES   => V_NUMERALES,
                                        P_VALOR                       => V_VALOR ,
                                        P_VALOR_USD                   => C_DECLARACION_UNO.FOU_VALOR_USD_UNO,
                                        P_TIPO_CAMBIO                 => C_DECLARACION_UNO.FOU_TIPO_CAMBIO_USD);
          END IF;


          IF C_DECLARACION_UNO.FOU_CLN_NUM_NUMERO_TIENE IS NOT NULL THEN
             V_VALOR                                  := C_DECLARACION_UNO.FOU_VALOR_GIRO_DOS;
             V_NUMERALES.CLN_TIPO_MOVIMIENTO          := C_DECLARACION_UNO.FOU_CLN_TIPO_MOVIMIENTO_TIENE;
             V_NUMERALES.CLN_NUM_NUMERO               := C_DECLARACION_UNO.FOU_CLN_NUM_NUMERO_TIENE;

             PR_ESCRIBE_TYPE_DECLARACION(P_TYPE_DECLARACION            => R_TYPE_DECLARACION,
                                        P_DECLARACIONES_CAMBIO        => V_DECLARACION,
                                        P_CLASIFICACIONES_NUMERALES   => V_NUMERALES,
                                        P_VALOR                       => V_VALOR ,
                                        P_VALOR_USD                   => C_DECLARACION_UNO.FOU_VALOR_USD_DOS,
                                        P_TIPO_CAMBIO                 => C_DECLARACION_UNO.FOU_TIPO_CAMBIO_USD);
          END IF; 




          FETCH DECLARACION_UNO INTO C_DECLARACION_UNO;
      END LOOP;
      CLOSE DECLARACION_UNO;

      V_DECLARACION     := NULL;
      C_DECLARACION_DOS := NULL;
      V_NUMERALES       := NULL;
      V_VALOR           := 0;
      OPEN DECLARACION_DOS (P_ORD_CONSECUTIVO => C_ORDEN_DIV.ORD_CONSECUTIVO,
                           P_ORD_SUC_CODIGO  => C_ORDEN_DIV.ORD_SUC_CODIGO) ;

      FETCH DECLARACION_DOS INTO C_DECLARACION_DOS;
      WHILE DECLARACION_DOS%FOUND LOOP

         V_DECLARACION.DCA_NUMERO_DECLARACION     := C_DECLARACION_DOS.DCA_NUMERO_DECLARACION;
         V_DECLARACION.DCA_FORMULARIO             := C_DECLARACION_DOS.DCA_FORMULARIO;          
         V_DECLARACION.DCA_ORD_CONSECUTIVO        := C_DECLARACION_DOS.DCA_ORD_CONSECUTIVO;
         V_DECLARACION.DCA_ORD_SUC_CODIGO         := C_DECLARACION_DOS.DCA_ORD_SUC_CODIGO;
         V_NUMERALES.CLN_TIPO_MOVIMIENTO          := C_DECLARACION_DOS.EXD_CLN_TIPO_MOVIMIENTO;
         V_NUMERALES.CLN_NUM_NUMERO               := C_DECLARACION_DOS.EXD_CLN_NUM_NUMERO ;



         PR_ESCRIBE_TYPE_DECLARACION(P_TYPE_DECLARACION            => R_TYPE_DECLARACION,
                                    P_DECLARACIONES_CAMBIO        => V_DECLARACION,
                                    P_CLASIFICACIONES_NUMERALES   => V_NUMERALES,
                                    P_VALOR                       => C_DECLARACION_DOS.EXD_VALOR_REINTEGRO_USD ,
                                    P_VALOR_USD                   => C_DECLARACION_DOS.FOD_TOTAL_VALOR_FOB,
                                    P_TIPO_CAMBIO                 => C_DECLARACION_DOS.FOD_TIPO_CAMBIO_USD);


         FETCH DECLARACION_DOS INTO C_DECLARACION_DOS;
      END LOOP;
      CLOSE DECLARACION_DOS;


      V_DECLARACION      := NULL;
      C_DECLARACION_TRES := NULL;
      V_NUMERALES        := NULL;
      OPEN DECLARACION_TRES (P_ORD_CONSECUTIVO => C_ORDEN_DIV.ORD_CONSECUTIVO,
                             P_ORD_SUC_CODIGO  => C_ORDEN_DIV.ORD_SUC_CODIGO) ;

      FETCH DECLARACION_TRES INTO C_DECLARACION_TRES;
      WHILE DECLARACION_TRES%FOUND LOOP
         V_DECLARACION.DCA_NUMERO_DECLARACION     := C_DECLARACION_TRES.DCA_NUMERO_DECLARACION;
         V_DECLARACION.DCA_FORMULARIO             := C_DECLARACION_TRES.DCA_FORMULARIO;          
         V_DECLARACION.DCA_ORD_CONSECUTIVO        := C_DECLARACION_TRES.DCA_ORD_CONSECUTIVO;
         V_DECLARACION.DCA_ORD_SUC_CODIGO         := C_DECLARACION_TRES.DCA_ORD_SUC_CODIGO;
         V_NUMERALES.CLN_TIPO_MOVIMIENTO          := C_DECLARACION_TRES.NUL_CLN_TIPO_MOVIMIENTO;
         V_NUMERALES.CLN_NUM_NUMERO               := C_DECLARACION_TRES.NUL_CLN_NUM_NUMERO ;

         PR_ESCRIBE_TYPE_DECLARACION(P_TYPE_DECLARACION            => R_TYPE_DECLARACION,
                                    P_DECLARACIONES_CAMBIO        => V_DECLARACION,
                                    P_CLASIFICACIONES_NUMERALES   => V_NUMERALES,
                                    P_VALOR                       => C_DECLARACION_TRES.NUL_VALOR_MONEDA,
                                    P_VALOR_USD                   => C_DECLARACION_TRES.NUL_VALOR_USD,
                                    P_TIPO_CAMBIO                 => C_DECLARACION_TRES.FOT_TIPO_CAMBIO_A_USD);

         FETCH DECLARACION_TRES INTO C_DECLARACION_TRES;
      END LOOP;
      CLOSE DECLARACION_TRES;

      V_DECLARACION        := NULL;
      C_DECLARACION_CUATRO := NULL;
      V_NUMERALES          := NULL;
      OPEN DECLARACION_CUATRO (P_ORD_CONSECUTIVO => C_ORDEN_DIV.ORD_CONSECUTIVO,
                               P_ORD_SUC_CODIGO  => C_ORDEN_DIV.ORD_SUC_CODIGO) ;

      FETCH DECLARACION_CUATRO INTO C_DECLARACION_CUATRO;
      WHILE DECLARACION_CUATRO%FOUND LOOP
         V_DECLARACION.DCA_NUMERO_DECLARACION     := C_DECLARACION_CUATRO.DCA_NUMERO_DECLARACION;
         V_DECLARACION.DCA_FORMULARIO             := C_DECLARACION_CUATRO.DCA_FORMULARIO;          
         V_DECLARACION.DCA_ORD_CONSECUTIVO        := C_DECLARACION_CUATRO.DCA_ORD_CONSECUTIVO;
         V_DECLARACION.DCA_ORD_SUC_CODIGO         := C_DECLARACION_CUATRO.DCA_ORD_SUC_CODIGO;
         V_NUMERALES.CLN_TIPO_MOVIMIENTO          := C_DECLARACION_CUATRO.FOC_CLN_TIPO_MOVIMIENTO;
         V_NUMERALES.CLN_NUM_NUMERO               := C_DECLARACION_CUATRO.FOC_CLN_NUM_NUMERO ;
         PR_ESCRIBE_TYPE_DECLARACION(P_TYPE_DECLARACION            => R_TYPE_DECLARACION,
                                    P_DECLARACIONES_CAMBIO        => V_DECLARACION,
                                    P_CLASIFICACIONES_NUMERALES   => V_NUMERALES,
                                    P_VALOR                       => C_DECLARACION_CUATRO.FOC_VALOR_GIRO_REINTEGRO,
                                    P_VALOR_USD                   => C_DECLARACION_CUATRO.FOC_VALOR_USD,
                                    P_TIPO_CAMBIO                 => C_DECLARACION_CUATRO.FOC_TIPO_CAMBIO_USD);



         FETCH DECLARACION_CUATRO INTO C_DECLARACION_CUATRO;
      END LOOP;
      CLOSE DECLARACION_CUATRO;

      V_DECLARACION        := NULL;
      C_DECLARACION_CINCO  := NULL;
      V_NUMERALES          := NULL;
      OPEN DECLARACION_CINCO (P_ORD_CONSECUTIVO  => C_ORDEN_DIV.ORD_CONSECUTIVO,
                               P_ORD_SUC_CODIGO  => C_ORDEN_DIV.ORD_SUC_CODIGO) ;

      FETCH DECLARACION_CINCO INTO C_DECLARACION_CINCO;
      WHILE DECLARACION_CINCO%FOUND LOOP
         V_DECLARACION.DCA_NUMERO_DECLARACION     := C_DECLARACION_CINCO.DCA_NUMERO_DECLARACION;
         V_DECLARACION.DCA_FORMULARIO             := C_DECLARACION_CINCO.DCA_FORMULARIO;          
         V_DECLARACION.DCA_ORD_CONSECUTIVO        := C_DECLARACION_CINCO.DCA_ORD_CONSECUTIVO;
         V_DECLARACION.DCA_ORD_SUC_CODIGO         := C_DECLARACION_CINCO.DCA_ORD_SUC_CODIGO;
         V_NUMERALES.CLN_TIPO_MOVIMIENTO          := C_DECLARACION_CINCO.DEO_CLN_TIPO_MOVIMIENTO;
         V_NUMERALES.CLN_NUM_NUMERO               := C_DECLARACION_CINCO.DEO_CLN_NUM_NUMERO ;




         PR_ESCRIBE_TYPE_DECLARACION(P_TYPE_DECLARACION            => R_TYPE_DECLARACION,
                                    P_DECLARACIONES_CAMBIO        => V_DECLARACION,
                                    P_CLASIFICACIONES_NUMERALES   => V_NUMERALES,
                                    P_VALOR                       => C_DECLARACION_CINCO.DEO_VALOR_USD,
                                    P_VALOR_USD                   => C_DECLARACION_CINCO.DEO_VALOR_USD,
                                    P_TIPO_CAMBIO                 => C_DECLARACION_CINCO.FOI_TIPO_CAMBIO_USD);

         FETCH DECLARACION_CINCO INTO C_DECLARACION_CINCO;
      END LOOP;
      CLOSE DECLARACION_CINCO;

      C_CARGUE := NULL;
      OPEN CARGUE(P_ORDEN => C_REGISTROS.ORDEN,P_SUCURSAL => C_REGISTROS.SUCURSAL);
      FETCH CARGUE INTO C_CARGUE;
      WHILE CARGUE%FOUND LOOP
         PR_ESCRIBE_TYPE_BENEFICIARIO(P_TYPE_BENEFICIARIO     => R_TYPE_BENEFICIARIO,
                                      P_TAE_CONSECUTIVO      => C_CARGUE.TAE_CONSECUTIVO,
                                      P_ORD_SUC_CODIGO       => C_ORDEN_DIV.ORD_SUC_CODIGO,
                                      P_ORD_CONSECUTIVO      => C_ORDEN_DIV.ORD_CONSECUTIVO);

         FETCH CARGUE INTO C_CARGUE;
      END LOOP;
      CLOSE CARGUE;

      /* TODOS LOS NUMERALES SE COMPLEMENTA CON EL REGISTRO DEL BENEFICIARIO POR TENER UN SOLO BENEFICIARIO*/
      C_CARGUE_COM := NULL;
      IF R_TYPE_BENEFICIARIO.COUNT() = 1 AND R_TYPE_DECLARACION.COUNT() = 1  THEN

         V_BENEFICIARIOS                          := NULL;         
         V_BENEFICIARIOS.BFU_TERMINAL_COMPLEMENTA := P_TERMINAL_COMPLEMENTA;
         V_BENEFICIARIOS.BFU_USUARIO_COMPLEMENTA  := P_USUARIO_COMPLEMENTA;
         V_BENEFICIARIOS.BFU_FECHA_COMPLEMENTA    := P_FECHA_COMPLEMENTA;
         V_BENEFICIARIOS.BFU_BEX_MNEMONICO        := P_BEX_MNEMONICO;         

         OPEN CARGUE_COM(P_TAE_CONSECUTIVO => R_TYPE_BENEFICIARIO(0).TAE_CONSECUTIVO);
         FETCH CARGUE_COM INTO C_CARGUE_COM;
         CLOSE CARGUE_COM;                                                                                   

        FOR I IN R_TYPE_DECLARACION.FIRST .. R_TYPE_DECLARACION.LAST  LOOP
          V_BENEFICIARIOS.BFU_FOU_DCA_NUMERO_DECLARACION := R_TYPE_DECLARACION(I).DCA_NUMERO_DECLARACION;
          V_BENEFICIARIOS.BFU_VALOR                      := C_CARGUE_COM.MONTO_TRANSACCION;
          V_BENEFICIARIOS.BFU_CLN_TIPO_MOVIMIENTO        := R_TYPE_DECLARACION(I).CLN_TIPO_MOVIMIENTO;
          V_BENEFICIARIOS.BFU_CLN_NUM_NUMERO             := R_TYPE_DECLARACION(I).CLN_NUM_NUMERO;
          V_BENEFICIARIOS.BFU_PRIMER_APELLIDO            := NULL;--REPLACE(RPAD(' ', 40, '*'), '*', ' ');
          V_BENEFICIARIOS.BFU_SEGUNDO_APELLIDO           := NULL;--REPLACE(RPAD(' ', 40, '*'), '*', ' ');
          V_BENEFICIARIOS.BFU_NOMBRE                     := NULL;--REPLACE(RPAD(' ', 40, '*'), '*', ' ');
          V_BENEFICIARIOS.BFU_OTROS_NOMBRE               := NULL;--REPLACE(RPAD(' ', 40, '*'), '*', ' ');               
          V_BENEFICIARIOS.BFU_TIPO_CAMBIO                := R_TYPE_DECLARACION(I).TIPO_CAMBIO;

          IF R_TYPE_DECLARACION(I).TIPO_CAMBIO != 1 THEN
            V_BENEFICIARIOS.BFU_VALOR_USD                := ROUND(C_CARGUE_COM.MONTO_TRANSACCION/R_TYPE_DECLARACION(I).TIPO_CAMBIO,2);
          ELSE
            V_BENEFICIARIOS.BFU_VALOR_USD                := C_CARGUE_COM.MONTO_TRANSACCION;
          END IF;                  


          IF C_ORDEN_DIV.ORD_TIPO_ORDEN = 'C' THEN
            V_BENEFICIARIOS.BFU_RAZON_SOCIAL             :=  RPAD(TRIM(C_CARGUE_COM.TAE_NOMBRE_ORDENANTE), 60, ' '); 
            V_BENEFICIARIOS.BFU_NUMERO_CUENTA_ENTIDAD    := C_CARGUE_COM.TAE_CUENTA_ORDENANTE;
          END IF;

          IF C_ORDEN_DIV.ORD_TIPO_ORDEN = 'V' THEN               
            V_BENEFICIARIOS.BFU_RAZON_SOCIAL             :=  RPAD(TRIM(C_CARGUE_COM.TAE_DIREC_CUENTA_BENFICIARIO), 60, ' ');            
            V_BENEFICIARIOS.BFU_NUMERO_CUENTA_ENTIDAD   := C_CARGUE_COM.TAE_NUM_CUENTA_BENEFICIARIO;            
          END IF;

          V_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA       := C_CARGUE_COM.TAE_NUMERO_CUENTA;
          --
          V_BENEFICIARIOS.BFU_ENTIDAD_ENVIA_RECIBE    := C_CARGUE_COM.TAE_NOMBRE_BANCO;

          V_DATO    := NULL;
          V_PAIS    := NULL;          
          V_CIUDAD  := NULL;
          V_DATO := FN_CIUDAD_PAISES(REPLACE (C_CARGUE_COM.TAE_NOMBRE_SUCURSAL, 'LONDON', 'LONDRES'));

          IF V_DATO IS NOT NULL THEN
            V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
            V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1); 
          END IF;

          V_BENEFICIARIOS.BFU_PAI_CODIGO_ENV_REC      := V_PAIS;
              V_BENEFICIARIOS_1.BFA_PAI_CODIGO_ENV_REC      := V_PAIS;

          V_BENEFICIARIOS.BFU_CIUDAD_ENVIA_RECIBE     := V_CIUDAD;
          V_MONTO := TO_NUMBER(TRIM(C_CARGUE_COM.TAE_MONTO_TRANSACCION),'999,999,999,999,999.00');
          IF V_MONTO > 0 THEN
            V_BENEFICIARIOS.BFU_INTERMEDIARO_ENV_REC    := C_CARGUE_COM.TAE_DIRECCION_BANCO_CORRES;
            V_BENEFICIARIOS.BFU_ENTIDAD                 := C_CARGUE_COM.TAE_DIRECCION_SOLICITANTE;

            V_DATO    := NULL;
            V_PAIS    := NULL;
            V_CIUDAD  := NULL;
            V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_CUATRO_INTER);

            IF V_DATO IS NOT NULL THEN
              V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
              V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
            ELSE
              V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_TRES_INTER);            
              IF V_DATO IS NOT NULL THEN
                V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
              ELSE
                V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_DOS_INTER);           
                IF V_DATO IS NOT NULL THEN
                  V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                  V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                ELSE
                  V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_UNO_INTER);           
                  IF V_DATO IS NOT NULL THEN
                    V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                    V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                  END IF;
                END IF;
              END IF;
            END IF;           

            V_BENEFICIARIOS.BFU_PAI_COD_INT_ENV_REC     := V_PAIS;

            V_BENEFICIARIOS.BFU_CIUDAD_INT_ENVIA_RECIBE := V_CIUDAD;

            V_DATO    := NULL;
            V_PAIS    := NULL;
            V_CIUDAD  := NULL;
            V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_CUATRO_ORDENA);
            --V_DATO := FN_CIUDAD_PAISES(REPLACE (C_CARGUE_COM.TAE_NOMBRE_SUCURSAL, 'LONDON', 'LONDRES'));

            IF V_DATO IS NOT NULL THEN
              V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
              V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
            ELSE
              V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_TRES_ORDENANTE);            
              IF V_DATO IS NOT NULL THEN
                V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
              ELSE
                V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_DOS_ORDENANTE);           
                IF V_DATO IS NOT NULL THEN
                  V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                  V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                ELSE
                  V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_UNO_ORDENANTE);           
                  IF V_DATO IS NOT NULL THEN
                    V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                    V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                  END IF;
                END IF;
              END IF;
            END IF;

            V_BENEFICIARIOS.BFU_PAI_CODIGO            := V_PAIS;    

            V_BENEFICIARIOS.BFU_CIUDAD_ORIGEN_DESTINO := V_CIUDAD;    

          ELSIF V_MONTO < 0 THEN
            V_BENEFICIARIOS.BFU_INTERMEDIARO_ENV_REC    := C_CARGUE_COM.TAE_NOMBRE_DIRECCION_INTER;
            V_BENEFICIARIOS.BFU_ENTIDAD                 := C_CARGUE_COM.TAE_DIRECCION_BENEFICIARIO;

            V_DATO    := NULL;
            V_PAIS    := NULL;
            V_CIUDAD  := NULL;
            V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_CUATRO_CORRESPON);

            IF V_DATO IS NOT NULL THEN
              V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
              V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
            ELSE
              V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_TRES_CORRES);           
              IF V_DATO IS NOT NULL THEN
                V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
              ELSE
                V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_DOS_CORRESPONSAL);            
                IF V_DATO IS NOT NULL THEN
                  V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                  V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                ELSE
                  V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_UNO_CORRESPONSAL);            
                  IF V_DATO IS NOT NULL THEN
                    V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                    V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                  END IF;
                END IF;
              END IF;
            END IF;

            V_BENEFICIARIOS.BFU_PAI_COD_INT_ENV_REC     := V_PAIS;

            V_BENEFICIARIOS.BFU_CIUDAD_INT_ENVIA_RECIBE := V_CIUDAD;

            V_DATO    := NULL;
            V_PAIS    := NULL;
            V_CIUDAD  := NULL;
            V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_LINEA_4);

            IF V_DATO IS NOT NULL THEN
              V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
              V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
            ELSE
              V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_LINEA_3);           
              IF V_DATO IS NOT NULL THEN
                V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
              ELSE
                V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_LINEA_2);           
                IF V_DATO IS NOT NULL THEN
                  V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                  V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                ELSE
                  V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_LINEA_1);           
                  IF V_DATO IS NOT NULL THEN
                    V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                    V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                  END IF;
                END IF;
              END IF;
            END IF;                                                     

            V_BENEFICIARIOS.BFU_PAI_CODIGO            := V_PAIS;    

            V_BENEFICIARIOS.BFU_CIUDAD_ORIGEN_DESTINO := V_CIUDAD;

          END IF; 
          --

          DBMS_OUTPUT.PUT_LINE('ANTE DE PR_CREAR_BENEFICIARIOS '||V_BENEFICIARIOS.BFU_FOU_DCA_NUMERO_DECLARACION);
          V_FORMULARIO := R_TYPE_DECLARACION(I).FORMULARIO;

          PR_CREAR_BENEFICIARIOS(P_FORMULARIO        => R_TYPE_DECLARACION(I).FORMULARIO,
                                P_BENEFICIARIOS     => V_BENEFICIARIOS);      
          DBMS_OUTPUT.PUT_LINE('DESPUES DE PR_CREAR_BENEFICIARIOS '||V_BENEFICIARIOS.BFU_FOU_DCA_NUMERO_DECLARACION);                      
        END LOOP;

        /* ACTUALIZAR ESTADO DE LA TABLA DE CARGUE'*/
        BEGIN
         P_DIVISAS.PR_ACTUALIZAR_ESTADO(P_CONSECUTIVO   =>  R_TYPE_BENEFICIARIO(0).TAE_CONSECUTIVO,
                                        P_ESTADO        => 'PRO',
                                        P_OBSERVACIONES => 'REGISTRO PROCESADO');
        END;  
      END IF;


      /* UN UNIC BENEFICIARIO SE COMPLEMENTA CON TODAS LAS DECLARACIONES*/ 
      C_CARGUE_COM := NULL;
      IF R_TYPE_BENEFICIARIO.COUNT() = 1 AND R_TYPE_DECLARACION.COUNT() >= 2  THEN

        OPEN CARGUE_COM(P_TAE_CONSECUTIVO => R_TYPE_BENEFICIARIO(0).TAE_CONSECUTIVO);
        FETCH CARGUE_COM INTO C_CARGUE_COM;
        CLOSE CARGUE_COM;                                                                              

        FOR I IN R_TYPE_DECLARACION.FIRST .. R_TYPE_DECLARACION.LAST  LOOP

          V_BENEFICIARIOS                                := NULL;         
          V_BENEFICIARIOS.BFU_TERMINAL_COMPLEMENTA       := P_TERMINAL_COMPLEMENTA;
          V_BENEFICIARIOS.BFU_USUARIO_COMPLEMENTA        := P_USUARIO_COMPLEMENTA;
          V_BENEFICIARIOS.BFU_FECHA_COMPLEMENTA          := P_FECHA_COMPLEMENTA;
          V_BENEFICIARIOS.BFU_BEX_MNEMONICO              := P_BEX_MNEMONICO;    
          V_BENEFICIARIOS.BFU_FOU_DCA_NUMERO_DECLARACION := R_TYPE_DECLARACION(I).DCA_NUMERO_DECLARACION;
          V_BENEFICIARIOS.BFU_VALOR                      := R_TYPE_DECLARACION(I).VALOR;
          V_BENEFICIARIOS.BFU_CLN_TIPO_MOVIMIENTO        := R_TYPE_DECLARACION(I).CLN_TIPO_MOVIMIENTO;
          V_BENEFICIARIOS.BFU_CLN_NUM_NUMERO             := R_TYPE_DECLARACION(I).CLN_NUM_NUMERO;
          V_BENEFICIARIOS.BFU_PRIMER_APELLIDO            := NULL;--REPLACE(RPAD(' ', 40, '*'), '*', ' ');
          V_BENEFICIARIOS.BFU_SEGUNDO_APELLIDO           := NULL;--REPLACE(RPAD(' ', 40, '*'), '*', ' ');
          V_BENEFICIARIOS.BFU_NOMBRE                     := NULL;--REPLACE(RPAD(' ', 40, '*'), '*', ' ');
          V_BENEFICIARIOS.BFU_OTROS_NOMBRE               := NULL;--REPLACE(RPAD(' ', 40, '*'), '*', ' ');               
          V_BENEFICIARIOS.BFU_TIPO_CAMBIO                := R_TYPE_DECLARACION(I).TIPO_CAMBIO;

          IF R_TYPE_DECLARACION(I).TIPO_CAMBIO != 1 THEN
            V_BENEFICIARIOS.BFU_VALOR_USD                  := ROUND(R_TYPE_DECLARACION(I).VALOR/R_TYPE_DECLARACION(I).TIPO_CAMBIO,2);
          ELSE
            V_BENEFICIARIOS.BFU_VALOR_USD                  := R_TYPE_DECLARACION(I).VALOR;
          END IF;               



          IF C_ORDEN_DIV.ORD_TIPO_ORDEN = 'C' THEN
            V_BENEFICIARIOS.BFU_RAZON_SOCIAL            :=  RPAD(TRIM(C_CARGUE_COM.TAE_NOMBRE_ORDENANTE), 60, ' '); 




            V_BENEFICIARIOS.BFU_NUMERO_CUENTA_ENTIDAD   := C_CARGUE_COM.TAE_CUENTA_ORDENANTE  ;


          END IF;

          IF C_ORDEN_DIV.ORD_TIPO_ORDEN = 'V' THEN               
            V_BENEFICIARIOS.BFU_RAZON_SOCIAL            :=  RPAD(TRIM(C_CARGUE_COM.TAE_DIREC_CUENTA_BENFICIARIO), 60, ' ');           


            V_BENEFICIARIOS.BFU_CIUDAD_ORIGEN_DESTINO   := C_CARGUE_COM.CIUDAD_VENTA;
            V_BENEFICIARIOS.BFU_NUMERO_CUENTA_ENTIDAD   := C_CARGUE_COM.TAE_NUM_CUENTA_BENEFICIARIO;
          END IF;

          V_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA       := C_CARGUE_COM.TAE_NUMERO_CUENTA;
          --
          V_BENEFICIARIOS.BFU_ENTIDAD_ENVIA_RECIBE    := C_CARGUE_COM.TAE_NOMBRE_BANCO;

          V_DATO    := NULL;
          V_PAIS    := NULL;          
          V_CIUDAD  := NULL;
          V_DATO := FN_CIUDAD_PAISES(REPLACE (C_CARGUE_COM.TAE_NOMBRE_SUCURSAL, 'LONDON', 'LONDRES'));

          IF V_DATO IS NOT NULL THEN
            V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
            V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1); 
          END IF;

          V_BENEFICIARIOS.BFU_PAI_CODIGO_ENV_REC      := V_PAIS;
          V_BENEFICIARIOS.BFU_CIUDAD_ENVIA_RECIBE     := V_CIUDAD;
          V_MONTO := TO_NUMBER(TRIM(C_CARGUE_COM.TAE_MONTO_TRANSACCION),'999,999,999,999,999.00');
          IF V_MONTO > 0 THEN
            V_BENEFICIARIOS.BFU_INTERMEDIARO_ENV_REC    := C_CARGUE_COM.TAE_DIRECCION_BANCO_CORRES;
            V_BENEFICIARIOS.BFU_ENTIDAD                 := C_CARGUE_COM.TAE_DIRECCION_SOLICITANTE;

            V_DATO    := NULL;
            V_PAIS    := NULL;
            V_CIUDAD  := NULL;
            V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_CUATRO_INTER);

            IF V_DATO IS NOT NULL THEN
              V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
              V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
            ELSE
              V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_TRES_INTER);            
              IF V_DATO IS NOT NULL THEN
                V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
              ELSE
                V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_DOS_INTER);           
                IF V_DATO IS NOT NULL THEN
                  V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                  V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                ELSE
                  V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_UNO_INTER);           
                  IF V_DATO IS NOT NULL THEN
                    V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                    V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                  END IF;
                END IF;
              END IF;
            END IF;           

            V_BENEFICIARIOS.BFU_PAI_COD_INT_ENV_REC     := V_PAIS;

            V_BENEFICIARIOS.BFU_CIUDAD_INT_ENVIA_RECIBE := V_CIUDAD;

            V_DATO    := NULL;
            V_PAIS    := NULL;
            V_CIUDAD  := NULL;
            V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_CUATRO_ORDENA);

            IF V_DATO IS NOT NULL THEN
              V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
              V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
            ELSE
              V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_TRES_ORDENANTE);            
              IF V_DATO IS NOT NULL THEN
                V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
              ELSE
                V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_DOS_ORDENANTE);           
                IF V_DATO IS NOT NULL THEN
                  V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                  V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                ELSE
                  V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_UNO_ORDENANTE);           
                  IF V_DATO IS NOT NULL THEN
                    V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                    V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                  END IF;
                END IF;
              END IF;
            END IF;

            V_BENEFICIARIOS.BFU_PAI_CODIGO            := V_PAIS;    

            V_BENEFICIARIOS.BFU_CIUDAD_ORIGEN_DESTINO := V_CIUDAD;    

          ELSIF V_MONTO < 0 THEN
            V_BENEFICIARIOS.BFU_INTERMEDIARO_ENV_REC    := C_CARGUE_COM.TAE_NOMBRE_DIRECCION_INTER;
            V_BENEFICIARIOS.BFU_ENTIDAD                 := C_CARGUE_COM.TAE_DIRECCION_BENEFICIARIO;

            V_DATO    := NULL;
            V_PAIS    := NULL;
            V_CIUDAD  := NULL;
            V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_CUATRO_CORRESPON);

            IF V_DATO IS NOT NULL THEN
              V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
              V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
            ELSE
              V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_TRES_CORRES);           
              IF V_DATO IS NOT NULL THEN
                V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
              ELSE
                V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_DOS_CORRESPONSAL);            
                IF V_DATO IS NOT NULL THEN
                  V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                  V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                ELSE
                  V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_UNO_CORRESPONSAL);            
                  IF V_DATO IS NOT NULL THEN
                    V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                    V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                  END IF;
                END IF;
              END IF;
            END IF;

            V_BENEFICIARIOS.BFU_PAI_COD_INT_ENV_REC     := V_PAIS;

            V_BENEFICIARIOS.BFU_CIUDAD_INT_ENVIA_RECIBE := V_CIUDAD;

            V_DATO    := NULL;
            V_PAIS    := NULL;
            V_CIUDAD  := NULL;
            V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_LINEA_4);

            IF V_DATO IS NOT NULL THEN
              V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
              V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
            ELSE
              V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_LINEA_3);           
              IF V_DATO IS NOT NULL THEN
                V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
              ELSE
                V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_LINEA_2);           
                IF V_DATO IS NOT NULL THEN
                  V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                  V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                ELSE
                  V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_LINEA_1);           
                  IF V_DATO IS NOT NULL THEN
                    V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                    V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                  END IF;
                END IF;
              END IF;
            END IF;                                                     

            V_BENEFICIARIOS.BFU_PAI_CODIGO            := V_PAIS;    

            V_BENEFICIARIOS.BFU_CIUDAD_ORIGEN_DESTINO := V_CIUDAD;

          END IF; 
          --
          DBMS_OUTPUT.PUT_LINE('ANTE DE PR_CREAR_BENEFICIARIOS '||V_BENEFICIARIOS.BFU_FOU_DCA_NUMERO_DECLARACION);

          PR_CREAR_BENEFICIARIOS(P_FORMULARIO        => R_TYPE_DECLARACION(I).FORMULARIO,
                                P_BENEFICIARIOS     => V_BENEFICIARIOS);      

          DBMS_OUTPUT.PUT_LINE('DESPUES DE PR_CREAR_BENEFICIARIOS '||V_BENEFICIARIOS.BFU_FOU_DCA_NUMERO_DECLARACION); 

        END LOOP;

        /* ACTUALIZAR ESTADO DE LA TABLA DE CARGUE'*/
        BEGIN
          P_DIVISAS.PR_ACTUALIZAR_ESTADO(P_CONSECUTIVO   =>  R_TYPE_BENEFICIARIO(0).TAE_CONSECUTIVO,
                                         P_ESTADO        => 'PRO',
                                         P_OBSERVACIONES => 'REGISTRO PROCESADO');
        END;                       
      END IF;

      /* MAS DE UN BENEFICARIO  Y UNA SOLA DECLARACION*/ 
      C_CARGUE_COM := NULL;
      IF R_TYPE_BENEFICIARIO.COUNT() >= 2 AND R_TYPE_DECLARACION.COUNT() = 1  THEN       
        FOR I IN R_TYPE_BENEFICIARIO.FIRST .. R_TYPE_BENEFICIARIO.LAST  LOOP          
          V_BENEFICIARIOS                          := NULL;         
          V_BENEFICIARIOS.BFU_TERMINAL_COMPLEMENTA := P_TERMINAL_COMPLEMENTA;
          V_BENEFICIARIOS.BFU_USUARIO_COMPLEMENTA  := P_USUARIO_COMPLEMENTA;
          V_BENEFICIARIOS.BFU_FECHA_COMPLEMENTA    := P_FECHA_COMPLEMENTA;
          V_BENEFICIARIOS.BFU_BEX_MNEMONICO        := P_BEX_MNEMONICO;         

          C_CARGUE_COM := NULL;
          OPEN CARGUE_COM(P_TAE_CONSECUTIVO => R_TYPE_BENEFICIARIO(I).TAE_CONSECUTIVO);
          FETCH CARGUE_COM INTO C_CARGUE_COM;
          WHILE CARGUE_COM%FOUND LOOP                                                                                    

            V_BENEFICIARIOS.BFU_FOU_DCA_NUMERO_DECLARACION := R_TYPE_DECLARACION(0).DCA_NUMERO_DECLARACION;
            V_BENEFICIARIOS.BFU_CLN_TIPO_MOVIMIENTO        := R_TYPE_DECLARACION(0).CLN_TIPO_MOVIMIENTO;
            V_BENEFICIARIOS.BFU_CLN_NUM_NUMERO             := R_TYPE_DECLARACION(0).CLN_NUM_NUMERO;
            V_BENEFICIARIOS.BFU_PRIMER_APELLIDO            := NULL;--REPLACE(RPAD(' ', 40, '*'), '*', ' ');
            V_BENEFICIARIOS.BFU_SEGUNDO_APELLIDO           := NULL;--REPLACE(RPAD(' ', 40, '*'), '*', ' ');
            V_BENEFICIARIOS.BFU_NOMBRE                     := NULL;--REPLACE(RPAD(' ', 40, '*'), '*', ' ');
            V_BENEFICIARIOS.BFU_OTROS_NOMBRE               := NULL;--REPLACE(RPAD(' ', 40, '*'), '*', ' ');               
            V_BENEFICIARIOS.BFU_TIPO_CAMBIO                := R_TYPE_DECLARACION(0).TIPO_CAMBIO;
            V_BENEFICIARIOS.BFU_VALOR                      := C_CARGUE_COM.MONTO_TRANSACCION;

            IF R_TYPE_DECLARACION(0).TIPO_CAMBIO != 1 THEN
              V_BENEFICIARIOS.BFU_VALOR_USD               := ROUND(C_CARGUE_COM.MONTO_TRANSACCION/R_TYPE_DECLARACION(0).TIPO_CAMBIO,2);
            ELSE
              V_BENEFICIARIOS.BFU_VALOR_USD               := C_CARGUE_COM.MONTO_TRANSACCION;
            END IF;

            IF C_ORDEN_DIV.ORD_TIPO_ORDEN = 'C' THEN
              V_BENEFICIARIOS.BFU_RAZON_SOCIAL            :=  RPAD(TRIM(C_CARGUE_COM.TAE_NOMBRE_ORDENANTE), 60, ' '); 




              V_BENEFICIARIOS.BFU_NUMERO_CUENTA_ENTIDAD   := C_CARGUE_COM.TAE_CUENTA_ORDENANTE  ;

            END IF;

            IF C_ORDEN_DIV.ORD_TIPO_ORDEN = 'V' THEN               
              V_BENEFICIARIOS.BFU_RAZON_SOCIAL            :=  RPAD(TRIM(C_CARGUE_COM.TAE_DIREC_CUENTA_BENFICIARIO), 60, ' ');                      



              V_BENEFICIARIOS.BFU_NUMERO_CUENTA_ENTIDAD   := C_CARGUE_COM.TAE_NUM_CUENTA_BENEFICIARIO;
            END  IF;

            V_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA       := C_CARGUE_COM.TAE_NUMERO_CUENTA;
            --
            V_BENEFICIARIOS.BFU_ENTIDAD_ENVIA_RECIBE    := C_CARGUE_COM.TAE_NOMBRE_BANCO;

            V_DATO    := NULL;
            V_PAIS    := NULL;          
            V_CIUDAD  := NULL;
            V_DATO := FN_CIUDAD_PAISES(REPLACE (C_CARGUE_COM.TAE_NOMBRE_SUCURSAL, 'LONDON', 'LONDRES'));

            IF V_DATO IS NOT NULL THEN
              V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
              V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1); 
            END IF;

            V_BENEFICIARIOS.BFU_PAI_CODIGO_ENV_REC      := V_PAIS;
            V_BENEFICIARIOS.BFU_CIUDAD_ENVIA_RECIBE     := V_CIUDAD;
            V_MONTO := TO_NUMBER(TRIM(C_CARGUE_COM.TAE_MONTO_TRANSACCION),'999,999,999,999,999.00');
            IF V_MONTO > 0 THEN
              V_BENEFICIARIOS.BFU_INTERMEDIARO_ENV_REC    := C_CARGUE_COM.TAE_DIRECCION_BANCO_CORRES;
              V_BENEFICIARIOS.BFU_ENTIDAD                 := C_CARGUE_COM.TAE_DIRECCION_SOLICITANTE;

              V_DATO    := NULL;
              V_PAIS    := NULL;
              V_CIUDAD  := NULL;
              V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_CUATRO_INTER);

              IF V_DATO IS NOT NULL THEN
                V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
              ELSE
                V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_TRES_INTER);            
                IF V_DATO IS NOT NULL THEN
                  V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                  V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                ELSE
                  V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_DOS_INTER);           
                  IF V_DATO IS NOT NULL THEN
                    V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                    V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                  ELSE
                    V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_UNO_INTER);           
                    IF V_DATO IS NOT NULL THEN
                      V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                      V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                    END IF;
                  END IF;
                END IF;
              END IF;           

              V_BENEFICIARIOS.BFU_PAI_COD_INT_ENV_REC     := V_PAIS;

              V_BENEFICIARIOS.BFU_CIUDAD_INT_ENVIA_RECIBE := V_CIUDAD;

              V_DATO    := NULL;
              V_PAIS    := NULL;
              V_CIUDAD  := NULL;
              V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_CUATRO_ORDENA);

              IF V_DATO IS NOT NULL THEN
                V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
              ELSE
                V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_TRES_ORDENANTE);            
                IF V_DATO IS NOT NULL THEN
                  V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                  V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                ELSE
                  V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_DOS_ORDENANTE);           
                  IF V_DATO IS NOT NULL THEN
                    V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                    V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                  ELSE
                    V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_UNO_ORDENANTE);           
                    IF V_DATO IS NOT NULL THEN
                      V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                      V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                    END IF;
                  END IF;
                END IF;
              END IF;

              V_BENEFICIARIOS.BFU_PAI_CODIGO            := V_PAIS;    

              V_BENEFICIARIOS.BFU_CIUDAD_ORIGEN_DESTINO := V_CIUDAD;    

            ELSIF V_MONTO < 0 THEN
              V_BENEFICIARIOS.BFU_INTERMEDIARO_ENV_REC    := C_CARGUE_COM.TAE_NOMBRE_DIRECCION_INTER;
              V_BENEFICIARIOS.BFU_ENTIDAD                 := C_CARGUE_COM.TAE_DIRECCION_BENEFICIARIO;

              V_DATO    := NULL;
              V_PAIS    := NULL;
              V_CIUDAD  := NULL;
              V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_CUATRO_CORRESPON);

              IF V_DATO IS NOT NULL THEN
                V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
              ELSE
                V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_TRES_CORRES);           
                IF V_DATO IS NOT NULL THEN
                  V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                  V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                ELSE
                  V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_DOS_CORRESPONSAL);            
                  IF V_DATO IS NOT NULL THEN
                    V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                    V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                  ELSE
                    V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_UNO_CORRESPONSAL);            
                    IF V_DATO IS NOT NULL THEN
                      V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                      V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                    END IF;
                  END IF;
                END IF;
              END IF;

              V_BENEFICIARIOS.BFU_PAI_COD_INT_ENV_REC     := V_PAIS;

              V_BENEFICIARIOS.BFU_CIUDAD_INT_ENVIA_RECIBE := V_CIUDAD;

              V_DATO    := NULL;
              V_PAIS    := NULL;
              V_CIUDAD  := NULL;
              V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_LINEA_4);

              IF V_DATO IS NOT NULL THEN
                V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
              ELSE
                V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_LINEA_3);           
                IF V_DATO IS NOT NULL THEN
                  V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                  V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                ELSE
                  V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_LINEA_2);           
                  IF V_DATO IS NOT NULL THEN
                    V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                    V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                  ELSE
                    V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_LINEA_1);           
                    IF V_DATO IS NOT NULL THEN
                      V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                      V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                    END IF;
                  END IF;
                END IF;
              END IF;                                                     

              V_BENEFICIARIOS.BFU_PAI_CODIGO            := V_PAIS;    

              V_BENEFICIARIOS.BFU_CIUDAD_ORIGEN_DESTINO := V_CIUDAD;

            END IF; 
            --
            PR_CREAR_BENEFICIARIOS(P_FORMULARIO        => R_TYPE_DECLARACION(0).FORMULARIO,
                                  P_BENEFICIARIOS     => V_BENEFICIARIOS);        
            FETCH CARGUE_COM INTO C_CARGUE_COM;

            /* ACTUALIZAR ESTADO DE LA TABLA DE CARGUE'*/
            BEGIN
               P_DIVISAS.PR_ACTUALIZAR_ESTADO(P_CONSECUTIVO   =>  R_TYPE_BENEFICIARIO(I).TAE_CONSECUTIVO,
                                              P_ESTADO        => 'PRO',
                                              P_OBSERVACIONES => 'REGISTRO PROCESADO');
            END;
          END LOOP;
          CLOSE CARGUE_COM;
        END LOOP;     
      END IF;      



      /* TODOS BENEFICARIOS SE COMPLEMENTAN CON EL UNICO NUMERAL*/
      IF R_TYPE_DECLARACION.COUNT() >= 2 AND
        R_TYPE_BENEFICIARIO.COUNT() >= 2  THEN
        IF R_TYPE_DECLARACION.COUNT() = R_TYPE_BENEFICIARIO.COUNT() THEN
          V_BENEFICIARIOS                          := NULL;         
          V_BENEFICIARIOS.BFU_TERMINAL_COMPLEMENTA := P_TERMINAL_COMPLEMENTA;
          V_BENEFICIARIOS.BFU_USUARIO_COMPLEMENTA  := P_USUARIO_COMPLEMENTA;
          V_BENEFICIARIOS.BFU_FECHA_COMPLEMENTA    := P_FECHA_COMPLEMENTA;
          V_BENEFICIARIOS.BFU_BEX_MNEMONICO        := P_BEX_MNEMONICO;         
          FOR I IN R_TYPE_DECLARACION.FIRST .. R_TYPE_DECLARACION.LAST  LOOP
            C_CARGUE_COM := NULL;

            OPEN CARGUE_COM_VAL(P_MONTO           => R_TYPE_DECLARACION(I).VALOR,
                               P_ORD_CONSECUTIVO => R_TYPE_DECLARACION(I).ORD_CONSECUTIVO,
                               P_ORD_SUC_CODIGO  => R_TYPE_DECLARACION(I).ORD_SUC_CODIGO);


            FETCH CARGUE_COM_VAL INTO C_CARGUE_COM;
            CLOSE CARGUE_COM_VAL;


            IF C_CARGUE_COM.TAE_CONSECUTIVO IS NULL THEN
              OPEN CARGUE_COM(P_TAE_CONSECUTIVO => R_TYPE_BENEFICIARIO(I).TAE_CONSECUTIVO);
              FETCH CARGUE_COM INTO C_CARGUE_COM;
              CLOSE CARGUE_COM;

              IF C_ORDEN_DIV.ORD_TIPO_ORDEN = 'C' THEN
                 V_BENEFICIARIOS.BFU_RAZON_SOCIAL            :=  'POR COMPLEMENTAR';--RPAD(TRIM(C_CARGUE_COM.TAE_NOMBRE_ORDENANTE), 60, ' '); 
              END IF;  

              IF C_ORDEN_DIV.ORD_TIPO_ORDEN = 'V' THEN               
                  V_BENEFICIARIOS.BFU_RAZON_SOCIAL           :=  'POR COMPLEMENTAR';--RPAD(TRIM(C_CARGUE_COM.TAE_DIREC_CUENTA_BENFICIARIO), 60, ' '); 
              END IF;                  
            ELSE
              IF C_ORDEN_DIV.ORD_TIPO_ORDEN = 'C' THEN
                 V_BENEFICIARIOS.BFU_RAZON_SOCIAL            :=  RPAD(TRIM(C_CARGUE_COM.TAE_NOMBRE_ORDENANTE), 60, ' '); 
              END IF;  

              IF C_ORDEN_DIV.ORD_TIPO_ORDEN = 'V' THEN               
                  V_BENEFICIARIOS.BFU_RAZON_SOCIAL           := RPAD(TRIM(C_CARGUE_COM.TAE_DIREC_CUENTA_BENFICIARIO), 60, ' '); 
              END IF;                  
            END IF;                                                                     

            V_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA       := C_CARGUE_COM.TAE_NUMERO_CUENTA;

            V_BENEFICIARIOS.BFU_FOU_DCA_NUMERO_DECLARACION := R_TYPE_DECLARACION(I).DCA_NUMERO_DECLARACION;
            V_BENEFICIARIOS.BFU_VALOR                      := C_CARGUE_COM.MONTO_TRANSACCION;
            V_BENEFICIARIOS.BFU_CLN_TIPO_MOVIMIENTO        := R_TYPE_DECLARACION(I).CLN_TIPO_MOVIMIENTO;
            V_BENEFICIARIOS.BFU_CLN_NUM_NUMERO             := R_TYPE_DECLARACION(I).CLN_NUM_NUMERO;
            V_BENEFICIARIOS.BFU_PRIMER_APELLIDO            := NULL;--REPLACE(RPAD(' ', 40, '*'), '*', ' ');
            V_BENEFICIARIOS.BFU_SEGUNDO_APELLIDO           := NULL;--REPLACE(RPAD(' ', 40, '*'), '*', ' ');
            V_BENEFICIARIOS.BFU_NOMBRE                     := NULL;--REPLACE(RPAD(' ', 40, '*'), '*', ' ');
            V_BENEFICIARIOS.BFU_OTROS_NOMBRE               := NULL;--REPLACE(RPAD(' ', 40, '*'), '*', ' ');               
            V_BENEFICIARIOS.BFU_TIPO_CAMBIO                := R_TYPE_DECLARACION(I).TIPO_CAMBIO;

            IF R_TYPE_DECLARACION(I).TIPO_CAMBIO != 1 THEN
              V_BENEFICIARIOS.BFU_VALOR_USD               := ROUND(C_CARGUE_COM.MONTO_TRANSACCION/R_TYPE_DECLARACION(I).TIPO_CAMBIO,2);
            ELSE
               V_BENEFICIARIOS.BFU_VALOR_USD              := C_CARGUE_COM.MONTO_TRANSACCION;
            END IF;

            IF C_ORDEN_DIV.ORD_TIPO_ORDEN = 'C' THEN
             --V_BENEFICIARIOS.BFU_RAZON_SOCIAL            :=  RPAD(TRIM(C_CARGUE_COM.TAE_NOMBRE_ORDENANTE), 60, ' '); 




             V_BENEFICIARIOS.BFU_NUMERO_CUENTA_ENTIDAD   := C_CARGUE_COM.TAE_CUENTA_ORDENANTE  ;

            END IF;

            IF C_ORDEN_DIV.ORD_TIPO_ORDEN = 'V' THEN               
              --V_BENEFICIARIOS.BFU_RAZON_SOCIAL            :=  RPAD(TRIM(C_CARGUE_COM.TAE_DIREC_CUENTA_BENFICIARIO), 60, ' ');
              V_BENEFICIARIOS.BFU_NUMERO_CUENTA_ENTIDAD   := C_CARGUE_COM.TAE_NUM_CUENTA_BENEFICIARIO;
            END IF;
            --
            V_BENEFICIARIOS.BFU_ENTIDAD_ENVIA_RECIBE    := C_CARGUE_COM.TAE_NOMBRE_BANCO;

            V_DATO    := NULL;
            V_PAIS    := NULL;          
            V_CIUDAD  := NULL;
            V_DATO := FN_CIUDAD_PAISES(REPLACE (C_CARGUE_COM.TAE_NOMBRE_SUCURSAL, 'LONDON', 'LONDRES'));

            IF V_DATO IS NOT NULL THEN
              V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
              V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1); 
            END IF;

            V_BENEFICIARIOS.BFU_PAI_CODIGO_ENV_REC      := V_PAIS;
            V_BENEFICIARIOS.BFU_CIUDAD_ENVIA_RECIBE     := V_CIUDAD;
            V_MONTO := TO_NUMBER(TRIM(C_CARGUE_COM.TAE_MONTO_TRANSACCION),'999,999,999,999,999.00');
            IF V_MONTO > 0 THEN
              V_BENEFICIARIOS.BFU_INTERMEDIARO_ENV_REC    := C_CARGUE_COM.TAE_DIRECCION_BANCO_CORRES;
              V_BENEFICIARIOS.BFU_ENTIDAD                 := C_CARGUE_COM.TAE_DIRECCION_SOLICITANTE;

              V_DATO    := NULL;
              V_PAIS    := NULL;
              V_CIUDAD  := NULL;
              V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_CUATRO_INTER);

              IF V_DATO IS NOT NULL THEN
                V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
              ELSE
                V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_TRES_INTER);            
                IF V_DATO IS NOT NULL THEN
                  V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                  V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                ELSE
                  V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_DOS_INTER);           
                  IF V_DATO IS NOT NULL THEN
                    V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                    V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                  ELSE
                    V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_UNO_INTER);           
                    IF V_DATO IS NOT NULL THEN
                      V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                      V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                    END IF;
                  END IF;
                END IF;
              END IF;           

              V_BENEFICIARIOS.BFU_PAI_COD_INT_ENV_REC     := V_PAIS;

              V_BENEFICIARIOS.BFU_CIUDAD_INT_ENVIA_RECIBE := V_CIUDAD;

              V_DATO    := NULL;
              V_PAIS    := NULL;
              V_CIUDAD  := NULL;
              V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_CUATRO_ORDENA);

              IF V_DATO IS NOT NULL THEN
                V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
              ELSE
                V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_TRES_ORDENANTE);            
                IF V_DATO IS NOT NULL THEN
                  V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                  V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                ELSE
                  V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_DOS_ORDENANTE);           
                  IF V_DATO IS NOT NULL THEN
                    V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                    V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                  ELSE
                    V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_UNO_ORDENANTE);           
                    IF V_DATO IS NOT NULL THEN
                      V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                      V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                    END IF;
                  END IF;
                END IF;
              END IF;

              V_BENEFICIARIOS.BFU_PAI_CODIGO            := V_PAIS;    

              V_BENEFICIARIOS.BFU_CIUDAD_ORIGEN_DESTINO := V_CIUDAD;    

            ELSIF V_MONTO < 0 THEN
              V_BENEFICIARIOS.BFU_INTERMEDIARO_ENV_REC    := C_CARGUE_COM.TAE_NOMBRE_DIRECCION_INTER;
              V_BENEFICIARIOS.BFU_ENTIDAD                 := C_CARGUE_COM.TAE_DIRECCION_BENEFICIARIO;

              V_DATO    := NULL;
              V_PAIS    := NULL;
              V_CIUDAD  := NULL;
              V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_CUATRO_CORRESPON);

              IF V_DATO IS NOT NULL THEN
                V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
              ELSE
                V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_TRES_CORRES);           
                IF V_DATO IS NOT NULL THEN
                  V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                  V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                ELSE
                  V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_DOS_CORRESPONSAL);            
                  IF V_DATO IS NOT NULL THEN
                    V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                    V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                  ELSE
                    V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_UNO_CORRESPONSAL);            
                    IF V_DATO IS NOT NULL THEN
                      V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                      V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                    END IF;
                  END IF;
                END IF;
              END IF;

              V_BENEFICIARIOS.BFU_PAI_COD_INT_ENV_REC     := V_PAIS;

              V_BENEFICIARIOS.BFU_CIUDAD_INT_ENVIA_RECIBE := V_CIUDAD;

              V_DATO    := NULL;
              V_PAIS    := NULL;
              V_CIUDAD  := NULL;
              V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_LINEA_4);

              IF V_DATO IS NOT NULL THEN
                V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
              ELSE
                V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_LINEA_3);           
                IF V_DATO IS NOT NULL THEN
                  V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                  V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                ELSE
                  V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_LINEA_2);           
                  IF V_DATO IS NOT NULL THEN
                    V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                    V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                  ELSE
                    V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_LINEA_1);           
