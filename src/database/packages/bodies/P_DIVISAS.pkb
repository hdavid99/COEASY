      IF r_registro.COUNT() > 0 THEN
        p_registro.DELETE;
        FOR i IN r_registro.FIRST .. r_registro.LAST LOOP
          v_registro := p_registro.COUNT();
          p_registro(v_registro).subcuenta          := r_registro(i).subcuenta;
          p_registro(v_registro).nombre             := r_registro(i).nombre;
          p_registro(v_registro).semana_ant         := r_registro(i).semana_ant;
