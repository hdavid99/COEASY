PROCEDURE PR_ESCRIBE_PLANTILLA_311(P_REGISTRO        IN OUT T_REGISTRO_2,
                                  P_UNIDAD_CAPTURA  VARCHAR2,
                                  P_SUBCUENTA       VARCHAR2,
                                  P_T               VARCHAR2,
                                  P_VALOR_1         NUMBER,
                                  P_VALOR_2         NUMBER) IS
  v_numero_registro NUMBER;
BEGIN
  /************************/
  /* P_T   0_C = T+0 - COMPRA -- 0_V = T+0 - VENTA
           1_C = T+1 - COMPRA -- 1_V = T+1 - VENTA
           2_C = T+2 - COMPRA -- 2_V = T+2 - VENTA
           3_C = T+3 - COMPRA -- 3_V = T+3 - VENTA*/
  v_numero_registro := P_REGISTRO.COUNT();
  IF v_numero_registro > 0 THEN
    FOR i IN P_REGISTRO.FIRST .. P_REGISTRO.LAST loop
      IF P_REGISTRO(i).SUBCUENTA = P_SUBCUENTA AND
         P_REGISTRO(i).unidad_captura  = P_UNIDAD_CAPTURA THEN
         IF P_T = '0_C' THEN
           IF P_REGISTRO(i).SUBCUENTA = '100' THEN
             P_REGISTRO(i).COM_TC_0  := P_REGISTRO(i).COM_TC_0 + (P_VALOR_1*P_VALOR_2);
             P_REGISTRO(i).COM_MON_0 := P_REGISTRO(i).COM_MON_0 + P_VALOR_2;
           ELSE
             P_REGISTRO(i).COM_TC_0  := P_VALOR_1;
             P_REGISTRO(i).COM_MON_0 := P_VALOR_2;
           END IF;  
         ELSIF P_T = '0_V' THEN
           IF P_REGISTRO(i).SUBCUENTA = '100' THEN
             P_REGISTRO(i).VEN_TC_0  := P_REGISTRO(i).VEN_TC_0 + (P_VALOR_1*P_VALOR_2);
             P_REGISTRO(i).VEN_MON_0 := P_REGISTRO(i).VEN_MON_0 + P_VALOR_2;
           ELSE
             P_REGISTRO(i).VEN_TC_0  := P_VALOR_1;
             P_REGISTRO(i).VEN_MON_0 := P_VALOR_2;
           END IF;
         ELSIF P_T = '1_C' THEN
           IF P_REGISTRO(i).SUBCUENTA = '100' THEN
             P_REGISTRO(i).COM_TC_1  := P_REGISTRO(i).COM_TC_1 + (P_VALOR_1*P_VALOR_2);
             P_REGISTRO(i).COM_MON_1 := P_REGISTRO(i).COM_MON_1 + P_VALOR_2;
           ELSE
             P_REGISTRO(i).COM_TC_1  := P_VALOR_1;
             P_REGISTRO(i).COM_MON_1 := P_VALOR_2;
           END IF;
         ELSIF P_T = '1_V' THEN
           IF P_REGISTRO(i).SUBCUENTA = '100' THEN
             P_REGISTRO(i).VEN_TC_1  := P_REGISTRO(i).VEN_TC_1 + (P_VALOR_1*P_VALOR_2);
             P_REGISTRO(i).VEN_MON_1 := P_REGISTRO(i).VEN_MON_1 + P_VALOR_2;
           ELSE
             P_REGISTRO(i).VEN_TC_1  := P_VALOR_1;
             P_REGISTRO(i).VEN_MON_1 := P_VALOR_2;
           END IF;
         ELSIF P_T = '2_C' THEN
           IF P_REGISTRO(i).SUBCUENTA = '100' THEN
             P_REGISTRO(i).COM_TC_2  := P_REGISTRO(i).COM_TC_2 + (P_VALOR_1*P_VALOR_2);
             P_REGISTRO(i).COM_MON_2 := P_REGISTRO(i).COM_MON_2 + P_VALOR_2;
           ELSE
             P_REGISTRO(i).COM_TC_2  := P_VALOR_1;
             P_REGISTRO(i).COM_MON_2 := P_VALOR_2;
           END IF;
         ELSIF P_T = '2_V' THEN
           IF P_REGISTRO(i).SUBCUENTA = '100' THEN
             P_REGISTRO(i).VEN_TC_2  := P_REGISTRO(i).VEN_TC_2 + (P_VALOR_1*P_VALOR_2);
             P_REGISTRO(i).VEN_MON_2 := P_REGISTRO(i).VEN_MON_2 + P_VALOR_2;
           ELSE
             P_REGISTRO(i).VEN_TC_2  := P_VALOR_1;
             P_REGISTRO(i).VEN_MON_2 := P_VALOR_2;
           END IF;
         ELSIF P_T = '3_C' THEN
           IF P_REGISTRO(i).SUBCUENTA = '100' THEN
             P_REGISTRO(i).COM_TC_3  := P_REGISTRO(i).COM_TC_3 + (P_VALOR_1*P_VALOR_2);
             P_REGISTRO(i).COM_MON_3 := P_REGISTRO(i).COM_MON_3 + P_VALOR_2;
           ELSE
             P_REGISTRO(i).COM_TC_3  := P_VALOR_1;
             P_REGISTRO(i).COM_MON_3 := P_VALOR_2;
           END IF;
         ELSIF P_T = '3_V' THEN
           IF P_REGISTRO(i).SUBCUENTA = '100' THEN
             P_REGISTRO(i).VEN_TC_3  := P_REGISTRO(i).VEN_TC_3 + (P_VALOR_1*P_VALOR_2);
             P_REGISTRO(i).VEN_MON_3 := P_REGISTRO(i).VEN_MON_3 + P_VALOR_2;
           ELSE
             P_REGISTRO(i).VEN_TC_3  := P_VALOR_1;
             P_REGISTRO(i).VEN_MON_3 := P_VALOR_2;
           END IF;  
         END IF;
      END IF;
    END LOOP;
  END IF;
END PR_ESCRIBE_PLANTILLA_311;
-- FIN HROSAS
