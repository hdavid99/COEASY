                      V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                    END IF;
                  END IF;
                END IF;
              END IF;                                                     

              V_BENEFICIARIOS.BFU_PAI_CODIGO            := V_PAIS;    

              V_BENEFICIARIOS.BFU_CIUDAD_ORIGEN_DESTINO := V_CIUDAD;

            END IF; 
            --             
            PR_CREAR_BENEFICIARIOS(P_FORMULARIO        => R_TYPE_DECLARACION(I).FORMULARIO,
                                   P_BENEFICIARIOS     => V_BENEFICIARIOS);                
          END LOOP;

          FOR T IN R_TYPE_BENEFICIARIO.FIRST .. R_TYPE_BENEFICIARIO.LAST LOOP
             /* ACTUALIZAR ESTADO DE LA TABLA DE CARGUE'*/
            BEGIN
              P_DIVISAS.PR_ACTUALIZAR_ESTADO(P_CONSECUTIVO   =>  R_TYPE_BENEFICIARIO(T).TAE_CONSECUTIVO,
                                             P_ESTADO        => 'PRO',
                                             P_OBSERVACIONES => 'REGISTRO PROCESADO');
            END;                       
          END LOOP;
        END IF;

        IF R_TYPE_DECLARACION.COUNT() > R_TYPE_BENEFICIARIO.COUNT() THEN
          V_BENEFICIARIOS                          := NULL;         
          V_BENEFICIARIOS.BFU_TERMINAL_COMPLEMENTA := P_TERMINAL_COMPLEMENTA;
          V_BENEFICIARIOS.BFU_USUARIO_COMPLEMENTA  := P_USUARIO_COMPLEMENTA;
          V_BENEFICIARIOS.BFU_FECHA_COMPLEMENTA    := P_FECHA_COMPLEMENTA;
          V_BENEFICIARIOS.BFU_BEX_MNEMONICO        := P_BEX_MNEMONICO;


          FOR I IN R_TYPE_DECLARACION.FIRST .. R_TYPE_DECLARACION.LAST  LOOP
            C_CARGUE_COM := NULL;


            OPEN CARGUE_COM(P_TAE_CONSECUTIVO => R_TYPE_BENEFICIARIO(0).TAE_CONSECUTIVO);
            FETCH CARGUE_COM INTO C_CARGUE_COM;
            CLOSE CARGUE_COM;

            V_BENEFICIARIOS.BFU_FOU_DCA_NUMERO_DECLARACION := R_TYPE_DECLARACION(I).DCA_NUMERO_DECLARACION;
            V_BENEFICIARIOS.BFU_VALOR                      := R_TYPE_DECLARACION(I).VALOR;
            V_BENEFICIARIOS.BFU_CLN_TIPO_MOVIMIENTO        := R_TYPE_DECLARACION(I).CLN_TIPO_MOVIMIENTO;
            V_BENEFICIARIOS.BFU_CLN_NUM_NUMERO             := R_TYPE_DECLARACION(I).CLN_NUM_NUMERO;
            V_BENEFICIARIOS.BFU_PRIMER_APELLIDO            := NULL;--REPLACE(RPAD(' ', 40, '*'), '*', ' ');
            V_BENEFICIARIOS.BFU_SEGUNDO_APELLIDO           := NULL;--REPLACE(RPAD(' ', 40, '*'), '*', ' ');
            V_BENEFICIARIOS.BFU_NOMBRE                     := NULL;--REPLACE(RPAD(' ', 40, '*'), '*', ' ');
            V_BENEFICIARIOS.BFU_OTROS_NOMBRE               := NULL;--REPLACE(RPAD(' ', 40, '*'), '*', ' ');               
            V_BENEFICIARIOS.BFU_TIPO_CAMBIO                := R_TYPE_DECLARACION(I).TIPO_CAMBIO;

            IF  R_TYPE_DECLARACION(I).TIPO_CAMBIO != 1 THEN
              V_BENEFICIARIOS.BFU_VALOR_USD               := ROUND(R_TYPE_DECLARACION(I).VALOR/R_TYPE_DECLARACION(I).TIPO_CAMBIO,2);
            ELSE
              V_BENEFICIARIOS.BFU_VALOR_USD               := R_TYPE_DECLARACION(I).VALOR;
            END IF;


            IF C_ORDEN_DIV.ORD_TIPO_ORDEN = 'C' THEN
              V_BENEFICIARIOS.BFU_RAZON_SOCIAL            :=  'POR COMPLEMENTAR';--RPAD(TRIM(C_CARGUE_COM.TAE_NOMBRE_ORDENANTE), 60, ' '); 




              V_BENEFICIARIOS.BFU_NUMERO_CUENTA_ENTIDAD   := C_CARGUE_COM.TAE_CUENTA_ORDENANTE  ;

            END IF;

            IF C_ORDEN_DIV.ORD_TIPO_ORDEN = 'V' THEN               
              V_BENEFICIARIOS.BFU_RAZON_SOCIAL            :=  'POR COMPLEMENTAR';--RPAD(TRIM(C_CARGUE_COM.TAE_DIREC_CUENTA_BENFICIARIO), 60, ' '); 
              V_BENEFICIARIOS.BFU_NUMERO_CUENTA_ENTIDAD   := C_CARGUE_COM.TAE_NUM_CUENTA_BENEFICIARIO;
            END IF;

            V_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA       := C_CARGUE_COM.TAE_NUMERO_CUENTA;   
            --
            V_BENEFICIARIOS.BFU_ENTIDAD_ENVIA_RECIBE    := C_CARGUE_COM.TAE_NOMBRE_BANCO;

            V_DATO    := NULL;
            V_PAIS    := NULL;          
            V_CIUDAD  := NULL;
            V_DATO := FN_CIUDAD_PAISES(REPLACE (C_CARGUE_COM.TAE_NOMBRE_SUCURSAL, 'LONDON', 'LONDRES'));

            IF V_DATO IS NOT NULL THEN
              V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
              V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1); 
            END IF;

            V_BENEFICIARIOS.BFU_PAI_CODIGO_ENV_REC      := V_PAIS;
            V_BENEFICIARIOS.BFU_CIUDAD_ENVIA_RECIBE     := V_CIUDAD;
            V_MONTO := TO_NUMBER(TRIM(C_CARGUE_COM.TAE_MONTO_TRANSACCION),'999,999,999,999,999.00');
            IF V_MONTO > 0 THEN
              V_BENEFICIARIOS.BFU_INTERMEDIARO_ENV_REC    := C_CARGUE_COM.TAE_DIRECCION_BANCO_CORRES;
              V_BENEFICIARIOS.BFU_ENTIDAD                 := C_CARGUE_COM.TAE_DIRECCION_SOLICITANTE;

              V_DATO    := NULL;
              V_PAIS    := NULL;
              V_CIUDAD  := NULL;
              V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_CUATRO_INTER);

              IF V_DATO IS NOT NULL THEN
                V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
              ELSE
                V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_TRES_INTER);            
                IF V_DATO IS NOT NULL THEN
                  V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                  V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                ELSE
                  V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_DOS_INTER);           
                  IF V_DATO IS NOT NULL THEN
                    V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                    V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                  ELSE
                    V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_UNO_INTER);           
                    IF V_DATO IS NOT NULL THEN
                      V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                      V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                    END IF;
                  END IF;
                END IF;
              END IF;           

              V_BENEFICIARIOS.BFU_PAI_COD_INT_ENV_REC     := V_PAIS;

              V_BENEFICIARIOS.BFU_CIUDAD_INT_ENVIA_RECIBE := V_CIUDAD;

              V_DATO    := NULL;
              V_PAIS    := NULL;
              V_CIUDAD  := NULL;
              V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_CUATRO_ORDENA);

              IF V_DATO IS NOT NULL THEN
                V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
              ELSE
                V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_TRES_ORDENANTE);            
                IF V_DATO IS NOT NULL THEN
                  V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                  V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                ELSE
                  V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_DOS_ORDENANTE);           
                  IF V_DATO IS NOT NULL THEN
                    V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                    V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                  ELSE
                    V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_UNO_ORDENANTE);           
                    IF V_DATO IS NOT NULL THEN
                      V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                      V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                    END IF;
                  END IF;
                END IF;
              END IF;

              V_BENEFICIARIOS.BFU_PAI_CODIGO            := V_PAIS;    

              V_BENEFICIARIOS.BFU_CIUDAD_ORIGEN_DESTINO := V_CIUDAD;    

            ELSIF V_MONTO < 0 THEN
              V_BENEFICIARIOS.BFU_INTERMEDIARO_ENV_REC    := C_CARGUE_COM.TAE_NOMBRE_DIRECCION_INTER;
              V_BENEFICIARIOS.BFU_ENTIDAD                 := C_CARGUE_COM.TAE_DIRECCION_BENEFICIARIO;

              V_DATO    := NULL;
              V_PAIS    := NULL;
              V_CIUDAD  := NULL;
              V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_CUATRO_CORRESPON);

              IF V_DATO IS NOT NULL THEN
                V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
              ELSE
                V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_TRES_CORRES);           
                IF V_DATO IS NOT NULL THEN
                  V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                  V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                ELSE
                  V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_DOS_CORRESPONSAL);            
                  IF V_DATO IS NOT NULL THEN
                    V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                    V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                  ELSE
                    V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_UNO_CORRESPONSAL);            
                    IF V_DATO IS NOT NULL THEN
                      V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                      V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                    END IF;
                  END IF;
                END IF;
              END IF;

              V_BENEFICIARIOS.BFU_PAI_COD_INT_ENV_REC     := V_PAIS;

              V_BENEFICIARIOS.BFU_CIUDAD_INT_ENVIA_RECIBE := V_CIUDAD;

              V_DATO    := NULL;
              V_PAIS    := NULL;
              V_CIUDAD  := NULL;
              V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_LINEA_4);

              IF V_DATO IS NOT NULL THEN
                V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
              ELSE
                V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_LINEA_3);           
                IF V_DATO IS NOT NULL THEN
                  V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                  V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                ELSE
                  V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_LINEA_2);           
                  IF V_DATO IS NOT NULL THEN
                    V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                    V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                  ELSE
                    V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_LINEA_1);           
                    IF V_DATO IS NOT NULL THEN
                      V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                      V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                    END IF;
                  END IF;
                END IF;
              END IF;                                                     

              V_BENEFICIARIOS.BFU_PAI_CODIGO            := V_PAIS;    

              V_BENEFICIARIOS.BFU_CIUDAD_ORIGEN_DESTINO := V_CIUDAD;

            END IF; 
            --

            PR_CREAR_BENEFICIARIOS(P_FORMULARIO        => R_TYPE_DECLARACION(I).FORMULARIO,
                                   P_BENEFICIARIOS     => V_BENEFICIARIOS);  


          END LOOP;         

          FOR T IN R_TYPE_BENEFICIARIO.FIRST .. R_TYPE_BENEFICIARIO.LAST LOOP
             /* ACTUALIZAR ESTADO DE LA TABLA DE CARGUE'*/
            BEGIN
              P_DIVISAS.PR_ACTUALIZAR_ESTADO(P_CONSECUTIVO   =>  R_TYPE_BENEFICIARIO(T).TAE_CONSECUTIVO,
                                             P_ESTADO        => 'PRO',
                                             P_OBSERVACIONES => 'REGISTRO PROCESADO');
            END; 
          END LOOP;       
        END IF;      


        IF R_TYPE_BENEFICIARIO.COUNT() > R_TYPE_DECLARACION.COUNT() THEN
          V_BENEFICIARIOS                          := NULL;         
          V_BENEFICIARIOS.BFU_TERMINAL_COMPLEMENTA := P_TERMINAL_COMPLEMENTA;
          V_BENEFICIARIOS.BFU_USUARIO_COMPLEMENTA  := P_USUARIO_COMPLEMENTA;
          V_BENEFICIARIOS.BFU_FECHA_COMPLEMENTA    := P_FECHA_COMPLEMENTA;
          V_BENEFICIARIOS.BFU_BEX_MNEMONICO        := P_BEX_MNEMONICO;


          FOR I IN R_TYPE_BENEFICIARIO.FIRST .. R_TYPE_BENEFICIARIO.LAST  LOOP
            C_CARGUE_COM := NULL;
            OPEN CARGUE_COM(P_TAE_CONSECUTIVO => R_TYPE_BENEFICIARIO(I).TAE_CONSECUTIVO);
            FETCH CARGUE_COM INTO C_CARGUE_COM;
            CLOSE CARGUE_COM; 

            V_BENEFICIARIOS.BFU_FOU_DCA_NUMERO_DECLARACION := R_TYPE_DECLARACION(0).DCA_NUMERO_DECLARACION;
            V_BENEFICIARIOS.BFU_VALOR                      := C_CARGUE_COM.MONTO_TRANSACCION;
            V_BENEFICIARIOS.BFU_CLN_TIPO_MOVIMIENTO        := R_TYPE_DECLARACION(0).CLN_TIPO_MOVIMIENTO;
            V_BENEFICIARIOS.BFU_CLN_NUM_NUMERO             := R_TYPE_DECLARACION(0).CLN_NUM_NUMERO;
            V_BENEFICIARIOS.BFU_PRIMER_APELLIDO            := NULL;--REPLACE(RPAD(' ', 40, '*'), '*', ' ');
            V_BENEFICIARIOS.BFU_SEGUNDO_APELLIDO           := NULL;--REPLACE(RPAD(' ', 40, '*'), '*', ' ');
            V_BENEFICIARIOS.BFU_NOMBRE                     := NULL;--REPLACE(RPAD(' ', 40, '*'), '*', ' ');
            V_BENEFICIARIOS.BFU_OTROS_NOMBRE               := NULL;--REPLACE(RPAD(' ', 40, '*'), '*', ' ');               
            V_BENEFICIARIOS.BFU_TIPO_CAMBIO                := R_TYPE_DECLARACION(0).TIPO_CAMBIO;

            IF R_TYPE_DECLARACION(0).TIPO_CAMBIO != 1 THEN
              V_BENEFICIARIOS.BFU_VALOR_USD               := ROUND(C_CARGUE_COM.MONTO_TRANSACCION/R_TYPE_DECLARACION(0).TIPO_CAMBIO,2);
            ELSE
              V_BENEFICIARIOS.BFU_VALOR_USD               := C_CARGUE_COM.MONTO_TRANSACCION;
            END IF;

            IF C_ORDEN_DIV.ORD_TIPO_ORDEN = 'C' THEN
              V_BENEFICIARIOS.BFU_RAZON_SOCIAL            :=  'POR COMPLEMENTAR';--RPAD(TRIM(C_CARGUE_COM.TAE_NOMBRE_ORDENANTE), 60, ' '); 




              V_BENEFICIARIOS.BFU_NUMERO_CUENTA_ENTIDAD   := C_CARGUE_COM.TAE_CUENTA_ORDENANTE  ;

            END IF;

            IF C_ORDEN_DIV.ORD_TIPO_ORDEN = 'V' THEN               
              V_BENEFICIARIOS.BFU_RAZON_SOCIAL            :=  'POR COMPLEMENTAR';--RPAD(TRIM(C_CARGUE_COM.TAE_DIREC_CUENTA_BENFICIARIO), 60, ' '); 
              V_BENEFICIARIOS.BFU_NUMERO_CUENTA_ENTIDAD   := C_CARGUE_COM.TAE_NUM_CUENTA_BENEFICIARIO;
            END IF;

            V_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA       := C_CARGUE_COM.TAE_NUMERO_CUENTA;
            --
            V_BENEFICIARIOS.BFU_ENTIDAD_ENVIA_RECIBE    := C_CARGUE_COM.TAE_NOMBRE_BANCO;

            V_DATO    := NULL;
            V_PAIS    := NULL;          
            V_CIUDAD  := NULL;
            V_DATO := FN_CIUDAD_PAISES(REPLACE (C_CARGUE_COM.TAE_NOMBRE_SUCURSAL, 'LONDON', 'LONDRES'));

            IF V_DATO IS NOT NULL THEN
              V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
              V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1); 
            END IF;

            V_BENEFICIARIOS.BFU_PAI_CODIGO_ENV_REC      := V_PAIS;
            V_BENEFICIARIOS.BFU_CIUDAD_ENVIA_RECIBE     := V_CIUDAD;
            V_MONTO := TO_NUMBER(TRIM(C_CARGUE_COM.TAE_MONTO_TRANSACCION),'999,999,999,999,999.00');
            IF V_MONTO > 0 THEN
              V_BENEFICIARIOS.BFU_INTERMEDIARO_ENV_REC    := C_CARGUE_COM.TAE_DIRECCION_BANCO_CORRES;
              V_BENEFICIARIOS.BFU_ENTIDAD                 := C_CARGUE_COM.TAE_DIRECCION_SOLICITANTE;

              V_DATO    := NULL;
              V_PAIS    := NULL;
              V_CIUDAD  := NULL;
              V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_CUATRO_INTER);

              IF V_DATO IS NOT NULL THEN
                V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
              ELSE
                V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_TRES_INTER);            
                IF V_DATO IS NOT NULL THEN
                  V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                  V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                ELSE
                  V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_DOS_INTER);           
                  IF V_DATO IS NOT NULL THEN
                    V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                    V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                  ELSE
                    V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_UNO_INTER);           
                    IF V_DATO IS NOT NULL THEN
                      V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                      V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                    END IF;
                  END IF;
                END IF;
              END IF;           

              V_BENEFICIARIOS.BFU_PAI_COD_INT_ENV_REC     := V_PAIS;

              V_BENEFICIARIOS.BFU_CIUDAD_INT_ENVIA_RECIBE := V_CIUDAD;

              V_DATO    := NULL;
              V_PAIS    := NULL;
              V_CIUDAD  := NULL;
              V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_CUATRO_ORDENA);

              IF V_DATO IS NOT NULL THEN
                V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
              ELSE
                V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_TRES_ORDENANTE);            
                IF V_DATO IS NOT NULL THEN
                  V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                  V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                ELSE
                  V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_DOS_ORDENANTE);           
                  IF V_DATO IS NOT NULL THEN
                    V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                    V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                  ELSE
                    V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_UNO_ORDENANTE);           
                    IF V_DATO IS NOT NULL THEN
                      V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                      V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                    END IF;
                  END IF;
                END IF;
              END IF;

              V_BENEFICIARIOS.BFU_PAI_CODIGO            := V_PAIS;    

              V_BENEFICIARIOS.BFU_CIUDAD_ORIGEN_DESTINO := V_CIUDAD;    

            ELSIF V_MONTO < 0 THEN
              V_BENEFICIARIOS.BFU_INTERMEDIARO_ENV_REC    := C_CARGUE_COM.TAE_NOMBRE_DIRECCION_INTER;
              V_BENEFICIARIOS.BFU_ENTIDAD                 := C_CARGUE_COM.TAE_DIRECCION_BENEFICIARIO;

              V_DATO    := NULL;
              V_PAIS    := NULL;
              V_CIUDAD  := NULL;
              V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_CUATRO_CORRESPON);

              IF V_DATO IS NOT NULL THEN
                V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
              ELSE
                V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_TRES_CORRES);           
                IF V_DATO IS NOT NULL THEN
                  V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                  V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                ELSE
                  V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_DOS_CORRESPONSAL);            
                  IF V_DATO IS NOT NULL THEN
                    V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                    V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                  ELSE
                    V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_UNO_CORRESPONSAL);            
                    IF V_DATO IS NOT NULL THEN
                      V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                      V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                    END IF;
                  END IF;
                END IF;
              END IF;

              V_BENEFICIARIOS.BFU_PAI_COD_INT_ENV_REC     := V_PAIS;

              V_BENEFICIARIOS.BFU_CIUDAD_INT_ENVIA_RECIBE := V_CIUDAD;

              V_DATO    := NULL;
              V_PAIS    := NULL;
              V_CIUDAD  := NULL;
              V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_LINEA_4);

              IF V_DATO IS NOT NULL THEN
                V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
              ELSE
                V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_LINEA_3);           
                IF V_DATO IS NOT NULL THEN
                  V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                  V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                ELSE
                  V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_LINEA_2);           
                  IF V_DATO IS NOT NULL THEN
                    V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                    V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                  ELSE
                    V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM.TAE_DOMICILIO_LINEA_1);           
                    IF V_DATO IS NOT NULL THEN
                      V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
                      V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
                    END IF;
                  END IF;
                END IF;
              END IF;                                                     

              V_BENEFICIARIOS.BFU_PAI_CODIGO            := V_PAIS;    

              V_BENEFICIARIOS.BFU_CIUDAD_ORIGEN_DESTINO := V_CIUDAD;

            END IF; 
            --

            PR_CREAR_BENEFICIARIOS(P_FORMULARIO        => R_TYPE_DECLARACION(0).FORMULARIO,
                                     P_BENEFICIARIOS     => V_BENEFICIARIOS);   
            BEGIN
              P_DIVISAS.PR_ACTUALIZAR_ESTADO(P_CONSECUTIVO   =>  R_TYPE_BENEFICIARIO(I).TAE_CONSECUTIVO,
                                             P_ESTADO        => 'PRO',
                                             P_OBSERVACIONES => 'REGISTRO PROCESADO');
            END; 

          END LOOP;
        END IF;
      END IF;
    FETCH REGISTROS INTO C_REGISTROS;
  END LOOP;
  CLOSE REGISTROS;

  /* TODOS LOS REGISTROS DE LAS OPERACIONES NO MONETIZADAS*/
  C_CARGUE_COM_1 := NULL;

  OPEN CARGUE_COM_1;
  FETCH CARGUE_COM_1 INTO C_CARGUE_COM_1;
  WHILE CARGUE_COM_1%FOUND LOOP
    V_MONTO        := NULL;
    V_REFERENCIA   := NULL;
    V_ORDEN         := C_CARGUE_COM_1.TAE_CONSECUTIVO; 
    V_MONTO         := TO_NUMBER(TRIM(C_CARGUE_COM_1.TAE_MONTO_TRANSACCION),'999,999,999,999,999.00');
    V_REFERENCIA    := TO_NUMBER(SUBSTR(TRIM(REPLACE(C_CARGUE_COM_1.TAE_REFERENCIA_CLIENTE, ' ')), 1, 8),'99999999');
    V_BENEFICIARIOS_1                               := NULL;    
    V_BENEFICIARIOS_1.BFA_TERMINAL_COMPLEMENTA      := P_TERMINAL_COMPLEMENTA;
    V_BENEFICIARIOS_1.BFA_USUARIO_COMPLEMENTA       := P_USUARIO_COMPLEMENTA;
    V_BENEFICIARIOS_1.BFA_FECHA_COMPLEMENTA         := P_FECHA_COMPLEMENTA;
    V_BENEFICIARIOS_1.BFA_BEX_MNEMONICO             := P_BEX_MNEMONICO;         
    --
    V_BENEFICIARIOS_1.BFA_VALOR                     := V_MONTO;
    V_BENEFICIARIOS_1.BFA_NRO_CUENTA_BANCARIA       := C_CARGUE_COM_1.TAE_NUMERO_CUENTA;    

    IF V_MONTO > 0 THEN 
      V_BENEFICIARIOS_1.BFA_CLN_TIPO_MOVIMIENTO     := 'ING';
      V_BENEFICIARIOS_1.BFA_CLN_NUM_NUMERO          := 9003;
      V_BENEFICIARIOS_1.BFA_DESCRIPCION             := 'Operaciones No Monetizadas Ingreso de Divisas';
    ELSIF V_MONTO < 0 THEN  
      V_BENEFICIARIOS_1.BFA_CLN_TIPO_MOVIMIENTO     := 'EGR';
      V_BENEFICIARIOS_1.BFA_CLN_NUM_NUMERO          := 9004;
      V_BENEFICIARIOS_1.BFA_DESCRIPCION             := 'Operaciones No Monetizadas Egreso de Divisas';
    END IF; 

    IF V_REFERENCIA IS NOT NULL THEN
      OPEN RECIBO_CAJA (V_REFERENCIA);
      FETCH RECIBO_CAJA INTO C_RECIBO_CAJA;
      IF RECIBO_CAJA%FOUND THEN
        V_BENEFICIARIOS_1.BFA_RECIBO_CAJA           := V_REFERENCIA;
        V_BENEFICIARIOS_1.BFA_NUMERO_IDENTIFICACION := C_RECIBO_CAJA.RCD_CCC_CLI_PER_NUM_IDEN;
        V_BENEFICIARIOS_1.BFA_TIPO_ID               := C_RECIBO_CAJA.RCD_CCC_CLI_PER_TID_CODIGO;
        V_BENEFICIARIOS_1.BFA_ESTADO                := 'ONM';
        OPEN C_PERSONAS (C_RECIBO_CAJA.RCD_CCC_CLI_PER_NUM_IDEN, C_RECIBO_CAJA.RCD_CCC_CLI_PER_TID_CODIGO);
        FETCH C_PERSONAS INTO R_PERSONAS;
        CLOSE C_PERSONAS;
        IF R_PERSONAS.PER_TIPO = 'PNA' THEN   
          V_BENEFICIARIOS_1.BFA_PRIMER_APELLIDO     := R_PERSONAS.PER_PRIMER_APELLIDO;
          V_BENEFICIARIOS_1.BFA_SEGUNDO_APELLIDO    := R_PERSONAS.PER_SEGUNDO_APELLIDO;
          V_BENEFICIARIOS_1.BFA_NOMBRE              := R_PERSONAS.PER_NOMBRE;
        ELSE                                                     
          V_BENEFICIARIOS_1.BFA_RAZON_SOCIAL        := R_PERSONAS.PER_RAZON_SOCIAL;
        END IF;
      ELSE
        V_BENEFICIARIOS_1.BFA_ESTADO                := 'SID';
      END IF; 
      CLOSE RECIBO_CAJA;
    ELSE
      V_BENEFICIARIOS_1.BFA_ESTADO                := 'SID';  
    END IF; 

    V_BENEFICIARIOS_1.BFA_FECHA_OPERACION         := TO_DATE(TRIM(C_CARGUE_COM_1.TAE_FECHA_INGRESO), 'MM/DD/YYYY');
    --
    V_BENEFICIARIOS_1.BFA_ENTIDAD_ENVIA_RECIBE    := C_CARGUE_COM_1.TAE_NOMBRE_BANCO;

    V_DATO    := NULL;
    V_PAIS    := NULL;          
    V_CIUDAD  := NULL;
    V_DATO := FN_CIUDAD_PAISES(REPLACE (C_CARGUE_COM_1.TAE_NOMBRE_SUCURSAL, 'LONDON', 'LONDRES'));

    IF V_DATO IS NOT NULL THEN
      V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
      V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1); 
    END IF;

    V_BENEFICIARIOS_1.BFA_PAI_CODIGO_ENV_REC      := V_PAIS;
    V_BENEFICIARIOS_1.BFA_CIUDAD_ENVIA_RECIBE     := V_CIUDAD;
    V_MONTO := TO_NUMBER(TRIM(C_CARGUE_COM_1.TAE_MONTO_TRANSACCION),'999,999,999,999,999.00');
    IF V_MONTO > 0 THEN

      V_BENEFICIARIOS_1.BFA_NUMERO_CUENTA_ENTIDAD   := C_CARGUE_COM_1.TAE_CUENTA_ORDENANTE  ;
      V_BENEFICIARIOS_1.BFA_INTERMEDIARO_ENV_REC    := C_CARGUE_COM_1.TAE_DIRECCION_BANCO_CORRES;
      V_BENEFICIARIOS_1.BFA_ENTIDAD                 := C_CARGUE_COM_1.TAE_DIRECCION_SOLICITANTE;

      V_DATO    := NULL;
      V_PAIS    := NULL;
      V_CIUDAD  := NULL;
      V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM_1.TAE_DOMICILIO_CUATRO_INTER);

      IF V_DATO IS NOT NULL THEN
        V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
        V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
      ELSE
        V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM_1.TAE_DOMICILIO_TRES_INTER);            
        IF V_DATO IS NOT NULL THEN
          V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
          V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
        ELSE
          V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM_1.TAE_DOMICILIO_DOS_INTER);           
          IF V_DATO IS NOT NULL THEN
            V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
            V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
          ELSE
            V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM_1.TAE_DOMICILIO_UNO_INTER);           
            IF V_DATO IS NOT NULL THEN
              V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
              V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
            END IF;
          END IF;
        END IF;
      END IF;           

      V_BENEFICIARIOS_1.BFA_PAI_COD_INT_ENV_REC     := V_PAIS;

      V_BENEFICIARIOS_1.BFA_CIUDAD_INT_ENVIA_RECIBE := V_CIUDAD;

      V_DATO    := NULL;
      V_PAIS    := NULL;
      V_CIUDAD  := NULL;
      V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM_1.TAE_DOMICILIO_CUATRO_ORDENA);

      IF V_DATO IS NOT NULL THEN
        V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
        V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
      ELSE
        V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM_1.TAE_DOMICILIO_TRES_ORDENANTE);            
        IF V_DATO IS NOT NULL THEN
          V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
          V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
        ELSE
          V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM_1.TAE_DOMICILIO_DOS_ORDENANTE);           
          IF V_DATO IS NOT NULL THEN
            V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
            V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
          ELSE
            V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM_1.TAE_DOMICILIO_UNO_ORDENANTE);           
            IF V_DATO IS NOT NULL THEN
              V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
              V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
            END IF;
          END IF;
        END IF;
      END IF;

      V_BENEFICIARIOS_1.BFA_PAI_CODIGO            := V_PAIS;    

      V_BENEFICIARIOS_1.BFA_CIUDAD_ORIGEN_DESTINO := V_CIUDAD;    

    ELSIF V_MONTO < 0 THEN      

      V_BENEFICIARIOS_1.BFA_NUMERO_CUENTA_ENTIDAD   := C_CARGUE_COM_1.TAE_NUM_CUENTA_BENEFICIARIO;
      V_BENEFICIARIOS_1.BFA_INTERMEDIARO_ENV_REC    := C_CARGUE_COM_1.TAE_NOMBRE_DIRECCION_INTER;
      V_BENEFICIARIOS_1.BFA_ENTIDAD                 := C_CARGUE_COM_1.TAE_DIRECCION_BENEFICIARIO;

      V_DATO    := NULL;
      V_PAIS    := NULL;
      V_CIUDAD  := NULL;
      V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM_1.TAE_DOMICILIO_CUATRO_CORRESPON);

      IF V_DATO IS NOT NULL THEN
        V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
        V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
      ELSE
        V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM_1.TAE_DOMICILIO_TRES_CORRES);           
        IF V_DATO IS NOT NULL THEN
          V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
          V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
        ELSE
          V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM_1.TAE_DOMICILIO_DOS_CORRESPONSAL);            
          IF V_DATO IS NOT NULL THEN
            V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
            V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
          ELSE
            V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM_1.TAE_DOMICILIO_UNO_CORRESPONSAL);            
            IF V_DATO IS NOT NULL THEN
              V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
              V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
            END IF;
          END IF;
        END IF;
      END IF;

      V_BENEFICIARIOS_1.BFA_PAI_COD_INT_ENV_REC     := V_PAIS;

      V_BENEFICIARIOS_1.BFA_CIUDAD_INT_ENVIA_RECIBE := V_CIUDAD;

      V_DATO    := NULL;
      V_PAIS    := NULL;
      V_CIUDAD  := NULL;
      V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM_1.TAE_DOMICILIO_LINEA_4);

      IF V_DATO IS NOT NULL THEN
        V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
        V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
      ELSE
        V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM_1.TAE_DOMICILIO_LINEA_3);           
        IF V_DATO IS NOT NULL THEN
          V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
          V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
        ELSE
          V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM_1.TAE_DOMICILIO_LINEA_2);           
          IF V_DATO IS NOT NULL THEN
            V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
            V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
          ELSE
            V_DATO := FN_CIUDAD_PAISES(C_CARGUE_COM_1.TAE_DOMICILIO_LINEA_1);           
            IF V_DATO IS NOT NULL THEN
              V_PAIS    := SUBSTR (V_DATO, 1,INSTR(V_DATO, ':', 1)-1);
              V_CIUDAD  := SUBSTR(V_DATO, INSTR(V_DATO, ':', 1)+1);
            END IF;
          END IF;
        END IF;
      END IF;                                                     

      V_BENEFICIARIOS_1.BFA_PAI_CODIGO            := V_PAIS;    

      V_BENEFICIARIOS_1.BFA_CIUDAD_ORIGEN_DESTINO := V_CIUDAD;

    END IF; 
    --          
    PR_CREAR_BENEFICIARIOS_1(P_FORMULARIO       => 6,
                            P_BENEFICIARIOS     => V_BENEFICIARIOS_1);

    /* ACTUALIZAR ESTADO DE LA TABLA DE CARGUE'*/
    BEGIN
      P_DIVISAS.PR_ACTUALIZAR_ESTADO(P_CONSECUTIVO   =>  C_CARGUE_COM_1.TAE_CONSECUTIVO,
                                    P_ESTADO        => 'PRO',
                                    P_OBSERVACIONES => 'REGISTRO PROCESADO');
    END;                        

    FETCH CARGUE_COM_1 INTO C_CARGUE_COM_1;
  END LOOP; 
  CLOSE CARGUE_COM_1;

  COMMIT;

   EXCEPTION WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20001,'Error PR_CARGUE_COM_UIAF:'||V_FORMULARIO||'--'||V_ORDEN ||'-'||SQLERRM );

END PR_CARGUE_COM_UIAF;


PROCEDURE PR_ESCRIBE_TYPE_DECLARACION(P_TYPE_DECLARACION            IN OUT T_TYPE_DECLARACION,
                                     P_DECLARACIONES_CAMBIO        DECLARACIONES_CAMBIO%ROWTYPE,
                                     P_CLASIFICACIONES_NUMERALES   CLASIFICACIONES_NUMERALES%ROWTYPE,
                                     P_VALOR                       BENEFICIARIOS_FORMULARIO_UNO.BFU_VALOR%TYPE,
                                     P_VALOR_USD                   ORDENES_DIVISAS.ORD_VALOR_DOLARES%TYPE,
                                     P_TIPO_CAMBIO                 ORDENES_DIVISAS.ORD_TIPO_CAMBIO%TYPE) IS
   V_REGISTRO NUMBER;                                     
BEGIN
   V_REGISTRO := P_TYPE_DECLARACION.COUNT();
   P_TYPE_DECLARACION(V_REGISTRO).ORD_CONSECUTIVO           := P_DECLARACIONES_CAMBIO.DCA_ORD_CONSECUTIVO;
   P_TYPE_DECLARACION(V_REGISTRO).ORD_SUC_CODIGO            := P_DECLARACIONES_CAMBIO.DCA_ORD_SUC_CODIGO;
   P_TYPE_DECLARACION(V_REGISTRO).DCA_NUMERO_DECLARACION    := P_DECLARACIONES_CAMBIO.DCA_NUMERO_DECLARACION;
   P_TYPE_DECLARACION(V_REGISTRO).FORMULARIO                := P_DECLARACIONES_CAMBIO.DCA_FORMULARIO;
   P_TYPE_DECLARACION(V_REGISTRO).CLN_TIPO_MOVIMIENTO       := P_CLASIFICACIONES_NUMERALES.CLN_TIPO_MOVIMIENTO;
   P_TYPE_DECLARACION(V_REGISTRO).CLN_NUM_NUMERO            := P_CLASIFICACIONES_NUMERALES.CLN_NUM_NUMERO;
   P_TYPE_DECLARACION(V_REGISTRO).VALOR                     := P_VALOR;
   P_TYPE_DECLARACION(V_REGISTRO).VALOR_USD                 := P_VALOR_USD;
   P_TYPE_DECLARACION(V_REGISTRO).TIPO_CAMBIO               := P_TIPO_CAMBIO;

END PR_ESCRIBE_TYPE_DECLARACION;


PROCEDURE PR_ESCRIBE_TYPE_BENEFICIARIO(P_TYPE_BENEFICIARIO    IN OUT T_TYPE_BENEFICIARIO,
                                      P_TAE_CONSECUTIVO      TMP_CARGUES_BENEFICARIOS.TAE_CONSECUTIVO%TYPE,
                                      P_ORD_SUC_CODIGO       ORDENES_DIVISAS.ORD_SUC_CODIGO%TYPE,
                                      P_ORD_CONSECUTIVO      ORDENES_DIVISAS.ORD_CONSECUTIVO%TYPE) IS
   V_REGISTRO NUMBER;                                     
BEGIN
   V_REGISTRO := P_TYPE_BENEFICIARIO.COUNT();
   P_TYPE_BENEFICIARIO(V_REGISTRO).TAE_CONSECUTIVO      := P_TAE_CONSECUTIVO;
   P_TYPE_BENEFICIARIO(V_REGISTRO).ORD_CONSECUTIVO      := P_ORD_CONSECUTIVO;
   P_TYPE_BENEFICIARIO(V_REGISTRO).ORD_SUC_CODIGO       := P_ORD_SUC_CODIGO;  
END PR_ESCRIBE_TYPE_BENEFICIARIO;

FUNCTION FN_CIUDAD_PAISES(P_DATO VARCHAR2) RETURN VARCHAR2 IS 
  V_DATO              VARCHAR2(26); 
BEGIN

  SELECT DISTINCT AGE_PAI_CODIGO||':'||AGE_CIUDAD
  INTO V_DATO
  FROM AREAS_GEOGRAFICAS
  WHERE INSTR (UPPER(P_TOOLS.FN_QUITAR_CARACTERES_ESP(P_DATO)), UPPER(PROD.P_TOOLS.FN_QUITAR_CARACTERES_ESP(AGE_CIUDAD)))> 0
  AND AGE_PAI_CODIGO NOT IN ('SLV', 'VEN')
  AND AGE_PAI_CODIGO != 'COL';
  RETURN (V_DATO);
EXCEPTION 
  WHEN OTHERS THEN
    V_DATO := NULL;
    RETURN (V_DATO);  
END;                                                              
PROCEDURE PR_CREAR_BENEFICIARIOS_1(P_FORMULARIO   NUMBER,
                                  P_BENEFICIARIOS BENEFICIARIOS_FORMULARIO_UIAF%ROWTYPE) IS

BEGIN
  IF P_FORMULARIO = 6  THEN

    INSERT INTO BENEFICIARIOS_FORMULARIO_UIAF(
       BFA_CONSECUTIVO
      ,BFA_VALOR
      ,BFA_TERMINAL_COMPLEMENTA
      ,BFA_USUARIO_COMPLEMENTA
      ,BFA_FECHA_COMPLEMENTA
      ,BFA_FOU_DCA_NUMERO_DECLARACION
      ,BFA_BEX_MNEMONICO
      ,BFA_CLN_TIPO_MOVIMIENTO
      ,BFA_CLN_NUM_NUMERO
      ,BFA_PRIMER_APELLIDO
      ,BFA_SEGUNDO_APELLIDO
      ,BFA_NOMBRE
      ,BFA_OTROS_NOMBRE
      ,BFA_RAZON_SOCIAL
      ,BFA_TIPO_ID
      ,BFA_NUMERO_IDENTIFICACION
      ,BFA_PAI_CODIGO
      ,BFA_CIUDAD_ORIGEN_DESTINO
      ,BFA_VALOR_USD
      ,BFA_TIPO_CAMBIO
      ,BFA_ENTIDAD
      ,BFA_NUMERO_CUENTA_ENTIDAD
      ,BFA_ENTIDAD_ENVIA_RECIBE
      ,BFA_PAI_CODIGO_ENV_REC
      ,BFA_CIUDAD_ENVIA_RECIBE
      ,BFA_INTERMEDIARO_ENV_REC
      ,BFA_PAI_COD_INT_ENV_REC
      ,BFA_CIUDAD_INT_ENVIA_RECIBE
      ,BFA_NRO_CUENTA_BANCARIA
      ,BFA_RECIBO_CAJA
      ,BFA_FECHA_OPERACION
      ,BFA_ESTADO
      ,BFA_DESCRIPCION
      ,BFA_MDI_MNEMONICO
      )
    VALUES (
       BFA_SEQ.NEXTVAL
      ,P_BENEFICIARIOS.BFA_VALOR
      ,P_BENEFICIARIOS.BFA_TERMINAL_COMPLEMENTA
      ,P_BENEFICIARIOS.BFA_USUARIO_COMPLEMENTA
      ,P_BENEFICIARIOS.BFA_FECHA_COMPLEMENTA
      ,P_BENEFICIARIOS.BFA_FOU_DCA_NUMERO_DECLARACION
      ,P_BENEFICIARIOS.BFA_BEX_MNEMONICO
      ,P_BENEFICIARIOS.BFA_CLN_TIPO_MOVIMIENTO
      ,P_BENEFICIARIOS.BFA_CLN_NUM_NUMERO
      ,P_BENEFICIARIOS.BFA_PRIMER_APELLIDO
      ,P_BENEFICIARIOS.BFA_SEGUNDO_APELLIDO
      ,P_BENEFICIARIOS.BFA_NOMBRE
      ,P_BENEFICIARIOS.BFA_OTROS_NOMBRE
      ,P_BENEFICIARIOS.BFA_RAZON_SOCIAL
      ,P_BENEFICIARIOS.BFA_TIPO_ID
      ,P_BENEFICIARIOS.BFA_NUMERO_IDENTIFICACION
      ,P_BENEFICIARIOS.BFA_PAI_CODIGO
      ,P_BENEFICIARIOS.BFA_CIUDAD_ORIGEN_DESTINO
      ,P_BENEFICIARIOS.BFA_VALOR_USD
      ,P_BENEFICIARIOS.BFA_TIPO_CAMBIO
      ,P_BENEFICIARIOS.BFA_ENTIDAD
      ,P_BENEFICIARIOS.BFA_NUMERO_CUENTA_ENTIDAD
      ,P_BENEFICIARIOS.BFA_ENTIDAD_ENVIA_RECIBE
      ,P_BENEFICIARIOS.BFA_PAI_CODIGO_ENV_REC
      ,P_BENEFICIARIOS.BFA_CIUDAD_ENVIA_RECIBE
      ,P_BENEFICIARIOS.BFA_INTERMEDIARO_ENV_REC
      ,P_BENEFICIARIOS.BFA_PAI_COD_INT_ENV_REC
      ,P_BENEFICIARIOS.BFA_CIUDAD_INT_ENVIA_RECIBE
      ,P_BENEFICIARIOS.BFA_NRO_CUENTA_BANCARIA
      ,P_BENEFICIARIOS.BFA_RECIBO_CAJA
      ,P_BENEFICIARIOS.BFA_FECHA_OPERACION
      ,P_BENEFICIARIOS.BFA_ESTADO
      ,P_BENEFICIARIOS.BFA_DESCRIPCION
      ,CASE  WHEN TRIM(P_BENEFICIARIOS.BFA_NRO_CUENTA_BANCARIA) = '36272171' THEN
          'USD'
        WHEN TRIM(P_BENEFICIARIOS.BFA_NRO_CUENTA_BANCARIA) = '12565382' THEN      
          'EUR'
        WHEN TRIM(P_BENEFICIARIOS.BFA_NRO_CUENTA_BANCARIA) = '12565412' THEN    
          'GBP'
        WHEN TRIM(P_BENEFICIARIOS.BFA_NRO_CUENTA_BANCARIA) = '12565390' THEN    
          'JPY'   
        WHEN TRIM(P_BENEFICIARIOS.BFA_NRO_CUENTA_BANCARIA) = '12565404' THEN
          'CAD'     
      END 
    );
  END IF;

  DBMS_OUTPUT.PUT_LINE('TERMINE PPROCEDIMIENTO '||P_FORMULARIO||'-'||P_BENEFICIARIOS.BFA_FOU_DCA_NUMERO_DECLARACION);
EXCEPTION 
  WHEN OTHERS THEN
    DBMS_OUTPUT.PUT_LINE('ERROR EN PR_CREAR_BENEFICIARIOS_1 '||SQLERRM);
    RAISE_APPLICATION_ERROR(-20002,'Error P_CREAR_BENEFICIARIOS:'||P_FORMULARIO||'-'||P_BENEFICIARIOS.BFA_FOU_DCA_NUMERO_DECLARACION||' '||SQLERRM );

END PR_CREAR_BENEFICIARIOS_1;    

PROCEDURE PR_CREAR_BENEFICIARIOS(P_FORMULARIO        DECLARACIONES_CAMBIO.DCA_FORMULARIO%TYPE,
                                 P_BENEFICIARIOS     BENEFICIARIOS_FORMULARIO_UNO%ROWTYPE) IS
  V_TIPO_ID VARCHAR2(3);
  V_NUM_IDE VARCHAR2(20);

  CURSOR CLIENTES (P_DECLARA NUMBER) IS 
    SELECT ORD_CLI_PER_NUM_IDEN,
    ORD_CLI_PER_TID_CODIGO
    FROM ORDENES_DIVISAS 
    WHERE ORD_CONSECUTIVO||ORD_SUC_CODIGO = (SELECT DCA_ORD_CONSECUTIVO||DCA_ORD_SUC_CODIGO
                                              FROM DECLARACIONES_CAMBIO
                                              WHERE DCA_NUMERO_DECLARACION = P_DECLARA)
    AND ORD_EOF_CODIGO = 'APR';

  C_CLIENTES  CLIENTES%ROWTYPE;                      
BEGIN
  DBMS_OUTPUT.PUT_LINE('DECLARA INSERTANDO :'||P_FORMULARIO||'-'||P_BENEFICIARIOS.BFU_FOU_DCA_NUMERO_DECLARACION);
  V_TIPO_ID := P_BENEFICIARIOS.BFU_TIPO_ID;
  V_NUM_IDE := P_BENEFICIARIOS.BFU_NUMERO_IDENTIFICACION;
  IF P_BENEFICIARIOS.BFU_CLN_NUM_NUMERO IN (5382, 5379, 5908, 5913) THEN  
    OPEN CLIENTES (P_BENEFICIARIOS.BFU_FOU_DCA_NUMERO_DECLARACION);
    FETCH CLIENTES INTO C_CLIENTES;
    CLOSE CLIENTES;

    V_TIPO_ID := C_CLIENTES.ORD_CLI_PER_TID_CODIGO;
    V_NUM_IDE := C_CLIENTES.ORD_CLI_PER_NUM_IDEN;
  END IF;

   IF P_FORMULARIO = 1  THEN
     DBMS_OUTPUT.PUT_LINE('PRE INSERTE '||P_FORMULARIO||'-'||P_BENEFICIARIOS.BFU_FOU_DCA_NUMERO_DECLARACION);
      INSERT INTO BENEFICIARIOS_FORMULARIO_UNO(
         BFU_CONSECUTIVO
        ,BFU_VALOR
        ,BFU_TERMINAL_COMPLEMENTA
        ,BFU_USUARIO_COMPLEMENTA
        ,BFU_FECHA_COMPLEMENTA
        ,BFU_FOU_DCA_NUMERO_DECLARACION
        ,BFU_BEX_MNEMONICO
        ,BFU_CLN_TIPO_MOVIMIENTO
        ,BFU_CLN_NUM_NUMERO
        ,BFU_PRIMER_APELLIDO
        ,BFU_SEGUNDO_APELLIDO
        ,BFU_NOMBRE
        ,BFU_OTROS_NOMBRE
        ,BFU_RAZON_SOCIAL
        ,BFU_TIPO_ID
        ,BFU_NUMERO_IDENTIFICACION
        ,BFU_PAI_CODIGO
        ,BFU_CIUDAD_ORIGEN_DESTINO
        ,BFU_VALOR_USD
        ,BFU_TIPO_CAMBIO
        ,BFU_ENTIDAD
        ,BFU_NUMERO_CUENTA_ENTIDAD
        ,BFU_MDI_MNEMONICO
        ,BFU_NRO_CUENTA_BANCARIA
        ,BFU_ENTIDAD_ENVIA_RECIBE
        ,BFU_INTERMEDIARO_ENV_REC
        ,BFU_PAI_COD_INT_ENV_REC
        ,BFU_CIUDAD_INT_ENVIA_RECIBE
        ,BFU_PAI_CODIGO_ENV_REC
        ,BFU_CIUDAD_ENVIA_RECIBE
        )
      VALUES (
         BFU_SEQ.NEXTVAL
        ,P_BENEFICIARIOS.BFU_VALOR
        ,P_BENEFICIARIOS.BFU_TERMINAL_COMPLEMENTA
        ,P_BENEFICIARIOS.BFU_USUARIO_COMPLEMENTA
        ,P_BENEFICIARIOS.BFU_FECHA_COMPLEMENTA
        ,P_BENEFICIARIOS.BFU_FOU_DCA_NUMERO_DECLARACION
        ,P_BENEFICIARIOS.BFU_BEX_MNEMONICO
        ,P_BENEFICIARIOS.BFU_CLN_TIPO_MOVIMIENTO
        ,P_BENEFICIARIOS.BFU_CLN_NUM_NUMERO
        ,P_BENEFICIARIOS.BFU_PRIMER_APELLIDO
        ,P_BENEFICIARIOS.BFU_SEGUNDO_APELLIDO
        ,P_BENEFICIARIOS.BFU_NOMBRE
        ,P_BENEFICIARIOS.BFU_OTROS_NOMBRE
        ,P_BENEFICIARIOS.BFU_RAZON_SOCIAL
        ,V_TIPO_ID
        ,V_NUM_IDE
        ,P_BENEFICIARIOS.BFU_PAI_CODIGO
        ,P_BENEFICIARIOS.BFU_CIUDAD_ORIGEN_DESTINO
        ,P_BENEFICIARIOS.BFU_VALOR_USD
        ,P_BENEFICIARIOS.BFU_TIPO_CAMBIO
        ,P_BENEFICIARIOS.BFU_ENTIDAD
        ,P_BENEFICIARIOS.BFU_NUMERO_CUENTA_ENTIDAD
        ,CASE  WHEN TRIM(P_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA) = '36272171' THEN
            'USD'
          WHEN TRIM(P_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA) = '12565382' THEN      
            'EUR'
          WHEN TRIM(P_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA) = '12565412' THEN    
            'GBP'
          WHEN TRIM(P_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA) = '12565390' THEN    
            'JPY'   
          WHEN TRIM(P_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA) = '12565404' THEN
            'CAD'     
        END
        ,P_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA
        ,P_BENEFICIARIOS.BFU_ENTIDAD_ENVIA_RECIBE
        ,P_BENEFICIARIOS.BFU_INTERMEDIARO_ENV_REC
        ,P_BENEFICIARIOS.BFU_PAI_COD_INT_ENV_REC
        ,P_BENEFICIARIOS.BFU_CIUDAD_INT_ENVIA_RECIBE
        ,P_BENEFICIARIOS.BFU_PAI_CODIGO_ENV_REC
        ,P_BENEFICIARIOS.BFU_CIUDAD_ENVIA_RECIBE
      );
      DBMS_OUTPUT.PUT_LINE('POST INSERTE '||P_FORMULARIO||'-'||P_BENEFICIARIOS.BFU_FOU_DCA_NUMERO_DECLARACION);
   END IF;

   IF P_FORMULARIO = 2  THEN

      INSERT INTO BENEFICIARIOS_FORMULARIO_DOS(
         BFD_CONSECUTIVO
        ,BFD_VALOR
        ,BFD_TERMINAL_COMPLEMENTA
        ,BFD_USUARIO_COMPLEMENTA
        ,BFD_FECHA_COMPLEMENTA
        ,BFD_FOD_DCA_NUMERO_DECLARACION
        ,BFD_BEX_MNEMONICO
        ,BFD_CLN_TIPO_MOVIMIENTO
        ,BFD_CLN_NUM_NUMERO
        ,BFD_PRIMER_APELLIDO
        ,BFD_SEGUNDO_APELLIDO
        ,BFD_NOMBRE
        ,BFD_OTROS_NOMBRE
        ,BFD_RAZON_SOCIAL
        ,BFD_TIPO_ID
        ,BFD_NUMERO_IDENTIFICACION
        ,BFD_PAI_CODIGO
        ,BFD_CIUDAD_ORIGEN_DESTINO 
        ,BFD_VALOR_USD
        ,BFD_TIPO_CAMBIO
        ,BFD_ENTIDAD
        ,BFD_NUMERO_CUENTA_ENTIDAD
        ,BFD_MDI_MNEMONICO
        ,BFD_NRO_CUENTA_BANCARIA
        ,BFD_ENTIDAD_ENVIA_RECIBE
        ,BFD_INTERMEDIARO_ENV_REC
        ,BFD_PAI_COD_INT_ENV_REC
        ,BFD_CIUDAD_INT_ENVIA_RECIBE
        ,BFD_PAI_CODIGO_ENV_REC
        ,BFD_CIUDAD_ENVIA_RECIBE)
      VALUES (
         BFD_SEQ.NEXTVAL
        ,P_BENEFICIARIOS.BFU_VALOR
        ,P_BENEFICIARIOS.BFU_TERMINAL_COMPLEMENTA
        ,P_BENEFICIARIOS.BFU_USUARIO_COMPLEMENTA
        ,P_BENEFICIARIOS.BFU_FECHA_COMPLEMENTA
        ,P_BENEFICIARIOS.BFU_FOU_DCA_NUMERO_DECLARACION
        ,P_BENEFICIARIOS.BFU_BEX_MNEMONICO
        ,P_BENEFICIARIOS.BFU_CLN_TIPO_MOVIMIENTO
        ,P_BENEFICIARIOS.BFU_CLN_NUM_NUMERO
        ,P_BENEFICIARIOS.BFU_PRIMER_APELLIDO
        ,P_BENEFICIARIOS.BFU_SEGUNDO_APELLIDO
        ,P_BENEFICIARIOS.BFU_NOMBRE
        ,P_BENEFICIARIOS.BFU_OTROS_NOMBRE
        ,P_BENEFICIARIOS.BFU_RAZON_SOCIAL
        ,V_TIPO_ID
        ,V_NUM_IDE
        ,P_BENEFICIARIOS.BFU_PAI_CODIGO
        ,P_BENEFICIARIOS.BFU_CIUDAD_ORIGEN_DESTINO
        ,P_BENEFICIARIOS.BFU_VALOR_USD
        ,P_BENEFICIARIOS.BFU_TIPO_CAMBIO
        ,P_BENEFICIARIOS.BFU_ENTIDAD
        ,P_BENEFICIARIOS.BFU_NUMERO_CUENTA_ENTIDAD
        ,CASE  WHEN TRIM(P_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA) = '36272171' THEN
            'USD'
          WHEN TRIM(P_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA) = '12565382' THEN      
            'EUR'
          WHEN TRIM(P_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA) = '12565412' THEN    
            'GBP'
          WHEN TRIM(P_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA) = '12565390' THEN    
            'JPY'   
          WHEN TRIM(P_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA) = '12565404' THEN
            'CAD'     
         END
        ,P_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA
        ,P_BENEFICIARIOS.BFU_ENTIDAD_ENVIA_RECIBE
        ,P_BENEFICIARIOS.BFU_INTERMEDIARO_ENV_REC
        ,P_BENEFICIARIOS.BFU_PAI_COD_INT_ENV_REC
        ,P_BENEFICIARIOS.BFU_CIUDAD_INT_ENVIA_RECIBE  
        ,P_BENEFICIARIOS.BFU_PAI_CODIGO_ENV_REC
        ,P_BENEFICIARIOS.BFU_CIUDAD_ENVIA_RECIBE);
   END IF;

   IF P_FORMULARIO = 3  THEN
      INSERT INTO BENEFICIARIOS_FORMULARIO_TRE(
         BFT_CONSECUTIVO
        ,BFT_VALOR
        ,BFT_TERMINAL_COMPLEMENTA
        ,BFT_USUARIO_COMPLEMENTA
        ,BFT_FECHA_COMPLEMENTA
        ,BFT_FOT_DCA_NUMERO_DECLARACION
        ,BFT_BEX_MNEMONICO
        ,BFT_CLN_TIPO_MOVIMIENTO
        ,BFT_CLN_NUM_NUMERO
        ,BFT_PRIMER_APELLIDO
        ,BFT_SEGUNDO_APELLIDO
        ,BFT_NOMBRE
        ,BFT_OTROS_NOMBRE
        ,BFT_RAZON_SOCIAL
        ,BFT_TIPO_ID
        ,BFT_NUMERO_IDENTIFICACION
        ,BFT_PAI_CODIGO
        ,BFT_CIUDAD_ORIGEN_DESTINO
        ,BFT_VALOR_USD
        ,BFT_TIPO_CAMBIO
        ,BFT_ENTIDAD
        ,BFT_NUMERO_CUENTA_ENTIDAD
        ,BFT_MDI_MNEMONICO
        ,BFT_NRO_CUENTA_BANCARIA
        ,BFT_ENTIDAD_ENVIA_RECIBE
        ,BFT_INTERMEDIARO_ENV_REC
        ,BFT_PAI_COD_INT_ENV_REC
        ,BFT_CIUDAD_INT_ENVIA_RECIBE
        ,BFT_PAI_CODIGO_ENV_REC
        ,BFT_CIUDAD_ENVIA_RECIBE)
      VALUES (
         BFT_SEQ.NEXTVAL
        ,P_BENEFICIARIOS.BFU_VALOR
        ,P_BENEFICIARIOS.BFU_TERMINAL_COMPLEMENTA
        ,P_BENEFICIARIOS.BFU_USUARIO_COMPLEMENTA
        ,P_BENEFICIARIOS.BFU_FECHA_COMPLEMENTA
        ,P_BENEFICIARIOS.BFU_FOU_DCA_NUMERO_DECLARACION
        ,P_BENEFICIARIOS.BFU_BEX_MNEMONICO
        ,P_BENEFICIARIOS.BFU_CLN_TIPO_MOVIMIENTO
        ,P_BENEFICIARIOS.BFU_CLN_NUM_NUMERO
        ,P_BENEFICIARIOS.BFU_PRIMER_APELLIDO
        ,P_BENEFICIARIOS.BFU_SEGUNDO_APELLIDO
        ,P_BENEFICIARIOS.BFU_NOMBRE
        ,P_BENEFICIARIOS.BFU_OTROS_NOMBRE
        ,P_BENEFICIARIOS.BFU_RAZON_SOCIAL
        ,V_TIPO_ID
        ,V_NUM_IDE
        ,P_BENEFICIARIOS.BFU_PAI_CODIGO
        ,P_BENEFICIARIOS.BFU_CIUDAD_ORIGEN_DESTINO
        ,P_BENEFICIARIOS.BFU_VALOR_USD
        ,P_BENEFICIARIOS.BFU_TIPO_CAMBIO
        ,P_BENEFICIARIOS.BFU_ENTIDAD
        ,P_BENEFICIARIOS.BFU_NUMERO_CUENTA_ENTIDAD
        ,CASE  WHEN TRIM(P_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA) = '36272171' THEN
            'USD'
          WHEN TRIM(P_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA) = '12565382' THEN      
            'EUR'
          WHEN TRIM(P_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA) = '12565412' THEN    
            'GBP'
          WHEN TRIM(P_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA) = '12565390' THEN    
            'JPY'   
          WHEN TRIM(P_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA) = '12565404' THEN
            'CAD'     
         END  
        ,P_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA
        ,P_BENEFICIARIOS.BFU_ENTIDAD_ENVIA_RECIBE
        ,P_BENEFICIARIOS.BFU_INTERMEDIARO_ENV_REC
        ,P_BENEFICIARIOS.BFU_PAI_COD_INT_ENV_REC
        ,P_BENEFICIARIOS.BFU_CIUDAD_INT_ENVIA_RECIBE
        ,P_BENEFICIARIOS.BFU_PAI_CODIGO_ENV_REC
        ,P_BENEFICIARIOS.BFU_CIUDAD_ENVIA_RECIBE
      );
   END IF;


   IF P_FORMULARIO = 4  THEN
      INSERT INTO BENEFICIARIOS_FORMULARIO_CUA(
         BFC_CONSECUTIVO
        ,BFC_VALOR
        ,BFC_TERMINAL_COMPLEMENTA
        ,BFC_USUARIO_COMPLEMENTA
        ,BFC_FECHA_COMPLEMENTA
        ,BFC_FOC_DCA_NUMERO_DECLARACION
        ,BFC_BEX_MNEMONICO
        ,BFC_CLN_TIPO_MOVIMIENTO
        ,BFC_CLN_NUM_NUMERO
        ,BFC_PRIMER_APELLIDO
        ,BFC_SEGUNDO_APELLIDO
        ,BFC_NOMBRE
        ,BFC_OTROS_NOMBRE
        ,BFC_RAZON_SOCIAL
        ,BFC_TIPO_ID
        ,BFC_NUMERO_IDENTIFICACION
        ,BFC_PAI_CODIGO
        ,BFC_CIUDAD_ORIGEN_DESTINO 
        ,BFC_VALOR_USD
        ,BFC_TIPO_CAMBIO
        ,BFC_ENTIDAD
        ,BFC_NUMERO_CUENTA_ENTIDAD
        ,BFC_MDI_MNEMONICO
        ,BFC_NRO_CUENTA_BANCARIA
        ,BFC_ENTIDAD_ENVIA_RECIBE
        ,BFC_INTERMEDIARO_ENV_REC
        ,BFC_PAI_COD_INT_ENV_REC
        ,BFC_CIUDAD_INT_ENVIA_RECIBE
        ,BFC_PAI_CODIGO_ENV_REC
        ,BFC_CIUDAD_ENVIA_RECIBE
    )
      VALUES (
         BFC_SEQ.NEXTVAL
        ,P_BENEFICIARIOS.BFU_VALOR
        ,P_BENEFICIARIOS.BFU_TERMINAL_COMPLEMENTA
        ,P_BENEFICIARIOS.BFU_USUARIO_COMPLEMENTA
        ,P_BENEFICIARIOS.BFU_FECHA_COMPLEMENTA
        ,P_BENEFICIARIOS.BFU_FOU_DCA_NUMERO_DECLARACION
        ,P_BENEFICIARIOS.BFU_BEX_MNEMONICO
        ,P_BENEFICIARIOS.BFU_CLN_TIPO_MOVIMIENTO
        ,P_BENEFICIARIOS.BFU_CLN_NUM_NUMERO
        ,P_BENEFICIARIOS.BFU_PRIMER_APELLIDO
        ,P_BENEFICIARIOS.BFU_SEGUNDO_APELLIDO
        ,P_BENEFICIARIOS.BFU_NOMBRE
        ,P_BENEFICIARIOS.BFU_OTROS_NOMBRE
        ,P_BENEFICIARIOS.BFU_RAZON_SOCIAL
        ,V_TIPO_ID
        ,V_NUM_IDE
        ,P_BENEFICIARIOS.BFU_PAI_CODIGO
        ,P_BENEFICIARIOS.BFU_CIUDAD_ORIGEN_DESTINO
        ,P_BENEFICIARIOS.BFU_VALOR_USD
        ,P_BENEFICIARIOS.BFU_TIPO_CAMBIO
        ,P_BENEFICIARIOS.BFU_ENTIDAD
        ,P_BENEFICIARIOS.BFU_NUMERO_CUENTA_ENTIDAD
        ,CASE  WHEN TRIM(P_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA) = '36272171' THEN
            'USD'
          WHEN TRIM(P_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA) = '12565382' THEN      
            'EUR'
          WHEN TRIM(P_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA) = '12565412' THEN    
            'GBP'
          WHEN TRIM(P_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA) = '12565390' THEN    
            'JPY'   
          WHEN TRIM(P_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA) = '12565404' THEN
            'CAD'     
         END
        ,P_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA
       ,P_BENEFICIARIOS.BFU_ENTIDAD_ENVIA_RECIBE
       ,P_BENEFICIARIOS.BFU_INTERMEDIARO_ENV_REC
       ,P_BENEFICIARIOS.BFU_PAI_COD_INT_ENV_REC
       ,P_BENEFICIARIOS.BFU_CIUDAD_INT_ENVIA_RECIBE
       ,P_BENEFICIARIOS.BFU_PAI_CODIGO_ENV_REC
       ,P_BENEFICIARIOS.BFU_CIUDAD_ENVIA_RECIBE
      );
   END IF;

   IF P_FORMULARIO = 5  THEN
      INSERT INTO BENEFICIARIOS_FORMULARIO_CIN(
         BFI_CONSECUTIVO
        ,BFI_VALOR
        ,BFI_TERMINAL_COMPLEMENTA
        ,BFI_USUARIO_COMPLEMENTA
        ,BFI_FECHA_COMPLEMENTA
        ,BFI_FOI_DCA_NUMERO_DECLARACION
        ,BFI_BEX_MNEMONICO
        ,BFI_CLN_TIPO_MOVIMIENTO
        ,BFI_CLN_NUM_NUMERO
        ,BFI_PRIMER_APELLIDO
        ,BFI_SEGUNDO_APELLIDO
        ,BFI_NOMBRE
        ,BFI_OTROS_NOMBRE
        ,BFI_RAZON_SOCIAL
        ,BFI_TIPO_ID
        ,BFI_NUMERO_IDENTIFICACION
        ,BFI_PAI_CODIGO
        ,BFI_CIUDAD_ORIGEN_DESTINO
        ,BFI_VALOR_USD
        ,BFI_TIPO_CAMBIO
        ,BFI_ENTIDAD
        ,BFI_NUMERO_CUENTA_ENTIDAD
        ,BFI_MDI_MNEMONICO
        ,BFI_NRO_CUENTA_BANCARIA
        ,BFI_ENTIDAD_ENVIA_RECIBE
        ,BFI_INTERMEDIARO_ENV_REC
        ,BFI_PAI_COD_INT_ENV_REC
        ,BFI_CIUDAD_INT_ENVIA_RECIBE
        ,BFI_PAI_CODIGO_ENV_REC
        ,BFI_CIUDAD_ENVIA_RECIBE)
      VALUES (
         BFI_SEQ.NEXTVAL
        ,P_BENEFICIARIOS.BFU_VALOR
        ,P_BENEFICIARIOS.BFU_TERMINAL_COMPLEMENTA
        ,P_BENEFICIARIOS.BFU_USUARIO_COMPLEMENTA
        ,P_BENEFICIARIOS.BFU_FECHA_COMPLEMENTA
        ,P_BENEFICIARIOS.BFU_FOU_DCA_NUMERO_DECLARACION
        ,P_BENEFICIARIOS.BFU_BEX_MNEMONICO
        ,P_BENEFICIARIOS.BFU_CLN_TIPO_MOVIMIENTO
        ,P_BENEFICIARIOS.BFU_CLN_NUM_NUMERO
        ,P_BENEFICIARIOS.BFU_PRIMER_APELLIDO
        ,P_BENEFICIARIOS.BFU_SEGUNDO_APELLIDO
        ,P_BENEFICIARIOS.BFU_NOMBRE
        ,P_BENEFICIARIOS.BFU_OTROS_NOMBRE
        ,P_BENEFICIARIOS.BFU_RAZON_SOCIAL
        ,V_TIPO_ID
        ,V_NUM_IDE
        ,P_BENEFICIARIOS.BFU_PAI_CODIGO
        ,P_BENEFICIARIOS.BFU_CIUDAD_ORIGEN_DESTINO
        ,P_BENEFICIARIOS.BFU_VALOR_USD
        ,P_BENEFICIARIOS.BFU_TIPO_CAMBIO
        ,P_BENEFICIARIOS.BFU_ENTIDAD
        ,P_BENEFICIARIOS.BFU_NUMERO_CUENTA_ENTIDAD
        ,CASE  WHEN TRIM(P_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA) = '36272171' THEN
            'USD'
          WHEN TRIM(P_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA) = '12565382' THEN      
            'EUR'
          WHEN TRIM(P_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA) = '12565412' THEN    
            'GBP'
          WHEN TRIM(P_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA) = '12565390' THEN    
            'JPY'   
          WHEN TRIM(P_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA) = '12565404' THEN
            'CAD'     
         END
        ,P_BENEFICIARIOS.BFU_NRO_CUENTA_BANCARIA
        ,P_BENEFICIARIOS.BFU_ENTIDAD_ENVIA_RECIBE
        ,P_BENEFICIARIOS.BFU_INTERMEDIARO_ENV_REC
        ,P_BENEFICIARIOS.BFU_PAI_COD_INT_ENV_REC
        ,P_BENEFICIARIOS.BFU_CIUDAD_INT_ENVIA_RECIBE   
        ,P_BENEFICIARIOS.BFU_PAI_CODIGO_ENV_REC
        ,P_BENEFICIARIOS.BFU_CIUDAD_ENVIA_RECIBE
      );
   END IF;

   DBMS_OUTPUT.PUT_LINE('TERMINE PPROCEDIMIENTO '||P_FORMULARIO||'-'||P_BENEFICIARIOS.BFU_FOU_DCA_NUMERO_DECLARACION);
    EXCEPTION WHEN OTHERS THEN
      DBMS_OUTPUT.PUT_LINE('ERROR EN PR_CREAR_BENEFICIARIOS '||SQLERRM);
      RAISE_APPLICATION_ERROR(-20001,'Error P_CREAR_BENEFICIARIOS:'||P_FORMULARIO||'-'||P_BENEFICIARIOS.BFU_FOU_DCA_NUMERO_DECLARACION||' '||SQLERRM );

END PR_CREAR_BENEFICIARIOS;

FUNCTION FN_VALIDA_CARGUE_COM_BEN RETURN BOOLEAN IS
  V_NUMERO NUMBER(5);
  V_TOTAL  NUMBER(5);
BEGIN
   /* BENEFICIARIOS UNO*/
   BEGIN
      V_NUMERO := 0;
      SELECT COUNT(*)
      INTO V_NUMERO
      FROM BENEFICIARIOS_FORMULARIO_UNO
      WHERE TRUNC(BFU_FECHA_COMPLEMENTA) = TRUNC(SYSDATE);

      V_NUMERO := NVL(V_NUMERO,0);
      V_TOTAL := V_TOTAL+V_NUMERO ;
   END;

   BEGIN
      V_NUMERO := 0;
      SELECT COUNT(*)
      INTO V_NUMERO
      FROM BENEFICIARIOS_FORMULARIO_DOS
      WHERE TRUNC(BFD_FECHA_COMPLEMENTA) = TRUNC(SYSDATE);

      V_NUMERO := NVL(V_NUMERO,0);
      V_TOTAL := V_TOTAL+V_NUMERO ;
   END;

   BEGIN
      V_NUMERO := 0;
      SELECT COUNT(*)
      INTO V_NUMERO
      FROM BENEFICIARIOS_FORMULARIO_TRE
      WHERE TRUNC(BFT_FECHA_COMPLEMENTA) = TRUNC(SYSDATE);

      V_NUMERO := NVL(V_NUMERO,0);
      V_TOTAL := V_TOTAL+V_NUMERO ;
   END;

   BEGIN
      V_NUMERO := 0;
      SELECT COUNT(*)
      INTO V_NUMERO
      FROM BENEFICIARIOS_FORMULARIO_CUA
      WHERE TRUNC(BFC_FECHA_COMPLEMENTA) = TRUNC(SYSDATE);

      V_NUMERO := NVL(V_NUMERO,0);
      V_TOTAL := V_TOTAL+V_NUMERO ;
   END;

   BEGIN
      V_NUMERO := 0;
      SELECT COUNT(*)
      INTO V_NUMERO
      FROM BENEFICIARIOS_FORMULARIO_CIN
      WHERE TRUNC(BFI_FECHA_COMPLEMENTA) = TRUNC(SYSDATE);

      V_NUMERO := NVL(V_NUMERO,0);
      V_TOTAL := V_TOTAL+V_NUMERO ;
   END;

   IF V_TOTAL > 0 THEN
      RETURN(TRUE);
   ELSE
      RETURN(FALSE);
   END IF;

END FN_VALIDA_CARGUE_COM_BEN ;

PROCEDURE PR_REVERSAR_CARGUE_COM_BEN(P_FECHA DATE DEFAULT NULL) IS
BEGIN
  /* BENEFICIARIOS UNO*/
   BEGIN
      DELETE  BENEFICIARIOS_FORMULARIO_UNO
      WHERE TRUNC(BFU_FECHA_COMPLEMENTA) = TRUNC(SYSDATE);
   END;

   BEGIN
      DELETE  BENEFICIARIOS_FORMULARIO_DOS
      WHERE TRUNC(BFD_FECHA_COMPLEMENTA) = TRUNC(SYSDATE);
   END;

   BEGIN
      DELETE  BENEFICIARIOS_FORMULARIO_TRE
      WHERE TRUNC(BFT_FECHA_COMPLEMENTA) = TRUNC(SYSDATE);
   END;

   BEGIN
      DELETE  BENEFICIARIOS_FORMULARIO_CUA
      WHERE TRUNC(BFC_FECHA_COMPLEMENTA) = TRUNC(SYSDATE);
   END;

   BEGIN
      DELETE  BENEFICIARIOS_FORMULARIO_CIN
      WHERE TRUNC(BFI_FECHA_COMPLEMENTA) = TRUNC(SYSDATE);
   END;

   BEGIN
      DELETE  BENEFICIARIOS_FORMULARIO_UIAF
      WHERE TRUNC(BFA_FECHA_COMPLEMENTA) = TRUNC(SYSDATE);
   END;

   BEGIN
      DELETE  TMP_CARGUES_BENEFICARIOS;
   END;                                      

   COMMIT;

   EXCEPTION WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20001,'Error PR_REVERSAR_CARGUE_COM_BEN '||SQLERRM );


END PR_REVERSAR_CARGUE_COM_BEN;

PROCEDURE PR_ENVIO_MAIL_COMPLEMENTACION IS
    CONN                    UTL_SMTP.CONNECTION;
    REQ                     UTL_HTTP.REQ;  
    RESP                    UTL_HTTP.RESP;
    DATA                    RAW(200);
    V_NOMBRE_MAIL           VARCHAR2(200);
    TEXTO_CUERPO            VARCHAR2(4000);
    V_ARCHIVO_DETALLE       VARCHAR2(500);
    CONT                    NUMBER(3);

BEGIN 
  SELECT COUNT(*) CONT
  INTO CONT 
  FROM  NEGOCIOS_INTERNACIONALES
  WHERE  NIN_PAGO IS NOT NULL 
  AND NIN_MONETIZACION IS NOT NULL 
  AND NIN_COMPLEMENTACION IS NULL;

   V_NOMBRE_MAIL := 'jmaldonado@corredores.com;crojas@corredores.com;jbeltran@corredores.com;jtaborda@corredores.com;ecanon@corredores.com;jlrodriguez@corredores.com';
   TEXTO_CUERPO := 'EXISTEN '|| CONT || ' CUENTAS DE COBRO DE CORRESPONSALIAS CON PAGO  Y MONETIZACION, POR FAVOR COMPLEMENTAR:  ' ||CHR(13)||
                    TO_CHAR(SYSDATE,'DD/MM/YYYY HH24:MI:SS');


   CONN := P_MAIL.BEGIN_MAIL(
   SENDER     =>  'administrador@corredores.com',
   RECIPIENTS => V_NOMBRE_MAIL,
   SUBJECT    => 'GENERADO PAGO Y MONETIZACION CORRESPONSALIAS - MODULO NEGOCIOS INTERNACIONALES - CUCOME',
   MIME_TYPE  => P_MAIL.MULTIPART_MIME_TYPE);
   P_MAIL.ATTACH_TEXT(
                           CONN      => CONN,
                           DATA      => TEXTO_CUERPO,
                           MIME_TYPE => 'TEXT/HTML');
                           p_mail.end_mail( conn => conn );   

END PR_ENVIO_MAIL_COMPLEMENTACION;

--Ordenes Divisas para proyecto declaraciones WPG INICIAL
PROCEDURE P_CONSULTAR_ORDENES(P_ORD_TIPO_ORDEN ORDENES_DIVISAS.ORD_TIPO_ORDEN%TYPE,
             P_ORD_FECHA_COLOCACION VARCHAR2, 
             P_ORD_FIRMA_DELEGADA ORDENES_DIVISAS.ORD_FIRMA_DELEGADA%TYPE DEFAULT NULL,
             io_cursor IN OUT O_CURSOR)
IS
BEGIN
  OPEN io_cursor FOR
  SELECT 
     ORD_CONSECUTIVO ORD_OME_CONSECUTIVO
    ,ORD_TIPO_ORDEN --TIPO ORDEN C, V
    ,TO_CHAR(ORD_FECHA_APROBACION,'yyyy-mm-dd') ORD_FECHA_APROBACION
    ,TO_CHAR(ORD_FECHA_CUMPLIMIENTO,'yyyy-mm-dd') ORD_FECHA_CUMPLIMIENTO
    ,ORD_COLOCADO_POR
    ,PER_NOMBRE
    ,ORD_CLI_PER_NUM_IDEN
    ,ORD_CLI_PER_TID_CODIGO
    ,PER_DIGITO_CONTROL
    ,ORD_EOF_CODIGO --ESTADO ORDEN APR
    ,TO_CHAR(ORD_FECHA_COLOCACION,'yyyy-mm-dd') ORD_FECHA_COLOCACION
    ,CASE NVL(ORD_BMO_MNEMONICO_FX,'0') WHEN '0' THEN 'USD' ELSE ORD_BMO_MNEMONICO_FX END ORD_BMO_MNEMONICO  --CODIGO MONEDA
    ,CASE NVL(ORD_BMO_MNEMONICO_FX,'0') WHEN '0' THEN TRIM(TO_CHAR(ORD_VALOR_DOLARES,'99,999,999,999,999,999,999.00')) ELSE TRIM(TO_CHAR(ORD_VALOR_FX,'99,999,999,999,999,999,999.00')) END VALOR_MONEDA --VALOR MONEDA
    ,CASE NVL(ORD_BMO_MNEMONICO_FX,'0') WHEN '0' THEN '1' ELSE TRIM(TO_CHAR(ORD_TIPO_CAMBIO,'99,999,999,999,990.0000000000000000')) END TIPO_CAMBIO_USD --TIPO DE CAMBIO A USD
    ,TRIM(TO_CHAR(ORD_VALOR_DOLARES,'99,999,999,999,999,999,999.00')) ORD_VALOR_DOLARES --VALOR DOLARES
    ,TRIM(TO_CHAR(ORD_TASA_CAMBIO,'99,999,999,999,999,999,990.00000000')) ORD_TASA_CAMBIO --TIPO CAMBIO PESOS
    ,TRIM(TO_CHAR(ORD_VALOR_PESOS,'99,999,999,999,999,999,999.00')) ORD_VALOR_PESOS
    ,ORD_PVI_ID 
  ,'4585' NUMERAL
  FROM ORDENES_DIVISAS
  INNER JOIN CLIENTES ON ORD_CLI_PER_NUM_IDEN = CLI_PER_NUM_IDEN AND ORDENES_DIVISAS.ORD_CLI_PER_TID_CODIGO = CLIENTES.CLI_PER_TID_CODIGO
  INNER JOIN FILTRO_PERSONAS ON CLI_PER_NUM_IDEN = PER_NUM_IDEN AND CLI_PER_TID_CODIGO = PER_TID_CODIGO 
  WHERE ORD_EOF_CODIGO = 'APR' 
       AND ORD_FIRMA_DELEGADA = 'S' 
       AND ORD_TIPO_ORDEN IN ('V') 
       AND ORD_FECHA_COLOCACION BETWEEN TO_DATE(P_ORD_FECHA_COLOCACION,'DD/MM/YYYY') AND TO_DATE(P_ORD_FECHA_COLOCACION,'DD/MM/YYYY') + 1
       --AND ORD_FECHA_COLOCACION > TRUNC(SYSDATE) - 1
  UNION ALL 
  --Ordenes de compra capital
  SELECT 
     ORD_CONSECUTIVO ORD_OME_CONSECUTIVO
    ,ORD_TIPO_ORDEN --TIPO ORDEN C, V
    ,TO_CHAR(ORD_FECHA_APROBACION,'yyyy-mm-dd') ORD_FECHA_APROBACION
    ,TO_CHAR(ORD_FECHA_CUMPLIMIENTO,'yyyy-mm-dd') ORD_FECHA_CUMPLIMIENTO
    ,ORD_COLOCADO_POR
    ,PER_NOMBRE
    ,ORD_CLI_PER_NUM_IDEN
    ,ORD_CLI_PER_TID_CODIGO
    ,PER_DIGITO_CONTROL
    ,ORD_EOF_CODIGO --ESTADO ORDEN APR
    ,TO_CHAR(ORD_FECHA_COLOCACION,'yyyy-mm-dd') ORD_FECHA_COLOCACION
    ,CASE NVL(ORD_BMO_MNEMONICO_FX_C,'0') WHEN '0' THEN 'USD' ELSE ORD_BMO_MNEMONICO_FX_C END ORD_BMO_MNEMONICO --CODIGO MONEDA
    ,TRIM(TO_CHAR(ORD_VALOR_CAPITAL,'99,999,999,999,999,999,999.00')) VALOR_MONEDA --VALOR MONEDA
    ,CASE NVL(ORD_BMO_MNEMONICO_FX_C,'0') WHEN '0' THEN '1' ELSE TRIM(TO_CHAR(ORD_TIPO_CAMBIO_FX_C,'99,999,999,999,990.0000000000000000')) END TIPO_CAMBIO_USD --TIPO DE CAMBIO A USD
    ,CASE NVL(ORD_BMO_MNEMONICO_FX_C,'0') WHEN '0' THEN TRIM(TO_CHAR(ORD_VALOR_CAPITAL,'99,999,999,999,999,999,999.00')) ELSE TRIM(TO_CHAR((ORD_VALOR_CAPITAL / ORD_TIPO_CAMBIO_FX_C),'99,999,999,999,999,999,999.00')) END ORD_VALOR_DOLARES --VALOR DOLARES
    ,TRIM(TO_CHAR(ORD_TASA_CAMBIO,'99,999,999,999,999,999,990.00000000')) ORD_TASA_CAMBIO --TIPO CAMBIO PESOS
    ,CASE NVL(ORD_BMO_MNEMONICO_FX_C,'0') WHEN '0' THEN TRIM(TO_CHAR((ORD_VALOR_CAPITAL*ORD_TASA_CAMBIO),'99,999,999,999,999,999,999.00')) ELSE  TRIM(TO_CHAR(((ORD_VALOR_CAPITAL / ORD_TIPO_CAMBIO_FX_C) * ORD_TASA_CAMBIO),'99,999,999,999,999,999,999.00')) END ORD_VALOR_PESOS
    ,ORD_PVI_ID 
  ,'4058' NUMERAL
  FROM ORDENES_DIVISAS
  INNER JOIN CLIENTES ON ORD_CLI_PER_NUM_IDEN = CLI_PER_NUM_IDEN AND ORDENES_DIVISAS.ORD_CLI_PER_TID_CODIGO = CLIENTES.CLI_PER_TID_CODIGO
  INNER JOIN FILTRO_PERSONAS ON CLI_PER_NUM_IDEN = PER_NUM_IDEN AND CLI_PER_TID_CODIGO = PER_TID_CODIGO 
  WHERE ORD_EOF_CODIGO = 'APR' AND ORD_FIRMA_DELEGADA = 'S' AND ORD_TIPO_ORDEN IN ('C') AND ORD_FECHA_COLOCACION BETWEEN TO_DATE(P_ORD_FECHA_COLOCACION,'DD/MM/YYYY') AND TO_DATE(P_ORD_FECHA_COLOCACION,'DD/MM/YYYY') + 1 AND ORD_VALOR_CAPITAL > 0
  UNION ALL 
  --Ordenes de compra rendimientos
  SELECT 
     ORD_CONSECUTIVO ORD_OME_CONSECUTIVO
    ,ORD_TIPO_ORDEN --TIPO ORDEN C, V
    ,TO_CHAR(ORD_FECHA_APROBACION,'yyyy-mm-dd') ORD_FECHA_APROBACION
    ,TO_CHAR(ORD_FECHA_CUMPLIMIENTO,'yyyy-mm-dd') ORD_FECHA_CUMPLIMIENTO
    ,ORD_COLOCADO_POR
    ,PER_NOMBRE
    ,ORD_CLI_PER_NUM_IDEN
    ,ORD_CLI_PER_TID_CODIGO
    ,PER_DIGITO_CONTROL
    ,ORD_EOF_CODIGO --ESTADO ORDEN APR
    ,TO_CHAR(ORD_FECHA_COLOCACION,'yyyy-mm-dd') ORD_FECHA_COLOCACION
    ,CASE NVL(ORD_BMO_MNEMONICO_FX_C,'0') WHEN '0' THEN 'USD' ELSE ORD_BMO_MNEMONICO_FX_C END ORD_BMO_MNEMONICO  --CODIGO MONEDA
    ,TRIM(TO_CHAR(ORD_VALOR_RENDIMIENTOS,'99,999,999,999,999,999,999.00')) VALOR_MONEDA --VALOR MONEDA
    ,CASE NVL(ORD_BMO_MNEMONICO_FX_C,'0') WHEN '0' THEN '1' ELSE TRIM(TO_CHAR(ORD_TIPO_CAMBIO_FX_C,'99,999,999,999,990.0000000000000000')) END TIPO_CAMBIO_USD --TIPO DE CAMBIO A USD
    ,CASE NVL(ORD_BMO_MNEMONICO_FX_C,'0') WHEN '0' THEN TRIM(TO_CHAR(ORD_VALOR_RENDIMIENTOS,'99,999,999,999,999,999,999.00')) ELSE TRIM(TO_CHAR((ORD_VALOR_RENDIMIENTOS / ORD_TIPO_CAMBIO_FX_C),'99,999,999,999,999,999,999.00')) END ORD_VALOR_DOLARES --VALOR DOLARES
    ,TRIM(TO_CHAR(ORD_TASA_CAMBIO,'99,999,999,999,999,999,990.00000000')) ORD_TASA_CAMBIO --TIPO CAMBIO PESOS
    ,CASE NVL(ORD_BMO_MNEMONICO_FX_C,'0') WHEN '0' THEN TRIM(TO_CHAR((ORD_VALOR_RENDIMIENTOS*ORD_TASA_CAMBIO),'99,999,999,999,999,999,999.00')) ELSE  TRIM(TO_CHAR(((ORD_VALOR_RENDIMIENTOS / ORD_TIPO_CAMBIO_FX_C) * ORD_TASA_CAMBIO),'99,999,999,999,999,999,999.00')) END ORD_VALOR_PESOS
    ,ORD_PVI_ID 
  ,'1595' NUMERAL
  FROM ORDENES_DIVISAS
  INNER JOIN CLIENTES ON ORD_CLI_PER_NUM_IDEN = CLI_PER_NUM_IDEN AND ORDENES_DIVISAS.ORD_CLI_PER_TID_CODIGO = CLIENTES.CLI_PER_TID_CODIGO
  INNER JOIN FILTRO_PERSONAS ON CLI_PER_NUM_IDEN = PER_NUM_IDEN AND CLI_PER_TID_CODIGO = PER_TID_CODIGO 
  WHERE ORD_EOF_CODIGO = 'APR' AND ORD_FIRMA_DELEGADA = 'S' AND ORD_TIPO_ORDEN IN ('C') AND ORD_FECHA_COLOCACION BETWEEN TO_DATE(P_ORD_FECHA_COLOCACION,'DD/MM/YYYY') AND TO_DATE(P_ORD_FECHA_COLOCACION,'DD/MM/YYYY') + 1 AND ORD_VALOR_RENDIMIENTOS > 0;
END P_CONSULTAR_ORDENES;

-- SORTIZ INVERSIONES FILIALES
FUNCTION PR_VALOR_FILIAL (P_FECHA DATE) RETURN NUMBER IS
   CURSOR C_FILIAL IS
     SELECT FCOR_MNEMONICO
       FROM FILIALES_CORREDORES
      ;
   C_FIL C_FILIAL%ROWTYPE;

    CURSOR C_VALOR_INVERS (FILIAL VARCHAR2) IS
        SELECT I.IFC_FACTOR
        FROM INVERSION_FILIALES_CORREDORES I
        WHERE I.IFC_FECHA_APLICACION <= P_FECHA
        AND I.IFC_FCOR_MNEMONICO = FILIAL
        AND I.IFC_FECHA_APLICACION = (SELECT MAX(I1.IFC_FECHA_APLICACION)
                                       FROM INVERSION_FILIALES_CORREDORES I1
                                       WHERE I1.IFC_FCOR_MNEMONICO = I.IFC_FCOR_MNEMONICO
                                       AND I1.IFC_FECHA_APLICACION <=  P_FECHA
                                       );
   VALOR_INVERS  NUMBER;
   VALOR NUMBER;

BEGIN

   VALOR := 0;
   OPEN C_FILIAL;
   FETCH C_FILIAL INTO C_FIL;
   WHILE C_FILIAL%FOUND  LOOP

      OPEN C_VALOR_INVERS(C_FIL.FCOR_MNEMONICO);
      FETCH C_VALOR_INVERS INTO VALOR_INVERS;
      IF NVL(VALOR_INVERS,0) != 0 THEN
         VALOR := VALOR + VALOR_INVERS;
      END IF;
      CLOSE C_VALOR_INVERS;

   FETCH C_FILIAL INTO C_FIL;
   END LOOP;
   CLOSE C_FILIAL;

   RETURN (NVL(VALOR,0));

END PR_VALOR_FILIAL;
  -------------------------------------------------------------------------------
   -- OMORA ARBITRAJE INTERNACIONAL PP --
   -------------------------------------------------------------------------------
   PROCEDURE PR_INSERTA_MOV_BAN_EXTERIOR(P_BEX_MNEMONICO         MOVIMIENTOS_BANCARIOS_EXTERIOR.MBE_CBE_BEX_MNEMONICO%TYPE
                                        ,P_NUMERO_CUENTA         MOVIMIENTOS_BANCARIOS_EXTERIOR.MBE_CBE_NUMERO_CUENTA%TYPE
                                        ,P_TME_MNEMONICO         MOVIMIENTOS_BANCARIOS_EXTERIOR.MBE_TME_MNEMONICO%TYPE
                                        ,P_MONTO                 MOVIMIENTOS_BANCARIOS_EXTERIOR.MBE_MONTO%TYPE
                                        ,P_CONCILIADO            MOVIMIENTOS_BANCARIOS_EXTERIOR.MBE_CONCILIADO%TYPE
                                        ,P_DETALLE               MOVIMIENTOS_BANCARIOS_EXTERIOR.MBE_DETALLE%TYPE
                                        ,P_CONTROL_TRANSFERENCIA MOVIMIENTOS_BANCARIOS_EXTERIOR.MBE_CONTROL_TRANSFERENCIA%TYPE
                                        ,P_NUMERO_OPERACION      MOVIMIENTOS_BANCARIOS_EXTERIOR.MBE_OCI_NUMERO_OPERACION%TYPE
                                        ,P_FON_CODIGO            MOVIMIENTOS_BANCARIOS_EXTERIOR.MBE_OCI_FON_CODIGO%TYPE
                                        ,P_ERROR                 OUT VARCHAR2
                                        ,P_RESPUESTA             OUT VARCHAR2) IS

      CURSOR C_TIPO_MOVIMIENTO(P_TME_MNEMONICO VARCHAR2) IS
         SELECT TME.TME_SIGNO,
                TME.TME_DESCRIPCION
           FROM TIPOS_MVTOS_BANCOS_EXTERIOR TME
          WHERE TME.TME_MNEMONICO = P_TME_MNEMONICO;

      P_SIGNO       TIPOS_MVTOS_BANCOS_EXTERIOR.TME_SIGNO%TYPE;
      P_DESCRIPCION TIPOS_MVTOS_BANCOS_EXTERIOR.TME_DESCRIPCION%TYPE;

      CURSOR C_CIERRE(P_BEX_MNEMONICO VARCHAR2, P_NUMERO_CUENTA VARCHAR2) IS
         SELECT 'X'
           FROM CIERRES_CUENTAS_EXTERIOR
          WHERE CCX_CBE_BEX_MNEMONICO = P_BEX_MNEMONICO
            AND CCX_CBE_NUMERO_CUENTA = P_NUMERO_CUENTA
            AND CCX_FECHA >= TRUNC(SYSDATE);
      COND VARCHAR2(1);

      CURSOR C_VALIDA_BANEXT IS
      SELECT 'S'
      FROM MOVIMIENTOS_BANCARIOS_EXTERIOR
      WHERE MBE_FECHA = SYSDATE
      AND MBE_CBE_NUMERO_CUENTA = P_NUMERO_CUENTA
      AND MBE_CBE_BEX_MNEMONICO = P_BEX_MNEMONICO;
      V_EXIS_MOV VARCHAR2(1);

      P_MONTO_FINAL        NUMBER;
      P_FECHA              DATE;
      P_FECHA_CONCILIACION DATE;

   BEGIN
      P_ERROR := 'N';
      P_FECHA := SYSDATE;
       OPEN C_VALIDA_BANEXT;
            FETCH C_VALIDA_BANEXT INTO V_EXIS_MOV;
             IF V_EXIS_MOV = 'S' THEN
               P_FECHA := SYSDATE+0.00002;
             END IF;      
            CLOSE C_VALIDA_BANEXT;
      IF NVL(P_CONCILIADO, 'N') = 'S' THEN
         P_FECHA_CONCILIACION := SYSDATE;
      ELSE
         P_FECHA_CONCILIACION := NULL;
      END IF;

      OPEN C_TIPO_MOVIMIENTO(P_TME_MNEMONICO);
      FETCH C_TIPO_MOVIMIENTO
         INTO P_SIGNO,
              P_DESCRIPCION;

      IF P_SIGNO = 'A' THEN
         P_MONTO_FINAL := ABS(P_MONTO);
      ELSE
         P_MONTO_FINAL := -ABS(P_MONTO);
      END IF;
      CLOSE C_TIPO_MOVIMIENTO;

      OPEN C_CIERRE(P_BEX_MNEMONICO, P_NUMERO_CUENTA);
      FETCH C_CIERRE
         INTO COND;
      CLOSE C_CIERRE;

      IF NVL(COND, ' ') = 'X' THEN
         P_ERROR     := 'S';
         P_RESPUESTA := 'El dia para este banco ya fue cerrado. No puede ingresar movimientos';
      END IF;

      IF P_ERROR = 'N' THEN
         INSERT INTO MOVIMIENTOS_BANCARIOS_EXTERIOR
            (MBE_CBE_BEX_MNEMONICO,
             MBE_CBE_NUMERO_CUENTA,
             MBE_FECHA,
             MBE_TME_MNEMONICO,
             MBE_MONTO,
             MBE_CONCILIADO,
             MBE_DETALLE,
             MBE_FECHA_CONCILIACION,
             MBE_CONTROL_TRANSFERENCIA,
             MBE_OCI_NUMERO_OPERACION,
             MBE_OCI_FON_CODIGO)
         VALUES
            (P_BEX_MNEMONICO,
             P_NUMERO_CUENTA,
             P_FECHA,
             P_TME_MNEMONICO,
             P_MONTO_FINAL,
             P_CONCILIADO,
             P_DETALLE,
             P_FECHA_CONCILIACION,
             P_CONTROL_TRANSFERENCIA,
             P_NUMERO_OPERACION,
             P_FON_CODIGO);
      END IF;

   EXCEPTION
      WHEN OTHERS THEN
         ROLLBACK;
         P_ERROR     := 'S';
         P_RESPUESTA := 'ERROR EN PR_INSERTA_MOV_BAN_EXTERIOR:' || SQLERRM;
         RAISE_APPLICATION_ERROR(-20020, P_RESPUESTA);
   END PR_INSERTA_MOV_BAN_EXTERIOR;
END P_DIVISAS;

/

  GRANT EXECUTE ON "PROD"."P_DIVISAS" TO "COE_RECURSOS";
  GRANT EXECUTE ON "PROD"."P_DIVISAS" TO "RESOURCE";
