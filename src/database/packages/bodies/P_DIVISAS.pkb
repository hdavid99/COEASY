                                P_TIPO_MOVIMIENTO      IN VARCHAR2,
                                P_VALOR_DOLARES        IN NUMBER,
                                P_TASA_NEGOCIACION     IN NUMBER,
                                P_VALORMONEDAFX        IN NUMBER,
                                P_BMOFX                IN VARCHAR2,
                                P_TASA_CONVERSIONFX    IN NUMBER,
                                P_VALOR_PESOS          IN NUMBER,
                                P_GASTOS_ENVIO         IN NUMBER,
                                P_IVA_GASTOS_ENVIO     IN NUMBER,
                                P_VALOR_RETEFUENTE     IN NUMBER,
                                P_IVA_VENTA            IN NUMBER,
                                P_VALOR_PESOS_NETOS    IN NUMBER,
                                P_TASA_NEGOCIO_NETA    IN NUMBER,
                                P_TODO_COSTO           IN VARCHAR2,
                                P_CARGO_CUENTA         IN VARCHAR2,
                                P_MONTO_CARGO_CUENTA   IN NUMBER,
                                P_CARGO_USD_CLIENTE    IN VARCHAR2,
                                P_CARGO_CUENTA_INVEXT  IN VARCHAR2,
                                P_TERMINAL_OPERACION   IN VARCHAR2,
                                P_NEXT_DAY             IN NUMBER,
                                P_FECHA_CUM_NEXT_DAY   IN VARCHAR2,
                                P_MEDIO_RECEPCION      IN VARCHAR2,
                                P_HORA_RECEPCION       IN VARCHAR2,
                                P_DETALLE_RECEPCION    IN VARCHAR,
                                P_EXECENTO_RETENCION   IN VARCHAR2,
                                P_POSICION_PROPIA      IN VARCHAR2,
                                P_TASA_NEG_MESA        IN NUMBER,
                                P_PORCENTAJE_MESA      IN NUMBER,
                                P_PORCENTAJE_COMERCIAL IN NUMBER,
                                P_MARGEN_COMISION      IN NUMBER,                                
                                P_ID_ORDEN             OUT NUMBER,
                                P_CLOB                 OUT CLOB)  IS



   CURSOR SALDO IS
      SELECT CDV_SALDO_RESTRINGIDO
      FROM CUENTAS_CLIENTES_DIVISAS
      WHERE CDV_CCC_CLI_PER_NUM_IDEN = P_CLI_NUM_IDEN
        AND CDV_CCC_CLI_PER_TID_CODIGO =  P_CLI_TID_CODIGO
        AND CDV_CCC_NUMERO_CUENTA = P_CUENTA_CORREDORES
        AND CDV_BMO_MNEMONICO = 'DOLAR';     --ORDDIV.ORD_BMO_MNEMONICO;



   CURSOR COL IS
      SELECT SUM(ORD_VALOR_DOLARES)
      FROM ORDENES_DIVISAS
      WHERE ORD_TIPO_ORDEN IN ('C','T')
        AND ORD_EOF_CODIGO = 'COL'
        AND ORD_INDICADOR_RESTRINGIDO = 'S'
        AND ORD_CLI_PER_NUM_IDEN = P_CLI_NUM_IDEN
        AND ORD_CLI_PER_TID_CODIGO = P_CLI_TID_CODIGO
        AND ORD_CCC_NUMERO_CUENTA =  P_CUENTA_CORREDORES
        AND ORD_BMO_MNEMONICO = P_BMO_MNEMONICO;

  CURSOR VERIFICA_PRODUCTO IS
    SELECT CUENTAS_CLIENTE_CORREDORES.*,'SP' CCP_PRO_MNEMONICO
    FROM CUENTAS_CLIENTE_CORREDORES
    WHERE CCC_CLI_PER_NUM_IDEN = P_CLI_NUM_IDEN
      AND CCC_CLI_PER_TID_CODIGO = P_CLI_TID_CODIGO
      AND CCC_NUMERO_CUENTA = P_CUENTA_CORREDORES;

  CURSOR RETENCION IS
    SELECT NVL(CLI_SUJETO_RTEFTE,'N') CLI_SUJETO_RTEFTE, CLI_PERFIL_RIESGO,CLI_PROFESIONAL
    FROM CLIENTES
    WHERE CLI_PER_NUM_IDEN = P_CLI_NUM_IDEN
      AND CLI_PER_TID_CODIGO = P_CLI_TID_CODIGO;


   CURSOR VALIDA_COMERCIAL IS
    SELECT  PER_TID_CODIGO,
            PER_NUM_IDEN,
            PER_INICIALES_USUARIO,
            PER_SUC_CODIGO,
            SUC_NOMBRE,
            PER_TIPO_COMERCIAL
    FROM  SUCURSALES,PERSONAS
    WHERE SUC_CODIGO          = PER_SUC_CODIGO
      AND PER_SUC_CODIGO      = SUC_CODIGO
      AND PER_NUM_IDEN        = P_PER_NUN_IDEN
      AND PER_TID_CODIGO      = P_TID_CODIGO;


  CURSOR SUMA_DOLARES_PXC IS
    SELECT SUM(PXC_VALOR_DOLARES) PXC_VALOR_DOLARES
    FROM PAGOS_EXTERIOR_CODIVISAS  -- OJO ESTO SE VALIDA UNA VEZ SE INSERT LOS ORDENES DE PAGO EXTERIOR
    WHERE PXC_IDCODIVISAS = P_IDCODIVISAS
      AND PXC_ESTADO  = 'COL';

   CURSOR SUMA_CARGOS IS
     SELECT SUM(ORC_MONTO) DAC_VALOR
     FROM RECAUDOS_CODIVISAS
     WHERE ORC_IDCODIVISAS = P_IDCODIVISAS;

  CURSOR SUMA_DETALLE_CARGO IS
    SELECT SUM(DAC_VALOR) DAC_VALOR
     FROM DETALLES_CARGO_CODIVISAS
     WHERE DAC_IDCODIVISAS = P_IDCODIVISAS;

   CURSOR NOMBRE_CUENTA IS
     SELECT CCC_NUMERO_CUENTA
           ,CCC_NOMBRE_CUENTA
     FROM   CUENTAS_CLIENTE_CORREDORES
     WHERE  CCC_CLI_PER_NUM_IDEN = P_CLI_NUM_IDEN
     AND    CCC_CLI_PER_TID_CODIGO = P_CLI_TID_CODIGO
     AND    CCC_NUMERO_CUENTA = P_CUENTA_CORREDORES;

  CURSOR TIPO_MOVIMIENTOS IS
    SELECT *
    FROM TIPOS_MVTOS_DIVISAS
    WHERE TMD_MNEMONICO = P_TIPO_MOVIMIENTO;

  CURSOR SALDO_RESTRINGIDO IS
    SELECT * FROM CUENTAS_CLIENTES_DIVISAS
    WHERE CDV_CCC_CLI_PER_NUM_IDEN = P_CLI_NUM_IDEN
      AND CDV_CCC_CLI_PER_TID_CODIGO = P_CLI_TID_CODIGO
      AND CDV_CCC_NUMERO_CUENTA = P_CUENTA_CORREDORES
      AND CDV_BMO_MNEMONICO = 'DOLAR';

  CURSOR CONSECUTIVO(P_SUC_CODIGO NUMBER) IS
      SELECT MAX(ORD_CONSECUTIVO) SIGUIENTE
      FROM   ORDENES_DIVISAS
      WHERE  ORD_SUC_CODIGO = P_SUC_CODIGO;

  CURSOR TRM IS
   SELECT CBM_FECHA, CBM_BMO_MNEMONICO, CBM_VALOR, CBM_VALOR_DOLARES, CBM_VALOR_SPOT
        FROM COTIZACIONES_BASE_MONETARIAS
        WHERE TRUNC(CBM_FECHA) = TRUNC(SYSDATE) AND CBM_BMO_MNEMONICO = 'DOLAR';

   CURSOR CONSECUTIVO_OPE IS
      SELECT MAX(OPE_CONSECUTIVO)
      FROM   ORDENES_PAGOS_EXTERIOR;

   CURSOR OPE_DIVISAS IS
     SELECT
          PXC_ESTADO
         ,PXC_FECHA
         ,PXC_PAGAR_A
         ,PXC_VALOR_DOLARES
         ,PXC_DESTINO
         ,PXC_BENEFICIARIO
         ,PXC_CBX_NUMERO_CUENTA
         ,PXC_CBX_BEX_MNEMONICO
         ,PXC_OCL_CLI_PER_NUM_REL
         ,PXC_OCL_CLI_PER_TID_REL
         ,PXC_IDCODIVISAS
       FROM PAGOS_EXTERIOR_CODIVISAS
       WHERE PXC_IDCODIVISAS =  P_IDCODIVISAS
         AND PXC_ESTADO = 'COL';

   CURSOR CONSEC_OME IS
     SELECT NVL(MAX(OME_CONSECUTIVO), 0) + 1
     FROM OPERACION_DIVISAS_ENTRE_MESAS;

  CURSOR MONEDA_DIV (P_BMO_FX  VARCHAR2) IS
    SELECT *
    FROM BASES_MONETARIAS
    WHERE  BMO_MDI_MNEMONICO = P_BMO_FX;

  CURSOR CONSECUTIVO_ORR(P_NEG_CONSECUTIVO NUMBER, P_SUC_CODIGO NUMBER) IS
      SELECT NVL(MAX(ORR_CONSECUTIVO),0)+1
      FROM   ORDENES_RECAUDO
      WHERE  ORR_NEG_CONSECUTIVO   = P_NEG_CONSECUTIVO
      AND    ORR_SUC_CODIGO        = P_SUC_CODIGO;


  CURSOR CONSECUTIVO_DAU(P_SUC_CODIGO NUMBER,P_NEG_CONSECUTIVO NUMBER) IS
    SELECT NVL(MAX(DAU_CONSECUTIVO),0)+1
    FROM   DETALLES_CARGOS_CUENTAS
    WHERE  DAU_SUC_CODIGO      = P_SUC_CODIGO
    AND    DAU_NEG_CONSECUTIVO = P_NEG_CONSECUTIVO;


  CURSOR  REC_CODIVISAS  IS
    SELECT *
         FROM RECAUDOS_CODIVISAS
         WHERE ORC_IDCODIVISAS  = P_IDCODIVISAS
           AND ORC_ESTADO = 'COL';

  CURSOR DET_CAR_CODIVISAS IS
    SELECT *
    FROM DETALLES_CARGO_CODIVISAS
    WHERE DAC_IDCODIVISAS = P_IDCODIVISAS;


  C_RETENCION           RETENCION%ROWTYPE;
  C_VALIDA_COMERCIAL    VALIDA_COMERCIAL%ROWTYPE;
  C_SUMA_DOLARES_PXC    SUMA_DOLARES_PXC%ROWTYPE;
  C_VERIFICA_PRODUCTO   VERIFICA_PRODUCTO%ROWTYPE;
  C_NOMBRE_CUENTA       NOMBRE_CUENTA%ROWTYPE;
  C_TIPO_MOVIMIENTOS    TIPO_MOVIMIENTOS%ROWTYPE;
  C_SALDO_RESTRINGIDO   SALDO_RESTRINGIDO%ROWTYPE;
  C_OPE_DIVISAS         OPE_DIVISAS%ROWTYPE;
  C_TRM                 TRM%ROWTYPE;
  C_CONSEC_OME          CONSEC_OME%ROWTYPE;
  C_MONEDA_DIV          MONEDA_DIV%ROWTYPE;
  C_REC_CODIVISAS       REC_CODIVISAS%ROWTYPE;
  C_DET_CAR_CODIVISAS   DET_CAR_CODIVISAS%ROWTYPE;

  V_OME_CONSECUTIVO     OPERACION_DIVISAS_ENTRE_MESAS.OME_CONSECUTIVO%TYPE;
  V_NEG_CONSECUTIVO     DETALLES_CARGOS_CUENTAS.DAU_NEG_CONSECUTIVO%TYPE;
  V_SEBRA_COMPENSADO    ORDENES_RECAUDO.ORR_SEBRA_COMPENSADO%TYPE;
  V_OPE_CONSECUTIVO     ORDENES_PAGOS_EXTERIOR.OPE_CONSECUTIVO%TYPE;

  V_OPE_CBX_CLI_PER_NUM_IDEN    ORDENES_PAGOS_EXTERIOR.OPE_CBX_CLI_PER_NUM_IDEN%TYPE;
  V_OPE_CBX_CLI_PER_TID_CODIGO  ORDENES_PAGOS_EXTERIOR.OPE_CBX_CLI_PER_TID_CODIGO%TYPE;
  V_OPE_OCL_CLI_PER_NUM_IDEN    ORDENES_PAGOS_EXTERIOR.OPE_OCL_CLI_PER_NUM_IDEN%TYPE;
  V_OPE_OCL_CLI_PER_TID_CODIGO  ORDENES_PAGOS_EXTERIOR.OPE_OCL_CLI_PER_TID_CODIGO%TYPE;
  V_OPE_OCL_CLI_PER_NUM_REL     ORDENES_PAGOS_EXTERIOR.OPE_OCL_CLI_PER_NUM_REL%TYPE;
  V_OPE_OCL_CLI_PER_TID_REL     ORDENES_PAGOS_EXTERIOR.OPE_OCL_CLI_PER_TID_REL%TYPE;
  V_P_CLI_NUM_IDEN              ORDENES_DIVISAS.ORD_CLI_PER_NUM_IDEN%TYPE;
  V_P_CLI_TID_CODIGO            ORDENES_DIVISAS.ORD_CLI_PER_TID_CODIGO%TYPE;
  V_OME_CDM_MNEMONICO           OPERACION_DIVISAS_ENTRE_MESAS.OME_CDM_MNEMONICO%TYPE;
  V_ORR_CONSECUTIVO             ORDENES_RECAUDO.ORR_CONSECUTIVO%TYPE;
  V_CONSECUTIVO_DAU             DETALLES_CARGOS_CUENTAS.DAU_CONSECUTIVO%TYPE;
  V_ORD_TASA_NETA               ORDENES_DIVISAS.ORD_TASA_NETA%TYPE;
  V_ORD_VALOR_PESOS_NETOS       ORDENES_DIVISAS.ORD_VALOR_PESOS_NETOS%TYPE;
  V_PER_NUM_IDEN                ORDENES_DIVISAS.ORD_PER_NUM_IDEN%TYPE;
  V_PER_TID_CODIGO              ORDENES_DIVISAS.ORD_PER_TID_CODIGO%TYPE;

  V_COLOCADAS           NUMBER;
  V_ERRORES             NUMBER;
  V_SALDO_R             NUMBER;
  V_SUMA_CARGO          NUMBER;
  V_SUMA_DET_CARGO      NUMBER;
  V_GASTOS_GIRO         NUMBER;
  V_COMISION_COMERCIAL  NUMBER;
  V_VALOR_CONS          NUMBER;
  V_VALIDA_PAG_EXTERIOR NUMBER;

  V_UTILIDAD_COMERCIAL  ORDENES_DIVISAS.ORD_UTILIDAD_COMERCIAL%TYPE;
  V_UTILIDAD_MESA       ORDENES_DIVISAS.ORD_UTILIDAD_MESA%TYPE;
  V_UTILIDAD_TOTAL      ORDENES_DIVISAS.ORD_UTILIDAD_TOTAL%TYPE; 


  V_VALOR_DATE_CONS     DATE;
  V_FECHA_CUMPLIMIENTO  DATE;
  V_PRODUCTO            VARCHAR2(5);
  V_EXISTE              VARCHAR2(1);
  V_AUTORIZADO          VARCHAR2(1);
  V_VALIDA_ROL          VARCHAR2(5);
  V_TIPO_USUARIO        VARCHAR2(1);
  V_TIPO_ORDEN          VARCHAR2(1);
  V_ORIGEN_OPERACION    VARCHAR2(1);
  V_VALOR_CHAR_CONS     VARCHAR2(200);
  V_RESTRINGIDO         VARCHAR2(1);
  V_COMPLEMENTADA       VARCHAR2(2);

     --VALORES PERMITIDOS
       --R:Monetizar           Op Restringida :R
       --T:Traslado            SE ENVIA P_TIPO_ORDEN (C,V,T)
       --D:divisas             Divisas : D
       --P:PyG                 PyG : P
       --E: Op Entre Mesas     Op Entre Mesas : CAMBIAR A M

BEGIN
   P_ID_ORDEN                    := NULL;
   V_GASTOS_GIRO                 := NULL;
   V_COMISION_COMERCIAL          := NULL;
   V_OME_CONSECUTIVO             := NULL;
   C_MONEDA_DIV.BMO_MNEMONICO    := NULL;
   V_ORD_TASA_NETA               := 0;
   V_ORD_VALOR_PESOS_NETOS       := 0;
   V_FECHA_CUMPLIMIENTO          := NULL;
   V_UTILIDAD_COMERCIAL          := 0;
   V_UTILIDAD_MESA               := 0;
   V_UTILIDAD_TOTAL              := 0;
   DELEte GL_CAB_ERROR;

   IF  P_TIPO_ORDEN IN ('V')  THEN
     V_ORD_VALOR_PESOS_NETOS := NVL(P_VALOR_PESOS,0)+NVL(P_GASTOS_ENVIO,0)+NVL(P_IVA_GASTOS_ENVIO,0)+NVL(P_IVA_VENTA,0);     
   ELSE
     V_ORD_VALOR_PESOS_NETOS := NVL(P_VALOR_PESOS,0)-(NVL(P_GASTOS_ENVIO,0)+NVL(P_IVA_GASTOS_ENVIO,0));
   END IF;

   IF NVL(P_VALOR_DOLARES,0) = 0 THEN
     V_ORD_TASA_NETA         := V_ORD_VALOR_PESOS_NETOS/1;
   ELSE 
     V_ORD_TASA_NETA         := V_ORD_VALOR_PESOS_NETOS/NVL(P_VALOR_DOLARES,0);
   END IF;

   V_P_CLI_NUM_IDEN      := P_CLI_NUM_IDEN;
   V_P_CLI_TID_CODIGO    := P_CLI_TID_CODIGO;

   IF P_ORIGEN_OPERACION = 'T'  THEN
     V_TIPO_ORDEN := 'T';
   ELSE
     V_TIPO_ORDEN := P_TIPO_ORDEN;
   END IF;

   IF P_ORIGEN_OPERACION = 'E'  THEN
     V_ORIGEN_OPERACION := 'M';
   ELSE
     V_ORIGEN_OPERACION := P_ORIGEN_OPERACION;
   END IF;


   V_ERRORES :=0;
   -- validaciones para codivisas activo
   P_TOOLS.CONSULTARCONSTANTE(P_CONSTANTE   => 'COA',
                              P_VALOR       => V_VALOR_CONS,
                              P_VALOR_DATE  => V_VALOR_DATE_CONS,
                              P_VALOR_CHAR  => V_VALOR_CHAR_CONS);

   IF NVL( V_VALOR_CHAR_CONS,'N') = 'N' THEN
     V_ERRORES := V_ERRORES+1;
     P_CAB.CREARERROR('Sistema codivisas no activo ingrese ordenes por Coeasy');
   END IF;

   --VALIDA VALOR CORRECTO DE IVA COMISIONES
   P_TOOLS.CONSULTARCONSTANTE( P_CONSTANTE => 'IVA',
                                P_VALOR       => V_VALOR_CONS,
                                P_VALOR_DATE  => V_VALOR_DATE_CONS,
                                P_VALOR_CHAR  => V_VALOR_CHAR_CONS);

   IF ROUND((NVL(P_GASTOS_ENVIO,0) * NVL(V_VALOR_CONS,0)),0) != P_IVA_GASTOS_ENVIO THEN
     IF ABS(ROUND((NVL(P_GASTOS_ENVIO,0) * NVL(V_VALOR_CONS,0)),0) - P_IVA_GASTOS_ENVIO) > 1 THEN
       V_ERRORES := V_ERRORES+1;
       P_CAB.CREARERROR('Valor de Iva de comisiones erroneo. No es posible colocar Orden. Contactar al administrador del sistema');  
     END IF;
   END IF;

   IF NVL(P_NEXT_DAY,99) NOT  IN(0,1,2,3) THEN
     V_ERRORES := V_ERRORES+1;
     P_CAB.CREARERROR('Valor para next day debe ser 0,1,2,3');
   END IF;

   IF P_MEDIO_RECEPCION IS NULL OR
      P_MEDIO_RECEPCION NOT IN ('TEL','FAX','MSN','COE','PSE') THEN
     V_ERRORES := V_ERRORES+1;
     P_CAB.CREARERROR('Medio de recepcion no valido');
   END IF;

   IF V_P_CLI_TID_CODIGO      IS NULL OR
      V_P_CLI_NUM_IDEN        IS NULL THEN
     V_ERRORES := V_ERRORES+1;
     P_CAB.CREARERROR('El Tipo de Identificacion es Nulo o el Numero de Identificacion es Nulo ');
   END IF;

   IF P_PER_NUN_IDEN  IS NULL OR
      P_TID_CODIGO     IS NULL THEN
      V_ERRORES := V_ERRORES+1;
     P_CAB.CREARERROR('La Informacion del comercial para la operacion es Nula');
   END IF;

   OPEN VALIDA_COMERCIAL;
   FETCH VALIDA_COMERCIAL INTO C_VALIDA_COMERCIAL;
   IF VALIDA_COMERCIAL%NOTFOUND THEN
     V_ERRORES := V_ERRORES+1;
     P_CAB.CREARERROR('Usuario :'||P_USUARIO_COLOCA||' no es corredor o no tiene asignados centros de produccion');
   END IF;
   CLOSE VALIDA_COMERCIAL;


   -- OBTENER BASE MONETARIA HOMOLOGA CON MONEDAS DIVISAS DE VENTAS EN OTRAS MONEDAS
   IF P_BMOFX  IS NOT NULL THEN
     OPEN MONEDA_DIV (P_BMO_FX => P_BMOFX);
     FETCH MONEDA_DIV INTO C_MONEDA_DIV;
     IF MONEDA_DIV%NOTFOUND THEN
       C_MONEDA_DIV.BMO_MNEMONICO    := NULL;
       V_ERRORES := V_ERRORES+1;
       P_CAB.CREARERROR('Para la base monetaria'||P_BMOFX||' no existe Homologacion con base moneraria');
     END IF;
     CLOSE MONEDA_DIV;

     IF P_VALORMONEDAFX    IS NULL OR
       P_TASA_CONVERSIONFX IS NULL THEN
       V_ERRORES := V_ERRORES+1;
       P_CAB.CREARERROR('Para operaciones en:'||P_BMOFX||' no se especifico valor moneda fx o tasa fx');
     END IF;
   END IF;

   V_PER_NUM_IDEN := P_PER_NUN_IDEN;
   V_PER_TID_CODIGO := P_TID_CODIGO;
   IF NVL(P_CUENTA_CORREDORES,-1) > 0 THEN

      OPEN NOMBRE_CUENTA;
      FETCH NOMBRE_CUENTA INTO C_NOMBRE_CUENTA;
      IF NOMBRE_CUENTA%NOTFOUND THEN
        V_ERRORES := V_ERRORES+1;
        P_CAB.CREARERROR('Error: Esta cuenta corredores no existe');
      END IF;
      CLOSE NOMBRE_CUENTA;

      V_PRODUCTO := 'DIV';
      V_EXISTE := 'N';
      OPEN VERIFICA_PRODUCTO;
      FETCH VERIFICA_PRODUCTO INTO C_VERIFICA_PRODUCTO;
      WHILE VERIFICA_PRODUCTO%FOUND LOOP
        IF  C_VERIFICA_PRODUCTO.CCP_PRO_MNEMONICO = V_PRODUCTO OR C_VERIFICA_PRODUCTO.CCP_PRO_MNEMONICO = 'SP' THEN
          V_PER_NUM_IDEN := C_VERIFICA_PRODUCTO.CCC_PER_NUM_IDEN;
          V_PER_TID_CODIGO := C_VERIFICA_PRODUCTO.CCC_PER_TID_CODIGO;
          V_EXISTE := 'S';
          EXIT;
        END IF;
        FETCH VERIFICA_PRODUCTO INTO C_VERIFICA_PRODUCTO;
      END LOOP;
      CLOSE VERIFICA_PRODUCTO;
      IF NVL(V_EXISTE,'N')= 'N' THEN
        V_ERRORES := V_ERRORES+1;
        P_CAB.CrearError('Cuenta no autorizada para este producto' );
      END IF;
   END IF;

   IF V_ORIGEN_OPERACION != 'M'  THEN
     OPEN RETENCION;
     FETCH RETENCION  INTO C_RETENCION;
     IF RETENCION%NOTFOUND THEN
       V_ERRORES := V_ERRORES+1;
       P_CAB.CrearError('No se puedo determinar del cliente  Si es sujeto a retencion o no');
     END IF;
     CLOSE RETENCION;

     IF NVL(C_RETENCION.CLI_PERFIL_RIESGO,0) = 0 THEN
       V_ERRORES := V_ERRORES+1;
       P_CAB.CrearError('Cliente sin perfil de riesgo Definido. No se puede registrar la operacion');
     END IF;

     V_AUTORIZADO  :=   P_CLIENTES.AUTORIZACOLOCACIONORDENPERFIL('DIV',
                                                                  V_TIPO_ORDEN,
                                                                  'NA',
                                                                  'N',
                                                                   C_RETENCION.CLI_PERFIL_RIESGO,
                                                                  'N',
                                                                  'N');
     IF NVL(V_AUTORIZADO,' ') = 'F' THEN
        V_ERRORES := V_ERRORES+1;
        P_CAB.CREARERROR('Este tipo de Operacion no esta en la Matriz de Riesgo');
     ELSIF V_AUTORIZADO = 'N' THEN
        V_ERRORES := V_ERRORES+1;
        P_CAB.CREARERROR('Ud. esta ingresando una orden que no corresponde al perfil de riesgo registrado para su cliente.'||
                         'Para poder continuar con el proceso de registro de esta operacion,'||
                         'debe modificar el perfil de su cliente');
     END IF;
   END IF;

   IF NVL(P_NEXT_DAY,0) IN (1,2,3)  THEN
     IF  p_tools.consultarparmetrosnegocio(55,8) = 1  THEN
       V_ERRORES := V_ERRORES+1;
       p_cab.crearerror('No existe parametro de hora para este negocio de ordenes next day');
     elsif p_tools.consultarparmetrosnegocio(55,8) = 2  THEN
       V_ERRORES := V_ERRORES+1;
       P_CAB.CREARERROR('Hora de Colocacion termino para ordenes next day');
     elsif p_tools.consultarparmetrosnegocio(55,8) = 3  THEN
       NULL;
     end if;

     --CALCULAR FECHA DE CUMPLIMIENTO

     IF P_NEXT_DAY = 0  THEN
       V_FECHA_CUMPLIMIENTO := NULL;
     ELSIF P_NEXT_DAY= 1 THEN  -- OPERACIONES T+1
       V_FECHA_CUMPLIMIENTO := CALCULAR_FECHA_CUMPLIMIENTO(SYSDATE+1);  
     ELSIF P_NEXT_DAY = 2 THEN -- OPERACIONES T+2
       V_FECHA_CUMPLIMIENTO := CALCULAR_FECHA_CUMPLIMIENTO(SYSDATE+1);
       V_FECHA_CUMPLIMIENTO := CALCULAR_FECHA_CUMPLIMIENTO(V_FECHA_CUMPLIMIENTO+1);   
     ELSIF P_NEXT_DAY = 3 THEN -- OPERACIONES T+3
       V_FECHA_CUMPLIMIENTO := CALCULAR_FECHA_CUMPLIMIENTO(SYSDATE+1);
       V_FECHA_CUMPLIMIENTO := CALCULAR_FECHA_CUMPLIMIENTO(V_FECHA_CUMPLIMIENTO +1);
       V_FECHA_CUMPLIMIENTO := CALCULAR_FECHA_CUMPLIMIENTO(V_FECHA_CUMPLIMIENTO +1);    
     END IF;


   ELSE
     IF  P_TOOLS.CONSULTARPARMETROSNEGOCIO(9,8) = 1  THEN
       V_ERRORES := V_ERRORES+1;
       P_CAB.CREARERROR('No existe parametro de hora para este negocio');
     ELSIF P_TOOLS.CONSULTARPARMETROSNEGOCIO(9,8) = 3  THEN
       NULL;
     END IF;
   END IF;


   V_VALIDA_ROL := 'NOK';
   IF P_TOOLS.VALIDAROL( ROL => 'DIV_USUARIO',P_USUARIO => P_USUARIO_COLOCA) OR P_TOOLS.VALIDAROL( ROL => 'DIV_COMERCIAL',P_USUARIO => P_USUARIO_COLOCA) OR
      P_TOOLS.VALIDAROL( ROL => 'COM_ASISTENTE',P_USUARIO => P_USUARIO_COLOCA) THEN
     V_VALIDA_ROL := 'OK';
   END IF;

   IF V_VALIDA_ROL = 'NOK' THEN
     V_ERRORES := V_ERRORES+1;
     P_CAB.CREARERROR('El usuario :'||P_USUARIO_COLOCA||' no tiene permiso para el modulo de divisas');
   END IF;

   V_TIPO_USUARIO := ' ';
   IF P_TOOLS.VALIDAROL( ROL =>'DIV_COMERCIAL',P_USUARIO => P_USUARIO_COLOCA ) AND
     NOT(P_TOOLS.VALIDAROL(ROL => 'DIV_USUARIO',P_USUARIO => P_USUARIO_COLOCA)) THEN
    V_TIPO_USUARIO := 'C';
   ELSIF P_TOOLS.VALIDAROL( ROL =>'DIV_USUARIO',P_USUARIO => P_USUARIO_COLOCA ) THEN
    V_TIPO_USUARIO := 'D';
   ELSIF  P_TOOLS.VALIDAROL( ROL =>'AUD_AUDITORIA',P_USUARIO => P_USUARIO_COLOCA ) THEN
    V_TIPO_USUARIO := 'D';
   ELSIF  P_TOOLS.VALIDAROL( ROL =>'COM_ASISTENTE',P_USUARIO => P_USUARIO_COLOCA ) THEN
    V_TIPO_USUARIO := 'C';
   ELSE
     V_ERRORES := V_ERRORES+1;
     P_CAB.CREARERROR('El usuario :'||P_USUARIO_COLOCA||' no tiene asignado roles para el modulo de divisas');
     END IF;

   IF V_TIPO_USUARIO = ' ' THEN
    V_ERRORES := V_ERRORES+1;
    P_CAB.CREARERROR('No se pudo determinar el tipo de usuario.. no es posible relizar operacion');
   END IF;

   IF V_TIPO_USUARIO = 'C' AND V_ORIGEN_OPERACION IN ('P') THEN
     V_ERRORES := V_ERRORES+1;
     P_CAB.CREARERROR('Solo es permitido operaciones de Divisas, para este tipo de usuario');
   END IF;

   IF P_TIPO_MOVIMIENTO IS  NULL THEN
     V_ERRORES := V_ERRORES+1;
     P_CAB.CREARERROR('Se debe especificar el tipo de movimiento');
   END IF;

   IF P_VALOR_DOLARES IS NULL OR
      P_VALOR_DOLARES < 1 THEN
     V_ERRORES := V_ERRORES+1;
     P_CAB.CREARERROR('Se debe especificar el valor de dolares de la operacion');
   END IF;

   IF P_TASA_NEGOCIACION IS NULL OR --ORD_TASA_CAMBIO
      P_TASA_NEGOCIACION < 1 THEN
     V_ERRORES := V_ERRORES+1;
     P_CAB.CREARERROR('El Valor de la Tasa de Cambio debe ser mayor a CERO');
   END IF;


   IF P_VALOR_PESOS IS NULL OR
     P_VALOR_PESOS  < 1 THEN
     V_ERRORES := V_ERRORES+1;
     P_CAB.CREARERROR('El Valor de los Pesos debe ser mayor a CERO ');
   END IF;

   IF V_ORIGEN_OPERACION IS NULL THEN
    V_ERRORES := V_ERRORES+1;
     P_CAB.CREARERROR('No se ha seleccionado el origen de la operacion');
   END IF;

   OPEN TIPO_MOVIMIENTOS;
   FETCH TIPO_MOVIMIENTOS INTO C_TIPO_MOVIMIENTOS;
   IF TIPO_MOVIMIENTOS%NOTFOUND  THEN
     V_ERRORES := V_ERRORES+1;
     P_CAB.CREARERROR('Tipo de movimiento no existe');
   END IF;
   CLOSE TIPO_MOVIMIENTOS;

   IF C_TIPO_MOVIMIENTOS.TMD_MOVIMIENTO_INTERBANCARIO = 'S' AND C_VALIDA_COMERCIAL.PER_SUC_CODIGO <> 1 THEN
     V_ERRORES := V_ERRORES+1;
     P_CAB.CREARERROR('Las Compras Interbancarias solo se realizan por la Sucursal Principal.');
   END IF;

   -- Validacion para Compras
   IF V_ORIGEN_OPERACION != 'M'  THEN
     IF V_TIPO_ORDEN IN ('C','T') AND
        P_BMO_MNEMONICO = 'DOLAR'     AND
        P_CUENTA_CORREDORES IS NOT NULL THEN
       OPEN SALDO;
       FETCH SALDO INTO V_SALDO_R;
       CLOSE SALDO;
       V_SALDO_R := NVL(V_SALDO_R,0);

       OPEN COL;
       FETCH COL INTO V_COLOCADAS;
       IF COL%NOTFOUND THEN
         V_COLOCADAS := 0;
       END IF;
       CLOSE COL;
       V_COLOCADAS := NVL(V_COLOCADAS,0);

       V_SALDO_R := NVL(V_SALDO_R,0) - V_COLOCADAS;


       IF P_VALORMONEDAFX    IS NOT NULL OR
          P_TASA_CONVERSIONFX IS NOT NULL OR
          P_BMOFX IS NOT NULL THEN
         V_ERRORES := V_ERRORES+1;
         P_CAB.CREARERROR('Para operaciones compras en coeasy no esta permitido en otras monedas');
       END IF;

       /*IF V_SALDO_R < 0 THEN
         IF NVL(P_NEXT_DAY,0) NOT IN (1,2) THEN
           V_ERRORES := V_ERRORES+1;
           P_CAB.CREARERROR('Saldo Insuficiente. Otro usuario coloco una orden');
         END IF;
       END IF;
       */
       -- VALIDACIONM OPERACIONES DE MONETIZACION CON SALDO RESTRINGIDO
       /*IF V_ORIGEN_OPERACION = 'R' THEN
         -- OBTENAR SALDO RESTRINGIDO DE LA CUENTA
         OPEN SALDO_RESTRINGIDO;
         FETCH SALDO_RESTRINGIDO INTO C_SALDO_RESTRINGIDO;
         IF SALDO_RESTRINGIDO%NOTFOUND THEN
           V_ERRORES := V_ERRORES+1;
           P_CAB.CREARERROR('No se encontro cuenta con saldo restringido del cliente para monetizar');
         ELSE
            IF NVL(C_SALDO_RESTRINGIDO.CDV_SALDO_RESTRINGIDO,0)- V_COLOCADAS <= 0 THEN
              V_ERRORES := V_ERRORES+1;
              P_CAB.CREARERROR('Saldo restringido insuficiente para colocar orden. Saldo:'||TO_CHAR(P_VALOR_DOLARES,'999,999,999,999.99'));
            END IF;

            IF NVL(P_VALOR_DOLARES,0) > NVL(C_SALDO_RESTRINGIDO.CDV_SALDO_RESTRINGIDO,0)- V_COLOCADAS THEN
              V_ERRORES := V_ERRORES+1;
              P_CAB.CREARERROR('El valor de la orden no puede ser mayor al del saldo restringido');
            END IF;
         END IF;
         CLOSE SALDO_RESTRINGIDO;         
       END IF;*/
     END IF;
   END IF;

   V_COMPLEMENTADA := NULL;
   -- Validacion para compras
   IF V_TIPO_ORDEN IN ('C')  THEN 
     IF V_ORIGEN_OPERACION = 'R' THEN
       V_COMPLEMENTADA := 'N';
     ELSE
       IF V_TIPO_USUARIO IN ('C','D') THEN
         IF C_TIPO_MOVIMIENTOS.TMD_COMERCIAL_USUARIO = 'C' THEN
            V_COMPLEMENTADA := 'N';
         ELSE  
            V_COMPLEMENTADA  := 'S';
         END IF;
       ELSE
         V_ERRORES := V_ERRORES+1;
         P_CAB.CREARERROR('No se pudo determinar el tipo Usuario (Comercial o Administrador Divisas).. imposible colocar orden Compra');
       END IF;      
      END IF;
   END IF;

   -- Validacion para Ventas
   IF V_TIPO_ORDEN IN ('V')  THEN    
     IF V_ORIGEN_OPERACION != 'M'  THEN
       IF V_ORIGEN_OPERACION != 'P' THEN
         OPEN SUMA_DOLARES_PXC;  -- VALIDA CONTRA TEMPORAL DE PAGOS EXTERIOR
         FETCH SUMA_DOLARES_PXC INTO C_SUMA_DOLARES_PXC;
         CLOSE SUMA_DOLARES_PXC;

         IF NVL(C_SUMA_DOLARES_PXC.PXC_VALOR_DOLARES,0)  = 0  THEN
            V_ERRORES := V_ERRORES+1;
            P_CAB.CREARERROR('Orden de divisas sin ordenes de pago EXTERIOR asociadas');
         END IF;


         IF NVL(P_VALOR_DOLARES,0) != NVL(C_SUMA_DOLARES_PXC.PXC_VALOR_DOLARES,0) THEN
           V_ERRORES := V_ERRORES+1;
            P_CAB.CREARERROR('El monto de la Venta no es igual a la suma de las '
          || 'Ordenes de Pago del exterior'||TO_CHAR(P_VALOR_DOLARES,'999,999,999,999.99')||' vs '||TO_CHAR(NVL(C_SUMA_DOLARES_PXC.PXC_VALOR_DOLARES,0),'999,999,999,999,999.99'));
         END IF;
       END IF;

       IF P_VALORMONEDAFX IS NOT NULL THEN
         IF V_ORIGEN_OPERACION  IN ('Y','R') THEN
           V_ERRORES := V_ERRORES+1;
           P_CAB.CREARERROR('Operaciones de venta en otras monedas no son permitidas con saldo restringido');
         END IF;

         IF C_MONEDA_DIV.BMO_MNEMONICO  IN ('DOLAR','PESOS') THEN
           V_ERRORES := V_ERRORES+1;
           P_CAB.CREARERROR('Si selecciono otras monedas no se puede elegir DOLAR ni PESOS');
         END IF;
       END IF;


       OPEN SUMA_CARGOS;
       FETCH SUMA_CARGOS INTO V_SUMA_CARGO;
       CLOSE SUMA_CARGOS;


       V_SUMA_CARGO     := NVL(V_SUMA_CARGO,0)+NVL(P_MONTO_CARGO_CUENTA,0);
       V_SUMA_DET_CARGO := 0;
       IF  NVL(P_MONTO_CARGO_CUENTA,0) > 0  THEN
         OPEN SUMA_DETALLE_CARGO;
         FETCH SUMA_DETALLE_CARGO INTO V_SUMA_DET_CARGO;
         CLOSE SUMA_DETALLE_CARGO;
       END IF;
       V_SUMA_DET_CARGO := NVL(V_SUMA_DET_CARGO,0);

       IF V_ORIGEN_OPERACION NOT IN ('D') AND NVL(P_MONTO_CARGO_CUENTA,0) != 0  THEN
         V_ERRORES := V_ERRORES+1;
         P_CAB.CREARERROR('Orden de Divisas no se debe especificar monto cargo a cuenta');
       END IF;

       IF V_ORIGEN_OPERACION IN ('D') THEN
         IF NVL(V_SUMA_CARGO,0) = 0 THEN
           V_ERRORES := V_ERRORES+1;
           P_CAB.CREARERROR('Orden de Divisas sin ordenes de recaudo asociadas');
         END IF;

         IF NVL(P_CARGO_CUENTA,'N') = 'S' AND
           NVL(P_MONTO_CARGO_CUENTA,0) = 0 THEN
           V_ERRORES := V_ERRORES+1;
           P_CAB.CREARERROR('No se especifico valor del cargo a cuenta');
         END IF;

         IF NVL(V_ORD_VALOR_PESOS_NETOS,0) != NVL(V_SUMA_CARGO,0) THEN
           V_ERRORES := V_ERRORES+1;
           P_CAB.CREARERROR('El monto de la Venta no es igual a la suma de las Ordenes de Recaudo '||TO_CHAR(V_ORD_VALOR_PESOS_NETOS,'999,999,999,999.99')||' vs '||TO_CHAR(V_SUMA_CARGO,'999,999,999,999.99'));
         END IF;

         IF NVL(V_SUMA_DET_CARGO,0) > 0  THEN
           IF NVL(V_SUMA_DET_CARGO,0) != NVL(P_MONTO_CARGO_CUENTA,0) THEN
              V_ERRORES := V_ERRORES+1;
              P_CAB.CREARERROR('El valor total del datalle del cargo cuenta '
                  ||TO_CHAR(NVL(V_SUMA_DET_CARGO,0),'999,999,999,999,999.99')
                  ||' no es igual al valor del Cargo A Cuenta '
                  ||TO_CHAR(P_MONTO_CARGO_CUENTA,'999,999,999,999.99'));

           END IF;
         END IF;
       END IF;
     END IF;
   END IF;

   -- Validacion para Traslados
   IF V_TIPO_ORDEN IN ('T') THEN
     OPEN SUMA_DOLARES_PXC; -- VALIDA CONTRA TEMPORAL DE PAGOS EXTERIOR
     FETCH SUMA_DOLARES_PXC INTO C_SUMA_DOLARES_PXC;
     CLOSE SUMA_DOLARES_PXC;

     IF NVL(C_SUMA_DOLARES_PXC.PXC_VALOR_DOLARES,0)  = 0  THEN
       V_ERRORES := V_ERRORES+1;
       P_CAB.CREARERROR('Orden de divisas sin ordenes de pago EXTERIOR asociadas');
     END IF;
   END IF;

   OPEN TRM;
   FETCH TRM INTO C_TRM;
   IF TRM%NOTFOUND THEN
     V_ERRORES := V_ERRORES+1;
     P_CAB.CREARERROR('Valor de TRM no existe para este dia');
   END IF;
   CLOSE TRM;


   IF NVL(V_ORIGEN_OPERACION,' ') NOT IN ('P','M') THEN
     P_TOOLS.CONSULTARCONSTANTE(
       P_CONSTANTE   => 'VGD',
       P_VALOR       => V_VALOR_CONS,
       P_VALOR_DATE  => V_VALOR_DATE_CONS,
       P_VALOR_CHAR  => V_VALOR_CHAR_CONS
     );


     IF NVL(P_GASTOS_ENVIO,0) = 0 THEN
        V_GASTOS_GIRO := 0;
        V_COMISION_COMERCIAL := 0;
     ELSE

        V_GASTOS_GIRO := ROUND(V_VALOR_CONS*C_TRM.CBM_VALOR,0);
        IF V_TIPO_ORDEN IN ('C','V') THEN
           V_COMISION_COMERCIAL   := NVL(P_GASTOS_ENVIO,0)-NVL(V_GASTOS_GIRO,0);
        ELSE
           V_COMISION_COMERCIAL  := 0;
        END IF;
     END IF;
   END IF;

   V_RESTRINGIDO := NULL;
   IF V_ORIGEN_OPERACION = 'R' THEN
     V_RESTRINGIDO := 'S';
   ELSE
     IF NVL(P_NEXT_DAY,0) IN (1,2,3) THEN
       V_RESTRINGIDO := 'S';
     ELSE
       V_RESTRINGIDO := 'N';
     END IF;
   END IF;


   IF V_ORIGEN_OPERACION = 'M' THEN
      --1 : NO EXISTE PARAMETRO HORA
      --2 : HORA FUERA DE RANGO
      --3 : HORA OK

     IF  p_tools.consultarparmetrosnegocio(36,8) = 1  THEN
       V_ERRORES := V_ERRORES+1;
       p_cab.crearerror('No existe parametro de hora para este negocio de ordenes next day');
     elsif p_tools.consultarparmetrosnegocio(36,8) = 2  THEN
       V_ERRORES := V_ERRORES+1;
       P_CAB.CREARERROR('Hora de Colocacion termino para ordenes next day');
     elsif p_tools.consultarparmetrosnegocio(36,8) = 3  THEN
       NULL;
     end if;

     IF P_DETALLE_RECEPCION IS NULL THEN
       V_ERRORES := V_ERRORES+1;
       P_CAB.CREARERROR('Debe ingresar informacion en el detalle');
     END IF;

     V_RESTRINGIDO          := NULL;
     V_COMISION_COMERCIAL   := NULL;
     V_P_CLI_NUM_IDEN       := '860079174';
     V_P_CLI_TID_CODIGO     := 'NIT';



     IF V_TIPO_ORDEN = 'C' THEN
       IF P_TIPO_MOVIMIENTO = 'DXADR'  THEN
         V_OME_CDM_MNEMONICO := 'CXVADR';
       ELSE
         V_ERRORES := V_ERRORES+1;
         P_CAB.CREARERROR('Tipo de movimiento no valido para operaciones de compra entre mesas');
       END IF;
     END IF;

     IF V_TIPO_ORDEN = 'V' THEN
       IF P_TIPO_MOVIMIENTO = 'CXADR'  THEN
         V_OME_CDM_MNEMONICO := 'DXCADR';
       ELSE
         V_ERRORES := V_ERRORES+1;
         P_CAB.CREARERROR('Tipo de movimiento no valido para operaciones de venta entre mesas');
       END IF;
     END IF;
   END IF;

   IF V_ORIGEN_OPERACION IN ('D','R') THEN
       IF NVL(P_PORCENTAJE_MESA,0)+NVL(P_PORCENTAJE_COMERCIAL,0) != 100 THEN
          V_ERRORES := V_ERRORES+1;
          P_CAB.CREARERROR('El porcentaje de Mesa+Comercial debe ser igual a 100%: '||TO_CHAR(NVL(P_PORCENTAJE_MESA,0)+NVL(P_PORCENTAJE_COMERCIAL,0),'99999999.00'));
       END IF;

       IF V_TIPO_ORDEN = 'C' AND (TRUNC(NVL(P_TASA_NEG_MESA,0)-NVL(P_TASA_NEGOCIACION,0),2)) != NVL(P_MARGEN_COMISION,0) THEN
          V_ERRORES := V_ERRORES+1;
          P_CAB.CREARERROR('Margen de Comision en compra erroneo: '||TO_CHAR(NVL(P_MARGEN_COMISION,0),'999,999,999,999.00'));
       END IF;

       IF V_TIPO_ORDEN = 'V' AND (TRUNC(NVL(P_TASA_NEGOCIACION,0)-NVL(P_TASA_NEG_MESA,0),2)) != NVL(P_MARGEN_COMISION,0) THEN
          V_ERRORES := V_ERRORES+1;
          P_CAB.CREARERROR('Margen de Comision en venta erroneo: '||TO_CHAR(NVL(P_MARGEN_COMISION,0),'999,999,999,999.00'));
       END IF;      

       IF NVL(P_MARGEN_COMISION,0) < 0 THEN
          V_ERRORES := V_ERRORES+1;
          P_CAB.CREARERROR('Margen de comision erroneo  :'||TO_CHAR(NVL(P_MARGEN_COMISION,0)));
       END IF;

       IF V_ERRORES = 0 THEN           
          IF V_TIPO_ORDEN IN ('C','V') AND P_CUENTA_CORREDORES IS NOT NULL  THEN  
             V_UTILIDAD_TOTAL     := ROUND((NVL(P_MARGEN_COMISION,0)*NVL(P_VALOR_DOLARES,0)),2);
             V_UTILIDAD_COMERCIAL := ROUND(((NVL(P_PORCENTAJE_COMERCIAL,0)/100)*NVL(V_UTILIDAD_TOTAL,0)),2);
             V_UTILIDAD_MESA      := ROUND((NVL(P_PORCENTAJE_MESA,0)/100)*NVL(V_UTILIDAD_TOTAL,0),2);
          END IF;  
       END IF;


    END IF;


   -- creacion de ordenes divisas
   IF V_ERRORES = 0 THEN
     OPEN CONSECUTIVO(P_SUC_CODIGO => C_VALIDA_COMERCIAL.PER_SUC_CODIGO);
     FETCH CONSECUTIVO INTO P_ID_ORDEN;
     CLOSE CONSECUTIVO;
     P_ID_ORDEN := NVL(P_ID_ORDEN,0) + 1;



     V_OME_CONSECUTIVO := NULL;
     IF V_ORIGEN_OPERACION = 'M' THEN
       OPEN CONSEC_OME;
       FETCH CONSEC_OME INTO V_OME_CONSECUTIVO;
       CLOSE CONSEC_OME;
       BEGIN
         BEGIN
           INSERT INTO OPERACION_DIVISAS_ENTRE_MESAS
             (OME_CONSECUTIVO
             ,OME_PER_NUM_IDEN
             ,OME_PER_TID_CODIGO
             ,OME_PUNTA
             ,OME_MONTO_DOLARES
             ,OME_TASA_NEGOCIACION
             ,OME_MONTO_PESOS
             ,OME_DETALLE
             ,OME_ESTADO
             ,OME_HORA_REGISTRO
             ,OME_USUARIO_REGISTRO
             ,OME_OMD_FECHA
             ,OME_CDM_MNEMONICO
             ,OME_ORIGEN )
           VALUES
           (  V_OME_CONSECUTIVO              --OME_CONSECUTIVO
             ,V_PER_NUM_IDEN                 --OME_PER_NUM_IDEN
             ,V_PER_TID_CODIGO               --OME_PER_TID_CODIGO
             ,V_TIPO_ORDEN                   --OME_PUNTA
             ,P_VALOR_DOLARES                --OME_MONTO_DOLARES
             ,P_TASA_NEGOCIACION             --OME_TASA_NEGOCIACION
             ,P_VALOR_PESOS                  --OME_MONTO_PESOS
             ,P_DETALLE_RECEPCION            --OME_DETALLE
             ,'REG'                          --OME_ESTADO
             ,TO_CHAR(SYSDATE, 'HH24:MI:SS') --OME_HORA_REGISTRO
             ,P_USUARIO_COLOCA               --OME_USUARIO_REGISTRO
             ,TRUNC(SYSDATE)                 --OME_OMD_FECHA
             ,V_OME_CDM_MNEMONICO            --OME_CDM_MNEMONICO
             ,'COD'                          --OME_ORIGEN
             );
             EXCEPTION WHEN OTHERS THEN
                  V_ERRORES := V_ERRORES+1;
                  -- BORRADO DE TABLAS TEMPORALES
                  DELETE RECAUDOS_CODIVISAS
                       WHERE ORC_IDCODIVISAS  = P_IDCODIVISAS;


                   DELETE DETALLES_CARGO_CODIVISAS WHERE DAC_IDCODIVISAS = P_IDCODIVISAS;

                   DELETE PAGOS_EXTERIOR_CODIVISAS
                     WHERE PXC_IDCODIVISAS =  P_IDCODIVISAS;

                   DELETE OPERACION_DIVISAS_ENTRE_MESAS where OME_CONSECUTIVO = V_OME_CONSECUTIVO;

                   COMMIT;
                   P_ID_ORDEN := NULL;
                   P_CLOB := NULL ;
                   RAISE_APPLICATION_ERROR(-20900, 'Errores en colocacion ordenes divisas:'||SQLERRM);         
           IF SQL%ROWCOUNT = 0 THEN
             V_ERRORES := V_ERRORES+1;
             P_ID_ORDEN := NULL;
           END IF;
          END;
         END;
     END IF;

     BEGIN
       BEGIN
         INSERT INTO ORDENES_DIVISAS
           (ORD_CONSECUTIVO
           ,ORD_SUC_CODIGO
           ,ORD_BMO_MNEMONICO
           ,ORD_EOF_CODIGO
           ,ORD_CLI_PER_NUM_IDEN
           ,ORD_CLI_PER_TID_CODIGO
           ,ORD_TMD_MNEMONICO
           ,ORD_TIPO_ORDEN
           ,ORD_TIPO_MERCADO
           ,ORD_VALOR_DOLARES
           ,ORD_VALOR_PESOS
           ,ORD_COLOCADO_POR
           ,ORD_FECHA_COLOCACION
           ,ORD_TASA_CAMBIO
           ,ORD_TASA_NETA
           ,ORD_VALOR_PESOS_NETOS
           ,ORD_CCC_NUMERO_CUENTA
           ,ORD_PER_NUM_IDEN
           ,ORD_PER_TID_CODIGO
           ,ORD_EXCENTO_RETENCION
           ,ORD_ORIGEN_OPERACION
           ,ORD_POSICION_PROPIA
           ,ORD_CONTRATO_COMISION
           ,ORD_TIPO_CAMBIO
           ,ORD_VALOR_IVA_VENTA
           ,ORD_VALOR_COMISION
           ,ORD_VALOR_IVA_COMISIONES
           ,ORD_VALOR_RETEFUENTE
           ,ORD_OPERACION_TODO_COSTO
           ,ORD_APROBADO_POR
           ,ORD_FECHA_APROBACION
           ,ORD_ANULADA_POR
           ,ORD_FECHA_ANULACION
           ,ORD_TASA_CONVERSION
           ,ORD_AUTORIZACION
           ,ORD_AUTORIZADOR
           ,ORD_VALOR_FX
           ,ORD_BMO_MNEMONICO_FX
           ,ORD_VALOR_IVA_DESCONTABLE
           ,ORD_CARGO_ABONO_CUENTA
           ,ORD_GENERADO_FACTURA
           ,ORD_MONTO_CARGO_ABONO_CUENTA
           ,ORD_GASTOS_GIRO
           ,ORD_COMISION_COMERCIAL
           ,ORD_TERMINAL_VERIFICA
           ,ORD_PER_NUM_IDEN_ES_DUENO
           ,ORD_PER_TID_CODIGO_ES_DUENO
           ,ORD_VERIFICADO_COMERCIAL
           ,ORD_INDICADOR_RESTRINGIDO
           ,ORD_FECHA_CUMPLIMIENTO
           ,ORD_DIAS_NEXT_DAY
           ,ORD_MEDIO_RECEPCION
           ,ORD_DETALLE_MEDIO_RECEPCION
           ,ORD_HORA_RECEPCION
           ,ORD_PROFESIONAL
           ,ORD_OME_CONSECUTIVO
           ,ORD_CARGO_CTA_COMPENSACION
           ,ORD_CARGO_INV_EXTERIOR
           ,ORD_IDCODIVISAS
           ,ORD_FECHA_VERIFICA
           ,ORD_TASA_NEG_MESA
           ,ORD_MARGEN_COMISION
           ,ORD_PORCENTAJE_MESA
           ,ORD_PORCENTAJE_COMERCIAL
           ,ORD_UTILIDAD_COMERCIAL
           ,ORD_UTILIDAD_MESA
           ,ORD_UTILIDAD_TOTAL   
           )
           VALUES
           (
            P_ID_ORDEN                                            --ORD_CONSECUTIVO
           ,C_VALIDA_COMERCIAL.PER_SUC_CODIGO                     --ORD_SUC_CODIGO
           ,'DOLAR'                                               --ORD_BMO_MNEMONICO
           ,'COL'                                                 --ORD_EOF_CODIGO
           ,V_P_CLI_NUM_IDEN                                      --ORD_CLI_PER_NUM_IDEN
           ,V_P_CLI_TID_CODIGO                                    --ORD_CLI_PER_TID_CODIGO
           ,P_TIPO_MOVIMIENTO                                     --ORD_TMD_MNEMONICO
           ,V_TIPO_ORDEN                                          --ORD_TIPO_ORDEN
           ,'C'                                                   --ORD_TIPO_MERCADO
           ,P_VALOR_DOLARES                                       --ORD_VALOR_DOLARES
           ,P_VALOR_PESOS                                         --ORD_VALOR_PESOS
           ,P_USUARIO_COLOCA                                      --ORD_COLOCADO_POR
           ,SYSDATE                                               --ORD_FECHA_COLOCACION
           ,P_TASA_NEGOCIACION                                    --ORD_TASA_CAMBIO
           ,V_ORD_TASA_NETA                                       --ORD_TASA_NETA
           ,V_ORD_VALOR_PESOS_NETOS                               --ORD_VALOR_PESOS_NETOS
           ,P_CUENTA_CORREDORES                                   --ORD_CCC_NUMERO_CUENTA
           ,V_PER_NUM_IDEN                                        --ORD_PER_NUM_IDEN
           ,V_PER_TID_CODIGO                                      --ORD_PER_TID_CODIGO
           ,P_EXECENTO_RETENCION                                  --ORD_EXCENTO_RETENCION
           ,V_ORIGEN_OPERACION                                    --ORD_ORIGEN_OPERACION
           ,P_POSICION_PROPIA                                     --ORD_POSICION_PROPIA
           ,'N'                                                   --ORD_CONTRATO_COMISION
           ,P_TASA_CONVERSIONFX                                   --ORD_TIPO_CAMBIO
           ,P_IVA_VENTA                                           --ORD_VALOR_IVA_VENTA
           ,P_GASTOS_ENVIO                                        --ORD_VALOR_COMISION
           ,P_IVA_GASTOS_ENVIO                                    --ORD_VALOR_IVA_COMISIONES
           ,P_VALOR_RETEFUENTE                                    --ORD_VALOR_RETEFUENTE
           ,P_TODO_COSTO                                          --ORD_OPERACION_TODO_COSTO
           ,NULL                                                  --ORD_APROBADO_POR
           ,NULL                                                  --ORD_FECHA_APROBACION
           ,NULL                                                  --ORD_ANULADA_POR
           ,NULL                                                  --ORD_FECHA_ANULACION
           ,NULL                                                  --ORD_TASA_CONVERSION
           ,NULL                                                  --ORD_AUTORIZACION
           ,NULL                                                  --ORD_AUTORIZADOR
           ,P_VALORMONEDAFX                                       --ORD_VALOR_FX
           ,C_MONEDA_DIV.BMO_MNEMONICO                            --ORD_BMO_MNEMONICO_FX
           ,NULL                                                  --ORD_VALOR_IVA_DESCONTABLE
           ,NVL(P_CARGO_CUENTA,'N')                               --ORD_CARGO_ABONO_CUENTA
           ,'N'                                                   --ORD_GENERADO_FACTURA
           ,P_MONTO_CARGO_CUENTA                                  --ORD_MONTO_CARGO_ABONO_CUENTA
           ,NVL(V_GASTOS_GIRO,0)                                  --ORD_GASTOS_GIRO
           ,NVL(V_COMISION_COMERCIAL,0)                           --ORD_COMISION_COMERCIAL
           ,P_TERMINAL_OPERACION                                  --ORD_TERMINAL_VERIFICA
           ,V_PER_NUM_IDEN                                        --ORD_PER_NUM_IDEN_ES_DUENO
           ,V_PER_TID_CODIGO                                      --ORD_PER_TID_CODIGO_ES_DUENO
           ,'S'                                                   --ORD_VERIFICADO_COMERCIAL
           ,V_RESTRINGIDO                                         --ORD_INDICADOR_RESTRINGIDO
           ,DECODE(NVL(P_NEXT_DAY,0),0,NULL,V_FECHA_CUMPLIMIENTO) --ORD_FECHA_CUMPLIMIENTO
           ,P_NEXT_DAY                                            --ORD_DIAS_NEXT_DAY
           ,P_MEDIO_RECEPCION                                     --ORD_MEDIO_RECEPCION
           ,P_DETALLE_RECEPCION                                   --ORD_DETALLE_MEDIO_RECEPCION
           ,P_HORA_RECEPCION                                      --ORD_HORA_RECEPCION
           ,C_RETENCION.CLI_PROFESIONAL                           --ORD_PROFESIONAL
           ,V_OME_CONSECUTIVO                                     --ORD_OME_CONSECUTIVO
           ,P_CARGO_USD_CLIENTE                                   --ORD_CARGO_CTA_COMPENSACION
           ,P_CARGO_CUENTA_INVEXT                                 --ORD_CARGO_INV_EXTERIOR
           ,P_IDCODIVISAS                                         --ORD_IDCODIVISAS
           ,DECODE(C_VALIDA_COMERCIAL.PER_TIPO_COMERCIAL,'C', SYSDATE,
                                                         'P',SYSDATE, NULL) -- ORD_FECHA_VERIFICA
           ,P_TASA_NEG_MESA                                       --ORD_TASA_NEG_MESA                                     
           ,P_MARGEN_COMISION                                     --ORD_MARGEN_COMISION
           ,P_PORCENTAJE_MESA                                     --ORD_PORCENTAJE_MESA
           ,P_PORCENTAJE_COMERCIAL                                --ORD_PORCENTAJE_COMERCIAL
           ,V_UTILIDAD_COMERCIAL                                  --ORD_UTILIDAD_COMERCIAL
           ,V_UTILIDAD_MESA                                       --ORD_UTILIDAD_MESA
           ,V_UTILIDAD_TOTAL                                      --ORD_UTILIDAD_TOTAL
           );
           EXCEPTION WHEN OTHERS THEN
                V_ERRORES := V_ERRORES+1;
                -- BORRADO DE TABLAS TEMPORALES
                DELETE RECAUDOS_CODIVISAS
                     WHERE ORC_IDCODIVISAS  = P_IDCODIVISAS;


                 DELETE DETALLES_CARGO_CODIVISAS WHERE DAC_IDCODIVISAS = P_IDCODIVISAS;

                 DELETE PAGOS_EXTERIOR_CODIVISAS
                   WHERE PXC_IDCODIVISAS =  P_IDCODIVISAS;

                 DELETE OPERACION_DIVISAS_ENTRE_MESAS where OME_CONSECUTIVO = V_OME_CONSECUTIVO;

                 DELETE ORDENES_DIVISAS WHERE ORD_CONSECUTIVO = P_ID_ORDEN  AND ORD_SUC_CODIGO = C_VALIDA_COMERCIAL.PER_SUC_CODIGO;

                 COMMIT;
                 P_ID_ORDEN := NULL;
                 P_CLOB := NULL ;
                 RAISE_APPLICATION_ERROR(-20900, 'Errores en colocacion ordenes divisas:'||SQLERRM);         
         END;
         IF SQL%ROWCOUNT = 0 THEN
           V_ERRORES := V_ERRORES+1;
           P_ID_ORDEN := NULL;
         END IF;
     END;

     IF P_ID_ORDEN IS NOT NULL  AND V_ORIGEN_OPERACION != 'M' AND V_TIPO_ORDEN = 'V'  THEN
       -- CREACION DE RECAUDOS
       IF V_ORIGEN_OPERACION = 'D' AND C_TIPO_MOVIMIENTOS.TMD_COMERCIAL_USUARIO = 'C' THEN
         V_NEG_CONSECUTIVO := 2;
       ELSE
         V_NEG_CONSECUTIVO := 8;
       END IF;

       IF P_TIPO_MOVIMIENTO = 'PSE' THEN
         V_SEBRA_COMPENSADO := 'N';
       ELSE
         V_SEBRA_COMPENSADO := NULL;
       END IF;

       --- Creacion de recudos
       OPEN REC_CODIVISAS;
       FETCH REC_CODIVISAS INTO C_REC_CODIVISAS;
       WHILE REC_CODIVISAS%FOUND LOOP

         OPEN CONSECUTIVO_ORR(V_NEG_CONSECUTIVO, C_VALIDA_COMERCIAL.PER_SUC_CODIGO);
         FETCH CONSECUTIVO_ORR INTO V_ORR_CONSECUTIVO;
         CLOSE CONSECUTIVO_ORR;

         BEGIN
           BEGIN
             INSERT INTO ORDENES_RECAUDO
             (
               ORR_CONSECUTIVO
              ,ORR_SUC_CODIGO
              ,ORR_NEG_CONSECUTIVO
              ,ORR_ESTADO
              ,ORR_TPA_MNEMONICO
              ,ORR_MONTO
              ,ORR_INSTRUCCION_CHEQUE
              ,ORR_DIRECCION_RECOGE_CHEQUE
              ,ORR_PREGUNTAR_POR
              ,ORR_AGE_CODIGO
              ,ORR_OTRAS_INSTRUCCIONES
              ,ORR_SEBRA_COMPENSADO
              ,ORR_ORD_CONSECUTIVO
              ,ORR_ORD_SUC_CODIGO
             )
             VALUES(
                V_ORR_CONSECUTIVO
               ,C_VALIDA_COMERCIAL.PER_SUC_CODIGO
               ,V_NEG_CONSECUTIVO
               ,C_REC_CODIVISAS.ORC_ESTADO
               ,C_REC_CODIVISAS.ORC_TPA_MNEMONICO
               ,C_REC_CODIVISAS.ORC_MONTO
               ,C_REC_CODIVISAS.ORC_INSTRUCCION_CHEQUE
               ,C_REC_CODIVISAS.ORC_DIRECCION_RECOGE_CHEQUE
               ,C_REC_CODIVISAS.ORC_PREGUNTAR_POR 
               ,C_REC_CODIVISAS.ORC_AGE_CODIGO
               ,C_REC_CODIVISAS.ORC_OTRAS_INSTRUCCIONES
               ,V_SEBRA_COMPENSADO
               ,P_ID_ORDEN
               ,C_VALIDA_COMERCIAL.PER_SUC_CODIGO);

             -- NOTIFICAR A CONTROLES EN LINEA RECAUDOS EN CHEQUE
             -- se comentariza para c?habilitar con cotroles en linea
             IF C_REC_CODIVISAS.ORC_TPA_MNEMONICO IN('CHE','CHG') THEN
               INSERT INTO CENLINEA_NOTIFICA_CANJE_DIV               
                 (CNCD_CONSECUTIVO               
                 ,CNCD_ESTADO                    
                 ,CNCD_FECHA_INGRESO             
                 ,CNCD_FECHA_ENTREGA             
                 ,CNCD_CLI_PER_NUM_IDEN          
                 ,CNCD_CLI_PER_TID_CODIGO        
                 ,CNCD_VALOR_CANJE                              
                 ,CNCD_ID_CODIVISAS)
               VALUES
               (  CNCD_SEQ.NEXTVAL          --CNCD_CONSECUTIVO               
                 ,'POR_PROCESAR'            --CNCD_ESTADO                    
                 ,SYSDATE                   --CNCD_FECHA_INGRESO             
                 ,NULL                      --CNCD_FECHA_ENTREGA             
                 ,V_P_CLI_NUM_IDEN          --CNCD_CLI_PER_NUM_IDEN          
                 ,V_P_CLI_TID_CODIGO        --CNCD_CLI_PER_TID_CODIGO        
                 ,C_REC_CODIVISAS.ORC_MONTO --CNCD_VALOR_CANJE                              
                 ,P_IDCODIVISAS             --CNCD_ID_CODIVISAS
               );
             END IF;

             EXCEPTION WHEN OTHERS THEN
               V_ERRORES := V_ERRORES+1;
               -- BORRADO DE TABLAS TEMPORALES
               DELETE RECAUDOS_CODIVISAS
                   WHERE ORC_IDCODIVISAS  = P_IDCODIVISAS;


               DELETE DETALLES_CARGO_CODIVISAS WHERE DAC_IDCODIVISAS = P_IDCODIVISAS;

               DELETE PAGOS_EXTERIOR_CODIVISAS
                 WHERE PXC_IDCODIVISAS =  P_IDCODIVISAS;

               IF C_REC_CODIVISAS.ORC_TPA_MNEMONICO IN('CHE','CHG') THEN
                 DELETE CENLINEA_NOTIFICA_CANJE_DIV WHERE CNCD_ID_CODIVISAS = P_IDCODIVISAS;
               END IF;

               DELETE OPERACION_DIVISAS_ENTRE_MESAS where OME_CONSECUTIVO = V_OME_CONSECUTIVO;

               DELETE  ORDENES_RECAUDO WHERE ORR_CONSECUTIVO = V_ORR_CONSECUTIVO AND ORR_SUC_CODIGO = C_VALIDA_COMERCIAL.PER_SUC_CODIGO AND ORR_NEG_CONSECUTIVO = V_NEG_CONSECUTIVO;

               DELETE CENLINEA_NOTIFICA_CANJE_DIV WHERE  CNCD_ID_CODIVISAS = P_IDCODIVISAS;

               DELETE ORDENES_DIVISAS WHERE ORD_CONSECUTIVO = P_ID_ORDEN  AND ORD_SUC_CODIGO = C_VALIDA_COMERCIAL.PER_SUC_CODIGO;

               COMMIT;
               P_ID_ORDEN := NULL;
               P_CLOB := NULL ;
               RAISE_APPLICATION_ERROR(-20900, 'Errores en colocacion ordenes divisas:'||SQLERRM);               
           END;

           IF SQL%ROWCOUNT = 0 THEN           
             V_ERRORES := V_ERRORES+1;
             P_ID_ORDEN := NULL;
           END IF;
         END;
         FETCH REC_CODIVISAS INTO C_REC_CODIVISAS;
       END LOOP;
       CLOSE REC_CODIVISAS;

       -- CREACION MOVIMIENTOS DETALLE CARGO CUENTA
       IF NVL(P_CARGO_CUENTA,'N') = 'S' THEN
         OPEN DET_CAR_CODIVISAS;
         FETCH DET_CAR_CODIVISAS INTO C_DET_CAR_CODIVISAS;
         WHILE DET_CAR_CODIVISAS%FOUND LOOP

           OPEN CONSECUTIVO_DAU(C_VALIDA_COMERCIAL.PER_SUC_CODIGO,V_NEG_CONSECUTIVO);
           FETCH CONSECUTIVO_DAU INTO V_CONSECUTIVO_DAU;
           CLOSE CONSECUTIVO_DAU;

           BEGIN
             BEGIN
               INSERT INTO DETALLES_CARGOS_CUENTAS
               (
                  DAU_CONSECUTIVO
                 ,DAU_SUC_CODIGO
                 ,DAU_NEG_CONSECUTIVO
                 ,DAU_TIU_MNEMONICO
                 ,DAU_VALOR
                 ,DAU_ORD_CONSECUTIVO
                 ,DAU_ORD_SUC_CODIGO
               )
               VALUES
               (       V_CONSECUTIVO_DAU
                      ,C_VALIDA_COMERCIAL.PER_SUC_CODIGO
                      ,V_NEG_CONSECUTIVO
                      ,C_DET_CAR_CODIVISAS.DAC_TIU_MNEMONICO
                      ,C_DET_CAR_CODIVISAS.DAC_VALOR
                      ,P_ID_ORDEN
                      ,C_VALIDA_COMERCIAL.PER_SUC_CODIGO);
               EXCEPTION WHEN OTHERS THEN
                 V_ERRORES := V_ERRORES+1;
                 -- BORRADO DE TABLAS TEMPORALES
                 DELETE RECAUDOS_CODIVISAS
                     WHERE ORC_IDCODIVISAS  = P_IDCODIVISAS;


                 DELETE DETALLES_CARGO_CODIVISAS WHERE DAC_IDCODIVISAS = P_IDCODIVISAS;

                 DELETE PAGOS_EXTERIOR_CODIVISAS
                   WHERE PXC_IDCODIVISAS =  P_IDCODIVISAS;


                 DELETE OPERACION_DIVISAS_ENTRE_MESAS where OME_CONSECUTIVO = V_OME_CONSECUTIVO;

                 DELETE  ORDENES_RECAUDO WHERE ORR_CONSECUTIVO = V_ORR_CONSECUTIVO AND ORR_SUC_CODIGO = C_VALIDA_COMERCIAL.PER_SUC_CODIGO AND ORR_NEG_CONSECUTIVO = V_NEG_CONSECUTIVO;

                 DELETE CENLINEA_NOTIFICA_CANJE_DIV WHERE  CNCD_ID_CODIVISAS = P_IDCODIVISAS;

                 DELETE DETALLES_CARGOS_CUENTAS WHERE DAU_CONSECUTIVO = V_CONSECUTIVO_DAU AND DAU_SUC_CODIGO = C_VALIDA_COMERCIAL.PER_SUC_CODIGO AND DAU_NEG_CONSECUTIVO = V_NEG_CONSECUTIVO;

                 DELETE ORDENES_DIVISAS WHERE ORD_CONSECUTIVO = P_ID_ORDEN  AND ORD_SUC_CODIGO = C_VALIDA_COMERCIAL.PER_SUC_CODIGO;

                 COMMIT;
                 P_ID_ORDEN := NULL;
                 P_CLOB := NULL ;
                 RAISE_APPLICATION_ERROR(-20900, 'Errores en colocacion ordenes divisas:'||SQLERRM);         
             END;
             IF SQL%ROWCOUNT = 0 THEN
               V_ERRORES := V_ERRORES+1;
               P_ID_ORDEN := NULL;
             END IF;
           END;
           FETCH DET_CAR_CODIVISAS INTO C_DET_CAR_CODIVISAS;
         END LOOP;
         CLOSE DET_CAR_CODIVISAS;
       END IF;

       --- CREACION ORDENES PAGO EXTERIOR
       OPEN OPE_DIVISAS;
       FETCH OPE_DIVISAS INTO C_OPE_DIVISAS;
       WHILE OPE_DIVISAS%FOUND LOOP

         OPEN CONSECUTIVO_OPE;
         FETCH CONSECUTIVO_OPE INTO V_OPE_CONSECUTIVO;
         CLOSE CONSECUTIVO_OPE;
         V_OPE_CONSECUTIVO     := NVL(V_OPE_CONSECUTIVO,0) + 1;

         IF C_OPE_DIVISAS.PXC_PAGAR_A IN ( 'C','SE')  AND C_OPE_DIVISAS.PXC_DESTINO = 'CE'  AND C_OPE_DIVISAS.PXC_CBX_NUMERO_CUENTA IS NULL THEN
           V_ERRORES := V_ERRORES+1;
           P_CAB.CREARERROR('Para cliente o segundo con destino Transferencias al Exterior se debe especificar banco del exterior');
         END IF;

         IF C_OPE_DIVISAS.PXC_PAGAR_A  IN ( 'C','SE')  AND C_OPE_DIVISAS.PXC_DESTINO != 'CE'  AND C_OPE_DIVISAS.PXC_CBX_NUMERO_CUENTA IS NOT NULL THEN
           V_ERRORES := V_ERRORES+1;
           P_CAB.CREARERROR('Para cliente o segundo con destino diferente a Transferencias al Exterior NO se debe especificar banco del exterior');
         END IF;

         IF V_ERRORES > 0 THEN
           CLOSE OPE_DIVISAS;
           EXIT;
         END IF;

         IF C_OPE_DIVISAS.PXC_PAGAR_A = 'C' AND C_OPE_DIVISAS.PXC_DESTINO = 'CE' THEN
           V_OPE_CBX_CLI_PER_NUM_IDEN     := V_P_CLI_NUM_IDEN ;
           V_OPE_CBX_CLI_PER_TID_CODIGO   := V_P_CLI_TID_CODIGO;
           V_OPE_OCL_CLI_PER_NUM_IDEN     := NULL;
           V_OPE_OCL_CLI_PER_TID_CODIGO   := NULL;
           V_OPE_OCL_CLI_PER_NUM_REL      := NULL;
           V_OPE_OCL_CLI_PER_TID_REL      := NULL;
         ELSIF  C_OPE_DIVISAS.PXC_PAGAR_A = 'S' AND C_OPE_DIVISAS.PXC_DESTINO = 'CE' THEN
           V_OPE_CBX_CLI_PER_NUM_IDEN     := C_OPE_DIVISAS.PXC_OCL_CLI_PER_NUM_REL ;
           V_OPE_CBX_CLI_PER_TID_CODIGO   := C_OPE_DIVISAS.PXC_OCL_CLI_PER_TID_REL;
           V_OPE_OCL_CLI_PER_NUM_IDEN     := V_P_CLI_NUM_IDEN   ;
           V_OPE_OCL_CLI_PER_TID_CODIGO   := V_P_CLI_TID_CODIGO;
           V_OPE_OCL_CLI_PER_NUM_REL      := C_OPE_DIVISAS.PXC_OCL_CLI_PER_NUM_REL;
           V_OPE_OCL_CLI_PER_TID_REL      := C_OPE_DIVISAS.PXC_OCL_CLI_PER_NUM_REL;
         ELSE
           V_OPE_CBX_CLI_PER_NUM_IDEN     := NULL ;
           V_OPE_CBX_CLI_PER_TID_CODIGO   := NULL;
           V_OPE_OCL_CLI_PER_NUM_IDEN     := NULL;
           V_OPE_OCL_CLI_PER_TID_CODIGO   := NULL;
           V_OPE_OCL_CLI_PER_NUM_REL      := NULL;
           V_OPE_OCL_CLI_PER_TID_REL      := NULL;
         END IF;

         BEGIN
           BEGIN
             INSERT INTO ORDENES_PAGOS_EXTERIOR
             (
               OPE_CONSECUTIVO
              ,OPE_SUC_CODIGO
              ,OPE_NEG_CONSECUTIVO
              ,OPE_ESTADO
              ,OPE_FECHA
              ,OPE_CLIENTE_TERCERO
              ,OPE_PAGAR_A
              ,OPE_VALOR_DOLARES
              ,OPE_VALOR_GASTOS
              ,OPE_DESTINO
              ,OPE_BENEFICIARIO
              ,OPE_CBX_NUMERO_CUENTA
              ,OPE_CBX_BEX_MNEMONICO
              ,OPE_CBX_CLI_PER_NUM_IDEN
              ,OPE_CBX_CLI_PER_TID_CODIGO
              ,OPE_OCL_CLI_PER_NUM_IDEN
              ,OPE_OCL_CLI_PER_TID_CODIGO
              ,OPE_OCL_CLI_PER_NUM_REL
              ,OPE_OCL_CLI_PER_TID_REL
              ,OPE_ORD_CONSECUTIVO
              ,OPE_ORD_SUC_CODIGO
             )
             VALUES
             (
               V_OPE_CONSECUTIVO                                  --OPE_CONSECUTIVO
              ,C_VALIDA_COMERCIAL.PER_SUC_CODIGO                  --OPE_SUC_CODIGO
              ,2                                                  --OPE_NEG_CONSECUTIVO
              ,C_OPE_DIVISAS.PXC_ESTADO                           --OPE_ESTADO
              ,SYSDATE                                            --OPE_FECHA
              ,'C'                                                --OPE_CLIENTE_TERCERO
              ,C_OPE_DIVISAS.PXC_PAGAR_A                          --OPE_PAGAR_A
              ,C_OPE_DIVISAS.PXC_VALOR_DOLARES                    --OPE_VALOR_DOLARES
              ,0                                                  --OPE_VALOR_GASTOS
              ,DECODE(C_OPE_DIVISAS.PXC_PAGAR_A,'T',
                          'P', C_OPE_DIVISAS.PXC_DESTINO)         --OPE_DESTINO
              ,C_OPE_DIVISAS.PXC_BENEFICIARIO                     --OPE_BENEFICIARIO
              ,C_OPE_DIVISAS.PXC_CBX_NUMERO_CUENTA                --OPE_CBX_NUMERO_CUENTA
              ,C_OPE_DIVISAS.PXC_CBX_BEX_MNEMONICO                --OPE_CBX_BEX_MNEMONICO
              ,V_OPE_CBX_CLI_PER_NUM_IDEN                         --OPE_CBX_CLI_PER_NUM_IDEN
              ,V_OPE_CBX_CLI_PER_TID_CODIGO                       --OPE_CBX_CLI_PER_TID_CODIGO
              ,V_OPE_OCL_CLI_PER_NUM_IDEN                         --OPE_OCL_CLI_PER_NUM_IDEN
              ,V_OPE_OCL_CLI_PER_TID_CODIGO                       --OPE_OCL_CLI_PER_TID_CODIGO
              ,V_OPE_OCL_CLI_PER_NUM_REL                          --OPE_OCL_CLI_PER_NUM_REL
              ,V_OPE_OCL_CLI_PER_TID_REL                          --OPE_OCL_CLI_PER_TID_REL
              ,P_ID_ORDEN                                         --OPE_ORD_CONSECUTIVO
              ,C_VALIDA_COMERCIAL.PER_SUC_CODIGO                  --OPE_ORD_SUC_CODIGO
             );
             EXCEPTION WHEN OTHERS THEN
                 V_ERRORES := V_ERRORES+1;
                 -- BORRADO DE TABLAS TEMPORALES
                 DELETE RECAUDOS_CODIVISAS
                     WHERE ORC_IDCODIVISAS  = P_IDCODIVISAS;


                 DELETE DETALLES_CARGO_CODIVISAS WHERE DAC_IDCODIVISAS = P_IDCODIVISAS;

                 DELETE PAGOS_EXTERIOR_CODIVISAS
                   WHERE PXC_IDCODIVISAS =  P_IDCODIVISAS;


                 DELETE OPERACION_DIVISAS_ENTRE_MESAS WHERE OME_CONSECUTIVO = V_OME_CONSECUTIVO;

                 DELETE  ORDENES_RECAUDO WHERE ORR_CONSECUTIVO = V_ORR_CONSECUTIVO AND ORR_SUC_CODIGO = C_VALIDA_COMERCIAL.PER_SUC_CODIGO AND ORR_NEG_CONSECUTIVO = V_NEG_CONSECUTIVO;

                 DELETE CENLINEA_NOTIFICA_CANJE_DIV WHERE  CNCD_ID_CODIVISAS = P_IDCODIVISAS;

                 DELETE DETALLES_CARGOS_CUENTAS WHERE DAU_CONSECUTIVO = V_CONSECUTIVO_DAU AND DAU_SUC_CODIGO = C_VALIDA_COMERCIAL.PER_SUC_CODIGO AND DAU_NEG_CONSECUTIVO = V_NEG_CONSECUTIVO;

                 DELETE ORDENES_PAGOS_EXTERIOR WHERE OPE_CONSECUTIVO = V_OPE_CONSECUTIVO;

                 DELETE ORDENES_DIVISAS WHERE ORD_CONSECUTIVO = P_ID_ORDEN  AND ORD_SUC_CODIGO = C_VALIDA_COMERCIAL.PER_SUC_CODIGO;

                 COMMIT;
                 P_ID_ORDEN := NULL;
                 P_CLOB := NULL ;
                 RAISE_APPLICATION_ERROR(-20900, 'Errores en colocacion ordenes divisas:'||SQLERRM);         
           END;
           IF  SQL%ROWCOUNT = 0 THEN
               V_ERRORES := V_ERRORES+1;
               P_ID_ORDEN := NULL;
               EXIT;
           END IF;
         END;
         FETCH OPE_DIVISAS INTO C_OPE_DIVISAS;
       END LOOP;
       CLOSE OPE_DIVISAS;
     END IF;
   END IF;


   IF V_ERRORES = 0 THEN
     -- BORRADO DE TABLAS TEMPORALES
     DELETE RECAUDOS_CODIVISAS
         WHERE ORC_IDCODIVISAS  = P_IDCODIVISAS;


     DELETE DETALLES_CARGO_CODIVISAS WHERE DAC_IDCODIVISAS = P_IDCODIVISAS;

     DELETE PAGOS_EXTERIOR_CODIVISAS
       WHERE PXC_IDCODIVISAS =  P_IDCODIVISAS;
     COMMIT;
   ELSE

     P_CLOB := P_CAB.OBTENERCLOB_ERROR('ColocarOrdenDivisas') ;


     -- BORRADO DE TABLAS TEMPORALES
     DELETE RECAUDOS_CODIVISAS
         WHERE ORC_IDCODIVISAS  = P_IDCODIVISAS;


     DELETE DETALLES_CARGO_CODIVISAS WHERE DAC_IDCODIVISAS = P_IDCODIVISAS;

     DELETE PAGOS_EXTERIOR_CODIVISAS
       WHERE PXC_IDCODIVISAS =  P_IDCODIVISAS;

     DELETE OPERACION_DIVISAS_ENTRE_MESAS where OME_CONSECUTIVO = V_OME_CONSECUTIVO;

     DELETE  ORDENES_RECAUDO WHERE ORR_CONSECUTIVO = V_ORR_CONSECUTIVO AND ORR_SUC_CODIGO = C_VALIDA_COMERCIAL.PER_SUC_CODIGO AND ORR_NEG_CONSECUTIVO = V_NEG_CONSECUTIVO;

     DELETE CENLINEA_NOTIFICA_CANJE_DIV WHERE  CNCD_ID_CODIVISAS = P_IDCODIVISAS;

     DELETE DETALLES_CARGOS_CUENTAS WHERE DAU_CONSECUTIVO = V_CONSECUTIVO_DAU AND DAU_SUC_CODIGO = C_VALIDA_COMERCIAL.PER_SUC_CODIGO AND DAU_NEG_CONSECUTIVO = V_NEG_CONSECUTIVO;

     DELETE ORDENES_PAGOS_EXTERIOR WHERE OPE_CONSECUTIVO = V_OPE_CONSECUTIVO;

     DELETE ORDENES_DIVISAS WHERE ORD_CONSECUTIVO = P_ID_ORDEN  AND ORD_SUC_CODIGO = C_VALIDA_COMERCIAL.PER_SUC_CODIGO;

     P_ID_ORDEN := NULL;
     COMMIT;

   END IF;

     --- Validar que la orden tenga ORDEN_PAGOS_EXTERIOR_ASOCIADOS
   IF V_TIPO_ORDEN = 'V'  THEN
     IF V_ORIGEN_OPERACION NOT IN ('M','P') THEN
       V_VALIDA_PAG_EXTERIOR := 0;
       SELECT COUNT(*) INTO V_VALIDA_PAG_EXTERIOR
       FROM ORDENES_PAGOS_EXTERIOR
       WHERE OPE_ORD_CONSECUTIVO=P_ID_ORDEN           
         AND OPE_ORD_SUC_CODIGO = C_VALIDA_COMERCIAL.PER_SUC_CODIGO ;

       IF NVL(V_VALIDA_PAG_EXTERIOR,0) = 0 THEN
         V_ERRORES := V_ERRORES+1;
         P_ID_ORDEN := NULL;
         P_CAB.CREARERROR('Orden de divisas sin pago exterior asociado');
         P_CLOB := P_CAB.OBTENERCLOB_ERROR('ColocarOrdenDivisas') ;
       END IF;     
     END IF;
   END IF;

END P_COLOCAR_ORDEN_DIV;

PROCEDURE P_ANULAR_ORDEN_DIVISAS(P_TIPO_ORDEN   IN VARCHAR2,
                                 P_ID_ORDEN     IN NUMBER,
                                 P_USUARIO      IN VARCHAR2,
                                 P_TERMINAL     IN VARCHAR2,
                                 P_ERRORES      IN OUT NUMBER) IS
  CURSOR COMERCIAL IS
    SELECT *
    FROM PERSONAS
    WHERE PER_NOMBRE_USUARIO = P_USUARIO
      AND PER_ES_CORREDOR    = 'S'
      AND PER_SUC_CODIGO     IS NOT NULL;


  CURSOR ORDEN(P_ORDEN NUMBER,P_SUC_CODIGO NUMBER) IS
    SELECT *
    FROM ORDENES_DIVISAS
    WHERE ORD_CONSECUTIVO  IS NOT NULL
     AND ORD_SUC_CODIGO = P_SUC_CODIGO
     AND ORD_IDCODIVISAS = P_ORDEN;

   CURSOR FACTURA(P_ORDEN NUMBER,P_SUC_CODIGO NUMBER) IS
      SELECT *
      FROM   FACTURAS_DIVISAS
      WHERE  FAD_ORD_CONSECUTIVO = P_ORDEN
        AND  FAD_ORD_SUC_CODIGO  = P_SUC_CODIGO
        AND  NVL(FAD_ANULADO,'N') = 'N';

   CURSOR ORDEN_ODP(P_ORDEN NUMBER,P_SUC_CODIGO NUMBER) IS
      SELECT ODP_SUC_CODIGO
            ,ODP_CONSECUTIVO
            ,ODP_ESTADO
            ,ODP_MONTO_ORDEN
            ,ODP_ORD_SUC_CODIGO
            ,ODP_ORD_CONSECUTIVO
            ,ODP_TBC_CONSECUTIVO
            ,ODP_TCC_CONSECUTIVO
            ,ODP_CEG_CONSECUTIVO
            ,ODP_CGE_CONSECUTIVO
      FROM   ORDENES_DE_PAGO
      WHERE  ODP_ORD_CONSECUTIVO = P_ORDEN
       AND   ODP_ORD_SUC_CODIGO = P_SUC_CODIGO;


   CURSOR OP_REGISTRADA(P_OME OPERACION_DIVISAS_ENTRE_MESAS.OME_CONSECUTIVO%TYPE) IS
     SELECT 'S'
     FROM OPERACION_DIVISAS_ENTRE_MESAS
     WHERE OME_CONSECUTIVO = P_OME
     AND   OME_ESTADO = 'REG';

   CURSOR OPE(P_ORDEN NUMBER,P_SUC_CODIGO NUMBER) IS
      SELECT OPE_CONSECUTIVO
            ,OPE_ESTADO
            ,OPE_VALOR_DOLARES
            ,OPE_VALOR_GASTOS
            ,OPE_ORD_SUC_CODIGO
            ,OPE_ORD_CONSECUTIVO
      FROM   ORDENES_PAGOS_EXTERIOR
      WHERE  OPE_ORD_CONSECUTIVO = P_ORDEN
      AND    OPE_ORD_SUC_CODIGO = P_SUC_CODIGO;


  C_COMERCIAL        COMERCIAL%ROWTYPE;
  C_ORDEN            ORDEN%ROWTYPE;
  C_FACTURA          FACTURA%ROWTYPE;
  C_ORDEN_ODP        ORDEN_ODP%ROWTYPE;
  C_OP_REGISTRADA    OP_REGISTRADA%ROWTYPE;
  C_OPE              OPE%ROWTYPE;
  V_EXISTE_ORDEN_ODP NUMBER(5);
  V_EXISTE_ORDEN_OPE NUMBER(5);
  V_EXISTE_OP        VARCHAR2(1) := 'N';
BEGIN
  P_ERRORES := 0;
  OPEN COMERCIAL;
  FETCH COMERCIAL INTO C_COMERCIAL;
  IF COMERCIAL%NOTFOUND THEN
    P_ERRORES := P_ERRORES+1;
    P_CAB.CREARERROR('Comercial no existe en Coeasy :'||P_USUARIO);
  END IF;
  CLOSE COMERCIAL;

  IF P_ERRORES = 0 THEN
    OPEN ORDEN(P_ORDEN =>P_ID_ORDEN ,P_SUC_CODIGO =>C_COMERCIAL.PER_SUC_CODIGO );
    FETCH ORDEN INTO C_ORDEN;
    IF ORDEN%NOTFOUND THEN
      P_ERRORES := P_ERRORES+1;
      P_CAB.CREARERROR('Orden divisas no existe :'||P_ID_ORDEN);
    ELSE
      IF C_ORDEN.ORD_EOF_CODIGO != 'COL' THEN
        P_ERRORES := P_ERRORES+1;
        P_CAB.CREARERROR('Orden divisas en estado invalido para anular:'||C_ORDEN.ORD_CONSECUTIVO);
      END IF;

      OPEN FACTURA(P_ORDEN =>C_ORDEN.ORD_CONSECUTIVO ,P_SUC_CODIGO =>C_ORDEN.ORD_SUC_CODIGO ) ;
      FETCH FACTURA INTO C_FACTURA;
      IF FACTURA%FOUND THEN
        P_ERRORES := P_ERRORES+1;
        P_CAB.CREARERROR('La Orden de Divisas Posee Facturas Asociadas .. Deben Anularse primero');
      END IF;
      CLOSE FACTURA;

      IF C_ORDEN.ORD_ORIGEN_OPERACION NOT IN ('P','M','R') THEN
        V_EXISTE_ORDEN_ODP := 0;
        OPEN ORDEN_ODP(P_ORDEN =>C_ORDEN.ORD_CONSECUTIVO ,P_SUC_CODIGO =>C_ORDEN.ORD_SUC_CODIGO );
        FETCH ORDEN_ODP INTO C_ORDEN_ODP;
        WHILE ORDEN_ODP%FOUND LOOP
          IF C_ORDEN_ODP.ODP_TBC_CONSECUTIVO IS NOT NULL OR
             C_ORDEN_ODP.ODP_TCC_CONSECUTIVO IS NOT NULL OR
             C_ORDEN_ODP.ODP_CEG_CONSECUTIVO IS NOT NULL OR
             C_ORDEN_ODP.ODP_CGE_CONSECUTIVO IS NOT NULL THEN
            V_EXISTE_ORDEN_ODP := V_EXISTE_ORDEN_ODP+1;
          END IF;
          FETCH ORDEN_ODP INTO C_ORDEN_ODP;
        END LOOP;
        CLOSE ORDEN_ODP;
        IF V_EXISTE_ORDEN_ODP > 0 THEN
          P_ERRORES := P_ERRORES+1;
          P_CAB.CREARERROR('La Orden de Divisas ya ha sido ejecutada ... Comuniquese con tesoreria');
        END IF;
      END IF;

      IF C_ORDEN.ORD_ORIGEN_OPERACION = 'M'  AND C_ORDEN.ORD_OME_CONSECUTIVO IS NOT NULL THEN
        OPEN OP_REGISTRADA(C_ORDEN.ORD_OME_CONSECUTIVO);
        FETCH OP_REGISTRADA INTO V_EXISTE_OP;
        CLOSE OP_REGISTRADA;

        IF NVL(V_EXISTE_OP, 'N') != 'S' THEN
          P_ERRORES := P_ERRORES+1;
          P_CAB.CREARERROR('No se encontró en estado Registrado la operación entre mesas número '||C_ORDEN.ORD_OME_CONSECUTIVO||
                            ' correspondiente a la orden divisas:'||C_ORDEN.ORD_CONSECUTIVO);
        END IF;
      END IF;
    END IF;
    CLOSE ORDEN;

    -- VALIDA ORDENES DE PAGO EXTERIOR
    V_EXISTE_ORDEN_OPE := 0;
    OPEN OPE(P_ORDEN =>C_ORDEN.ORD_CONSECUTIVO,P_SUC_CODIGO =>C_ORDEN.ORD_SUC_CODIGO );
    FETCH OPE INTO C_OPE;
    WHILE OPE%FOUND LOOP
      IF C_OPE.OPE_ESTADO = 'APL' THEN
        V_EXISTE_ORDEN_OPE := V_EXISTE_ORDEN_OPE+1;
        EXIT;
      END IF;
      FETCH OPE INTO C_OPE;
    END LOOP;
    CLOSE OPE;

    IF V_EXISTE_ORDEN_OPE > 0 THEN
      P_ERRORES := P_ERRORES+1;
      P_CAB.CREARERROR('Existen Ordenes de Pago en el exterior ya ejecutadas, se deben reversar');
    END IF;

    -- TENER EN CUENTA ANULACION DE ORDENES ENTRE MESAS
    IF P_ERRORES = 0 THEN   -- ANULACION DE ORDEN DE DIVISAS, ORDENES_RECAUDO,DETALLES_PAGOS_DCVAL,ORDENES_PAGOS_EXTERIOR,OPERACION_DIVISAS_ENTRE_MESAS
      ---ANULAR ORDENES DE PAGO

        IF C_ORDEN.ORD_TIPO_ORDEN  = 'C' THEN
          BEGIN
            UPDATE ORDENES_DE_PAGO
              SET ODP_ESTADO = 'ANU'
                 ,ODP_ANULADA_POR = P_USUARIO
                 ,ODP_FECHA_ANULACION = SYSDATE
                 ,ODP_RAZON_ANULACION = 'Reversion Operacion Divisas Asociada.'
            WHERE ODP_ORD_SUC_CODIGO = C_ORDEN.ORD_SUC_CODIGO
              AND ODP_ORD_CONSECUTIVO = C_ORDEN.ORD_CONSECUTIVO;
          END;



        IF  C_ORDEN.ORD_TIPO_ORDEN  = 'V' THEN
          BEGIN
            UPDATE ORDENES_RECAUDO
              SET    ORR_ESTADO = 'ANU'
            WHERE  ORR_ORD_SUC_CODIGO = C_ORDEN.ORD_SUC_CODIGO
              AND    ORR_ORD_CONSECUTIVO = C_ORDEN.ORD_CONSECUTIVO;
          END;
        END IF;
     END IF;

      IF  C_ORDEN.ORD_ORIGEN_OPERACION = 'M' THEN
        BEGIN
          UPDATE OPERACION_DIVISAS_ENTRE_MESAS
            SET OME_ESTADO = 'ANU'
          WHERE OME_CONSECUTIVO = C_ORDEN.ORD_OME_CONSECUTIVO;
        END;
      END IF;

      IF C_ORDEN.ORD_ORIGEN_OPERACION NOT IN ('P','M') THEN
        BEGIN
          UPDATE ORDENES_PAGOS_EXTERIOR
          SET OPE_ESTADO = 'ANU',
             OPE_ANULADA_POR = P_USUARIO,
             OPE_FECHA_ANULACION = SYSDATE,
             OPE_TERMINAL_ANULACION = P_TERMINAL
          WHERE OPE_ORD_SUC_CODIGO = C_ORDEN.ORD_SUC_CODIGO
            AND OPE_ORD_CONSECUTIVO = C_ORDEN.ORD_CONSECUTIVO
            AND OPE_ESTADO = 'COL';
        END;
      END IF;

      BEGIN
        UPDATE ORDENES_DIVISAS
          SET ORD_FECHA_ANULACION = SYSDATE,
              ORD_ANULADA_POR     = P_USUARIO,
              ORD_EOF_CODIGO      = 'ANU'
        WHERE ORD_SUC_CODIGO = C_ORDEN.ORD_SUC_CODIGO
          AND ORD_CONSECUTIVO = C_ORDEN.ORD_CONSECUTIVO;
        IF SQL%ROWCOUNT = 0 THEN
          RAISE_APPLICATION_ERROR(-20001,'Orden de divisas:'||P_TIPO_ORDEN||'-'||C_ORDEN.ORD_CONSECUTIVO ||' no existe .. no es posible anularla') ;
        END IF;
      END;
    END IF;


  END IF;

  EXCEPTION
     WHEN OTHERS THEN
       RAISE_APPLICATION_ERROR(-20001,'Error en procedimiento P_ANULAR_ORDEN_DIVISAS : '||sqlerrm);

END P_ANULAR_ORDEN_DIVISAS;

---- PROCEDIMIENTO PARA CONTROLES EN LINEA------------------
PROCEDURE P_NOTIFICA_OPERACION_DIV( P_ID_ORDEN            IN NUMBER,
                                    P_TIPO                IN VARCHAR2,
                                    P_INTERBANCARIO       IN VARCHAR2,
                                    P_VALOR_DOLARES       IN NUMBER,
                                    P_TASA                IN NUMBER,
                                    P_USUARIO             IN VARCHAR2,
                                    P_PER_NUM_IDEN        IN VARCHAR2,
                                    P_PER_TID_CODIGO      IN VARCHAR2,
                                    P_CLI_PER_NUM_IDEN    IN VARCHAR2,
                                    P_CLI_PER_TID_COD     IN VARCHAR2,
                                    P_NEXT_DAY            IN VARCHAR2,
                                    P_ORIGEN_OPERACION    IN VARCHAR2,
                                    P_ESTADO_ORD_DIV      IN VARCHAR2,
                                    P_MONEDA_FX           IN VARCHAR2,
                                    P_FECHA_CUMP_NEXTDAY  IN VARCHAR,
                                    P_CODIGO_CONTRAPARTE  IN VARCHAR2,
                                    P_LLAMADO             IN VARCHAR2 DEFAULT NULL,
                                    P_ERRORES             IN OUT NUMBER)  AS
  CURSOR ORDEN IS
    SELECT *
    FROM ORDENES_DIVISAS
    WHERE ORD_IDCODIVISAS = P_ID_ORDEN;

  C_ORDEN              ORDEN%ROWTYPE;  
  V_NEXT_DAY           VARCHAR2(1);
  V_FECHA_CUMP_NEXTDAY DATE;
BEGIN
  P_ERRORES := 0;
  -- con la entrada de notificaon se hablita

  IF NVL(P_LLAMADO,' ') != ' ' THEN
     IF P_ORIGEN_OPERACION = 'M' THEN
        OPEN ORDEN;
        FETCH ORDEN INTO C_ORDEN;
        IF ORDEN%FOUND THEN       
           IF NVL(C_ORDEN.ORD_DIAS_NEXT_DAY,0) >= 1 THEN
              V_NEXT_DAY := 'S';
              V_FECHA_CUMP_NEXTDAY := C_ORDEN.ORD_FECHA_CUMPLIMIENTO;
           ELSE
              V_NEXT_DAY := 'N';
              V_FECHA_CUMP_NEXTDAY := C_ORDEN.ORD_FECHA_COLOCACION;
           END IF;
        ELSE
           V_NEXT_DAY := P_NEXT_DAY; 
           V_FECHA_CUMP_NEXTDAY := TO_DATE(P_FECHA_CUMP_NEXTDAY,'DD-MM-YYYY'); 
        END IF;
        CLOSE ORDEN;    
     ELSE
        V_NEXT_DAY := P_NEXT_DAY; 
        V_FECHA_CUMP_NEXTDAY := TO_DATE(P_FECHA_CUMP_NEXTDAY,'DD-MM-YYYY');
     END IF;
  ELSE
     V_NEXT_DAY := P_NEXT_DAY; 
     V_FECHA_CUMP_NEXTDAY := TO_DATE(P_FECHA_CUMP_NEXTDAY,'DD-MM-YYYY');
  END IF;


  BEGIN 
    INSERT INTO CENLINEA_NOTIFICA_DIV
        (CNDV_CONSECUTIVO
        ,CNDV_ESTADO
        ,CNDV_FECHA_INGRESO
        ,CNDV_FECHA_ENTREGA
        ,CNDV_TIPO
        ,CNDV_INTERBANCARIO
        ,CNDV_VALOR_DOLARES
        ,CNDV_TASA
        ,CNDV_PER_TID_CODIGO
        ,CNDV_PER_NUM_IDEN
        ,CNDV_CLI_PER_TID_CODIGO
        ,CNDV_CLI_PER_NUM_IDEN
        ,CNDV_NEXTDAY
        ,CNDV_OPERACION_ORIGEN
        ,CNDV_USUARIO
        ,CNDV_EOC_MNENMONICO
        ,CNDV_BMO_MNEMONICO
        ,CNDV_FECHA_CUMP_NEXTDAY
        ,CNDV_CODIGO_CONTRAPARTE
        ,CNDV_ID_CODIVISAS)
    VALUES
        (CNDV_SEQ.NEXTVAL         --CNDV_CONSECUTIVO
        ,'POR_PROCESAR'           --CNDV_ESTADO
        ,SYSDATE                  --CNDV_FECHA_INGRESO
        ,NULL                     --CNDV_FECHA_ENTREGA
        ,P_TIPO                   --CNDV_TIPO
        ,P_INTERBANCARIO          --CNDV_INTERBANCARIO
        ,P_VALOR_DOLARES          --CNDV_VALOR_DOLARES
        ,P_TASA                   --CNDV_TASA
        ,P_PER_TID_CODIGO         --CNDV_PER_TID_CODIGO
        ,P_PER_NUM_IDEN           --CNDV_PER_NUM_IDEN
        ,P_CLI_PER_TID_COD        --CNDV_CLI_PER_TID_CODIGO
        ,P_CLI_PER_NUM_IDEN       --CNDV_CLI_PER_NUM_IDEN
        ,V_NEXT_DAY               --CNDV_NEXTDAY
        ,P_ORIGEN_OPERACION       --CNDV_OPERACION_ORIGEN
        ,P_USUARIO                --CNDV_USUARIO
        ,P_ESTADO_ORD_DIV         --CNDV_EOC_MNENMONICO
        ,P_MONEDA_FX              -- CNDV_BMO_MNEMONICO
        ,V_FECHA_CUMP_NEXTDAY     --CNDV_FECHA_CUMP_NEXTDAY
        ,P_CODIGO_CONTRAPARTE     --CNDV_CODIGO_CONTRAPARTE
        ,P_ID_ORDEN);             --CNDV_ID_CODIVISAS
    IF SQL%ROWCOUNT = 0 THEN
       IF NVL(P_LLAMADO,' ') = ' ' THEN
          P_ERRORES := P_ERRORES+1;
          RAISE_APPLICATION_ERROR(-20301,SQLERRM || 'Error en notificacion operacion divisas');
       ELSE
          P_CAB.CrearError('Error en notificacion operacion divisas'||SQLERRM) ;
          P_ERRORES := P_ERRORES+1;
       END IF;
    END IF;
  END;
END P_NOTIFICA_OPERACION_DIV;

FUNCTION CALCULAR_FECHA_CUMPLIMIENTO(P_FECHA DATE) RETURN DATE AS
    CURSOR C_DIA_NO_HABIL(P_FECHA DATE) IS
       SELECT DNH_FECHA
       FROM   DIAS_NO_HABILES
       WHERE  TRUNC(DNH_FECHA) = TRUNC(P_FECHA)
       UNION
       SELECT DHI_FECHA
       FROM   DIAS_NO_HABILES_INT
       WHERE TRUNC(DHI_FECHA) = TRUNC(P_FECHA)
         AND DHI_PAI_CODIGO  = 'USA';
    C_DIA    C_DIA_NO_HABIL%ROWTYPE;
    V_FECHA  DATE;
    V_CUENTA NUMBER;
BEGIN
    V_FECHA := P_FECHA;
    WHILE TRUE LOOP
      V_CUENTA := 0;
      FOR K IN C_DIA_NO_HABIL(V_FECHA) LOOP
        V_CUENTA := V_CUENTA+1;
      END LOOP;
      IF NVL(V_CUENTA,0) > 0 OR TO_CHAR(V_FECHA,'D') IN (1,7) THEN
        V_FECHA := V_FECHA + 1;
      ELSE
        EXIT;
      END IF;
    END LOOP;
    RETURN V_FECHA;    
END CALCULAR_FECHA_CUMPLIMIENTO;


--- PROCEDIMIENTO DE CREACION DE REGISTRO EN PAGOS DIVISAS
PROCEDURE P_INSERTA_PADI(P_MONTO                  IN NUMBER 
                        ,P_ANULADO                IN VARCHAR2
                        ,P_ODP_CONSECUTIVO        IN NUMBER DEFAULT NULL
                        ,P_ODP_SUC_CODIGO         IN NUMBER DEFAULT NULL
                        ,P_ODP_NEG_CONSECUTIVO    IN NUMBER DEFAULT NULL
                        ,P_MCC_CONSECUTIVO        IN NUMBER DEFAULT NULL
                        ,P_MCC_MCC_CONSECUTIVO    IN NUMBER DEFAULT NULL
                        ,P_DAA_CONSECUTIVO        IN NUMBER DEFAULT NULL
                        ,P_DAA_SUC_CODIGO         IN NUMBER DEFAULT NULL
                        ,P_DAA_NEG_CONSECUTIVO    IN NUMBER DEFAULT NULL
                        ,P_DPA_CONSECUTIVO        IN NUMBER DEFAULT NULL) AS
BEGIN
  INSERT INTO PROD.PAGOS_DIVISAS(
      PADI_CONSECUTIVO
     ,PADI_MONTO
     ,PADI_ANULADO
     ,PADI_ODP_CONSECUTIVO
     ,PADI_ODP_SUC_CODIGO
     ,PADI_ODP_NEG_CONSECUTIVO
     ,PADI_MCC_CONSECUTIVO
     ,PADI_MCC_MCC_CONSECUTIVO
     ,PADI_DAA_CONSECUTIVO
     ,PADI_DAA_SUC_CODIGO
     ,PADI_DAA_NEG_CONSECUTIVO
     ,PADI_DPA_CONSECUTIVO)
  VALUES
  (
     PADI_SEQ.NEXTVAL
    ,P_MONTO
    ,P_ANULADO                
    ,DECODE(P_ODP_CONSECUTIVO,NULL,NULL,P_ODP_CONSECUTIVO)
    ,DECODE(P_ODP_SUC_CODIGO,NULL,NULL,P_ODP_SUC_CODIGO)      
    ,DECODE(P_ODP_NEG_CONSECUTIVO,NULL,NULL,P_ODP_NEG_CONSECUTIVO) 
    ,DECODE(P_MCC_CONSECUTIVO,NULL,NULL,P_MCC_CONSECUTIVO)       
    ,DECODE(P_MCC_MCC_CONSECUTIVO,NULL,NULL,P_MCC_MCC_CONSECUTIVO)   
    ,DECODE(P_DAA_CONSECUTIVO,NULL,NULL,P_DAA_CONSECUTIVO)       
    ,DECODE(P_DAA_SUC_CODIGO,NULL,NULL,P_DAA_SUC_CODIGO)         
    ,DECODE(P_DAA_NEG_CONSECUTIVO,NULL,NULL,P_DAA_NEG_CONSECUTIVO)
    ,DECODE(P_DPA_CONSECUTIVO,NULL,NULL,P_DPA_CONSECUTIVO));
EXCEPTION
   WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20001,SQLERRM || 'Error insertando PADI :'||SQLERRM);

END P_INSERTA_PADI;

PROCEDURE PR_FORMATO_AUNO(P_FECHA DATE DEFAULT NULL,
                          P_LLAMADO_REPORTE VARCHAR2  DEFAULT NULL,
                          P_REGISTRO_AUNO IN OUT T_REGISTRO_AUNO) IS

   CURSOR C_DPN (P_FECHA1 DATE) IS
      SELECT  CDI_PATRIMONIO_TECNICO_USD DPN_TECNICO
      FROM CIERRE_DIVISAS
      WHERE CDI_FECHA_PROCESO >= TRUNC(P_FECHA1)
        AND CDI_FECHA_PROCESO <  TRUNC(P_FECHA1+1);
   PATRIMONIO_TECNICO NUMBER;

   CURSOR C_BMO IS
      SELECT BMO_MNEMONICO
            ,BMO_CONS_BANREPUBLICA_AN1
            ,DECODE(BMO_CONS_BANREPUBLICA_AN1,99, 'Otras monedas', BMO_DESCRIPCION_BANREPUBLICA) BMO_DESCRIPCION_BANREPUBLICA
      FROM BASES_MONETARIAS
      WHERE BMO_CONS_BANREPUBLICA_AN1 IS NOT NULL
      UNION 
      SELECT 'HON' BMO_MNEMONICO, 6 BMO_CONS_BANREPUBLICA_AN1, 'Lempiras (HON)' BMO_DESCRIPCION_BANREPUBLICA  FROM DUAL
      UNION 
      SELECT 'CRC' BMO_MNEMONICO, 7 BMO_CONS_BANREPUBLICA_AN1, 'Colones (CRC)' BMO_DESCRIPCION_BANREPUBLICA  FROM DUAL
      UNION 
      SELECT 'GTM' BMO_MNEMONICO, 8 BMO_CONS_BANREPUBLICA_AN1, 'Quetzales (GTM)' BMO_DESCRIPCION_BANREPUBLICA  FROM DUAL
      UNION 
      SELECT 'NIO' BMO_MNEMONICO, 9 BMO_CONS_BANREPUBLICA_AN1, 'Córdobas (NIO)' BMO_DESCRIPCION_BANREPUBLICA  FROM DUAL
      UNION
      SELECT 'BRL' BMO_MNEMONICO, 12 BMO_CONS_BANREPUBLICA_AN1, 'Real brasilero (BRL)' BMO_DESCRIPCION_BANREPUBLICA  FROM DUAL
      ORDER BY BMO_CONS_BANREPUBLICA_AN1;
   R_BMO C_BMO%ROWTYPE;

   CURSOR C_CBE (BMO VARCHAR2) IS
      SELECT CBE_BEX_MNEMONICO
           , CBE_NUMERO_CUENTA
      FROM CUENTAS_BANCARIAS_EXTERIOR
      WHERE CBE_POSICION_PROPIA = 'S'
        AND CBE_BMO_MNEMONICO = BMO
        AND CBE_BEX_MNEMONICO NOT IN ('DEUTE','DEUTG')
      UNION
      SELECT CBE_BEX_MNEMONICO
           , CBE_NUMERO_CUENTA
      FROM CUENTAS_BANCARIAS_EXTERIOR
      WHERE CBE_POSICION_PROPIA = 'S'
        AND CBE_BEX_MNEMONICO IN ('DEUTE')
        AND BMO = 'EURO'
      UNION
      SELECT CBE_BEX_MNEMONICO
           , CBE_NUMERO_CUENTA
      FROM CUENTAS_BANCARIAS_EXTERIOR
      WHERE CBE_POSICION_PROPIA = 'S'
        AND CBE_BEX_MNEMONICO IN ('DEUTG')
        AND BMO = 'GBP';        
   R_CBE C_CBE%ROWTYPE;

   CURSOR C_MBE (BEX VARCHAR2, CTA VARCHAR2) IS   
      SELECT MBE_SALDO 
      FROM MOVIMIENTOS_BANCARIOS_EXTERIOR
      WHERE MBE_CBE_BEX_MNEMONICO = BEX
        AND MBE_CBE_NUMERO_CUENTA = CTA
        AND MBE_FECHA < TRUNC(P_FECHA + 1)
      ORDER BY MBE_FECHA DESC;
   R_MBE C_MBE%ROWTYPE;

   CURSOR C_CDI (FEC DATE) IS
      SELECT  NVL(CDI_SALDO_DEPOSITOS,0)  CDI_SALDO_DEPOSITOS
             ,NVL(CDI_DER_BVC_PP_COM,0) CDI_DER_BVC_PP_COM
             ,NVL(CDI_DER_BVC_PP_VEN,0) CDI_DER_BVC_PP_VEN
             ,NVL(CDI_ACTIVOS_ME_PLAZO1,0)+ NVL(CDI_ACTIVOS_ME_PLAZO2,0)+NVL(CDI_ACTIVOS_ME_PLAZO3,0)+NVL(CDI_ACTIVOS_ME_PLAZO4,0) CDI_DERECHOS_YANKEES
             ,NVL(CDI_PASIVOS_ME_PLAZO1,0)+ NVL(CDI_PASIVOS_ME_PLAZO2,0)+NVL(CDI_PASIVOS_ME_PLAZO3,0)+NVL(CDI_PASIVOS_ME_PLAZO4,0) CDI_OBLIGACIONES_YANKEES
      FROM CIERRE_DIVISAS
      WHERE CDI_FECHA_PROCESO >= TRUNC(FEC)
        AND CDI_FECHA_PROCESO <  TRUNC(FEC+1);
   R_CDI C_CDI%ROWTYPE;     

   CURSOR C_IFC IS
      SELECT   IFC_FACTOR  IFC_VALOR
      FROM INVERSION_FILIALES_CORREDORES
      WHERE IFC_FECHA_APLICACION < TRUNC(P_FECHA+1)
      ORDER BY IFC_FECHA_APLICACION DESC;
   R_IFC C_IFC%ROWTYPE;

   CURSOR C_PROV IS
      SELECT   BACO_VALOR
      FROM BALANCES_CORREDORES
      WHERE BACO_FECHA = LAST_DAY(P_FECHA)
        AND BACO_TIPO_BALANCE = 'CME'  --- BALANCE EN MONEDA
        AND BACO_CUENTA ='136095';
   R_PROV C_PROV%ROWTYPE;

   CURSOR C_LSF (BMO VARCHAR2, TIPO VARCHAR2) IS
      SELECT  SUM(LSF_NUMERO_TRANSADO) LSF_NUMERO_TRANSADO
      FROM LIQUIDACIONES_SET_FX
      WHERE LSF_NEXT_DAY = 'S' 
        AND LSF_ESTADO ='APL'
        AND LSF_BMO_MNEMONICO = BMO
        AND LSF_FECHA < TRUNC(P_FECHA+1)
        AND LSF_FECHA_CUMPLIMIENTO > TRUNC(P_FECHA)
        AND TIPO = 'C'
        AND ((LSF_OFERTA_DEMANDA = 'D'  AND (LSF_INSTITUCION_POSTURA LIKE 'CORREDORES ASOCIADOS%' OR LSF_INSTITUCION_POSTURA LIKE 'CORREDORES DAVIVIENDA S.A.%')) 
         OR (LSF_OFERTA_DEMANDA = 'O' AND (LSF_INSTITUCION_ACEPTANTE LIKE 'CORREDORES ASOCIADOS%' OR LSF_INSTITUCION_ACEPTANTE LIKE 'CORREDORES DAVIVIENDA S.A.%')))
      UNION
      SELECT  SUM(LSF_NUMERO_TRANSADO) LSF_NUMERO_TRANSADO
      FROM LIQUIDACIONES_SET_FX
      WHERE LSF_NEXT_DAY = 'S' 
        AND LSF_ESTADO ='APL'
        AND LSF_BMO_MNEMONICO = BMO
        AND LSF_FECHA < TRUNC(P_FECHA+1)
        AND LSF_FECHA_CUMPLIMIENTO > TRUNC(P_FECHA)
        AND TIPO = 'V'
        AND ((LSF_OFERTA_DEMANDA = 'O'  AND (LSF_INSTITUCION_POSTURA LIKE 'CORREDORES ASOCIADOS%' OR LSF_INSTITUCION_POSTURA LIKE 'CORREDORES DAVIVIENDA S.A.%')) 
        OR (LSF_OFERTA_DEMANDA = 'D' AND (LSF_INSTITUCION_ACEPTANTE LIKE 'CORREDORES ASOCIADOS%' OR LSF_INSTITUCION_ACEPTANTE LIKE 'CORREDORES DAVIVIENDA S.A.%')));
   R_LSF C_LSF%ROWTYPE;

   CURSOR C_ORD (BMO VARCHAR2 ,TIPO VARCHAR2) IS
      SELECT SUM(ORD_VALOR_DOLARES) ORD_DOLARES
      FROM ORDENES_DIVISAS 
      WHERE NVL(ORD_DIAS_NEXT_DAY,0) IN (1,2,3)
        AND ORD_FECHA_COLOCACION < TRUNC(P_FECHA+1)
        AND TRUNC(ORD_FECHA_CUMPLIMIENTO)  >= TRUNC(P_FECHA+1)   
        AND ORD_TIPO_ORDEN = TIPO
        AND NVL(ORD_BMO_MNEMONICO_FX,ORD_BMO_MNEMONICO)  = BMO
        AND (ORD_EOF_CODIGO in ('APL','APR')
             OR (ORD_EOF_CODIGO ='REV' AND ORD_FECHA_REVERSION > TRUNC(P_FECHA+1)));
   R_ORD C_ORD%ROWTYPE;             

   CURSOR C_SCFI IS
      SELECT SCFI_VALOR
      FROM SALDOS_CUENTAS_FILIALES
      WHERE SCFI_FECHA_APLICACION < TRUNC(P_FECHA+1)
      ORDER BY SCFI_FECHA_APLICACION DESC;
   R_SCFI C_SCFI%ROWTYPE;     

   CURSOR C_BACO (TIPO VARCHAR2) IS
      SELECT   SUM(BACO_VALOR) BACO_VALOR
      FROM BALANCES_CORREDORES
      WHERE BACO_FECHA = LAST_DAY(P_FECHA)
        AND BACO_TIPO_BALANCE = 'CCOP'  --- BALANCE EN PESOS
        AND TIPO = 'DERECHO'
        AND BACO_CUENTA IN (110505,110510,111005,112005,120400,120500,120700,121416,121419,121495,
                            122300,122406,122415,122416,126401,126402,126406,126415,126416,126431,
                            123462,126438,126800,126900,127000,127100,126501,126502,126503,126504,
                            126505,126506,126507,126508,126509,126510,126511,126512,126513,126514,
                            126515,126516,126517,126518,126519,126520,126521,126522,126523,126524,
                            126525,126526,126527,126528,126529,126530,126531,126532,126533,126534,
                            126545,126546,120200)
      UNION
      SELECT   SUM(BACO_VALOR) BACO_VALOR
      FROM BALANCES_CORREDORES
      WHERE BACO_FECHA = LAST_DAY(P_FECHA)
        AND BACO_TIPO_BALANCE = 'CCOP'  --- BALANCE EN PESOS
        AND TIPO = 'OBLIGACION'
        AND BACO_CUENTA IN (122425,122435,122436,126451,126452,126456,126465,126466,126481,126482,
                            126486,126551,126552,126553,126554,126555,126556,126557,126558,126559,
                            126560,126561,126562,126563,126564,126565,126566,126567,126568,126569,
                            126570,126571,126572,126573,126574,126575,126576,126577,126578,126579,
                            126580,126581,126582,126583,126584,126595,126596) ;
   R_BACO C_BACO%ROWTYPE;                            

   SALDO                 NUMBER := 0;
   V_DIA_TRM             DATE;
   VALOR_TRM             NUMBER := 0;
   DERECHO_IMC           NUMBER := 0;  
   OBLIGACION_IMC        NUMBER := 0;
   DERECHO_IMC_CONS      NUMBER := 0;
   OBLIGACION_IMC_CONS   NUMBER := 0;
   REL_IMC               NUMBER := 0;
   REL_IMC_CONS          NUMBER := 0;
   DERECHO_COP_IMC       NUMBER := 0;
   OBLIGACION_COP_IMC    NUMBER := 0;
   TOTAL_PATRIMONIO      NUMBER := 0;
   TOTAL_PATRIMONIO_CONS NUMBER := 0;
   REL_COP_IMC           NUMBER := 0;

   DERECHO_99_IMC        NUMBER := 0;
   OBLIGACION_99_IMC     NUMBER := 0;
   REL_99_IMC            NUMBER := 0;

   TOTAL_DERECHOS          NUMBER := 0;
   TOTAL_OBLIGACIONES      NUMBER := 0;
   REL_TOTAL_IMC           NUMBER := 0;
   TOTAL_DERECHOS_CONS     NUMBER := 0;
   TOTAL_OBLIGACIONES_CONS NUMBER := 0;
   REL_TOTAL_IMC_CONS      NUMBER := 0;


   P_ULTIMO_CDI       DATE;
   v_mensaje_error    VARCHAR2(1000);
   v_bufline          VARCHAR2(3000) := NULL;
   v_registro         NUMBER;
   error              EXCEPTION;

BEGIN
   SELECT MAX(CDI_FECHA_DIA) INTO P_ULTIMO_CDI FROM CIERRE_DIVISAS WHERE CDI_FECHA_DIA < TRUNC(P_FECHA+1);
   DELETE FROM GL_MONEDA_DO;

   OPEN C_DPN (P_ULTIMO_CDI);
   FETCH C_DPN INTO PATRIMONIO_TECNICO;
   IF C_DPN%NOTFOUND OR NVL(PATRIMONIO_TECNICO,0) = 0 THEN
      v_mensaje_error := 'No se pudo determinar el patrimonio tecnico vigente para el mes de '||TO_CHAR(P_FECHA,'MM-YYYY');
      RAISE ERROR;
   END IF;
   CLOSE C_DPN; 

   PATRIMONIO_TECNICO :=  NVL(PATRIMONIO_TECNICO,0);

   VALOR_TRM := P_WEB_EXTRACTO.ValorBMO ('DOLAR',P_FECHA+1);
   IF NVL(VALOR_TRM,0) = 0 THEN
      v_mensaje_error := 'No se pudo determinar el valor del Dolar para el dia '||TO_CHAR(P_FECHA+1,'DD-MON-YYYY');
      RAISE ERROR;
   END IF; 

   R_REGISTRO_AUNO.DELETE;
   v_bufline := 'ANEXO1';
   PR_ESCRIBE_FORMATO_AUNO(P_REGISTRO_AUNO  => R_REGISTRO_AUNO,P_BUFLINE      =>  v_bufline);
   v_bufline := 'FORMATO DE EXPOSICION CAMBIARIA POR MONEDA';
   PR_ESCRIBE_FORMATO_AUNO(P_REGISTRO_AUNO  => R_REGISTRO_AUNO,P_BUFLINE      =>  v_bufline);
   v_bufline := 'Montos expresados en US$ millones';
   PR_ESCRIBE_FORMATO_AUNO(P_REGISTRO_AUNO  => R_REGISTRO_AUNO,P_BUFLINE      =>  v_bufline);
   v_bufline := ' ,Posición IMC, , ,Posición IMC Consolidado';
   PR_ESCRIBE_FORMATO_AUNO(P_REGISTRO_AUNO  => R_REGISTRO_AUNO,P_BUFLINE      =>  v_bufline);
   v_bufline := 'Moneda,Derechos,Obligaciones,Posición neta/ Patrimonio Técnico, Derechos, Obligaciones, Posición neta/Patrimonio Técnico';
   PR_ESCRIBE_FORMATO_AUNO(P_REGISTRO_AUNO  => R_REGISTRO_AUNO,P_BUFLINE      =>  v_bufline);

   TOTAL_PATRIMONIO        := 0;
   TOTAL_PATRIMONIO_CONS   := 0;
   TOTAL_DERECHOS          := 0;
   TOTAL_OBLIGACIONES      := 0;
   REL_TOTAL_IMC           := 0;
   TOTAL_DERECHOS_CONS     := 0;
   TOTAL_OBLIGACIONES_CONS := 0;
   REL_TOTAL_IMC_CONS      := 0;

   DERECHO_99_IMC       := 0;
   OBLIGACION_99_IMC    := 0;
   REL_99_IMC           := 0;

   OPEN C_BMO;
   FETCH C_BMO INTO R_BMO;
   WHILE C_BMO%FOUND LOOP
      DERECHO_IMC           := 0;  
      OBLIGACION_IMC        := 0;
      DERECHO_IMC_CONS      := 0;
      OBLIGACION_IMC_CONS   := 0;
      REL_IMC               := 0;
      REL_IMC_CONS          := 0;
      DERECHO_COP_IMC       := 0;
      OBLIGACION_COP_IMC    := 0;
      REL_IMC               := 0;
      --DERECHOS IMC Y CONSOLIDADO
      -- CUENTAS BANCARIAS DEL EXTERIOR
      OPEN C_CBE(R_BMO.BMO_MNEMONICO);
      FETCH C_CBE INTO R_CBE;
      WHILE C_CBE%FOUND LOOP
         OPEN C_MBE (R_CBE.CBE_BEX_MNEMONICO, R_CBE.CBE_NUMERO_CUENTA);
         FETCH C_MBE INTO R_MBE;
         IF C_MBE%FOUND THEN
            SALDO := NVL(R_MBE.MBE_SALDO,0);
         ELSE 
            SALDO := 0;
         END IF;
         CLOSE C_MBE;
         DERECHO_IMC := DERECHO_IMC + SALDO;
         FETCH C_CBE INTO R_CBE;
      END LOOP;
      CLOSE C_CBE;

      -- DERECHO IMC
      OPEN C_LSF(R_BMO.BMO_MNEMONICO,'C');
      FETCH C_LSF INTO R_LSF;
      IF C_LSF%FOUND THEN
         DERECHO_IMC := DERECHO_IMC + NVL(R_LSF.LSF_NUMERO_TRANSADO,0);
      END IF;
      CLOSE C_LSF;

      -- DERECHO IMC
      OPEN C_ORD(R_BMO.BMO_MNEMONICO,'C');
      FETCH C_ORD INTO R_ORD;
      IF C_ORD%FOUND THEN
         DERECHO_IMC := DERECHO_IMC + NVL(R_ORD.ORD_DOLARES,0);
      END IF;
      CLOSE C_ORD;

      --OBLIGACION IMC
      OPEN C_LSF(R_BMO.BMO_MNEMONICO,'V');
      FETCH C_LSF INTO R_LSF;
      IF C_LSF%FOUND THEN
         OBLIGACION_IMC := OBLIGACION_IMC + NVL(R_LSF.LSF_NUMERO_TRANSADO,0);
      END IF;
      CLOSE C_LSF;

      --OBLIGACION IMC
      OPEN C_ORD(R_BMO.BMO_MNEMONICO,'V');
      FETCH C_ORD INTO R_ORD;
      IF C_ORD%FOUND THEN
         OBLIGACION_IMC := OBLIGACION_IMC + NVL(R_ORD.ORD_DOLARES,0);
      END IF;
      CLOSE C_ORD;

      IF R_BMO.BMO_MNEMONICO = 'DOLAR' THEN
         OPEN C_CDI(P_ULTIMO_CDI);
         FETCH C_CDI INTO R_CDI;
         WHILE C_CDI%FOUND LOOP
            DERECHO_IMC := DERECHO_IMC + R_CDI.CDI_SALDO_DEPOSITOS + R_CDI.CDI_DER_BVC_PP_COM + R_CDI.CDI_DERECHOS_YANKEES;
            OBLIGACION_IMC := OBLIGACION_IMC + R_CDI.CDI_DER_BVC_PP_VEN + R_CDI.CDI_OBLIGACIONES_YANKEES;
            FETCH C_CDI INTO R_CDI;
         END LOOP;
         CLOSE C_CDI;

         OPEN C_PROV;
         FETCH C_PROV INTO R_PROV;
         IF C_PROV%FOUND THEN
            DERECHO_IMC := DERECHO_IMC + (NVL(R_PROV.BACO_VALOR,0)/VALOR_TRM);
         END IF;
         CLOSE C_PROV;

         OPEN C_IFC;
         FETCH C_IFC INTO R_IFC;
         IF C_IFC%FOUND THEN
            DERECHO_IMC := DERECHO_IMC + NVL(R_IFC.IFC_VALOR,0);
         END IF;
         CLOSE C_IFC;

         OPEN C_SCFI;
         FETCH C_SCFI INTO R_SCFI;
         IF C_SCFI%FOUND THEN
            DERECHO_IMC_CONS := DERECHO_IMC_CONS + NVL(R_SCFI.SCFI_VALOR,0);
         END IF;
         CLOSE C_SCFI;
      ELSE
         IF R_BMO.BMO_CONS_BANREPUBLICA_AN1 = 99 THEN
            DERECHO_99_IMC := DERECHO_99_IMC + DERECHO_IMC ;
            OBLIGACION_99_IMC := OBLIGACION_99_IMC +  OBLIGACION_IMC;
         ELSE
            OPEN C_BACO('DERECHO');
            FETCH C_BACO INTO R_BACO;
            IF C_BACO%FOUND THEN
               DERECHO_COP_IMC := DERECHO_COP_IMC + (R_BACO.BACO_VALOR/VALOR_TRM);
            END IF;
            CLOSE C_BACO;
            OPEN C_BACO('OBLIGACION');
            FETCH C_BACO INTO R_BACO;
            IF C_BACO%FOUND THEN
               OBLIGACION_COP_IMC := OBLIGACION_COP_IMC + (R_BACO.BACO_VALOR/VALOR_TRM);
            END IF;
            CLOSE C_BACO;
         END IF;
      END IF;
      DERECHO_IMC_CONS := DERECHO_IMC_CONS + DERECHO_IMC;
      OBLIGACION_IMC_CONS := OBLIGACION_IMC_CONS + OBLIGACION_IMC;
      REL_IMC := (DERECHO_IMC-OBLIGACION_IMC) / PATRIMONIO_TECNICO;
      REL_IMC_CONS := (DERECHO_IMC_CONS-OBLIGACION_IMC_CONS) / PATRIMONIO_TECNICO;
      REL_COP_IMC := (DERECHO_COP_IMC-OBLIGACION_COP_IMC) / PATRIMONIO_TECNICO;
      TOTAL_PATRIMONIO := TOTAL_PATRIMONIO + (DERECHO_IMC-OBLIGACION_IMC);
      TOTAL_PATRIMONIO_CONS:= TOTAL_PATRIMONIO_CONS + (DERECHO_IMC_CONS-OBLIGACION_IMC_CONS);

      IF R_BMO.BMO_CONS_BANREPUBLICA_AN1 != 99 THEN
         IF R_BMO.BMO_MNEMONICO = 'PESOS' THEN
            v_bufline := R_BMO.BMO_DESCRIPCION_BANREPUBLICA||','||
                         DERECHO_COP_IMC/1000000||','||OBLIGACION_COP_IMC/1000000||','||REL_COP_IMC||','||
                         DERECHO_COP_IMC/1000000||','||OBLIGACION_COP_IMC/1000000||','||REL_COP_IMC||',';
           INSERT INTO GL_MONEDA_DO (BMO_MNEMONICO, DERECHO, OBLIGACION)
           VALUES (R_BMO.BMO_MNEMONICO, DERECHO_COP_IMC, OBLIGACION_COP_IMC);
         ELSE
            v_bufline := R_BMO.BMO_DESCRIPCION_BANREPUBLICA||','||
                         DERECHO_IMC/1000000||','||OBLIGACION_IMC/1000000||','||REL_IMC||','||
                         DERECHO_IMC_CONS/1000000||','||OBLIGACION_IMC_CONS/1000000||','||REL_IMC_CONS||',';
           INSERT INTO GL_MONEDA_DO (BMO_MNEMONICO, DERECHO, OBLIGACION)
           VALUES (R_BMO.BMO_MNEMONICO, DERECHO_IMC, OBLIGACION_IMC);
         END IF;
         PR_ESCRIBE_FORMATO_AUNO(P_REGISTRO_AUNO  => R_REGISTRO_AUNO,P_BUFLINE      =>  v_bufline);
      END IF;
      TOTAL_DERECHOS          := TOTAL_DERECHOS + DERECHO_IMC;
      TOTAL_OBLIGACIONES      := TOTAL_OBLIGACIONES + OBLIGACION_IMC;

      TOTAL_DERECHOS_CONS      := TOTAL_DERECHOS_CONS + DERECHO_IMC_CONS;
      TOTAL_OBLIGACIONES_CONS  := TOTAL_OBLIGACIONES_CONS + OBLIGACION_IMC_CONS;

      FETCH C_BMO INTO R_BMO;
   END LOOP;
   CLOSE C_BMO;
   REL_99_IMC          := (DERECHO_99_IMC-OBLIGACION_99_IMC) / PATRIMONIO_TECNICO;
   REL_TOTAL_IMC       := (TOTAL_DERECHOS-TOTAL_OBLIGACIONES) / PATRIMONIO_TECNICO;
   REL_TOTAL_IMC_CONS  := (TOTAL_DERECHOS_CONS-TOTAL_OBLIGACIONES_CONS) / PATRIMONIO_TECNICO;

   v_bufline := 'Otras monedas'||','||
                DERECHO_99_IMC/1000000||','||OBLIGACION_99_IMC/1000000||','||REL_99_IMC||','||
                DERECHO_99_IMC/1000000||','||OBLIGACION_99_IMC/1000000||','||REL_99_IMC||',';
   PR_ESCRIBE_FORMATO_AUNO(P_REGISTRO_AUNO  => R_REGISTRO_AUNO,P_BUFLINE      =>  v_bufline);

   v_bufline := '1'||', , , , , , ,';
   PR_ESCRIBE_FORMATO_AUNO(P_REGISTRO_AUNO  => R_REGISTRO_AUNO,P_BUFLINE      =>  v_bufline);

   v_bufline := '2'||', , , , , , ,';
   PR_ESCRIBE_FORMATO_AUNO(P_REGISTRO_AUNO  => R_REGISTRO_AUNO,P_BUFLINE      =>  v_bufline);

   v_bufline := '3'||', , , , , , ,';
   PR_ESCRIBE_FORMATO_AUNO(P_REGISTRO_AUNO  => R_REGISTRO_AUNO,P_BUFLINE      =>  v_bufline);

   v_bufline := '4'||', , , , , , ,';
   PR_ESCRIBE_FORMATO_AUNO(P_REGISTRO_AUNO  => R_REGISTRO_AUNO,P_BUFLINE      =>  v_bufline);

   v_bufline := '5'||', , , , , , ,';
   PR_ESCRIBE_FORMATO_AUNO(P_REGISTRO_AUNO  => R_REGISTRO_AUNO,P_BUFLINE      =>  v_bufline);

   v_bufline := 'Total sin incluir pesos colombianos'||','||
                TOTAL_DERECHOS/1000000||','||TOTAL_OBLIGACIONES/1000000||','||REL_TOTAL_IMC||','||
                TOTAL_DERECHOS_CONS/1000000||','||TOTAL_OBLIGACIONES_CONS/1000000||','||REL_TOTAL_IMC_CONS||',';
   PR_ESCRIBE_FORMATO_AUNO(P_REGISTRO_AUNO  => R_REGISTRO_AUNO,P_BUFLINE      =>  v_bufline);

   v_bufline := 'Valor patrimonio'||','||PATRIMONIO_TECNICO/1000000||','||' ,'||' ,'||PATRIMONIO_TECNICO/1000000||','||' ,'||' ,';
   PR_ESCRIBE_FORMATO_AUNO(P_REGISTRO_AUNO  => R_REGISTRO_AUNO,P_BUFLINE      =>  v_bufline);

   IF P_LLAMADO_REPORTE = 'F' THEN
      IF r_registro_AUNO.COUNT() > 0 THEN
        p_registro_AUNO.DELETE;
        FOR i IN r_registro_AUNO.FIRST .. r_registro_AUNO.LAST LOOP
          v_registro := p_registro_AUNO.COUNT();
          p_registro_AUNO(v_registro).bufline   := r_registro_AUNO(i).bufline;
        END LOOP;
      END IF;
   END IF;

EXCEPTION
    WHEN ERROR THEN
      RAISE_APPLICATION_ERROR(-20002,'Error ejecutando P_DIVISAS.P_MAIL_FORMATO_AUNO '||V_MENSAJE_ERROR);
    WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20001,'Error ejecutando P_DIVISAS.P_MAIL_FORMATO_AUNO '||SQLERRM);
END PR_FORMATO_AUNO;


PROCEDURE PR_ESCRIBE_FORMATO_AUNO(P_REGISTRO_AUNO  IN OUT T_REGISTRO_AUNO,
                                  P_BUFLINE       VARCHAR2) IS
  v_registro NUMBER;
BEGIN
  v_registro := P_REGISTRO_AUNO.COUNT();
  P_REGISTRO_AUNO(v_registro).bufline := P_BUFLINE;
END PR_ESCRIBE_FORMATO_AUNO;

PROCEDURE PR_FORMATO_ADOS(P_FECHA DATE DEFAULT NULL,
                          P_LLAMADO_REPORTE VARCHAR2  DEFAULT NULL,
                          P_REGISTRO_ADOS IN OUT T_REGISTRO_ADOS) IS
   R_REGISTRO_AUNO    P_DIVISAS.T_REGISTRO_AUNO;                          

   CURSOR C_BACO IS
      SELECT   BACO_VALOR
      FROM BALANCES_CORREDORES
      WHERE BACO_FECHA = LAST_DAY(P_FECHA)
        AND BACO_TIPO_BALANCE = 'CMT'  --- BALANCE EN MONEDA
        AND BACO_CUENTA ='100000';
   R_BACO C_BACO%ROWTYPE;

   CURSOR C_AN1 (P_VALOR NUMBER) IS
      SELECT BMO_MNEMONICO,
            ( (NVL(DERECHO,0) + NVL(OBLIGACION,0)) / P_VALOR ) * 100  RELACION
      FROM GL_MONEDA_DO
      WHERE NVL(DERECHO,0) != 0
         OR NVL(OBLIGACION,0) != 0
      ORDER BY 2 DESC;
   R_AN1 C_AN1%ROWTYPE;         

   CURSOR C_CBE (BMO VARCHAR2) IS
      SELECT CBE_BEX_MNEMONICO
           , CBE_NUMERO_CUENTA
      FROM CUENTAS_BANCARIAS_EXTERIOR
      WHERE CBE_POSICION_PROPIA = 'S'
        AND CBE_BMO_MNEMONICO = BMO
        AND CBE_BEX_MNEMONICO NOT IN ('DEUTE','DEUTG')
      UNION
      SELECT CBE_BEX_MNEMONICO
           , CBE_NUMERO_CUENTA
      FROM CUENTAS_BANCARIAS_EXTERIOR
      WHERE CBE_POSICION_PROPIA = 'S'
        AND CBE_BEX_MNEMONICO IN ('DEUTE')
        AND BMO = 'EURO'
      UNION
      SELECT CBE_BEX_MNEMONICO
           , CBE_NUMERO_CUENTA
      FROM CUENTAS_BANCARIAS_EXTERIOR
      WHERE CBE_POSICION_PROPIA = 'S'
        AND CBE_BEX_MNEMONICO IN ('DEUTG')
        AND BMO = 'GBP';        
   R_CBE C_CBE%ROWTYPE;

   CURSOR C_MBE (BEX VARCHAR2, CTA VARCHAR2) IS   
      SELECT MBE_SALDO 
      FROM MOVIMIENTOS_BANCARIOS_EXTERIOR
      WHERE MBE_CBE_BEX_MNEMONICO = BEX
        AND MBE_CBE_NUMERO_CUENTA = CTA
        AND MBE_FECHA < TRUNC(P_FECHA + 1)
      ORDER BY MBE_FECHA DESC;
   R_MBE C_MBE%ROWTYPE;

   CURSOR C_CDI (V_FECHA DATE) IS
      SELECT  NVL(CDI_SALDO_DEPOSITOS,0)  CDI_SALDO_DEPOSITOS
      FROM CIERRE_DIVISAS
      WHERE CDI_FECHA_PROCESO >= TRUNC(V_FECHA)
        AND CDI_FECHA_PROCESO <  TRUNC(V_FECHA+1);
   R_CDI C_CDI%ROWTYPE;     


   CURSOR C_F475 IS
      SELECT ABS((F475_UCAP01_SBCTA015_BANDA1*1000) +
                 (F475_UCAP01_SBCTA020_BANDA1*1000) +
                 (F475_UCAP01_SBCTA025_BANDA1*1000) +
                 (F475_UCAP01_SBCTA030_BANDA1*1000) +
                 (F475_UCAP01_SBCTA035_BANDA1*1000) +
                 (F475_UCAP01_SBCTA040_BANDA1*1000) +
                 (F475_UCAP01_SBCTA045_BANDA1*1000) +
                 (F475_UCAP01_SBCTA050_BANDA1*1000) +
                 (F475_UCAP01_SBCTA055_BANDA1*1000) +
                 (F475_UCAP01_SBCTA060_BANDA1*1000) +
                 (F475_UCAP01_SBCTA065_BANDA1*1000)) REG17_COP,
             ABS(F475_UCAP01_SBCTA075_BANDA1*1000) REG37_COP,
             ABS(F475_UCAP01_SBCTA010_BANDA1*1000) REG39_COP,
             ABS(F475_UCAP01_SBCTA070_BANDA1*1000) REG17_USD
      FROM FORMATO_475
      WHERE F475_FECHA >= TRUNC(P_FECHA)
        AND F475_FECHA <  TRUNC(P_FECHA+1);
   R_F475 C_F475%ROWTYPE;

   CURSOR C_SCFI IS
      SELECT SCFI_VALOR
      FROM SALDOS_CUENTAS_FILIALES
      WHERE SCFI_FECHA_APLICACION < TRUNC(P_FECHA+1)
      ORDER BY SCFI_FECHA_APLICACION DESC;
   R_SCFI C_SCFI%ROWTYPE;     

   CURSOR C_DER (P_BMO VARCHAR2, V_FECHA DATE) IS
      SELECT SUM(LID_VALOR_LIQUIDACION) LID_VALOR_LIQUIDACION
      FROM LIQUIDACIONES_DERIVADOS L, 
           ESPECIES_CONTRATOS E, 
           SUBYACENTES S
      WHERE L.LID_ESPECIE_CONTRATO = E.ESC_MNEMONICO
        AND E.ESC_SYT_MNEMONICO = S.SYT_MNEMONICO
        AND L.LID_CCC_CLI_PER_NUM_IDEN = '860079174'
        AND L.LID_CCC_CLI_PER_TID_CODIGO = 'NIT'
        AND L.LID_FECHA_OPERACION = TRUNC(V_FECHA)
        AND ESC_FECHA_CUMPLIMIENTO >= TRUNC(V_FECHA)
         AND ((P_BMO = 'PESOS' AND S.SYT_TSU_MNEMONICO NOT IN ('CF','CF1','TRM'))
             OR (P_BMO = 'DOLAR' AND S.SYT_TSU_MNEMONICO IN ('CF','CF1','TRM') ));
   R_DER C_DER%ROWTYPE;      

   CURSOR C_NEXT (P_BMO VARCHAR2) IS
      SELECT TIPO,
             BMO_MNEMONICO,
             ABS(SUM(DERECHO)) DERECHO,
             ABS(SUM(OBLIGACION)) OBLIGACION
      FROM ( SELECT 'COMPRA' TIPO,
                   LSF_BMO_MNEMONICO BMO_MNEMONICO,
                   LSF_NUMERO_TRANSADO*P_WEB_EXTRACTO.VALORBMO('DOLAR', P_FECHA+1)   DERECHO,
                   LSF_NUMERO_TRANSADO*LSF_PRECIO             OBLIGACION
             FROM LIQUIDACIONES_SET_FX
             WHERE LSF_NEXT_DAY = 'S' 
               AND LSF_ESTADO ='APL'
               AND LSF_FECHA < TRUNC(P_FECHA+1) 
               AND LSF_FECHA_CUMPLIMIENTO > TRUNC(P_FECHA) 
               AND (LSF_BMO_MNEMONICO = P_BMO
                    OR P_BMO = 'PESOS')
               AND ((LSF_OFERTA_DEMANDA = 'D'  AND (LSF_INSTITUCION_POSTURA LIKE 'CORREDORES ASOCIADOS%' OR LSF_INSTITUCION_POSTURA LIKE 'CORREDORES DAVIVIENDA S.A.%')) 
                    OR (LSF_OFERTA_DEMANDA = 'O' AND (LSF_INSTITUCION_ACEPTANTE LIKE 'CORREDORES ASOCIADOS%' OR LSF_INSTITUCION_ACEPTANTE LIKE 'CORREDORES DAVIVIENDA S.A.%')))  
             UNION ALL
             SELECT  'COMPRA'                                                                 TIPO,
                     NVL(ORD_BMO_MNEMONICO_FX,ORD_BMO_MNEMONICO) BMO_MNEMONICO,
                     ORD_VALOR_DOLARES*P_WEB_EXTRACTO.VALORBMO('DOLAR', P_FECHA +1) DERECHO,
                     ORD_VALOR_DOLARES*ORD_TASA_CAMBIO      OBLIGACION
            FROM ORDENES_DIVISAS
            WHERE NVL(ORD_DIAS_NEXT_DAY,0) IN (1,2,3)
                  AND ORD_FECHA_COLOCACION < TRUNC(P_FECHA+1)
                  AND ORD_FECHA_CUMPLIMIENTO  >= TRUNC(P_FECHA+1)   
                  AND ORD_TIPO_ORDEN = 'C'
               AND (ORD_BMO_MNEMONICO = P_BMO
                    OR P_BMO = 'PESOS')                  
               AND (ORD_EOF_CODIGO IN ('APL','APR')
                      OR (ORD_EOF_CODIGO ='REV' AND ORD_FECHA_REVERSION > TRUNC(P_FECHA+1)))           
            UNION ALL
            SELECT  'VENTA'  TIPO,
                    LSF_BMO_MNEMONICO  BMO_MNEMONICO,
                    LSF_NUMERO_TRANSADO*LSF_PRECIO  DERECHO,
                   LSF_NUMERO_TRANSADO*P_WEB_EXTRACTO.VALORBMO('DOLAR', P_FECHA+1 ) OBLIGACION
            FROM   LIQUIDACIONES_SET_FX
            WHERE LSF_NEXT_DAY = 'S' 
                  AND LSF_ESTADO ='APL'
                  AND LSF_FECHA < TRUNC(P_FECHA+1) 
                  AND LSF_FECHA_CUMPLIMIENTO > TRUNC(P_FECHA) 
                  AND (LSF_BMO_MNEMONICO = P_BMO
                       OR P_BMO = 'PESOS')                  
                  AND ((LSF_OFERTA_DEMANDA = 'O'  AND (LSF_INSTITUCION_POSTURA LIKE 'CORREDORES ASOCIADOS%' OR LSF_INSTITUCION_POSTURA LIKE 'CORREDORES DAVIVIENDA S.A.%')) 
                  OR (LSF_OFERTA_DEMANDA = 'D' AND (LSF_INSTITUCION_ACEPTANTE LIKE 'CORREDORES ASOCIADOS%' OR LSF_INSTITUCION_ACEPTANTE LIKE 'CORREDORES DAVIVIENDA S.A.%')))    
            UNION ALL
            SELECT  'VENTA' TIPO,
                    NVL(ORD_BMO_MNEMONICO_FX,ORD_BMO_MNEMONICO) BMO_MNEMONICO,
                    ORD_VALOR_DOLARES*ORD_TASA_CAMBIO  DERECHO,
                    ORD_VALOR_DOLARES* P_WEB_EXTRACTO.VALORBMO('DOLAR', P_FECHA+1 )  OBLIGACION
            FROM ORDENES_DIVISAS
            WHERE NVL(ORD_DIAS_NEXT_DAY,0) IN (1,2,3)
                  AND ORD_FECHA_COLOCACION < TRUNC(P_FECHA+1)
                  AND ORD_FECHA_CUMPLIMIENTO  >= TRUNC(P_FECHA+1)   
                  AND ORD_TIPO_ORDEN = 'V'
                  AND (ORD_BMO_MNEMONICO = P_BMO
                       OR P_BMO = 'PESOS')                  
                  AND (ORD_EOF_CODIGO IN ('APL','APR')
                            OR (ORD_EOF_CODIGO ='REV' AND ORD_FECHA_REVERSION > TRUNC(P_FECHA+1))))
    group by TIPO, BMO_MNEMONICO;

   R_NEXT C_NEXT%ROWTYPE;

   CURSOR C_BMO IS
      SELECT DISTINCT B.BMO_CODIGO_PIP  BMO_CODIGO, B.BMO_MNEMONICO, ( (NVL(DERECHO,0) + NVL(OBLIGACION,0)) / 1000000 ) * 100  RELACION
      FROM GL_ANEXO2 A,
           BASES_MONETARIAS B,
           GL_MONEDA_DO C
      WHERE A.GLAD_BMO_MNEMONICO = B.BMO_MNEMONICO
        AND B.BMO_MNEMONICO = C.BMO_MNEMONICO
        AND (NVL(DERECHO,0) != 0
              OR NVL(OBLIGACION,0) != 0)
      ORDER BY 3 DESC;      
   R_BMO C_BMO%ROWTYPE;

   CURSOR C_TADB IS
      SELECT TADB_CONSECUTIVO,TADB_TITULO_C1,TADB_TITULO_C2 ,TADB_TITULO_C3, TADB_TITULO_C4, TADB_ORDEN
      FROM TITULOS_ANEXO2_BR
      WHERE TADB_ORDEN IS NOT NULL
      ORDER BY TADB_ORDEN ASC;
   R_TADB C_TADB%ROWTYPE;

   CURSOR C_DATO (P_CONS NUMBER, P_BMO VARCHAR2 ) IS
      SELECT GLAD_CONSECUTIVO,
             GLAD_BMO_MNEMONICO,
             GLAD_CONSECUTIVO_AFECTADO,
             NVL(GLAD_VALOR,0) GLAD_VALOR
      FROM GL_ANEXO2
      WHERE GLAD_BMO_MNEMONICO = P_BMO
        AND GLAD_CONSECUTIVO_AFECTADO = P_CONS;
   R_DATO C_DATO%ROWTYPE;        

   TYPE t_base IS RECORD (bmo_codigo varchar2(5):= '', bmo_mnemonico varchar2(5):= '');
   TYPE t_bmo IS TABLE OF t_base INDEX BY BINARY_INTEGER;
   TYPE t_dato IS RECORD (valor NUMBER(22,2) := 0);
   TYPE t_datobmo IS TABLE OF t_dato INDEX BY BINARY_INTEGER;
   i BINARY_INTEGER := 0;
   j BINARY_INTEGER := 0;
   reg_bmo      t_bmo;   
   reg_datobmo  t_datobmo; 

   VALOR_TRM          NUMBER;
   SALDO              NUMBER := 0;
   ACTIVO_TOTAL       NUMBER;      
   CONTADOR           NUMBER := 0;
   VALOR_CUENTA       NUMBER;   
   VR_DISPONIBLE      NUMBER;
   VR_TAL             NUMBER;
   TOTAL_AAL_COL      NUMBER;
   TOTAL_AAL_EX       NUMBER;
   TOTAL_AAL          NUMBER;
   VR_DEUDA_P         NUMBER;
   VR_OTRAS_I         NUMBER;
   ING_DER            NUMBER;
   EGR_DER            NUMBER;
   TOTAL_OTROA_AL_COL NUMBER;
   TOTAL_OTROS_ALIQ   NUMBER;
   VR_FLUJO_ING       NUMBER;
   TOTAL_ALIQ         NUMBER;
   VR_FLUJO_EG        NUMBER;
   VR_INDICADOR       NUMBER;
   TOTAL_NETO_LIQ     NUMBER;
   VALOR_CORTOS       NUMBER := 0;
   V_CUENTAS          VARCHAR2(500);
   OBLIGACION_COMPRA  NUMBER := 0;
   DERECHO_COMPRA     NUMBER := 0;
   OBLIGACION_VENTA   NUMBER := 0;
   DERECHO_VENTA      NUMBER := 0;
   P_ULTIMO_CDI       DATE;

   v_mensaje_error    VARCHAR2(1000);
   v_bufline          VARCHAR2(3000) := NULL;
   v_bufline1         VARCHAR2(1000) := NULL;
   v_registro         NUMBER;
   error              EXCEPTION;

BEGIN

   SELECT MAX(CDI_FECHA_DIA) INTO P_ULTIMO_CDI FROM CIERRE_DIVISAS WHERE CDI_FECHA_DIA < TRUNC(P_FECHA+1);
   DELETE FROM GL_ANEXO2;
   VALOR_TRM := P_WEB_EXTRACTO.ValorBMO ('DOLAR',P_FECHA+1);
   IF NVL(VALOR_TRM,0) = 0 THEN
      v_mensaje_error := 'No se pudo determinar el valor del Dolar para el dia '||TO_CHAR(P_FECHA+1,'DD-MON-YYYY');
      RAISE ERROR;
   END IF; 

   -- TRAER LA INFORMACION DE DERECHOS Y OBLIGACIONES DE ANEXO1
   R_REGISTRO_AUNO.DELETE;
   P_DIVISAS.PR_FORMATO_AUNO( P_FECHA           => P_FECHA,
                              P_LLAMADO_REPORTE => 'F',
                              P_REGISTRO_AUNO   => R_REGISTRO_AUNO );

   OPEN C_BACO;
   FETCH C_BACO INTO R_BACO;
   IF C_BACO%FOUND THEN
      ACTIVO_TOTAL := NVL(R_BACO.BACO_VALOR,0)/VALOR_TRM;
   ELSE
      ACTIVO_TOTAL := 0;
   END IF;
   CLOSE C_BACO;

   IF NVL(ACTIVO_TOTAL,0) = 0 THEN
      v_mensaje_error := 'No se pudo determinar el valor del activo total, para calcular la proporción de la moneda ';
      RAISE ERROR;
   END IF; 

   OPEN C_AN1 (ACTIVO_TOTAL);
   FETCH C_AN1 INTO R_AN1;
   WHILE C_AN1%FOUND AND NVL(R_AN1.RELACION,0) > 5 LOOP
      IF R_AN1.BMO_MNEMONICO = 'PESOS' THEN
         /* 8: Suma del pasivo, el activo y la posición bruta de derivados como proporción del activo total reportado en el balance individual de la matriz.*/
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO,8,NVL(R_AN1.RELACION,0));                                      

         -- 15: Activos de alta liquidez - Disponible
         VALOR_CUENTA := 0;
         VR_DISPONIBLE := 0;
         V_CUENTAS := '110000';
         P_DIVISAS.PR_VALOR_BALANCE ('CCOP' , P_FECHA , V_CUENTAS , VALOR_CUENTA);    
         IF VALOR_CUENTA != 0 THEN
            VALOR_CUENTA := VALOR_CUENTA /VALOR_TRM;
         END IF;
         VR_DISPONIBLE := VALOR_CUENTA;
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO,15, VALOR_CUENTA/1000);

         -- 16: Encaje Requerido
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 16 , 0 );

         OPEN C_F475;
         FETCH C_F475 INTO R_F475;
         IF C_F475%FOUND THEN
            VR_TAL     := NVL(R_F475.REG17_COP,0);         --USD REG17_USD
            VR_DEUDA_P := NVL(R_F475.REG37_COP,0);         --USD  CERO
            VR_OTRAS_I := NVL(R_F475.REG39_COP,0);         --USD CERO
         ELSE
            VR_TAL := 0;  
            VR_DEUDA_P := 0;
            VR_OTRAS_I := 0;
         END IF;
         CLOSE C_F475;

         -- VALOR DE LAS POSICION EN CORTO
         P_DIVISAS.PR_VALOR_CORTOS(P_FECHA, VALOR_CORTOS);
         VALOR_CORTOS := ABS(VALOR_CORTOS);

         -- 17: Títulos incluidos en el rubro de "Activos líquidos de alta calidad"
         VR_TAL := (NVL(VR_TAL,0)/VALOR_TRM) + (NVL(VALOR_CORTOS,0)/VALOR_TRM);
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 17 , VR_TAL/1000 );

         -- 18: Promedio ponderado de los haircuts aplicados a los títulos incluidos en el rubro de "Activos líquidos de alta calidad" 
         VALOR_CUENTA := 0;
         V_CUENTAS := '120500,213500';
         P_DIVISAS.PR_VALOR_BALANCE ('CCOP' , P_FECHA , V_CUENTAS , VALOR_CUENTA);    
         IF VALOR_CUENTA != 0 THEN
            VALOR_CUENTA := VALOR_CUENTA /VALOR_TRM;
            VALOR_CUENTA := (VALOR_CUENTA - VR_TAL)/VALOR_CUENTA;
         END IF;
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 18 , VALOR_CUENTA);

         -- 19: Total Activos de alta liquidez de las entidades establecidas en Colombia 2.+ 3.
         TOTAL_AAL_COL := VR_DISPONIBLE + VR_TAL;   --15+17
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 19 , TOTAL_AAL_COL/1000);

        -- 23: DISPONIBLE Activos de alta liquidez de entidades establecidas en el exterior 
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 23 , 0 );

         -- 24: Encaje Requerido tit exterior
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 24 , 0 );

         -- 25: Tit aceptables por el banco central del pais
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 25 , 0 );

         -- 26: Haircut promedio ponderado de los títulos.
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 26 , 0 );

         -- 27: Títulos emitidos en moneda local por los gobiernos de los Estados Unidos de América, Alemania, Francia, Dinamarca, Noruega, Suecia, Australia, Canadá, Nueva Zelanda, Reino Unido, Japón y Suiza
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 27 , 0 );

         -- 28: Total activos de alta liquidez de entidades establecidas en el exterior 
         TOTAL_AAL_EX := 0;    --23+25+27
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 28 , TOTAL_AAL_EX/1000 );

        -- 32: Total Activos de alta liquidez 4.+ 8.
         TOTAL_AAL := TOTAL_AAL_COL + TOTAL_AAL_EX;   --19+28
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 32 , TOTAL_AAL/1000 );

         --37: Deuda privada incluida en el rubro de "Otros activos líquidos" 
         VR_DEUDA_P := NVL(VR_DEUDA_P,0)/VALOR_TRM;
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 37 , VR_DEUDA_P/1000 );

         -- 38: Promedio ponderado de los haircuts de la deuda privada incluida en "Otros activos líquidos" 
         VALOR_CUENTA := 0;
         V_CUENTAS := '120700';
         P_DIVISAS.PR_VALOR_BALANCE ('CCOP' , P_FECHA , V_CUENTAS , VALOR_CUENTA);    
         IF VALOR_CUENTA != 0 THEN
            VALOR_CUENTA := VALOR_CUENTA /VALOR_TRM;
            VALOR_CUENTA := (VALOR_CUENTA - VR_DEUDA_P)/VALOR_CUENTA;
         END IF;
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 38 , VALOR_CUENTA);

         -- 39: Otras inversiones incluidas en el rubro de "Otros activos líquidos"
         VR_OTRAS_I := NVL(VR_OTRAS_I,0)/VALOR_TRM;
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 39 , VR_OTRAS_I/1000 );

         -- 40 : Promedio ponderado de los haircuts de otras inversiones incluidas en "Otros activos líquidos"  
         VALOR_CUENTA := 0;
         V_CUENTAS := '120400';
         P_DIVISAS.PR_VALOR_BALANCE ('CCOP' , P_FECHA , V_CUENTAS , VALOR_CUENTA);    
         IF VALOR_CUENTA != 0 THEN
            VALOR_CUENTA := VALOR_CUENTA /VALOR_TRM;
            VALOR_CUENTA := (VALOR_CUENTA - VR_OTRAS_I)/VALOR_CUENTA;
         END IF;
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 40 , VALOR_CUENTA);


         -- 41: total otros activos líquidos de entidades establecidas en Colombia 
         TOTAL_OTROA_AL_COL := VR_DEUDA_P + VR_OTRAS_I;  --37+39
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 41 , TOTAL_OTROA_AL_COL/1000 );

         -- 45: Títulos emitidos o garantizados por gobiernos que no cumplan los criterios mencionados en 6. y 7.
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 45 , 0 );

         -- 46: Títulos emitidos o garantizados por bancos centrales que no cumplan el criterio mencionado en 6. 
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 46 , 0 );

         --  47: Títulos emitidos por entidades multilaterales 2
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 47 , 0 );

         -- 48: Total de otros activos líquidos de entidades establecidas en el exterior 13.+ 14.+ 15.
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 48 , 0 );

         -- 52: Total Otros activos líquidos 2.12.+2.16.
         TOTAL_OTROS_ALIQ := TOTAL_OTROA_AL_COL + 0 ;    --41+48
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 52 , TOTAL_OTROS_ALIQ/1000 );

         --  57: Títulos de deuda privada de las entidades establecidas en el exterior
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 57 , 0 );

         -- 61: Activos líquidos totales 9.+mín{17.;9.*3/7}
         IF (TOTAL_AAL * 3/7) >= TOTAL_OTROS_ALIQ THEN
            TOTAL_ALIQ := TOTAL_AAL + TOTAL_OTROS_ALIQ;
         ELSE
            TOTAL_ALIQ := TOTAL_AAL + (TOTAL_AAL * 3/7);
         END IF;
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 61 , TOTAL_ALIQ/1000 );

         -- 67: Flujo de ingresos sujetos a vencimientos contractuales
         OBLIGACION_COMPRA := 0;
         DERECHO_COMPRA    := 0;
         OBLIGACION_VENTA  := 0;
         DERECHO_VENTA     := 0;
         OPEN C_NEXT(R_AN1.BMO_MNEMONICO);
         FETCH C_NEXT INTO R_NEXT;
         WHILE C_NEXT%FOUND LOOP
            IF R_NEXT.TIPO = 'COMPRA' THEN
               OBLIGACION_COMPRA := OBLIGACION_COMPRA + NVL(R_NEXT.OBLIGACION,0);
               DERECHO_COMPRA    := DERECHO_COMPRA + NVL(R_NEXT.DERECHO,0);
            ELSE
               OBLIGACION_VENTA := OBLIGACION_VENTA + NVL(R_NEXT.OBLIGACION,0);
               DERECHO_VENTA    := DERECHO_VENTA + NVL(R_NEXT.DERECHO,0);
            END IF;        
            FETCH C_NEXT INTO R_NEXT;
         END LOOP;
         CLOSE C_NEXT;
         OBLIGACION_COMPRA := OBLIGACION_COMPRA/VALOR_TRM;
         DERECHO_COMPRA    := DERECHO_COMPRA/VALOR_TRM;
         OBLIGACION_VENTA  := OBLIGACION_VENTA/VALOR_TRM;
         DERECHO_VENTA     := DERECHO_VENTA/VALOR_TRM;
         VALOR_CUENTA := 0;
         V_CUENTAS := '122305,122310,122315,122320,122325,122330,122335,122340,122345,122350,122355,122360,122365,
                       122370,122375,122380,122385,122390,122395,126402,126406,126408,126410,126412,126414,126416,
                       126432,126434,126446,126502,126504,126506,126508,126510,126512,126514,126516,126518,126520,
                       126522,126524,126526,126528,126530,126532,126546,120200';
         P_DIVISAS.PR_VALOR_BALANCE ('CCOP' , P_FECHA , V_CUENTAS , VALOR_CUENTA);    
         IF VALOR_CUENTA != 0 THEN
            VALOR_CUENTA := VALOR_CUENTA /VALOR_TRM;
         END IF;
         VR_FLUJO_ING := VALOR_CUENTA + DERECHO_VENTA;
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 67 , VR_FLUJO_ING/1000);

         -- 68:Flujo de ingresos provenientes de operaciones con derivados 
         OPEN C_DER (R_AN1.BMO_MNEMONICO, P_ULTIMO_CDI);
         FETCH C_DER INTO R_DER;
         IF C_DER%FOUND THEN
            IF R_DER.LID_VALOR_LIQUIDACION < 0 THEN
               ING_DER := 0;
               EGR_DER := NVL(R_DER.LID_VALOR_LIQUIDACION,0)/VALOR_TRM;
            ELSE
               ING_DER := NVL(R_DER.LID_VALOR_LIQUIDACION,0)/VALOR_TRM;
               EGR_DER := 0;
            END IF;
         ELSE
               ING_DER := 0;
               EGR_DER := 0;
         END IF;
         CLOSE C_DER;
         ING_DER := ABS(ING_DER);
         EGR_DER := ABS(EGR_DER);
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 68 , ING_DER/1000);


         -- 69: Flujo de egresos sujetos a vencimientos contractuales         
         VALOR_CUENTA := 0;
         V_CUENTAS := '126451,126453,126455,126457,126459,126461,126463,126465,126481,126483,126495,126551,126553,
                       126555,126557,126559,126561,126563,126565,126567,126569,126571,126573,126575,126577,126579,
                       126581,126583,126595,213105,213110,213115,213120,213125,213130,213135,213140,213145,213150,
                       213155,213160,213165,213170,213175,213180,213185,213190,213195,213300';
         P_DIVISAS.PR_VALOR_BALANCE ('CCOP' , P_FECHA , V_CUENTAS , VALOR_CUENTA);    
         IF VALOR_CUENTA != 0 THEN
            VALOR_CUENTA := VALOR_CUENTA /VALOR_TRM;
         END IF;
         VR_FLUJO_EG := VALOR_CUENTA + OBLIGACION_COMPRA;
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 69 , VR_FLUJO_EG/1000);

         -- 70:  Flujo de egresos provenientes de operaciones con derivados
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 70 , EGR_DER/1000);

         -- 71: Flujo de egresos no contractuales (únicamente para entidades que realizan intermediación crediticia).
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 71 , 0 );

         --  72: Total requerimiento neto de liquidez  21.+ 22.-mín{0.75*[21.+22.];20.}
         IF ((VR_FLUJO_EG + 0) * 0.75) >=  VR_FLUJO_ING THEN
            TOTAL_NETO_LIQ := VR_FLUJO_EG + 0 - VR_FLUJO_ING;
         ELSE
            TOTAL_NETO_LIQ := VR_FLUJO_EG + 0 - ((VR_FLUJO_EG + 0) * 0.75);
         END IF;
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 72 , TOTAL_NETO_LIQ/1000 );

         -- 79:  Indicador de exposición de corto plazo por moneda 19./ 23.
         IF TOTAL_NETO_LIQ != 0 THEN
            VR_INDICADOR := TOTAL_ALIQ / TOTAL_NETO_LIQ;
         ELSE
            VR_INDICADOR := 0;
         END IF;
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 79 , VR_INDICADOR );

      -- D O L A R 
      ELSIF R_AN1.BMO_MNEMONICO = 'DOLAR' THEN         
         /* 8: Suma del pasivo, el activo y la posición bruta de derivados como proporción del activo total reportado en el balance individual de la matriz.*/
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO,8,NVL(R_AN1.RELACION,0));                                      

         -- 15: Activos de alta liquidez - Disponible
         VR_DISPONIBLE := 0;
         OPEN C_CBE(R_AN1.BMO_MNEMONICO);
         FETCH C_CBE INTO R_CBE;
         WHILE C_CBE%FOUND LOOP
            OPEN C_MBE (R_CBE.CBE_BEX_MNEMONICO, R_CBE.CBE_NUMERO_CUENTA);
            FETCH C_MBE INTO R_MBE;
            IF C_MBE%FOUND THEN
               SALDO := NVL(R_MBE.MBE_SALDO,0);
            ELSE 
               SALDO := 0;
            END IF;
            CLOSE C_MBE;
            VR_DISPONIBLE := VR_DISPONIBLE + SALDO;
            FETCH C_CBE INTO R_CBE;
         END LOOP;
         CLOSE C_CBE;

         VALOR_CUENTA := 0;
         V_CUENTAS := '136000';
         P_DIVISAS.PR_VALOR_BALANCE ('CME' , P_FECHA , V_CUENTAS , VALOR_CUENTA);   
         IF VALOR_CUENTA != 0 THEN
            VALOR_CUENTA := VALOR_CUENTA /VALOR_TRM;
         END IF;
         VR_DISPONIBLE := NVL(VR_DISPONIBLE,0) + VALOR_CUENTA; 

         OPEN C_CDI(P_ULTIMO_CDI);
         FETCH C_CDI INTO R_CDI;
         WHILE C_CDI%FOUND LOOP
            VALOR_CUENTA := NVL(R_CDI.CDI_SALDO_DEPOSITOS,0);
            FETCH C_CDI INTO R_CDI;
         END LOOP;
         CLOSE C_CDI;
         VR_DISPONIBLE := NVL(VR_DISPONIBLE,0) + VALOR_CUENTA; 
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO,15, VR_DISPONIBLE/1000);

         -- 16: Encaje Requerido
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 16 , 0 );

         OPEN C_F475;
         FETCH C_F475 INTO R_F475;
         IF C_F475%FOUND THEN
            VR_TAL     := NVL(R_F475.REG17_USD,0);        
            VR_DEUDA_P := 0;
            VR_OTRAS_I := 0;
         ELSE
            VR_TAL := 0;  
            VR_DEUDA_P := 0;
            VR_OTRAS_I := 0;
         END IF;
         CLOSE C_F475;

         -- 17: Títulos incluidos en el rubro de "Activos líquidos de alta calidad"
         VR_TAL := NVL(VR_TAL,0)/VALOR_TRM;
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 17 , VR_TAL/1000 );

         -- 18: Promedio ponderado de los haircuts aplicados a los títulos incluidos en el rubro de "Activos líquidos de alta calidad" 
         VALOR_CUENTA := 0;
         V_CUENTAS := '120600';
         P_DIVISAS.PR_VALOR_BALANCE ('CMT' , P_FECHA , V_CUENTAS , VALOR_CUENTA);    
         IF VALOR_CUENTA != 0 THEN
            VALOR_CUENTA := VALOR_CUENTA /VALOR_TRM;
            VALOR_CUENTA := (VALOR_CUENTA - VR_TAL)/VALOR_CUENTA;
         END IF;
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 18 , VALOR_CUENTA);

         -- 19: Total Activos de alta liquidez de las entidades establecidas en Colombia 2.+ 3.
         TOTAL_AAL_COL := VR_DISPONIBLE + VR_TAL;   --15+17
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 19 , TOTAL_AAL_COL/1000);

        -- 23: DISPONIBLE Activos de alta liquidez de entidades establecidas en el exterior 
         OPEN C_SCFI;
         FETCH C_SCFI INTO R_SCFI;
         IF C_SCFI%FOUND THEN
            VR_DISPONIBLE := NVL(R_SCFI.SCFI_VALOR,0);
         ELSE
            VR_DISPONIBLE := 0;
         END IF;
         CLOSE C_SCFI;
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 23 , VR_DISPONIBLE/1000);

         -- 24: Encaje Requerido tit exterior
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 24 , 0 );

         -- 25: Tit aceptables por el banco central del pais
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 25 , 0 );

         -- 26: Haircut promedio ponderado de los títulos.
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 26 , 0 );

         -- 27: Títulos emitidos en moneda local por los gobiernos de los Estados Unidos de América, Alemania, Francia, Dinamarca, Noruega, Suecia, Australia, Canadá, Nueva Zelanda, Reino Unido, Japón y Suiza
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 27 , 0 );

         -- 28: Total activos de alta liquidez de entidades establecidas en el exterior 
         TOTAL_AAL_EX := VR_DISPONIBLE;    --23+25+27
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 28 , TOTAL_AAL_EX/1000 );

        -- 32: Total Activos de alta liquidez 4.+ 8.
         TOTAL_AAL := TOTAL_AAL_COL + TOTAL_AAL_EX;   --19+28
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 32 , TOTAL_AAL/1000 );

         --37: Deuda privada incluida en el rubro de "Otros activos líquidos" 
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 37 , 0 );

         -- 38: Promedio ponderado de los haircuts de la deuda privada incluida en "Otros activos líquidos" 
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 38 , 0 );

         -- 39: Otras inversiones incluidas en el rubro de "Otros activos líquidos"
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 39 , 0 );

         -- 40 : Promedio ponderado de los haircuts de otras inversiones incluidas en "Otros activos líquidos"  
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 40 , 0 );


         -- 41: total otros activos líquidos de entidades establecidas en Colombia 
         TOTAL_OTROA_AL_COL := VR_DEUDA_P + VR_OTRAS_I;  --37+39
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 41 , TOTAL_OTROA_AL_COL/1000 );

         -- 45: Títulos emitidos o garantizados por gobiernos que no cumplan los criterios mencionados en 6. y 7.
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 45 , 0 );

         -- 46: Títulos emitidos o garantizados por bancos centrales que no cumplan el criterio mencionado en 6. 
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 46 , 0 );

         --  47: Títulos emitidos por entidades multilaterales 2
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 47 , 0 );

         -- 48: Total de otros activos líquidos de entidades establecidas en el exterior 13.+ 14.+ 15.
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 48 , 0 );

         -- 52: Total Otros activos líquidos 2.12.+2.16.
         TOTAL_OTROS_ALIQ := TOTAL_OTROA_AL_COL + 0 ;    --41+48
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 52 , TOTAL_OTROS_ALIQ/1000 );

         --  57: Títulos de deuda privada de las entidades establecidas en el exterior
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 57 , 0 );

         -- 61: Activos líquidos totales 9.+mín{17.;9.*3/7}
         IF (TOTAL_AAL * 3/7) >= TOTAL_OTROS_ALIQ THEN
            TOTAL_ALIQ := TOTAL_AAL + TOTAL_OTROS_ALIQ;
         ELSE
            TOTAL_ALIQ := TOTAL_AAL + (TOTAL_AAL * 3/7);
         END IF;
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 61 , TOTAL_ALIQ/1000 );

         -- 67: Flujo de ingresos sujetos a vencimientos contractuales
         OBLIGACION_COMPRA := 0;
         DERECHO_COMPRA    := 0;
         OBLIGACION_VENTA  := 0;
         DERECHO_VENTA     := 0;
         OPEN C_NEXT (R_AN1.BMO_MNEMONICO);
         FETCH C_NEXT INTO R_NEXT;
         WHILE C_NEXT%FOUND LOOP
            IF R_NEXT.TIPO = 'COMPRA' THEN
               OBLIGACION_COMPRA := OBLIGACION_COMPRA + NVL(R_NEXT.OBLIGACION,0);
               DERECHO_COMPRA    := DERECHO_COMPRA + NVL(R_NEXT.DERECHO,0);
            ELSE
               OBLIGACION_VENTA := OBLIGACION_VENTA + NVL(R_NEXT.OBLIGACION,0);
               DERECHO_VENTA    := DERECHO_VENTA + NVL(R_NEXT.DERECHO,0);
            END IF;        
            FETCH C_NEXT INTO R_NEXT;
         END LOOP;
         CLOSE C_NEXT;
         OBLIGACION_COMPRA := OBLIGACION_COMPRA/VALOR_TRM;
         DERECHO_COMPRA    := DERECHO_COMPRA/VALOR_TRM;
         OBLIGACION_VENTA  := OBLIGACION_VENTA/VALOR_TRM;
         DERECHO_VENTA     := DERECHO_VENTA/VALOR_TRM;

         VALOR_CUENTA := 0;
         V_CUENTAS := '126404,126418,126420,126422,126424,126426,126428,126430,126534 ';
         P_DIVISAS.PR_VALOR_BALANCE ('CME' , P_FECHA , V_CUENTAS , VALOR_CUENTA);    
         IF VALOR_CUENTA != 0 THEN
            VALOR_CUENTA := VALOR_CUENTA /VALOR_TRM;
         END IF;
         VR_FLUJO_ING := VALOR_CUENTA + DERECHO_COMPRA;
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 67 , VR_FLUJO_ING/1000);

         -- 68:Flujo de ingresos provenientes de operaciones con derivados 
         OPEN C_DER (R_AN1.BMO_MNEMONICO, P_ULTIMO_CDI);
         FETCH C_DER INTO R_DER;
         IF C_DER%FOUND THEN
            IF R_DER.LID_VALOR_LIQUIDACION < 0 THEN
               ING_DER := 0;
               EGR_DER := NVL(R_DER.LID_VALOR_LIQUIDACION,0)/VALOR_TRM;
            ELSE
               ING_DER := NVL(R_DER.LID_VALOR_LIQUIDACION,0)/VALOR_TRM;
               EGR_DER := 0;
            END IF;
         ELSE
               ING_DER := 0;
               EGR_DER := 0;
         END IF;
         CLOSE C_DER;
         ING_DER := ABS(ING_DER);
         EGR_DER := ABS(EGR_DER);         
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 68 , ING_DER/1000);


         -- 69: Flujo de egresos sujetos a vencimientos contractuales         
         VALOR_CUENTA := 0;
         V_CUENTAS := '126467, 126469,126471,126473,126475, 126477,126479';
         P_DIVISAS.PR_VALOR_BALANCE ('CME' , P_FECHA , V_CUENTAS , VALOR_CUENTA);    
         IF VALOR_CUENTA != 0 THEN
            VALOR_CUENTA := VALOR_CUENTA /VALOR_TRM;
         END IF;
         VR_FLUJO_EG := VALOR_CUENTA + OBLIGACION_VENTA;
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 69 , VR_FLUJO_EG/1000);

         -- 70:  Flujo de egresos provenientes de operaciones con derivados
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 70 , EGR_DER/1000);

         -- 71: Flujo de egresos no contractuales (únicamente para entidades que realizan intermediación crediticia).
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 71 , 0 );

         --  72: Total requerimiento neto de liquidez  21.+ 22.-mín{0.75*[21.+22.];20.}
         IF ((VR_FLUJO_EG + 0) * 0.75) >=  VR_FLUJO_ING THEN
            TOTAL_NETO_LIQ := VR_FLUJO_EG + 0 - VR_FLUJO_ING;
         ELSE
            TOTAL_NETO_LIQ := VR_FLUJO_EG + 0 - ((VR_FLUJO_EG + 0) * 0.75);
         END IF;
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 72 , TOTAL_NETO_LIQ/1000 );

         -- 79:  Indicador de exposición de corto plazo por moneda 19./ 23.
         IF TOTAL_NETO_LIQ != 0 THEN
            VR_INDICADOR := TOTAL_ALIQ / TOTAL_NETO_LIQ;
         ELSE
            VR_INDICADOR := 0;
         END IF;
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 79 , VR_INDICADOR );

      -- OTRAS MONEDAS
      ELSE
         /* 8: Suma del pasivo, el activo y la posición bruta de derivados como proporción del activo total reportado en el balance individual de la matriz.*/
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO,8,NVL(R_AN1.RELACION,0));                                      

         -- 15: Activos de alta liquidez - Disponible

         VR_DISPONIBLE := 0;
         OPEN C_CBE(R_AN1.BMO_MNEMONICO);
         FETCH C_CBE INTO R_CBE;
         WHILE C_CBE%FOUND LOOP
            OPEN C_MBE (R_CBE.CBE_BEX_MNEMONICO, R_CBE.CBE_NUMERO_CUENTA);
            FETCH C_MBE INTO R_MBE;
            IF C_MBE%FOUND THEN
               SALDO := NVL(R_MBE.MBE_SALDO,0);
            ELSE 
               SALDO := 0;
            END IF;
            CLOSE C_MBE;
            VR_DISPONIBLE := VR_DISPONIBLE + SALDO;
            FETCH C_CBE INTO R_CBE;
         END LOOP;
         CLOSE C_CBE;
         VALOR_CUENTA := 0;
         VR_DISPONIBLE := NVL(VR_DISPONIBLE,0) + VALOR_CUENTA; 
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO,15,VR_DISPONIBLE/1000);

         -- 16: Encaje Requerido
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 16 , 0 );

         VR_TAL := 0;  
         VR_DEUDA_P := 0;
         VR_OTRAS_I := 0;

         -- 17: Títulos incluidos en el rubro de "Activos líquidos de alta calidad"
         VR_TAL := 0;
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 17 , VR_TAL/1000 );

         -- 18: Promedio ponderado de los haircuts aplicados a los títulos incluidos en el rubro de "Activos líquidos de alta calidad" 
         VALOR_CUENTA := 0;
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 18 , VALOR_CUENTA);

         -- 19: Total Activos de alta liquidez de las entidades establecidas en Colombia 2.+ 3.
         TOTAL_AAL_COL := VR_DISPONIBLE + VR_TAL;   --15+17
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 19 , TOTAL_AAL_COL/1000);

        -- 23: DISPONIBLE Activos de alta liquidez de entidades establecidas en el exterior 
         VR_DISPONIBLE := 0;
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 23 , VR_DISPONIBLE/1000);

         -- 24: Encaje Requerido tit exterior
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 24 , 0 );

         -- 25: Tit aceptables por el banco central del pais
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 25 , 0 );

         -- 26: Haircut promedio ponderado de los títulos.
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 26 , 0 );

         -- 27: Títulos emitidos en moneda local por los gobiernos de los Estados Unidos de América, Alemania, Francia, Dinamarca, Noruega, Suecia, Australia, Canadá, Nueva Zelanda, Reino Unido, Japón y Suiza
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 27 , 0 );

         -- 28: Total activos de alta liquidez de entidades establecidas en el exterior 
         TOTAL_AAL_EX := VR_DISPONIBLE;    --23+25+27
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 28 , TOTAL_AAL_EX/1000 );

        -- 32: Total Activos de alta liquidez 4.+ 8.
         TOTAL_AAL := TOTAL_AAL_COL + TOTAL_AAL_EX;   --19+28
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 32 , TOTAL_AAL/1000 );

         --37: Deuda privada incluida en el rubro de "Otros activos líquidos" 
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 37 , 0 );

         -- 38: Promedio ponderado de los haircuts de la deuda privada incluida en "Otros activos líquidos" 
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 38 , 0 );

         -- 39: Otras inversiones incluidas en el rubro de "Otros activos líquidos"
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 39 , 0 );

         -- 40 : Promedio ponderado de los haircuts de otras inversiones incluidas en "Otros activos líquidos"  
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 40 , 0 );


         -- 41: total otros activos líquidos de entidades establecidas en Colombia 
         TOTAL_OTROA_AL_COL := VR_DEUDA_P + VR_OTRAS_I;  --37+39
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 41 , TOTAL_OTROA_AL_COL/1000 );

         -- 45: Títulos emitidos o garantizados por gobiernos que no cumplan los criterios mencionados en 6. y 7.
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 45 , 0 );

         -- 46: Títulos emitidos o garantizados por bancos centrales que no cumplan el criterio mencionado en 6. 
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 46 , 0 );

         --  47: Títulos emitidos por entidades multilaterales 2
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 47 , 0 );

         -- 48: Total de otros activos líquidos de entidades establecidas en el exterior 13.+ 14.+ 15.
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 48 , 0 );

         -- 52: Total Otros activos líquidos 2.12.+2.16.
         TOTAL_OTROS_ALIQ := TOTAL_OTROA_AL_COL + 0 ;    --41+48
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 52 , TOTAL_OTROS_ALIQ/1000 );

         --  57: Títulos de deuda privada de las entidades establecidas en el exterior
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 57 , 0 );

         -- 61: Activos líquidos totales 9.+mín{17.;9.*3/7}
         IF (TOTAL_AAL * 3/7) >= TOTAL_OTROS_ALIQ THEN
            TOTAL_ALIQ := TOTAL_AAL + TOTAL_OTROS_ALIQ;
         ELSE
            TOTAL_ALIQ := TOTAL_AAL + (TOTAL_AAL * 3/7);
         END IF;
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 61 , TOTAL_ALIQ/1000 );

         -- 67: Flujo de ingresos sujetos a vencimientos contractuales
         OBLIGACION_COMPRA := 0;
         DERECHO_COMPRA    := 0;
         OBLIGACION_VENTA  := 0;
         DERECHO_VENTA     := 0;
         OPEN C_NEXT (R_AN1.BMO_MNEMONICO);
         FETCH C_NEXT INTO R_NEXT;
         WHILE C_NEXT%FOUND LOOP
            IF R_NEXT.TIPO = 'COMPRA' THEN
               OBLIGACION_COMPRA := OBLIGACION_COMPRA + NVL(R_NEXT.OBLIGACION,0);
               DERECHO_COMPRA    := DERECHO_COMPRA + NVL(R_NEXT.DERECHO,0);
            ELSE
               OBLIGACION_VENTA := OBLIGACION_VENTA + NVL(R_NEXT.OBLIGACION,0);
               DERECHO_VENTA    := DERECHO_VENTA + NVL(R_NEXT.DERECHO,0);
            END IF;        
            FETCH C_NEXT INTO R_NEXT;
         END LOOP;
         CLOSE C_NEXT;
         OBLIGACION_COMPRA := OBLIGACION_COMPRA/VALOR_TRM;
         DERECHO_COMPRA    := DERECHO_COMPRA/VALOR_TRM;
         OBLIGACION_VENTA  := OBLIGACION_VENTA/VALOR_TRM;
         DERECHO_VENTA     := DERECHO_VENTA/VALOR_TRM;

         VALOR_CUENTA := 0;
         CONTADOR := CONTADOR+1;
         VR_FLUJO_ING := DERECHO_COMPRA;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 67 , VR_FLUJO_ING/1000);

         -- 68:Flujo de ingresos provenientes de operaciones con derivados 
         ING_DER := 0;
         EGR_DER := 0;
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 68 , ING_DER/1000);


         -- 69: Flujo de egresos sujetos a vencimientos contractuales         
         VALOR_CUENTA := 0;
         VR_FLUJO_EG := OBLIGACION_VENTA;
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 69 , VR_FLUJO_EG/1000);

         -- 70:  Flujo de egresos provenientes de operaciones con derivados
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 70 , EGR_DER/1000);

         -- 71: Flujo de egresos no contractuales (únicamente para entidades que realizan intermediación crediticia).
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 71 , 0 );

         --  72: Total requerimiento neto de liquidez  21.+ 22.-mín{0.75*[21.+22.];20.}
         IF ((VR_FLUJO_EG + 0) * 0.75) >=  VR_FLUJO_ING THEN
            TOTAL_NETO_LIQ := VR_FLUJO_EG + 0 - VR_FLUJO_ING;
         ELSE
            TOTAL_NETO_LIQ := VR_FLUJO_EG + 0 - ((VR_FLUJO_EG + 0) * 0.75);
         END IF;
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 72 , TOTAL_NETO_LIQ/1000 );

         -- 79:  Indicador de exposición de corto plazo por moneda 19./ 23.
         IF TOTAL_NETO_LIQ != 0 THEN
            VR_INDICADOR := TOTAL_ALIQ / TOTAL_NETO_LIQ;
         ELSE
            VR_INDICADOR := 0;
         END IF;
         CONTADOR := CONTADOR+1;
         INSERT INTO GL_ANEXO2 (GLAD_CONSECUTIVO,GLAD_BMO_MNEMONICO,GLAD_CONSECUTIVO_AFECTADO,GLAD_VALOR)
         VALUES(CONTADOR,R_AN1.BMO_MNEMONICO, 79 , VR_INDICADOR );

      END IF;
      FETCH C_AN1 INTO R_AN1;
   END LOOP;
   CLOSE C_AN1;

-- genera archivo plano con separador de lista "|"
   R_REGISTRO_ADOS.DELETE;
   v_bufline := '| | ANEXO2';
   PR_ESCRIBE_FORMATO_ADOS(P_REGISTRO_ADOS  => R_REGISTRO_ADOS,P_BUFLINE      =>  v_bufline);
   v_bufline := '| | Indicador de exposición de corto plazo por moneda';
   PR_ESCRIBE_FORMATO_ADOS(P_REGISTRO_ADOS  => R_REGISTRO_ADOS,P_BUFLINE      =>  v_bufline);
   v_bufline := '| | | ';
   PR_ESCRIBE_FORMATO_ADOS(P_REGISTRO_ADOS  => R_REGISTRO_ADOS,P_BUFLINE      =>  v_bufline);
   v_bufline := '| | Montos expresados en US$ miles | | BR-3-897-0';
   PR_ESCRIBE_FORMATO_ADOS(P_REGISTRO_ADOS  => R_REGISTRO_ADOS,P_BUFLINE      =>  v_bufline);

   i := 0;
   For R_BMO IN C_BMO loop
      i := i + 1;  
      reg_bmo(i).bmo_codigo    := R_BMO.BMO_CODIGO;
      reg_bmo(i).bmo_mnemonico := R_BMO.BMO_MNEMONICO;
   End Loop;
   For j in 1 .. reg_bmo.Count loop
      v_bufline1 := v_bufline1||'|'||reg_bmo(j).bmo_codigo;
   End Loop;

   For R_TADB IN C_TADB loop
      v_bufline := '|'||R_TADB.TADB_TITULO_C1||'|'||R_TADB.TADB_TITULO_C2||'|'||R_TADB.TADB_TITULO_C3;
      IF R_TADB.TADB_TITULO_C4 = 'Moneda' THEN
         v_bufline := v_bufline||v_bufline1;
      END IF;

      For j in 1 .. reg_bmo.Count loop
         open C_DATO (R_TADB.TADB_CONSECUTIVO, reg_bmo(j).bmo_mnemonico);
         FETCH C_DATO INTO R_DATO;
         IF C_DATO%NOTFOUND THEN
            IF R_TADB.TADB_CONSECUTIVO IN (8,15,16,17,18,19,23,24,25,26,27,28,32,37,38,39,40,41,45,46,47,
                                           48,52,57,61,67,68,69, 70,71,72,75,79)  THEN
               reg_datobmo(j).valor := 0;   
            ELSE
               reg_datobmo(j).valor := null;   
            END IF;
         ELSE
            IF R_TADB.TADB_CONSECUTIVO IN (8,15,16,17,18,19,23,24,25,26,27,28,32,37,38,39,40,41,45,46,47,
                                           48,52,57,61,67,68,69, 70,71,72,75,79)  THEN
               reg_datobmo(j).valor := NVL(R_DATO.GLAD_VALOR,0);   
            ELSE
               reg_datobmo(j).valor := NULL;
            END IF;
         End if;
         CLOSE C_DATO;
      End Loop;


      For j in 1 .. reg_bmo.Count loop
         v_bufline := v_bufline||'|'||reg_datobmo(j).valor;
      End Loop;
      PR_ESCRIBE_FORMATO_ADOS(P_REGISTRO_ADOS => R_REGISTRO_ADOS,P_BUFLINE  =>  v_bufline);
   End Loop;


   IF P_LLAMADO_REPORTE = 'F' THEN
      IF r_registro_ADOS.COUNT() > 0 THEN
        p_registro_ADOS.DELETE;
        FOR i IN r_registro_ADOS.FIRST .. r_registro_ADOS.LAST LOOP
          v_registro := p_registro_ADOS.COUNT();
          p_registro_ADOS(v_registro).bufline   := r_registro_ADOS(i).bufline;
        END LOOP;
      END IF;
   END IF;

EXCEPTION
    WHEN ERROR THEN
      RAISE_APPLICATION_ERROR(-20002,'Error ejecutando P_DIVISAS.PR_FORMATO_ADOS '||V_MENSAJE_ERROR);
    WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20001,'Error ejecutando P_DIVISAS.PR_FORMATO_ADOS '||SQLERRM);
END PR_FORMATO_ADOS;                                                


PROCEDURE PR_VALOR_BALANCE (P_TIPO VARCHAR2, P_FECHA DATE, P_CUENTAS VARCHAR2, P_VALOR IN OUT NUMBER)  IS 
   /* P_TIPO : TIPO DE BALANCE --> CCOP : PESOS ; CMT : TOTAL   ; CME : MONEDA  */  

  C_BACO O_CURSOR;
  TYPE T_BACO IS RECORD (VALOR NUMBER(22,2));               
  R_BACO T_BACO;

  V_SELECT VARCHAR2(4000);

BEGIN

    V_SELECT := 'SELECT  SUM(BACO_VALOR) VALOR FROM BALANCES_CORREDORES ';
    V_SELECT := V_SELECT || ' WHERE  BACO_FECHA = ' || '''' || LAST_DAY(P_FECHA) || '''';
    V_SELECT := V_SELECT || ' AND    BACO_TIPO_BALANCE = ' || '''' || P_TIPO || '''';
    V_SELECT := V_SELECT || ' AND    BACO_CUENTA IN ('||P_CUENTAS ||')';

    OPEN C_BACO FOR (V_SELECT);
    FETCH C_BACO INTO R_BACO;
    IF C_BACO%FOUND THEN
       P_VALOR := NVL(R_BACO.VALOR,0);
    ELSE
       P_VALOR := 0;
    END IF;
    CLOSE C_BACO;
END PR_VALOR_BALANCE;

PROCEDURE PR_ESCRIBE_FORMATO_ADOS(P_REGISTRO_ADOS  IN OUT T_REGISTRO_ADOS,
                                  P_BUFLINE       VARCHAR2) IS
  v_registro NUMBER;
BEGIN
  v_registro := P_REGISTRO_ADOS.COUNT();
  P_REGISTRO_ADOS(v_registro).bufline := P_BUFLINE;
END PR_ESCRIBE_FORMATO_ADOS;

/*** PROCEDIMIENTO QUE INSERTA DE LA TABLA GL_PORTAFOLIOS QUE SE GENERA 
     EN LA DINAMICA DE POSICION PROPIA, LOS TITULOS QUE QUEDAN EN CORTO EN LA FECHA  */
PROCEDURE PR_TITULOS_POSICION_CORTOS (P_FECHA DATE) IS

   CURSOR C_FDO IS
      SELECT  DISTINCT MRF_TFO_FON_CODIGO FON_CODIGO
      FROM GL_PORTAFOLIOS
      WHERE MRF_TFO_FON_CODIGO IN ('860079174','8600791743');
   R_FDO C_FDO%ROWTYPE;      

   CURSOR C_TFO (P_FDO VARCHAR2) IS
      SELECT  TFO_ENA_MNEMONICO
             ,MRF_TFO_FON_CODIGO 
             ,MRF_TFO_CODIGO
             ,MRF_VALOR_NOMINAL
             ,MRF_VALOR_TITULO_TM
      FROM GL_PORTAFOLIOS
      WHERE MRF_TFO_FON_CODIGO = P_FDO
         AND MRF_TMT_MNEMONICO IN ('VCT') ;  
   R_TFO C_TFO%ROWTYPE;      
BEGIN
   OPEN C_FDO;
   FETCH C_FDO INTO R_FDO;
   WHILE C_FDO%FOUND LOOP
      DELETE FROM TITULOS_POSICION_CORTOS
      WHERE TPCO_FON_CODIGO = R_FDO.FON_CODIGO
      AND   TPCO_FECHA >= TRUNC(P_FECHA)
      AND   TPCO_FECHA <  TRUNC(P_FECHA+1);

      OPEN C_TFO (R_FDO.FON_CODIGO);
      FETCH C_TFO INTO R_TFO;
      WHILE C_TFO%FOUND LOOP
         INSERT INTO TITULOS_POSICION_CORTOS
                  (TPCO_CONSECUTIVO 
                  ,TPCO_ENA_MNEMONICO
                  ,TPCO_FON_CODIGO
                  ,TPCO_TFO_CODIGO
                  ,TPCO_FECHA
                  ,TPCO_VALOR_NOMINAL
                  ,TPCO_VALOR_TM )
         VALUES (  TPCO_SEQ.NEXTVAL
                  ,R_TFO.TFO_ENA_MNEMONICO
                  ,R_TFO.MRF_TFO_FON_CODIGO
                  ,R_TFO.MRF_TFO_CODIGO
                  ,TRUNC(P_FECHA)
                  ,R_TFO.MRF_VALOR_NOMINAL
                  ,R_TFO.MRF_VALOR_TITULO_TM );
         FETCH C_TFO INTO R_TFO;
      END LOOP;
      CLOSE C_TFO;
      FETCH C_FDO INTO R_FDO;
   END LOOP;
   CLOSE C_FDO;
   COMMIT;
END PR_TITULOS_POSICION_CORTOS;

PROCEDURE PR_VALOR_CORTOS (P_FECHA IN DATE , P_VALOR_CORTOS IN OUT NUMBER) IS
   CURSOR C_HAIR IS
      SELECT DISTINCT TPCO_ENA_MNEMONICO ENA_MNEMONICO
      FROM TITULOS_POSICION_CORTOS T
      WHERE T.TPCO_FECHA  >= TRUNC(P_FECHA)
        AND T.TPCO_FECHA  <  TRUNC(P_FECHA+1)
        AND NOT EXISTS (SELECT 'X'
                        FROM  EMISIONES E,
                              EMISIONES_HAIRCUTS H
                         WHERE T.TPCO_ENA_MNEMONICO   = E.EMS_ENA_MNEMONICO
                         AND   E.EMS_ENA_MNEMONICO    = H.EMH_EMS_ENA_MNEMONICO
                         AND   E.EMS_NUMERO_EMISION   = H.EMH_EMS_NUMERO_EMISION
                         AND   H.EMH_PLAZO            = 1);
   R_HAIR C_HAIR%ROWTYPE;                         

   CURSOR C_CORTOS IS
      SELECT SUM(TPCO_VALOR_TM * (1- H.EMH_HAIRCUT)) AS VALOR
      FROM TITULOS_POSICION_CORTOS T,
           EMISIONES E,
           EMISIONES_HAIRCUTS H
      WHERE T.TPCO_ENA_MNEMONICO   = E.EMS_ENA_MNEMONICO
      AND   E.EMS_ENA_MNEMONICO    = H.EMH_EMS_ENA_MNEMONICO
      AND   E.EMS_NUMERO_EMISION   = H.EMH_EMS_NUMERO_EMISION
      AND   H.EMH_PLAZO            = 1
      AND   T.TPCO_FECHA           >= TRUNC(P_FECHA)
      AND   T.TPCO_FECHA          <  TRUNC(P_FECHA+1);
   R_CORTOS C_CORTOS%ROWTYPE;
   v_mensaje_especies  VARCHAR2(2000);
   v_mensaje_error     VARCHAR2(2000);
   error               EXCEPTION;
BEGIN
   -- VERIFICA QUE TODAS LAS ESPECIES DE LOS TITULOS EN CORTO TENGAN HAIRCUT
   v_mensaje_especies := '';
   OPEN C_HAIR;
   FETCH C_HAIR INTO R_HAIR;
   WHILE C_HAIR%FOUND LOOP
      v_mensaje_especies := R_HAIR.ENA_MNEMONICO||',';
      FETCH C_HAIR INTO R_HAIR;
   END LOOP;
   CLOSE C_HAIR;
   IF v_mensaje_especies IS NOT NULL THEN
      v_mensaje_error := ' No existe Haircut para las siguientes especies: '||v_mensaje_especies;
      RAISE ERROR;
   END IF;

   OPEN C_CORTOS;
   FETCH C_CORTOS INTO R_CORTOS;
   IF C_CORTOS%FOUND THEN
      P_VALOR_CORTOS := NVL(R_CORTOS.VALOR,0);
   ELSE
      P_VALOR_CORTOS := 0;
   END IF;
EXCEPTION
    WHEN ERROR THEN
      RAISE_APPLICATION_ERROR(-20002,'Error ejecutando PR_VALOR_CORTOS '||V_MENSAJE_ERROR);
    WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20001,'Error ejecutando PR_VALOR_CORTOS  '||SQLERRM);

END PR_VALOR_CORTOS;

PROCEDURE PR_ORDENES_SETFX_PORREGISTRAR (P_FECHA DATE,P_SETFX_PREGISTRAR IN OUT P_CURSOR_SETFX) IS
  V_FECHA               DATE;
  V_SELECT              VARCHAR2(4000);
  V_CURSOR              P_DIVISAS.P_CURSOR_SETFX;
  V_SETX_REF            GL_DIVISAS_SETFX_P%ROWTYPE;
  V_PER_TIPO            PERSONAS.PER_TIPO%TYPE;
  V_PER_DIGITO_CONTROL  PERSONAS.PER_DIGITO_CONTROL%TYPE;
  V_ORD_TIPO_CAMBIO_FX  ORDENES_DIVISAS.ORD_TIPO_CAMBIO%TYPE; 
  V_CLI_PER_NUM_IDEN    NUMBER;
BEGIN
   IF P_FECHA IS NOT NULL THEN
      V_FECHA := TRUNC(P_FECHA);
   ELSE
    SELECT TRUNC(SYSDATE) INTO V_FECHA FROM DUAL;
   END IF;  

   V_SETX_REF           := NULL;
   V_PER_TIPO           := NULL;
   V_PER_DIGITO_CONTROL := NULL;
   V_CLI_PER_NUM_IDEN   := NULL;
   V_ORD_TIPO_CAMBIO_FX := NULL;

   DELETE GL_DIVISAS_SETFX_P;
   V_SELECT := ' SELECT ORD.ORD_CONSECUTIVO '||
         ' ,ORD.ORD_SUC_CODIGO '||
         ' ,ORD.ORD_CLI_PER_NUM_IDEN '||
         ' ,ORD.ORD_CLI_PER_TID_CODIGO '||
         ' ,ORD.ORD_CCC_NUMERO_CUENTA '||
         ' ,ORD.ORD_TMD_MNEMONICO '||
         ' ,ORD.ORD_TIPO_ORDEN '||
         ' ,ORD.ORD_TIPO_MERCADO '||
         ' ,ORD.ORD_VALOR_DOLARES '||
         ' ,ORD.ORD_VALOR_PESOS '||
         ' ,ORD.ORD_COLOCADO_POR '||
         ' ,ORD.ORD_FECHA_COLOCACION '||
         ' ,ORD.ORD_TASA_CAMBIO '||
         ' ,ORD.ORD_PER_NUM_IDEN '||
         ' ,ORD.ORD_PER_TID_CODIGO '||
         ' ,DECODE(ORD.ORD_BMO_MNEMONICO_FX, NULL, ORD.ORD_VALOR_FX_C, ORD.ORD_VALOR_FX) ORD_VALOR_FX  '||
         ' ,DECODE(ORD.ORD_BMO_MNEMONICO_FX, NULL, ORD.ORD_BMO_MNEMONICO_FX_C,ORD.ORD_BMO_MNEMONICO_FX) ORD_BMO_MNEMONICO_FX '||
         ' ,ORD.ORD_HORA_RECEPCION '||
         ' ,ORD.ORD_HORA_RECEPCION_I '||  -- SORTIZ
         ' ,ORD.ORD_DIAS_NEXT_DAY'|| 
         ' ,PER.PER_INICIALES_USUARIO '||
         ' ,PER.PER_NOMBRE_USUARIO '||
         ' ,FIL.PER_NOMBRE '||
         ' ,TO_DATE(TO_CHAR(ORD_FECHA_COLOCACION,'||CHR(39)||'dd/MM/yyyy'||CHR(39)||')||'||CHR(39)||' '||CHR(39)||'||TRIM(ORD_HORA_RECEPCION)  ,'||CHR(39)||'dd/MM/yyyy HH24:MI:SS'||CHR(39)||')  ORD_HORA_REGISTRO '||
         ' ,NVL(ORD_TIPO_CAMBIO,0) ORD_TIPO_CAMBIO '||
         ' ,ORD_FECHA_CUMPLIMIENTO '||
         ' ,PER.PER_TIPO '||
         ' ,NULL POF_CONSECUTIVO '||
         ' ,NULL POF_DIAS_FIX '||
         ' ,NULL POF_FECHA_FIX '||   
         ' ,ORD_EVO_NIT ORD_EVO_NIT'||
         ' FROM FILTRO_PERSONAS FIL, '||
         ' PERSONAS PER, '||
         ' ORDENES_DIVISAS ORD '||
         ' WHERE FIL.PER_NUM_IDEN = ORD_CLI_PER_NUM_IDEN '||
             ' AND FIL.PER_TID_CODIGO = ORD_CLI_PER_TID_CODIGO '||
             ' AND PER.PER_NUM_IDEN = ORD_PER_NUM_IDEN_NEGOCIA '||
             ' AND PER.PER_TID_CODIGO = ORD_PER_TID_CODIGO_NEGOCIA '||
             ' AND ORD.ORD_FECHA_COLOCACION >= TO_DATE(''' || TO_CHAR(V_FECHA,'dd/MM/yyyy HH24:MI:SS') || ''',''dd/MM/yyyy HH24:MI:SS'') '||
             ' AND ORD.ORD_FECHA_COLOCACION < TO_DATE(''' || TO_CHAR(V_FECHA+1,'dd/MM/yyyy HH24:MI:SS') || ''',''dd/MM/yyyy HH24:MI:SS'') '||
             ' AND ORD.ORD_EOF_CODIGO = '||CHR(39)||'COL'||CHR(39)||
             ' AND NVL(ORD.ORD_OPERACION_SETFX,'||CHR(39)||'N'||CHR(39)||') = '||CHR(39)||'S'||CHR(39)||
             ' AND ORD.ORD_USUARIO_REG_SETFX IS NULL '||

         ' UNION SELECT POF.POF_ORD_CONSECUTIVO ORD_CONSECUTIVO '||
         ',POF.POF_ORD_SUC_CODIGO ORD_SUC_CODIGO '||
         ',POF.POF_CCC_CLI_PER_NUM_IDEN ORD_CLI_PER_NUM_IDEN  '||
         ',POF.POF_CCC_CLI_PER_TID_CODIGO ORD_CLI_PER_TID_CODIGO '||
         ',POF.POF_CCC_NUMERO_CUENTA ORD_CCC_NUMERO_CUENTA '||
         ',NULL ORD_TMD_MNEMONICO '||
         ',POF.POF_TIPO_ORDEN ORD_TIPO_ORDEN '||
         ',POF.POF_TIPO_MERCADO ORD_TIPO_MERCADO '||
         ',POF.POF_VALOR_DOLARES ORD_VALOR_DOLARES '||
         ',NULL ORD_VALOR_PESOS '||
         ',POF.POF_COLOCADO_POR ORD_COLOCADO_POR '||
         ',POF.POF_FECHA_COLOCACION ORD_FECHA_COLOCACION '||
         ',NULL ORD_TASA_CAMBIO '||
         ',POF.POF_PER_NUM_IDEN ORD_PER_NUM_IDEN '||
         ',POF.POF_PER_TID_CODIGO ORD_PER_TID_CODIGO '||
         ',NULL ORD_VALOR_FX '||
         ',NULL ORD_BMO_MNEMONICO_FX '||
         ',POF.POF_HORA_RECEPCION ORD_HORA_RECEPCION '||
         ',POF.POF_HORA_RECEPCION ORD_HORA_RECEPCION_I '||  -- SORTIZ
         ',NULL DIAS_NEXT_DAY '||
         ',PER.PER_INICIALES_USUARIO '||
         ',PER.PER_NOMBRE_USUARIO  '||
         ',FIL.PER_NOMBRE '||
         ',TO_DATE(TO_CHAR(POF.POF_FECHA_COLOCACION,'||CHR(39)||'dd/MM/yyyy'||CHR(39)||')||'||CHR(39)||' '||CHR(39)||'||TRIM(POF.POF_HORA_RECEPCION)  ,'||CHR(39)||'dd/MM/yyyy HH24:MI:SS'||CHR(39)||')  ORD_HORA_REGISTRO '||
         ',NULL ORD_TIPO_CAMBIO '||
         ',POF.POF_FECHA_CUMPLIMIENTO ORD_FECHA_CUMPLIMIENTO '||
         ',PER.PER_TIPO '||
         ',POF_CONSECUTIVO '||
         ',POF_DIAS_FIX '||
         ',POF_FECHA_FIX '||
         ',POF.POF_EVO_NIT ORD_EVO_NIT  '||
         'FROM PREORDENES_FIX POF '||
         ',PERSONAS PER '||
         ',FILTRO_PERSONAS FIL '||
         'WHERE FIL.PER_NUM_IDEN = POF_CCC_CLI_PER_NUM_IDEN '|| 
            'AND FIL.PER_TID_CODIGO = POF_CCC_CLI_PER_TID_CODIGO '|| 
            'AND PER.PER_NUM_IDEN = POF.POF_PER_NUM_IDEN_NEG '||
            'AND PER.PER_TID_CODIGO = POF.POF_PER_TID_CODIGO_NEG '||
            'AND POF.POF_EOF_CODIGO ='||CHR(39)||'COL'||CHR(39)||
            'AND POF.POF_FECHA_COLOCACION >= TO_DATE(''' || TO_CHAR(V_FECHA,'dd/MM/yyyy HH24:MI:SS') || ''',''dd/MM/yyyy HH24:MI:SS'') '||
            'AND POF.POF_FECHA_COLOCACION < TO_DATE(''' || TO_CHAR(V_FECHA+1,'dd/MM/yyyy HH24:MI:SS') || ''',''dd/MM/yyyy HH24:MI:SS'') '||
            'AND POF.POF_USUARIO_REG_SETFX IS NULL ';

   V_CURSOR := NULL;        
   OPEN V_CURSOR FOR V_SELECT; 
   LOOP
      V_SETX_REF           := NULL;
      V_PER_TIPO           := NULL;
      V_PER_DIGITO_CONTROL := NULL;
      V_CLI_PER_NUM_IDEN   := NULL;
      FETCH V_CURSOR INTO  V_SETX_REF.ORD_CONSECUTIVO
                          ,V_SETX_REF.ORD_SUC_CODIGO
                          ,V_SETX_REF.ORD_CLI_PER_NUM_IDEN
                          ,V_SETX_REF.ORD_CLI_PER_TID_CODIGO
                          ,V_SETX_REF.ORD_CCC_NUMERO_CUENTA
                          ,V_SETX_REF.ORD_TMD_MNEMONICO
                          ,V_SETX_REF.ORD_TIPO_ORDEN
                          ,V_SETX_REF.ORD_TIPO_MERCADO
                          ,V_SETX_REF.ORD_VALOR_DOLARES
                          ,V_SETX_REF.ORD_VALOR_PESOS
                          ,V_SETX_REF.ORD_COLOCADO_POR
                          ,V_SETX_REF.ORD_FECHA_COLOCACION
                          ,V_SETX_REF.ORD_TASA_CAMBIO
                          ,V_SETX_REF.ORD_PER_NUM_IDEN
                          ,V_SETX_REF.ORD_PER_TID_CODIGO
                          ,V_SETX_REF.ORD_VALOR_FX
                          ,V_SETX_REF.ORD_BMO_MNEMONICO_FX
                          ,V_SETX_REF.ORD_HORA_RECEPCION
                          ,V_SETX_REF.ORD_HORA_RECEPCION_I  -- SORTIZ
                          ,V_SETX_REF.ORD_DIAS_NEXT_DAY
                          ,V_SETX_REF.PER_INICIALES_USUARIO
                          ,V_SETX_REF.PER_NOMBRE_USUARIO
                          ,V_SETX_REF.PER_NOMBRE
                          ,V_SETX_REF.ORD_HORA_REGISTRO
                          ,V_SETX_REF.ORD_TIPO_CAMBIO
                          ,V_SETX_REF.ORD_FECHA_CUMPLIMIENTO
                          ,V_PER_TIPO
                          ,V_SETX_REF.POF_CONSECUTIVO
                          ,V_SETX_REF.POF_DIAS_FIX
                          ,V_SETX_REF.POF_FECHA_FIX
                          ,V_SETX_REF.ORD_EVO_NIT;

      EXIT WHEN V_CURSOR%NOTFOUND;

      IF V_PER_TIPO = 'PNA' THEN
        BEGIN
          V_CLI_PER_NUM_IDEN := TO_NUMBER(V_SETX_REF.ORD_CLI_PER_NUM_IDEN);
          V_PER_DIGITO_CONTROL := P_CLIENTES.RT_DIGITO_CONTROL(V_CLI_PER_NUM_IDEN);
          EXCEPTION WHEN OTHERS THEN
             V_PER_DIGITO_CONTROL := 0;
        END;     
      END IF;

      IF V_SETX_REF.ORD_BMO_MNEMONICO_FX IS NULL THEN
        V_SETX_REF.ORD_VALOR_FX := 0;
        V_ORD_TIPO_CAMBIO_FX    := 0;
      ELSE
         BEGIN
            V_ORD_TIPO_CAMBIO_FX :=ROUND(NVL(V_SETX_REF.ORD_VALOR_PESOS,0)/(NVL(V_SETX_REF.ORD_VALOR_FX,0)),2);
            EXCEPTION WHEN OTHERS THEN
             V_ORD_TIPO_CAMBIO_FX := 0;
         END;
      END IF;  

      INSERT INTO GL_DIVISAS_SETFX_P
         ( ORD_CONSECUTIVO
          ,ORD_SUC_CODIGO
          ,ORD_CLI_PER_NUM_IDEN
          ,ORD_CLI_PER_TID_CODIGO
          ,ORD_CCC_NUMERO_CUENTA
          ,ORD_TMD_MNEMONICO
          ,ORD_TIPO_ORDEN
          ,ORD_TIPO_MERCADO
          ,ORD_VALOR_DOLARES
          ,ORD_VALOR_PESOS
          ,ORD_COLOCADO_POR
          ,ORD_FECHA_COLOCACION
          ,ORD_TASA_CAMBIO
          ,ORD_PER_NUM_IDEN
          ,ORD_PER_TID_CODIGO
          ,ORD_VALOR_FX
          ,ORD_BMO_MNEMONICO_FX
          ,ORD_HORA_RECEPCION
          ,ORD_HORA_RECEPCION_I -- SORTIZ
          ,ORD_DIAS_NEXT_DAY
          ,PER_INICIALES_USUARIO
          ,PER_NOMBRE_USUARIO
          ,PER_NOMBRE
          ,ORD_HORA_REGISTRO
          ,ORD_TIPO_CAMBIO
          ,ORD_FECHA_CUMPLIMIENTO
          ,PER_DIGITO_CONTROL
          ,ORD_TIPO_CAMBIO_FX
          ,POF_CONSECUTIVO
          ,POF_DIAS_FIX
          ,POF_FECHA_FIX
          ,ORD_EVO_NIT)
      VALUES
        ( V_SETX_REF.ORD_CONSECUTIVO
         ,V_SETX_REF.ORD_SUC_CODIGO
         ,V_SETX_REF.ORD_CLI_PER_NUM_IDEN
         ,V_SETX_REF.ORD_CLI_PER_TID_CODIGO
         ,V_SETX_REF.ORD_CCC_NUMERO_CUENTA
         ,V_SETX_REF.ORD_TMD_MNEMONICO
         ,V_SETX_REF.ORD_TIPO_ORDEN
         ,V_SETX_REF.ORD_TIPO_MERCADO
         ,V_SETX_REF.ORD_VALOR_DOLARES
         ,V_SETX_REF.ORD_VALOR_PESOS
         ,V_SETX_REF.ORD_COLOCADO_POR
         ,V_SETX_REF.ORD_FECHA_COLOCACION
         ,V_SETX_REF.ORD_TASA_CAMBIO
         ,V_SETX_REF.ORD_PER_NUM_IDEN
         ,V_SETX_REF.ORD_PER_TID_CODIGO
         ,V_SETX_REF.ORD_VALOR_FX
         ,V_SETX_REF.ORD_BMO_MNEMONICO_FX
         ,V_SETX_REF.ORD_HORA_RECEPCION
         ,V_SETX_REF.ORD_HORA_RECEPCION_I -- SORTIZ
         ,V_SETX_REF.ORD_DIAS_NEXT_DAY
         ,V_SETX_REF.PER_INICIALES_USUARIO
         ,V_SETX_REF.PER_NOMBRE_USUARIO
         ,V_SETX_REF.PER_NOMBRE
         ,V_SETX_REF.ORD_HORA_REGISTRO
         ,V_SETX_REF.ORD_TIPO_CAMBIO
         ,V_SETX_REF.ORD_FECHA_CUMPLIMIENTO
         ,V_PER_DIGITO_CONTROL
         ,V_ORD_TIPO_CAMBIO_FX
         ,V_SETX_REF.POF_CONSECUTIVO
         ,V_SETX_REF.POF_DIAS_FIX
         ,V_SETX_REF.POF_FECHA_FIX     
         ,V_SETX_REF.ORD_EVO_NIT
         );      
  END LOOP;
  CLOSE V_CURSOR;   


   OPEN P_SETFX_PREGISTRAR FOR ('SELECT A.ORD_CONSECUTIVO'||  
          ',ORD_SUC_CODIGO '||
          ',ORD_CLI_PER_NUM_IDEN '||
          ',ORD_CLI_PER_TID_CODIGO '||
          ',ORD_CCC_NUMERO_CUENTA '||
          ',ORD_TMD_MNEMONICO '||
          ',ORD_TIPO_ORDEN '||
          ',ORD_TIPO_MERCADO '||
          ',ORD_VALOR_DOLARES '||
          ',ORD_VALOR_PESOS '||
          ',ORD_COLOCADO_POR '||
          ',ORD_FECHA_COLOCACION '||
          ',ORD_TASA_CAMBIO '||
          ',ORD_PER_NUM_IDEN '||
          ',ORD_PER_TID_CODIGO '||
          ',ORD_VALOR_FX '||
          ',ORD_BMO_MNEMONICO_FX '||
          ',ORD_HORA_RECEPCION '||
          ',ORD_HORA_RECEPCION_I '||  -- SORTIZ
          ',ORD_DIAS_NEXT_DAY '||
          ',PER_INICIALES_USUARIO '||
          ',PER_NOMBRE_USUARIO '||
          ',PER_NOMBRE '||
          ',ORD_HORA_REGISTRO '||
          ',ORD_TIPO_CAMBIO '||
          ',ORD_FECHA_CUMPLIMIENTO '||
          ',PER_DIGITO_CONTROL '||
          ',ORD_TIPO_CAMBIO_FX '||
          ',POF_CONSECUTIVO '||
          ',POF_DIAS_FIX '||
          ',POF_FECHA_FIX '||     
          ',ORD_EVO_NIT '||
          ' FROM GL_DIVISAS_SETFX_P A ORDER BY A.ORD_HORA_REGISTRO');        

  EXCEPTION
   WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20001,'Error PR_ORDENES_SETFX_PORREGISTRAR:'||SQLERRM );
END PR_ORDENES_SETFX_PORREGISTRAR;

PROCEDURE PR_ESTADO_ORDEN_DIV_SETFX(P_ORD_SUC_CODIGO NUMBER, P_ORD_CONSECUTIVO NUMBER,P_RESPUESTA IN OUT VARCHAR2) IS
  V_SELECT    VARCHAR2(4000);
  V_CURSOR    P_DIVISAS.P_CURSOR_SETFX;  
  V_REG_ORD   ORDENES_DIVISAS%ROWTYPE;
BEGIN
  V_SELECT    := NULL;
  V_CURSOR    := NULL;
  V_REG_ORD   := NULL;


  V_SELECT :=  'SELECT ORD_EOF_CODIGO,ORD_USUARIO_REG_SETFX FROM ORDENES_DIVISAS '||
                ' WHERE ORD_SUC_CODIGO = '||P_ORD_SUC_CODIGO||
                ' AND ORD_CONSECUTIVO = '||P_ORD_CONSECUTIVO;
  OPEN V_CURSOR FOR V_SELECT; 
  LOOP
     FETCH V_CURSOR INTO V_REG_ORD.ORD_EOF_CODIGO,
                         V_REG_ORD.ORD_USUARIO_REG_SETFX;
     EXIT WHEN V_CURSOR%NOTFOUND;     
     IF V_REG_ORD.ORD_EOF_CODIGO != 'COL' THEN
        P_RESPUESTA := 'Orden :'|| P_ORD_SUC_CODIGO||'-'||P_ORD_CONSECUTIVO||' en estado invalido para registrar en Setfx';
     ELSE
        IF NVL(V_REG_ORD.ORD_USUARIO_REG_SETFX,' ') != ' ' THEN
           P_RESPUESTA := 'Orden :'|| P_ORD_SUC_CODIGO||'-'||P_ORD_CONSECUTIVO||' ya registrada en Setfx';
        END IF;
     END IF;
  END LOOP;   
  CLOSE  V_CURSOR; 

  IF NVL(V_REG_ORD.ORD_EOF_CODIGO,' ') = ' ' THEN
     P_RESPUESTA := 'Orden :'|| P_ORD_SUC_CODIGO||'-'||P_ORD_CONSECUTIVO||' no registrada en el sistema';
  END IF;

END PR_ESTADO_ORDEN_DIV_SETFX;

PROCEDURE PR_ANULAR_ORDEN_DIVISAS_CON(P_SUC_CODIGO           ORDENES_DIVISAS.ORD_SUC_CODIGO%TYPE,
                                     P_CONSECUTIVO          ORDENES_DIVISAS.ORD_CONSECUTIVO%TYPE,
                                     P_ORD_ORD_CONSECUTIVO  ORDENES_DIVISAS.ORD_ORD_CONSECUTIVO%TYPE) IS 

 CURSOR ORDEN(P_ORDEN NUMBER,P_SUC_CODIGO NUMBER) IS
    SELECT *
    FROM ORDENES_DIVISAS
    WHERE ORD_CONSECUTIVO  = P_ORDEN
     AND ORD_SUC_CODIGO    = P_SUC_CODIGO
     AND ORD_EOF_CODIGO    = 'COL';

   CURSOR FACTURA(P_ORDEN NUMBER,P_SUC_CODIGO NUMBER) IS
      SELECT *
      FROM   FACTURAS_DIVISAS
      WHERE  FAD_ORD_CONSECUTIVO = P_ORDEN
        AND  FAD_ORD_SUC_CODIGO  = P_SUC_CODIGO
        AND  NVL(FAD_ANULADO,'N') = 'N';

   CURSOR ORDEN_ODP(P_ORDEN NUMBER,P_SUC_CODIGO NUMBER) IS
      SELECT ODP_SUC_CODIGO
            ,ODP_CONSECUTIVO
            ,ODP_ESTADO
            ,ODP_MONTO_ORDEN
            ,ODP_ORD_SUC_CODIGO
            ,ODP_ORD_CONSECUTIVO
            ,ODP_TBC_CONSECUTIVO
            ,ODP_TCC_CONSECUTIVO
            ,ODP_CEG_CONSECUTIVO
            ,ODP_CGE_CONSECUTIVO
      FROM   ORDENES_DE_PAGO
      WHERE  ODP_ORD_CONSECUTIVO = P_ORDEN
       AND   ODP_ORD_SUC_CODIGO = P_SUC_CODIGO;


   CURSOR OP_REGISTRADA(P_OME OPERACION_DIVISAS_ENTRE_MESAS.OME_CONSECUTIVO%TYPE) IS
     SELECT 'S'
     FROM OPERACION_DIVISAS_ENTRE_MESAS
     WHERE OME_CONSECUTIVO = P_OME
     AND   OME_ESTADO = 'REG';

   CURSOR OPE(P_ORDEN NUMBER,P_SUC_CODIGO NUMBER) IS
      SELECT OPE_CONSECUTIVO
            ,OPE_ESTADO
            ,OPE_VALOR_DOLARES
            ,OPE_VALOR_GASTOS
            ,OPE_ORD_SUC_CODIGO
            ,OPE_ORD_CONSECUTIVO
      FROM   ORDENES_PAGOS_EXTERIOR
      WHERE  OPE_ORD_CONSECUTIVO = P_ORDEN
      AND    OPE_ORD_SUC_CODIGO = P_SUC_CODIGO;


  C_ORDEN            ORDEN%ROWTYPE;
  C_FACTURA          FACTURA%ROWTYPE;
  C_ORDEN_ODP        ORDEN_ODP%ROWTYPE;
  C_OP_REGISTRADA    OP_REGISTRADA%ROWTYPE;
  C_OPE              OPE%ROWTYPE;
  V_EXISTE_ORDEN_ODP NUMBER(5);
  V_EXISTE_ORDEN_OPE NUMBER(5);
  V_EXISTE_OP        VARCHAR2(1) := 'N';
BEGIN
    OPEN ORDEN(P_ORDEN =>P_CONSECUTIVO ,P_SUC_CODIGO =>P_SUC_CODIGO );
    FETCH ORDEN INTO C_ORDEN;
    IF ORDEN%NOTFOUND THEN
      RAISE_APPLICATION_ERROR(-20001, 'Orden divisas no existe :'||P_CONSECUTIVO);
    ELSE
      IF C_ORDEN.ORD_EOF_CODIGO != 'COL' THEN
        RAISE_APPLICATION_ERROR(-20002,'Orden divisas en estado invalido para anular:'||C_ORDEN.ORD_CONSECUTIVO);
      END IF;

      OPEN FACTURA(P_ORDEN =>C_ORDEN.ORD_CONSECUTIVO ,P_SUC_CODIGO =>C_ORDEN.ORD_SUC_CODIGO ) ;
      FETCH FACTURA INTO C_FACTURA;
      IF FACTURA%FOUND THEN
        RAISE_APPLICATION_ERROR(-20002,'La Orden de Divisas Posee Facturas Asociadas .. Deben Anularse primero');
      END IF;
      CLOSE FACTURA;

      IF C_ORDEN.ORD_ORIGEN_OPERACION NOT IN ('P','M','R') THEN
        V_EXISTE_ORDEN_ODP := 0;
        OPEN ORDEN_ODP(P_ORDEN =>C_ORDEN.ORD_CONSECUTIVO ,P_SUC_CODIGO =>C_ORDEN.ORD_SUC_CODIGO );
        FETCH ORDEN_ODP INTO C_ORDEN_ODP;
        WHILE ORDEN_ODP%FOUND LOOP
          IF C_ORDEN_ODP.ODP_TBC_CONSECUTIVO IS NOT NULL OR
             C_ORDEN_ODP.ODP_TCC_CONSECUTIVO IS NOT NULL OR
             C_ORDEN_ODP.ODP_CEG_CONSECUTIVO IS NOT NULL OR
             C_ORDEN_ODP.ODP_CGE_CONSECUTIVO IS NOT NULL THEN
            V_EXISTE_ORDEN_ODP := V_EXISTE_ORDEN_ODP+1;
          END IF;
          FETCH ORDEN_ODP INTO C_ORDEN_ODP;
        END LOOP;
        CLOSE ORDEN_ODP;
        IF V_EXISTE_ORDEN_ODP > 0 THEN
          RAISE_APPLICATION_ERROR(-20003,'La Orden de Divisas ya ha sido ejecutada ... Comuniquese con tesoreria');
        END IF;
      END IF;

      IF C_ORDEN.ORD_ORIGEN_OPERACION = 'M'  AND C_ORDEN.ORD_OME_CONSECUTIVO IS NOT NULL THEN
        OPEN OP_REGISTRADA(C_ORDEN.ORD_OME_CONSECUTIVO);
        FETCH OP_REGISTRADA INTO V_EXISTE_OP;
        CLOSE OP_REGISTRADA;

        IF NVL(V_EXISTE_OP, 'N') != 'S' THEN
          RAISE_APPLICATION_ERROR(-20004,'No se encontró en estado Registrado la operación entre mesas número '||C_ORDEN.ORD_OME_CONSECUTIVO||
                            ' correspondiente a la orden divisas:'||C_ORDEN.ORD_CONSECUTIVO);
        END IF;
      END IF;
    END IF;
    CLOSE ORDEN;

    -- VALIDA ORDENES DE PAGO EXTERIOR
    V_EXISTE_ORDEN_OPE := 0;
    OPEN OPE(P_ORDEN =>C_ORDEN.ORD_CONSECUTIVO,P_SUC_CODIGO =>C_ORDEN.ORD_SUC_CODIGO );
    FETCH OPE INTO C_OPE;
    WHILE OPE%FOUND LOOP
      IF C_OPE.OPE_ESTADO = 'APL' THEN
        V_EXISTE_ORDEN_OPE := V_EXISTE_ORDEN_OPE+1;
        EXIT;
      END IF;
      FETCH OPE INTO C_OPE;
    END LOOP;
    CLOSE OPE;

    IF V_EXISTE_ORDEN_OPE > 0 THEN
      RAISE_APPLICATION_ERROR(-20005,'Existen Ordenes de Pago en el exterior ya ejecutadas, se deben reversar');
    END IF;

    -- TENER EN CUENTA ANULACION DE ORDENES ENTRE MESAS
    ---ANULAR ORDENES DE PAGO

    IF C_ORDEN.ORD_TIPO_ORDEN  = 'C' THEN
       BEGIN
            UPDATE ORDENES_DE_PAGO
              SET ODP_ESTADO = 'ANU'
                 ,ODP_ANULADA_POR = USER
                 ,ODP_FECHA_ANULACION = SYSDATE
                 ,ODP_RAZON_ANULACION = 'Consolidacion Orden Divisas'
            WHERE ODP_ORD_SUC_CODIGO = C_ORDEN.ORD_SUC_CODIGO
              AND ODP_ORD_CONSECUTIVO = C_ORDEN.ORD_CONSECUTIVO;
       END;
    END IF;

    IF  C_ORDEN.ORD_TIPO_ORDEN  = 'V' THEN
       BEGIN
            UPDATE ORDENES_RECAUDO
              SET    ORR_ESTADO = 'ANU'
            WHERE  ORR_ORD_SUC_CODIGO = C_ORDEN.ORD_SUC_CODIGO
              AND    ORR_ORD_CONSECUTIVO = C_ORDEN.ORD_CONSECUTIVO;
       END;
    END IF;

    IF  C_ORDEN.ORD_ORIGEN_OPERACION = 'M' THEN
        BEGIN
          UPDATE OPERACION_DIVISAS_ENTRE_MESAS
            SET OME_ESTADO = 'ANU'
          WHERE OME_CONSECUTIVO = C_ORDEN.ORD_OME_CONSECUTIVO;
        END;
      END IF;

      IF C_ORDEN.ORD_ORIGEN_OPERACION NOT IN ('P','M') THEN
        BEGIN
          UPDATE ORDENES_PAGOS_EXTERIOR
          SET OPE_ESTADO = 'ANU',
             OPE_ANULADA_POR = USER,
             OPE_FECHA_ANULACION = SYSDATE,
             OPE_TERMINAL_ANULACION = FN_TERMINAL
          WHERE OPE_ORD_SUC_CODIGO = C_ORDEN.ORD_SUC_CODIGO
            AND OPE_ORD_CONSECUTIVO = C_ORDEN.ORD_CONSECUTIVO
            AND OPE_ESTADO = 'COL';
        END;
    END IF;

    BEGIN
        UPDATE ORDENES_DIVISAS
          SET ORD_FECHA_ANULACION          = SYSDATE,
              ORD_ANULADA_POR              = USER,
              ORD_EOF_CODIGO               = 'ANU',
              ORD_FECHA_CONSOLIDACION      = SYSDATE,
              ORD_TERMINAL_CONSOLIDACION   = FN_TERMINAL,
              ORD_USUARIO_CONSOLIDACION    = USER,
              ORD_ORD_SUC_CODIGO           = C_ORDEN.ORD_SUC_CODIGO,
              ORD_ORD_CONSECUTIVO          = P_ORD_ORD_CONSECUTIVO
        WHERE ORD_SUC_CODIGO = C_ORDEN.ORD_SUC_CODIGO
          AND ORD_CONSECUTIVO = C_ORDEN.ORD_CONSECUTIVO;
        IF SQL%ROWCOUNT = 0 THEN
          RAISE_APPLICATION_ERROR(-20006,'Orden de divisas:'||P_SUC_CODIGO||'-'||P_CONSECUTIVO ||' no existe .. no es posible anularla') ;
        END IF;
    END;


    EXCEPTION
      WHEN OTHERS THEN
          RAISE_APPLICATION_ERROR(-20060,'Error en procedimiento P_ANULAR_ORDEN_DIVISAS (2) : '||sqlerrm);

END PR_ANULAR_ORDEN_DIVISAS_CON;


PROCEDURE PR_CONSOLIDA_ORDENES(P_ORD_CONSOLIDAR           IN  T_ORDENES_CON,
                               P_VALOR_DOLARES_FX         OUT ORDENES_DIVISAS.ORD_VALOR_FX%TYPE,
                               P_VALOR_DOLARES            OUT ORDENES_DIVISAS.ORD_VALOR_DOLARES%TYPE, 
                               P_VALOR_PESOS              OUT ORDENES_DIVISAS.ORD_VALOR_PESOS%TYPE,
                               P_VALOR_PESOS_MESA         OUT ORDENES_DIVISAS.ORD_VALOR_PESOS%TYPE,
                               P_TASA_CAMBIO              OUT ORDENES_DIVISAS.ORD_TASA_CAMBIO%TYPE,
                               P_TASA_CAMBIO_MESA         OUT ORDENES_DIVISAS.ORD_TASA_NEG_MESA%TYPE,
                               P_ORD_TIPO_CAMBIO          OUT ORDENES_DIVISAS.ORD_TIPO_CAMBIO%TYPE) IS 

   CURSOR ORD_DIV(P_ORD_CONSECUTIVO NUMBER,
                  P_ORD_SUC_CODIGO NUMBER) IS
      SELECT ORD_CONSECUTIVO
            ,ORD_SUC_CODIGO
            ,ORD_BMO_MNEMONICO
            ,ORD_EOF_CODIGO
            ,ORD_CLI_PER_NUM_IDEN
            ,ORD_CLI_PER_TID_CODIGO
            ,ORD_TMD_MNEMONICO
            ,ORD_TIPO_ORDEN
            ,ORD_TIPO_MERCADO
            ,ORD_VALOR_DOLARES
            ,ORD_VALOR_PESOS
            ,ORD_COLOCADO_POR
            ,ORD_FECHA_COLOCACION
            ,ORD_TASA_CAMBIO
            ,ORD_TASA_NETA
            ,ORD_VALOR_PESOS_NETOS
            ,ORD_CCC_NUMERO_CUENTA
            ,ORD_PER_NUM_IDEN
            ,ORD_PER_TID_CODIGO
            ,ORD_EXCENTO_RETENCION
            ,ORD_ORIGEN_OPERACION
            ,ORD_POSICION_PROPIA
            ,ORD_CONTRATO_COMISION
            ,ORD_TIPO_CAMBIO
            ,ORD_VALOR_IVA_VENTA
            ,ORD_VALOR_COMISION
            ,ORD_VALOR_IVA_COMISIONES
            ,ORD_VALOR_RETEFUENTE
            ,ORD_OPERACION_TODO_COSTO
            ,ORD_APROBADO_POR
            ,ORD_FECHA_APROBACION
            ,ORD_ANULADA_POR
            ,ORD_FECHA_ANULACION
            ,ORD_TASA_CONVERSION
            ,ORD_AUTORIZACION
            ,ORD_AUTORIZADOR
            ,ORD_VALOR_FX
            ,ORD_BMO_MNEMONICO_FX
            ,ORD_VALOR_IVA_DESCONTABLE
            ,ORD_CARGO_ABONO_CUENTA
            ,ORD_GENERADO_FACTURA
            ,ORD_MONTO_CARGO_ABONO_CUENTA
            ,ORD_CBE_NUMERO_CUENTA
            ,ORD_CBE_BEX_MNEMONICO
            ,ORD_FECHA_REVERSION
            ,ORD_REVERSADO_POR
            ,ORD_MOTIVO_REVERSION
            ,ORD_MARGEN_COMISION
            ,ORD_UTILIDAD_COMERCIAL
            ,ORD_PORCENTAJE_COMERCIAL
            ,ORD_PORCENTAJE_MESA
            ,ORD_OCR_CONSECUTIVO
            ,ORD_OCR_SUC_CODIGO
            ,ORD_CONTROL_TRANSFERENCIA
            ,ORD_NUMERO_GIROS
            ,ORD_TOTAL_GIROS
            ,ORD_OTROS_GASTOS
            ,ORD_GASTOS_GIRO
            ,ORD_COMISION_COMERCIAL
            ,ORD_IMPUESTO_IBC
            ,ORD_IMPUESTO_IBA
            ,ORD_CBX_NUMERO_CUENTA
            ,ORD_CBX_BEX_MNEMONICO
            ,ORD_DPD_PYC_TLO_CODIGO
            ,ORD_DPD_PYC_FECHA
            ,ORD_DPD_CONSECUTIVO
            ,ORD_DPC_PYD_FECHA
            ,ORD_DPC_CONSECUTIVO
            ,ORD_DPC_PYD_CFC_FUG_ISI_MNEMON
            ,ORD_DPC_PYD_CFC_FUG_MNEMONICO
            ,ORD_DPC_PYD_CFC_CUENTA_DECEVAL
            ,ORD_DPO_CONSECUTIVO
            ,ORD_DPO_PCO_FECHA
            ,ORD_DPO_PCO_OCR_CONSECUTIVO
            ,ORD_DPO_PCO_OCR_SUC_CODIGO
            ,ORD_VALOR_DOLARES_NETOS
            ,ORD_DESTINO_TRASLADO
            ,ORD_REMISION_TRASLADO
            ,ORD_FECHA_VERIFICA
            ,ORD_TERMINAL_VERIFICA
            ,ORD_PER_NUM_IDEN_ES_DUENO
            ,ORD_PER_TID_CODIGO_ES_DUENO
            ,ORD_VERIFICADO_COMERCIAL
            ,ORD_NEGOCIACION_PESOS
            ,ORD_NOMBRE_REMITE_BENEFICIARIO
            ,ORD_NUM_IDEN_REMITE_BENEF
            ,ORD_TID_CODIGO_REMITE_BENEF
            ,ORD_CIUDAD_ORIGEN_DESTINO
            ,ORD_PAI_CODIGO
            ,ORD_BENEFICIARIO_CHEQUE_TRASL
            ,ORD_INSTRUCCIONES_TRASLADO
            ,ORD_INDICADOR_RESTRINGIDO
            ,ORD_FECHA_CUMPLIMIENTO
            ,ORD_DIAS_NEXT_DAY
            ,ORD_MEDIO_RECEPCION
            ,ORD_DETALLE_MEDIO_RECEPCION
            ,ORD_HORA_RECEPCION
            ,ORD_PROFESIONAL
            ,ORD_RADICACION_PROFESIONAL
            ,ORD_SALDO_X_COMPLEMENTAR
            ,ORD_OME_CONSECUTIVO
            ,ORD_CARGO_CTA_COMPENSACION
            ,ORD_CARGO_INV_EXTERIOR
            ,ORD_IDCODIVISAS
            ,ORD_TASA_NEG_MESA
            ,ORD_UTILIDAD_MESA
            ,ORD_UTILIDAD_TOTAL
            ,ORD_OPERACION_SETFX
            ,ORD_USUARIO_REG_SETFX
            ,ORD_TERMINAL_REG_SETFX
            ,ORD_FECHA_REG_SETFX
            ,ORD_FECHA_CONSOLIDACION
            ,ORD_TERMINAL_CONSOLIDACION
            ,ORD_USUARIO_CONSOLIDACION
            ,ORD_ORD_SUC_CODIGO
            ,ORD_ORD_CONSECUTIVO
         FROM ORDENES_DIVISAS
         WHERE ORD_CONSECUTIVO = P_ORD_CONSECUTIVO
           AND ORD_SUC_CODIGO  = P_ORD_SUC_CODIGO;

   V_REG_DIVISAS            ORDENES_DIVISAS%ROWTYPE;      
   V_MENSAJE_ERROR          VARCHAR2(200);

   ERROR EXCEPTION;

BEGIN
   IF P_ORD_CONSOLIDAR.COUNT() > 1 THEN  
      P_VALOR_DOLARES_FX         := 0;
      P_VALOR_DOLARES            := 0;
      P_VALOR_PESOS              := 0;
      P_VALOR_PESOS_MESA         := 0;
      P_TASA_CAMBIO              := 0;
      P_TASA_CAMBIO_MESA         := 0;
      P_ORD_TIPO_CAMBIO          := 0;

      FOR REG IN P_ORD_CONSOLIDAR.FIRST .. P_ORD_CONSOLIDAR.LAST LOOP
         -- VALIDAR QUE LA ORDEN NO ESTE YA CONSOLIDADA.
         V_REG_DIVISAS          := NULL;
         OPEN ORD_DIV( P_ORD_CONSECUTIVO => P_ORD_CONSOLIDAR(REG).ORD_CONSECUTIVO,
                       P_ORD_SUC_CODIGO  => P_ORD_CONSOLIDAR(REG).ORD_SUC_CODIGO);
         FETCH ORD_DIV INTO V_REG_DIVISAS.ORD_CONSECUTIVO
                           ,V_REG_DIVISAS.ORD_SUC_CODIGO
                           ,V_REG_DIVISAS.ORD_BMO_MNEMONICO
                           ,V_REG_DIVISAS.ORD_EOF_CODIGO
                           ,V_REG_DIVISAS.ORD_CLI_PER_NUM_IDEN
                           ,V_REG_DIVISAS.ORD_CLI_PER_TID_CODIGO
                           ,V_REG_DIVISAS.ORD_TMD_MNEMONICO
                           ,V_REG_DIVISAS.ORD_TIPO_ORDEN
                           ,V_REG_DIVISAS.ORD_TIPO_MERCADO
                           ,V_REG_DIVISAS.ORD_VALOR_DOLARES
                           ,V_REG_DIVISAS.ORD_VALOR_PESOS
                           ,V_REG_DIVISAS.ORD_COLOCADO_POR
                           ,V_REG_DIVISAS.ORD_FECHA_COLOCACION
                           ,V_REG_DIVISAS.ORD_TASA_CAMBIO
                           ,V_REG_DIVISAS.ORD_TASA_NETA
                           ,V_REG_DIVISAS.ORD_VALOR_PESOS_NETOS
                           ,V_REG_DIVISAS.ORD_CCC_NUMERO_CUENTA
                           ,V_REG_DIVISAS.ORD_PER_NUM_IDEN
                           ,V_REG_DIVISAS.ORD_PER_TID_CODIGO
                           ,V_REG_DIVISAS.ORD_EXCENTO_RETENCION
                           ,V_REG_DIVISAS.ORD_ORIGEN_OPERACION
                           ,V_REG_DIVISAS.ORD_POSICION_PROPIA
                           ,V_REG_DIVISAS.ORD_CONTRATO_COMISION
                           ,V_REG_DIVISAS.ORD_TIPO_CAMBIO
                           ,V_REG_DIVISAS.ORD_VALOR_IVA_VENTA
                           ,V_REG_DIVISAS.ORD_VALOR_COMISION
                           ,V_REG_DIVISAS.ORD_VALOR_IVA_COMISIONES
                           ,V_REG_DIVISAS.ORD_VALOR_RETEFUENTE
                           ,V_REG_DIVISAS.ORD_OPERACION_TODO_COSTO
                           ,V_REG_DIVISAS.ORD_APROBADO_POR
                           ,V_REG_DIVISAS.ORD_FECHA_APROBACION
                           ,V_REG_DIVISAS.ORD_ANULADA_POR
                           ,V_REG_DIVISAS.ORD_FECHA_ANULACION
                           ,V_REG_DIVISAS.ORD_TASA_CONVERSION
                           ,V_REG_DIVISAS.ORD_AUTORIZACION
                           ,V_REG_DIVISAS.ORD_AUTORIZADOR
                           ,V_REG_DIVISAS.ORD_VALOR_FX
                           ,V_REG_DIVISAS.ORD_BMO_MNEMONICO_FX
                           ,V_REG_DIVISAS.ORD_VALOR_IVA_DESCONTABLE
                           ,V_REG_DIVISAS.ORD_CARGO_ABONO_CUENTA
                           ,V_REG_DIVISAS.ORD_GENERADO_FACTURA
                           ,V_REG_DIVISAS.ORD_MONTO_CARGO_ABONO_CUENTA
                           ,V_REG_DIVISAS.ORD_CBE_NUMERO_CUENTA
                           ,V_REG_DIVISAS.ORD_CBE_BEX_MNEMONICO
                           ,V_REG_DIVISAS.ORD_FECHA_REVERSION
                           ,V_REG_DIVISAS.ORD_REVERSADO_POR
                           ,V_REG_DIVISAS.ORD_MOTIVO_REVERSION
                           ,V_REG_DIVISAS.ORD_MARGEN_COMISION
                           ,V_REG_DIVISAS.ORD_UTILIDAD_COMERCIAL
                           ,V_REG_DIVISAS.ORD_PORCENTAJE_COMERCIAL
                           ,V_REG_DIVISAS.ORD_PORCENTAJE_MESA
                           ,V_REG_DIVISAS.ORD_OCR_CONSECUTIVO
                           ,V_REG_DIVISAS.ORD_OCR_SUC_CODIGO
                           ,V_REG_DIVISAS.ORD_CONTROL_TRANSFERENCIA
                           ,V_REG_DIVISAS.ORD_NUMERO_GIROS
                           ,V_REG_DIVISAS.ORD_TOTAL_GIROS
                           ,V_REG_DIVISAS.ORD_OTROS_GASTOS
                           ,V_REG_DIVISAS.ORD_GASTOS_GIRO
                           ,V_REG_DIVISAS.ORD_COMISION_COMERCIAL
                           ,V_REG_DIVISAS.ORD_IMPUESTO_IBC
                           ,V_REG_DIVISAS.ORD_IMPUESTO_IBA
                           ,V_REG_DIVISAS.ORD_CBX_NUMERO_CUENTA
                           ,V_REG_DIVISAS.ORD_CBX_BEX_MNEMONICO
                           ,V_REG_DIVISAS.ORD_DPD_PYC_TLO_CODIGO
                           ,V_REG_DIVISAS.ORD_DPD_PYC_FECHA
                           ,V_REG_DIVISAS.ORD_DPD_CONSECUTIVO
                           ,V_REG_DIVISAS.ORD_DPC_PYD_FECHA
                           ,V_REG_DIVISAS.ORD_DPC_CONSECUTIVO
                           ,V_REG_DIVISAS.ORD_DPC_PYD_CFC_FUG_ISI_MNEMON
                           ,V_REG_DIVISAS.ORD_DPC_PYD_CFC_FUG_MNEMONICO
                           ,V_REG_DIVISAS.ORD_DPC_PYD_CFC_CUENTA_DECEVAL
                           ,V_REG_DIVISAS.ORD_DPO_CONSECUTIVO
                           ,V_REG_DIVISAS.ORD_DPO_PCO_FECHA
                           ,V_REG_DIVISAS.ORD_DPO_PCO_OCR_CONSECUTIVO
                           ,V_REG_DIVISAS.ORD_DPO_PCO_OCR_SUC_CODIGO
                           ,V_REG_DIVISAS.ORD_VALOR_DOLARES_NETOS
                           ,V_REG_DIVISAS.ORD_DESTINO_TRASLADO
                           ,V_REG_DIVISAS.ORD_REMISION_TRASLADO
                           ,V_REG_DIVISAS.ORD_FECHA_VERIFICA
                           ,V_REG_DIVISAS.ORD_TERMINAL_VERIFICA
                           ,V_REG_DIVISAS.ORD_PER_NUM_IDEN_ES_DUENO
                           ,V_REG_DIVISAS.ORD_PER_TID_CODIGO_ES_DUENO
                           ,V_REG_DIVISAS.ORD_VERIFICADO_COMERCIAL
                           ,V_REG_DIVISAS.ORD_NEGOCIACION_PESOS
                           ,V_REG_DIVISAS.ORD_NOMBRE_REMITE_BENEFICIARIO
                           ,V_REG_DIVISAS.ORD_NUM_IDEN_REMITE_BENEF
                           ,V_REG_DIVISAS.ORD_TID_CODIGO_REMITE_BENEF
                           ,V_REG_DIVISAS.ORD_CIUDAD_ORIGEN_DESTINO
                           ,V_REG_DIVISAS.ORD_PAI_CODIGO
                           ,V_REG_DIVISAS.ORD_BENEFICIARIO_CHEQUE_TRASL
                           ,V_REG_DIVISAS.ORD_INSTRUCCIONES_TRASLADO
                           ,V_REG_DIVISAS.ORD_INDICADOR_RESTRINGIDO
                           ,V_REG_DIVISAS.ORD_FECHA_CUMPLIMIENTO
                           ,V_REG_DIVISAS.ORD_DIAS_NEXT_DAY
                           ,V_REG_DIVISAS.ORD_MEDIO_RECEPCION
                           ,V_REG_DIVISAS.ORD_DETALLE_MEDIO_RECEPCION
                           ,V_REG_DIVISAS.ORD_HORA_RECEPCION
                           ,V_REG_DIVISAS.ORD_PROFESIONAL
                           ,V_REG_DIVISAS.ORD_RADICACION_PROFESIONAL
                           ,V_REG_DIVISAS.ORD_SALDO_X_COMPLEMENTAR
                           ,V_REG_DIVISAS.ORD_OME_CONSECUTIVO
                           ,V_REG_DIVISAS.ORD_CARGO_CTA_COMPENSACION
                           ,V_REG_DIVISAS.ORD_CARGO_INV_EXTERIOR
                           ,V_REG_DIVISAS.ORD_IDCODIVISAS
                           ,V_REG_DIVISAS.ORD_TASA_NEG_MESA
                           ,V_REG_DIVISAS.ORD_UTILIDAD_MESA
                           ,V_REG_DIVISAS.ORD_UTILIDAD_TOTAL
                           ,V_REG_DIVISAS.ORD_OPERACION_SETFX
                           ,V_REG_DIVISAS.ORD_USUARIO_REG_SETFX
                           ,V_REG_DIVISAS.ORD_TERMINAL_REG_SETFX
                           ,V_REG_DIVISAS.ORD_FECHA_REG_SETFX
                           ,V_REG_DIVISAS.ORD_FECHA_CONSOLIDACION
                           ,V_REG_DIVISAS.ORD_TERMINAL_CONSOLIDACION
                           ,V_REG_DIVISAS.ORD_USUARIO_CONSOLIDACION
                           ,V_REG_DIVISAS.ORD_ORD_SUC_CODIGO
                           ,V_REG_DIVISAS.ORD_ORD_CONSECUTIVO;
         IF  ORD_DIV%NOTFOUND THEN
            V_MENSAJE_ERROR := 'Orden no existe para consolidar';
            CLOSE ORD_DIV;
            RAISE ERROR;
         ELSE
            IF V_REG_DIVISAS.ORD_EOF_CODIGO != 'COL' THEN
               V_MENSAJE_ERROR := 'Orden en estado invalido para consolidar';
               CLOSE ORD_DIV;
               RAISE ERROR;
            END IF;

            IF V_REG_DIVISAS.ORD_ORD_CONSECUTIVO != 0  THEN
               V_MENSAJE_ERROR := 'Orden ya consolidada';
               CLOSE ORD_DIV;
               RAISE ERROR;
            END IF;   
         END IF;    
         CLOSE ORD_DIV;

         P_VALOR_DOLARES_FX  := P_VALOR_DOLARES_FX+ V_REG_DIVISAS.ORD_VALOR_FX;
         P_VALOR_DOLARES     := P_VALOR_DOLARES + V_REG_DIVISAS.ORD_VALOR_DOLARES;
         P_VALOR_PESOS       := P_VALOR_PESOS   + V_REG_DIVISAS.ORD_VALOR_PESOS;
         P_VALOR_PESOS_MESA  := P_VALOR_PESOS_MESA + (V_REG_DIVISAS.ORD_VALOR_DOLARES*V_REG_DIVISAS.ORD_TASA_NEG_MESA);

      END LOOP;
      P_TASA_CAMBIO      := P_VALOR_PESOS/ P_VALOR_DOLARES;
      P_TASA_CAMBIO_MESA := P_VALOR_PESOS_MESA/ P_VALOR_DOLARES;      

      IF V_REG_DIVISAS.ORD_TIPO_ORDEN = 'V' THEN 
         IF V_REG_DIVISAS.ORD_BMO_MNEMONICO_FX IS NOT NULL THEN
            P_ORD_TIPO_CAMBIO := P_VALOR_DOLARES_FX / P_VALOR_DOLARES  ;            
         ELSE
            P_ORD_TIPO_CAMBIO := NULL;
         END IF;
      END IF;
   ELSE
     V_MENSAJE_ERROR := 'Para consolidar ordenes se debe elegir mas de una orden';
     RAISE ERROR;   
   END IF;
EXCEPTION
   WHEN ERROR THEN
     RAISE_APPLICATION_ERROR(-20010,V_MENSAJE_ERROR);  
   WHEN OTHERS THEN
      RAISE_APPLICATION_ERROR(-20040,SQLERRM || 'Error recalculando saldo de clientes en divisas');  


END PR_CONSOLIDA_ORDENES;


PROCEDURE PR_ENVIO_MAIL_CAUSACION IS
    CONN                    UTL_SMTP.CONNECTION;
    REQ                     UTL_HTTP.REQ;  
    RESP                    UTL_HTTP.RESP;
    DATA                    RAW(200);
    V_NOMBRE_MAIL           VARCHAR2(200);
    TEXTO_CUERPO            VARCHAR2(4000);
    V_ARCHIVO_DETALLE       VARCHAR2(500);
    CONT                    NUMBER(3);

BEGIN 
   SELECT COUNT(*) CONT
   INTO CONT
   FROM   NEGOCIOS_INTERNACIONALES
   WHERE  NIN_CAUSACION IS NOT NULL 
   AND NIN_NUM_FACTURA IS NULL;

   V_NOMBRE_MAIL := 'jmaldonado@corredores.com;crojas@corredores.com;jlrodriguez@corredores.com;jsanchezm@corredores.com;conciliacionesbancarias@corredores.com;posicionpropia@corredores.com';
   TEXTO_CUERPO := 'Existen '|| CONT || '  partidas pendientes por facturar  '||CHR(13)||
                    TO_CHAR(SYSDATE,'DD/MM/YYYY HH24:MI:SS');
   CONN := P_MAIL.BEGIN_MAIL(
   SENDER     =>  'administrador@corredores.com',
   RECIPIENTS => V_NOMBRE_MAIL,
   SUBJECT    => 'PARTIDAS PENDIENTES POR FACTURAR - MODULO NEGOCIOS INTERNACIONALES - CUCOME',
   MIME_TYPE  => P_MAIL.MULTIPART_MIME_TYPE);
   P_MAIL.ATTACH_TEXT(
                           CONN      => CONN,
                           DATA      => TEXTO_CUERPO,
                           MIME_TYPE => 'TEXT/HTML');
                           p_mail.end_mail( conn => conn );   

END PR_ENVIO_MAIL_CAUSACION;

PROCEDURE PR_ENVIO_MAIL_FACTURACION IS
    CONN                    UTL_SMTP.CONNECTION;
    REQ                     UTL_HTTP.REQ;  
    RESP                    UTL_HTTP.RESP;
    DATA                    RAW(200);
    V_NOMBRE_MAIL           VARCHAR2(200);
    TEXTO_CUERPO            VARCHAR2(4000);
    V_ARCHIVO_DETALLE       VARCHAR2(500);
    CONT                    NUMBER(3);

BEGIN 
     SELECT COUNT(*) CONT
     INTO  CONT
     FROM  NEGOCIOS_INTERNACIONALES
     WHERE NIN_NUM_FACTURA IS NOT NULL 
     AND   NIN_PAGO IS NULL;

   V_NOMBRE_MAIL := 'jmaldonado@corredores.com;crojas@corredores.com;jbeltran@corredores.com;jtaborda@corredores.com;ecanon@corredores.com;jlrodriguez@corredores.com';
   TEXTO_CUERPO := 'EXISTEN '|| CONT ||'  CUENTAS DE COBRO DE CORRESPONSALIAS FACTURADAS, POR FAVOR REVISAR '||CHR(13)||
                    TO_CHAR(SYSDATE,'DD/MM/YYYY HH24:MI:SS');  
   CONN := P_MAIL.BEGIN_MAIL(
   SENDER     =>  'administrador@corredores.com',
   RECIPIENTS => V_NOMBRE_MAIL,
   SUBJECT    => 'FACTURACION DE CORRESPONSALIAS GENERADA - MODULO NEGOCIOS INTERNACIONALES - CUCOME',
   MIME_TYPE  => P_MAIL.MULTIPART_MIME_TYPE);
   P_MAIL.ATTACH_TEXT(
                           CONN      => CONN,
                           DATA      => TEXTO_CUERPO,
                           MIME_TYPE => 'TEXT/HTML');
                           p_mail.end_mail( conn => conn );   

END PR_ENVIO_MAIL_FACTURACION;

