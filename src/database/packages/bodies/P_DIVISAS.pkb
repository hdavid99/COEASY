      P_MAIL.ENVIO_MAIL_ERROR('Error ejecutando P_DIVISAS.P_MAIL_EXCEL_230 ',V_MENSAJE_ERROR);
      RAISE_APPLICATION_ERROR(-20002,'Error ejecutando P_DIVISAS.P_MAIL_EXCEL_230 '||V_MENSAJE_ERROR);
    WHEN OTHERS THEN
      P_MAIL.ENVIO_MAIL_ERROR('Error ejecutando P_DIVISAS.P_MAIL_EXCEL_230 ',SQLERRM);
      RAISE_APPLICATION_ERROR(-20001,'Error ejecutando P_DIVISAS.P_MAIL_EXCEL_230 '||SQLERRM);
END P_MAIL_EXCEL_230;
