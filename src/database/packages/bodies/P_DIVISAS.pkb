                abs(nvl(V_DER_OPE_CONT, 0)) +
                abs(nvl(V_ACC_PORTAFOLIO, 0))+
                abs(nvl(V_ACC_PORTAFOLIO_LOCAL, 0));
      v_consecutivo := v_consecutivo + 1;
